        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
        <rdfs:comment xml:lang="en">A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">process-controlled flow process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
        <rdfs:comment xml:lang="en">A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
        <rdfs:comment xml:lang="en">A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
        <rdfs:comment xml:lang="en">A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement and transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:comment xml:lang="en">A bounded portion of matter in a fluid state (gaseous, liquid, or supercritical) that participates in an equipment-realizing process as input, output, or transformed substance.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a fluid state (gaseous, liquid, or supercritical) that participates in an equipment-realizing process as input, output, or transformed substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039"/>
        <rdfs:comment xml:lang="en">A portion of fluid in liquid phase.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of liquid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in liquid phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:comment xml:lang="en">A portion of fluid in gaseous phase.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of gas</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in gaseous phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000040 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:comment xml:lang="en">A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of solid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product).</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038"/>
        <rdfs:comment xml:lang="en">A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">absorbent phase</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000042 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000042">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041"/>
        <rdfs:comment xml:lang="en">An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rich absorbent</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000043 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000043">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:comment xml:lang="en">A fluid from which target components have been removed or transferred during a treatment process.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">depleted fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid from which target components have been removed or transferred during a treatment process.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000044 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000044">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:comment xml:lang="en">A fluid portion consisting of two or more components or phases that have not yet been fully separated.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">fluid mixture</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid portion consisting of two or more components or phases that have not yet been fully separated.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:comment xml:lang="en">An information content entity that conveys an instruction or set-point to a control device.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">control signal</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity that conveys an instruction or set-point to a control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:comment xml:lang="en">An information content entity perceptible through visual representation at the point of measurement or display.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">visual indication</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity perceptible through visual representation at the point of measurement or display.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a temperature quality of some material entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a temperature quality of some material entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a pressure quality of some material entity or fluid.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a pressure quality of some material entity or fluid.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a flow rate quality of a fluid stream.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a flow rate quality of a fluid stream.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000050 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000050">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a liquid level quality of a vessel or container.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a liquid level quality of a vessel or container.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000051 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000051">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing the chemical or phase composition quality of a substance.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing the chemical or phase composition quality of a substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a material entity that represents the intensity of thermal energy of that entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a material entity that represents the intensity of thermal energy of that entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow rate</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">vibration</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in an electrical system that represents the rate of electrical energy transfer.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">electrical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in an electrical system that represents the rate of electrical energy transfer.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000059 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000059">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">mechanical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:comment xml:lang="en">A quality inhering in a rotating element that represents the number of complete revolutions per unit time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rotational speed</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating element that represents the number of complete revolutions per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de bombeamento</rdfs:label>
        <rdfs:label xml:lang="en">pumping function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the transfer of mechanical energy to a fluid to increase its pressure, velocity, or both.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">compression function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de compressão</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the compression of a gas stream to increase its pressure for transport, injection, or processing.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transferência de calor</rdfs:label>
        <rdfs:label xml:lang="en">heat transfer function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a HeatTransferProcess and that consists in facilitating the transfer of thermal energy between two or more fluid media while maintaining their physical separation.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a HeatTransferProcess and that consists in facilitating the transfer of thermal energy between two or more fluid media while maintaining their physical separation.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de absorção de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas absorption function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the selective transfer of gaseous components from a gas phase into a liquid absorbent phase.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de sensoriamento de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the detection and measurement of the temperature of a process stream or equipment surface.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba</rdfs:label>
        <rdfs:label xml:lang="en">pump</rdfs:label>
        <skos:definition xml:lang="en">A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Pump(x) ↔ (Assembly(x) ∧ ∃f (PumpingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba é um conjunto que possui a função projetada de adicionar energia mecânica ao fluido para pressurização e transporte.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump is an assembly that has the function of pumping fluid</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">compressor</rdfs:label>
        <rdfs:label xml:lang="pt-br">compressor</rdfs:label>
        <skos:definition xml:lang="en">A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Compressor(x) ↔ Assembly(x) ∧ ∃f(CompressionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um compressor é um conjunto que possui a função projetada de comprimir gases através da adição de energia mecânica para aumentar sua pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every compressor is an assembly that bears a compression function and has component parts including a compressor casing, compression element, gas inlet, and gas outlet.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000074 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000074">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Shell"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubeBundle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">shell and tube heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor de casco e tubos</rdfs:label>
        <skos:definition xml:lang="en">A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">ShellAndTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃tb(TubeBundle(tb) ∧ hasComponentPartAtAllTimes(x,tb)) ∧ ∃s(Shell(s) ∧ hasComponentPartAtAllTimes(x,s) ∧ spatiallyContains(s,tb))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de casco e tubos é um trocador de calor que possui um feixe de tubos contido espacialmente dentro de um casco envolvente.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type to avoid false positives under OWA. Any equipment with a shell and tube bundle could theoretically be classified as a standard shell-and-tube heat exchanger, but specialized variants (like graphite shell-and-tube or custom multi-stream designs) should not be automatically forced into this maintenance category without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every shell and tube heat exchanger is a heat exchanger that has a tube bundle as component part and has a shell as component part, where the tube bundle is spatially contained within the shell.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula</rdfs:label>
        <skos:definition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Valve(x) ↔ MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula é um conjunto que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Might be too restrictive to define as sufficient being a material artifact and having a flow control function.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
        <rdfs:label xml:lang="en">valve body</rdfs:label>
        <skos:definition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ValveBody(x) → ValveComponent(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃y(WorkingComponent(y) ∧ houses(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um ValveComponent que porta uma ContainmentFunction e que serve como o principal componente de contenção de fluido e pressão de uma válvula, alojando e suportando os componentes de trabalho.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type - the structural characteristics of being the main pressure-containing housing component are necessary conditions but may not be sufficient under OWA, as various specialized valve body configurations exist that might contain additional components or have hybrid designs that could lead to false positive classifications.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve body is a valve component that contains and supports valve working components and bears the function of fluid and pressure containment.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000287"/>
        <rdfs:label xml:lang="pt-br">assento</rdfs:label>
        <rdfs:label xml:lang="en">seat</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Seat(x) → MaterialArtifact(x) ∧ ∃y(SealingSurface(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ValveClosingProcess(z) ∧ participatesIn(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui um componente de superfície de vedação e participa em processos de fechamento de válvulas, consistindo na parte da válvula contra a qual o elemento de fechamento se apoia para proporcionar vedação hermética.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions for &apos;seat&apos; based solely on structural properties could lead to false positives where other valve components with sealing surfaces are incorrectly classified as seats.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every Seat is a MaterialArtifact that has some sealing surface component at all times and participates in some valve closing process.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">filter</rdfs:label>
        <rdfs:label xml:lang="pt-br">filtro</rdfs:label>
        <skos:definition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Filter(x) ↔ (Separator(x) ∧ ∃f(FiltrationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilterElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃h(FilterHousing(h) ∧ hasComponentPartAtAllTimes(x,h))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um filtro é um separador que possui uma função de filtração para remover seletivamente constituintes indesejados de um fluxo de fluido usando um elemento filtrante dentro de um alojamento de filtro.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter is a separator that has a filtration function and has a filter element as component part and has a filter housing as component part</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116"/>
        <rdfs:label xml:lang="pt-br">MeasuringElement que possui uma FlowMeasurementFunction e</rdfs:label>
        <rdfs:label xml:lang="en">flow measuring element</rdfs:label>
        <skos:definition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeasuringElement(x) ↔ (MeasuringElement(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MeasuringElement que possui uma FlowMeasurementFunction e que é projetado para determinar e quantificar a taxa de fluxo de fluido através de um sistema.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every FlowMeasuringElement is a MeasuringElement that bears a FlowMeasurementFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma FlowModificationFunction e</rdfs:label>
        <rdfs:label xml:lang="en">flow modification accessory</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that bears a FlowModificationFunction and that is used as a component in flow control assemblies to alter the characteristics of fluid flow such as velocity profile, turbulence, or pressure distribution.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowModificationAccessory(x) ↔ (MaterialArtifact(x) ∧ ∃f(FlowModificationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a FlowModificationFunction and that is used as a component in flow control assemblies to alter the characteristics of fluid flow such as velocity profile, turbulence, or pressure distribution.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma FlowModificationFunction e que é usado como componente em conjuntos de controle de fluxo para alterar as características do fluxo de fluido, como perfil de velocidade, turbulência ou distribuição de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow modification accessory is a MaterialArtifact that bears a FlowModificationFunction and participates in processes that alter fluid flow characteristics.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:label xml:lang="pt-br">separador</rdfs:label>
        <rdfs:label xml:lang="en">separator</rdfs:label>
        <skos:definition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Separator(x) ↔ (Vessel(x) ∧ ∃f (SeparationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um separador é um vaso que possui uma FunçãoDeSeparação - projetado para separar diferentes substâncias ou fases de uma corrente fluida mista em correntes de saída distintas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every separator is a vessel that has the function of separating mixed fluid streams into distinct phases or components.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">sight glass</rdfs:label>
        <rdfs:label xml:lang="pt-br">visor</rdfs:label>
        <skos:definition xml:lang="en">An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SightGlass(x) ↔ Instrument(x) ∧ ∃f(VisualInspectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Instrumento que porta uma VisualInspectionFunction e que consiste em uma interface de visualização transparente que permite observação óptica direta de condições internas, propriedades de fluidos ou estados de processo dentro de recipientes, vasos ou sistemas de tubulação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every sight glass is an instrument that bears a visual inspection function and enables direct optical observation of process internals through a transparent viewing interface.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">transformador</rdfs:label>
        <rdfs:label xml:lang="en">transformer</rdfs:label>
        <skos:definition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Transformer(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(PrimaryWinding(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃s(SecondaryWinding(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(MagneticCore(c) ∧ hasComponentPartAtAllTimes(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transformador é um equipamento elétrico que transforma energia elétrica de um circuito para outro na mesma frequência através de indução eletromagnética usando enrolamentos e um núcleo magnético.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every transformer is an electrical equipment that bears an electrical power transformation function and has component parts including primary winding, secondary winding, and magnetic core.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">control valve</rdfs:label>
        <skos:definition xml:lang="en">A control valve is a valve that modulates flow rate in response to external control signals by means of an actuator-driven closure element.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A control valve is a valve that modulates flow rate in response to external control signals by means of an actuator-driven closure element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">definição teste</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000088 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000088">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">isolation valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de isolamento</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that bears a binary flow control function whose realization constitutes the complete opening or closing of a flow path to isolate a process segment in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000089 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000089">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
        <dcterms:source>Green &amp; Southard (eds.), Perry&apos;s Chemical Engineers&apos; Handbook, 9th ed. §11 (heat transfer).</dcterms:source>
        <dcterms:source>ODR-016 §A (HeatExchange leaf, Nível 2 Incremento 1a)</dcterms:source>
        <rdfs:comment xml:lang="en">A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de calor na qual energia térmica é trocada entre dois ou mais fluidos, tipicamente separados por uma superfície sólida de troca de calor, sem mistura dessas correntes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">heat exchange</rdfs:label>
        <rdfs:label xml:lang="pt-br">troca de calor</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#TemperatureChange"/>
        <annotation:adaptedFrom>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §11–12 (heat transfer without/with phase change).</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (HeatExchange(x) ↔ HeatTransfer(x) ∧ ∃f1,f2,f3,f4(hasInput(x,f1) ∧ Fluid(f1) ∧ hasInput(x,f2) ∧ Fluid(f2) ∧ f1≠f2 ∧ hasOutput(x,f3) ∧ Fluid(f3) ∧ hasOutput(x,f4) ∧ Fluid(f4) ∧ f3≠f4 ∧ derivesFrom(f3,f1) ∧ derivesFrom(f4,f2) ∧ ¬∃c3(hasConstituent(f3,c3) ∧ ¬∃c1(hasConstituent(f1,c1) ∧ sameSubstance(c1,c3))) ∧ ¬∃c4(hasConstituent(f4,c4) ∧ ¬∃c2(hasConstituent(f2,c2) ∧ sameSubstance(c2,c4)))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de calor na qual energia térmica é trocada entre dois ou mais fluidos, tipicamente separados por uma superfície sólida de troca de calor, sem mistura dessas correntes.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Although a full first-order definition is available, OWL 2 DL carries only the genus (HeatTransfer); the pair-wise input–output correspondence (derivesFrom linking each output to its source input) and the cross-stream composition conservation (no constituent transferred between streams) are FOL-only constructs that exceed OWL 2 DL expressivity.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o gênero (HeatTransfer); a correspondência par-a-par entrada–saída (derivesFrom ligando cada saída à sua entrada de origem) e a conservação de composição entre correntes (nenhum constituinte transferido entre as correntes) são construtos apenas-FOL que excedem a expressividade do OWL 2 DL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;heat exchange&apos; if and only if x is a &apos;heat transfer&apos; in which two distinct fluid inputs each give rise to a corresponding fluid output of identical composition, with no constituent transferred between streams</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;troca de calor&apos; se e somente se x é uma &apos;transferência de calor&apos; na qual dois fluidos de entrada distintos dão origem cada um a um fluido de saída correspondente de composição idêntica, sem transferência de constituinte entre as correntes</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>ODR-018</dcterms:source>
        <rdfs:comment xml:lang="en">A closed assembly designed to hold fluids at a pressure substantially different from ambient, with a shell rated to withstand the resulting mechanical stress.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um conjunto fechado projetado para conter fluidos a uma pressão substancialmente diferente da ambiente, com casco classificado para suportar a tensão mecânica resultante.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">pressure vessel</rdfs:label>
        <rdfs:label xml:lang="pt-br">vaso de pressão</rdfs:label>
        <skos:definition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</skos:definition>
        <annotation:firstOrderLogicAxiom>∀x (PressureVessel(x) → Assembly(x))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PressureVessel(x) ↔ (Vessel(x) ∧ ∃f (PressureContainmentFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A closed assembly designed to hold fluids at a pressure substantially different from ambient, with a shell rated to withstand the resulting mechanical stress.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um conjunto fechado projetado para conter fluidos a uma pressão substancialmente diferente da ambiente, com casco classificado para suportar a tensão mecânica resultante.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um vaso de pressão é um vaso que possui uma função de contenção sob pressão, projetado para suportar com segurança cargas de pressão internas e/ou externas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">A diferença estrutural de contenção de pressão (casco classificado, especificação de tensão mecânica) é expressa informalmente na NLD; OWL carrega apenas o gênero (Assembly). Axiomas estruturais são adiados ao Incremento 2b.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">The pressure-containing structural differentia (rated shell, mechanical stress specification) is expressed informally in the NLD; OWL carries only the genus (Assembly). Structural axioms are deferred to Incremento 2b.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure vessel is a vessel that has a pressure containment function, and every vessel with a pressure containment function is a pressure vessel.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;pressure vessel&apos; then x is an &apos;assembly&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;vaso de pressão&apos;, então x é um &apos;conjunto&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>ODR-018</dcterms:source>
        <rdfs:comment xml:lang="en">A material artifact designed to sense, measure, or indicate a physical quantity of a process stream or plant item.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material projetado para detectar, medir ou indicar uma grandeza física de uma corrente de processo ou item de planta.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">instrument</rdfs:label>
        <rdfs:label xml:lang="pt-br">instrumento</rdfs:label>
        <skos:definition xml:lang="en">An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables.</skos:definition>
        <annotation:firstOrderLogicAxiom>∀x (Instrument(x) → MaterialArtifact(x))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Instrument(x) ↔ (Assembly(x) ∧ ∃f(InstrumentationFunction(f) ∧ hasFunction(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact designed to sense, measure, or indicate a physical quantity of a process stream or plant item.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material projetado para detectar, medir ou indicar uma grandeza física de uma corrente de processo ou item de planta.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um instrumento é um artefato material que tem a função projetada de realizar medição, monitoramento ou controle de variáveis de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">A diferença estrutural de detecção-ou-medição é expressa informalmente na NLD; OWL carrega apenas o gênero (MaterialArtifact). O eixo estrutural (Instrument) é ortogonal ao eixo funcional (MeasurementInstrument); um artefato é ambos simultaneamente — intencional (ODR-018).</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">The sensing-or-measuring structural differentia is expressed informally in the NLD; OWL carries only the genus (MaterialArtifact). The structural axis (Instrument) is orthogonal to the functional axis (MeasurementInstrument); an artifact is both simultaneously — intended (ODR-018).</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every instrument is a material artifact that has an instrumentation function, and every material artifact that has an instrumentation function is an instrument.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is an &apos;instrument&apos; then x is a &apos;material artifact&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;instrumento&apos;, então x é um &apos;artefato material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>ODR-018, ODR-019</dcterms:source>
        <rdfs:comment xml:lang="en">A pressure vessel in which two fluid circuits are separated by a solid heat-transfer surface, so that thermal energy passes between them without the circuits mixing.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um vaso de pressão no qual dois circuitos de fluido são separados por uma superfície sólida de transferência de calor, de modo que energia térmica passa entre eles sem mistura dos circuitos.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor</rdfs:label>
        <skos:definition xml:lang="en">A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation.</skos:definition>
        <annotation:firstOrderLogicAxiom>∀x (HeatExchanger(x) → PressureVessel(x) ∧ ∃s(SolidHeatTransferSurface(s) ∧ hasComponentPartAtAllTimes(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (HeatExchanger(x) ↔ (Assembly(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure vessel in which two fluid circuits are separated by a solid heat-transfer surface, so that thermal energy passes between them without the circuits mixing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor é um vaso de pressão que possui a função projetada de transferir energia térmica entre duas ou mais correntes de fluido mantendo sua separação.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um vaso de pressão no qual dois circuitos de fluido são separados por uma superfície sólida de transferência de calor, de modo que energia térmica passa entre eles sem mistura dos circuitos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">SolidHeatTransferSurface is a FOL-only predicate (no OWL IRI), analogous to Fluid and sameSubstance in operation axioms; OWL carries only the genus (PressureVessel). The two-circuit-separation and no-mixing differentia are in the NLD. Full equivalentClass axiomatisation is deferred to Incremento 2c.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">SolidHeatTransferSurface é um predicado somente-FOL (sem IRI OWL), análogo a Fluid e sameSubstance nos axiomas de operação; OWL carrega apenas o gênero (PressureVessel). A differentia de separação de dois circuitos e não-mistura está na NLD. Axiomatização plena equivalentClass adiada ao Incremento 2c.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat exchanger is an assembly that has the function of heat transfer and has component parts including heat transfer surfaces and fluid passages for separated streams.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;heat exchanger&apos; then x is a &apos;pressure vessel&apos; that has a &apos;solid heat-transfer surface&apos; as a component part at all times</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;trocador de calor&apos;, então x é um &apos;vaso de pressão&apos; que tem uma &apos;superfície sólida de transferência de calor&apos; como parte componente em todo momento</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">angle valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula angular</rdfs:label>
        <skos:definition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (AngleValve(x) → Valve(x) ∧ ∃p (hasPart(x,p) ∧ NonInlinePortArrangement(p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula angular é uma válvula que tem portas da válvula que não estão alinhadas, mas dispostas em ângulo uma em relação à outra.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by geometric configuration. Under OWA, sufficient conditions for non-inline port arrangement could lead to false positives where complex multi-port manifolds or specialized valves with angular components get incorrectly classified as standard angle valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every angle valve is a valve that has a non-inline port arrangement.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:label xml:lang="en">ball control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
        <skos:definition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">ball valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula esfera</rdfs:label>
        <skos:definition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BallValve(x) → Valve(x) ∧ ∃y(BallClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(RotationalMotionProcess(z) ∧ participatesIn(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula esfera é uma válvula que controla o fluxo de fluidos usando um elemento de fechamento esférico que gira aproximadamente 90 graus para alinhar ou desalinhar sua passagem de fluxo com as portas do corpo da válvula.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by physical mechanism, sufficient conditions are omitted to avoid false positives under Open World Assumption. Complex multi-way valves or specialized equipment containing ball mechanisms should not be automatically classified as standard ball valves without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every ball valve is a valve that has a ball closure component and participates in rotational motion processes</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000096 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000096">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">block and bleed valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de bloqueio e sangria</rdfs:label>
        <skos:definition xml:lang="en">A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BlockAndBleedValve(x) → Valve(x) ∧ ∃s(SingleSeat(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃l(BleederLine(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃v(BleederValve(v) ∧ hasComponentPartAtAllTimes(x,v)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de bloqueio e sangria é uma válvula que possui um assento que fornece vedação, e uma linha de sangria e válvula que são conectadas ao castelo da válvula para ventilação controlada da pressão a jusante.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive types require necessary conditions only due to Open World Assumption. The structural differentia (single seat + bleeder system) could theoretically be present in specialized equipment that should not be classified as a standard block and bleed valve without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every block and bleed valve is a valve that has component parts: exactly one seat, a bleeder line, and a bleeder valve integrated into the bonnet.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">blow down valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de blow down</rdfs:label>
        <skos:definition xml:lang="en">A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (BlowDownValve(x) ↔ Valve(x) ∧ ∃f (RapidDepressurizationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de blow down é uma válvula que possui uma função projetada para despressurização rápida de sistemas de alta pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every blow down valve is a valve that has the function of rapid depressurization.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
        <rdfs:label xml:lang="en">blower</rdfs:label>
        <rdfs:label xml:lang="pt-br">soprador</rdfs:label>
        <skos:definition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Blower(x) ↔ (Compressor(x) ∧ ∃f,p,v (CompressionFunction(f) ∧ bearerOf(x,f) ∧ MediumPressureRange(p) ∧ MediumVolumeFlowRange(v) ∧ hasOperatingParameter(x,p) ∧ hasOperatingParameter(x,v))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um soprador é um compressor que comprime e fornece ar ou gás em pressão média e vazão volumétrica média.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every blower is a compressor that has the function of compressing gas and operates at medium pressure and medium volume flow ranges.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000099 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000099">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">butterfly control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula borboleta de controle</rdfs:label>
        <skos:definition xml:lang="en">A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ButterflyControlValve(x) → Valve(x) ∧ ∃d(RotatingDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(Actuator(a) ∧ hasComponentPartAtAllTimes(x,a)) ∧ ∃f(ProcessControlledFlowFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula borboleta de controle é uma válvula de controle que possui um mecanismo de fechamento por disco rotativo e possui uma função de fluxo controlado por processo, permitindo modulação automatizada do fluxo em resposta a sinais de controle externos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">This is a constructive type that combines two existing differentia (butterfly mechanism + control function). Under OWA, providing sufficient conditions could lead to false positives where any valve with both a rotating disc and control capability would be classified as this specific type, even if it has additional specialized features or hybrid mechanisms.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every butterfly control valve is a valve that has-component-part-at-all-times some rotating disc and has-component-part-at-all-times some actuator and bearer-of some process-controlled flow function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">butterfly valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula borboleta</rdfs:label>
        <skos:definition xml:lang="en">A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ButterflyValve(x) → Valve(x) ∧ ∃y(DiscTypeClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(TransverseRotationAxis(z) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula borboleta é uma válvula que possui um membro de fechamento tipo disco com haste paralela ao plano do disco e eixo de rotação transversal à direção do fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">This is a constructive classification based on physical mechanism. Under the Open World Assumption, any artifact with a disc-type closure and transverse rotation axis would be forced into the ButterflyValve class, including specialized hybrid equipment or custom manifolds containing butterfly mechanisms that should not be classified as standard butterfly valves for maintenance purposes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every butterfly valve is a valve that has a disc-type closure member and has a transverse rotation axis.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000224"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">centrifugal compressor</rdfs:label>
        <rdfs:label xml:lang="pt-br">compressor centrífugo</rdfs:label>
        <skos:definition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (CentrifugalCompressor(x) → Compressor(x) ∧ ∃i(CentrifugalImpeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃p(RadialFlowPattern(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um compressor centrífugo é um compressor que usa um ou mais impelidores centrífugos para acelerar o gás através de fluxo radial e gerar aumento de pressão por ação centrífuga.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because under OWA, any equipment with a centrifugal impeller could be incorrectly classified as a standard centrifugal compressor, including specialized hybrid equipment or multi-stage systems that contain centrifugal elements but should not be forced into this maintenance category. Domain expert validation needed to confirm structural differentia is sufficient.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal compressor is a compressor that has component part at all times some centrifugal impeller and participates in some radial flow pattern.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
        <rdfs:label xml:lang="pt-br">bomba centrífuga</rdfs:label>
        <rdfs:label xml:lang="en">centrifugal pump</rdfs:label>
        <skos:definition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalPump(x) → Pump(x) ∧ ∃y(CentrifugalImpeller(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(VoluteCasing(z) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba centrífuga é uma bomba que usa força centrífuga gerada por impulsores rotativos com pás para aumentar a pressão do fluido através de uma carcaça voluta.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under Open World Assumption, any equipment with centrifugal impellers and volute casing could be inferred as a standard centrifugal pump, potentially misclassifying specialized hybrid equipment or complex pump systems that contain centrifugal stages but serve different operational roles.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal pump is a pump that has a centrifugal impeller as component part at all times and has a volute casing as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">check valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de retenção</rdfs:label>
        <skos:definition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CheckValve(x) ↔ Valve(x) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção é uma válvula que possui uma função de prevenção de refluxo, permitindo automaticamente que o fluido flua em apenas uma direção enquanto previne o fluxo reverso.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every check valve is a valve that has the function to prevent backflow and automatically allow unidirectional fluid flow.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">choke control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle de choke</rdfs:label>
        <skos:definition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ChokeControlValve(x) → ControlValve(x) ∧ ∃y (ChokeGeometry(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle de choke é uma válvula de controle que possui um componente de geometria de choke para redução de pressão através de restrição de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as &apos;both&apos; functional and constructive. The constructive differentia (choke geometry) makes it safer to use necessary conditions to avoid forcing all valves with choke components into this specific control category under the Open World Assumption.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke control valve is a control valve that has a choke geometry component at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">choke valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula choke</rdfs:label>
        <skos:definition xml:lang="en">A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ChokeValve(x) ↔ (Valve(x) ∧ ∃f (PressureReductionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula choke é uma válvula que possui uma função de redução de pressão, projetada para reduzir a pressão do fluido da entrada para a saída através de restrição controlada do fluxo e dissipação de energia.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke valve is a valve that bears a pressure reduction function and has a flow restriction element as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">circuit breaker</rdfs:label>
        <rdfs:label xml:lang="pt-br">disjuntor</rdfs:label>
        <skos:definition xml:lang="en">A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current.</skos:definition>
        <skos:definition xml:lang="en">A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (CircuitBreaker(x) ↔ ElectricalSwitchingDevice(x) ∧ ∃f (ElectricalCurrentInterruptionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p (RegularInterruptionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CircuitBreaker(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(CurrentInterruptionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um disjuntor é um dispositivo de chaveamento elétrico que possui uma função de interrupção de corrente elétrica e participa regularmente em processos que interrompem com segurança a corrente elétrica.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um disjuntor é um equipamento elétrico que possui uma função de proteção de circuito e participa em processos de interrupção de corrente em intervalos regulares.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every circuit breaker is an electrical switching device that has the function to interrupt electrical current and participates in regular current interruption processes.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every circuit-breaker is an electrical equipment that has the function to protect circuits and participates in the process of interrupting electrical current at regular intervals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000107 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000107">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">coalescedor</rdfs:label>
        <rdfs:label xml:lang="en">coalescer</rdfs:label>
        <skos:definition xml:lang="en">A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Coalescer(x) ↔ (Separator(x) ∧ ∃f(CoalescenceFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(GravitySeparationProcess(p) ∧ participatesIn(x,p)) ∧ ∃o(SkimmableLiquidPortion(o) ∧ hasOutput(x,o))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um coalescedor é um separador que usa meio de coalescência para promover a fusão de gotículas em misturas líquidas imiscíveis, permitindo separação por gravidade onde a fase líquida menos densa pode ser removida por escumação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every coalescer is a separator that bears a coalescence function and participates in gravity separation processes to produce skimmable liquid portions.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000108 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000108">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diaphragm valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de diafragma</rdfs:label>
        <skos:definition xml:lang="en">A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DiaphragmValve(x) → Valve(x) ∧ ∃d,p (ResilientDiaphragm(d) ∧ Port(p) ∧ hasComponentPartAtAllTimes(x,d) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de diafragma é uma válvula que usa um diafragma resiliente forçado contra uma porta como seu mecanismo de fechamento para controlar o fluxo de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Since this is a constructive type defined by physical mechanism (diaphragm closure), necessary conditions are used to avoid over-classification under the Open World Assumption. Not every equipment with a diaphragm component should automatically be classified as a diaphragm valve - the structural differentia requires domain validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every diaphragm valve is a valve that has a resilient diaphragm as component part and has a port as component part and participates in diaphragm closure processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">differential pressure gauge</rdfs:label>
        <rdfs:label xml:lang="pt-br">manômetro de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureGauge(x) ↔ PressureGauge(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(DifferentialPressureMeasuringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(PressurePortPair(p) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um manômetro de pressão diferencial é um manômetro que mede e indica a diferença entre duas entradas de pressão usando um elemento de medição de pressão diferencial.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure gauge is a pressure gauge that bears a DifferentialPressureMeasurementFunction and has component parts including a DifferentialPressureMeasuringElement and PressurePortPair.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000110 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000110">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000186"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000186"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">differential pressure transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureTransmitter(x) ↔ PressureTransmitter(x) ∧ ∃f (DifferentialPressureTransmissionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão diferencial é um transmissor de pressão que possui uma função de transmissão de pressão diferencial, permitindo medir a diferença de pressão entre dois sinais de pressão de entrada e transmitir essa diferença como um sinal de saída padronizado.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000111 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000111">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">double block and bleed valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de bloqueio duplo e sangria</rdfs:label>
        <skos:definition xml:lang="en">A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DoubleBlockAndBleedValve(x) → (Valve(x) ∧ ∃p,s,b (PrimarySeat(p) ∧ SecondarySeat(s) ∧ BleedPort(b) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,b))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de bloqueio duplo e sangria é uma válvula que incorpora duas sedes, cada uma proporcionando capacidade de vedação, e inclui um meio de ventilação do espaço entre as sedes.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive basis - the structural differentia (dual seats plus bleed port) defines necessary conditions, but under OWA we cannot assert that ANY artifact with these structural components is definitively a double block and bleed valve, as specialized multi-way valves or custom manifolds might contain similar mechanisms without being standard maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every double block and bleed valve is a valve that has a primary seat and has a secondary seat and has a bleed port.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">down hole safety valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de segurança de fundo de poço</rdfs:label>
        <skos:definition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(DownHoleSafetyValve(x) ↔ SafetyValve(x) ∧ ∃f(SubsurfaceSafetyFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SubsurfaceOperationProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança de fundo de poço é uma válvula de segurança que possui uma função de segurança subsuperficial para operações de alívio de pressão e controle de fluxo em poços ou outros ambientes subsuperficiais.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every down hole safety valve is a safety valve that bears a SubsurfaceSafetyFunction and participates in SubsurfaceOperationProcess</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000113 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000113">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electric motor</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor elétrico</rdfs:label>
        <skos:definition xml:lang="en">An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">ElectricMotor(x) ↔ Assembly(x) ∧ ∃f(ElectricToMechanicalConversionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(Stator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃r(Rotor(r) ∧ hasComponentPartAtAllTimes(x,r))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor elétrico é um conjunto que possui uma função de conversão de energia elétrica para mecânica e tem tanto um estator quanto um rotor como componentes essenciais.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric motor is an assembly that bears an electric-to-mechanical conversion function and has component parts including a stator and rotor at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">emergency shut down valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de parada de emergência</rdfs:label>
        <skos:definition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (EmergencyShutDownValve(x) ↔ (Valve(x) ∧ ∃f(EmergencyShutDownFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de parada de emergência é uma válvula que possui uma função de parada de emergência, permitindo o isolamento rápido de fluxo em situações de emergência através de mecanismos atuados com capacidade à prova de falhas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every emergency shut down valve is a valve that has an emergency shut down function and has an actuator and has a fail-safe system.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fan</rdfs:label>
        <rdfs:label xml:lang="pt-br">ventilador</rdfs:label>
        <skos:definition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Fan(x) ↔ (Assembly(x) ∧ ∃f(GasMovementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um ventilador é um conjunto que possui uma função de movimentação de gás para fornecer ou exaurir volumes de vapor ou gás com baixa pressão diferencial.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every fan is an assembly that bears a gas movement function, and every assembly that bears a gas movement function is a fan.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278"/>
        <rdfs:label xml:lang="pt-br">elemento de vazão</rdfs:label>
        <rdfs:label xml:lang="en">flow element</rdfs:label>
        <skos:definition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowElement(x) ↔ (Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de vazão é um instrumento que tem a função de medir vazões em um fluxo e produzir sinais proporcionais à vazão medida.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow element is an instrument that bears a FlowMeasurementFunction and has component parts including a FlowSensingElement and SignalGenerationComponent.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow indicator</rdfs:label>
        <rdfs:label xml:lang="pt-br">indicador de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (FlowIndicator(x) ↔ (Instrument(x) ∧ ∃f(FlowIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FlowMeasuringElement(e) ∧ hasComponentPartAtSomeTime(x,e)) ∧ ∃d(DisplayElement(d) ∧ hasComponentPartAtAllTimes(x,d))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador de fluxo é um indicador projetado para indicar taxas de fluxo usando um elemento de medição de fluxo e elemento de exibição.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow indicator is an instrument that bears a flow indication function and has a flow measuring element and display element as component parts.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000185"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000185"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (FlowTransmitter(x) ↔ Transmitter(x) ∧ ∃f(FlowSignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(FlowMeasurement(m) ∧ hasInput(x,m)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de fluxo é um transmissor que produz sinais de saída padronizados proporcionais às medições de fluxo provenientes de elementos sensores de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow transmitter is a transmitter that has the function of transmitting flow signals and has as input flow measurements.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:label xml:lang="en">gate control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle tipo gaveta</rdfs:label>
        <skos:definition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GateControlValve(x) → ControlValve(x) ∧ ∃g(GateClosureMechanism(g) ∧ hasComponentPartAtAllTimes(x,g)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle tipo gaveta é uma válvula de controle que usa um elemento de fechamento tipo gaveta ou cunha movendo-se perpendicular ao caminho do fluxo para modular o fluxo de fluido em resposta a sinais de controle.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">This is a constructive subtype where the structural differentia (gate closure mechanism) defines necessary conditions. Under OWA, making this sufficient could force any assembly with a gate closure into this maintenance category, including specialized multi-way valves or custom manifolds that should not be classified as standard gate control valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate control valve is a control valve that has a gate closure mechanism as component part at all times</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000120 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000120">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gate valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula gaveta</rdfs:label>
        <skos:definition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (GateValve(x) → (Valve(x) ∧ ∃g(GateClosure(g) ∧ hasComponentPartAtAllTimes(x,g)) ∧ ∃m(LinearActuationMechanism(m) ∧ hasComponentPartAtAllTimes(x,m))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula gaveta é uma válvula que possui um membro de fechamento tipo gaveta ou disco com movimento linear paralelo ao plano dos assentos planos, que são transversais à direção do fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for structural features like &apos;linear sliding gate&apos; risks false positives from complex hybrid equipment or custom manifolds that contain gate mechanisms but should not be classified as standard gate valves. Necessary conditions provide safer classification that can be validated by domain experts.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate valve is a valve that has a gate closure component and a linear actuation mechanism.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000290"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">caixa de engrenagens</rdfs:label>
        <rdfs:label xml:lang="en">gearbox</rdfs:label>
        <skos:definition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Gearbox(x) → Assembly(x) ∧ ∃c,g1,g2,i,o (GearCasing(c) ∧ GearWheel(g1) ∧ GearWheel(g2) ∧ g1≠g2 ∧ InputShaft(i) ∧ OutputShaft(o) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,g1) ∧ hasComponentPartAtAllTimes(x,g2) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma caixa de engrenagens é um conjunto que consiste em um invólucro de engrenagens contendo um arranjo de duas ou mais rodas de engrenagem que transmitem movimento rotativo de um eixo de entrada para um eixo de saída.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because the structural differentia (specific gear casing and gear-wheel arrangement) is complex and making it sufficient under Open World Assumption could lead to false positives - specialized equipment containing gear mechanisms might be incorrectly classified as standard gearboxes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gearbox is an assembly that has component parts including a gear casing, at least two gear-wheels, an input shaft, and an output shaft, and bears a power transmission function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000122 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000122">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:label xml:lang="en">globe control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle globo</rdfs:label>
        <skos:definition xml:lang="en">A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (GlobeControlValve(x) → ControlValve(x) ∧ ∃y,z (GlobeValveBody(y) ∧ LinearMotionClosure(z) ∧ hasComponentPartAtAllTimes(x,y) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle globo é uma válvula de controle que possui um corpo em formato de globo e usa um mecanismo de fechamento de movimento linear para modular o fluxo de fluido em resposta a sinais de controle de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive subtype (both classification basis). The structural differentia (globe body + linear closure) provides strong necessary conditions, but declaring sufficiency under OWA could lead to unwanted automatic classification of specialized equipment that contains globe mechanisms but should not be categorized as standard globe control valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe control valve is a control valve that has a globe valve body and has a linear motion closure as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000123 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000123">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">globe valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula globo</rdfs:label>
        <skos:definition xml:lang="en">A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GlobeValve(x) → Valve(x) ∧ ∃y,z(hasComponentPartAtAllTimes(x,y) ∧ LinearMotionClosure(y) ∧ hasComponentPartAtAllTimes(x,z) ∧ NormalSeat(z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula globo é uma válvula caracterizada por um elemento de fechamento (disco ou tampão) que opera com movimento linear perpendicular a uma sede orientada normal ao caminho do fluxo do fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under OWA, making the structural differentia sufficient could force classification of specialized equipment containing linear motion closures (like complex multi-way valves or custom manifolds) as standard globe valves when they may warrant distinct maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe valve is a valve that has as component part at all times a linear motion closure and a normal seat.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">aquecedor</rdfs:label>
        <rdfs:label xml:lang="en">heater</rdfs:label>
        <skos:definition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Heater(x) ↔ Assembly(x) ∧ ∃f(HeatingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every heater is an assembly that bears a heating function and has heating elements and housing as component parts at all times</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000180"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000180"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">analisador de umidade</rdfs:label>
        <rdfs:label xml:lang="en">humidity analyser</rdfs:label>
        <skos:definition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (HumidityAnalyser(x) ↔ ProcessAnalyzer(x) ∧ ∃f (HumidityMeasurementFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um analisador de umidade é um analisador de processo que é projetado para medir e indicar o conteúdo de umidade ou vapor d&apos;água em correntes de processo ou ambientes.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every humidity analyser is a process analyzer that has the function to measure humidity content.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">indicador</rdfs:label>
        <rdfs:label xml:lang="en">indicator</rdfs:label>
        <skos:definition xml:lang="en">An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Indicator(x) ↔ (Instrument(x) ∧ ∃f(IndicationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador é um instrumento que exibe ou mostra o valor ou status de uma variável medida ou condição para torná-la perceptível aos operadores.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every indicator is an instrument that bears an indication function to display process information in human-perceptible form.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000128 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000128">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000176"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000176"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">elemento de nível</rdfs:label>
        <rdfs:label xml:lang="en">level element</rdfs:label>
        <skos:definition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LevelElement(x) ↔ Detector(x) ∧ ∃f(LevelDetectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de nível é um instrumento que possui uma função de detecção de nível para determinar o nível de fluido em um vaso ou recipiente.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level element is a detector that has the function to detect fluid level</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">indicador de nível</rdfs:label>
        <rdfs:label xml:lang="en">level indicator</rdfs:label>
        <skos:definition xml:lang="en">A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LevelIndicator(x) ↔ (Indicator(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador de nível é um indicador que mede e exibe localmente o nível de material líquido ou sólido a granel em um vaso ou tanque.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level indicator is an indicator that has the function to measure and locally indicate level.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000130 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000130">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129"/>
        <rdfs:label xml:lang="en">level sight glass</rdfs:label>
        <rdfs:label xml:lang="pt-br">visor de nível</rdfs:label>
        <skos:definition xml:lang="en">A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LevelSightGlass(x) ↔ SightGlass(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um visor de nível é um visor que possui uma função projetada para indicar o nível de líquido através de inspeção visual.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level sight glass is a sight glass that has the function of level indication.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000187"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000187"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">level transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de nível</rdfs:label>
        <skos:definition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(LevelTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(LevelMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de nível é um transmissor que mede o nível (altura) de material líquido ou sólido a granel em um recipiente e produz um sinal elétrico de saída padronizado proporcional ao nível medido.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level transmitter is a transmitter that bears a LevelMeasurementAndTransmissionFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">limit switch</rdfs:label>
        <rdfs:label xml:lang="pt-br">limit switch</rdfs:label>
        <skos:definition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LimitSwitch(x) ↔ Instrument(x) ∧ ∃f(PositionLimitDetectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MechanicalMotion(p) ∧ hasInput(x,p)) ∧ ∃s(ElectricalSignal(s) ∧ hasOutput(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um limit switch é um instrumento que possui uma função de detecção de limite de posição, acionado mecanicamente pelo movimento de objetos para fornecer sinais de chaveamento elétrico quando limites de posição predeterminados são atingidos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every limit switch is an instrument that has the function to detect position limits and is mechanically operated by object motion to generate electrical switching signals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">manual valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula manual</rdfs:label>
        <skos:definition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ManualValve(x) → Valve(x) ∧ ∃y(ManualActuator(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula manual é uma válvula que possui um atuador manual que requer força manual para operação.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on actuation mechanism. Under OWA, any valve with a manual actuator component might be classified as manual valve even if it has additional automated features (hybrid valves). Starting with necessary conditions allows domain experts to validate that manual actuation is both necessary and sufficient before upgrading to equivalent axiom.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every manual valve is a valve that has a manual actuator as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">needle valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula agulha</rdfs:label>
        <skos:definition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(NeedleValve(x) → Valve(x) ∧ ∃y(NeedlePlug(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(SmallOrificeSeat(z) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula agulha é uma válvula que possui um membro de fechamento cônico em forma de agulha que se assenta em um pequeno orifício para fornecer controle preciso de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by specific structural features (needle plug geometry), providing sufficient conditions under the Open World Assumption could lead to over-classification. Complex valve assemblies or custom equipment containing needle-like mechanisms might be incorrectly classified as standard needle valves for maintenance purposes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every needle valve is a valve that has a needle plug component and has a small orifice seat component.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">on off control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle liga-desliga</rdfs:label>
        <skos:definition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(OnOffControlValve(x) ↔ ControlValve(x) ∧ ∃f(BinaryFlowControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle liga-desliga é uma válvula de controle que possui uma função de controle de fluxo binária, tendo apenas duas posições definidas: totalmente aberta e totalmente fechada.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every on-off control valve is a control valve that has a BinaryFlowControlFunction and has component part a BinaryPositioner.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">orifice plate</rdfs:label>
        <rdfs:label xml:lang="pt-br">placa de orifício</rdfs:label>
        <skos:definition xml:lang="en">An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(OrificePlate(x) → FlowMeasuringElement(x) ∧ ∃p,h(ThinPlate(p) ∧ SpecifiedHole(h) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma placa de orifício é um elemento de medição de fluxo que consiste de uma placa fina com um orifício especificado através do qual o fluido flui para criar pressão diferencial para medição da taxa de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical structure. Under OWA, any plate with a hole could potentially be classified as an orifice plate, but many perforated plates serve different purposes (structural, filtering, etc.). The structural differentia alone is not sufficient without industrial context validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every orifice plate is a flow measuring element that has a thin plate component and has a specified hole component and bears a flow measurement function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000137 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000137">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000181"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000181"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">medidor de sequência de fases</rdfs:label>
        <rdfs:label xml:lang="en">phase sequence meter</rdfs:label>
        <skos:definition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PhaseSequenceMeter(x) ↔ ElectricMeasuringInstrument(x) ∧ ∃f(PhaseSequenceMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PolyphaseElectricalSignal(s) ∧ hasInput(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um medidor de sequência de fases é um instrumento de medição elétrica que possui uma função de medição de sequência de fases para determinar e indicar a sequência na qual as tensões instantâneas dos condutores de fase atingem seu valor máximo em um sistema elétrico polifásico.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every phase sequence meter is an electric measuring instrument that has the function to measure phase sequence and has as input polyphase electrical signals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <rdfs:label xml:lang="en">piston check valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de retenção tipo pistão</rdfs:label>
        <skos:definition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PistonCheckValve(x) → CheckValve(x) ∧ ∃y(PistonClosure(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção tipo pistão é uma válvula de retenção que possui um elemento de fechamento tipo pistão que se move linearmente ao longo do eixo de fluxo sob ação da gravidade ou mola para prevenir refluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under Open World Assumption, any artifact with a piston closure could potentially be classified as piston check valve, but specialized hybrid valves or custom manifolds containing piston mechanisms should not be automatically asserted into this standard maintenance category without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every piston check valve is a check valve that has a piston closure as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">plate heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor de placas</rdfs:label>
        <skos:definition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PlateHeatExchanger(x) → HeatExchanger(x) ∧ ∃p(HeatTransferPlate(p) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de placas é um trocador de calor que possui placas de transferência de calor como sua superfície primária de transferência de calor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the plate-based structure is characteristic, under the Open World Assumption, asserting equivalence could lead to false positives where any equipment with heat transfer plates (e.g., specialized hybrid equipment, multi-function process units) would be automatically classified as a standard plate heat exchanger. Domain expert validation is needed to confirm the structural differentia is sufficient.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every plate heat exchanger is a heat exchanger that has component part heat transfer plates at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000140 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000140">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">plug valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula plug</rdfs:label>
        <skos:definition xml:lang="en">A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PlugValve(x) → Valve(x) ∧ ∃p(PlugClosure(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃r(QuarterTurnRotationProcess(r) ∧ participatesIn(x,r)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula plug é uma válvula que possui um elemento de fechamento em forma de plugue cilíndrico ou cônico que opera por rotação de um quarto de volta em seu eixo para controlar o fluxo de fluido selando contra um assento.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification requires necessary conditions only. Under OWA, any artifact with a plug closure and quarter-turn mechanism would be forcibly classified as a plug valve, but specialized multi-port valves or custom manifolds containing plug mechanisms should not automatically inherit the standard plug valve classification without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every plug valve is a valve that has a plug closure component and participates in quarter-turn rotation processes</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086"/>
        <rdfs:label xml:lang="en">power transformer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transformador de potência</rdfs:label>
        <skos:definition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformer(x) ↔ (Transformer(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃r(ElectricalPowerTransmissionRole(r) ∧ bearerOf(x,r))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transformador de potência é um transformador que possui uma função de transformação de energia elétrica, realizada por indução eletromagnética para transformar sistemas de tensão e corrente alternadas para diferentes níveis na mesma frequência para fins de transmissão de energia.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every power transformer is a transformer that has the function of transforming electrical power through electromagnetic induction, taking alternating current at one voltage level as input and producing alternating current at different voltage level(s) as output for power transmission.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">elemento de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure element</rdfs:label>
        <skos:definition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PressureElement(x) ↔ DetectingElement(x) ∧ ∃f(PressureSensingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão é um instrumento que possui uma função de detecção de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure element is a detecting element that has the function of sensing pressure</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">manômetro</rdfs:label>
        <rdfs:label xml:lang="en">pressure gauge</rdfs:label>
        <skos:definition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PressureGauge(x) ↔ (Instrument(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um manômetro é um indicador que possui a função de medir e exibir valores de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure gauge is an instrument that has the function to measure and display pressure</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pressure transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de pressão</rdfs:label>
        <skos:definition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PressureTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(PressureTransmissionFunction(f) ∧ hasFunction(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão é um transmissor que converte medições de pressão em sinais de saída padronizados para transmissão a sistemas de controle ou monitoramento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure transmitter is a transmitter that has the function to transmit pressure measurement signals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">relief valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de alívio</rdfs:label>
        <skos:definition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ReliefValve(x) ↔ (Valve(x) ∧ ∃f (PressureReliefFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de alívio é uma válvula projetada para abrir automaticamente em um ponto de ajuste de pressão predeterminado para aliviar o excesso de pressão e prevenir níveis de pressão inseguros em um sistema.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every relief valve is a valve that bears a pressure relief function, which realizes a pressure relief process that automatically opens the valve when system pressure exceeds a predetermined setpoint.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000146 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000146">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">orifício de restrição</rdfs:label>
        <rdfs:label xml:lang="en">restriction orifice</rdfs:label>
        <skos:definition xml:lang="en">A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(RestrictionOrifice(x) ↔ FlowModificationAccessory(x) ∧ ∃f(FlowRestrictionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um orifício de restrição é um acessório de modificação de fluxo que possui a função de restringir o fluxo de fluido criando queda de pressão controlada através de constrição geométrica.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every restriction orifice is a flow modification accessory that bears a flow restriction function</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">safety relief valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de segurança e alívio</rdfs:label>
        <skos:definition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SafetyReliefValve(x) ↔ (Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança e alívio é uma válvula que possui uma função de alívio de segurança que combina capacidades de proteção de segurança e alívio de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety relief valve is a valve that has the function of providing both safety protection and pressure relief.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">safety valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de segurança</rdfs:label>
        <skos:definition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SafetyValve(x) ↔ Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança é uma válvula que possui uma função de ventilação de segurança para alívio automático de pressão por abertura rápida e total para proteção contra condições perigosas de sobrepressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety valve is a valve that has the function to automatically relieve excess pressure for emergency protection</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">self operating valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula auto-operante</rdfs:label>
        <skos:definition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SelfOperatingValve(x) → Valve(x) ∧ ∃m(SelfOperatingMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(EnergyIndependentOperationCapability(c) ∧ bearerOf(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula auto-operante é uma válvula que inclui um mecanismo interno de operação (como mola, gravidade, pressão do fluido ou contrapeso) e não depende de uma fonte externa de energia para seu acionamento.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical configuration (self-operating mechanism). Under OWA, any valve with an internal operating mechanism might be classified as self-operating even if it has additional external actuators or specialized applications. Domain expert validation needed to confirm structural differentia is sufficient.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every self-operating valve is a valve that has a self-operating mechanism as component part at all times and bears the capability of energy-independent operation.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">solenoid valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula solenoide</rdfs:label>
        <skos:definition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (SolenoidValve(x) → Valve(x) ∧ ∃s (SolenoidActuator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f (ElectricalControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula solenoide é uma válvula que possui um atuador solenoide para controle elétrico do fluxo de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type where the solenoid mechanism is the distinguishing structural feature. Under OWA, making it equivalent could incorrectly classify complex valve assemblies that contain solenoid components but are not standard solenoid valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid valve is a valve that has a solenoid actuator component and bears an electrical control function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000151 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000151">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">storage tank</rdfs:label>
        <rdfs:label xml:lang="pt-br">tanque de armazenamento</rdfs:label>
        <skos:altLabel xml:lang="en">tank</skos:altLabel>
        <skos:definition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(StorageTank(x) ↔ (Tank(x) ∧ ∃f(ExtendedStorageFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um tanque de armazenamento é um vaso projetado para armazenar fluidos ou materiais por períodos prolongados sem transformação ou processamento ativo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every storage tank is a tank that has the function to store materials for extended periods.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">filtro grosso</rdfs:label>
        <rdfs:label xml:lang="en">strainer</rdfs:label>
        <skos:definition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Strainer(x) ↔ (MaterialArtifact(x) ∧ ∃f(SeparationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilteringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(SolidLiquidSeparationProcess(p) ∧ participatesIn(x,p))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um filtro grosso é um artefato material que possui uma função de separação e tem um elemento filtrante, projetado para separar partículas sólidas de fluidos fazendo o fluido passar através de telas ou perfurações.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every strainer is a material artifact that bears a separation function and has a filtering element as component part at all times and participates in solid-liquid separation processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000153 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000153">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <rdfs:label xml:lang="en">swing check valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de retenção basculante</rdfs:label>
        <skos:definition xml:lang="en">A swing check valve is a check valve that has a closure member consisting of a disc which swings freely on a hinge mechanism and opens automatically when flow is established and closes automatically when flow ceases or reverses.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SwingCheckValve(x) → CheckValve(x) ∧ ∃d(HingedDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(SwingArm(a) ∧ hasComponentPartAtAllTimes(x,a)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A swing check valve is a check valve that has a closure member consisting of a disc which swings freely on a hinge mechanism and opens automatically when flow is established and closes automatically when flow ceases or reverses.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção basculante é uma válvula de retenção que possui um elemento de fechamento consistindo de um disco que gira livremente em um mecanismo de dobradiça e abre automaticamente quando o fluxo é estabelecido e fecha automaticamente quando o fluxo cessa ou se inverte.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type to avoid false positives under OWA. Any artifact with a hinged disc mechanism should not automatically be classified as a swing check valve without domain expert validation, as specialized equipment may contain swing mechanisms but serve different primary functions.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every swing check valve is a check valve that has a hinged disc as component part and has a swing arm as component part</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">indicador de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature indicator</rdfs:label>
        <skos:definition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (TemperatureIndicator(x) ↔ (Instrument(x) ∧ ∃f (TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃s (TemperatureSensingElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃d (LocalDisplay(d) ∧ hasComponentPartAtAllTimes(x,d))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador de temperatura é um indicador que mede temperatura e exibe o valor medido localmente na localização do instrumento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature indicator is an instrument that has the function of temperature indication and has component parts including a temperature sensing element and a local display.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">temperature transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de temperatura</rdfs:label>
        <skos:definition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureTransmitter(x) ↔ Transmitter(x) ∧ ∃f(TemperatureMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de temperatura é um transmissor que mede temperatura e produz um sinal de saída padronizado dependente do sinal de entrada recebido de um elemento de temperatura.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature transmitter is a transmitter that has the function to measure temperature and transmit standardized signals based on temperature input.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000156 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000156">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">poço termométrico</rdfs:label>
        <rdfs:label xml:lang="en">thermowell</rdfs:label>
        <skos:definition xml:lang="en">A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Thermowell(x) → Instrument(x) ∧ ∃r,c,f (PressureTightReceptacle(r) ∧ ProcessConnection(c) ∧ TemperatureSensorProtectionFunction(f) ∧ hasComponentPartAtAllTimes(x,r) ∧ hasComponentPartAtAllTimes(x,c) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um poço termométrico é um instrumento que é um receptáculo resistente à pressão adaptado para receber um elemento sensor de temperatura, provido com roscas externas ou outros meios para fixação resistente à pressão a um vaso ou tubulação.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Thermowell has constructive classification basis. The structural differentia (pressure-tight receptacle with process connection) defines necessary conditions, but making these sufficient under OWA could lead to false classifications of other threaded pressure-tight devices that happen to contain receptacles but are not intended as thermowells.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell is an instrument that has a pressure-tight receptacle as component part and has a process connection as component part and is designed for temperature sensing elements.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">transmissor</rdfs:label>
        <rdfs:label xml:lang="en">transmitter</rdfs:label>
        <skos:definition xml:lang="en">A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Transmitter(x) ↔ Instrument(x) ∧ ∃f(SignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SensorElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(SignalConditioner(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃t(TransmissionModule(t) ∧ hasComponentPartAtAllTimes(x,t)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor é um instrumento que possui uma função de transmissão de sinal, recebendo sinais de variáveis de processo de sensores e convertendo-os em sinais de saída padronizados para transmissão a sistemas de controle.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every transmitter is an instrument that has the function of signal transmission and has a sensor element and signal conditioner and transmission module and receives process variable inputs and produces standardized signal outputs.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">vaso</rdfs:label>
        <rdfs:label xml:lang="en">vessel</rdfs:label>
        <skos:definition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Vessel(x) ↔ Assembly(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(VesselShell(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃h(VesselHead(h) ∧ hasComponentPartAtAllTimes(x,h)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel is an assembly that bears a containment function and has a vessel shell and vessel head as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">transmissor de vibração</rdfs:label>
        <rdfs:label xml:lang="en">vibration transmitter</rdfs:label>
        <skos:definition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (VibrationTransmitter(x) ↔ (Transmitter(x) ∧ ∃v (VibrationSignal(v) ∧ hasInput(x,v)) ∧ ∃f (VibrationMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de vibração é um transmissor que mede vibrações mecânicas e produz um sinal de saída proporcional aos parâmetros de vibração medidos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every vibration transmitter is a transmitter that has a vibration signal as input and bears a vibration measurement function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <rdfs:label xml:lang="pt-br">válvula de retenção wafer</rdfs:label>
        <rdfs:label xml:lang="en">wafer check valve</rdfs:label>
        <skos:definition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(WaferCheckValve(x) → CheckValve(x) ∧ ∃y(WaferPatternValveBody(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive subtype (both functional and structural aspects). The wafer pattern mounting configuration is a structural differentia that, while characteristic, may have edge cases or specialized variants that should not be automatically classified without expert validation. The structural differentia should be confirmed as both necessary and sufficient in industrial practice before upgrading to equivalent mode.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every wafer check valve is a check valve that has a wafer pattern valve body as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">backflow prevention function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de prevenção de refluxo</rdfs:label>
        <skos:definition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">binary flow control function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de controle binário de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the complete opening or closing of a flow path to allow or prevent fluid passage.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow restriction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de restrição de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the reduction of fluid flow rate by creating a controlled resistance in the flow path.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de redução de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure reduction function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the reduction of fluid pressure from a higher upstream value to a controlled downstream value.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">emergency shut down function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de parada de emergência</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic isolation of process equipment upon detection of a hazardous condition.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de despressurização rápida</rdfs:label>
        <rdfs:label xml:lang="en">rapid depressurization function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the rapid controlled release of process pressure to a safe disposal system to prevent catastrophic failure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de ventilação de segurança</rdfs:label>
        <rdfs:label xml:lang="en">safety venting function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the release of excess pressure from a process system to a safe disposal location.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de alívio de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure relief function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic release of process fluid when pressure exceeds a defined set point to protect equipment from overpressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceSafetyProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceSafetyProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de segurança subsuperficial</rdfs:label>
        <rdfs:label xml:lang="en">subsurface safety function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by a downhole safety valve whose realization constitutes the isolation of wellbore flow to prevent uncontrolled release of reservoir fluids to surface.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow indication function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de indicação de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the flow rate of a process stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de indicação de nível</rdfs:label>
        <rdfs:label xml:lang="en">level indication function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the fluid level within a vessel.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173 -->

