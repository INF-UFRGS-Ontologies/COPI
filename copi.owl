    <!-- https://spec.industrialontologies.org/ontology/annotation/abbreviation -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/abbreviation">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">abbreviation</rdfs:label>
        <skos:definition xml:lang="en-us">synonym that is an alternate short label for the resource</skos:definition>
