        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow measurement function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de medição de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000176 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000176">
