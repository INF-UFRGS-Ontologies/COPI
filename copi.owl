                                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/meets"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000202"/>
                                                    <owl:Restriction>
