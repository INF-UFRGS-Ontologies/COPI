                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transmissão de vibração</rdfs:label>
        <rdfs:label xml:lang="en">vibration transmission function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and remote transmission of mechanical vibration amplitude or frequency in rotating equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de aquecimento</rdfs:label>
        <rdfs:label xml:lang="en">heating function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the transfer of thermal energy to a process stream or vessel to raise its temperature.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de movimentação de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas movement function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the movement of a gas stream from a region of lower pressure to a region of higher pressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transmissão de potência</rdfs:label>
        <rdfs:label xml:lang="en">power transmission function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transfer mechanical energy from a prime mover to one or more driven machines, maintaining rotational motion while potentially modifying torque and speed characteristics.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from a prime mover through rotational motion or to generate energy when acting as a driven element.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from one mechanical component to another through rotational or linear motion.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical energy from an external energy source through rotational motion to downstream mechanical components.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical power from one shaft to another through direct mechanical coupling or engagement.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical rotational energy from a driving mechanism to driven components, enabling the transfer of torque and rotational motion through a mechanical system.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transfer mechanical energy from a prime mover to one or more driven machines, maintaining rotational motion while potentially modifying torque and speed characteristics.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from a prime mover through rotational motion or to generate energy when acting as a driven element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from one mechanical component to another through rotational or linear motion.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical energy from an external energy source through rotational motion to downstream mechanical components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical power from one shaft to another through direct mechanical coupling or engagement.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical rotational energy from a driving mechanism to driven components, enabling the transfer of torque and rotational motion through a mechanical system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricToMechanicalConversionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricToMechanicalConversionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electric to mechanical conversion function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de conversão elétrico-mecânica</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of electrical energy into rotational or linear mechanical motion.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">filtration function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de filtração</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a FiltrationProcess and that consists in selectively retaining particles, contaminants, or unwanted substances from a fluid stream while allowing the clean fluid to pass through.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FiltrationProcess and that consists in selectively retaining particles, contaminants, or unwanted substances from a fluid stream while allowing the clean fluid to pass through.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de separação</rdfs:label>
        <rdfs:label xml:lang="en">separation function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation of a mixed-phase or mixed-component stream into distinct phases or fractions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">coalescence function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de coalescência</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the merging of dispersed liquid droplets into a continuous liquid phase to facilitate their subsequent removal.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StorageProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StorageProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de armazenamento</rdfs:label>
        <rdfs:label xml:lang="en">storage function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the temporary or permanent containment of fluids or materials in a defined storage volume.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical power transformation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transformação de energia elétrica</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in changing the voltage and current levels of electrical power through electromagnetic induction while maintaining power transfer efficiency.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in converting electrical energy from one voltage level to another through electromagnetic induction, enabling power distribution and utilization at appropriate voltage levels.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in changing the voltage and current levels of electrical power through electromagnetic induction while maintaining power transfer efficiency.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in converting electrical energy from one voltage level to another through electromagnetic induction, enabling power distribution and utilization at appropriate voltage levels.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentInterruptionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentInterruptionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical current interruption function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de interrupção de corrente elétrica</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the interruption of electrical current flow in a circuit under normal operating or fault conditions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de proteção de sensor de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensor protection function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a TemperatureSensorProtectionProcess and that consists in providing a protective enclosure for temperature sensing elements while enabling thermal conductivity from the process medium to the sensor.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a TemperatureSensorProtectionProcess and that consists in providing a protective enclosure for temperature sensing elements while enabling thermal conductivity from the process medium to the sensor.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000205 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000205">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureSensor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VacuumReferenceeChamber"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">absolute pressure transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de pressão absoluta</rdfs:label>
        <skos:definition xml:lang="en">An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (AbsolutePressureTransmitter(x) → PressureTransmitter(x) ∧ ∃y (VacuumReferenceeChamber(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão absoluta é um transmissor de pressão que possui uma câmara de referência de vácuo de um lado do sensor de pressão enquanto o outro lado recebe a pressão do processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on vacuum reference chamber configuration. Under Open World Assumption, defining sufficient conditions could lead to unintended classification of complex instruments that contain vacuum chambers but serve different primary functions. The structural differentia is necessary but making it sufficient requires domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber as a component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">accumulator</rdfs:label>
        <rdfs:label xml:lang="pt-br">acumulador</rdfs:label>
        <skos:definition xml:lang="en">An accumulator is a vessel that has the designed function to accumulate (store and controllably release) energy or matter.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Accumulator(x) ↔ (Vessel(x) ∧ ∃f (AccumulationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An accumulator is a vessel that has the designed function to accumulate (store and controllably release) energy or matter.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um acumulador é um vaso que tem a função projetada de acumular (armazenar e liberar de forma controlada) energia ou matéria.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every accumulator is a vessel that bears an accumulation function</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">actuator</rdfs:label>
        <rdfs:label xml:lang="pt-br">atuador</rdfs:label>
        <skos:definition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Actuator(x) ↔ Assembly(x) ∧ ∃f (ActuationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador é um conjunto que possui uma função de atuação para converter energia de uma fonte externa em movimento cinético em resposta a sinais de controle.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every actuator is an assembly that has the function of converting external energy into controlled kinetic motion.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovingVane"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovingVane"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
        <rdfs:label xml:lang="en">agitator</rdfs:label>
        <skos:definition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000209 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000209">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:label xml:lang="en">air cooled heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor resfriado a ar</rdfs:label>
        <skos:definition xml:lang="en">An air cooled heat exchanger is a heat exchanger that has finned air cooling surfaces and uses ambient air as the cooling medium to transfer thermal energy from process fluids.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(AirCooledHeatExchanger(x) → HeatExchanger(x) ∧ ∃y(AirFinSystem(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(TubeBundle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃p(AirCoolingProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An air cooled heat exchanger is a heat exchanger that has finned air cooling surfaces and uses ambient air as the cooling medium to transfer thermal energy from process fluids.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor resfriado a ar é um trocador de calor que possui superfícies aletadas de resfriamento a ar e usa ar ambiente como meio de resfriamento para transferir energia térmica de fluidos de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Under the Open World Assumption, defining air cooling constructively as sufficient conditions could lead to false positives. Complex hybrid equipment or specialized configurations with air cooling components might be inappropriately classified. Starting with necessary conditions allows for proper validation by domain experts before upgrading to equivalence.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every air cooled heat exchanger is a heat exchanger that has component parts including an air fin system and tube bundle, and participates in air cooling processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154"/>
        <rdfs:label xml:lang="en">analogue temperature indicator</rdfs:label>
        <rdfs:label xml:lang="pt-br">indicador analógico de temperatura</rdfs:label>
        <skos:definition xml:lang="en">An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (AnalogueTemperatureIndicator(x) ↔ Instrument(x) ∧ ∃f(TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃d(AnalogueDial(d) ∧ hasComponentPartAtAllTimes(x,d)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador analógico de temperatura é um instrumento que possui uma função de indicação de temperatura e tem um mostrador analógico para exibição visual da temperatura.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every analogue temperature indicator is an instrument that bears a temperature indication function and has component parts including a temperature sensor, analogue dial, and indicator pointer.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000211 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000211">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">angle valve body</rdfs:label>
        <rdfs:label xml:lang="pt-br">corpo de válvula angular</rdfs:label>
        <skos:definition xml:lang="en">A ValveBody that has an internal flow path geometry where the inlet and outlet axes are positioned at an angle to each other, creating an L-shaped or angled flow configuration.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (AngleValveBody(x) → ValveBody(x) ∧ ∃g (AngularFlowPath(g) ∧ hasGeometry(x,g)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A ValveBody that has an internal flow path geometry where the inlet and outlet axes are positioned at an angle to each other, creating an L-shaped or angled flow configuration.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um ValveBody que possui uma geometria de caminho de fluxo interno onde os eixos de entrada e saída são posicionados em ângulo um em relação ao outro, criando uma configuração de fluxo em formato de L ou angular.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on geometric configuration. Under OWA, sufficient conditions for geometric characteristics like &apos;angular flow path&apos; are difficult to specify precisely without detailed geometric constraints that could lead to false classification of complex multi-path valve bodies or hybrid designs.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">AngleValveBody subClassOf ValveBody and hasGeometry some AngularFlowPath</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000212 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000212">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">anode</rdfs:label>
        <rdfs:label xml:lang="pt-br">ânodo</rdfs:label>
        <skos:definition xml:lang="en">An anode is electrical equipment that bears the function of serving as the positive electrode in electrochemical processes, capable of emitting positive charge carriers to and/or receiving negative charge carriers from a medium of lower conductivity.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Anode(x) ↔ ElectricalEquipment(x) ∧ ∃f(AnodeFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An anode is electrical equipment that bears the function of serving as the positive electrode in electrochemical processes, capable of emitting positive charge carriers to and/or receiving negative charge carriers from a medium of lower conductivity.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um ânodo é um equipamento elétrico que possui a função de servir como eletrodo positivo em processos eletroquímicos, capaz de emitir portadores de carga positiva para e/ou receber portadores de carga negativa de um meio de menor condutividade.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every anode is electrical equipment that has the function of electrochemical oxidation and has electrical connection and active material as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000213 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000213">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">axial displacement transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de deslocamento axial</rdfs:label>
        <skos:definition xml:lang="en">An axial displacement transmitter is a transmitter that measures axial displacement and generates a standardized output signal representing the measured axial displacement.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(AxialDisplacementTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(AxialDisplacementTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(AxialDisplacementMeasuringProbe(p) ∧ hasComponentPartAtAllTimes(x,p))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An axial displacement transmitter is a transmitter that measures axial displacement and generates a standardized output signal representing the measured axial displacement.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de deslocamento axial é um transmissor que mede deslocamento axial e gera um sinal de saída padronizado representando o deslocamento axial medido.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every axial displacement transmitter is a transmitter that has the function to measure axial displacement and has as component part an axial displacement measuring probe.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000214 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000214">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bacia</rdfs:label>
        <rdfs:label xml:lang="en">basin</rdfs:label>
        <skos:definition xml:lang="en">A basin is a vessel that is designed to store liquid or solid material, characterized by being typically open at the top and installed partly or totally below grade.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000214"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">Basin(x) ↔ Vessel(x) ∧ ∃f(StorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(OpenTop(p) ∧ hasGeometricProperty(x,p)) ∧ ∃q(PartlyBelowGrade(q) ∧ hasInstallationProperty(x,q))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A basin is a vessel that is designed to store liquid or solid material, characterized by being typically open at the top and installed partly or totally below grade.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bacia é um vaso projetado para armazenar material líquido ou sólido, caracterizado por ser tipicamente aberto no topo e instalado parcial ou totalmente abaixo do nível do solo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every basin is a vessel that bears a storage function and has an open top configuration and is installed partly below grade.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bearing</rdfs:label>
        <rdfs:label xml:lang="pt-br">mancal</rdfs:label>
        <skos:definition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Bearing(x) ↔ MaterialArtifact(x) ∧ ∃f(SupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(FrictionReductionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um mancal é um artefato material que é projetado para suportar e localizar elementos mecânicos móveis ou estáticos enquanto reduz o atrito na conexão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every bearing is a material artifact that bears a support function and participates in friction reduction processes</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SideOutlet"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SideOutlet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bell nipple</rdfs:label>
        <rdfs:label xml:lang="pt-br">bell nipple</rdfs:label>
        <skos:definition xml:lang="en">A bell nipple is a pipe that conducts drilling fluids in drilling operations and is characterized by an enlarged diameter that serves as a funnel and a location at the wellhead assembly.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BellNipple(x) ↔ (Pipe(x) ∧ ∃f(DrillingFluidConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(EnlargedDiameter(s) ∧ hasCharacteristicShape(x,s)) ∧ ∃l(WellheadAssembly(l) ∧ hasLocation(x,l))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A bell nipple is a pipe that conducts drilling fluids in drilling operations and is characterized by an enlarged diameter that serves as a funnel and a location at the wellhead assembly.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um bell nipple é um tubo que conduz fluidos de perfuração em operações de perfuração e é caracterizado por um diâmetro alargado que serve como funil e uma localização no conjunto da cabeça do poço.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every bell nipple is a pipe that bears a DrillingFluidConductionFunction and has an enlarged diameter shape and is located at a wellhead assembly.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000217 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000217">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BoilingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BoilingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">boiler</rdfs:label>
        <rdfs:label xml:lang="pt-br">caldeira</rdfs:label>
        <skos:definition xml:lang="en">A boiler is a heater that brings a liquid to its boiling point through indirect contact heat exchange, producing steam or vapor.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Boiler(x) ↔ Heater(x) ∧ ∃f(BoilingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A boiler is a heater that brings a liquid to its boiling point through indirect contact heat exchange, producing steam or vapor.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma caldeira é um aquecedor que leva um líquido ao seu ponto de ebulição através de troca de calor por contato indireto, produzindo vapor.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every boiler is a heater that bears a BoilingFunction and has component parts including a steam drum and heat exchange surface.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000218 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000218">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillBit"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillBit"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bottom hole assembly</rdfs:label>
        <rdfs:label xml:lang="pt-br">conjunto de fundo de poço</rdfs:label>
        <skos:definition xml:lang="en">A bottom hole assembly is a drilling component that performs specialized drilling operations at the bottom of the drill string, characterized by including a drill bit and being positioned at the bottom hole location.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BottomHoleAssembly(x) ↔ DrillingComponent(x) ∧ ∃y(DrillBit(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(BottomHoleLocation(z) ∧ locatedAt(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A bottom hole assembly is a drilling component that performs specialized drilling operations at the bottom of the drill string, characterized by including a drill bit and being positioned at the bottom hole location.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um conjunto de fundo de poço é um componente de perfuração que realiza operações especializadas de perfuração na parte inferior da coluna de perfuração, caracterizado por incluir uma broca e estar posicionado no local do fundo do poço.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every bottom hole assembly is a drilling component that has a drill bit as component part at all times and is located at bottom hole location.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BrakingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BrakingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">brake</rdfs:label>
        <rdfs:label xml:lang="pt-br">freio</rdfs:label>
        <skos:definition xml:lang="en">A brake is an assembly that bears a braking function to arrest or prevent the motion of an object, typically through friction or electromagnetic force application.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Brake(x) ↔ (Assembly(x) ∧ ∃f(BrakingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A brake is an assembly that bears a braking function to arrest or prevent the motion of an object, typically through friction or electromagnetic force application.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um freio é um conjunto que possui uma função de frenagem para deter ou prevenir o movimento de um objeto, tipicamente através da aplicação de força de atrito ou eletromagnética.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every brake is an assembly that has the function of braking, and every assembly that has the function of braking is a brake.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CombustionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CombustionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">burner</rdfs:label>
        <rdfs:label xml:lang="pt-br">queimador</rdfs:label>
        <skos:definition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Burner(x) ↔ (Heater(x) ∧ ∃f (CombustionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um queimador é um aquecedor que libera energia térmica através da queima de uma mistura combustível de combustível e ar.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every burner is a heater that has the function of combustion, which is realized by burning a fuel-air mixture to release thermal energy.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000221 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000221">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RaisedEdge"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableSupportFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RaisedEdge"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableSupportFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bandeja de cabos</rdfs:label>
        <rdfs:label xml:lang="en">cable tray</rdfs:label>
        <skos:definition xml:lang="en">A cable tray is an assembly that bears a cable support function and consists of a continuous base with raised edges, forming a rigid structural system for securely supporting and routing electrical cables.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CableTray(x) ↔ Assembly(x) ∧ ∃f(CableSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ContinuousBase(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃e(RaisedEdge(e) ∧ hasComponentPartAtAllTimes(x,e)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A cable tray is an assembly that bears a cable support function and consists of a continuous base with raised edges, forming a rigid structural system for securely supporting and routing electrical cables.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bandeja de cabos é um conjunto que possui função de suporte de cabos e consiste em uma base contínua com bordas elevadas, formando um sistema estrutural rígido para suportar e rotear cabos elétricos de forma segura.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every cable tray is an assembly that has the function to support cables and has a continuous base part and raised edge parts.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">casing</rdfs:label>
        <rdfs:label xml:lang="pt-br">casing</rdfs:label>
        <skos:definition xml:lang="en">A casing is an assembly that provides structural enclosure with pressure containment capability, characterized by walls that separate internal components or fluids from the external environment.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Casing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(CasingWall(w) ∧ hasComponentPartAtAllTimes(x,w)) ∧ ∃p(PressureContainmentFunction(p) ∧ hasFunction(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A casing is an assembly that provides structural enclosure with pressure containment capability, characterized by walls that separate internal components or fluids from the external environment.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um casing é um conjunto que fornece invólucro estrutural com capacidade de contenção de pressão, caracterizado por paredes que separam componentes internos ou fluidos do ambiente externo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on structural configuration. Under OWA, sufficient conditions for enclosure structure could lead to over-classification of complex assemblies that contain enclosure elements but serve different primary functions (e.g., pressure vessels, housings, containers).</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every casing is an assembly that has an enclosure function and has component part some casing wall and has function some pressure containment function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000223 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000223">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionFunction"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000212"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000212"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cathodic protection system</rdfs:label>
        <rdfs:label xml:lang="pt-br">sistema de proteção catódica</rdfs:label>
        <skos:definition xml:lang="en">A cathodic protection system is a corrosion protection system that uses electrochemical cathodic protection mechanisms with anodes to prevent corrosion of carbon and low-alloy steel equipment or structures.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CathodicProtectionSystem(x) ↔ CorrosionProtectionSystem(x) ∧ ∃f(CathodicProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃a(Anode(a) ∧ hasComponentPartAtSomeTime(x,a)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A cathodic protection system is a corrosion protection system that uses electrochemical cathodic protection mechanisms with anodes to prevent corrosion of carbon and low-alloy steel equipment or structures.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um sistema de proteção catódica é um sistema de proteção contra corrosão que usa mecanismos eletroquímicos de proteção catódica com ânodos para prevenir a corrosão de equipamentos ou estruturas de aço carbono e baixa liga.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every cathodic protection system is a corrosion protection system that bears a cathodic protection function and has anodes as component parts.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000224 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000224">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
        <rdfs:label xml:lang="en">centrifugal compressor casing</rdfs:label>
        <rdfs:label xml:lang="pt-br">invólucro</rdfs:label>
        <skos:definition xml:lang="en">A casing that is specifically designed and dimensioned for structural compatibility with centrifugal compressor mechanisms, providing enclosure and protection for rotating impellers and associated flow components.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalCompressorCasing(x) → Casing(x) ∧ ∃y(CentrifugalCompressor(y) ∧ intendedFor(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A casing that is specifically designed and dimensioned for structural compatibility with centrifugal compressor mechanisms, providing enclosure and protection for rotating impellers and associated flow components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que é especificamente projetado e dimensionado para compatibilidade estrutural com mecanismos de compressor centrífugo, fornecendo contenção e proteção para impulsores rotativos e componentes de fluxo associados.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by structural compatibility. Under OWA, asserting equivalence could force classification of any casing with centrifugal compressor compatibility, including hybrid or specialized equipment that should not be automatically classified as standard centrifugal compressor casings.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal compressor casing is a casing that is intended for use with centrifugal compressors</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000225 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000225">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:label xml:lang="en">centrifuge</rdfs:label>
        <rdfs:label xml:lang="pt-br">centrífuga</rdfs:label>
        <skos:definition xml:lang="en">A centrifuge is a separator that uses centrifugal force generated by a rotating drum to separate phases of different densities.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Centrifuge(x) → Separator(x) ∧ ∃d (RotatingDrum(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p (CentrifugalForceProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A centrifuge is a separator that uses centrifugal force generated by a rotating drum to separate phases of different densities.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma centrífuga é um separador que usa força centrífuga gerada por um tambor rotativo para separar fases de diferentes densidades.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Although functionally defined as a separator, the constructive differentia (centrifugal mechanism) makes sufficient conditions complex under OWA. Any equipment with a rotating drum could potentially be classified as a centrifuge even if designed for other purposes (mixing, drying, etc.). Starting with necessary conditions protects against false positives.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifuge is a separator that has a rotating drum as component part and participates in centrifugal force processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">check valve body</rdfs:label>
        <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
        <skos:definition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveBody(x) → ValveBody(x) ∧ ∃y(CheckValve(y) ∧ designedFor(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que é especificamente projetado para acomodar e alojar os mecanismos internos de uma válvula de retenção dentro de uma barreira de contenção de pressão.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive identity based on structural design for check valve accommodation. Under OWA, any housing designed for check valves could include specialized configurations, custom manifolds, or hybrid designs that should not be automatically classified as standard check valve bodies without domain expert validation of the structural differentia.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">CheckValveBody subClassOf ValveBody and (designedFor some CheckValve)</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000227 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000227">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">check valve closure member</rdfs:label>
        <rdfs:label xml:lang="pt-br">membro de fechamento de válvula de retenção</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that is a component part of a check valve and that bears a BackflowPreventionFunction, consisting in a mechanical element that prevents fluid flow reversal by physically blocking the flow path when pressure conditions indicate potential backflow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveClosureMember(x) → MaterialArtifact(x) ∧ ∃y(CheckValve(y) ∧ isComponentPartOf(x,y)) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is a component part of a check valve and that bears a BackflowPreventionFunction, consisting in a mechanical element that prevents fluid flow reversal by physically blocking the flow path when pressure conditions indicate potential backflow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é uma parte componente de uma válvula de retenção e que possui uma BackflowPreventionFunction, consistindo em um elemento mecânico que previne o refluxo de fluido bloqueando fisicamente o caminho de fluxo quando as condições de pressão indicam potencial refluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by structural role and mechanism. Under OWA, sufficient conditions would force classification of any artifact with backflow prevention function and check valve association, potentially including hybrid or specialized designs that should not be automatically classified as standard closure members without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every check valve closure member is a MaterialArtifact that is component part of some check valve and bears some BackflowPreventionFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000228 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000228">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MasterValve"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WingValve"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MasterValve"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WingValve"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">christmas tree</rdfs:label>
        <rdfs:label xml:lang="pt-br">árvore de natal</rdfs:label>
        <skos:definition xml:lang="en">A christmas tree is an assembly that bears a well fluid control function, is connected to a wellhead, and contains master valves for controlling formation fluids from oil and gas wells.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000228"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ChristmasTree(x) ↔ (Assembly(x) ∧ ∃f(WellFluidControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ hasComponentPartAtAllTimes(x,w)) ∧ ∃v(MasterValve(v) ∧ hasComponentPartAtAllTimes(x,v))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A christmas tree is an assembly that bears a well fluid control function, is connected to a wellhead, and contains master valves for controlling formation fluids from oil and gas wells.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma árvore de natal é um conjunto que possui uma função de controle de fluidos de poço, está conectada a uma cabeça de poço, e contém válvulas mestras para controlar fluidos de formação de poços de petróleo e gás.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every christmas tree is an assembly that has the function to control well fluids and is connected to a wellhead and has master valves as component parts.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000229 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000229">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">chromatograph</rdfs:label>
        <rdfs:label xml:lang="pt-br">cromatógrafo</rdfs:label>
        <skos:definition xml:lang="en">A chromatograph is a process analyzer that bears a chromatographic analysis function.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Chromatograph(x) ↔ ProcessAnalyzer(x) ∧ ∃f (ChromatographicAnalysisFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A chromatograph is a process analyzer that bears a chromatographic analysis function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um cromatógrafo é um analisador de processo que possui uma função de análise cromatográfica.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every chromatograph is a process analyzer that has the function of chromatographic analysis.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000230 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000230">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">compensador</rdfs:label>
        <rdfs:label xml:lang="en">compensator</rdfs:label>
        <skos:definition xml:lang="en">A compensator is a material artifact that has the designed function of compensating for axial or radial movement between two connected elements.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Compensator(x) ↔ MaterialArtifact(x) ∧ ∃f(MovementCompensationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A compensator is a material artifact that has the designed function of compensating for axial or radial movement between two connected elements.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um compensador é um artefato material que tem a função projetada de compensar movimento axial ou radial entre dois elementos conectados.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every compensator is a material artifact that bears a movement compensation function and has component parts including a compensation mechanism and connection interfaces.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
        <rdfs:label xml:lang="pt-br">Invólucro</rdfs:label>
        <rdfs:label xml:lang="en">compressor casing</rdfs:label>
        <skos:definition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (CompressorCasing(x) → (Casing(x) ∧ ∃y (Compressor(y) ∧ intendedForUseWith(x,y))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Invólucro que é destinado a abrigar componentes internos do compressor, incluindo o eixo com impulsores e outros componentes mecânicos específicos do compressor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, sufficient conditions for compressor-specific casing identity could lead to false positives where any enclosure intended for compressors might be classified as a standard compressor casing, including specialized or hybrid enclosures that warrant distinct classification.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">CompressorCasing ⊑ Casing ⊓ ∃intendedForUseWith.Compressor</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000232 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000232">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">condensador</rdfs:label>
        <rdfs:label xml:lang="en">condenser</rdfs:label>
        <skos:definition xml:lang="en">A condenser is a heat exchanger that bears a designed function to condense vapor to liquid by removing latent heat of vaporization.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Condenser(x) ↔ (HeatExchanger(x) ∧ ∃f(CondensationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A condenser is a heat exchanger that bears a designed function to condense vapor to liquid by removing latent heat of vaporization.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um condensador é um trocador de calor que possui uma função projetada para condensar vapor em líquido removendo o calor latente de vaporização.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every condenser is a heat exchanger that bears a condensation function, and every heat exchanger that bears a condensation function is a condenser.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000233 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000233">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">conductivity transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de condutividade</rdfs:label>
        <skos:definition xml:lang="en">A conductivity transmitter is a transmitter that bears a conductivity measurement function.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ConductivityTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(ConductivityMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A conductivity transmitter is a transmitter that bears a conductivity measurement function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de condutividade é um transmissor que possui uma função de medição de condutividade.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every conductivity transmitter is a transmitter that has the function to measure and transmit electrical conductivity of process fluids.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000234 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000234">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">controlador</rdfs:label>
        <rdfs:label xml:lang="en">controller</rdfs:label>
        <skos:definition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Controller(x) ↔ Instrument(x) ∧ ∃f(ControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um controlador é um instrumento que possui uma função de controle, regulando automaticamente uma variável controlada ao medi-la, comparar com um valor de referência e gerar sinais de saída para reduzir o desvio.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every controller is an instrument that has the function to control a process variable by automatic feedback regulation</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cooler</rdfs:label>
        <rdfs:label xml:lang="pt-br">resfriador</rdfs:label>
        <skos:definition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Cooler(x) ↔ HeatExchanger(x) ∧ ∃f (CoolingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um resfriador é um trocador de calor que possui uma FunçãoDeResfriamento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooler is a heat exchanger that has the function of cooling.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235"/>
        <rdfs:label xml:lang="en">cooling tower</rdfs:label>
        <rdfs:label xml:lang="pt-br">torre de resfriamento</rdfs:label>
        <skos:definition xml:lang="en">A cooling tower is a heat exchanger that incorporates a tall tower structure through which air circulates by convection to remove heat from process fluids.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CoolingTower(x) ↔ HeatExchanger(x) ∧ ∃t(Tower(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(ConvectiveAirCirculationProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A cooling tower is a heat exchanger that incorporates a tall tower structure through which air circulates by convection to remove heat from process fluids.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma torre de resfriamento é um trocador de calor que incorpora uma estrutura de torre alta através da qual o ar circula por convecção para remover calor de fluidos de processo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooling tower is a heat exchanger that has a tower structure as component part at all times and participates in convective air circulation processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000237 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000237">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278"/>
        <rdfs:label xml:lang="en">coriolis mass flow meter</rdfs:label>
        <rdfs:label xml:lang="pt-br">medidor de vazão Coriolis</rdfs:label>
        <skos:definition xml:lang="en">A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CoriolisMassFlowMeter(x) → FlowMeter(x) ∧ ∃y(CoriolisFlowTube(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CoriolisPrinciple(z) ∧ utilizesPhysicalPrinciple(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão que utiliza o princípio de Coriolis através de tubos de fluxo oscilantes especializados para medir diretamente a vazão mássica de fluidos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under the Open World Assumption, defining sufficient conditions based on Coriolis principle usage could lead to false positives where other devices using Coriolis forces (like gyroscopes or accelerometers) might be incorrectly classified as flow meters. The structural differentia provides necessary conditions that can be validated by domain experts.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every coriolis mass flow meter is a flow meter that has component part at all times some Coriolis flow tube and utilizes the Coriolis principle.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">acoplamento</rdfs:label>
        <rdfs:label xml:lang="en">coupling</rdfs:label>
        <skos:definition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Coupling(x) ↔ MaterialArtifact(x) ∧ ∃f(ConnectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um acoplamento é um artefato material que possui uma função de conexão para unir partes ou sistemas separados.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every coupling is a material artifact that has the function to connect separate parts or systems together.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000239 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000239">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DampingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DampingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">amortecedor</rdfs:label>
        <rdfs:label xml:lang="en">damper</rdfs:label>
        <skos:definition xml:lang="en">A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Damper(x) ↔ (Assembly(x) ∧ ∃f (DampingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um amortecedor é um conjunto que possui a função projetada de suprimir, regular ou reduzir características dinâmicas desfavoráveis como vibrações, flutuações de pressão ou distúrbios de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every damper is an assembly that bears a damping function, and every assembly that bears a damping function is a damper.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000240 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000240">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DeaerationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DeaerationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">deaerator</rdfs:label>
        <rdfs:label xml:lang="pt-br">desaerador</rdfs:label>
        <skos:definition xml:lang="en">A deaerator is a separator designed to remove dissolved gases from liquid streams through specialized degassing processes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Deaerator(x) ↔ (Separator(x) ∧ ∃f(DeaerationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A deaerator is a separator designed to remove dissolved gases from liquid streams through specialized degassing processes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um desaerador é um separador projetado para remover gases dissolvidos de correntes líquidas através de processos especializados de desgaseificação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every deaerator is a separator that bears a deaeration function for removing dissolved gases from liquids</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000241 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000241">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">degaseificador</rdfs:label>
        <rdfs:label xml:lang="en">degasser</rdfs:label>
        <skos:definition xml:lang="en">A degasser is a separator that removes gases from drilling fluids by realizing a degassing function.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Degasser(x) ↔ (Separator(x) ∧ ∃f (DegassingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A degasser is a separator that removes gases from drilling fluids by realizing a degassing function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um degaseificador é um separador que remove gases de fluidos de perfuração realizando uma função de degaseificação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every degasser is a separator that bears a degassing function and has drilling fluid as input and degassed drilling fluid plus separated gases as outputs.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dehumidifier</rdfs:label>
        <rdfs:label xml:lang="pt-br">desumidificador</rdfs:label>
        <skos:definition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um desumidificador é um conjunto que possui a função de remover umidade do ar.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehumidifier is an assembly that has the function to perform dehumidification.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dehydrator</rdfs:label>
        <rdfs:label xml:lang="pt-br">desidratador</rdfs:label>
        <skos:definition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehydrator is a separator that has the function of dehydration.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000244 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000244">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">demister</rdfs:label>
        <rdfs:label xml:lang="pt-br">demister</rdfs:label>
        <skos:definition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Demister(x) ↔ Separator(x) ∧ ∃f(DemistingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um demister é um separador que possui uma função de desmistificação para remover gotículas de líquido de correntes gasosas através de mecanismos de coalescência.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every demister is a separator that has the function of demisting gas streams by coalescing and removing entrained liquid droplets.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">densitometer</rdfs:label>
        <rdfs:label xml:lang="pt-br">densitômetro</rdfs:label>
        <skos:definition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um densitômetro é um instrumento que possui uma função de medição de densidade.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every densitometer is an instrument that has the function of measuring density.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SensingElement"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SensingElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">detector</rdfs:label>
        <rdfs:label xml:lang="pt-br">detector</rdfs:label>
        <skos:definition xml:lang="en">A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Detector(x) ↔ Instrument(x) ∧ ∃f(DetectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um detector é um instrumento que possui uma função de detecção, permitindo-lhe detectar estados, substâncias ou fenômenos e produzir sinais baseados na detecção.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every detector is an instrument that has a detection function and has component parts including a sensing element and signal generation device.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000247 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000247">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">analisador de ponto de orvalho</rdfs:label>
        <rdfs:label xml:lang="en">dew point analyser</rdfs:label>
        <skos:definition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(DewPointAnalyser(x) ↔ Instrument(x) ∧ ∃f(DewPointMeasurementFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um analisador de ponto de orvalho é um instrumento que possui uma função de medição de ponto de orvalho.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every dew point analyser is an instrument that has the function to determine the dew point of a substance</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000248 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000248">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
        <rdfs:label xml:lang="pt-br">atuador de diafragma</rdfs:label>
        <rdfs:label xml:lang="en">diaphragm actuator</rdfs:label>
        <skos:definition xml:lang="en">A diaphragm actuator is an actuator that uses a diaphragm as an essential component for converting control signals into mechanical motion or force to operate other equipment.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(DiaphragmActuator(x) → (Actuator(x) ∧ ∃y(Diaphragm(y) ∧ hasComponentPartAtAllTimes(x,y))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A diaphragm actuator is an actuator that uses a diaphragm as an essential component for converting control signals into mechanical motion or force to operate other equipment.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador de diafragma é um atuador que utiliza um diafragma como componente essencial para converter sinais de controle em movimento mecânico ou força para operar outros equipamentos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Classification basis is constructive - identity given by diaphragm mechanism. Under OWA, sufficient conditions would force any equipment with a diaphragm component to be classified as a diaphragm actuator, potentially including complex hybrid systems or custom equipment where the diaphragm serves auxiliary functions. Starting with necessary conditions protects against such false positives.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">DiaphragmActuator ⊑ Actuator ⊓ ∃hasComponentPartAtAllTimes.Diaphragm</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000249 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000249">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlexibleDiaphragm"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba de diafragma</rdfs:label>
        <rdfs:label xml:lang="en">diaphragm pump</rdfs:label>
        <skos:definition xml:lang="en">A diaphragm pump is a reciprocating pump that uses flexible diaphragms to displace liquid and seal the pumped fluid from atmospheric leakage.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(DiaphragmPump(x) → (ReciprocatingPump(x) ∧ ∃d(FlexibleDiaphragm(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p(DiaphragmSealing(p) ∧ participatesIn(x,p))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A diaphragm pump is a reciprocating pump that uses flexible diaphragms to displace liquid and seal the pumped fluid from atmospheric leakage.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de diafragma é uma bomba alternativa que usa diafragmas flexíveis para deslocar líquido e selar o fluido bombeado contra vazamento atmosférico.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under OWA, any pump with a flexible diaphragm component could be classified as a diaphragm pump, but there may be hybrid or specialized equipment containing diaphragms that should not be automatically classified into this maintenance category.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every diaphragm pump is a reciprocating pump that has flexible diaphragm as component part at all times and participates in diaphragm sealing.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000250 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000250">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Piston"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diesel engine</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor diesel</rdfs:label>
        <skos:definition xml:lang="en">A diesel engine is an engine that ignites fuel through compression heat rather than spark ignition, requiring compression ignition and fuel injection systems.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">DieselEngine(x) → Engine(x) ∧ ∃s(CompressionIgnitionSystem(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f(FuelInjectionSystem(f) ∧ hasComponentPartAtAllTimes(x,f)) ∧ ∃p(CompressionIgnitionProcess(p) ∧ participatesIn(x,p))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A diesel engine is an engine that ignites fuel through compression heat rather than spark ignition, requiring compression ignition and fuel injection systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor diesel é um motor que inflama combustível através do calor de compressão em vez de ignição por centelha, requerendo sistemas de ignição por compressão e injeção de combustível.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While compression ignition is characteristic of diesel engines, under OWA we cannot be certain that any engine with compression ignition systems is necessarily a diesel engine - there could be hybrid or specialized engines with similar mechanisms that should not be auto-classified as standard diesel engines without expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">A diesel engine is necessarily an engine that has compression ignition system and fuel injection system and participates in compression ignition process.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">differential pressure measuring element</rdfs:label>
        <rdfs:label xml:lang="pt-br">elemento medidor de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A pressure element that bears a differential pressure measurement function and that consists in sensing the pressure difference between two fluid media or connection points to enable measurement of differential pressure through mechanical deflection proportional to the pressure difference.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(DifferentialPressureMeasuringElement(x) ↔ (PressureElement(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure element that bears a differential pressure measurement function and that consists in sensing the pressure difference between two fluid media or connection points to enable measurement of differential pressure through mechanical deflection proportional to the pressure difference.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão que porta uma função de medição de pressão diferencial e que consiste em detectar a diferença de pressão entre duas mídias fluidas ou pontos de conexão para permitir a medição de pressão diferencial através de deflexão mecânica proporcional à diferença de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">DifferentialPressureMeasuringElement equivalentTo PressureElement and bearerOf some DifferentialPressureMeasurementFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000252 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000252">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">differential pressure switch</rdfs:label>
        <rdfs:label xml:lang="pt-br">interruptor de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A differential pressure switch is a pressure switch that bears a differential pressure switching function to switch or provide on/off signals when the measured differential pressure between two inputs reaches a pre-set value.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(DifferentialPressureSwitch(x) ↔ PressureSwitch(x) ∧ ∃f(DifferentialPressureSwitchingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A differential pressure switch is a pressure switch that bears a differential pressure switching function to switch or provide on/off signals when the measured differential pressure between two inputs reaches a pre-set value.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de pressão diferencial é um interruptor de pressão que possui uma função de comutação de pressão diferencial para comutar ou fornecer sinais liga/desliga quando a pressão diferencial medida entre duas entradas atinge um valor pré-estabelecido.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure switch is a pressure switch that has the function to switch based on differential pressure measurements between two pressure inputs.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000253 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000253">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivergingChannel"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivergingChannel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diffuser</rdfs:label>
        <rdfs:label xml:lang="pt-br">difusor</rdfs:label>
        <skos:definition xml:lang="en">A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Diffuser(x) ↔ Assembly(x) ∧ ∃f(EnergyDiffusionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um difusor é um conjunto que tem a função projetada de converter energia cinética do fluxo de fluido em energia de pressão através de desaceleração controlada em uma passagem divergente.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every diffuser is an assembly that bears an energy diffusion function and has a diverging channel as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000254 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000254">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">display</rdfs:label>
        <rdfs:label xml:lang="pt-br">display</rdfs:label>
        <skos:definition xml:lang="en">A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Display(x) ↔ Instrument(x) ∧ ∃f(InformationDisplayFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Display é um Instrumento que possui uma InformationDisplayFunction e que apresenta informações visualmente para operadores ou usuários.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Display is an Instrument that necessarily bears an InformationDisplayFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">coluna de destilação</rdfs:label>
        <rdfs:label xml:lang="en">distillation column</rdfs:label>
        <skos:definition xml:lang="en">A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DistillationColumn(x) ↔ (Separator(x) ∧ ∃f (DistillationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de destilação é um separador que possui uma função de destilação para permitir a separação de misturas de fluidos baseada nas diferenças dos pontos de ebulição dos componentes através do equilíbrio vapor-líquido.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every distillation column is a separator that has the function to perform distillation processes</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000256 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000256">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivertingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivertingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diverter</rdfs:label>
        <rdfs:label xml:lang="pt-br">diverter</rdfs:label>
        <skos:definition xml:lang="en">A diverter is a material artifact that bears a designed function to divert or redirect materials, fluids, or flows from their expected course to alternative paths or destinations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Diverter(x) ↔ MaterialArtifact(x) ∧ ∃f(DivertingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A diverter is a material artifact that bears a designed function to divert or redirect materials, fluids, or flows from their expected course to alternative paths or destinations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um diverter é um artefato material que possui uma função projetada para desviar ou redirecionar materiais, fluidos ou fluxos de seu curso esperado para caminhos ou destinos alternativos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every diverter is a material artifact that has the function of diverting materials or flows from expected paths to alternative destinations.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">drive shaft</rdfs:label>
        <rdfs:label xml:lang="pt-br">eixo de transmissão</rdfs:label>
        <skos:definition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DriveShaft(x) ↔ (Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(RotationalPowerTransferProcess(p) ∧ participatesIn(x,p))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um eixo de transmissão é um Assembly que possui uma PowerTransmissionFunction e consiste em um sistema baseado em eixo usado para transferir energia mecânica rotacional de um motor primário para múltiplas máquinas acionadas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">DriveShaft ≡ Assembly ⊓ ∃bearerOf.PowerTransmissionFunction ⊓ ∃participatesIn.RotationalPowerTransferProcess</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000258 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000258">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DryingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DryingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dryer</rdfs:label>
        <rdfs:label xml:lang="pt-br">secador</rdfs:label>
        <skos:definition xml:lang="en">A dryer is an assembly that bears a drying function to remove moisture from materials.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Dryer(x) ↔ Assembly(x) ∧ ∃f(DryingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A dryer is an assembly that bears a drying function to remove moisture from materials.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um secador é um conjunto que possui uma função de secagem para remover umidade de materiais.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every dryer is an assembly that has the function of drying materials by removing moisture.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000259 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000259">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SuctionInlet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">eductor</rdfs:label>
        <rdfs:label xml:lang="pt-br">edutor</rdfs:label>
        <skos:definition xml:lang="en">An eductor is a pump that uses a high-pressure motive fluid jet to create a low-pressure zone that entrains and moves a second fluid via momentum transfer.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Eductor(x) → Pump(x) ∧ ∃n(MotiveFluidNozzle(n) ∧ hasComponentPartAtAllTimes(x,n)) ∧ ∃t(VenturaThroat(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(JetEntrainmentProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An eductor is a pump that uses a high-pressure motive fluid jet to create a low-pressure zone that entrains and moves a second fluid via momentum transfer.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um edutor é uma bomba que usa um jato de fluido motriz de alta pressão para criar uma zona de baixa pressão que arrasta e move um segundo fluido via transferência de momento.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">The constructive differentia based on jet entrainment mechanism could potentially apply to hybrid or specialized equipment that incorporates eductor principles but should not be automatically classified as a standard eductor type. Under OWA, necessary conditions protect against false positive classifications.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every eductor is a pump that has a motive fluid nozzle and Ventura throat as component parts and participates in a jet entrainment process.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
        <rdfs:label xml:lang="pt-br">atuador elétrico</rdfs:label>
        <rdfs:label xml:lang="en">electric actuator</rdfs:label>
        <skos:definition xml:lang="en">An electric actuator is an actuator that converts electrical energy to mechanical movement through an electric-to-mechanical converter component and operates via electrical signal input.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ElectricActuator(x) → Actuator(x) ∧ ∃y(ElectricToMechanicalConverter(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ElectricalSignal(z) ∧ hasInput(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An electric actuator is an actuator that converts electrical energy to mechanical movement through an electric-to-mechanical converter component and operates via electrical signal input.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador elétrico é um atuador que converte energia elétrica em movimento mecânico através de um componente conversor elétrico-mecânico e opera via entrada de sinal elétrico.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on electrical energy conversion mechanism. Under OWA, asserting equivalence would force any artifact with electrical-to-mechanical conversion into this category, potentially misclassifying specialized hybrid equipment or complex electrical machinery that should not be categorized as standard actuators.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric actuator is an actuator that has an electric-to-mechanical converter component at all times and has electrical signal input.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000261 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000261">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electric generator</rdfs:label>
        <rdfs:label xml:lang="pt-br">gerador elétrico</rdfs:label>
        <skos:definition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ElectricGenerator(x) ↔ (Assembly(x) ∧ ∃f(ElectricEnergyGenerationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um gerador elétrico é um conjunto que possui a função de converter energia não-elétrica em energia elétrica</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric generator is an assembly that has the function to convert non-electric energy into electric energy</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">conexão elétrica</rdfs:label>
        <rdfs:label xml:lang="en">electrical connection</rdfs:label>
        <skos:definition xml:lang="en">An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnection(x) ↔ (MaterialArtifact(x) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ElectricalConductionProcess(p) ∧ participatesIn(x,p) ∧ ∃y(ElectricalApparatus(y) ∧ has_participant_at_some_time(p,y)))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma conexão elétrica é um MaterialArtifact que possui uma ElectricalConductionFunction e que fornece um caminho para a corrente elétrica passar de um aparelho elétrico para outro.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every electrical connection is a material artifact that bears an electrical conduction function and participates in processes involving electrical apparatus.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000263 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000263">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">conector elétrico</rdfs:label>
        <rdfs:label xml:lang="en">electrical connector</rdfs:label>
        <skos:definition xml:lang="en">An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnector(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalConnectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um conector elétrico é um equipamento elétrico que possui uma função de conexão elétrica e que mantém contato elétrico íntimo entre duas ou mais partes de condutor elétrico para permitir fluxo contínuo de corrente.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">ElectricalConnector ≡ ElectricalEquipment ⊓ ∃bearerOf.ElectricalConnectionFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
        <rdfs:label xml:lang="en">engine</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor</rdfs:label>
        <skos:definition xml:lang="en">An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Engine(x) ↔ Motor(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ChemicalFuelPortion(p) ∧ hasInput(x,p)) ∧ ∃c(CombustionProcess(c) ∧ participatesIn(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor é um motor que converte energia de combustível químico em força mecânica e movimento através de processos de combustão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every Engine is a Motor that has function MechanicalEnergyGenerationFunction and has input ChemicalFuelPortion and participates in CombustionProcess.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000265 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000265">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">expansion joint</rdfs:label>
        <rdfs:label xml:lang="pt-br">junta de expansão</rdfs:label>
        <skos:definition xml:lang="en">An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ExpansionJoint(x) ↔ (MaterialArtifact(x) ∧ ∃f(ThermalExpansionAccommodationFunction(f) ∧ bearerOf(x,f)) ∧ ∃g(FlexibilityFunction(g) ∧ hasFunction(x,g))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma junta de expansão é um artefato material que possui a função projetada de acomodar expansão e contração térmica entre componentes conectados através de flexibilidade inerente, mantendo a integridade estrutural.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every expansion joint is a material artifact that bears a thermal expansion accommodation function and has a flexibility function, and every material artifact that bears a thermal expansion accommodation function and has a flexibility function is an expansion joint.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
        <rdfs:label xml:lang="pt-br">cartucho de filtro</rdfs:label>
        <rdfs:label xml:lang="en">filter cartridge</rdfs:label>
        <skos:definition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
        <rdfs:label xml:lang="pt-br">elemento filtrante</rdfs:label>
        <rdfs:label xml:lang="en">filter element</rdfs:label>
        <skos:definition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FilterElement(x) → Filter(x) ∧ ∃m(FilterMedia(m) ∧ madeFrom(x,m)) ∧ ∃a(FilterAssembly(a) ∧ componentPartOf(x,a)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Filtro que é feito de meio filtrante e que é uma parte componente de um conjunto de filtro.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on material composition (filter media) and mereological relationship (component of assembly). Under OWA, asserting equivalence could lead to unintended classification of any artifact made from filter media as a filter element, including specialized or hybrid components that contain filter media but serve different primary functions.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">FilterElement SubClassOf Filter and (madeFrom some FilterMedia) and (componentPartOf some FilterAssembly)</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000268 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000268">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FilterMedium"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">filter press</rdfs:label>
        <rdfs:label xml:lang="pt-br">prensa filtrante</rdfs:label>
        <skos:definition xml:lang="en">A filter press is a filter that applies mechanical compression force to enhance the separation of substances through a pressurized filtration process.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FilterPress(x) → Filter(x) ∧ ∃p(PressureMechanism(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃proc(MechanicalCompressionProcess(proc) ∧ participatesIn(x,proc)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A filter press is a filter that applies mechanical compression force to enhance the separation of substances through a pressurized filtration process.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma prensa filtrante é um filtro que aplica força de compressão mecânica para melhorar a separação de substâncias através de um processo de filtração pressurizada.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as &apos;both&apos; functional and constructive. The structural differentia (pressure mechanism and compression process) involves specific mechanical configurations that are harder to make sufficient under Open World Assumption without detailed engineering specifications.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter press is a filter that has a pressure mechanism as part and participates in mechanical compression processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000269 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000269">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FinnedTube"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">finned tube heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor de tubos aletados</rdfs:label>
        <skos:definition xml:lang="en">A finned tube heat exchanger is a heat exchanger that has finned tubes as the primary heat transfer surface enhancement mechanism.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FinnedTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃y(FinnedTube(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A finned tube heat exchanger is a heat exchanger that has finned tubes as the primary heat transfer surface enhancement mechanism.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de tubos aletados é um trocador de calor que possui tubos aletados como mecanismo primário de aumento da superfície de transferência de calor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While finned tubes are the defining structural feature, making sufficient conditions (equivalence) under Open World Assumption could lead to false positives where any assembly containing finned tubes would be classified as this specific heat exchanger type, including complex multi-function equipment or specialized hybrid systems.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every finned tube heat exchanger is a heat exchanger that has finned tubes as component parts at all times</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000270 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000270">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">aquecedor a combustão</rdfs:label>
        <rdfs:label xml:lang="en">fired heater</rdfs:label>
        <skos:definition xml:lang="en">A fired heater is a heater that burns fuel (solid, liquid, or gas) to generate heat for transfer to a process fluid medium.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FiredHeater(x) ↔ (Heater(x) ∧ ∃f(FiredHeatingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A fired heater is a heater that burns fuel (solid, liquid, or gas) to generate heat for transfer to a process fluid medium.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor a combustão é um aquecedor que queima combustível (sólido, líquido ou gasoso) para gerar calor para transferência para um fluido de processo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every fired heater is a heater that bears a FiredHeatingFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000271 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000271">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">arrestador de chama</rdfs:label>
        <rdfs:label xml:lang="en">flame arrestor</rdfs:label>
        <skos:definition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlameArrestor(x) ↔ SafetyDevice(x) ∧ ∃f(FlameArrestFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um arrestador de chama é um dispositivo de segurança que possui uma função de arrestar chama para prevenir que chamas entrem em um sistema através de uma abertura.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame arrestor is a safety device that has the function of arresting flames and processes gaseous portions while preventing flame propagation.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000272 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000272">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">detector de chama</rdfs:label>
        <rdfs:label xml:lang="en">flame detector</rdfs:label>
        <skos:definition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlameDetector(x) ↔ Detector(x) ∧ ∃f(FlameDetectionFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um detector de chama é um detector que tem a função de detectar a presença de chamas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame detector is a detector that has a flame detection function, and every detector that has a flame detection function is a flame detector.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000273 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000273">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238"/>
        <rdfs:label xml:lang="en">flange</rdfs:label>
        <rdfs:label xml:lang="pt-br">flange</rdfs:label>
        <skos:definition xml:lang="en">A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Flange(x) → MaterialArtifact(x) ∧ ∃g(ProjectingFlatRimGeometry(g) ∧ hasCharacteristic(x,g)) ∧ ∃f(MechanicalConnectionFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um flange é um artefato material caracterizado por uma geometria de aro plano projetante, placa, colar ou nervura, projetado para fornecer conexão mecânica entre componentes.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by structural geometry. Under OWA, any artifact with projecting flat rim geometry would be forced into the flange category, which could incorrectly classify specialized equipment or complex assemblies that contain flange-like features but serve different primary functions.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flange is a material artifact that has a projecting flat rim geometry and has the function of mechanically connecting components.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000274 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000274">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flare</rdfs:label>
        <rdfs:label xml:lang="pt-br">flare</rdfs:label>
        <skos:definition xml:lang="en">A flare is a burner that safely disposes of unwanted gases through controlled combustion at an elevated location.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Flare(x) ↔ (Burner(x) ∧ ∃f (WasteGasDisposalFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flare is a burner that safely disposes of unwanted gases through controlled combustion at an elevated location.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um flare é um queimador que descarta com segurança gases indesejados através de combustão controlada em local elevado.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare is a burner that bears a waste gas disposal function and has component parts flare tip, flare stack, and pilot system.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000275 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000275">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000274"/>
        <rdfs:label xml:lang="en">flare tip</rdfs:label>
        <rdfs:label xml:lang="pt-br">queimador de flare</rdfs:label>
        <skos:definition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlareTip(x) ↔ Burner(x) ∧ ∃f(WasteGasDisposalFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um queimador de flare é um queimador que especificamente queima gás residual emitido de processos industriais e descarrega os produtos de combustão na atmosfera.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare tip is a burner that has the function to dispose of waste gas from processes by burning it into the atmosphere</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000276 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000276">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flash drum</rdfs:label>
        <rdfs:label xml:lang="pt-br">tambor de flash</rdfs:label>
        <skos:definition xml:lang="en">A flash drum is a separator that performs flash vaporization to separate lighter components (which vaporize and are drawn off at the top) from heavier components (which remain liquid and are drawn off at the bottom).</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlashDrum(x) ↔ Separator(x) ∧ ∃f(FlashVaporizationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flash drum is a separator that performs flash vaporization to separate lighter components (which vaporize and are drawn off at the top) from heavier components (which remain liquid and are drawn off at the bottom).</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um tambor de flash é um separador que realiza vaporização flash para separar componentes mais leves (que vaporizam e são retirados no topo) de componentes mais pesados (que permanecem líquidos e são retirados no fundo).</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flash drum is a separator that bears a flash vaporization function and has a vapor outlet, liquid outlet, and feed inlet.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000277 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000277">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339"/>
        <rdfs:label xml:lang="en">flexible riser</rdfs:label>
        <rdfs:label xml:lang="pt-br">riser flexível</rdfs:label>
        <skos:definition xml:lang="en">A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlexibleRiser(x) → Riser(x) ∧ ∃q(FlexibleProperty(q) ∧ hasQuality(x,q)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um riser flexível é um riser que possui construção de material flexível permitindo condução de fluido vertical ou quase vertical entre o fundo do mar e a superfície, acomodando o movimento da embarcação.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type where flexibility is a material/structural property. Under OWA, asserting equivalence would force any pipe with flexible qualities to be classified as a flexible riser, even if it serves different functions or has different deployment contexts. Starting with necessary conditions protects against false positives.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flexible riser is a riser that has a flexible property</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow meter</rdfs:label>
        <rdfs:label xml:lang="pt-br">medidor de vazão</rdfs:label>
        <skos:definition xml:lang="en">A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeter(x) ↔ Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão é um instrumento que possui uma função de medir taxa de fluxo e produzir sinais ou indicações correspondentes.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow meter is an instrument that bears a flow measurement function and has component parts including a flow sensing element and signal processing unit</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000279 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000279">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow switch</rdfs:label>
        <rdfs:label xml:lang="pt-br">interruptor de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A flow switch is an instrument that bears a flow switching function to automatically open or close electrical circuits when fluid flow rate reaches predetermined threshold values.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowSwitch(x) ↔ Instrument(x) ∧ ∃f(FlowSwitchingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow switch is an instrument that bears a flow switching function to automatically open or close electrical circuits when fluid flow rate reaches predetermined threshold values.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de fluxo é um instrumento que possui uma função de comutação de fluxo para automaticamente abrir ou fechar circuitos elétricos quando a taxa de fluxo de fluido atinge valores de limiar predeterminados.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow switch is an instrument that has the function to switch electrical circuits based on flow rate detection at preset thresholds.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326"/>
        <rdfs:label xml:lang="en">flowline</rdfs:label>
        <rdfs:label xml:lang="pt-br">linha de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Flowline(x) ↔ Pipeline(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ connectsDirectly(x,w)) ∧ ∃m((Manifold(m) ∨ ProductionFacility(m)) ∧ connectsDirectly(x,m)) ∧ ∃h(HydrocarbonFluid(h) ∧ hasInput(x,h)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma linha de fluxo é um duto que transporta óleo, gás ou água diretamente de uma cabeça de poço para um manifold ou instalação de produção.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flowline is a pipeline that bears a fluid transport function, has a wellhead connection, has a manifold or production facility connection, and transports hydrocarbon fluids.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">forno</rdfs:label>
        <rdfs:label xml:lang="en">furnace</rdfs:label>
        <skos:definition xml:lang="en">A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Furnace(x) ↔ Heater(x) ∧ ∃f(ReactiveHeatingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um forno é um aquecedor que possui a função de induzir reações químicas em fluidos de processo através do aquecimento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every furnace is a heater that has the function to induce reactions in process fluids by heating them.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000282 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000282">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106"/>
        <rdfs:label xml:lang="en">fuse</rdfs:label>
        <rdfs:label xml:lang="pt-br">fusível</rdfs:label>
        <skos:definition xml:lang="en">A fuse is an electrical equipment that protects circuits by interrupting current flow through the intentional melting of a fusible element when current exceeds specified values for a sufficient duration.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Fuse(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FuseElement(e) ∧ hasComponentPartAtAllTimes(x,e)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A fuse is an electrical equipment that protects circuits by interrupting current flow through the intentional melting of a fusible element when current exceeds specified values for a sufficient duration.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um fusível é um equipamento elétrico que protege circuitos interrompendo o fluxo de corrente através do derretimento intencional de um elemento fusível quando a corrente excede valores especificados por uma duração suficiente.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every fuse is an electrical equipment that bears a circuit protection function and has a fuse element that melts under overcurrent conditions.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000283 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000283">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:label xml:lang="en">gas cyclone separator</rdfs:label>
        <rdfs:label xml:lang="pt-br">separador ciclônico de gás</rdfs:label>
        <skos:definition xml:lang="en">A gas cyclone separator is a separator that separates solid particles or liquid droplets from gas using centrifugal force generated by cyclonic flow geometry.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (GasCycloneSeparator(x) → Separator(x) ∧ ∃y(CyclonicFlowChamber(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CentrifugalSeparationProcess(z) ∧ participatesIn(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gas cyclone separator is a separator that separates solid particles or liquid droplets from gas using centrifugal force generated by cyclonic flow geometry.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um separador ciclônico de gás é um separador que separa partículas sólidas ou gotículas líquidas do gás usando força centrífuga gerada pela geometria de fluxo ciclônico.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by cyclonic mechanism. Under Open World Assumption, any device with cyclonic flow chamber could be falsely classified as gas cyclone separator, including specialized multi-stage cyclones or hybrid separator designs that should not be forced into this standard maintenance category.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas cyclone separator is a separator that has a cyclonic flow chamber as component part and participates in centrifugal separation processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000284 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000284">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasDetectingMeasuringElement"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasDetectingMeasuringElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">detector de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas detector</rdfs:label>
        <skos:definition xml:lang="en">A gas detector is a detector that has the designed function to sense the presence of a specified concentration of a gas.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GasDetector(x) ↔ (Detector(x) ∧ ∃f(GasDetectionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A gas detector is a detector that has the designed function to sense the presence of a specified concentration of a gas.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um detector de gás é um detector que tem a função projetada de detectar a presença de uma concentração especificada de um gás.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas detector is a detector that bears a GasDetectionFunction and has a GasDetectingMeasuringElement as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000285 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000285">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264"/>
        <rdfs:label xml:lang="en">gas engine</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor a gás</rdfs:label>
        <skos:definition xml:lang="en">A gas engine is an engine that uses gaseous fuel as input, employs a spark ignition system, and operates with a reciprocating piston mechanism to generate mechanical energy.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GasEngine(x) → Engine(x) ∧ ∃f,s,r(GaseousFuelPortion(f) ∧ SparkIgnitionSystem(s) ∧ ReciprocatingPistonMechanism(r) ∧ hasInput(x,f) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,r)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gas engine is an engine that uses gaseous fuel as input, employs a spark ignition system, and operates with a reciprocating piston mechanism to generate mechanical energy.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor a gás é um motor que usa combustível gasoso como entrada, emprega um sistema de ignição por centelha e opera com um mecanismo de pistão alternativo para gerar energia mecânica.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Gas engine is defined by constructive characteristics (gaseous fuel, spark ignition, reciprocating mechanism) rather than a unique function. Under Open World Assumption, making these conditions sufficient could lead to false positives where complex hybrid engines or experimental designs with these features are automatically classified as standard gas engines when they might require different maintenance/operational categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas engine is an engine that has gaseous fuel portion as input and has spark ignition system as component part at all times and has reciprocating piston mechanism as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000286 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000286">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbineSection"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbineSection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gas turbine</rdfs:label>
        <rdfs:label xml:lang="pt-br">turbina a gás</rdfs:label>
        <skos:definition xml:lang="en">A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GasTurbine(x) ↔ Turbine(x) ∧ ∃c,h(Compressor(c) ∧ CombustionChamber(h) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃p1,p2(AirCompressionProcess(p1) ∧ FuelCombustionProcess(p2) ∧ participatesIn(x,p1) ∧ participatesIn(x,p2)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma turbina a gás é uma turbina que possui um compressor e câmara de combustão integrados, projetada para comprimir ar ambiente, misturá-lo com combustível para combustão, e expandir os gases quentes resultantes através de uma seção de turbina para gerar energia mecânica.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas turbine is a turbine that has component parts compressor and combustion chamber at all times, and participates in air compression process and fuel combustion process.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000287 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000287">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gasket</rdfs:label>
        <rdfs:label xml:lang="pt-br">junta</rdfs:label>
        <skos:definition xml:lang="en">A gasket is a material artifact made of deformable material arranged in closed loops that bears a sealing function to prevent leakage between mating surfaces with limited relative movement.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Gasket(x) ↔ MaterialArtifact(x) ∧ ∃f(SealingFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(DeformableMaterial(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃g(ClosedLoopGeometry(g) ∧ hasProperty(x,g)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A gasket is a material artifact made of deformable material arranged in closed loops that bears a sealing function to prevent leakage between mating surfaces with limited relative movement.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma junta é um artefato material feito de material deformável arranjado em loops fechados que possui uma função de vedação para prevenir vazamentos entre superfícies de acoplamento com movimento relativo limitado.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gasket is a material artifact that has component part some deformable material and bears some sealing function and has property some closed loop geometry.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000288 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000288">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
        <rdfs:label xml:lang="pt-br">carcaça de caixa de engrenagens</rdfs:label>
        <rdfs:label xml:lang="en">gear casing</rdfs:label>
        <skos:definition xml:lang="en">A casing that contains and houses the internal components of a gear mechanism, providing protective enclosure and structural support.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GearCasing(x) → casing(x) ∧ ∃y(GearMechanism(y) ∧ hasContent(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A casing that contains and houses the internal components of a gear mechanism, providing protective enclosure and structural support.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que contém e abriga os componentes internos de um mecanismo de engrenagem, fornecendo invólucro protetor e suporte estrutural.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">This is a constructive type defined by its physical configuration as a specific type of casing. Under OWA, declaring equivalence could lead to over-classification where any casing containing gear-like components might be inappropriately classified as a standard gear casing, including custom enclosures or hybrid systems that should not fall into this maintenance category.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">GearCasing ⊑ casing ⊓ ∃hasContent.GearMechanism</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000289 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000289">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba de engrenagem</rdfs:label>
        <rdfs:label xml:lang="en">gear pump</rdfs:label>
        <skos:definition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (GearPump(x) → Pump(x) ∧ ∃g,c (GearMechanism(g) ∧ PumpCasing(c) ∧ hasComponentPartAtAllTimes(x,g) ∧ hasComponentPartAtAllTimes(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de engrenagem é uma bomba que contém dentes de engrenagem dentro de um invólucro ou carcaça para transportar líquido em pressões de retorno relativamente altas através de ação de engrenamento.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the gear mechanism is definitionally necessary for gear pumps, making it sufficient under OWA could lead to false positives - any complex equipment containing gears (like gearboxes with integrated pumps or multi-function units) might be incorrectly classified as standard gear pumps for maintenance purposes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gear pump is a pump that has as component part at all times a gear mechanism and a pump casing, and bears a pumping function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000290 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000290">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121"/>
        <rdfs:label xml:lang="en">gear wheel</rdfs:label>
        <rdfs:label xml:lang="pt-br">roda dentada</rdfs:label>
        <skos:definition xml:lang="en">An Assembly that bears a PowerTransmissionFunction and that has circumferential teeth for positive mechanical engagement with mating gears or racks to transmit rotational motion and power.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GearWheel(x) → Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃t(Tooth(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃w(WheelBody(w) ∧ hasComponentPartAtAllTimes(x,w)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An Assembly that bears a PowerTransmissionFunction and that has circumferential teeth for positive mechanical engagement with mating gears or racks to transmit rotational motion and power.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma PowerTransmissionFunction e que possui dentes circunferenciais para engajamento mecânico positivo com engrenagens ou cremalheiras correspondentes para transmitir movimento rotacional e potência.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive differentia based on physical structure (toothed geometry). Under OWA, asserting equivalence could force classification of complex hybrid mechanisms or specialized toothed components that should not be categorized as standard gear wheels for maintenance purposes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">GearWheel SubClassOf Assembly and (bearerOf some PowerTransmissionFunction) and (hasComponentPartAtAllTimes some Tooth) and (hasComponentPartAtAllTimes some WheelBody)</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000291 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000291">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">corpo de válvula globo</rdfs:label>
        <rdfs:label xml:lang="en">globe valve body</rdfs:label>
        <skos:definition xml:lang="en">A valve body that has a globular geometry designed to accommodate the perpendicular flow path and disc closure mechanism characteristic of globe valve operation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (GlobeValveBody(x) → ValveBody(x) ∧ ∃g (GlobularGeometry(g) ∧ hasDesignCharacteristic(x,g)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A valve body that has a globular geometry designed to accommodate the perpendicular flow path and disc closure mechanism characteristic of globe valve operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que possui geometria globular projetada para acomodar o caminho de fluxo perpendicular e o mecanismo de fechamento por disco característico da operação de válvula globo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by structural geometry. Under OWA, asserting equivalence based on globular geometry alone could lead to false classifications of complex assemblies or hybrid components that contain globular elements but should not be classified as standard globe valve bodies.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe valve body is a valve body that has globular geometry for perpendicular flow path accommodation.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000292 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000292">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gravity separator</rdfs:label>
        <rdfs:label xml:lang="pt-br">separador gravitacional</rdfs:label>
        <skos:definition xml:lang="en">A gravity separator is a separator that performs separation based on differences in specific gravity of the substances being separated.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GravitySeparator(x) ↔ Separator(x) ∧ ∃f(GravitySeparationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A gravity separator is a separator that performs separation based on differences in specific gravity of the substances being separated.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um separador gravitacional é um separador que realiza separação baseada nas diferenças de gravidade específica das substâncias sendo separadas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gravity separator is a separator that bears a GravitySeparationFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311"/>
        <rdfs:label xml:lang="en">header</rdfs:label>
        <rdfs:label xml:lang="pt-br">header</rdfs:label>
        <skos:definition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Header(x) ↔ (manifold(x) ∧ ∃y(SmallPipe(y) ∧ connects_to(x,y)) ∧ ∃z(MultiStreamDistributionProcess(z) ∧ participatesIn(x,z))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um header é um manifold que se conecta a muitos tubos menores para coletar descarga de múltiplas fontes ou distribuir fluido para múltiplos destinos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Header ≡ manifold ⊓ ∃connects_to.SmallPipe ⊓ ∃participatesIn.MultiStreamDistributionProcess</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma HeatTransferFunction e</rdfs:label>
        <rdfs:label xml:lang="en">heat transfer plate</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(HeatTransferPlate(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MediaSeparationProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma HeatTransferFunction e que é destinado a ser usado em um trocador de calor não tubular para segregar dois meios fluidos enquanto facilita a transferência de energia térmica entre eles.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification basis requires necessary conditions only. Under OWA, sufficient conditions for &apos;plate geometry used in non-tubular heat exchangers&apos; could lead to false positives - other components with plate-like surfaces might be incorrectly classified as heat transfer plates without domain expert validation of the structural and application-specific criteria.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat transfer plate is a MaterialArtifact that bears a HeatTransferFunction and participates in segregating two fluid media in a non-tubular heat exchanger.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000295 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000295">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">hopper</rdfs:label>
        <rdfs:label xml:lang="pt-br">hopper</rdfs:label>
        <skos:definition xml:lang="en">A hopper is a vessel that is designed to store solid materials and dispense them through a controlled discharge opening.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Hopper(x) ↔ (Vessel(x) ∧ ∃f(SolidStorageAndDispensingFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SolidDischargeOpening(p) ∧ hasComponentPartAtAllTimes(x,p))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A hopper is a vessel that is designed to store solid materials and dispense them through a controlled discharge opening.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um hopper é um vaso projetado para armazenar materiais sólidos e dispensá-los através de uma abertura de descarga controlada.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every hopper is a vessel that bears a SolidStorageAndDispensingFunction and has a SolidDischargeOpening as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000296 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000296">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
        <rdfs:label xml:lang="en">hose</rdfs:label>
        <rdfs:label xml:lang="pt-br">mangueira</rdfs:label>
        <skos:definition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Hose(x) → Pipe(x) ∧ ∃q(Flexibility(q) ∧ hasQuality(x,q)) ∧ ∃c(PressurizedFluidConduction(c) ∧ capableOf(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma mangueira é um tubo flexível projetado para conduzir líquidos sob pressão enquanto acomoda movimento posicional e flexão.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical properties (flexibility). Under OWA, asserting equivalence would force any artifact with flexibility and pressure capability to be classified as a hose, potentially including complex equipment with flexible components that should not be categorized as standard hoses.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every hose is a pipe that has flexibility and is capable of conducting liquids under pressure.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">carcaça</rdfs:label>
        <rdfs:label xml:lang="en">housing</rdfs:label>
        <skos:definition xml:lang="en">An Assembly that bears both an EnclosureFunction and a SupportFunction, providing protective boundaries around internal components while structurally supporting them.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Housing(x) → Assembly(x) ∧ ∃f₁(EnclosureFunction(f₁) ∧ bearerOf(x,f₁)) ∧ ∃f₂(SupportFunction(f₂) ∧ bearerOf(x,f₂)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An Assembly that bears both an EnclosureFunction and a SupportFunction, providing protective boundaries around internal components while structurally supporting them.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que possui tanto uma EnclosureFunction quanto uma SupportFunction, fornecendo limites protetivos ao redor de componentes internos enquanto os suporta estruturalmente.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions would force any assembly with enclosure and support functions to be classified as a standard housing, potentially misclassifying specialized equipment with housing-like properties but different maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Housing SubClassOf Assembly and (bearerOf some EnclosureFunction) and (bearerOf some SupportFunction)</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000298 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000298">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
        <rdfs:label xml:lang="pt-br">atuador hidráulico</rdfs:label>
        <rdfs:label xml:lang="en">hydraulic actuator</rdfs:label>
        <skos:definition xml:lang="en">A hydraulic actuator is an actuator that converts hydraulic fluid pressure into mechanical motion through hydraulic power transmission.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(HydraulicActuator(x) → Actuator(x) ∧ ∃y(HydraulicFluidPortion(y) ∧ hasInput(x,y)) ∧ ∃z(HydraulicToMechanicalEnergyConversionProcess(z) ∧ participatesIn(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A hydraulic actuator is an actuator that converts hydraulic fluid pressure into mechanical motion through hydraulic power transmission.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador hidráulico é um atuador que converte pressão de fluido hidráulico em movimento mecânico através de transmissão de potência hidráulica.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on hydraulic power source. Under Open World Assumption, asserting equivalence could incorrectly classify complex hydraulic-mechanical hybrid systems or specialized equipment containing hydraulic actuator components as standard hydraulic actuators.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic actuator is an actuator that has hydraulic fluid portion as input and participates in hydraulic to mechanical energy conversion process.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000299 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000299">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
        <rdfs:label xml:lang="en">hydraulic motor</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor hidráulico</rdfs:label>
        <skos:definition xml:lang="en">A hydraulic motor is a motor that generates mechanical energy by converting high pressure hydraulic oil to rotational motion.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(HydraulicMotor(x) → Motor(x) ∧ ∃f,p(HydraulicFluidPortion(f) ∧ hasInput(x,f) ∧ HydraulicToMechanicalEnergyConversionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A hydraulic motor is a motor that generates mechanical energy by converting high pressure hydraulic oil to rotational motion.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor hidráulico é um motor que gera energia mecânica convertendo óleo hidráulico de alta pressão em movimento rotacional.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on hydraulic mechanism. Under Open World Assumption, any device with hydraulic input might be misclassified as a hydraulic motor without domain expert validation of the complete structural requirements.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic motor is a motor that has hydraulic fluid input and participates in hydraulic-to-mechanical energy conversion process</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000300 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000300">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpInlet"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpOutlet"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpInlet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpOutlet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba hidráulica</rdfs:label>
        <rdfs:label xml:lang="en">hydraulic pump</rdfs:label>
        <skos:definition xml:lang="en">A hydraulic pump is a positive displacement pump that converts mechanical power into hydraulic energy for hydraulic drive systems.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (HydraulicPump(x) ↔ PositiveDisplacementPump(x) ∧ ∃f(HydraulicPumpingFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(HydraulicPowerTransmissionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A hydraulic pump is a positive displacement pump that converts mechanical power into hydraulic energy for hydraulic drive systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba hidráulica é uma bomba de deslocamento positivo que converte energia mecânica em energia hidráulica para sistemas de acionamento hidráulico.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic pump is a positive displacement pump that bears a hydraulic pumping function and participates in hydraulic power transmission processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000301 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000301">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:label xml:lang="pt-br">hidrociclone</rdfs:label>
        <rdfs:label xml:lang="en">hydrocyclone</rdfs:label>
        <skos:definition xml:lang="en">A hydrocyclone is a separator that separates fluid mixtures using centrifugal forces generated by tangential flow through a conical chamber.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Hydrocyclone(x) ↔ Separator(x) ∧ ∃c(ConicalSection(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃p(CentrifugalSeparationProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A hydrocyclone is a separator that separates fluid mixtures using centrifugal forces generated by tangential flow through a conical chamber.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um hidrociclone é um separador que separa misturas de fluidos usando forças centrífugas geradas por fluxo tangencial através de uma câmara cônica.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydrocyclone is a separator that has a conical section as component part at all times and participates in centrifugal separation processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000302 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000302">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotatingVanes"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">impeller</rdfs:label>
        <rdfs:label xml:lang="pt-br">impulsor</rdfs:label>
        <skos:definition xml:lang="en">An impeller is an assembly consisting of rotating vanes mounted on a hub that transfers energy to or from fluids through dynamic rotational force within an enclosure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Impeller(x) → Assembly(x) ∧ ∃v,h(RotatingVanes(v) ∧ Hub(h) ∧ hasComponentPartAtAllTimes(x,v) ∧ hasComponentPartAtAllTimes(x,h) ∧ ∃m(RotationalMotion(m) ∧ participatesIn(x,m)) ∧ ∃f(EnergyTransferFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An impeller is an assembly consisting of rotating vanes mounted on a hub that transfers energy to or from fluids through dynamic rotational force within an enclosure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um impulsor é um conjunto que consiste em pás rotativas montadas em um cubo que transfere energia para ou de fluidos através de força rotacional dinâmica dentro de um invólucro.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for the rotating vane assembly could lead to false positives where other rotating equipment with vanes (like turbine rotors or fan assemblies) might be incorrectly classified as impellers when they should remain in their specific equipment categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every impeller is an assembly that has rotating vanes and a hub as component parts at all times, participates in rotational motion, and bears an energy transfer function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000303 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000303">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">incinerador</rdfs:label>
        <rdfs:label xml:lang="en">incinerator</rdfs:label>
        <skos:definition xml:lang="en">An incinerator is a furnace that is designed to combust waste material for disposal purposes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Incinerator(x) ↔ Furnace(x) ∧ ∃f(WasteCombustionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An incinerator is a furnace that is designed to combust waste material for disposal purposes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um incinerador é um forno que é projetado para combustir material de resíduo para fins de descarte.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every incinerator is a furnace that bears a waste combustion function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000304 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000304">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba de injeção</rdfs:label>
        <rdfs:label xml:lang="en">injection pump</rdfs:label>
        <skos:definition xml:lang="en">An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(InjectionPump(x) ↔ Pump(x) ∧ ∃f(InjectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de injeção é uma bomba especificamente projetada para injetar fluido em reservatórios ou sistemas de produção, tipicamente em pressões relativamente altas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every injection pump is a pump that bears an injection function for delivering fluids to reservoirs or production systems.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000305 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000305">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000375"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000375"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">injection well</rdfs:label>
        <rdfs:label xml:lang="pt-br">poço de injeção</rdfs:label>
        <skos:definition xml:lang="en">An injection well is a well that bears the designed function of injecting materials into a reservoir at pressure higher than formation pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (InjectionWell(x) ↔ (Well(x) ∧ ∃f (InjectionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An injection well is a well that bears the designed function of injecting materials into a reservoir at pressure higher than formation pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um poço de injeção é um poço que possui a função projetada de injetar materiais em um reservatório a uma pressão superior à pressão da formação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every injection well is a well that has the function to inject materials into a reservoir under pressure.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000306 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000306">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
        <rdfs:label xml:lang="pt-br">eixo de entrada</rdfs:label>
        <rdfs:label xml:lang="en">input shaft</rdfs:label>
        <skos:definition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(InputShaft(x) → Shaft(x) ∧ ∃p(MechanicalEnergyReceptionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(ExternalEnergySource(s) ∧ connectedTo(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um eixo de entrada é um eixo que serve como ponto de entrada para energia mecânica de uma fonte de energia externa em um sistema de transmissão de potência.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on physical configuration as energy entrance point. Under OWA, defining sufficient conditions could lead to false positives where any shaft receiving external energy input would be classified as a standard input shaft, even specialized or hybrid configurations that should remain in different maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">An InputShaft is a Shaft that participates in mechanical energy reception and is connected to an external energy source.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000307 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000307">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparateVapourSpace"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">kettle reboiler</rdfs:label>
        <rdfs:label xml:lang="pt-br">refervedor tipo kettle</rdfs:label>
        <skos:definition xml:lang="en">A kettle reboiler is a reboiler that has horizontal orientation and contains a separate vapour space for vapor-liquid disengagement.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(KettleReboiler(x) → Reboiler(x) ∧ ∃q(HorizontalOrientation(q) ∧ hasQuality(x,q)) ∧ ∃v(SeparateVapourSpace(v) ∧ hasComponentPartAtAllTimes(x,v)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A kettle reboiler is a reboiler that has horizontal orientation and contains a separate vapour space for vapor-liquid disengagement.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um refervedor tipo kettle é um refervedor que possui orientação horizontal e contém um espaço de vapor separado para desengajamento vapor-líquido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by specific physical configuration. Under Open World Assumption, sufficient conditions could incorrectly classify equipment with horizontal orientation and vapor space but fundamentally different purposes (e.g., horizontal separators, flash drums) as kettle reboilers. The structural differentia provides necessary conditions for the kettle reboiler maintenance/procurement category.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every kettle reboiler is a reboiler that has horizontal orientation and has a separate vapour space as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000308 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000308">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">knock out drum</rdfs:label>
        <rdfs:label xml:lang="pt-br">vaso separador de condensado</rdfs:label>
        <skos:definition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(KnockOutDrum(x) ↔ Separator(x) ∧ ∃f(KnockOutSeparationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um vaso separador de condensado é um separador projetado para separar quantidades relativamente pequenas de líquido de uma corrente de vapor através de separação de fases gravitacional e baseada em momento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every knock out drum is a separator that bears a knock out separation function, which is realized in processes that separate small quantities of liquid from vapor streams.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000309 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000309">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">interruptor de nível</rdfs:label>
        <rdfs:label xml:lang="en">level switch</rdfs:label>
        <skos:definition xml:lang="en">A level switch is an instrument that bears a LevelSwitchingFunction, combining level detection with switching capability to provide discrete on/off electrical signals when fluid or particulate material levels reach preset values.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(LevelSwitch(x) ↔ (Instrument(x) ∧ ∃f(LevelSwitchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(DiscreteElectricalSignal(s) ∧ hasOutput(x,s))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level switch is an instrument that bears a LevelSwitchingFunction, combining level detection with switching capability to provide discrete on/off electrical signals when fluid or particulate material levels reach preset values.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de nível é um instrumento que possui uma Função de Comutação de Nível, combinando detecção de nível com capacidade de comutação para fornecer sinais elétricos discretos ligado/desligado quando níveis de fluidos ou materiais particulados atingem valores predefinidos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level switch is an instrument that has the function of level switching and outputs discrete electrical signals based on preset level conditions.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000310 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000310">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">célula de carga</rdfs:label>
        <rdfs:label xml:lang="en">load cell</rdfs:label>
        <skos:definition xml:lang="en">A load cell is an instrument that converts mechanical force (tension, compression, pressure, or torque) into a proportional electrical signal for measurement purposes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LoadCell(x) ↔ Instrument(x) ∧ ∃f(ForceToElectricalTransductionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A load cell is an instrument that converts mechanical force (tension, compression, pressure, or torque) into a proportional electrical signal for measurement purposes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma célula de carga é um instrumento que converte força mecânica (tração, compressão, pressão ou torque) em um sinal elétrico proporcional para fins de medição.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every load cell is an instrument that bears a force-to-electrical transduction function and has a force-receiving element, transduction element, and electrical output.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Chamber"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidOpening"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">manifold</rdfs:label>
        <rdfs:label xml:lang="pt-br">manifold</rdfs:label>
        <skos:definition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Manifold(x) → Assembly(x) ∧ ∃c(Chamber(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃o(MultipleFluidOpenings(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃f(FluidDistributionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um manifold é um conjunto que possui uma câmara com múltiplas aberturas de fluido projetada para distribuir o fluxo de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type, manifolds are defined by structural configuration. Under OWA, asserting equivalence would force any assembly with a chamber and multiple openings to be classified as a manifold, potentially misclassifying complex equipment with manifold-like components (e.g., turbine casings, complex valves). Starting with necessary conditions protects against false positives.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every manifold is an assembly that has-component-part-at-all-times some chamber and has-component-part-at-all-times some multiple fluid openings and bears some fluid distribution function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
        <rdfs:label xml:lang="pt-br">atuador manual</rdfs:label>
        <rdfs:label xml:lang="en">manual actuator</rdfs:label>
        <skos:definition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ManualActuator(x) ↔ Actuator(x) ∧ ∃s(ManualControlSignal(s) ∧ hasInput(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador manual é um atuador que converte entradas de controle operadas por humanos em movimento mecânico ou força através de operação física direta.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">ManualActuator is an actuator that has input ManualControlSignal and has output MechanicalPower</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000313 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000313">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">mill</rdfs:label>
        <rdfs:label xml:lang="pt-br">moinho</rdfs:label>
        <skos:definition xml:lang="en">A mill is an assembly that bears a material processing function to reduce particle size or modify solid materials through mechanical grinding, cutting, or crushing operations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Mill(x) ↔ (Assembly(x) ∧ ∃f(MaterialProcessingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A mill is an assembly that bears a material processing function to reduce particle size or modify solid materials through mechanical grinding, cutting, or crushing operations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um moinho é um conjunto que possui uma função de processamento de material para reduzir o tamanho de partículas ou modificar materiais sólidos através de operações mecânicas de moagem, corte ou trituração.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every mill is an assembly that has the function to process materials, and every assembly that has the function to process materials is a mill.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">misturador</rdfs:label>
        <rdfs:label xml:lang="en">mixer</rdfs:label>
        <skos:definition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Mixer(x) ↔ (Assembly(x) ∧ ∃f (MixingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um misturador é um conjunto que tem a função projetada de misturar ou combinar dois ou mais ingredientes fluidos em uma mistura homogênea.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every mixer is an assembly that bears a mixing function, and every assembly that bears a mixing function is a mixer.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">motor</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor</rdfs:label>
        <skos:definition xml:lang="en">A motor is an assembly that bears a mechanical energy generation function to convert electrical, chemical, pneumatic, or hydraulic energy into rotational mechanical energy.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Motor(x) ↔ Assembly(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(RotationalKineticEnergy(e) ∧ hasOutput(x,e)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A motor is an assembly that bears a mechanical energy generation function to convert electrical, chemical, pneumatic, or hydraulic energy into rotational mechanical energy.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor é um conjunto que possui uma função de geração de energia mecânica para converter energia elétrica, química, pneumática ou hidráulica em energia mecânica rotacional.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every motor is an assembly that has the function of generating mechanical energy and has as output rotational kinetic energy.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000316 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000316">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bocal</rdfs:label>
        <rdfs:label xml:lang="en">nozzle</rdfs:label>
        <skos:definition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Nozzle(x) ↔ MaterialArtifact(x) ∧ ∃f(FluidDirectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃o(ShapedOrifice(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃p(ProtrudingPart(p) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um bocal é um artefato material que possui uma parte protuberante com um orifício moldado projetado para direcionar o fluxo de fluido em um padrão específico.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every nozzle is a material artifact that bears a fluid direction function and has a shaped orifice and protruding part as component parts.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
        <rdfs:label xml:lang="pt-br">eixo de saída</rdfs:label>
        <rdfs:label xml:lang="en">output shaft</rdfs:label>
        <skos:definition xml:lang="en">A Shaft that participates in mechanical energy output processes, serving as the exit point for mechanical energy transmission from a prime mover to external energy consuming equipment.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (OutputShaft(x) → Shaft(x) ∧ ∃p (MechanicalEnergyOutputProcess(p) ∧ participatesIn(x,p)) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A Shaft that participates in mechanical energy output processes, serving as the exit point for mechanical energy transmission from a prime mover to external energy consuming equipment.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Eixo que participa em processos de saída de energia mecânica, servindo como ponto de saída para transmissão de energia mecânica de um motor primário para equipamentos consumidores de energia externos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on positional role within mechanical systems. Under OWA, sufficient conditions would be difficult to specify without risk of misclassifying intermediate shafts or complex multi-shaft arrangements that happen to have output characteristics.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every output shaft is a shaft that participates in at least one mechanical energy output process and bears a power transmission function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">lançador de pig</rdfs:label>
        <rdfs:label xml:lang="en">pig launcher</rdfs:label>
        <skos:definition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PigLauncher(x) ↔ (Vessel(x) ∧ ∃f(PigLaunchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(PipelineConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um lançador de pig é um vaso que possui função de lançamento de pig para inserir pigs de duto em sistemas de tubulação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig launcher is a vessel that has the function to launch pipeline pigs and has a pipeline connection component.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pig receiver</rdfs:label>
        <rdfs:label xml:lang="pt-br">recebedor de pig</rdfs:label>
        <skos:definition xml:lang="en">A pig receiver is a vessel that has the function to receive pipe pigs from a pipeline.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PigReceiver(x) ↔ (Vessel(x) ∧ ∃f(PigReceivingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pig receiver is a vessel that has the function to receive pipe pigs from a pipeline.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um recebedor de pig é um vaso que tem a função de receber pigs de tubulação de um duto.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig receiver is a vessel that bears a pig receiving function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000320 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000320">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">armadilha de pig</rdfs:label>
        <rdfs:label xml:lang="en">pig trap</rdfs:label>
        <skos:definition xml:lang="en">A pig trap is an assembly that bears the function of launching and receiving pipe pigs for pipeline maintenance and has both launcher and receiver components.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PigTrap(x) ↔ Assembly(x) ∧ ∃f(PigLaunchingAndReceivingFunction(f) ∧ bearerOf(x,f)) ∧ ∃l(PigLauncher(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃r(PigReceiver(r) ∧ hasComponentPartAtAllTimes(x,r)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pig trap is an assembly that bears the function of launching and receiving pipe pigs for pipeline maintenance and has both launcher and receiver components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma armadilha de pig é um conjunto que possui a função de lançar e receber pigs de tubulação para manutenção de dutos e possui componentes de lançador e receptor.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig trap is an assembly that bears a pig launching and receiving function and has component parts that are a pig launcher and a pig receiver.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pipe</rdfs:label>
        <rdfs:label xml:lang="pt-br">tubo</rdfs:label>
        <skos:definition xml:lang="en">A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Pipe(x) → MaterialArtifact(x) ∧ ∃f(FluidConductionFunction(f) ∧ hasFunction(x,f)) ∧ ∃g(TubularGeometry(g) ∧ hasPhysicalProperty(x,g)) ∧ ∃h(LongitudinalExtent(h) ∧ hasPhysicalProperty(x,h)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um tubo é um artefato material caracterizado por geometria tubular e extensão longitudinal, projetado para conduzir materiais líquidos, gasosos ou sólidos finamente divididos de um local para outro, ou para servir a propósitos estruturais.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because pipe is defined by constructive/geometric properties (tubular geometry, longitudinal extent) rather than purely functional criteria. Under Open World Assumption, asserting sufficient conditions based on geometric properties could lead to unintended classification of complex tubular structures that happen to conduct fluids but should not be categorized as standard pipes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe is a material artifact that has fluid conduction function and has tubular geometry and has longitudinal extent.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000322 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000322">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
        <rdfs:label xml:lang="pt-br">curva de tubo</rdfs:label>
        <rdfs:label xml:lang="en">pipe bend</rdfs:label>
        <skos:definition xml:lang="en">A pipe bend is a pipe that has a curved geometry to change piping direction with a non-standard radius.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PipeBend(x) → Pipe(x) ∧ ∃g (CurvedGeometry(g) ∧ hasQuality(x,g)) ∧ ∃r (NonStandardBendRadius(r) ∧ hasQuality(x,r)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A pipe bend is a pipe that has a curved geometry to change piping direction with a non-standard radius.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma curva de tubo é um tubo que possui geometria curvada para mudar a direção da tubulação com um raio não padrão.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the curved geometry with non-standard radius is distinctive, making it sufficient under OWA could force classification of complex piping assemblies or custom manifolds containing bent sections into this maintenance category inappropriately.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe bend is a pipe that has curved geometry and has non-standard bend radius.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000323 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000323">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
        <rdfs:label xml:lang="pt-br">cotovelo de tubulação</rdfs:label>
        <rdfs:label xml:lang="en">pipe elbow</rdfs:label>
        <skos:definition xml:lang="en">A pipe elbow is a pipe that has curved geometry enabling directional changes in pipe runs between 0 and 135 degrees.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PipeElbow(x) → (Pipe(x) ∧ ∃g(CurvedGeometry(g) ∧ hasGeometricProperty(x,g)) ∧ ∃p(DirectionalChangeCapacity(p) ∧ hasProperty(x,p))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A pipe elbow is a pipe that has curved geometry enabling directional changes in pipe runs between 0 and 135 degrees.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um cotovelo de tubulação é uma tubulação que possui geometria curva permitindo mudanças direcionais em trechos de tubulação entre 0 e 135 graus.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type protects against false positives under OWA. Any curved piping component would be forcibly classified as a pipe elbow under equivalent axioms, including specialized equipment like coiled tubing, serpentine heat exchanger tubes, or custom manifold sections that contain curved passages but should not be asserted into the standard pipe elbow maintenance category.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe elbow is a pipe that has curved geometry and enables directional change capacity between 0 and 135 degrees.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000324 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000324">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
        <rdfs:label xml:lang="en">pipe reducer</rdfs:label>
        <rdfs:label xml:lang="pt-br">redutor de tubulação</rdfs:label>
        <skos:definition xml:lang="en">A pipe reducer is a pipe that has different nominal pipe sizes at its two ends, intended to connect pipes or piping components of different sizes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PipeReducer(x) → Pipe(x) ∧ ∃i,o (InletEnd(i) ∧ OutletEnd(o) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ DifferentNominalPipeSizes(i,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A pipe reducer is a pipe that has different nominal pipe sizes at its two ends, intended to connect pipes or piping components of different sizes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um redutor de tubulação é um tubo que possui tamanhos nominais diferentes de tubulação em suas duas extremidades, destinado a conectar tubos ou componentes de tubulação de tamanhos diferentes.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by geometric configuration, sufficient conditions are omitted under the Open World Assumption to prevent false positives. Complex assemblies or custom manifolds containing size transitions should not be automatically classified as standard pipe reducers without explicit assertion.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe reducer is a pipe that has an inlet end and outlet end with different nominal pipe sizes</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000325 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000325">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BranchPort"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pipe tee</rdfs:label>
        <rdfs:label xml:lang="pt-br">tê de tubulação</rdfs:label>
        <skos:definition xml:lang="en">A pipe tee is a pipe fitting that has three fluid ports arranged in T-shaped configuration, with one branch port perpendicular to two run ports, designed to realize fluid conduction function through flow division or combination.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PipeTee(x) → Pipe(x) ∧ ∃p1,p2,p3(BranchPort(p1) ∧ RunPort(p2) ∧ RunPort(p3) ∧ hasPartAtAllTimes(x,p1) ∧ hasPartAtAllTimes(x,p2) ∧ hasPartAtAllTimes(x,p3) ∧ perpendicularTo(p1,p2) ∧ perpendicularTo(p1,p3)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A pipe tee is a pipe fitting that has three fluid ports arranged in T-shaped configuration, with one branch port perpendicular to two run ports, designed to realize fluid conduction function through flow division or combination.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um tê de tubulação é uma conexão de tubulação que possui três portas de fluido dispostas em configuração em formato de T, com uma porta de ramal perpendicular a duas portas de passagem, projetada para realizar função de condução de fluido através de divisão ou combinação de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. The T-shaped geometric configuration with three specific ports is a structural differentia that is harder to make sufficient under OWA. Custom manifolds or complex fittings might contain T-shaped passages but should not be automatically classified as standard pipe tees without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe tee is a pipe that has exactly three fluid ports arranged in T-configuration and bears a fluid conduction function</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportFunction"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pipeline</rdfs:label>
        <rdfs:label xml:lang="pt-br">pipeline</rdfs:label>
        <skos:definition xml:lang="en">A pipeline is an engineered system that bears a fluid transport function, consisting of pipes and possibly including pumps, valves, and control devices, designed for conveying liquids, gases, or finely divided solids between locations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Pipeline(x) ↔ EngineeredSystem(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pipeline is an engineered system that bears a fluid transport function, consisting of pipes and possibly including pumps, valves, and control devices, designed for conveying liquids, gases, or finely divided solids between locations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um pipeline é um sistema engenheirado que possui uma função de transporte de fluidos, consistindo de tubos e possivelmente incluindo bombas, válvulas e dispositivos de controle, projetado para transportar líquidos, gases ou sólidos finamente divididos entre locais.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipeline is an engineered system that bears a fluid transport function and has pipe as a component part at some time.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000327 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000327">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
        <rdfs:label xml:lang="pt-br">atuador pneumático</rdfs:label>
        <rdfs:label xml:lang="en">pneumatic actuator</rdfs:label>
        <skos:definition xml:lang="en">A pneumatic actuator is an actuator that operates using pneumatic power.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PneumaticActuator(x) → Actuator(x) ∧ ∃y(PneumaticPower(y) ∧ hasOperatingMedium(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A pneumatic actuator is an actuator that operates using pneumatic power.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador pneumático é um atuador que opera usando energia pneumática.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type where pneumatic mechanism is necessary but may not be sufficient under OWA. Specialized pneumatic equipment (pneumatic tools, pneumatic cylinders) might have pneumatic power but should not be classified as actuators without additional validation of their actuation role in control systems.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic actuator is an actuator that has operating medium some pneumatic power.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PneumaticMotorFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PneumaticMotorFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">motor pneumático</rdfs:label>
        <rdfs:label xml:lang="en">pneumatic motor</rdfs:label>
        <skos:definition xml:lang="en">A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PneumaticMotor(x) ↔ Motor(x) ∧ ∃f(PneumaticMotorFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor pneumático é um motor que converte energia de gás comprimido em energia mecânica rotacional.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic motor is a motor that bears a PneumaticMotorFunction.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterfacingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterfacingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma InterfacingFunction e</rdfs:label>
        <rdfs:label xml:lang="en">port</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Port(x) ↔ (MaterialArtifact(x) ∧ ∃f(InterfacingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma InterfacingFunction e que é capaz de fornecer um ponto de interface para comunicação com outro objeto.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Port ≡ MaterialArtifact ⊓ ∃bearerOf.InterfacingFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000330 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000330">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">position transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de posição</rdfs:label>
        <skos:definition xml:lang="en">A position transmitter is a transmitter that measures position or displacement and converts it to a standardized output signal.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PositionTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PositionTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PositionSignal(s) ∧ hasInput(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A position transmitter is a transmitter that measures position or displacement and converts it to a standardized output signal.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de posição é um transmissor que mede posição ou deslocamento e o converte em um sinal de saída padronizado.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every position transmitter is a transmitter that has the function of position transmission and receives position or displacement signals as input.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
        <rdfs:label xml:lang="pt-br">bomba de deslocamento positivo</rdfs:label>
        <rdfs:label xml:lang="en">positive displacement pump</rdfs:label>
        <skos:definition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PositiveDisplacementPump(x) → Pump(x) ∧ ∃y(DisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(PositiveDisplacementProcess(z) ∧ participatesIn(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de deslocamento positivo é uma bomba que transporta líquido através do princípio de deslocamento alternativo ou rotativo com volume de deslocamento fixo por ciclo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by physical mechanism. Under OWA, sufficient conditions based on displacement mechanism alone could lead to false positives where specialized equipment containing displacement elements might be incorrectly classified as standard positive displacement pumps.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every positive displacement pump is a pump that has a displacement mechanism as component part at all times and participates in positive displacement processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000332 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000332">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">enrolamento de transformador</rdfs:label>
        <rdfs:label xml:lang="en">power transformer primary winding</rdfs:label>
        <skos:definition xml:lang="en">A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerPrimaryWinding(x) → TransformerWinding(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(PrimaryWindingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um enrolamento de transformador que é parte de um transformador de potência e que serve como enrolamento primário recebendo energia elétrica de entrada para transformação eletromagnética.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on structural position within power transformer. Under OWA, sufficient conditions for primary winding configuration would risk false positives for specialized or hybrid transformer components that contain primary-like windings but should not be classified as standard power transformer primary windings.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerPrimaryWinding is-a TransformerWinding that is-part-of PowerTransformer and has-function PrimaryWindingFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000333 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000333">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">enrolamento secundário de transformador de potência</rdfs:label>
        <rdfs:label xml:lang="en">power transformer secondary winding</rdfs:label>
        <skos:definition xml:lang="en">A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerSecondaryWinding(x) → FiatObjectPart(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(SecondaryWindingFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma FiatObjectPart que é o enrolamento secundário de um transformador de potência e que possui uma SecondaryWindingFunction consistindo em fornecer energia elétrica transformada no nível de tensão de saída.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification basis - the physical configuration (being the secondary winding of a power transformer) provides necessary conditions, but sufficient conditions are harder to assert under OWA without risking false positives for specialized or hybrid transformer configurations.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerSecondaryWinding SubClassOf FiatObjectPart and (partOf some PowerTransformer) and (hasFunction some SecondaryWindingFunction)</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pressure indicating transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor indicador de pressão</rdfs:label>
        <skos:definition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PressureIndicatingTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PressureIndicatingAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(PressureSignal(i) ∧ hasInput(x,i)) ∧ ∃o1(ElectricalSignal(o1) ∧ hasOutput(x,o1)) ∧ ∃o2(LocalPressureDisplay(o2) ∧ hasOutput(x,o2)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor indicador de pressão é um transmissor que mede pressão e fornece tanto indicação visual local quanto transmissão de sinal elétrico do valor da pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure indicating transmitter is a transmitter that bears a pressure indicating and transmission function, has pressure signal as input, and has both electrical signal output and local pressure display.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
        <rdfs:label xml:lang="pt-br">carcaça de bomba</rdfs:label>
        <rdfs:label xml:lang="en">pump casing</rdfs:label>
        <skos:definition xml:lang="en">A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PumpCasing(x) → Casing(x) ∧ ∃y(Impeller(y) ∧ surrounds(x,y)) ∧ ∃z(SuctionNozzle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃w(DischargeNozzle(w) ∧ hasComponentPartAtAllTimes(x,w)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que envolve um impulsor e possui bocais de sucção e descarga integrais como componentes estruturais, tipicamente aplicado em bombas centrífugas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under Open World Assumption, structural characteristics are harder to make sufficient - any assembly with an impeller and integral nozzles might be classified as a pump casing even if it serves a different specialized purpose. Starting with necessary conditions protects against false positives.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump casing is a casing that surrounds an impeller and has integral suction and discharge nozzles forming part of its structure.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000336 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000336">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">eixo de bomba</rdfs:label>
        <rdfs:label xml:lang="en">pump shaft</rdfs:label>
        <skos:definition xml:lang="en">A pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction and that is equipped with impeller(s), bearings, bushings, and sealing elements as part of a pump assembly for transmitting rotational mechanical energy to enable fluid pumping operations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PumpShaft(x) → MaterialArtifact(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(Impeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃b(Bearing(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃p(Pump(p) ∧ partOf(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction and that is equipped with impeller(s), bearings, bushings, and sealing elements as part of a pump assembly for transmitting rotational mechanical energy to enable fluid pumping operations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um eixo de bomba é um MaterialArtifact que possui uma PowerTransmissionFunction e que é equipado com impulsor(es), mancais, buchas e elementos de vedação como parte de um conjunto de bomba para transmitir energia mecânica rotacional e possibilitar operações de bombeamento de fluidos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration, sufficient conditions are omitted to avoid false positives under OWA. Any rotating component with an impeller and bearings could theoretically be classified as a pump shaft under sufficient conditions, including hybrid equipment or specialized assemblies that should not be automatically categorized as standard pump shafts.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction, has impeller(s) as component parts, has bearings as component parts, and is part of a pump assembly.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
        <rdfs:label xml:lang="pt-br">bomba alternativa</rdfs:label>
        <rdfs:label xml:lang="en">reciprocating pump</rdfs:label>
        <skos:definition xml:lang="en">A reciprocating pump is a pump that contains pistons or plungers designed to move in a reciprocating motion within cylindrical chambers to displace fluid through positive displacement action.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ReciprocatingPump(x) → Pump(x) ∧ ∃m(ReciprocatingDisplacementMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p(PistonOrPlunger(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃c(CylindricalChamber(c) ∧ hasComponentPartAtAllTimes(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A reciprocating pump is a pump that contains pistons or plungers designed to move in a reciprocating motion within cylindrical chambers to displace fluid through positive displacement action.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba alternativa é uma bomba que contém pistões ou êmbolos projetados para se moverem em movimento alternativo dentro de câmaras cilíndricas para deslocar fluido através de ação de deslocamento positivo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under Open World Assumption, asserting equivalence based on structural differentia could lead to false positives where complex equipment containing reciprocating elements (like reciprocating compressors with auxiliary pumps, or hybrid systems) might be incorrectly classified as standard reciprocating pumps. The structural mechanism is necessary but sufficient conditions require domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every reciprocating pump is a pump that has as component part at all times a reciprocating displacement mechanism and has as component part at all times pistons or plungers and has as component part at all times cylindrical chambers.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000338 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000338">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">relay</rdfs:label>
        <rdfs:label xml:lang="pt-br">relé</rdfs:label>
        <skos:definition xml:lang="en">A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Relay(x) ↔ (ElectricalSwitchingDevice(x) ∧ ∃f(SignalRelayFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um relé é um dispositivo de comutação elétrica que possui uma função de relé de sinal, realizada ao transmitir informações ou sinais de um circuito para controlar operações em outro circuito.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every Relay is an ElectricalSwitchingDevice that bearerOf some SignalRelayFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
        <rdfs:label xml:lang="en">riser</rdfs:label>
        <rdfs:label xml:lang="pt-br">riser</rdfs:label>
        <skos:definition xml:lang="en">A riser is a pipe that has vertical or near-vertical orientation and is designed for the upward flow of liquid or gas.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Riser(x) → Pipe(x) ∧ ∃q(VerticalOrientation(q) ∧ hasQuality(x,q)) ∧ ∃p(UpwardFlowProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A riser is a pipe that has vertical or near-vertical orientation and is designed for the upward flow of liquid or gas.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um riser é um tubo que tem orientação vertical ou quase vertical e é projetado para o fluxo ascendente de líquido ou gás.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical configuration. Under OWA, any pipe with vertical orientation and upward flow could be forced into this category, including specialized equipment that should not be classified as standard risers (e.g., reactor internals, distillation column internals). Starting with necessary conditions protects against false positives.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every riser is a pipe that has vertical orientation and participates in upward flow processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000340 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000340">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
        <rdfs:label xml:lang="pt-br">atuador rotativo</rdfs:label>
        <rdfs:label xml:lang="en">rotary actuator</rdfs:label>
        <skos:definition xml:lang="en">A rotary actuator is an actuator that causes rotary motion by converting control signals into controlled rotational mechanical output.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (RotaryActuator(x) → Actuator(x) ∧ ∃p (RotaryMotionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A rotary actuator is an actuator that causes rotary motion by converting control signals into controlled rotational mechanical output.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador rotativo é um atuador que causa movimento rotativo convertendo sinais de controle em saída mecânica rotacional controlada.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on rotary motion mechanism. Under OWA, providing sufficient conditions could lead to over-classification where any equipment that happens to produce rotary motion (motors, turbines, etc.) might be incorrectly classified as rotary actuators. The rotary motion differentia is necessary but requires domain expert validation to confirm it is sufficient for the actuator equipment category.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every rotary actuator is an actuator that participates in rotary motion processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000341 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000341">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpChamber"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba rotativa</rdfs:label>
        <rdfs:label xml:lang="en">rotary pump</rdfs:label>
        <skos:definition xml:lang="en">A rotary pump is a positive displacement pump that contains a chamber with gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing, and which has no separate inlet and outlet valves.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (RotaryPump(x) → PositiveDisplacementPump(x) ∧ ∃y (RotaryDisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ¬∃z (SeparateInletValve(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ¬∃w (SeparateOutletValve(w) ∧ hasComponentPartAtAllTimes(x,w)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A rotary pump is a positive displacement pump that contains a chamber with gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing, and which has no separate inlet and outlet valves.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba rotativa é uma bomba de deslocamento positivo que contém uma câmara com engrenagens, cames, parafusos, palhetas, êmbolos ou elementos similares acionados pela rotação relativa do eixo de acionamento ou carcaça, e que não possui válvulas separadas de entrada e saída.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the rotary mechanism is clearly necessary for rotary pumps, making it sufficient under OWA could lead to false positives where complex equipment containing rotary elements (like gearboxes with pumping side-effects or hybrid machines) might be misclassified as standard rotary pumps. The constructive differentia should be validated by domain experts before upgrading to equivalence.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every rotary pump is a positive displacement pump that has a rotary displacement mechanism as component part and lacks separate inlet and outlet valves.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000342 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000342">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">rotor</rdfs:label>
        <rdfs:label xml:lang="pt-br">rotor</rdfs:label>
        <skos:definition xml:lang="en">An Assembly that participates in rotational motion and has a rotor shaft as an essential component, designed to transfer mechanical energy through rotational motion within a machine assembly.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Rotor(x) → Assembly(x) ∧ ∃p(RotationalMotionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(RotorShaft(s) ∧ hasComponentPartAtAllTimes(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An Assembly that participates in rotational motion and has a rotor shaft as an essential component, designed to transfer mechanical energy through rotational motion within a machine assembly.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que participa em movimento rotacional e tem um eixo do rotor como componente essencial, projetado para transferir energia mecânica através de movimento rotacional dentro de um conjunto de máquina.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration (rotating portion with shaft), providing sufficient conditions under OWA could lead to overclassification. Complex assemblies containing rotating elements might be incorrectly classified as rotors rather than their proper categories (motors, compressors, etc.).</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every Rotor is an Assembly that participates in some RotationalMotionProcess and has some rotor shaft as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000343 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000343">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">disco de ruptura</rdfs:label>
        <rdfs:label xml:lang="en">rupture disc</rdfs:label>
        <skos:definition xml:lang="en">A rupture disc is an instrument that realizes pressure relief through irreversible rupture at a calibrated pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (RuptureDisc(x) ↔ Instrument(x) ∧ ∃f(PressureReliefFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(IrreversibleRuptureProcess(p) ∧ participatesIn(x,p)) ∧ ∃q(CalibrationPressure(q) ∧ hasQuality(x,q)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A rupture disc is an instrument that realizes pressure relief through irreversible rupture at a calibrated pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um disco de ruptura é um instrumento que realiza alívio de pressão através de ruptura irreversível em uma pressão calibrada.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every rupture disc is an instrument that has the function to relieve pressure and participates in irreversible rupture processes at calibrated pressure thresholds.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000344 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000344">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ScrapingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ScrapingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">raspador</rdfs:label>
        <rdfs:label xml:lang="en">scraper</rdfs:label>
        <skos:definition xml:lang="en">A scraper is a material artifact that bears a scraping function for mechanically removing deposits, debris, or contaminants from surfaces.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Scraper(x) ↔ (MaterialArtifact(x) ∧ ∃f(ScrapingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A scraper is a material artifact that bears a scraping function for mechanically removing deposits, debris, or contaminants from surfaces.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um raspador é um artefato material que possui uma função de raspagem para remover mecanicamente depósitos, detritos ou contaminantes de superfícies.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every scraper is a material artifact that has a scraping function, and every material artifact that has a scraping function is a scraper.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000345 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000345">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:label xml:lang="pt-br">lavador de gases</rdfs:label>
        <rdfs:label xml:lang="en">scrubber</rdfs:label>
        <skos:definition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Scrubber(x) ↔ Separator(x) ∧ ∃f,p,g,l (SeparationFunction(f) ∧ bearerOf(x,f) ∧ LiquidWashingProcess(p) ∧ participatesIn(x,p) ∧ GasPortion(g) ∧ LiquidPortion(l) ∧ hasInput(x,g) ∧ hasInput(x,l)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um lavador de gases é um separador que limpa gás através da lavagem do fluxo gasoso com líquido para remover contaminantes como poeira, partículas ou substâncias indesejadas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every scrubber is a separator that has the function of separation and participates in liquid washing processes with both gas and liquid inputs.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257"/>
        <rdfs:label xml:lang="pt-br">eixo</rdfs:label>
        <rdfs:label xml:lang="en">shaft</rdfs:label>
        <skos:definition xml:lang="en">An Assembly that bears a PowerTransmissionFunction and that has component parts including shaft keys for torque transmission and shaft seals for leakage prevention, serving as the core rotating element in rotating machinery.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Shaft(x) → Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃k(ShaftKey(k) ∧ hasComponentPartAtAllTimes(x,k)) ∧ ∃s(ShaftSeal(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃l(ShaftSleeve(l) ∧ hasComponentPartAtAllTimes(x,l)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An Assembly that bears a PowerTransmissionFunction and that has component parts including shaft keys for torque transmission and shaft seals for leakage prevention, serving as the core rotating element in rotating machinery.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma PowerTransmissionFunction e que possui partes componentes incluindo chavetas de eixo para transmissão de torque e vedações de eixo para prevenção de vazamento, servindo como o elemento rotativo central em máquinas rotativas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical structure. Under OWA, sufficient conditions for shaft identity could lead to false positives - any assembly with a shaft key and rotational motion might be classified as a shaft rather than a more specific equipment type that contains a shaft. The structural differentia provides necessary conditions while allowing domain experts to validate sufficiency.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every shaft is an assembly that transmits power through rotation and has shaft keys, shaft seals, and shaft sleeves as essential components.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000347 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000347">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShakingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShakingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
        <rdfs:label xml:lang="en">shaker</rdfs:label>
        <skos:definition xml:lang="en">A shaker is an assembly that bears a shaking function, capable of producing vibrating or oscillating motion for material processing, agitation, or separation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">Shaker(x) ↔ Assembly(x) ∧ ∃f(ShakingFunction(f) ∧ bearerOf(x,f))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A shaker is an assembly that bears a shaking function, capable of producing vibrating or oscillating motion for material processing, agitation, or separation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um conjunto que possui uma função de agitação, capaz de produzir movimento vibratório ou oscilatório para processamento, agitação ou separação de materiais.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every shaker is an assembly that has the capability of shaking and contains a vibration mechanism and a shaking element.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000348 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000348">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShearingBlade"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShearingBlade"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">aríete de corte</rdfs:label>
        <rdfs:label xml:lang="en">shear ram</rdfs:label>
        <skos:definition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ShearRam(x) ↔ Ram(x) ∧ ∃f(PipeShearingFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ShearingBlade(b) ∧ hasComponentPartAtAllTimes(x,b)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um aríete de corte é um aríete que possui função de corte de tubulação e tem lâminas de corte endurecidas projetadas para cortar a coluna de perfuração ou tubulação durante operações de prevenção de blowout.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every shear ram is a ram that has the function to shear pipe and has shearing blades as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000349 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000349">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">polia</rdfs:label>
        <rdfs:label xml:lang="en">sheave</rdfs:label>
        <skos:definition xml:lang="en">A sheave is a material artifact that is a grooved wheel designed to transmit mechanical power through interface with belts, ropes, wires, or pipes.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Sheave(x) → MaterialArtifact(x) ∧ ∃y(GroovedRim(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A sheave is a material artifact that is a grooved wheel designed to transmit mechanical power through interface with belts, ropes, wires, or pipes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma polia é um artefato material que é uma roda sulcada projetada para transmitir energia mecânica através da interface com correias, cordas, cabos ou tubos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on physical structure. Under OWA, defining sufficient conditions based solely on having a grooved rim could lead to false positives where other grooved mechanical elements (like timing belt pulleys with different design intents) are automatically classified as sheaves. The structural differentia provides necessary conditions while allowing domain experts to confirm sufficient conditions.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every sheave is a material artifact that has a grooved rim as component part and bears a power transmission function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000350 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000350">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silencer</rdfs:label>
        <rdfs:label xml:lang="pt-br">silenciador</rdfs:label>
        <skos:definition xml:lang="en">A silencer is an assembly that bears the designed function of reducing noise levels through acoustic treatment of fluid streams.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Silencer(x) ↔ Assembly(x) ∧ ∃f(NoiseSilencingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A silencer is an assembly that bears the designed function of reducing noise levels through acoustic treatment of fluid streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um silenciador é uma montagem que possui a função projetada de reduzir níveis de ruído através do tratamento acústico de fluxos de fluidos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every silencer is an assembly that has the function to silence noise, and every assembly that has the function to silence noise is a silencer.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000351 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000351">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">silo</rdfs:label>
        <rdfs:label xml:lang="pt-br">silo</rdfs:label>
        <skos:definition xml:lang="en">A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Silo(x) ↔ (Vessel(x) ∧ ∃f(SolidBulkStorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(ConicalBottom(c) ∧ hasComponentPartAtAllTimes(x,c))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um silo é um vaso que possui uma função de armazenamento de sólidos a granel e tem uma seção inferior cônica para facilitar o armazenamento e descarga de materiais sólidos a granel.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every silo is a vessel that has the function of storing bulk solids and has a conical bottom component.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000352 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000352">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">skid</rdfs:label>
        <rdfs:label xml:lang="pt-br">skid</rdfs:label>
        <skos:definition xml:lang="en">A skid is an assembly that bears an equipment support function, consisting of a support frame and mounting points, designed to support equipment items during manufacturing, transportation, handling, and installation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Skid(x) ↔ (Assembly(x) ∧ ∃f(EquipmentSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SupportFrame(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(MountingPoint(m) ∧ hasComponentPartAtAllTimes(x,m))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A skid is an assembly that bears an equipment support function, consisting of a support frame and mounting points, designed to support equipment items during manufacturing, transportation, handling, and installation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um skid é uma montagem que possui uma função de suporte de equipamento, consistindo de uma estrutura de suporte e pontos de montagem, projetada para suportar itens de equipamento durante fabricação, transporte, manuseio e instalação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every skid is an assembly that bears an equipment support function and has a support frame and mounting points as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260"/>
        <rdfs:label xml:lang="pt-br">atuador solenoide</rdfs:label>
        <rdfs:label xml:lang="en">solenoid actuator</rdfs:label>
        <skos:definition xml:lang="en">A solenoid actuator is an electric actuator that utilizes a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SolenoidActuator(x) → ElectricActuator(x) ∧ ∃s(Solenoid(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃p(Plunger(p) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A solenoid actuator is an electric actuator that utilizes a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um atuador solenoide é um atuador elétrico que utiliza um solenoide linear de serviço contínuo para converter energia elétrica em energia mecânica através de um êmbolo com curso axial em ação de empurrar ou puxar.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by solenoid mechanism. Under OWA, sufficient conditions would force any device with solenoid and plunger components to be classified as a solenoid actuator, potentially misclassifying complex hybrid devices or specialized equipment containing solenoid components but serving different primary functions.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid actuator is an electric actuator that has a solenoid as component part and has a plunger as component part and converts electrical power to linear mechanical motion.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000354 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000354">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">espaçador</rdfs:label>
        <rdfs:label xml:lang="en">spacer</rdfs:label>
        <skos:definition xml:lang="en">A spacer is a material artifact that has the function of maintaining spatial separation or distance between physical objects or fluids.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Spacer(x) ↔ MaterialArtifact(x) ∧ ∃f(SpacingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A spacer is a material artifact that has the function of maintaining spatial separation or distance between physical objects or fluids.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um espaçador é um artefato material que tem a função de manter separação espacial ou distância entre objetos físicos ou fluidos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every spacer is a material artifact that bears a spacing function</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000355 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000355">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StatorWinding"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma StationaryMachineComponentFunction e</rdfs:label>
        <rdfs:label xml:lang="en">stator</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Stator(x) → MaterialArtifact(x) ∧ ∃f(StationaryMachineComponentFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(RotatingMachine(m) ∧ partOf(x,m)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma StationaryMachineComponentFunction e que é o componente estrutural estacionário dentro de máquinas rotativas, fornecendo alojamento e estabilidade posicional para elementos ativos como bobinas, palhetas ou vedações.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on structural positioning within rotating machinery. Under OWA, any artifact described as stationary within a rotating machine context could be classified as a stator, but this may include specialized hybrid components, mounting structures, or custom configurations that should not be automatically asserted into the standard stator maintenance category. The structural differentia (stationary positioning) is necessary but making it sufficient requires domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every Stator is a MaterialArtifact that bears a StationaryMachineComponentFunction and is part of some RotatingMachine</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000356 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000356">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262"/>
        <rdfs:label xml:lang="pt-br">contato de chave</rdfs:label>
        <rdfs:label xml:lang="en">switch contact</rdfs:label>
        <skos:definition xml:lang="en">A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (SwitchContact(x) → ElectricalContact(x) ∧ ∃y(ElectricalContact(y) ∧ partOf(x,y)) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um contato de chave é um contato elétrico que é uma das partes condutoras que formam um conjunto de contato.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on structural role as a conductive part. Under OWA, asserting sufficient conditions could incorrectly classify any conductive part of an electrical contact as a switch contact, when there may be other specialized conductive components (bus bars, terminals, etc.) that serve different structural roles.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every switch contact is an electrical contact that is part of an electrical contact assembly and bears an electrical conduction function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000357 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000357">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalSwitch"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Panel"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalSwitch"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Panel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">quadro de distribuição</rdfs:label>
        <rdfs:label xml:lang="en">switchboard</rdfs:label>
        <skos:definition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Switchboard(x) ↔ ElectricalEquipment(x) ∧ ∃p,s,i(Panel(p) ∧ ElectricalSwitch(s) ∧ ControlIndicator(i) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃f(ElectricalCircuitControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um quadro de distribuição é um equipamento elétrico que consiste em painéis que acomodam chaves, indicadores e aparatos de controle para conectar, desconectar e controlar vários circuitos de um sistema elétrico.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every switchboard is electrical equipment that has component parts (panels, switches, indicators) and bears the function to control electrical circuits</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000358 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000358">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000380"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000380"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">elemento de medição de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature measuring element</rdfs:label>
        <skos:definition xml:lang="en">A temperature measuring element is a measuring element that has the function to measure temperature.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureMeasuringElement(x) ↔ MeasuringElement(x) ∧ ∃f(TemperatureMeasurementFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A temperature measuring element is a measuring element that has the function to measure temperature.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de medição de temperatura é um elemento de medição que tem a função de medir temperatura.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature measuring element is a measuring element that has a temperature measurement function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">termowell stem</rdfs:label>
        <rdfs:label xml:lang="en">thermowell stem</rdfs:label>
        <skos:definition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ThermowellStem(x) → FiatObjectPart(x) ∧ ∃y(Thermowell(y) ∧ partOf(x,y)) ∧ ∃q(HollowCylindricalShape(q) ∧ hasQuality(x,q)) ∧ ∃l(ProcessMediumIntrusionZone(l) ∧ hasLocation(x,l)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um termowell stem é uma parte de objeto fiducial que é parte de um termowell e que tem uma forma cilíndrica oca posicionada para se projetar no meio do processo, fornecendo habitação protetora para elementos de detecção de temperatura enquanto permite condução térmica.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification basis. The structural differentia (hollow cylindrical shape, positioning in process medium) is necessary but may not be sufficient under OWA - there could be other specialized parts of thermowells with similar geometry but different specific roles or configurations.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell stem is a fiat object part that is part of some thermowell and has hollow cylindrical shape and is located in process medium intrusion zone.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">Placa que possui geometria de espessura fina e</rdfs:label>
        <rdfs:label xml:lang="en">thin plate</rdfs:label>
        <skos:definition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ThinPlate(x) → Plate(x) ∧ ∃q1(ThinThickness(q1) ∧ hasQuality(x,q1)) ∧ ∃q2(ColdFormedManufacturing(q2) ∧ hasQuality(x,q2)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma Placa que possui geometria de espessura fina e é fabricada através de processos de conformação a frio, tipicamente usada para aplicações de suporte estrutural que requerem peso reduzido ou restrições geométricas específicas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by physical geometry (thinness) and manufacturing method (cold forming). Under OWA, sufficient conditions for thin plates are difficult to specify without risking false positives from specialized hybrid structures that contain thin cold-formed elements but should not be classified as standard thin plates.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">ThinPlate ⊑ Plate ⊓ ∃hasQuality.ThinThickness ⊓ ∃hasQuality.ColdFormedManufacturing</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000361 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000361">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">separador trifásico</rdfs:label>
        <rdfs:label xml:lang="en">three phase separator</rdfs:label>
        <skos:definition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ThreePhaseSeparator(x) ↔ (Separator(x) ∧ ∃f (ThreePhaseSeparationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um separador trifásico é um separador que possui uma função de separação trifásica para separar fluidos de poço em fases gasosa, oleosa e aquosa.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every three-phase separator is a separator that has the function of separating fluid into gas, oil, and water phases, and has gas outlet, oil outlet, and water outlet as component parts.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000362 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000362">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TransductionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TransductionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">transducer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transdutor</rdfs:label>
        <skos:definition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Transducer(x) ↔ Instrument(x) ∧ ∃f (TransductionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transdutor é um instrumento que possui uma FunçãoDeTransdução para converter informação de uma forma ou magnitude de energia para outra forma ou magnitude.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every transducer is an instrument that has the designed function to convert energy or signal forms while preserving information content.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000363 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000363">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">invólucro de transmissor</rdfs:label>
        <rdfs:label xml:lang="en">transmitter housing</rdfs:label>
        <skos:definition xml:lang="en">A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(TransmitterHousing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(TransmitterElectronicCircuit(c) ∧ hasComponentPartAtAllTimes(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um invólucro de transmissor é uma Assembly que possui uma EnclosureFunction e que tem um circuito eletrônico de transmissor como parte componente em todos os momentos, projetado para fornecer proteção ambiental e contenção física para componentes do transmissor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on physical structure as housing. Under OWA, sufficient conditions for transmitter housing would require specifying exact structural features (materials, dimensions, sealing mechanisms) that distinguish it from other instrument housings. The necessary conditions establish the core identity without risking false positives from other housing types that might share some structural features.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">TransmitterHousing ⊑ Assembly ⊓ ∃bearerOf.EnclosureFunction ⊓ ∃hasComponentPartAtAllTimes.TransmitterElectronicCircuit</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000364 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000364">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingSystem"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingSystem"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">suporte de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing hanger</rdfs:label>
        <skos:definition xml:lang="en">A tubing hanger is an assembly that supports tubing strings in wellheads with integrated sealing to isolate tubing conduit from annulus.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(TubingHanger(x) ↔ (Assembly(x) ∧ ∃f(TubingSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SealingSystem(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(SupportMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(TubingConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A tubing hanger is an assembly that supports tubing strings in wellheads with integrated sealing to isolate tubing conduit from annulus.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um suporte de coluna de produção é um conjunto que suporta colunas de produção em cabeças de poço com vedação integrada para isolar o conduto da coluna do anular.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every tubing hanger is an assembly that bears a tubing support function and has component parts including a sealing system, support mechanism, and tubing connection.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000365 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000365">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingBowl"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingBowl"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">cabeça de coluna</rdfs:label>
        <rdfs:label xml:lang="en">tubing head</rdfs:label>
        <skos:definition xml:lang="en">A tubing head is a wellhead component that supports the tubing hanger and provides a connection interface for attaching the Christmas tree to the wellhead assembly.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(TubingHead(x) ↔ WellheadComponent(x) ∧ ∃f(TubingSupportAndConnectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p1(TubingBowl(p1) ∧ hasComponentPartAtAllTimes(x,p1)) ∧ ∃p2(ChristmasTreeConnectionInterface(p2) ∧ hasComponentPartAtAllTimes(x,p2)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A tubing head is a wellhead component that supports the tubing hanger and provides a connection interface for attaching the Christmas tree to the wellhead assembly.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma cabeça de coluna é um componente de cabeça de poço que suporta o suspensor de coluna e fornece uma interface de conexão para fixar a árvore de natal ao conjunto de cabeça de poço.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every tubing head is a wellhead component that bears a tubing support and connection function, has a tubing bowl as component part, and has a Christmas tree connection interface as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">turbina</rdfs:label>
        <rdfs:label xml:lang="en">turbine</rdfs:label>
        <skos:definition xml:lang="en">A turbine is an assembly that bears an energy extraction function and has rotating shaft and fluid-interacting blades that extract energy from flowing fluids and convert it into useful mechanical work.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Turbine(x) ↔ Assembly(x) ∧ ∃f(EnergyExtractionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(RotatingShaft(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃b(FluidInteractionBlades(b) ∧ hasComponentPartAtAllTimes(x,b)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A turbine is an assembly that bears an energy extraction function and has rotating shaft and fluid-interacting blades that extract energy from flowing fluids and convert it into useful mechanical work.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma turbina é um conjunto que possui uma função de extração de energia e tem eixo rotativo e pás de interação com fluidos que extraem energia de fluidos em movimento e a convertem em trabalho mecânico útil.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every turbine is an assembly that bears an energy extraction function and has component parts including a rotating shaft, fluid interaction blades, casing, and bearing system.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000367 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000367">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableBundle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingBundle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">umbilical</rdfs:label>
        <rdfs:label xml:lang="pt-br">umbilical</rdfs:label>
        <skos:definition xml:lang="en">An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Umbilical(x) → Assembly(x) ∧ ∃c,t,s,conn (CableBundle(c) ∧ TubingBundle(t) ∧ ProtectiveSheathing(s) ∧ ConnectorAssembly(conn) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,t) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,conn) ∧ hasQuality(x,Flexibility) ∧ hasQuality(x,EasyDisconnectability)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um umbilical é uma montagem que é um feixe flexível e facilmente desconectável contendo cabos e tubulação para transmissão de múltiplos serviços incluindo controle, energia, comunicação e injeção química.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive basis requires necessary conditions only. Under OWA, any assembly with cables, tubing, flexibility, and disconnectability could be forcibly classified as umbilical, including specialized multi-service bundles, complex wiring harnesses, or custom transmission assemblies that contain these elements but serve different industrial contexts and maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every umbilical is an assembly that has component parts including cable bundles and tubing bundles, and has the qualities of flexibility and easy disconnectability.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000368 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000368">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">unidade UPS</rdfs:label>
        <rdfs:label xml:lang="en">ups unit</rdfs:label>
        <skos:definition xml:lang="en">A UPS unit is electrical equipment that bears the designed function of maintaining uninterrupted AC electric power supply to protected equipment during power disturbances.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(UPSUnit(x) ↔ ElectricalEquipment(x) ∧ ∃f(UninterruptedPowerSupplyFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A UPS unit is electrical equipment that bears the designed function of maintaining uninterrupted AC electric power supply to protected equipment during power disturbances.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma unidade UPS é um equipamento elétrico que possui a função projetada de manter o fornecimento ininterrupto de energia elétrica AC para equipamentos protegidos durante distúrbios de energia.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every UPS unit is electrical equipment that has the function of maintaining uninterrupted AC electric power supply.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000369 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000369">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255"/>
        <rdfs:label xml:lang="pt-br">coluna de vácuo</rdfs:label>
        <rdfs:label xml:lang="en">vacuum column</rdfs:label>
        <skos:definition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(VacuumColumn(x) → DistillationColumn(x) ∧ ∃q(VacuumPressureResistanceQuality(q) ∧ bearerOf(x,q)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de vácuo é uma coluna de destilação projetada para resistir à pressão externa durante operação sob vácuo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on structural capability. Under OWA, defining sufficient conditions for vacuum-capable design would be complex and could lead to false positives. The structural differentia (vacuum resistance) requires domain expert validation of what constitutes adequate vacuum design capability.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every vacuum column is a distillation column that bears a vacuum pressure resistance quality.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000370 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000370">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">membro de fechamento de válvula</rdfs:label>
        <rdfs:label xml:lang="en">valve closure member</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that is a component part of a valve and that is positioned in the flow stream to permit, obstruct, divert or regulate flow through mechanical positioning.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ValveClosureMember(x) → MaterialArtifact(x) ∧ ∃v (Valve(v) ∧ isComponentPartOf(x,v)) ∧ ∃p (FlowControlProcess(p) ∧ participatesIn(x,p)) ∧ ∃q (PositionableInFlowStream(q) ∧ hasQuality(x,q)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is a component part of a valve and that is positioned in the flow stream to permit, obstruct, divert or regulate flow through mechanical positioning.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é uma parte componente de uma válvula e que é posicionado no fluxo para permitir, obstruir, desviar ou regular o fluxo através de posicionamento mecânico.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration and mechanical role, the valve closure member should use necessary conditions. The structural differentia (being positioned in flow stream) is harder to make sufficient under OWA - other components or hybrid devices might satisfy the conditions but not be classified as standard valve closure members.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve closure member is a material artifact that is a component part of some valve and participates in flow control processes by being positioned within the flow stream.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">assento de válvula</rdfs:label>
        <rdfs:label xml:lang="en">valve seat</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ValveSeat(x) → (MaterialArtifact(x) ∧ ∃y(Valve(y) ∧ partOf(x,y)) ∧ ∃z(ValveClosureMember(z) ∧ adjacentTo(x,z)) ∧ ∃q(SealingSurfaceQuality(q) ∧ bearerOf(x,q))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é parte de uma válvula e que fornece a superfície de assentamento contra a qual o membro de fechamento se apoia para alcançar o fechamento e controle do fluxo de fluido de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Valve seat is a constructive type defined by its structural configuration and interface role. Under the Open World Assumption, making this an equivalence class could lead to false positives where any artifact that is part of a valve and adjacent to a closure member gets classified as a valve seat, even if it serves a different structural role (such as guides, stops, or supports).</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">ValveSeat ⊑ MaterialArtifact ⊓ ∃partOf.Valve ⊓ ∃adjacentTo.ValveClosureMember ⊓ ∃bearerOf.SealingSurfaceQuality</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">haste de válvula</rdfs:label>
        <rdfs:label xml:lang="en">valve stem</rdfs:label>
        <skos:definition xml:lang="en">An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ValveStem(x) → Assembly(x) ∧ ∃f(ForceTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(ValveStemSeal(s) ∧ hasComponentPartAtAllTimes(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma ForceTransmissionFunction e que tem um selo de haste de válvula como parte componente, especificamente projetado para transmitir movimento de um operador de válvula para o membro de fechamento da válvula.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by physical structure (rod/shaft mechanism). Under Open World Assumption, sufficient conditions would force any assembly with a valve stem seal and force transmission function to be classified as a valve stem, which could include complex multi-component assemblies, manifolds, or specialized valve mechanisms that contain these elements but should not be asserted into the standard valve stem maintenance category.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">ValveStem SubClassOf Assembly and bearerOf some ForceTransmissionFunction and hasComponentPartAtAllTimes some ValveStemSeal</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000373 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000373">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">tampo de vaso</rdfs:label>
        <rdfs:label xml:lang="en">vessel head</rdfs:label>
        <skos:definition xml:lang="en">A FiatObjectPart that is part of a vessel and that closes a vessel shell by providing an end boundary for containment.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(VesselHead(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃r(VesselClosureRole(r) ∧ realizes(x,r)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FiatObjectPart that is part of a vessel and that closes a vessel shell by providing an end boundary for containment.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma FiatObjectPart que é parte de um vaso e que fecha o casco do vaso fornecendo uma fronteira terminal para contenção.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, asserting sufficient conditions for vessel head closure would inappropriately classify any part that closes a vessel (including specialized manifolds, complex multi-port heads, or custom closures) as standard vessel heads, potentially creating false positives in maintenance categorization.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel head is a fiat object part that is part of some vessel and realizes a vessel closure role.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000374 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000374">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">parte de objeto por fiat</rdfs:label>
        <rdfs:label xml:lang="en">vessel shell</rdfs:label>
        <skos:definition xml:lang="en">A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(VesselShell(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃f(PressureContainmentFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma parte de objeto por fiat que é o limite estrutural externo de contenção de pressão de um vaso, projetada para encerrar e isolar o conteúdo interno enquanto suporta cargas de pressão interna.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by structural configuration as outer pressure-containing part of vessel. Under Open World Assumption, sufficient conditions are difficult to establish - other structural components might also be pressure-containing parts of vessels in specialized designs.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">VesselShell SubClassOf: FiatObjectPart and partOf some Vessel and bearerOf some PressureContainmentFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000375 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000375">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">poço</rdfs:label>
        <rdfs:label xml:lang="en">well</rdfs:label>
        <skos:definition xml:lang="en">A well is an engineered system that interacts with subsurface resources through a drilled wellbore, designed to obtain, produce, store, or inject materials into or from the earth.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Well(x) ↔ EngineeredSystem(x) ∧ ∃f(SubsurfaceResourceInteractionFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellbore(w) ∧ hasComponentPartAtSomeTime(x,w)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A well is an engineered system that interacts with subsurface resources through a drilled wellbore, designed to obtain, produce, store, or inject materials into or from the earth.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um poço é um sistema projetado que interage com recursos do subsolo através de um furo perfurado, projetado para obter, produzir, armazenar ou injetar materiais na terra ou a partir dela.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every well is an engineered system that bears a subsurface resource interaction function and has a wellbore as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000376 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000376">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
        <rdfs:label xml:lang="pt-br">poço perfurado</rdfs:label>
        <rdfs:label xml:lang="en">wellbore</rdfs:label>
        <skos:definition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Wellbore(x) ↔ Site(x) ∧ ∃f(SubsurfaceAccessFunction(f) ∧ hasFunction(x,f)) ∧ ∃w(Well(w) ∧ spatiallyContainedIn(x,w)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um poço perfurado é um local que fornece um caminho perfurado para acesso subsuperficial e está espacialmente contido dentro de um sistema de poço.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellbore is a site that has the function of providing subsurface access and is spatially contained within a well.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000377 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000377">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellheadSpool"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellheadSpool"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">cabeçal de poço</rdfs:label>
        <rdfs:label xml:lang="en">wellhead</rdfs:label>
        <skos:definition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Wellhead(x) ↔ Assembly(x) ∧ ∃f(WellSurfaceControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃h(CasingHanger(h) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃w(Wellbore(w) ∧ hasConnectionTo(x,w)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um cabeçal de poço é um conjunto que porta uma função de controle superficial do poço e fornece a interface estrutural e de controle entre um poço e os equipamentos de superfície.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellhead is an assembly that bears a well surface control function and has component parts including casing hangers and connection to wellbore</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000378 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000378">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">wireline</rdfs:label>
        <rdfs:label xml:lang="pt-br">wireline</rdfs:label>
        <skos:definition xml:lang="en">A wireline is an electrical cable that bears a wireline logging function for lowering tools into wellbores and transmitting data about wellbore conditions.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Wireline(x) ↔ ElectricalCable(x) ∧ ∃f (WirelineLoggingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A wireline is an electrical cable that bears a wireline logging function for lowering tools into wellbores and transmitting data about wellbore conditions.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um wireline é um cabo elétrico que possui uma função de perfilagem wireline para descer ferramentas em poços e transmitir dados sobre as condições do poço.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every wireline is an electrical cable that has the function to lower tools into wellbores and transmit logging data signals to the surface.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000379 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000379">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">absorber</rdfs:label>
        <rdfs:label xml:lang="pt-br">absorvedor</rdfs:label>
        <skos:definition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Absorber(x) ↔ (Separator(x) ∧ ∃f(AbsorptionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um absorvedor é um vaso de pressão que realiza uma função de absorção para transferência seletiva de massa de componentes de uma mistura fluida para uma fase absorvente.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every absorber is a separator that has the function to absorb specific components from fluid mixtures through mass transfer to an absorbent phase</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000380 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000380">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">elemento de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature element</rdfs:label>
        <skos:definition xml:lang="en">A temperature element is an instrument that bears a temperature sensing function.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureElement(x) ↔ DetectingElement(x) ∧ ∃f(TemperatureSensingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A temperature element is an instrument that bears a temperature sensing function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de temperatura é um instrumento que possui uma função de sensoreamento de temperatura.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature element is a detecting element that has the function to sense temperature</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CableBundle -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CableBundle">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:label xml:lang="en">cable bundle</rdfs:label>
        <rdfs:label xml:lang="pt-br">feixe de cabo</rdfs:label>
        <skos:definition xml:lang="en">An assembly of electrical cables routed together and secured as a group in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CableSupportFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CableSupportFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cable support function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de suporte de cabos</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical support and routing of cables to maintain their position and protect them from damage.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CableSupportProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CableSupportProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">cable support process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de suporte de cabos</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which cables are mechanically supported and routed to maintain their position and protect them from damage in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CapturedPig -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CapturedPig">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">captured pig</rdfs:label>
        <rdfs:label xml:lang="pt-br">pig de capturado</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a pipeline pig that has been retrieved and confined in a pig receiver following completion of its pipeline pass.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CarrierFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CarrierFluid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">carrier fluid</rdfs:label>
        <rdfs:label xml:lang="pt-br">fluido de portador</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a fluid used to transport or suspend another substance through petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cathodic protection function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de proteção catódica</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the prevention of electrochemical corrosion of a metallic structure by making it the cathode of an electrochemical cell.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">cathodic protection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de proteção catódica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which electrochemical corrosion of a metallic structure is prevented by making it the cathode of an electrochemical cell through the supply of electrical current or sacrificial anodes.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Chamber -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Chamber">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">chamber</rdfs:label>
        <rdfs:label xml:lang="pt-br">câmara</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an enclosed space within petroleum production equipment in which a process such as separation, compression, or storage takes place.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ChemicalFuelPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChemicalFuelPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">chemical fuel portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção químico de combustível</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of chemical fuel consumed in a combustion process in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ChristmasTreeConnectionPoint -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChristmasTreeConnectionPoint">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">christmas tree connection point</rdfs:label>
        <rdfs:label xml:lang="pt-br">ponto de árvore de natal de árvore de conexão</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a mechanical connection point on a Christmas tree for attachment of flowlines, control lines, or other equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">chromatographic analysis function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de análise cromatográfica</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation and quantification of chemical components in a sample by differential migration through a stationary phase.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">chromatographic analysis process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de análise cromatográfica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the chemical components of a sample are separated and quantified by their differential migration through a stationary phase in petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ChromatographicSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">chromatographic signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de cromatográfico</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting a signal generated by a chromatographic detector representing the presence and concentration of chemical components in a process sample.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">circuit protection function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de proteção de circuito</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic interruption or limitation of current in an electrical circuit to protect equipment from overload or fault conditions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">circuit protection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de proteção de circuito</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which current in an electrical circuit is automatically interrupted or limited to protect equipment from overload or fault conditions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CleanedGasPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CleanedGasPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">cleaned gas portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção limpo de gás</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas from which impurities have been removed by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CleanedSurface -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CleanedSurface">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">cleaned surface</rdfs:label>
        <rdfs:label xml:lang="pt-br">superfície limpo</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a surface from which scale, deposits, or contaminants have been removed by a cleaning process in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">coalescence process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de coalescência</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which dispersed droplets of one phase aggregate within another to form larger droplets that can be more readily separated from the continuous phase.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CombustionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CombustionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CombustionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">combustion function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de combustão</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the exothermic chemical reaction of a fuel with an oxidant to produce heat and combustion products.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CombustionGasPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionGasPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">combustion gas portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de combustão de gás</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas undergoing or having undergone a combustion reaction in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CombustionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">combustion process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de combustão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a fuel reacts exothermically with an oxidant to produce heat and combustion products in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CombustionProductPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionProductPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">combustion product portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de combustão de produto</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of the chemical products resulting from a combustion reaction in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CombustionProducts -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionProducts">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">combustion products</rdfs:label>
        <rdfs:label xml:lang="pt-br">produtos de combustão</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the chemical products—primarily carbon dioxide and water vapour—resulting from the combustion of a fuel in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CompositionAnalysisData -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompositionAnalysisData">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">composition analysis data</rdfs:label>
        <rdfs:label xml:lang="pt-br">dados de composição de análise</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting data representing the chemical composition of a process fluid as determined by analytical instrumentation in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CompressedAirPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressedAirPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">compressed air portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção comprimido de ar</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of air that has been compressed to a pressure above atmospheric for use in pneumatic systems of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CompressedGasPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressedGasPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">compressed gas portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção comprimido de gás</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas that has been compressed to a higher pressure for transport, storage, or processing in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">compression process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de compressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the pressure of a gas is increased by reducing its volume through mechanical work applied by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CompressorInternals -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressorInternals">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">compressor internals</rdfs:label>
        <rdfs:label xml:lang="pt-br">internos de compressor</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the internal components—such as impellers, valves, and seals—contained within the casing of a compressor in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">condensation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de condensação</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of a vapour into liquid by removing thermal energy until the substance reaches its dew point.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">condensation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de condensação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a vapour is converted into liquid by removing thermal energy until the substance reaches its dew point in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">conductivity transmission function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transmissão de condutividade</rdfs:label>
        <skos:definition xml:lang="en">A signal transmission function borne by petroleum production equipment whose realization constitutes the measurement of fluid electrical conductivity and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
        <rdfs:label xml:lang="en">conductivity transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de condutividade</rdfs:label>
        <skos:definition xml:lang="en">A signal transmission process in which the electrical conductivity of a fluid is measured and the corresponding signal transmitted to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">connection function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de conexão</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical or fluid joining of two or more components to allow the transfer of force, fluid, or signal between them.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">connection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de conexão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which two or more components or systems are mechanically or fluidly joined to allow the transfer of force, fluid, or signal between them.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ContainmentProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContainmentProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">containment process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de contenção</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ContaminatedSurface -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContaminatedSurface">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">contaminated surface</rdfs:label>
        <rdfs:label xml:lang="pt-br">superfície contaminado</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a surface bearing scale, deposits, or contaminants that are to be removed by a cleaning process in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">base contínuo</rdfs:label>
        <rdfs:label xml:lang="en">continuous base</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the base structure that provides continuous support for equipment or pipework in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ControlFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">control function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de controle</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the regulation of a process variable by adjusting a manipulated variable in response to a measured deviation from a set point.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">control indicator</rdfs:label>
        <rdfs:label xml:lang="pt-br">indicador de controle</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a component that displays and enables adjustment of a set point or control parameter in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ControlProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">control process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de controle</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a process variable is regulated by adjusting a manipulated variable in response to a measured deviation from a set point.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CoolantPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolantPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">coolant portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de refrigerante</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of cooling medium used to remove thermal energy from a process stream or equipment component.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CooledHeatingMedium -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CooledHeatingMedium">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">cooled heating medium</rdfs:label>
        <rdfs:label xml:lang="pt-br">meio de resfriado de aquecimento</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a heating medium that has transferred thermal energy to a process stream and returned to a lower temperature.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">cooling function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de resfriamento</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of thermal energy from a process stream or equipment component to reduce its temperature.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">cooling process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de resfriamento</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which thermal energy is removed from a process stream or equipment component to reduce its temperature in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CorrosionProducts -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CorrosionProducts">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">corrosion products</rdfs:label>
        <rdfs:label xml:lang="pt-br">produtos de corrosão</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the solid products—oxides, hydroxides, or sulfides—formed on a metallic surface as a result of corrosion in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CuttingsAndFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CuttingsAndFluid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">cuttings and fluid</rdfs:label>
        <rdfs:label xml:lang="pt-br">fluido de cascalhos de e</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a mixture of rock cuttings and drilling fluid circulated from the wellbore bottom to the surface during drilling operations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DampingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DampingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DampingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DampingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">damping function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de amortecimento</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the absorption and dissipation of mechanical energy to reduce the amplitude of oscillations or vibrations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DampingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DampingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">damping process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de amortecimento</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which mechanical energy is absorbed and dissipated to reduce the amplitude of oscillations or vibrations in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DeaerationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DeaerationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">deaeration function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de desaeração</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of dissolved oxygen and other non-condensable gases from a liquid stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">deaeration process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de desaeração</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which dissolved oxygen and other non-condensable gases are removed from a liquid stream in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">degassing function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de degaseificação</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of dissolved or entrained gases from a liquid to reduce their concentration.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">degassing process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de degaseificação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which dissolved or entrained gases are removed from a liquid to reduce their concentration below a specified level.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dehumidification function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de desumidificação</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of water vapour from a gas stream to reduce its relative humidity or dew point.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DehumidificationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">dehumidification process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de desumidificação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which water vapour is removed from a gas stream to reduce its relative humidity or dew point to a specified level.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dehydration function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de desidratação</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of water from a fluid stream by adsorption, absorption, or distillation to meet specification limits.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">dehydration process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de desidratação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which water is removed from a fluid stream by adsorption, absorption, or distillation to meet product specification limits.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">demisting function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de separação de névoa</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the coalescence and removal of entrained liquid droplets from a gas stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DemistingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DemistingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">demisting process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de separação de névoa</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which entrained liquid droplets are coalesced and removed from a gas stream by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DensePhase -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensePhase">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">dense phase</rdfs:label>
        <rdfs:label xml:lang="pt-br">fase denso</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the denser of two or more phases present in a separation process within petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">density measurement function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de medição de densidade</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the mass per unit volume of a fluid stream or substance.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">density measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição de densidade</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the mass per unit volume of a fluid stream or substance is measured by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">detection function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de detecção</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the sensing and identification of the presence, concentration, or state of a physical or chemical entity.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">detection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de detecção</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the presence, concentration, or state of a physical or chemical entity is sensed and identified by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DetectionSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">detection signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de detecção</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a signal generated by a detection element indicating the presence or concentration of a detected entity in petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dew point measurement function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de medição de ponto de orvalho</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the temperature at which a gas mixture begins to condense.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">dew point measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição de ponto de orvalho</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the temperature at which a gas mixture begins to condense is measured by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DieselFuel -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DieselFuel">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">combustível diesel</rdfs:label>
        <rdfs:label xml:lang="en">diesel fuel</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes diesel fuel used as energy source for engines or combustion equipment in petroleum production installations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureIndication -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureIndication">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">differential pressure indication</rdfs:label>
        <rdfs:label xml:lang="pt-br">indicação de diferencial de pressão</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting a displayed or transmitted value representing the differential pressure between two process points in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementAndTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementAndTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
        <rdfs:label xml:lang="en">differential pressure measurement and transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição e transmissão de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A pressure measurement and transmission process in which the differential pressure between two process points is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">differential pressure measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a differential pressure measuring element senses the pressure difference between two fluid inputs, producing a mechanical deflection or signal proportional to the differential pressure for measurement purposes.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a differential pressure measuring element senses the pressure difference between two fluid inputs, producing a mechanical deflection or signal proportional to the differential pressure for measurement purposes.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">differential pressure switching function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de chaveamento por pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the differential pressure between two process points crosses a defined threshold.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">differential pressure switching process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de chaveamento por pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the differential pressure between two process points crosses a defined threshold.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DiscreteElectricalSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DiscreteElectricalSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">discrete electrical signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal discreto elétrico</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting an electrical signal that can assume only two defined states—on or off—used in control and safety systems of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">distillation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de destilação</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation of a liquid mixture into fractions of differing volatilities by successive vaporisation and condensation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DistillationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DistillationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">distillation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de destilação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a liquid mixture is separated into fractions of differing volatilities by successive vaporisation and condensation in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DisturbanceSource -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DisturbanceSource">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">disturbance source</rdfs:label>
        <rdfs:label xml:lang="pt-br">fonte de perturbação</rdfs:label>
        <skos:definition xml:lang="en">A process in which a source of unwanted perturbation—vibration, electrical noise, or pressure surge—affecting the performance of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DivergingChannel -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DivergingChannel">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">canal divergente</rdfs:label>
        <rdfs:label xml:lang="en">diverging channel</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a flow passage that expands in cross-sectional area in the direction of flow to reduce fluid velocity in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DivertingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DivertingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivertingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivertingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diverting function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de desvio de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the redirection of fluid flow from one path to one or more alternative downstream paths.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DivertingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DivertingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">diverting process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de desvio de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which fluid flow is redirected from one path to one or more alternative downstream paths by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DownholeToolAssembly -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DownholeToolAssembly">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">conjunto de fundo de poço de ferramenta</rdfs:label>
        <rdfs:label xml:lang="en">downhole tool assembly</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an assembly of tools deployed in a wellbore on a wireline or tubing string to perform measurement, completion, or intervention operations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DriedMaterial -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DriedMaterial">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">dried material</rdfs:label>
        <rdfs:label xml:lang="pt-br">material seco</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a material from which moisture or solvent has been removed by a drying process in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DrillBit -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillBit">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">broca de perfuração</rdfs:label>
        <rdfs:label xml:lang="en">drill bit</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the rotating cutting tool at the bottom of a drill string that fragments rock to advance the wellbore.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DrillString -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillString">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">coluna de perfuração</rdfs:label>
        <rdfs:label xml:lang="en">drill string</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the assembly of drill pipe, drill collars, and bottom-hole assembly that transmits rotation and drilling fluid from surface to the drill bit.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DrillingFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">drilling fluid</rdfs:label>
        <rdfs:label xml:lang="pt-br">fluido de perfuração</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the fluid—water-based, oil-based, or synthetic—circulated during drilling to cool the bit, carry cuttings to surface, and stabilise the wellbore.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">drilling fluid conduction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de condução de fluido de perfuração</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the circulation of drilling fluid from surface to the drill bit and back through the wellbore annulus.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">drilling fluid conduction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de condução de fluido de perfuração</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which drilling fluid is circulated from the surface to the drill bit and returned through the wellbore annulus to remove cuttings and cool the bit.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">drilling fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de perfuração de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of drilling fluid at a defined point in the drilling circulation system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DrillingTool -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingTool">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">drilling tool</rdfs:label>
        <rdfs:label xml:lang="pt-br">ferramenta de perfuração</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a tool used in the bottom-hole assembly or drill string to perform a specific function during the drilling of a petroleum well.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DryAirPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DryAirPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">dry air portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção seco de ar</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of air from which water vapour has been removed to a specified dew point.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DryingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DryingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DryingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DryingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">drying function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de secagem</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of moisture or solvent from a solid, liquid, or gas stream by thermal, adsorptive, or other means.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DryingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DryingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">drying process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de secagem</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which moisture or solvent is removed from a solid, liquid, or gas stream by thermal, adsorptive, or other means.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electric energy generation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de geração de energia elétrica</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of mechanical, thermal, or chemical energy into electrical energy.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electric energy generation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de geração de energia elétrica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which mechanical, thermal, or chemical energy is converted into electrical energy by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricToMechanicalConversionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricToMechanicalConversionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electric to mechanical conversion process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de conversão elétrico-mecânica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which electrical energy is converted into rotational or linear mechanical motion by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalCable -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCable">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">cabo elétrico</rdfs:label>
        <rdfs:label xml:lang="en">electrical cable</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an insulated conductor or assembly of conductors used to transmit electrical power or signals in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical circuit control function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de controle de circuito elétrico</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the switching, routing, or regulation of current in an electrical circuit to control connected loads.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electrical circuit control process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de controle de circuito elétrico</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which current in an electrical circuit is switched, routed, or regulated to control connected loads.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical conduction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de condução elétrica</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electrical conduction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de condução elétrica</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical connection function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de conexão elétrica</rdfs:label>
        <skos:definition xml:lang="en">A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electrical connection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de conexão elétrica</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrent -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrent">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="pt-br">corrente elétrico</rdfs:label>
        <rdfs:label xml:lang="en">electrical current</rdfs:label>
        <skos:definition xml:lang="en">A process in which the flow of electric charge through a conductor in an electrical circuit of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentFlow -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentFlow">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">electrical current flow</rdfs:label>
        <rdfs:label xml:lang="pt-br">fluxo elétrico de corrente</rdfs:label>
        <skos:definition xml:lang="en">A process in which the directed movement of electric charge carriers through a conductor in petroleum production electrical systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentInterruptionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentInterruptionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electrical current interruption process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de interrupção de corrente elétrica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which an electrical circuit is opened to stop the flow of current, either under normal operating conditions or in response to a fault.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalEnergyPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalEnergyPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">electrical energy portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção elétrico de energia</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a quantity of electrical energy supplied to or consumed by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electrical power transformation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transformação de energia elétrica</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">electrical signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal elétrico</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting an electrical signal carrying a measurement, control, or status value within petroleum production instrumentation and control systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalSwitch -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalSwitch">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">electrical switch</rdfs:label>
        <rdfs:label xml:lang="pt-br">interruptor elétrico</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a device that opens or closes an electrical circuit in response to a manual or automatic input in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">electrochemical oxidation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de oxidação eletroquímica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a material is oxidised at an electrode surface through an electrochemical reaction, such as in cathodic protection or electrochemical sensing.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectromagneticRadiation -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectromagneticRadiation">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">electromagnetic radiation</rdfs:label>
        <rdfs:label xml:lang="pt-br">radiação eletromagnético</rdfs:label>
        <skos:definition xml:lang="en">A process in which electromagnetic energy—such as infrared or ultraviolet radiation—detected or emitted by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">emergency shut down process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de parada de emergência</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which process flows or equipment are rapidly and automatically isolated in response to a detected hazardous condition.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">enclosure function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de proteção e invólucro</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">enclosure process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de proteção e invólucro</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">energy diffusion function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de difusão de energia</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the dispersion of thermal, acoustic, or kinetic energy over a larger volume or surface to reduce its local intensity.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">energy diffusion process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de difusão de energia</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which thermal, acoustic, or kinetic energy is dispersed over a larger volume or surface to reduce its local intensity.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">energy extraction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de extração de energia</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the recovery of useful work or heat from a process stream, pressure differential, or thermal source.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">energy extraction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de extração de energia</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which useful work or heat is recovered from a process stream, pressure differential, or thermal source in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnergyPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">energy portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de energia</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a quantity of energy in a defined form that participates in a process within petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">energy transfer function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transferência de energia</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the movement of energy in the form of heat, work, or electromagnetic radiation from one medium or system to another.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">energy transfer process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transferência de energia</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which energy in the form of heat, work, or electromagnetic radiation is transferred from one medium or system to another.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EquipmentItem -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentItem">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">equipment item</rdfs:label>
        <rdfs:label xml:lang="pt-br">item de equipamento</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a discrete item of petroleum production equipment assembled or installed as a unit within a production system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">equipment support function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de suporte de equipamento</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical support of process equipment to maintain its position and transmit loads to a structural foundation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">equipment support process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de suporte de equipamento</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which process equipment is mechanically supported to maintain its position and transmit structural loads to a foundation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ExhaustGas -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ExhaustGas">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">exhaust gas</rdfs:label>
        <rdfs:label xml:lang="pt-br">gás de escapamento</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the combustion exhaust gas discharged from an engine, turbine, or fired heater in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ExhaustGasPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ExhaustGasPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">exhaust gas portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de escapamento de gás</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of exhaust gas at a defined point in the exhaust system of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ExpandedGasPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ExpandedGasPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">expanded gas portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção expandido de gás</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas that has undergone expansion and pressure reduction in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FilterMedium -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilterMedium">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">filter medium</rdfs:label>
        <rdfs:label xml:lang="pt-br">meio de filtro</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the porous material through which a fluid stream passes to remove suspended particulates or liquid droplets in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FilteredConstituents -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilteredConstituents">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">constituintes filtrado</rdfs:label>
        <rdfs:label xml:lang="en">filtered constituents</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the fluid constituents that pass through a filter medium during a filtration process in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FilteredContaminants -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilteredContaminants">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">contaminantes filtrado</rdfs:label>
        <rdfs:label xml:lang="en">filtered contaminants</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the solid or liquid contaminants captured and retained by a filter medium during a filtration process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FilteredFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilteredFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">filtered fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção filtrado de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid from which particulate or liquid contaminants have been removed by filtration.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">filtration process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de filtração</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which particles, contaminants, or unwanted substances are selectively retained from a fluid stream by a filter element through mechanical screening or other separation mechanisms while clean fluid passes through.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which particles, contaminants, or unwanted substances are selectively retained from a fluid stream by a filter element through mechanical screening or other separation mechanisms while clean fluid passes through.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FinnedTube -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FinnedTube">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">finned tube</rdfs:label>
        <rdfs:label xml:lang="pt-br">tubo de aletado</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a heat transfer tube with extended surfaces—fins—that increase the external surface area to enhance heat exchange with a gas stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fired heating function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de aquecimento a combustão</rdfs:label>
        <skos:definition xml:lang="en">A heating function borne by petroleum production equipment whose realization constitutes the transfer of thermal energy generated by combustion to a process stream or vessel.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
        <rdfs:label xml:lang="en">fired heating process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de aquecimento a combustão</rdfs:label>
        <skos:definition xml:lang="en">A heating process in which thermal energy is generated by the combustion of fuel and transferred to a process stream or vessel through a fired heater.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlameArrestFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flame arrest function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de contenção de chama</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the prevention of flame propagation through a flammable gas mixture by quenching the flame front in narrow passages.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flame arrest process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de contenção de chama</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which flame propagation through a flammable gas mixture is prevented by quenching the flame front in narrow passages of a flame arrester.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flame detection function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de detecção de chama</rdfs:label>
        <skos:definition xml:lang="en">A detection function borne by petroleum production equipment whose realization constitutes the sensing of the presence of a flame or combustion event by detecting radiant energy or other combustion signatures.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
        <rdfs:label xml:lang="en">flame detection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de detecção de chama</rdfs:label>
        <skos:definition xml:lang="en">A detection process in which the presence of a flame or combustion event is sensed by detecting radiant energy or other combustion signatures.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flash vaporization function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de vaporização flash</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the partial vaporisation of a pressurised liquid stream caused by a rapid reduction in pressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flash vaporization process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de vaporização flash</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a pressurised liquid stream is partially vaporised as a result of a rapid reduction in pressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlexibleDiaphragm -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlexibleDiaphragm">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">diafragma flexível</rdfs:label>
        <rdfs:label xml:lang="en">flexible diaphragm</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a flexible membrane that separates two chambers and transmits pressure between them in petroleum production measurement or control equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flow control process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de controle de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flow indication process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de indicação de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the instantaneous flow rate of a process stream is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurement">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">flow measurement</rdfs:label>
        <rdfs:label xml:lang="pt-br">medição de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting a quantitative value representing the flow rate of a process stream as measured by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flow measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow modification function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de modificação de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flow modification process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de modificação de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which the characteristics of fluid flow are altered by a flow modification accessory, resulting in changes to flow patterns, velocity profiles, turbulence levels, or pressure drop characteristics while the fluid passes through or around the device.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which the characteristics of fluid flow are altered by a flow modification accessory, resulting in changes to flow patterns, velocity profiles, turbulence levels, or pressure drop characteristics while the fluid passes through or around the device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flow restriction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de restrição de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the flow rate or pressure of a fluid stream is reduced in a controlled manner by introducing a fixed or variable resistance.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowSignalTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSignalTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
        <rdfs:label xml:lang="en">flow signal transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de sinal de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A signal transmission process in which a standardised signal representing a measured flow rate is transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow switching function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de chaveamento de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the flow rate of a process stream crosses a defined threshold.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">flow switching process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de chaveamento de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the flow rate of a process stream crosses a defined threshold.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fluid conduction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de condução de fluido</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conveyance of a fluid from one location to another while maintaining containment and flow direction.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">fluid conduction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de condução de fluido</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a fluid is conveyed from one location to another through containment structures while maintaining flow direction and preventing leakage.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fluid direction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de direcionamento de fluido</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the guidance or steering of fluid flow in a defined direction within a process system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">fluid direction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de direcionamento de fluido</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which fluid flow is guided or steered in a defined direction within a process system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fluid distribution function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de distribuição de fluido</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the splitting and delivery of a fluid stream to multiple downstream points in defined proportions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">fluid distribution process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de distribuição de fluido</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a fluid stream is split and delivered to multiple downstream points in defined proportions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidMixturePortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidMixturePortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">fluid mixture portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de fluido de mistura</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more fluids at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidOpening -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidOpening">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">abertura de fluido</rdfs:label>
        <rdfs:label xml:lang="en">fluid opening</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an opening in the body of petroleum production equipment through which fluid enters or exits.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidPort -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidPort">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">bocal de fluido</rdfs:label>
        <rdfs:label xml:lang="en">fluid port</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a port or connection point through which fluid enters or exits a component of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a defined portion of fluid at a specified point within a petroleum production process stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidTransportFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fluid transport function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transporte de fluido</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conveyance of a fluid over distance by exploiting pressure differentials, gravity, or imparted energy.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">fluid transport process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transporte de fluido</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a fluid is conveyed over distance by exploiting pressure differentials, gravity, or energy imparted by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">force to electrical transduction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transdução força-elétrica</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of a mechanical force or pressure into a proportional electrical signal.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">force to electrical transduction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transdução força-elétrica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a mechanical force or pressure is converted into a proportional electrical signal by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">force transmission function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transmissão de força</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a ForceTransmissionProcess and that consists in transmitting mechanical force or motion from one component to another through direct physical coupling.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a ForceTransmissionProcess and that consists in transmitting mechanical force or motion from one component to another through direct physical coupling.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">force transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de força</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which mechanical force or motion is transferred from an input component to an output component through direct physical coupling and mechanical linkage.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical force or motion is transferred from an input component to an output component through direct physical coupling and mechanical linkage.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FormationFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FormationFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">formation fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de formação de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid originating from a subsurface geological formation and produced through a petroleum production well.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FuelPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FuelPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">fuel portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de combustível</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of fuel supplied to a combustion device in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasDetectingMeasuringElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasDetectingMeasuringElement">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MeasuringElement"/>
        <rdfs:label xml:lang="pt-br">elemento de gás de detecção de medição</rdfs:label>
        <rdfs:label xml:lang="en">gas detecting measuring element</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a sensing element within petroleum production gas detection equipment that responds to the presence and concentration of a target gas.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasDetectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de detecção de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas detection function</rdfs:label>
        <skos:definition xml:lang="en">A detection function borne by petroleum production equipment whose realization constitutes the sensing and identification of the presence or concentration of a specific gas or vapour in the surrounding atmosphere.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasDetectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
        <rdfs:label xml:lang="en">gas detection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de detecção de gás</rdfs:label>
        <skos:definition xml:lang="en">A detection process in which the presence or concentration of a specific gas or vapour in the surrounding atmosphere is sensed and identified.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasMixturePortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasMixturePortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">gas mixture portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de gás de mistura</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more gases at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">gas movement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de movimentação de gás</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which gas is transported from one location to another by imparting kinetic or pressure energy to the gas stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">gas portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de gás</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GaseousFuelPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GaseousFuelPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">gaseous fuel portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção gasoso de combustível</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of gaseous fuel—such as natural gas—supplied to combustion equipment in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GaseousPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GaseousPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">gaseous portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção gasoso</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas phase material at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de separação gravitacional</rdfs:label>
        <rdfs:label xml:lang="en">gravity separation function</rdfs:label>
        <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the separation of phases of differing densities by the action of gravity in a settling vessel.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
        <rdfs:label xml:lang="en">gravity separation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de separação gravitacional</rdfs:label>
        <skos:definition xml:lang="en">A separation process in which phases of differing densities are separated by the action of gravity in a vessel or settler.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HeatingMedium -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatingMedium">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">heating medium</rdfs:label>
        <rdfs:label xml:lang="pt-br">meio de aquecimento</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the fluid—steam, hot oil, or heated water—used to supply thermal energy to a process stream in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">heating process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de aquecimento</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which thermal energy is transferred to a process stream or vessel to raise its temperature.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HighPressureFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HighPressureFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">high pressure fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção alto de pressão de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid maintained at a pressure significantly above the system reference pressure in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HighPressureSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HighPressureSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">high pressure signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal alto de pressão</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting an electrical or pneumatic signal representing a high-pressure condition in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HumidAirPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HumidAirPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">humid air portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção úmido de ar</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of air carrying a significant concentration of water vapour in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HumidityMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HumidityMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">humidity measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição de umidade</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the moisture content or relative humidity of a gas stream is measured by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">fluido hidráulico</rdfs:label>
        <rdfs:label xml:lang="en">hydraulic fluid</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the incompressible fluid used to transmit pressure and power in hydraulic systems of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">hydraulic fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção hidráulico de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of hydraulic fluid at a defined point in the hydraulic circuit of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpInlet -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpInlet">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
        <rdfs:label xml:lang="pt-br">entrada hidráulico de bomba</rdfs:label>
        <rdfs:label xml:lang="en">hydraulic pump inlet</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the suction inlet port through which fluid is drawn into a hydraulic pump in petroleum production hydraulic systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpOutlet -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpOutlet">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
        <rdfs:label xml:lang="en">hydraulic pump outlet</rdfs:label>
        <rdfs:label xml:lang="pt-br">saída hidráulico de bomba</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the discharge outlet port through which pressurised fluid leaves a hydraulic pump in petroleum production hydraulic systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de bombeamento hidráulico</rdfs:label>
        <rdfs:label xml:lang="en">hydraulic pumping function</rdfs:label>
        <skos:definition xml:lang="en">A pumping function borne by petroleum production equipment whose realization constitutes the transfer of mechanical energy to a hydraulic fluid to transmit power or actuate hydraulic equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
        <rdfs:label xml:lang="en">hydraulic pumping process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de bombeamento hidráulico</rdfs:label>
        <skos:definition xml:lang="en">A pumping process in which mechanical energy is imparted to a hydraulic fluid to transmit power or actuate hydraulic equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HydrocarbonFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydrocarbonFluid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">fluido de hidrocarboneto</rdfs:label>
        <rdfs:label xml:lang="en">hydrocarbon fluid</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a fluid consisting primarily of hydrocarbon compounds produced from or processed in a petroleum production system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InLineFilter -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InLineFilter">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
        <rdfs:label xml:lang="pt-br">filtro em linha</rdfs:label>
        <rdfs:label xml:lang="en">in line filter</rdfs:label>
        <skos:definition xml:lang="en">An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (InLineFilter(x) → Filter(x) ∧ ∃m,e (InLineInstallation(m) ∧ ConnectedEquipment(e) ∧ hasInstallationMethod(x,m) ∧ supportedBy(x,e)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um filtro em linha é um filtro que é instalado diretamente dentro de uma linha de fluido e suportado por tubulações ou equipamentos conectados, projetado para remover partículas ou contaminantes de correntes de fluido durante operações normais de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical installation configuration. Under OWA, any filter with in-line connections and piping support could be classified as in-line filter, but specialized hybrid equipment or custom installations might have these features without belonging to the standard in-line filter maintenance category. Starting with necessary conditions protects against false positives.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every in-line filter is a filter that has an in-line installation method and is supported by connected equipment.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/IndicationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/IndicationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">indication process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de indicação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the value of a process variable is measured and displayed locally or transmitted to enable monitoring.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InformationBearingArtifact -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationBearingArtifact">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">artefato de informação de mancal</rdfs:label>
        <rdfs:label xml:lang="en">information bearing artifact</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that bears information—in the form of a signal, display, or record—representing a process variable or equipment state in petroleum production systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InformationBearingEntity -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationBearingEntity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">entidade de informação de mancal</rdfs:label>
        <rdfs:label xml:lang="en">information bearing entity</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting that carries or encodes information representing a process variable, equipment state, or analytical result in petroleum production systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InformationContentEntity -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationContentEntity">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">entidade de informação de conteúdo</rdfs:label>
        <rdfs:label xml:lang="en">information content entity</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting the informational content—a measurement value, alarm state, or analysis result—encoded in a signal or record within petroleum production systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de exibição de informação</rdfs:label>
        <rdfs:label xml:lang="en">information display function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an InformationDisplayProcess and that consists in presenting or exhibiting information visually to operators or other users for the purpose of communication, monitoring, or decision-making.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an InformationDisplayProcess and that consists in presenting or exhibiting information visually to operators or other users for the purpose of communication, monitoring, or decision-making.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">information display process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de exibição de informação</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InformationSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">information signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de informação</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a signal carrying informational content such as a measurement value or status indication within petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de injeção</rdfs:label>
        <rdfs:label xml:lang="en">injection function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the introduction of a fluid, chemical, or material into a process stream, vessel, or wellbore under controlled conditions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">injection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de injeção</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a fluid, chemical, or material is introduced into a process stream, vessel, or wellbore under controlled conditions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InstrumentationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InstrumentationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">instrumentation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de instrumentação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which physical process variables are measured, transmitted, or controlled by instrumentation to enable monitoring and regulation of petroleum production operations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InterfacingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InterfacingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de interfaceamento</rdfs:label>
        <rdfs:label xml:lang="en">interfacing function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an InterfacingProcess and that consists in providing a standardized point of interface for communication, connection, or interaction with another object or system.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an InterfacingProcess and that consists in providing a standardized point of interface for communication, connection, or interaction with another object or system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">interfacing process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de interfaceamento</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a port establishes and maintains a point of interface that enables communication, connection, or interaction between distinct objects or systems.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a port establishes and maintains a point of interface that enables communication, connection, or interaction between distinct objects or systems.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/KineticMotion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KineticMotion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">kinetic motion</rdfs:label>
        <rdfs:label xml:lang="pt-br">movimento cinético</rdfs:label>
        <skos:definition xml:lang="en">A process in which the directed mechanical motion of a component or fluid stream carrying kinetic energy in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de separação knock-out</rdfs:label>
        <rdfs:label xml:lang="en">knock out separation function</rdfs:label>
        <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the removal of entrained liquid droplets from a gas stream by gravity or inertial impingement.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
        <rdfs:label xml:lang="en">knock out separation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de separação knock-out</rdfs:label>
        <skos:definition xml:lang="en">A separation process in which entrained liquid droplets are removed from a gas stream by gravity or inertial impingement in a knockout vessel.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelDetectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelDetectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">level detection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de detecção de nível</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the fluid level within a vessel is detected as reaching a defined high or low threshold.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">level indication process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de indicação de nível</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the fluid level within a vessel or container is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelInformation -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelInformation">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">informação de nível</rdfs:label>
        <rdfs:label xml:lang="en">level information</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a measurement or display value representing the fluid level in a vessel of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">level measurement and transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição e transmissão de nível</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the fluid level within a vessel is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">level signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de nível</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the fluid level in a vessel of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de chaveamento de nível</rdfs:label>
        <rdfs:label xml:lang="en">level switching function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the fluid level in a vessel crosses a defined high or low threshold.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">level switching process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de chaveamento de nível</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the fluid level in a vessel crosses a defined high or low threshold.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LightPhase -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LightPhase">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">fase leve</rdfs:label>
        <rdfs:label xml:lang="en">light phase</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the less dense of two or more phases present in a separation process within petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LiquidMixturePortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidMixturePortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">liquid mixture portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção líquido de mistura</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more liquid phases at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LiquidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">liquid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção líquido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of liquid phase material at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LocalPressureDisplay -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LocalPressureDisplay">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">display local de pressão</rdfs:label>
        <rdfs:label xml:lang="en">local pressure display</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an instrument mounted locally to a pressure measurement point that visually displays the process pressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LocalTemperatureDisplay -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LocalTemperatureDisplay">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">display local de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">local temperature display</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an instrument mounted locally to a temperature measurement point that visually displays the process temperature.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LoggingData -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LoggingData">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">dados de perfilagem</rdfs:label>
        <rdfs:label xml:lang="en">logging data</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting data acquired by measurement tools deployed in a wellbore to characterise subsurface formation properties.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LowPressureSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LowPressureSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">low pressure signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal baixo de pressão</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting an electrical or pneumatic signal representing a low-pressure condition in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ManualControlSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ManualControlSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">manual control signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal manual de controle</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a control signal generated by an operator to adjust the set point or state of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MassFlowRateSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MassFlowRateSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">mass flow rate signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de massa de fluxo de taxa</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the mass flow rate of a process stream as measured by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MasterValve -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MasterValve">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">master valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de principal</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the main isolation valve at the base of a Christmas tree that controls fluid flow from the tubing head.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MaterialArtifact -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialArtifact">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">artefato de material</rdfs:label>
        <rdfs:label xml:lang="en">material artifact</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a physical object that is part of a petroleum production system and bears functions whose realizations are planned processes in petroleum production operations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MaterialComponent -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialComponent">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">componente de material</rdfs:label>
        <rdfs:label xml:lang="en">material component</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a discrete material component of petroleum production equipment that contributes to its overall function.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MaterialPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">material portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de material</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a defined quantity of a material substance at a specified point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de processamento de material</rdfs:label>
        <rdfs:label xml:lang="en">material processing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the physical or chemical transformation of a material to alter its composition, form, or physical state.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">material processing process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de processamento de material</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a material is physically or chemically transformed to alter its composition, form, or physical state in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MatingSurface -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MatingSurface">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">mating surface</rdfs:label>
        <rdfs:label xml:lang="pt-br">superfície de encaixe</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a machined surface that mates with a corresponding surface of another component to form a seal or mechanical joint in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the value of a physical or chemical quantity is determined and expressed as a numerical value with an associated unit.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MeasurementSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasurementSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">measurement signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de medição</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing a measured process variable value in petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MeasuringElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasuringElement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">elemento de medição</rdfs:label>
        <rdfs:label xml:lang="en">measuring element</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a primary measurement element within petroleum production instrumentation that directly responds to the measured variable.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalDisplacement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalDisplacement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="pt-br">deslocamento mecânico</rdfs:label>
        <rdfs:label xml:lang="en">mechanical displacement</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a material entity, constituting the displacement of a mechanical component from its reference position in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de geração de energia mecânica</rdfs:label>
        <rdfs:label xml:lang="en">mechanical energy generation function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of thermal, chemical, or electrical energy into mechanical energy in the form of rotational or linear motion.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">mechanical energy generation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de geração de energia mecânica</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which thermal, chemical, or electrical energy is converted into rotational or linear mechanical energy by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">mechanical energy portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção mecânico de energia</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a quantity of mechanical energy—kinetic or potential—present in a component or fluid of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalForce -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalForce">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="pt-br">força mecânico</rdfs:label>
        <rdfs:label xml:lang="en">mechanical force</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a force applied to or by a mechanical component in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalLoad -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalLoad">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="pt-br">carga mecânico</rdfs:label>
        <rdfs:label xml:lang="en">mechanical load</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a material entity, constituting the aggregate mechanical force or moment applied to a structural component of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalMotion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalMotion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">mechanical motion</rdfs:label>
        <rdfs:label xml:lang="pt-br">movimento mecânico</rdfs:label>
        <skos:definition xml:lang="en">A process in which the movement of a mechanical component along a defined path in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalMovement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalMovement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">mechanical movement</rdfs:label>
        <rdfs:label xml:lang="pt-br">movimento mecânico</rdfs:label>
        <skos:definition xml:lang="en">A process in which the translational or rotational displacement of a mechanical element relative to a reference frame in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalRotation -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalRotation">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">mechanical rotation</rdfs:label>
        <rdfs:label xml:lang="pt-br">rotação mecânico</rdfs:label>
        <skos:definition xml:lang="en">A process in which the angular motion of a rotating component about its axis in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalSupport -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalSupport">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">mechanical support</rdfs:label>
        <rdfs:label xml:lang="pt-br">suporte mecânico</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a structural member that bears mechanical loads to maintain the position and alignment of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalWork -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalWork">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="en">mechanical work</rdfs:label>
        <rdfs:label xml:lang="pt-br">trabalho mecânico</rdfs:label>
        <skos:definition xml:lang="en">A process in which the work performed by or on a mechanical component through the application of force over a displacement in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MetallicStructure -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MetallicStructure">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">estrutura metálico</rdfs:label>
        <rdfs:label xml:lang="en">metallic structure</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a metallic structural element—frame, vessel shell, or structural member—that forms part of a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MixedFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixedFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">mixed fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção misto de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid formed by the combination of two or more streams in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MixingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de mistura</rdfs:label>
        <rdfs:label xml:lang="en">mixing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the combination and blending of two or more fluid streams or components to achieve a homogeneous mixture.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MixingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">mixing process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de mistura</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which two or more fluid streams or components are combined and blended to achieve a homogeneous mixture.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de compensação de movimentação</rdfs:label>
        <rdfs:label xml:lang="en">movement compensation function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the accommodation of relative movement between connected components caused by thermal expansion, vibration, or settlement.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">movement compensation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de compensação de movimentação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which relative movement between connected components caused by thermal expansion, vibration, or settlement is accommodated without transmitting excessive stress.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MovingObject -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovingObject">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">moving object</rdfs:label>
        <rdfs:label xml:lang="pt-br">objeto móvel</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a moving element within petroleum production equipment—such as a piston, rotor, or actuator—that transmits force or motion.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MovingVane -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovingVane">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">moving vane</rdfs:label>
        <rdfs:label xml:lang="pt-br">palheta móvel</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a moving blade or vane within a turbine, pump, or separator that interacts with a fluid stream in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transmissão de múltiplos serviços</rdfs:label>
        <rdfs:label xml:lang="en">multi service transmission function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the simultaneous measurement and transmission of multiple process variables to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">multi service transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de múltiplos serviços</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which multiple process variables are simultaneously measured and their corresponding signals transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MultiphaseFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiphaseFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">multiphase fluid portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção multifásico de fluido</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid containing two or more distinct phases—gas, liquid hydrocarbon, or water—at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de silenciamento de ruído</rdfs:label>
        <rdfs:label xml:lang="en">noise silencing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the attenuation of acoustic energy in a fluid stream or mechanical system to reduce radiated noise to acceptable levels.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">noise silencing process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de silenciamento de ruído</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which acoustic energy in a fluid stream or mechanical system is attenuated to reduce radiated noise to an acceptable level.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/OilPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/OilPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="en">oil portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de óleo</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of liquid hydrocarbon at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Panel -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Panel">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">painel</rdfs:label>
        <rdfs:label xml:lang="en">panel</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a flat structural panel that provides a mounting surface for instrumentation, controls, or electrical equipment in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceIndication -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceIndication">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">indicação de fase de sequência</rdfs:label>
        <rdfs:label xml:lang="en">phase sequence indication</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting a displayed or transmitted value representing the phase sequence of an alternating-current electrical supply in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">phase sequence measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição de sequência de fases</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the phase sequence of an alternating-current electrical supply is measured and verified by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PhysicalObject -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalObject">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">objeto físico</rdfs:label>
        <rdfs:label xml:lang="en">physical object</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a discrete physical entity within a petroleum production system that occupies space and has defined material properties.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PhysicalPhenomenon -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalPhenomenon">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="pt-br">fenômeno físico</rdfs:label>
        <rdfs:label xml:lang="en">physical phenomenon</rdfs:label>
        <skos:definition xml:lang="en">A process in which a physical phenomenon—such as a pressure wave, temperature gradient, or electromagnetic field—that participates in or is generated by a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PhysicalVariable -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalVariable">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">physical variable</rdfs:label>
        <rdfs:label xml:lang="pt-br">variável físico</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a measurable physical property—such as pressure, temperature, or flow rate—of a process stream or equipment state in petroleum production.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PigFromPipeline -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigFromPipeline">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">pig from pipeline</rdfs:label>
        <rdfs:label xml:lang="pt-br">pipeline de pig de proveniente de</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a pipeline pig that has been retrieved from a pipeline after completing its pass and is now held in the pig receiver.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de lançamento e recebimento de pig</rdfs:label>
        <rdfs:label xml:lang="en">pig launching and receiving function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes both the controlled introduction of a pipeline pig into a pipeline and its retrieval after passage through the line.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pig launching and receiving process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de lançamento e recebimento de pig</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a pipeline pig is introduced into a pipeline under operating pressure and subsequently retrieved after completing its passage.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de lançamento de pig</rdfs:label>
        <rdfs:label xml:lang="en">pig launching function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled introduction of a pipeline pig into a pipeline under operating pressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pig launching process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de lançamento de pig</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a pipeline pig is introduced into a pipeline under operating pressure to perform internal cleaning, inspection, or product separation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de recebimento de pig</rdfs:label>
        <rdfs:label xml:lang="en">pig receiving function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled retrieval and containment of a pipeline pig after its passage through a pipeline.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PigReceivingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pig receiving process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de recebimento de pig</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a pipeline pig is retrieved and contained in a receiving trap after completing its passage through a pipeline.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PipePig -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipePig">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">pig de tubo</rdfs:label>
        <rdfs:label xml:lang="en">pipe pig</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a device propelled through a pipeline by the flow of product to perform internal inspection, cleaning, or product separation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de corte de tubulação</rdfs:label>
        <rdfs:label xml:lang="en">pipe shearing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical cutting of a tubular string within a wellbore to enable emergency well control.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PipeShearingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pipe shearing process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de corte de tubulação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a tubular string within a wellbore is mechanically cut to enable emergency well control.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PipelinePig -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipelinePig">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">pig de pipeline</rdfs:label>
        <rdfs:label xml:lang="en">pipeline pig</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a device inserted into and propelled through a pipeline to perform internal inspection, cleaning, or gauging operations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Piston -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Piston">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">piston</rdfs:label>
        <rdfs:label xml:lang="pt-br">pistão</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a sliding disc or cylinder that moves within a cylindrical bore to compress gas or transmit hydraulic force in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PneumaticEnergyConversionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PneumaticEnergyConversionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pneumatic energy conversion process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de conversão de energia pneumática</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which compressed-gas energy is converted into rotational mechanical energy by pneumatic actuators or motors.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PneumaticMotorFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PneumaticMotorFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PneumaticEnergyConversionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PneumaticEnergyConversionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de acionamento pneumático</rdfs:label>
        <rdfs:label xml:lang="en">pneumatic motor function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of compressed-gas energy into rotational mechanical motion.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PolyphaseElectricalSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PolyphaseElectricalSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">polyphase electrical signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal polifásico elétrico</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a multi-phase electrical signal used to characterise or transmit information about a polyphase alternating-current supply.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PositionLimitDetectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionLimitDetectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">position limit detection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de detecção de limite de posição</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the end-of-travel or open or closed position of a moving mechanical component is detected and signalled.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PositionMeasurementAndTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionMeasurementAndTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MeasurementProcess"/>
        <rdfs:label xml:lang="en">position measurement and transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição e transmissão de posição</rdfs:label>
        <skos:definition xml:lang="en">A measurement process in which the position of a mechanical component is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PositionSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">position signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de posição</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the position of a mechanical component in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PositionMeasurementAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PositionMeasurementAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transmissão de posição</rdfs:label>
        <rdfs:label xml:lang="en">position transmission function</rdfs:label>
        <skos:definition xml:lang="en">A signal transmission function borne by petroleum production equipment whose realization constitutes the measurement of the position of a mechanical component and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">power transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de potência</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transferred from a prime mover through a rotating shaft to one or more driven machines, typically involving the conversion of torque and rotational speed to match operational requirements.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from a driving component to a driven component through the rotation or linear motion of a shaft, enabling the transfer of torque and rotational speed.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from an external energy source through a rotating shaft to downstream mechanical components, enabling power transfer within a mechanical system.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted through rotational motion from one component to another via a rotating shaft, enabling the transfer of torque and angular velocity to mounted components.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which mechanical power is transferred from one rotating or reciprocating component to another through direct mechanical engagement, resulting in motion transmission and potentially torque or speed modification.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which mechanical rotational energy is transmitted from a prime mover through a shaft to driven components, resulting in the transfer of torque and rotational motion necessary for equipment operation.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transferred from a prime mover through a rotating shaft to one or more driven machines, typically involving the conversion of torque and rotational speed to match operational requirements.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from a driving component to a driven component through the rotation or linear motion of a shaft, enabling the transfer of torque and rotational speed.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from an external energy source through a rotating shaft to downstream mechanical components, enabling power transfer within a mechanical system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted through rotational motion from one component to another via a rotating shaft, enabling the transfer of torque and angular velocity to mounted components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical power is transferred from one rotating or reciprocating component to another through direct mechanical engagement, resulting in motion transmission and potentially torque or speed modification.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical rotational energy is transmitted from a prime mover through a shaft to driven components, resulting in the transfer of torque and rotational motion necessary for equipment operation.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de contenção de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure containment function</rdfs:label>
        <skos:definition xml:lang="en">A containment function borne by petroleum production equipment whose realization constitutes the retention of fluid within a defined pressure boundary to prevent uncontrolled release.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pressure containment process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de contenção de pressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a fluid is held within a defined pressure boundary to prevent uncontrolled release to the environment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureField -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureField">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="pt-br">campo de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure field</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a material entity, constituting the pressure distribution within a fluid volume in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de indicação e transmissão de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure indicating and transmission function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of process pressure and both its local display and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pressure indicating and transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de indicação e transmissão de pressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which process pressure is measured and both displayed locally and transmitted as a standardised signal to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pressure measurement process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de medição de pressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the absolute or gauge pressure of a process stream is measured and expressed as a quantitative value.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureReading -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReading">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">leitura de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure reading</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting a quantitative value representing the pressure of a process stream as measured and displayed by petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pressure reduction process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de redução de pressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the pressure of a fluid is reduced from a higher upstream value to a controlled lower downstream value.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pressure relief process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de alívio de pressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a flow path is automatically opened to discharge fluid when process pressure exceeds a defined set point, protecting equipment from overpressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureReliefValve -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefValve">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">pressure relief valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de pressão de alívio</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a self-actuating safety valve that opens at a defined set pressure to discharge fluid and protect equipment from overpressure.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145"/>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureSensingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSensingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pressure sensing process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de sensoriamento de pressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which fluid pressure is detected and converted into a measurable electrical or pneumatic signal.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureSensor -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSensor">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:label xml:lang="en">pressure sensor</rdfs:label>
        <rdfs:label xml:lang="pt-br">sensor de pressão</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a sensing element assembly that measures fluid pressure and converts it into an electrical or pneumatic signal.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="en">pressure signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de pressão</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the pressure of a process stream in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureSignalPair -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignalPair">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">par de pressão de sinal</rdfs:label>
        <rdfs:label xml:lang="en">pressure signal pair</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a pair of pressure signals representing the upstream and downstream pressures at two points of a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureSignalTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignalTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
        <rdfs:label xml:lang="en">pressure signal transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de sinal de pressão</rdfs:label>
        <skos:definition xml:lang="en">A signal transmission process in which a standardised signal representing a measured pressure value is transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="en">pressure transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de pressão</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a standardised signal representing a measured pressure value is transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressurizedFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressurizedFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção pressurizado de fluido</rdfs:label>
        <rdfs:label xml:lang="en">pressurized fluid portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid held at a pressure above the reference pressure in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção de processo de fluido</rdfs:label>
        <rdfs:label xml:lang="en">process fluid portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of the process fluid—hydrocarbon, water, or gas—handled at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidSample -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidSample">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">amostra de processo de fluido</rdfs:label>
        <rdfs:label xml:lang="en">process fluid sample</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a representative sample of process fluid withdrawn from a petroleum production stream for analysis or testing.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ProcessVariable -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessVariable">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">process variable</rdfs:label>
        <rdfs:label xml:lang="pt-br">variável de processo</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a measurable variable—pressure, temperature, flow rate, or level—that characterises the state of a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ProtectedTemperatureSensingElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProtectedTemperatureSensingElement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">elemento protegido de temperatura de sensoriamento</rdfs:label>
        <rdfs:label xml:lang="en">protected temperature sensing element</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a temperature sensing element installed within a thermowell or protective sheath to isolate it from the process medium while remaining thermally coupled.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PumpChamber -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PumpChamber">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">câmara de bomba</rdfs:label>
        <rdfs:label xml:lang="en">pump chamber</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the enclosed space within a pump casing in which fluid is pressurised by the impeller or piston.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de bombeamento</rdfs:label>
        <rdfs:label xml:lang="en">pumping process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which mechanical energy is imparted to a fluid to increase its pressure, velocity, or elevation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RaisedEdge -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RaisedEdge">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">borda saliente</rdfs:label>
        <rdfs:label xml:lang="en">raised edge</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a raised rim or flange on a component of petroleum production equipment that provides a sealing surface or structural boundary.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de despressurização rápida</rdfs:label>
        <rdfs:label xml:lang="en">rapid depressurization process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which pressure within a process system is discharged at an accelerated rate to a safe destination in an emergency.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de aquecimento reativo</rdfs:label>
        <rdfs:label xml:lang="en">reactive heating function</rdfs:label>
        <skos:definition xml:lang="en">A heating function borne by petroleum production equipment whose realization constitutes the generation and transfer of thermal energy through an exothermic chemical reaction.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
        <rdfs:label xml:lang="pt-br">processo de aquecimento reativo</rdfs:label>
        <rdfs:label xml:lang="en">reactive heating process</rdfs:label>
        <skos:definition xml:lang="en">A heating process in which thermal energy is generated by a chemical reaction and transferred to the process, such as in a reactor or fired heater.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ReboilingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReboilingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de refervimento</rdfs:label>
        <rdfs:label xml:lang="en">reboiling function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the partial vaporisation of liquid at the base of a distillation column by supplying heat to drive vapour upward through the column.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de refervimento</rdfs:label>
        <rdfs:label xml:lang="en">reboiling process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which liquid at the base of a distillation column is partially vaporised by the supply of heat to drive vapour upward through the column.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ReferenceSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReferenceSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">reference signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal de referência</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a signal representing a reference value—such as a set point or calibration standard—used in control or measurement systems of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RemovedMaterial -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RemovedMaterial">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">material de removido</rdfs:label>
        <rdfs:label xml:lang="en">removed material</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes material—scale, deposits, or cuttings—removed from a surface or stream by a mechanical cleaning process in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RestrictedObject -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RestrictedObject">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">objeto restrito</rdfs:label>
        <rdfs:label xml:lang="en">restricted object</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a component whose movement or flow is constrained by a restriction mechanism in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RockCuttings -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RockCuttings">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">cascalhos de rocha</rdfs:label>
        <rdfs:label xml:lang="en">rock cuttings</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes rock fragments produced by the drill bit during drilling and transported to surface by the circulating drilling fluid.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RotatingVanes -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotatingVanes">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">palhetas rotativo</rdfs:label>
        <rdfs:label xml:lang="en">rotating vanes</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an assembly of vanes attached to a rotating element that interacts with a fluid stream in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transferência de energia rotacional</rdfs:label>
        <rdfs:label xml:lang="en">rotational energy transfer function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a RotationalEnergyTransferProcess and that consists in the capacity to transfer mechanical energy through rotational motion within a machine assembly.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a RotationalEnergyTransferProcess and that consists in the capacity to transfer mechanical energy through rotational motion within a machine assembly.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de transferência de energia rotacional</rdfs:label>
        <rdfs:label xml:lang="en">rotational energy transfer process</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a rotor transfers mechanical energy through its rotational motion, enabling the operation of rotating machinery such as motors, compressors, pumps, and turbines.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a rotor transfers mechanical energy through its rotational motion, enabling the operation of rotating machinery such as motors, compressors, pumps, and turbines.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RotationalMotion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalMotion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="pt-br">movimento rotacional</rdfs:label>
        <rdfs:label xml:lang="en">rotational motion</rdfs:label>
        <skos:definition xml:lang="en">A process in which the angular motion of a rotating component about its axis in petroleum production rotating equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ScrapingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ScrapingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ScrapingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ScrapingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de raspagem</rdfs:label>
        <rdfs:label xml:lang="en">scraping function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical removal of deposits, scale, or coatings from the interior surface of a pipeline or vessel.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ScrapingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ScrapingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de raspagem</rdfs:label>
        <rdfs:label xml:lang="en">scraping process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which deposits, scale, or coatings are mechanically removed from the interior surface of a pipeline or vessel.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SealedJoint -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealedJoint">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">junta selado</rdfs:label>
        <rdfs:label xml:lang="en">sealed joint</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a joint between two components in petroleum production equipment that is sealed to prevent leakage of process fluid.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SealingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de vedação</rdfs:label>
        <rdfs:label xml:lang="en">sealing function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a SealingProcess and that consists in providing a tight interface against which a closure element bears to prevent fluid leakage through a valve.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a SealingProcess and that consists in providing a tight interface against which a closure element bears to prevent fluid leakage through a valve.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SealingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de vedação</rdfs:label>
        <rdfs:label xml:lang="en">sealing process</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a valve seat provides a sealing interface for a closure element (gate, ball, disc) to bear against, preventing fluid passage when the valve is closed.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a valve seat provides a sealing interface for a closure element (gate, ball, disc) to bear against, preventing fluid passage when the valve is closed.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SealingSystem -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingSystem">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="en">sealing system</rdfs:label>
        <rdfs:label xml:lang="pt-br">sistema de vedação</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the assembly of seals, gaskets, and packing that prevents leakage between two components of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SensingElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SensingElement">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">elemento de sensoriamento</rdfs:label>
        <rdfs:label xml:lang="en">sensing element</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a primary element that directly responds to a physical or chemical variable to generate a measurement signal in petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SeparateVapourSpace -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparateVapourSpace">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">espaço separado de vapor</rdfs:label>
        <rdfs:label xml:lang="en">separate vapour space</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a distinct vapour space within petroleum production equipment where disengaged gas accumulates above the liquid level.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SeparatedSolidLiquidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparatedSolidLiquidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção separado líquido de sólido</rdfs:label>
        <rdfs:label xml:lang="en">separated solid liquid portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the solid–liquid fraction recovered after a phase separation process in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de separação</rdfs:label>
        <rdfs:label xml:lang="en">separation process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a heterogeneous mixture is divided into two or more fractions of differing composition by exploiting differences in physical properties.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ShakingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShakingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShakingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShakingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de agitação mecânica</rdfs:label>
        <rdfs:label xml:lang="en">shaking function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the application of oscillating mechanical motion to a screen or separator to promote separation of solids from a fluid.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ShakingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShakingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de agitação mecânica</rdfs:label>
        <rdfs:label xml:lang="en">shaking process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which oscillating mechanical motion is applied to a screen or separator to promote the separation of solids from a fluid.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ShearingBlade -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShearingBlade">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">lâmina de cisalhamento</rdfs:label>
        <rdfs:label xml:lang="en">shearing blade</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the cutting blade of a shear ram in a blowout preventer that severs a tubular string for well control purposes.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Shell -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Shell">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">casco</rdfs:label>
        <rdfs:label xml:lang="en">shell</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the outer cylindrical wall of a pressure vessel, heat exchanger, or column that forms the main pressure boundary in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SideOutlet -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SideOutlet">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">saída lateral</rdfs:label>
        <rdfs:label xml:lang="en">side outlet</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a lateral outlet port on a vessel or pipe fitting through which fluid is discharged from the side of the equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Signal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Signal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="en">signal</rdfs:label>
        <rdfs:label xml:lang="pt-br">sinal</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a physical quantity—electrical, pneumatic, or optical—carrying information about a process variable or equipment state in petroleum production systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SignalRelayFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de retransmissão de sinal</rdfs:label>
        <rdfs:label xml:lang="en">signal relay function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the reception and re-transmission of a control or monitoring signal to extend its range or provide electrical isolation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SignalRelayProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de retransmissão de sinal</rdfs:label>
        <rdfs:label xml:lang="en">signal relay process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a control or monitoring signal is received and re-transmitted to extend its range or provide electrical isolation between circuits.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de armazenamento de sólidos a granel</rdfs:label>
        <rdfs:label xml:lang="en">solid bulk storage function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the containment and temporary storage of solid bulk materials such as catalyst, proppant, or chemical reagents.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de armazenamento de sólidos a granel</rdfs:label>
        <rdfs:label xml:lang="en">solid bulk storage process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which solid bulk materials such as catalyst, proppant, or chemical reagents are contained and held for subsequent use.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SolidPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção de sólido</rdfs:label>
        <rdfs:label xml:lang="en">solid portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of solid material at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de armazenamento e distribuição de sólidos</rdfs:label>
        <rdfs:label xml:lang="en">solid storage and dispensing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the storage of solid materials and their controlled dispensing in metered quantities into a process stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de armazenamento e distribuição de sólidos</rdfs:label>
        <rdfs:label xml:lang="en">solid storage and dispensing process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which solid materials are stored and dispensed in metered quantities into a process stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SpacingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SpacingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de espaçamento</rdfs:label>
        <rdfs:label xml:lang="en">spacing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the maintenance of a defined spatial separation between components to ensure correct alignment, clearance, or insulation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de espaçamento</rdfs:label>
        <rdfs:label xml:lang="en">spacing process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a defined spatial separation between components is maintained to ensure correct alignment, clearance, or insulation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StandardizedElectricalSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StandardizedElectricalSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">sinal padronizado elétrico</rdfs:label>
        <rdfs:label xml:lang="en">standardized electrical signal</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting an electrical signal in a standardised format—such as 4–20 mA or 0–10 V—used to transmit process variable values between petroleum production instrumentation components.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StandardizedSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StandardizedSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">sinal padronizado</rdfs:label>
        <rdfs:label xml:lang="en">standardized signal</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a signal in a standardised format used to transmit measurement values or control commands between petroleum production instrumentation and control system components.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de componente estacionário de máquina</rdfs:label>
        <rdfs:label xml:lang="en">stationary machine component function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a StationaryMachineComponentProcess and that consists in providing a stationary structural foundation and housing for active elements (such as windings, vanes, or seals) within rotating machinery, maintaining positional stability relative to moving components.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a StationaryMachineComponentProcess and that consists in providing a stationary structural foundation and housing for active elements (such as windings, vanes, or seals) within rotating machinery, maintaining positional stability relative to moving components.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de componente estacionário de máquina</rdfs:label>
        <rdfs:label xml:lang="en">stationary machine component process</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a stator maintains its fixed position relative to rotating components within machinery, providing structural support and housing for electromagnetic windings, guide vanes, or other functional elements that require stable positioning.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a stator maintains its fixed position relative to rotating components within machinery, providing structural support and housing for electromagnetic windings, guide vanes, or other functional elements that require stable positioning.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StatorWinding -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StatorWinding">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">enrolamento de estator</rdfs:label>
        <rdfs:label xml:lang="en">stator winding</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the stationary winding of an electric motor or generator that produces or responds to the rotating magnetic field in petroleum production rotating electrical equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SteelPipe -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SteelPipe">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">steel pipe</rdfs:label>
        <rdfs:label xml:lang="pt-br">tubo de de aço</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a pipe made of steel used to convey fluids under pressure in petroleum production piping systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StorageProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StorageProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de armazenamento</rdfs:label>
        <rdfs:label xml:lang="en">storage process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a fluid or material is held within a contained space for a defined period before further processing or distribution.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StructuralDisplacement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralDisplacement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="pt-br">deslocamento estrutural</rdfs:label>
        <rdfs:label xml:lang="en">structural displacement</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a displacement—elongation, settlement, or lateral movement—of a structural element in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StructuralForce -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralForce">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="pt-br">força estrutural</rdfs:label>
        <rdfs:label xml:lang="en">structural force</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a force transmitted through a structural element of petroleum production equipment due to imposed loads.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de suporte estrutural</rdfs:label>
        <rdfs:label xml:lang="en">structural support function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a StructuralSupportProcess and that consists in providing mechanical support, load distribution, or structural integrity within an engineered system through a flat, planar configuration.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a StructuralSupportProcess and that consists in providing mechanical support, load distribution, or structural integrity within an engineered system through a flat, planar configuration.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de suporte estrutural</rdfs:label>
        <rdfs:label xml:lang="en">structural support process</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceAccessProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceAccessProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de acesso subsuperficial</rdfs:label>
        <rdfs:label xml:lang="en">subsurface access process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which access to subsurface formations is established and maintained through a wellbore to enable exploration, production, or injection activities.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de interação com recursos subsuperficiais</rdfs:label>
        <rdfs:label xml:lang="en">subsurface resource interaction function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled physical interaction with subsurface formations to enable exploration, drilling, completion, or production activities.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de interação com recursos subsuperficiais</rdfs:label>
        <rdfs:label xml:lang="en">subsurface resource interaction process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which petroleum production equipment physically interacts with subsurface formations to enable drilling, completion, or production operations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceSafetyProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceSafetyProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
        <rdfs:label xml:lang="pt-br">processo de segurança subsuperficial</rdfs:label>
        <rdfs:label xml:lang="en">subsurface safety process</rdfs:label>
        <skos:definition xml:lang="en">A safety relief process in which the wellbore flow path is automatically closed by a downhole safety valve to prevent uncontrolled flow of reservoir fluids to surface.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SuctionInlet -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SuctionInlet">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">entrada de sucção</rdfs:label>
        <rdfs:label xml:lang="en">suction inlet</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the inlet through which fluid is drawn into a pump or compressor under suction pressure in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SupportFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de suporte</rdfs:label>
        <rdfs:label xml:lang="en">support function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the bearing of mechanical loads from attached components or piping to maintain their position and structural integrity.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SupportedElectricalCable -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportedElectricalCable">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">cabo suportado elétrico</rdfs:label>
        <rdfs:label xml:lang="en">supported electrical cable</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an electrical cable that is mechanically supported and routed by cable support systems in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SupportedTubingString -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportedTubingString">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">coluna suportado de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">supported tubing string</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a downhole tubing string that is suspended and supported from the wellhead by a tubing hanger in a petroleum production well.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SupportingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de suporte</rdfs:label>
        <rdfs:label xml:lang="en">supporting process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which mechanical loads from attached components or piping are borne by a structural element to maintain their position and integrity.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SuppressedDisturbance -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SuppressedDisturbance">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:label xml:lang="pt-br">perturbação suprimido</rdfs:label>
        <rdfs:label xml:lang="en">suppressed disturbance</rdfs:label>
        <skos:definition xml:lang="en">A process in which an unwanted physical perturbation—vibration, noise, or pressure surge—that has been attenuated or eliminated by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SurfaceSafetyValve -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SurfaceSafetyValve">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="en">surface safety valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de superfície de segurança</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a safety valve installed at the wellhead or surface flowline that automatically closes to prevent uncontrolled flow from the well.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureIndicationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureIndicationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de indicação de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature indication process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the temperature of a process stream or equipment surface is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de medição e transmissão de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature measurement and transmission process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which process temperature is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de medição de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature measurement function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the thermal state of a process stream or equipment surface and its expression as a quantitative value.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de medição de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature measurement process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the thermal state of a process stream or equipment surface is determined and expressed as a quantitative value.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingElement">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">elemento de temperatura de sensoriamento</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensing element</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a primary sensing element—thermocouple, RTD, or thermistor—that responds to temperature to generate a measurable signal in petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de sensoriamento de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensing process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which thermal energy is detected and converted into a measurable signal representing the temperature of a process stream or component.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de proteção de sensor de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensor protection process</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a protective barrier shields a temperature sensing element from direct contact with the process medium while maintaining thermal conductivity to enable accurate temperature measurement.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a protective barrier shields a temperature sensing element from direct contact with the process medium while maintaining thermal conductivity to enable accurate temperature measurement.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">sinal de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature signal</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the temperature of a process stream or equipment surface in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ThermalEnergy -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalEnergy">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">energia térmico</rdfs:label>
        <rdfs:label xml:lang="en">thermal energy</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes thermal energy transferred between a process stream and heat exchange surfaces of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ThermalEnergyPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalEnergyPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção térmico de energia</rdfs:label>
        <rdfs:label xml:lang="en">thermal energy portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a quantity of thermal energy at a defined point in the heat transfer circuit of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de acomodação de expansão térmica</rdfs:label>
        <rdfs:label xml:lang="en">thermal expansion accommodation function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the absorption of dimensional changes in piping or structures caused by variations in process temperature.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de acomodação de expansão térmica</rdfs:label>
        <rdfs:label xml:lang="en">thermal expansion accommodation process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which dimensional changes in piping or structures caused by variations in process temperature are absorbed without transmitting excessive stress to connected equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de separação trifásica</rdfs:label>
        <rdfs:label xml:lang="en">three phase separation function</rdfs:label>
        <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the separation of a gas–liquid hydrocarbon–produced water mixture into three distinct phases by gravity and residence time.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
        <rdfs:label xml:lang="pt-br">processo de separação trifásica</rdfs:label>
        <rdfs:label xml:lang="en">three phase separation process</rdfs:label>
        <skos:definition xml:lang="en">A separation process in which a mixture of gas, liquid hydrocarbon, and produced water is divided into three distinct phases by gravity and residence time.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TransductionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TransductionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TransductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TransductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transdução</rdfs:label>
        <rdfs:label xml:lang="en">transduction function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of one form of physical signal or energy into another form suitable for measurement or transmission.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TransductionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TransductionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de transdução</rdfs:label>
        <rdfs:label xml:lang="en">transduction process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which one form of physical signal or energy is converted into another form suitable for measurement or transmission.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubeBundle -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubeBundle">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:label xml:lang="pt-br">feixe de tubo</rdfs:label>
        <rdfs:label xml:lang="en">tube bundle</rdfs:label>
        <skos:definition xml:lang="en">An assembly of heat transfer tubes, baffles, and tube sheets that forms the core of a shell-and-tube heat exchanger in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubingBowl -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingBowl">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">tigela de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing bowl</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the bowl at the top of a wellhead housing in which the tubing hanger is seated and sealed.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubingBundle -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingBundle">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:label xml:lang="pt-br">feixe de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing bundle</rdfs:label>
        <skos:definition xml:lang="en">An assembly of multiple tubing strings grouped and routed together for injection or production purposes in petroleum production wells or risers.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubingString -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingString">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
        <rdfs:label xml:lang="pt-br">coluna de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing string</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the continuous string of tubing that conveys production fluids from the wellbore to the surface or delivers injection fluids downhole.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de suporte e conexão de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing support and connection function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes both the mechanical support of tubing strings within a wellbore and their connection to surface or subsurface equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de suporte e conexão de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing support and connection process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which downhole tubing strings are mechanically supported within a wellbore and connected to surface or subsurface equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de suporte de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing support function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical suspension and support of downhole tubing strings within a wellbore.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TubingSupportProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de suporte de coluna de produção</rdfs:label>
        <rdfs:label xml:lang="en">tubing support process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which downhole tubing strings are mechanically suspended and supported within a wellbore.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TurbineSection -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbineSection">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
        <rdfs:label xml:lang="pt-br">seção de turbina</rdfs:label>
        <rdfs:label xml:lang="en">turbine section</rdfs:label>
        <skos:definition xml:lang="en">An assembly of rotor blades, stator vanes, and casing components that extracts energy from a fluid stream in a turbine stage of petroleum production turbomachinery.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de geração de energia por turbomáquina</rdfs:label>
        <rdfs:label xml:lang="en">turbomachinery power generation function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of fluid enthalpy into shaft power through interaction with rotating turbine blades.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de geração de energia por turbomáquina</rdfs:label>
        <rdfs:label xml:lang="en">turbomachinery power generation process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which fluid enthalpy is converted into shaft power through the interaction of a fluid stream with rotating turbine blades.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de fornecimento ininterrupto de energia</rdfs:label>
        <rdfs:label xml:lang="en">uninterrupted power supply function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the provision of continuous electrical power to critical loads during interruptions to the main power supply.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de fornecimento ininterrupto de energia</rdfs:label>
        <rdfs:label xml:lang="en">uninterrupted power supply process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which continuous electrical power is provided to critical loads during interruptions to the main power supply.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VacuumReferenceeChamber -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VacuumReferenceeChamber">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">câmara de vácuo de referência</rdfs:label>
        <rdfs:label xml:lang="en">vacuum referencee chamber</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a sealed reference cavity maintained at a known low pressure for use as a reference in absolute pressure measurement instruments.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VaporPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VaporPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção de vapor</rdfs:label>
        <rdfs:label xml:lang="en">vapor portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of vapour phase material at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de medição e transmissão de vibração</rdfs:label>
        <rdfs:label xml:lang="en">vibration measurement and transmission process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the amplitude or frequency of mechanical vibration is measured and the corresponding signal transmitted to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VibrationSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VibrationSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">sinal de vibração</rdfs:label>
        <rdfs:label xml:lang="en">vibration signal</rdfs:label>
        <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the amplitude or frequency of mechanical vibration measured in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VisualInformation -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInformation">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">informação visual</rdfs:label>
        <rdfs:label xml:lang="en">visual information</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting visual information—such as a colour, indicator state, or display value—conveying process or equipment status to an operator.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de inspeção visual</rdfs:label>
        <rdfs:label xml:lang="en">visual inspection function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de inspeção visual</rdfs:label>
        <rdfs:label xml:lang="en">visual inspection process</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VisualSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:label xml:lang="pt-br">sinal visual</rdfs:label>
        <rdfs:label xml:lang="en">visual signal</rdfs:label>
        <skos:definition xml:lang="en">An information content entity constituting a visual indication—such as a light, colour band, or pointer position—conveying the state of a process variable in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de combustão de resíduos</rdfs:label>
        <rdfs:label xml:lang="en">waste combustion function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the thermal destruction of waste gases, liquids, or solids by controlled combustion.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de combustão de resíduos</rdfs:label>
        <rdfs:label xml:lang="en">waste combustion process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which waste gases, liquids, or solids are thermally destroyed by controlled combustion in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WasteGasBurningProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasBurningProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de queima de gás residual</rdfs:label>
        <rdfs:label xml:lang="en">waste gas burning process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which surplus or waste gas is combusted in a flare or incinerator to destroy it safely and prevent atmospheric venting.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasBurningProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasBurningProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de descarte de gás residual</rdfs:label>
        <rdfs:label xml:lang="en">waste gas disposal function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the safe disposal of waste or surplus gas streams by combustion, venting, or re-injection into a formation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de descarte de gás residual</rdfs:label>
        <rdfs:label xml:lang="en">waste gas disposal process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which waste or surplus gas streams are safely disposed of by combustion, venting, or re-injection into a subsurface formation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WasteGasPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção de resíduo de gás</rdfs:label>
        <rdfs:label xml:lang="en">waste gas portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of waste or surplus gas generated in petroleum production operations that is directed to disposal equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WasteMaterialPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteMaterialPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção de resíduo de material</rdfs:label>
        <rdfs:label xml:lang="en">waste material portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of waste material generated by a processing step in petroleum production equipment and requiring disposal.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WaterPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WaterPortion">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">porção de água</rdfs:label>
        <rdfs:label xml:lang="en">water portion</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of water—produced water or injection water—at a defined point in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WaterVapor -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WaterVapor">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">vapor de água</rdfs:label>
        <rdfs:label xml:lang="en">water vapor</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes water in the vapour phase present in a process stream handled by petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WeightOnBit -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WeightOnBit">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:label xml:lang="pt-br">broca de peso de em</rdfs:label>
        <rdfs:label xml:lang="en">weight on bit</rdfs:label>
        <skos:definition xml:lang="en">A quality inhering in a material entity, constituting the compressive force applied to the drill bit through the drill string during a drilling operation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WellFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellFluid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">fluido de poço</rdfs:label>
        <rdfs:label xml:lang="en">well fluid</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the fluid—hydrocarbon, water, or gas—produced from or injected into a petroleum production well.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de controle de fluido de poço</rdfs:label>
        <rdfs:label xml:lang="en">well fluid control function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the regulation of fluid flow from a well to maintain production targets and prevent uncontrolled release.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de controle de fluido de poço</rdfs:label>
        <rdfs:label xml:lang="en">well fluid control process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the flow of fluids from a well is regulated to maintain production targets and prevent uncontrolled release.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de controle de superfície do poço</rdfs:label>
        <rdfs:label xml:lang="en">well surface control function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the control of wellbore conditions from surface to manage production flow, monitor integrity, and enable well interventions.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de controle de superfície do poço</rdfs:label>
        <rdfs:label xml:lang="en">well surface control process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which wellbore conditions are controlled from surface to manage production flow, monitor well integrity, and enable intervention operations.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WellheadSpool -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellheadSpool">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:label xml:lang="pt-br">spool de cabeçal de poço</rdfs:label>
        <rdfs:label xml:lang="en">wellhead spool</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a spool piece installed between wellhead components to provide the correct bore alignment and connection points.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WetMaterial -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WetMaterial">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
        <rdfs:label xml:lang="pt-br">material úmido</rdfs:label>
        <rdfs:label xml:lang="en">wet material</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a material containing a significant moisture or liquid content prior to processing in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WingValve -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WingValve">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="pt-br">válvula de ala</rdfs:label>
        <rdfs:label xml:lang="en">wing valve</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a flow control valve on the side outlet of a Christmas tree that directs well production to a flowline or test separator.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de perfilagem por wireline</rdfs:label>
        <rdfs:label xml:lang="en">wireline logging function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the acquisition of subsurface formation and wellbore data by lowering measurement tools into the well on a wireline cable.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:label xml:lang="pt-br">processo de perfilagem por wireline</rdfs:label>
        <rdfs:label xml:lang="en">wireline logging process</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which measurement tools are lowered into a well on a wireline cable to acquire subsurface formation and wellbore data.</skos:definition>
    </owl:Class>
    


