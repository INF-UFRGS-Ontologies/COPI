        <rdfs:label xml:lang="en">temperature indication function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the temperature of a process stream or equipment surface.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174">
