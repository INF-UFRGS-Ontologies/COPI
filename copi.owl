        <rdfs:label xml:lang="en-us">example</rdfs:label>
        <skos:definition xml:lang="en-us">example of the use of a concept</skos:definition>
        <annotation:usageNote xml:lang="en-us">Use of this annotation is optional, but recommended if it will help a user understand the intended interpretation(s).
- This annotation should use at most twice with/on a notion.
- Additional examples or more elaborate examples should be placed in the External Documentation (using rdfs:seeAlso).</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


