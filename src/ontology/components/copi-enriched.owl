>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1020">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementAndTransmissionProcess"/>
