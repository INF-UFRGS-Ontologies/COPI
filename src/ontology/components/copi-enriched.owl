  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b311">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical force or motion is transferred from an input component to an output component through direct physical coupling and mechanical linkage.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical force or motion is transferred from an input component to an output component through direct physical coupling and mechanical linkage.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de transmissão de força</rdfs:label>
    <rdfs:label xml:lang="en">force transmission process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalPort">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a connection point through which mechanical force or motion is transmitted between components of petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">mechanical port</rdfs:label>
    <rdfs:label xml:lang="pt-br">bocal mecânico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b984">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
