  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208">
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b61"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <rdfs:label xml:lang="en">agitator</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A propeller like device with agitational or rotational movement located in a tank to prevent the content of the tank to build component segments.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An Agitator is a dynamic mixer that stirs or shakes fluids by reaction force from moving vanes.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;AGITATOR&gt; is a &lt;DYNAMIC MIXER&gt; that stirs or shakes fluids by reaction force from moving vanes</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
