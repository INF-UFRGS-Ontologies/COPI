  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Instrument(x) ↔ (Assembly(x) ∧ ∃f(InstrumentationFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[isa5_1] a device used for direct or indirect measurement, monitoring, and/or control of a variable, including primary elements, indicators, controllers, final control elements, computing devices, and electrical devices such as annunciators, switches, and pushbuttons.</skos:definition>
    <rdfs:label xml:lang="pt-br">instrumento</rdfs:label>
    <rdfs:label xml:lang="en">instrument</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um instrumento é um artefato material que tem a função projetada de realizar medição, monitoramento ou controle de variáveis de processo.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2009"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every instrument is a material artifact that has an instrumentation function, and every material artifact that has an instrumentation function is an instrument.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2793">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000223">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cathodic protection system is a corrosion protection system that bears a cathodic protection function and has anodes as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">cathodic protection system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de proteção catódica</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CATHODIC PROTECTION SYSTEM&gt; is an &lt;ARTEFACT&gt; and a &lt;CORROSION PROTECTION SYSTEM&gt; using sacrificial anodes or impressed current anodes offering material and giving protection to carbon and low-alloy steel equipment or structures</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A corrosion protection system using sacrificial anodes or impressed current anodes offering material and giving protection to carbon and low-alloy steel equipment or structures.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cathodic protection system is a corrosion protection system that uses electrochemical cathodic protection mechanisms with anodes to prevent corrosion of carbon and low-alloy steel equipment or structures.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um sistema de proteção catódica é um sistema de proteção contra corrosão que usa mecanismos eletroquímicos de proteção catódica com ânodos para prevenir a corrosão de equipamentos ou estruturas de aço carbono e baixa liga.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CathodicProtectionSystem(x) ↔ CorrosionProtectionSystem(x) ∧ ∃f(CathodicProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃a(Anode(a) ∧ hasComponentPartAtSomeTime(x,a)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b406"/>
  </rdf:Description>
