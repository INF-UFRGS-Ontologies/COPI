    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb506"/>
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb513"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess">
    <rdfs:label xml:lang="pt-br">processo de absorção</rdfs:label>
    <rdfs:label xml:lang="en">absorption process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">carcaça de bomba</rdfs:label>
    <rdfs:label xml:lang="en">pump casing</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2695"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump casing is a casing that surrounds an impeller and has integral suction and discharge nozzles forming part of its structure.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PUMP CASING&gt; is a  &lt;CASING&gt; and a single wall surrounding the impeller. The suction and discharge nozzles form an integral part of the casing. Typically applied for centrifugal pumps</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PumpCasing(x) → Casing(x) ∧ ∃y(Impeller(y) ∧ surrounds(x,y)) ∧ ∃z(SuctionNozzle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃w(DischargeNozzle(w) ∧ hasComponentPartAtAllTimes(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que envolve um impulsor e possui bocais de sucção e descarga integrais como componentes estruturais, tipicamente aplicado em bombas centrífugas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under Open World Assumption, structural characteristics are harder to make sufficient - any assembly with an impeller and integral nozzles might be classified as a pump casing even if it serves a different specialized purpose. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3024">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000275">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador de flare é um queimador que especificamente queima gás residual emitido de processos industriais e descarrega os produtos de combustão na atmosfera.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1431"/>
    <rdfs:label xml:lang="pt-br">queimador de flare</rdfs:label>
    <rdfs:label xml:lang="en">flare tip</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLARE TIP&gt; is an &lt;ARTEFACT&gt; and a &lt;BURNER&gt; that burns gas emitted from a process into the atmosphere</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A burner that burns gas emitted from a process into the atmosphere.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A burner that burns gas emitted from a process into the atmosphere.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare tip is a burner that has the function to dispose of waste gas from processes by burning it into the atmosphere</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlareTip(x) ↔ Burner(x) ∧ ∃f(WasteGasDisposalFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
