  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FuseBase">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the mounting base that holds and connects a fuse element to an electrical circuit in petroleum production electrical equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">base de fusível</rdfs:label>
    <rdfs:label xml:lang="en">fuse base</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000128">
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2038"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level element is a detector that has the function to detect fluid level</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">elemento de nível</rdfs:label>
    <rdfs:label xml:lang="en">level element</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de nível é um instrumento que possui uma função de detecção de nível para determinar o nível de fluido em um vaso ou recipiente.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LevelElement(x) ↔ Detector(x) ∧ ∃f(LevelDetectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1764">
