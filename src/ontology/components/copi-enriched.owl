  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142">
    <rdfs:label xml:lang="pt-br">elemento de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure element</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão é um instrumento que possui uma função de detecção de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[CFIHOS] A detecting element intended to sense pressure.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A detecting element intended to sense pressure.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure element is a detecting element that has the function of sensing pressure</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureElement(x) ↔ DetectingElement(x) ∧ ∃f(PressureSensingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2564"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b883"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b884"/>
    <rdfs:label xml:lang="en">detection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de detecção</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b230">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000181">
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2295"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2296"/>
    <rdfs:label xml:lang="pt-br">função de medição de sequência de fases</rdfs:label>
    <rdfs:label xml:lang="en">phase sequence measurement function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Burner(x) ↔ (Heater(x) ∧ ∃f (CombustionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BURNER&gt; is a &lt;FunctionalObject&gt; that is intended to release thermal energy by burning a combustible mixture</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador é um aquecedor que libera energia térmica através da queima de uma mistura combustível de combustível e ar.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="en">burner</rdfs:label>
    <rdfs:label xml:lang="pt-br">queimador</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b338"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every burner is a heater that has the function of combustion, which is realized by burning a fuel-air mixture to release thermal energy.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246">
    <rdfs:label xml:lang="en">detector</rdfs:label>
    <rdfs:label xml:lang="pt-br">detector</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector é um instrumento que possui uma função de detecção, permitindo-lhe detectar estados, substâncias ou fenômenos e produzir sinais baseados na detecção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b887"/>
    <skos:definition xml:lang="en">[SLB Glossary] A sensor or receiver, such as a geophone or hydrophone, gravimeter or magnetometer.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is an assembly of a sensing element and necessary ancillary devices making it able of detecting a state, e.g. pressure, temperature, or detect the presence of a selected substance, and produce a signal based on the detection.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DETECTOR&gt; is an &lt;INSTRUMENTATION FUNCTION&gt; that has a capability of &lt;DETECTING&gt;</skos:definition>
    <skos:definition xml:lang="en">[isa5_1] a device that is used to detect the presence of something, such as flammable or toxic gases or discrete parts; see also primary element and sensor.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Detector(x) ↔ Instrument(x) ∧ ∃f(DetectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every detector is an instrument that has a detection function and has component parts including a sensing element and signal generation device.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">level measurement and transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de nível</rdfs:label>
  </rdf:Description>
