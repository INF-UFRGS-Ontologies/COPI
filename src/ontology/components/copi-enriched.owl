    <rdfs:label xml:lang="en">temperature indication function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de indicação de temperatura</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183">
    <rdfs:label xml:lang="en">position limit detection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de detecção de limite de posição</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132">
    <iof-av:naturalLanguageDefinition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um limit switch é um instrumento que possui uma função de detecção de limite de posição, acionado mecanicamente pelo movimento de objetos para fornecer sinais de chaveamento elétrico quando limites de posição predeterminados são atingidos.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LimitSwitch(x) ↔ Instrument(x) ∧ ∃f (PositionLimitDetectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (PositionLimitDetectionFunction(f) ∧ bearerOf(x,f)) ⊓ ∃hasInput.MechanicalMotion ⊓ ∃hasOutput.ElectricalSignal)</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b175"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">limit switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">limit switch</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b176"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nca3fbef7bb9b47148fb3dd59dc9a306f">
    <rdf:first rdf:nodeID="Nc21a0a8b4bdc40189b1722264b4b487a"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114">
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b108"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de parada de emergência é uma válvula que possui uma função de parada de emergência, permitindo o isolamento rápido de fluxo em situações de emergência através de mecanismos atuados com capacidade à prova de falhas.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b109"/>
    <rdfs:label xml:lang="en">emergency shut down valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de parada de emergência</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (EmergencyShutDownValve(x) ↔ Valve(x) ∧ ∃f (EmergencyShutDownFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula agulha é uma válvula que possui um membro de fechamento cônico em forma de agulha que se assenta em um pequeno orifício para fornecer controle preciso de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b181"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (NeedleValve(x) → Valve(x) ∧ ∃f (FlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">válvula agulha</rdfs:label>
    <rdfs:label xml:lang="en">needle valve</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b192">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b190"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b264">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
