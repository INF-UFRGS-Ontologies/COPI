  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction">
    <rdfs:label xml:lang="pt-br">função de recebimento de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig receiving function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2311"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2312"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled retrieval and containment of a pipeline pig after its passage through a pipeline.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2085">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2090"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2505">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2500"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2506"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionMeasurementAndTransmissionProcess">
    <rdfs:label xml:lang="en">position measurement and transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de posição</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MeasurementProcess"/>
    <skos:definition xml:lang="en">A measurement process in which the position of a mechanical component is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3200">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportMechanism"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2184">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2180"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CondensateOutlet">
    <skos:definition xml:lang="en">A material artifact that constitutes an outlet port through which condensed liquid hydrocarbon leaves a separator, scrubber, or heat exchanger in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">saída de condensado</rdfs:label>
    <rdfs:label xml:lang="en">condensate outlet</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2724">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000217">
    <skos:definition xml:lang="en">A boiler is a heater that brings a liquid to its boiling point through indirect contact heat exchange, producing steam or vapor.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A boiler is a heater that brings a liquid to its boiling point through indirect contact heat exchange, producing steam or vapor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma caldeira é um aquecedor que leva um líquido ao seu ponto de ebulição através de troca de calor por contato indireto, produzindo vapor.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Boiler(x) ↔ Heater(x) ∧ ∃f(BoilingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">boiler</rdfs:label>
    <rdfs:label xml:lang="pt-br">caldeira</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b286"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every boiler is a heater that bears a BoilingFunction and has component parts including a steam drum and heat exchange surface.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1751">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1752"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1746"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1153">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1148"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/IndicatorPointer">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">ponteiro de indicador</rdfs:label>
    <rdfs:label xml:lang="en">indicator pointer</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the pointer or needle of an analogue indicator that shows the value of a measured variable in petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2911">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2909"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2433">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162">
    <rdfs:label xml:lang="en">binary flow control function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de controle binário de fluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2250"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2251"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the complete opening or closing of a flow path to allow or prevent fluid passage.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b989">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b984"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b990"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">connection system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de conexão</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of components—fittings, flanges, seals, and fasteners—that form a connection between two petroleum production systems.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Cooler(x) ↔ HeatExchanger(x) ∧ ∃f (CoolingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooler is a heat exchanger that has the function of cooling.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">cooler</rdfs:label>
    <rdfs:label xml:lang="pt-br">resfriador</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b676"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um resfriador é um trocador de calor que possui uma FunçãoDeResfriamento.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3213">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1834">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DownholeToolAssembly">
    <skos:definition xml:lang="en">A material artifact that constitutes an assembly of tools deployed in a wellbore on a wireline or tubing string to perform measurement, completion, or intervention operations.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">downhole tool assembly</rdfs:label>
    <rdfs:label xml:lang="pt-br">conjunto de fundo de poço de ferramenta</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidPathway">
    <rdfs:label xml:lang="en">fluid pathway</rdfs:label>
    <rdfs:label xml:lang="pt-br">caminho de fluido</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the connected path through which fluid flows between defined points in a petroleum production system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000247">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">analisador de ponto de orvalho</rdfs:label>
    <rdfs:label xml:lang="en">dew point analyser</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b886"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de ponto de orvalho é um instrumento que possui uma função de medição de ponto de orvalho.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DewPointAnalyser(x) ↔ Instrument(x) ∧ ∃f(DewPointMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dew point analyser is an instrument that has the function to determine the dew point of a substance</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b273">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
