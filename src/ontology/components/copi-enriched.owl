  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000292">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador gravitacional é um separador que realiza separação baseada nas diferenças de gravidade específica das substâncias sendo separadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gravity separator is a separator that performs separation based on differences in specific gravity of the substances being separated.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A separator that is based on the difference in specific gravity for the substances to be separated.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GRAVITY SEPARATOR&gt; is an &lt;ARTEFACT&gt; and a &lt;FLUID SEPARATOR&gt; that is based on the difference in specific gravity for the substances to be separated</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A separator that is based on the difference in specific gravity for the substances to be separated.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GravitySeparator(x) ↔ Separator(x) ∧ ∃f(GravitySeparationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">separador gravitacional</rdfs:label>
    <rdfs:label xml:lang="en">gravity separator</rdfs:label>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1760"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gravity separator is a separator that bears a GravitySeparationFunction</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
