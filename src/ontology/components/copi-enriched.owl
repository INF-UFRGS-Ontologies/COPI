  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SwitchingMechanism">
    <rdfs:label xml:lang="pt-br">mecanismo de chaveamento</rdfs:label>
    <rdfs:label xml:lang="en">switching mechanism</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the mechanical assembly within a switch that transitions between open and closed states in petroleum production electrical equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2841">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2842"/>
