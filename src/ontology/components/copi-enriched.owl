  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1880">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
