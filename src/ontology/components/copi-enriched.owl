  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2246">
    <rdf:first rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2243"/>
    <rdf:rest rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2247"/>
