  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb294">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SteamDrum"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297">
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1863"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[CFIHOS] An enclosure that also provides support.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HOUSING&gt; is an &lt;ARTEFACT&gt; and an &lt;ENCLOSURE&gt; and a &lt;SUPPORT&gt; that, next to separation, also provides support</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The outside steel case of a cartridge or a sonde in a wireline logging tool.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que possui tanto uma EnclosureFunction quanto uma SupportFunction, fornecendo limites protetivos ao redor de componentes internos enquanto os suporta estruturalmente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears both an EnclosureFunction and a SupportFunction, providing protective boundaries around internal components while structurally supporting them.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">housing</rdfs:label>
    <rdfs:label xml:lang="pt-br">carcaça</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Housing SubClassOf Assembly and (bearerOf some EnclosureFunction) and (bearerOf some SupportFunction)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions would force any assembly with enclosure and support functions to be classified as a standard housing, potentially misclassifying specialized equipment with housing-like properties but different maintenance categories.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Housing(x) → Assembly(x) ∧ ∃f₁(EnclosureFunction(f₁) ∧ bearerOf(x,f₁)) ∧ ∃f₂(SupportFunction(f₂) ∧ bearerOf(x,f₂)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1334">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubeBundle"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2723">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RelayCoil"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131">
    <iof-av:naturalLanguageDefinition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de nível é um transmissor que mede o nível (altura) de material líquido ou sólido a granel em um recipiente e produz um sinal elétrico de saída padronizado proporcional ao nível medido.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level transmitter is a transmitter that bears a LevelMeasurementAndTransmissionFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(LevelTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(LevelMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that produces a continuous standardized output signal dependent of a received input signal from a level sensor.</skos:definition>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'LT'. First letter 'L': Level. Succeeding letters: 'T' = Transmit.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A transmitter that is producing a continuous standardized output signal dependent of a received input signal from a level sensor.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LEVEL TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;LEVEL MEASURING INSTRUMENT&gt;</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">level transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de nível</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2144"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3194">
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3188"/>
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3195"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DemistingElement">
    <rdfs:label xml:lang="pt-br">elemento de eliminação de névoa</rdfs:label>
    <rdfs:label xml:lang="en">demisting element</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155">
    <skos:definition xml:lang="en">[POSC Caesar] A 'transmitter' that is producing a standardized output signal dependent of a received input signal from a 'temperature element'.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TEMPERATURE TRANSMITTER&gt;is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;TEMPERATURE MEASURING INSTRUMENT&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a temperature element.</skos:definition>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'TT'. First letter 'T': Temperature. Succeeding letters: 'T' = Transmit.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureTransmitter(x) ↔ Transmitter(x) ∧ ∃f(TemperatureMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3150"/>
    <rdfs:label xml:lang="en">temperature transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de temperatura</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de temperatura é um transmissor que mede temperatura e produz um sinal de saída padronizado dependente do sinal de entrada recebido de um elemento de temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature transmitter is a transmitter that has the function to measure temperature and transmit standardized signals based on temperature input.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb216">
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb213"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1405">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1410"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1556">
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1557"/>
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1551"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000367">
    <rdfs:label xml:lang="en">umbilical</rdfs:label>
    <rdfs:label xml:lang="pt-br">umbilical</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3317"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3316"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3315"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3314"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3313"/>
    <skos:definition xml:lang="en">[CFIHOS] An assembly of hydraulic hoses which can also include electrical cables or optic fibres, used to control a sub sea structure or remote operated vehicle from a platform or a vessel.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;UMBILICAL&gt; is a &lt;DRILLING COMPONENT&gt; that is a flexible and easily disconnectable collection of cables and/or tubing for control, power, communication or chemical injection purposes.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A device which is a flexible and easily disconnectable collection of cables and/or tubing for control, power, communication or chemical injection purposes.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A control line attached to a remove piece of equipment, usually a subsea wellhead, to provide hydraulic or electrical control, or inject small amounts of chemicals.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um umbilical é uma montagem que é um feixe flexível e facilmente desconectável contendo cabos e tubulação para transmissão de múltiplos serviços incluindo controle, energia, comunicação e injeção química.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every umbilical is an assembly that has component parts including cable bundles and tubing bundles, and has the qualities of flexibility and easy disconnectability.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Umbilical(x) → Assembly(x) ∧ ∃c,t,s,conn (CableBundle(c) ∧ TubingBundle(t) ∧ ProtectiveSheathing(s) ∧ ConnectorAssembly(conn) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,t) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,conn) ∧ hasQuality(x,Flexibility) ∧ hasQuality(x,EasyDisconnectability)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive basis requires necessary conditions only. Under OWA, any assembly with cables, tubing, flexibility, and disconnectability could be forcibly classified as umbilical, including specialized multi-service bundles, complex wiring harnesses, or custom transmission assemblies that contain these elements but serve different industrial contexts and maintenance categories.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000363">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">TransmitterHousing ⊑ Assembly ⊓ ∃bearerOf.EnclosureFunction ⊓ ∃hasComponentPartAtAllTimes.TransmitterElectronicCircuit</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro de transmissor é uma Assembly que possui uma EnclosureFunction e que tem um circuito eletrônico de transmissor como parte componente em todos os momentos, projetado para fornecer proteção ambiental e contenção física para componentes do transmissor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3248"/>
    <rdfs:label xml:lang="pt-br">invólucro de transmissor</rdfs:label>
    <rdfs:label xml:lang="en">transmitter housing</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical structure as housing. Under OWA, sufficient conditions for transmitter housing would require specifying exact structural features (materials, dimensions, sealing mechanisms) that distinguish it from other instrument housings. The necessary conditions establish the core identity without risking false positives from other housing types that might share some structural features.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TransmitterHousing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(TransmitterElectronicCircuit(c) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TRANSMITTER HOUSING&gt; is an &lt;INSTRUMENT HOUSING&gt; of a transmitter.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207">
    <rdfs:label xml:lang="pt-br">atuador</rdfs:label>
    <rdfs:label xml:lang="en">actuator</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador é um conjunto que possui uma função de atuação para converter energia de uma fonte externa em movimento cinético em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[POSC Caesar] A transducer that is intended to convert energy (electric, mechanical, pneumatic or hydraulic) from an external source into kinetic energy (motion) in response to a signal or or power input.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] An actuator is a type of motor for moving or controlling a mechanism or system. Actuator's are a vital part of offshore operations.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object for changing a signal into a corresponding movement.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ACTUATOR&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;ACTUATING&gt;</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Actuator(x) ↔ Assembly(x) ∧ ∃f (ActuationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb49"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every actuator is an assembly that has the function of converting external energy into controlled kinetic motion.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2206">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction">
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2693"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1718"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1773"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb615"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1859"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3244"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1860"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1719"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb426"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb614"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3245"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb399"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb469"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb427"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb470"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2694"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1772"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb400"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">enclosure function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de proteção e invólucro</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000310">
    <skos:definition xml:lang="en">[SLB Glossary] The sensor component in a weight-indicator system that detects the tensional or compressional forces being imparted to the running string at surface.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LOAD CELL&gt; is an &lt;ARTEFACT&gt; and a &lt;FORCE MEASURING ELEMENT&gt; and a &lt;TRANSDUCER&gt; that converts a force such as tension, compression, pressure, or torque into an electrical signal that can be measured</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transducer which produces a signal with a defined relationship to the force applied to it.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A device based on strain gauge technology that helps measure the surface weight of coiled tubing.</skos:definition>
    <rdfs:label xml:lang="pt-br">célula de carga</rdfs:label>
    <rdfs:label xml:lang="en">load cell</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LoadCell(x) ↔ Instrument(x) ∧ ∃f(ForceToElectricalTransductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A load cell is an instrument that converts mechanical force (tension, compression, pressure, or torque) into a proportional electrical signal for measurement purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma célula de carga é um instrumento que converte força mecânica (tração, compressão, pressão ou torque) em um sinal elétrico proporcional para fins de medição.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2180"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every load cell is an instrument that bears a force-to-electrical transduction function and has a force-receiving element, transduction element, and electrical output.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ExhaustGas">
    <rdfs:label xml:lang="pt-br">gás de escapamento</rdfs:label>
    <rdfs:label xml:lang="en">exhaust gas</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/OverflowOutlet">
    <rdfs:label xml:lang="en">overflow outlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">saída de transbordamento</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3003">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MountingPoint"/>
  </rdf:Description>
