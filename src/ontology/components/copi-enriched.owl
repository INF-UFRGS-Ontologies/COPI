  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106">
    <iof-av:naturalLanguageDefinition xml:lang="en">A circuit breaker is an electrical switching device that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um disjuntor é um dispositivo de chaveamento elétrico que possui uma função de interrupção de corrente elétrica e participa regularmente em processos que interrompem com segurança a corrente elétrica.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">circuit breaker</rdfs:label>
    <rdfs:label xml:lang="pt-br">disjuntor</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b45"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b46"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CircuitBreaker(x) ↔ MaterialArtifact(x) ∧ ∃f (ElectricalCurrentInterruptionFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (ElectricalCurrentInterruptionFunction(f) ∧ bearerOf(x,f)) ⊓ ∃participatesIn.RegularInterruptionProcess)</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
