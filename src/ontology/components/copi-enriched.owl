    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b736"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1508"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1518"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b735"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2306"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1516"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1488"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1487"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1517"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1509"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2305"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
