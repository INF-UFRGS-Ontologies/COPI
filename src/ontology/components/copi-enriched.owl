    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2908"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2943"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2029"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2907"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1734"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1739"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical rotational energy from a driving mechanism to driven components, enabling the transfer of torque and rotational motion through a mechanical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from a prime mover through rotational motion or to generate energy when acting as a driven element.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from one mechanical component to another through rotational or linear motion.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical energy from an external energy source through rotational motion to downstream mechanical components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transfer mechanical energy from a prime mover to one or more driven machines, maintaining rotational motion while potentially modifying torque and speed characteristics.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical power from one shaft to another through direct mechanical coupling or engagement.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de transmissão de potência</rdfs:label>
    <rdfs:label xml:lang="en">power transmission function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction">
    <rdfs:label xml:lang="pt-br">função de atuação</rdfs:label>
    <rdfs:label xml:lang="en">actuation function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb927"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1884"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2206"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3008"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2769"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2497"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1885"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1147"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb44"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb928"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3009"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1148"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2768"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2498"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb45"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2207"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb768">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DeaerationFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3462">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um acumulador é um vaso que tem a função projetada de acumular (armazenar e liberar de forma controlada) energia ou matéria.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An accumulator is a vessel that has the designed function to accumulate (store and controllably release) energy or matter.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[SLB Glossary] A device used in a hydraulic system to store energy or, in some applications, dampen pressure fluctuations.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A functional object capable of storing energy, and which after discharge may be recharged.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] In context of a pressure control device, accumulators are canisters of hydraulic fluid, pressurized with a nitrogen gas cap of sufficient pressure and volume to operate all the rams on a BOP in case of power failure to the BOP.                  In context of a processing plant, an accumulator is a vessel that receives and temporarily stores a liquid used in the feed stock or the processing of a feed stream in a gas plant or other processing facility.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ACCUMULATOR&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;ACCUMULATING&gt; matter and/or energy</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object for storing energy, and which after discharge may be recharged.</skos:definition>
    <rdfs:label xml:lang="pt-br">acumulador</rdfs:label>
    <rdfs:label xml:lang="en">accumulator</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb24"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every accumulator is a vessel that bears an accumulation function</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Accumulator(x) ↔ (Vessel(x) ∧ ∃f (AccumulationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
