  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayFunction">
    <rdfs:label xml:lang="en">information display function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de exibição de informação</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an InformationDisplayProcess and that consists in presenting or exhibiting information visually to operators or other users for the purpose of communication, monitoring, or decision-making.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1022"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1021"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an InformationDisplayProcess and that consists in presenting or exhibiting information visually to operators or other users for the purpose of communication, monitoring, or decision-making.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b721">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess"/>
