  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000258">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dryer is an assembly that has the function of drying materials by removing moisture.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dryer(x) ↔ Assembly(x) ∧ ∃f(DryingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um secador é um conjunto que possui uma função de secagem para remover umidade de materiais.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dryer is an assembly that bears a drying function to remove moisture from materials.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[DEXPI] An object that has the capability of drying (from ``_).</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DRYER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;DRYING&gt;</skos:definition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1117"/>
    <rdfs:label xml:lang="en">dryer</rdfs:label>
    <rdfs:label xml:lang="pt-br">secador</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000361">
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b3186"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[SLB Glossary] A vessel that separates the well fluids into gas and two types of liquids: oil and water.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;THREE-PHASE SEPARATOR&gt; is an &lt;ARTEFACT&gt; and a &lt;FLUID SEPARATOR&gt; intended to separate three fluids in different phases, typically gas and liquid and water</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A separator intended to separate three fluids in different phases, typically gas and liquid and water</skos:definition>
    <rdfs:label xml:lang="en">three phase separator</rdfs:label>
    <rdfs:label xml:lang="pt-br">separador trifásico</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador trifásico é um separador que possui uma função de separação trifásica para separar fluidos de poço em fases gasosa, oleosa e aquosa.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every three-phase separator is a separator that has the function of separating fluid into gas, oil, and water phases, and has gas outlet, oil outlet, and water outlet as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ThreePhaseSeparator(x) ↔ (Separator(x) ∧ ∃f (ThreePhaseSeparationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoriolisForceDetector">
    <rdfs:label xml:lang="pt-br">detector de Coriolis de força</rdfs:label>
    <rdfs:label xml:lang="en">coriolis force detector</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
