  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000306">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2032"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">An InputShaft is a Shaft that participates in mechanical energy reception and is connected to an external energy source.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration as energy entrance point. Under OWA, defining sufficient conditions could lead to false positives where any shaft receiving external energy input would be classified as a standard input shaft, even specialized or hybrid configurations that should remain in different maintenance categories.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(InputShaft(x) → Shaft(x) ∧ ∃p(MechanicalEnergyReceptionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(ExternalEnergySource(s) ∧ connectedTo(x,s)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de entrada é um eixo que serve como ponto de entrada para energia mecânica de uma fonte de energia externa em um sistema de transmissão de potência.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">eixo de entrada</rdfs:label>
    <rdfs:label xml:lang="en">input shaft</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;INPUT SHAFT&gt; is a &lt;SHAFT&gt; that is the entrance of mechanical energy and driven by an external energy source.</skos:definition>
  </rdf:Description>
