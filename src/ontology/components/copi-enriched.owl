    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3014"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1539">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1540"/>
