  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuatingMechanism">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">actuating mechanism</rdfs:label>
    <rdfs:label xml:lang="pt-br">mecanismo de atuação</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the mechanical assembly that converts a control signal into physical movement to operate a valve or other device in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
