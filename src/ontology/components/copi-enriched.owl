    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationFunction">
    <rdfs:label xml:lang="en">gravity separation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de separação gravitacional</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1740"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1741"/>
    <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the separation of phases of differing densities by the action of gravity in a settling vessel.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b895">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b890"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2562">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2800">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152">
    <skos:definition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro grosso é um artefato material que possui uma função de separação e tem um elemento filtrante, projetado para separar partículas sólidas de fluidos fazendo o fluido passar através de telas ou perfurações.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">filtro grosso</rdfs:label>
    <rdfs:label xml:lang="en">strainer</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Strainer(x) ↔ (MaterialArtifact(x) ∧ ∃f(SeparationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilteringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(SolidLiquidSeparationProcess(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every strainer is a material artifact that bears a separation function and has a filtering element as component part at all times and participates in solid-liquid separation processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3008"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1035">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ColumnShell"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b28">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b29"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3293">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b400">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CasingConnectionPoint"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical or fluid joining of two or more components to allow the transfer of force, fluid, or signal between them.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b722"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1357"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b721"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1358"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">connection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de conexão</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080">
    <skos:definition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Seat(x) → MaterialArtifact(x) ∧ ∃y(SealingSurface(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ValveClosingProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions for 'seat' based solely on structural properties could lead to false positives where other valve components with sealing surfaces are incorrectly classified as seats.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">assento</rdfs:label>
    <rdfs:label xml:lang="en">seat</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Seat is a MaterialArtifact that has some sealing surface component at all times and participates in some valve closing process.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2824"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui um componente de superfície de vedação e participa em processos de fechamento de válvulas, consistindo na parte da válvula contra a qual o elemento de fechamento se apoia para proporcionar vedação hermética.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b626">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b622"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b258"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b259"/>
    <rdfs:label xml:lang="pt-br">função de despressurização rápida</rdfs:label>
    <rdfs:label xml:lang="en">rapid depressurization function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the rapid controlled release of process pressure to a safe disposal system to prevent catastrophic failure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3151">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SensingElement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b520">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000348">
    <skos:definition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aríete de corte é um aríete que possui função de corte de tubulação e tem lâminas de corte endurecidas projetadas para cortar a coluna de perfuração ou tubulação durante operações de prevenção de blowout.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ShearRam(x) ↔ Ram(x) ∧ ∃f(PipeShearingFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ShearingBlade(b) ∧ hasComponentPartAtAllTimes(x,b)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">aríete de corte</rdfs:label>
    <rdfs:label xml:lang="en">shear ram</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2878"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every shear ram is a ram that has the function to shear pipe and has shearing blades as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b98">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b99"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b93"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2256">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b584">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b588"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2038">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2040"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000234">
    <skos:definition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</skos:definition>
    <rdfs:label xml:lang="en">controller</rdfs:label>
    <rdfs:label xml:lang="pt-br">controlador</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Controller(x) ↔ Instrument(x) ∧ ∃f(ControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b657"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um controlador é um instrumento que possui uma função de controle, regulando automaticamente uma variável controlada ao medi-la, comparar com um valor de referência e gerar sinais de saída para reduzir o desvio.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every controller is an instrument that has the function to control a process variable by automatic feedback regulation</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000304">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(InjectionPump(x) ↔ Pump(x) ∧ ∃f(InjectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de injeção é uma bomba especificamente projetada para injetar fluido em reservatórios ou sistemas de produção, tipicamente em pressões relativamente altas.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">injection pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba de injeção</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1964"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every injection pump is a pump that bears an injection function for delivering fluids to reservoirs or production systems.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSensingProcess">
    <skos:definition xml:lang="en">A planned process in which fluid pressure is detected and converted into a measurable electrical or pneumatic signal.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de sensoriamento de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure sensing process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1510">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DiaphragmChamber">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an enclosed space separated by a flexible diaphragm that transmits or responds to pressure in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">câmara de diafragma</rdfs:label>
    <rdfs:label xml:lang="en">diaphragm chamber</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000233">
    <rdfs:label xml:lang="pt-br">transmissor de condutividade</rdfs:label>
    <rdfs:label xml:lang="en">conductivity transmitter</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de condutividade é um transmissor que possui uma função de medição de condutividade.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A conductivity transmitter is a transmitter that bears a conductivity measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ConductivityTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(ConductivityMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b632"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every conductivity transmitter is a transmitter that has the function to measure and transmit electrical conductivity of process fluids.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A conductivity transmitter is a transmitter that bears a conductivity measurement function.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction">
    <rdfs:label xml:lang="en">tubing support function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de suporte de coluna de produção</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical suspension and support of downhole tubing strings within a wellbore.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3194"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3193"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1718">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000291"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2280">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess">
    <rdfs:label xml:lang="pt-br">processo de chaveamento de nível</rdfs:label>
    <rdfs:label xml:lang="en">level switching process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the fluid level in a vessel crosses a defined high or low threshold.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1554">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionFunction">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3213"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3214"/>
    <rdfs:label xml:lang="en">tubing support and connection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de suporte e conexão de coluna de produção</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes both the mechanical support of tubing strings within a wellbore and their connection to surface or subsurface equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1012">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivergingChannel"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidPortion">
    <rdfs:label xml:lang="pt-br">porção de processo de fluido</rdfs:label>
    <rdfs:label xml:lang="en">process fluid portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of the process fluid—hydrocarbon, water, or gas—handled at a defined point in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SteamDrum">
    <rdfs:label xml:lang="pt-br">tambor de vapor</rdfs:label>
    <rdfs:label xml:lang="en">steam drum</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the upper drum of a water-tube boiler that separates steam from the steam–water mixture and delivers dry steam to the distribution system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3412">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CasingHanger"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLoadingChamber">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">câmara de pig de carregamento</rdfs:label>
    <rdfs:label xml:lang="en">pig loading chamber</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the chamber within a pig launcher in which the pig is loaded and prepared for launch.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentItem">
    <rdfs:label xml:lang="en">equipment item</rdfs:label>
    <rdfs:label xml:lang="pt-br">item de equipamento</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a discrete item of petroleum production equipment assembled or installed as a unit within a production system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3419">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3414"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2656">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b62">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de separação de névoa</rdfs:label>
    <rdfs:label xml:lang="en">demisting function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b828"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b827"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the coalescence and removal of entrained liquid droplets from a gas stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PneumaticSeal">
    <skos:definition xml:lang="en">A material artifact that constitutes a seal within a pneumatic actuator or valve that prevents leakage of the compressed gas medium.</skos:definition>
    <rdfs:label xml:lang="pt-br">vedação pneumático</rdfs:label>
    <rdfs:label xml:lang="en">pneumatic seal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActiveMaterial">
    <rdfs:label xml:lang="pt-br">material ativo</rdfs:label>
    <rdfs:label xml:lang="en">active material</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a chemically or electrochemically reactive substance participating in a process reaction within petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">dehydration process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de desidratação</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which water is removed from a fluid stream by adsorption, absorption, or distillation to meet product specification limits.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b402">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixingElement">
    <rdfs:label xml:lang="en">mixing element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de mistura</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a static or dynamic element within a mixer that induces turbulence or shear to blend two or more fluid streams.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000358">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature measuring element is a measuring element that has a temperature measurement function.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A temperature measuring element is a measuring element that has the function to measure temperature.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de medição de temperatura é um elemento de medição que tem a função de medir temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature measuring element is a measuring element that has the function to measure temperature.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3081"/>
    <rdfs:label xml:lang="en">temperature measuring element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de medição de temperatura</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureMeasuringElement(x) ↔ MeasuringElement(x) ∧ ∃f(TemperatureMeasurementFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b80">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b798">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b792"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b799"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de proteção e invólucro</rdfs:label>
    <rdfs:label xml:lang="en">enclosure process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2842">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2843"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2837"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b140">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b141"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b135"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DryAirPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of air from which water vapour has been removed to a specified dew point.</skos:definition>
    <rdfs:label xml:lang="en">dry air portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção seco de ar</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an actuator converts a control input signal to mechanical movement or force, enabling the positioning or operation of controlled equipment such as valves, dampers, or switches.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an actuator converts input energy into controlled mechanical motion to operate valves, dampers, or other equipment requiring remote or automated positioning.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a control signal or energy input is converted by an actuator into mechanical motion or force that operates or positions another piece of equipment according to control requirements.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an actuator converts input energy (electrical, pneumatic, or hydraulic) into mechanical motion to operate valves, dampers, or other control devices.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de atuação</rdfs:label>
    <rdfs:label xml:lang="en">actuation process</rdfs:label>
    <skos:definition xml:lang="en">A PlannedProcess in which an actuator converts a control input signal to mechanical movement or force, enabling the positioning or operation of controlled equipment such as valves, dampers, or switches.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which an actuator converts input energy (electrical, pneumatic, or hydraulic) into mechanical motion to operate valves, dampers, or other control devices.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which an actuator converts input energy into controlled mechanical motion to operate valves, dampers, or other equipment requiring remote or automated positioning.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a control signal or energy input is converted by an actuator into mechanical motion or force that operates or positions another piece of equipment according to control requirements.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction">
    <rdfs:label xml:lang="pt-br">função de geração de energia por turbomáquina</rdfs:label>
    <rdfs:label xml:lang="en">turbomachinery power generation function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1624"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1623"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of fluid enthalpy into shaft power through interaction with rotating turbine blades.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">subsurface resource interaction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de interação com recursos subsuperficiais</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which petroleum production equipment physically interacts with subsurface formations to enable drilling, completion, or production operations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1978">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureControlSystem"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2324">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2325"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2319"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2773"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2772"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the release of excess pressure from a process system to a safe disposal location.</skos:definition>
    <rdfs:label xml:lang="en">safety venting function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de ventilação de segurança</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2570">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2567"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000356">
    <skos:definition xml:lang="en">A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural role as a conductive part. Under OWA, asserting sufficient conditions could incorrectly classify any conductive part of an electrical contact as a switch contact, when there may be other specialized conductive components (bus bars, terminals, etc.) that serve different structural roles.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">switch contact</rdfs:label>
    <rdfs:label xml:lang="pt-br">contato de chave</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3031"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um contato de chave é um contato elétrico que é uma das partes condutoras que formam um conjunto de contato.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every switch contact is an electrical contact that is part of an electrical contact assembly and bears an electrical conduction function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (SwitchContact(x) → ElectricalContact(x) ∧ ∃y(ElectricalContact(y) ∧ partOf(x,y)) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1744">
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1749"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TransformerWinding">
    <rdfs:label xml:lang="en">transformer winding</rdfs:label>
    <rdfs:label xml:lang="pt-br">enrolamento de transformador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a winding of insulated conductor wound on a transformer core that transfers electrical energy between circuits by electromagnetic induction.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Absorber">
    <rdfs:label xml:lang="pt-br">absorvedor</rdfs:label>
    <rdfs:label xml:lang="en">absorber</rdfs:label>
    <skos:definition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um absorvedor é um vaso de pressão que realiza uma função de absorção para transferência seletiva de massa de componentes de uma mistura fluida para uma fase absorvente.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every absorber is a separator that has the function to absorb specific components from fluid mixtures through mass transfer to an absorbent phase</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b14"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Absorber(x) ↔ (Separator(x) ∧ ∃f(AbsorptionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1491">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalProcessingUnit"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipelinePig">
    <skos:definition xml:lang="en">A material artifact that constitutes a device inserted into and propelled through a pipeline to perform internal inspection, cleaning, or gauging operations.</skos:definition>
    <rdfs:label xml:lang="en">pipeline pig</rdfs:label>
    <rdfs:label xml:lang="pt-br">pig de pipeline</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2467">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PneumaticEnergyConversionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess">
    <skos:definition xml:lang="en">A planned process in which thermal, chemical, or electrical energy is converted into rotational or linear mechanical energy by petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de geração de energia mecânica</rdfs:label>
    <rdfs:label xml:lang="en">mechanical energy generation process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MountingPoint">
    <rdfs:label xml:lang="pt-br">ponto de suporte de montagem</rdfs:label>
    <rdfs:label xml:lang="en">mounting point</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a defined attachment point on petroleum production equipment at which another component or accessory is fixed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SparkIgnitionSystem">
    <rdfs:label xml:lang="pt-br">sistema de centelha de ignição</rdfs:label>
    <rdfs:label xml:lang="en">spark ignition system</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of components that generates an electrical spark to ignite a combustible mixture in spark-ignition engines of petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3172">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3166"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
