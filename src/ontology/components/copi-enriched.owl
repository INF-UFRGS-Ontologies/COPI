  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidMixturePortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more liquid phases at a defined point in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">liquid mixture portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção líquido de mistura</rdfs:label>
  </rdf:Description>
