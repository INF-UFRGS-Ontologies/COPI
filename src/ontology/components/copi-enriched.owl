    <rdfs:label xml:lang="pt-br">função de medição de fluxo</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2275"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1494"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1472"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1495"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2276"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b727"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b728"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1499"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1500"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1473"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
