    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b599"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1708">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
