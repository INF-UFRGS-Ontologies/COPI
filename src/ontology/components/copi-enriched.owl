  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000368">
    <skos:definition xml:lang="en">[CFIHOS] An ac power supply unit that maintains a continuous supply of electric power to the equipment it protects.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An A.C. power supply unit that maintains a continuous supply of electric power to the equipment it protects.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;UPS UNIT&gt; is an &lt;AC ELECTRIC POWER SUPPLY UNIT&gt; that maintains a uninterrupted supply of electric power to the equipment it protects</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A UPS unit is electrical equipment that bears the designed function of maintaining uninterrupted AC electric power supply to protected equipment during power disturbances.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma unidade UPS é um equipamento elétrico que possui a função projetada de manter o fornecimento ininterrupto de energia elétrica AC para equipamentos protegidos durante distúrbios de energia.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3328"/>
    <rdfs:label xml:lang="en">ups unit</rdfs:label>
    <rdfs:label xml:lang="pt-br">unidade UPS</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(UPSUnit(x) ↔ ElectricalEquipment(x) ∧ ∃f(UninterruptedPowerSupplyFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every UPS unit is electrical equipment that has the function of maintaining uninterrupted AC electric power supply.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2615">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144">
    <rdfs:label xml:lang="pt-br">transmissor de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure transmitter</rdfs:label>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'PT'. First letter 'P': Pressure. Succeeding letters: 'T' = Transmit.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a pressure element.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PRESSURE TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;PRESSURE MEASURING INSTRUMENT&gt;</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure transmitter is a transmitter that has the function to transmit pressure measurement signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão é um transmissor que converte medições de pressão em sinais de saída padronizados para transmissão a sistemas de controle ou monitoramento.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2654"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(PressureTransmissionFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChemicalFuelPortion">
    <rdfs:label xml:lang="en">chemical fuel portion</rdfs:label>
