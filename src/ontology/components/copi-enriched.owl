    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1202"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
