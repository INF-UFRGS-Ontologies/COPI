    <rdfs:label xml:lang="en">carrier fluid system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de portador de fluido</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1115">
    <rdf:rest rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1116"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
