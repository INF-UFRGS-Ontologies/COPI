    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2499">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2500"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
