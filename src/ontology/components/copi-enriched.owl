  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Closure">
    <rdfs:label xml:lang="en">closure</rdfs:label>
    <rdfs:label xml:lang="pt-br">fechamento</rdfs:label>
