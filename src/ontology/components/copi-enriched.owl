  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000358">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureMeasuringElement(x) ↔ MeasuringElement(x) ∧ ∃f(TemperatureMeasurementFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature measuring element is a measuring element that has a temperature measurement function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">elemento de medição de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature measuring element</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature measuring element is a measuring element that has the function to measure temperature.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de medição de temperatura é um elemento de medição que tem a função de medir temperatura.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3097"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TEMPERATURE MEASURING ELEMENT&gt; is a &lt;MEASURING ELEMENT&gt; for the measurement of &lt;TEMPERATURE&gt;</skos:definition>
  </rdf:Description>
