  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000214">
    <iof-av:naturalLanguageDefinition xml:lang="en">A basin is a vessel that is designed to store liquid or solid material, characterized by being typically open at the top and installed partly or totally below grade.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bacia é um vaso projetado para armazenar material líquido ou sólido, caracterizado por ser tipicamente aberto no topo e instalado parcial ou totalmente abaixo do nível do solo.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">basin</rdfs:label>
    <rdfs:label xml:lang="pt-br">bacia</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">Basin(x) ↔ Vessel(x) ∧ ∃f(StorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(OpenTop(p) ∧ hasGeometricProperty(x,p)) ∧ ∃q(PartlyBelowGrade(q) ∧ hasInstallationProperty(x,q))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[OnePetro] A large area with a general containment and an often thick accumulation of rock. A sedimentary basin is an area of regional settling that can be characterized in space, time, and sedimentary fill .It is a physical depression at the earth's surface which accumulates and preserves sediments. The scale of basins varies greatly, from ocean basins to small ponds.                  ==References==                   Helwig, J. A. 1985. Origin and Classification of Sedimentary Basins. Offshore Technology Conference. http://www.doi.org/doi:10.4043/4843-MS</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A container intended to store liquid or solid material partly or totally below grade and that is typically open.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A depression in the crust of the Earth, caused by plate tectonic activity and subsidence, in which sediments accumulate.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BASIN&gt; is a &lt;FLUID CONTAINER&gt;, intended to store liquid or solid material partly or totally below grade and that is typically open</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every basin is a vessel that bears a storage function and has an open top configuration and is installed partly below grade.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000214"/>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b187"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2009">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContaminatedSurface">
    <rdfs:label xml:lang="pt-br">superfície contaminado</rdfs:label>
    <rdfs:label xml:lang="en">contaminated surface</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242">
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b813"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehumidifier is an assembly that has the function to perform dehumidification.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desumidificador é um conjunto que possui a função de remover umidade do ar.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">desumidificador</rdfs:label>
    <rdfs:label xml:lang="en">dehumidifier</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEHUMIDIFIER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEHUMIDIFYING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A piece of equipment specifically designed to remove moisture from air.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2768">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InnerLining">
    <rdfs:label xml:lang="en">inner lining</rdfs:label>
    <rdfs:label xml:lang="pt-br">revestimento interno</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShakingElement">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">elemento de agitação</rdfs:label>
    <rdfs:label xml:lang="en">shaking element</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260">
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric actuator is an actuator that converts electrical energy to mechanical movement through an electric-to-mechanical converter component and operates via electrical signal input.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador elétrico é um atuador que converte energia elétrica em movimento mecânico através de um componente conversor elétrico-mecânico e opera via entrada de sinal elétrico.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricActuator(x) → Actuator(x) ∧ ∃y(ElectricToMechanicalConverter(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ElectricalSignal(z) ∧ hasInput(x,z)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1153"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1154"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1152"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1155"/>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ELECTRIC ACTUATOR&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROLLED ACTUATOR&gt; and an &lt;ELECTRICAL APPARATUS&gt; and an &lt;ELECTRIC TO MECHANICAL ENERGY CONVERTER&gt; that produces a specified movement when actuated by electrical energy</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] An actuator that produces a specified movement when excited by an electric signal.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An actuator that produces a specified movement when excited by an electric signal.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on electrical energy conversion mechanism. Under OWA, asserting equivalence would force any artifact with electrical-to-mechanical conversion into this category, potentially misclassifying specialized hybrid equipment or complex electrical machinery that should not be categorized as standard actuators.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">electric actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador elétrico</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric actuator is an actuator that has an electric-to-mechanical converter component at all times and has electrical signal input.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b618">
