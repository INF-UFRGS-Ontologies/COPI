  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2786"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2785"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a RotationalEnergyTransferProcess and that consists in the capacity to transfer mechanical energy through rotational motion within a machine assembly.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">função de transferência de energia rotacional</rdfs:label>
    <rdfs:label xml:lang="en">rotational energy transfer function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de acumulação</rdfs:label>
    <rdfs:label xml:lang="en">accumulation process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de ebulição</rdfs:label>
    <rdfs:label xml:lang="en">boiling process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210">
    <rdfs:label xml:lang="pt-br">indicador analógico de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">analogue temperature indicator</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador analógico de temperatura é um instrumento que possui uma função de indicação de temperatura e tem um mostrador analógico para exibição visual da temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb91"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AnalogueTemperatureIndicator(x) ↔ Instrument(x) ∧ ∃f(TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃d(AnalogueDial(d) ∧ hasComponentPartAtAllTimes(x,d)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ANALOGUE TEMPERATURE INDICATOR&gt; is an &lt;ANALOGUE INDICATOR&gt; that indicates temperature in an analogue way</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every analogue temperature indicator is an instrument that bears a temperature indication function and has component parts including a temperature sensor, analogue dial, and indicator pointer.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000336">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2700"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotatingShaft"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de bomba é um MaterialArtifact que possui uma PowerTransmissionFunction e que é equipado com impulsor(es), mancais, buchas e elementos de vedação como parte de um conjunto de bomba para transmitir energia mecânica rotacional e possibilitar operações de bombeamento de fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction and that is equipped with impeller(s), bearings, bushings, and sealing elements as part of a pump assembly for transmitting rotational mechanical energy to enable fluid pumping operations.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction, has impeller(s) as component parts, has bearings as component parts, and is part of a pump assembly.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PUMP SHAFT&gt; is a &lt;SHAFT&gt; of a pump that is provided with impeller(s), bearings, bushings, sealing elements etc.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration, sufficient conditions are omitted to avoid false positives under OWA. Any rotating component with an impeller and bearings could theoretically be classified as a pump shaft under sufficient conditions, including hybrid equipment or specialized assemblies that should not be automatically categorized as standard pump shafts.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">pump shaft</rdfs:label>
    <rdfs:label xml:lang="pt-br">eixo de bomba</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PumpShaft(x) → MaterialArtifact(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(Impeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃b(Bearing(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃p(Pump(p) ∧ partOf(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb80">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329">
    <rdfs:label xml:lang="en">port</rdfs:label>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma InterfacingFunction e</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma InterfacingFunction e que é capaz de fornecer um ponto de interface para comunicação com outro objeto.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Port ≡ MaterialArtifact ⊓ ∃bearerOf.InterfacingFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PORT&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;PROVIDING&gt; a point of interface for communication with another object</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Port(x) ↔ (MaterialArtifact(x) ∧ ∃f(InterfacingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2533"/>
  </rdf:Description>
