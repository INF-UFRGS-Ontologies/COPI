    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElbowBody"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3101">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3096"/>
