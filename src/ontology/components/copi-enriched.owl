  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000233">
    <rdfs:label xml:lang="en">conductivity transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de condutividade</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ConductivityTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(ConductivityMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CONDUCTIVITY TRANSMITTER&gt; is an &lt;CONDUCTIVITY METER&gt; and a &lt;PROCESS VARIABLE TRANSMITTER&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that is intended to measure and transmit conductivity.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every conductivity transmitter is a transmitter that has the function to measure and transmit electrical conductivity of process fluids.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A conductivity transmitter is a transmitter that bears a conductivity measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de condutividade é um transmissor que possui uma função de medição de condutividade.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b632"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b637">
    <rdf:rest rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b638"/>
    <rdf:first rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b633"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000347">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every shaker is an assembly that has the capability of shaking and contains a vibration mechanism and a shaking element.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <rdfs:label xml:lang="en">shaker</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um conjunto que possui uma função de agitação, capaz de produzir movimento vibratório ou oscilatório para processamento, agitação ou separação de materiais.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A shaker is an assembly that bears a shaking function, capable of producing vibrating or oscillating motion for material processing, agitation, or separation.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">Shaker(x) ↔ Assembly(x) ∧ ∃f(ShakingFunction(f) ∧ bearerOf(x,f))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[SLB Glossary] Abbreviation for shale shaker, the primary and probably most important device on the rig for removing drilled solids from the mud.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SHAKER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;SHAKING&gt;</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A piece of drilling equipment, usually with a vibrating screen, where drill cuttings are removed from the flowing mud.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2879"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3068">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess"/>
