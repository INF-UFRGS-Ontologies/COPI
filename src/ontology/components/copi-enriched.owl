    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1454">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000322">
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the curved geometry with non-standard radius is distinctive, making it sufficient under OWA could force classification of complex piping assemblies or custom manifolds containing bent sections into this maintenance category inappropriately.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma curva de tubo é um tubo que possui geometria curvada para mudar a direção da tubulação com um raio não padrão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe bend is a pipe that has a curved geometry to change piping direction with a non-standard radius.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pipe bend</rdfs:label>
    <rdfs:label xml:lang="pt-br">curva de tubo</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe bend is a pipe that has curved geometry and has non-standard bend radius.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[POSC Caesar] An 'artefact' that is intended to change piping direction with a non-standard radius</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is used to change piping direction with a non-standard radius.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIPE BEND&gt; is a &lt;PIPING COMPONENT&gt; that is intended to change piping direction with a non-standard radius</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2418"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2419"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PipeBend(x) → Pipe(x) ∧ ∃g (CurvedGeometry(g) ∧ hasQuality(x,g)) ∧ ∃r (NonStandardBendRadius(r) ∧ hasQuality(x,r)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b540">
    <rdf:rest rdf:nodeID="n297d145abb684750972df9e3ef9e1556b541"/>
    <rdf:first rdf:nodeID="n297d145abb684750972df9e3ef9e1556b534"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1850">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1846"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334">
    <rdfs:label xml:lang="en">pressure indicating transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor indicador de pressão</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureIndicatingTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PressureIndicatingAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(PressureSignal(i) ∧ hasInput(x,i)) ∧ ∃o1(ElectricalSignal(o1) ∧ hasOutput(x,o1)) ∧ ∃o2(LocalPressureDisplay(o2) ∧ hasOutput(x,o2)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure indicating transmitter is a transmitter that bears a pressure indicating and transmission function, has pressure signal as input, and has both electrical signal output and local pressure display.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor indicador de pressão é um transmissor que mede pressão e fornece tanto indicação visual local quanto transmissão de sinal elétrico do valor da pressão.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'PIT'. First letter 'P': Pressure. Succeeding letters: 'I' = Indicate, 'T' = Transmit.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2628"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1458">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1463"/>
  </rdf:Description>
