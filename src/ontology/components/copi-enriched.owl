    <rdfs:label xml:lang="pt-br">lâmina de cisalhamento</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the cutting blade of a shear ram in a blowout preventer that severs a tubular string for well control purposes.</skos:definition>
  </rdf:Description>
