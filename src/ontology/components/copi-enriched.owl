  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">tubing support and connection process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de suporte e conexão de coluna de produção</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which downhole tubing strings are mechanically supported within a wellbore and connected to surface or subsurface equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
