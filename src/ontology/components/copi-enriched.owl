    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1340">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSignal">
    <rdfs:label xml:lang="en">level signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de nível</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the fluid level in a vessel of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab169">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264">
    <skos:definition xml:lang="en">An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab979"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor é um motor que converte energia de combustível químico em força mecânica e movimento através de processos de combustão.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">engine</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Engine is a Motor that has function MechanicalEnergyGenerationFunction and has input ChemicalFuelPortion and participates in CombustionProcess.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Engine(x) ↔ Motor(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ChemicalFuelPortion(p) ∧ hasInput(x,p)) ∧ ∃c(CombustionProcess(c) ∧ participatesIn(x,c)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">information display process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de exibição de informação</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab229"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
    <skos:definition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um soprador é um compressor que comprime e fornece ar ou gás em pressão média e vazão volumétrica média.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every blower is a compressor that has the function of compressing gas and operates at medium pressure and medium volume flow ranges.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">blower</rdfs:label>
    <rdfs:label xml:lang="pt-br">soprador</rdfs:label>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Blower(x) ↔ (Compressor(x) ∧ ∃f,p,v (CompressionFunction(f) ∧ bearerOf(x,f) ∧ MediumPressureRange(p) ∧ MediumVolumeFlowRange(v) ∧ hasOperatingParameter(x,p) ∧ hasOperatingParameter(x,v))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1649">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1647"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every riser is a pipe that has vertical orientation and participates in upward flow processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A riser is a pipe that has vertical or near-vertical orientation and is designed for the upward flow of liquid or gas.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um riser é um tubo que tem orientação vertical ou quase vertical e é projetado para o fluxo ascendente de líquido ou gás.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A riser is a pipe that has vertical or near-vertical orientation and is designed for the upward flow of liquid or gas.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2224"/>
    <rdfs:label xml:lang="pt-br">riser</rdfs:label>
    <rdfs:label xml:lang="en">riser</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical configuration. Under OWA, any pipe with vertical orientation and upward flow could be forced into this category, including specialized equipment that should not be classified as standard risers (e.g., reactor internals, distillation column internals). Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Riser(x) → Pipe(x) ∧ ∃q(VerticalOrientation(q) ∧ hasQuality(x,q)) ∧ ∃p(UpwardFlowProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1903">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1899"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1904"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2216">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2214"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab713">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab711"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121">
    <skos:definition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1380"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1379"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1377"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1381"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1378"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gearbox is an assembly that has component parts including a gear casing, at least two gear-wheels, an input shaft, and an output shaft, and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma caixa de engrenagens é um conjunto que consiste em um invólucro de engrenagens contendo um arranjo de duas ou mais rodas de engrenagem que transmitem movimento rotativo de um eixo de entrada para um eixo de saída.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because the structural differentia (specific gear casing and gear-wheel arrangement) is complex and making it sufficient under Open World Assumption could lead to false positives - specialized equipment containing gear mechanisms might be incorrectly classified as standard gearboxes.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Gearbox(x) → Assembly(x) ∧ ∃c,g1,g2,i,o (GearCasing(c) ∧ GearWheel(g1) ∧ GearWheel(g2) ∧ g1≠g2 ∧ InputShaft(i) ∧ OutputShaft(o) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,g1) ∧ hasComponentPartAtAllTimes(x,g2) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">gearbox</rdfs:label>
    <rdfs:label xml:lang="pt-br">caixa de engrenagens</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2508"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2509"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de sensoriamento de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature sensing function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the detection and measurement of the temperature of a process stream or equipment surface.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1183">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1593">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1591"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000273">
    <rdfs:label xml:lang="pt-br">flange</rdfs:label>
    <rdfs:label xml:lang="en">flange</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flange is a material artifact that has a projecting flat rim geometry and has the function of mechanically connecting components.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by structural geometry. Under OWA, any artifact with projecting flat rim geometry would be forced into the flange category, which could incorrectly classify specialized equipment or complex assemblies that contain flange-like features but serve different primary functions.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1096"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um flange é um artefato material caracterizado por uma geometria de aro plano projetante, placa, colar ou nervura, projetado para fornecer conexão mecânica entre componentes.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flange(x) → MaterialArtifact(x) ∧ ∃g(ProjectingFlatRimGeometry(g) ∧ hasCharacteristic(x,g)) ∧ ∃f(MechanicalConnectionFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillString">
    <rdfs:label xml:lang="en">drill string</rdfs:label>
    <rdfs:label xml:lang="pt-br">coluna de perfuração</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of drill pipe, drill collars, and bottom-hole assembly that transmits rotation and drilling fluid from surface to the drill bit.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1287">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab361">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StandardizedElectricalSignal">
    <rdfs:label xml:lang="pt-br">sinal padronizado elétrico</rdfs:label>
    <rdfs:label xml:lang="en">standardized electrical signal</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <skos:definition xml:lang="en">An information content entity constituting an electrical signal in a standardised format—such as 4–20 mA or 0–10 V—used to transmit process variable values between petroleum production instrumentation components.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000347">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">Shaker(x) ↔ Assembly(x) ∧ ∃f(ShakingFunction(f) ∧ bearerOf(x,f))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um conjunto que possui uma função de agitação, capaz de produzir movimento vibratório ou oscilatório para processamento, agitação ou separação de materiais.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A shaker is an assembly that bears a shaking function, capable of producing vibrating or oscillating motion for material processing, agitation, or separation.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A shaker is an assembly that bears a shaking function, capable of producing vibrating or oscillating motion for material processing, agitation, or separation.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2346"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every shaker is an assembly that has the capability of shaking and contains a vibration mechanism and a shaking element.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <rdfs:label xml:lang="en">shaker</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a liquid is converted into vapour by supplying thermal energy at or above its boiling point in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">boiling process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de ebulição</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab579">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab925"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab924"/>
    <rdfs:label xml:lang="pt-br">função de geração de energia elétrica</rdfs:label>
    <rdfs:label xml:lang="en">electric energy generation function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of mechanical, thermal, or chemical energy into electrical energy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlexibleDiaphragm">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">diafragma flexível</rdfs:label>
    <rdfs:label xml:lang="en">flexible diaphragm</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a flexible membrane that separates two chambers and transmits pressure between them in petroleum production measurement or control equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197">
    <rdfs:label xml:lang="en">storage function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de armazenamento</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2450"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2449"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab149"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab150"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the temporary or permanent containment of fluids or materials in a defined storage volume.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000322">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PipeBend(x) → Pipe(x) ∧ ∃g (CurvedGeometry(g) ∧ hasQuality(x,g)) ∧ ∃r (NonStandardBendRadius(r) ∧ hasQuality(x,r)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1933"/>
    <rdfs:label xml:lang="pt-br">curva de tubo</rdfs:label>
    <rdfs:label xml:lang="en">pipe bend</rdfs:label>
    <skos:definition xml:lang="en">A pipe bend is a pipe that has a curved geometry to change piping direction with a non-standard radius.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe bend is a pipe that has a curved geometry to change piping direction with a non-standard radius.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma curva de tubo é um tubo que possui geometria curvada para mudar a direção da tubulação com um raio não padrão.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the curved geometry with non-standard radius is distinctive, making it sufficient under OWA could force classification of complex piping assemblies or custom manifolds containing bent sections into this maintenance category inappropriately.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe bend is a pipe that has curved geometry and has non-standard bend radius.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab176">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab174"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionFunction">
    <iof-av:naturalLanguageDefinition xml:lang="en">A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab958"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab957"/>
    <rdfs:label xml:lang="en">electrical connection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de conexão elétrica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1196"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1837"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1836"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab580"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab579"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1197"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1191"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1192"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1169"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1170"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measurement function</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab619"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab620"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of dissolved or entrained gases from a liquid to reduce their concentration.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de degaseificação</rdfs:label>
    <rdfs:label xml:lang="en">degassing function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementFunction">
    <rdfs:label xml:lang="en">temperature measurement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição de temperatura</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2533"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2534"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the thermal state of a process stream or equipment surface and its expression as a quantitative value.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab234">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2031">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2033"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab197">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SideOutlet"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab216">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2027">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab515">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab516"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000361">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every three-phase separator is a separator that has the function of separating fluid into gas, oil, and water phases, and has gas outlet, oil outlet, and water outlet as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</skos:definition>
    <rdfs:label xml:lang="en">three phase separator</rdfs:label>
    <rdfs:label xml:lang="pt-br">separador trifásico</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador trifásico é um separador que possui uma função de separação trifásica para separar fluidos de poço em fases gasosa, oleosa e aquosa.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2583"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ThreePhaseSeparator(x) ↔ (Separator(x) ∧ ∃f (ThreePhaseSeparationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1656">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2076">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureSensingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingProcess">
    <rdfs:label xml:lang="pt-br">processo de chaveamento por pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure switching process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the differential pressure between two process points crosses a defined threshold.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pressure measurement process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição de pressão</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the absolute or gauge pressure of a process stream is measured and expressed as a quantitative value.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2734">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2402">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction">
    <rdfs:label xml:lang="en">multi service transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de múltiplos serviços</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2668"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2669"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the simultaneous measurement and transmission of multiple process variables to a remote control or monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092">
    <iof-av:naturalLanguageDefinition xml:lang="en">A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor é um vaso de pressão que possui a função projetada de transferir energia térmica entre duas ou mais correntes de fluido mantendo sua separação.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">trocador de calor</rdfs:label>
    <rdfs:label xml:lang="en">heat exchanger</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (HeatExchanger(x) ↔ (Assembly(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat exchanger is an assembly that has the function of heat transfer and has component parts including heat transfer surfaces and fluid passages for separated streams.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1435"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the containment and temporary storage of solid bulk materials such as catalyst, proppant, or chemical reagents.</skos:definition>
    <rdfs:label xml:lang="en">solid bulk storage function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de armazenamento de sólidos a granel</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2395"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2394"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab649">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2323">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalPhenomenon">
    <skos:definition xml:lang="en">A process in which a physical phenomenon—such as a pressure wave, temperature gradient, or electromagnetic field—that participates in or is generated by a petroleum production process.</skos:definition>
    <rdfs:label xml:lang="pt-br">fenômeno físico</rdfs:label>
    <rdfs:label xml:lang="en">physical phenomenon</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotatingVanes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">rotating vanes</rdfs:label>
    <rdfs:label xml:lang="pt-br">palhetas rotativo</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an assembly of vanes attached to a rotating element that interacts with a fluid stream in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1945">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ACElectricalPower">
    <rdfs:label xml:lang="en">a c electrical power</rdfs:label>
    <rdfs:label xml:lang="pt-br">potência elétrico de CA</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting alternating-current electrical power delivered to petroleum production equipment to drive motors, instrumentation, or control systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SuppressedDisturbance">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:label xml:lang="pt-br">perturbação suprimido</rdfs:label>
    <rdfs:label xml:lang="en">suppressed disturbance</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A process in which an unwanted physical perturbation—vibration, noise, or pressure surge—that has been attenuated or eliminated by petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000227">
    <rdfs:label xml:lang="en">check valve closure member</rdfs:label>
    <rdfs:label xml:lang="pt-br">membro de fechamento de válvula de retenção</rdfs:label>
    <skos:definition xml:lang="en">A MaterialArtifact that is a component part of a check valve and that bears a BackflowPreventionFunction, consisting in a mechanical element that prevents fluid flow reversal by physically blocking the flow path when pressure conditions indicate potential backflow.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é uma parte componente de uma válvula de retenção e que possui uma BackflowPreventionFunction, consistindo em um elemento mecânico que previne o refluxo de fluido bloqueando fisicamente o caminho de fluxo quando as condições de pressão indicam potencial refluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is a component part of a check valve and that bears a BackflowPreventionFunction, consisting in a mechanical element that prevents fluid flow reversal by physically blocking the flow path when pressure conditions indicate potential backflow.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab388"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every check valve closure member is a MaterialArtifact that is component part of some check valve and bears some BackflowPreventionFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveClosureMember(x) → MaterialArtifact(x) ∧ ∃y(CheckValve(y) ∧ isComponentPartOf(x,y)) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural role and mechanism. Under OWA, sufficient conditions would force classification of any artifact with backflow prevention function and check valve association, potentially including hybrid or specialized designs that should not be automatically classified as standard closure members without domain expert validation.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferFunction">
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a RotationalEnergyTransferProcess and that consists in the capacity to transfer mechanical energy through rotational motion within a machine assembly.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2241"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2242"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">rotational energy transfer function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transferência de energia rotacional</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a RotationalEnergyTransferProcess and that consists in the capacity to transfer mechanical energy through rotational motion within a machine assembly.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab156">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab154"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1307">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialArtifact">
    <rdfs:label xml:lang="pt-br">artefato de material</rdfs:label>
    <rdfs:label xml:lang="en">material artifact</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a physical object that is part of a petroleum production system and bears functions whose realizations are planned processes in petroleum production operations.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334">
    <skos:definition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor indicador de pressão é um transmissor que mede pressão e fornece tanto indicação visual local quanto transmissão de sinal elétrico do valor da pressão.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pressure indicating transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor indicador de pressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureIndicatingTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PressureIndicatingAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(PressureSignal(i) ∧ hasInput(x,i)) ∧ ∃o1(ElectricalSignal(o1) ∧ hasOutput(x,o1)) ∧ ∃o2(LocalPressureDisplay(o2) ∧ hasOutput(x,o2)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2109"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure indicating transmitter is a transmitter that bears a pressure indicating and transmission function, has pressure signal as input, and has both electrical signal output and local pressure display.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132">
    <rdfs:label xml:lang="en">limit switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">limit switch</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um limit switch é um instrumento que possui uma função de detecção de limite de posição, acionado mecanicamente pelo movimento de objetos para fornecer sinais de chaveamento elétrico quando limites de posição predeterminados são atingidos.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1719"/>
    <skos:definition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every limit switch is an instrument that has the function to detect position limits and is mechanically operated by object motion to generate electrical switching signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LimitSwitch(x) ↔ Instrument(x) ∧ ∃f(PositionLimitDetectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MechanicalMotion(p) ∧ hasInput(x,p)) ∧ ∃s(ElectricalSignal(s) ∧ hasOutput(x,s)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1358">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LoggingData">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">dados de perfilagem</rdfs:label>
    <rdfs:label xml:lang="en">logging data</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting data acquired by measurement tools deployed in a wellbore to characterise subsurface formation properties.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000338">
    <skos:definition xml:lang="en">A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um relé é um dispositivo de comutação elétrica que possui uma função de relé de sinal, realizada ao transmitir informações ou sinais de um circuito para controlar operações em outro circuito.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">relay</rdfs:label>
    <rdfs:label xml:lang="pt-br">relé</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2185"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Relay(x) ↔ (ElectricalSwitchingDevice(x) ∧ ∃f(SignalRelayFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Relay is an ElectricalSwitchingDevice that bearerOf some SignalRelayFunction</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab108">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction">
    <rdfs:label xml:lang="en">energy transfer function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transferência de energia</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1544"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1545"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the movement of energy in the form of heat, work, or electromagnetic radiation from one medium or system to another.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1497">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1357"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab325"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2162"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1405"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1475"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab326"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab382"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1474"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab502"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1356"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab348"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab349"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2163"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2622"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab503"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2621"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab381"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1404"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">função de proteção e invólucro</rdfs:label>
    <rdfs:label xml:lang="en">enclosure function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372">
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma ForceTransmissionFunction e que tem um selo de haste de válvula como parte componente, especificamente projetado para transmitir movimento de um operador de válvula para o membro de fechamento da válvula.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical structure (rod/shaft mechanism). Under Open World Assumption, sufficient conditions would force any assembly with a valve stem seal and force transmission function to be classified as a valve stem, which could include complex multi-component assemblies, manifolds, or specialized valve mechanisms that contain these elements but should not be asserted into the standard valve stem maintenance category.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ValveStem(x) → Assembly(x) ∧ ∃f(ForceTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(ValveStemSeal(s) ∧ hasComponentPartAtAllTimes(x,s)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">valve stem</rdfs:label>
    <rdfs:label xml:lang="pt-br">haste de válvula</rdfs:label>
    <skos:definition xml:lang="en">An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2737"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ValveStem SubClassOf Assembly and bearerOf some ForceTransmissionFunction and hasComponentPartAtAllTimes some ValveStemSeal</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2056">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InterfacingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an InterfacingProcess and that consists in providing a standardized point of interface for communication, connection, or interaction with another object or system.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2027"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2028"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an InterfacingProcess and that consists in providing a standardized point of interface for communication, connection, or interaction with another object or system.</skos:definition>
    <rdfs:label xml:lang="en">interfacing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de interfaceamento</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000156">
    <rdfs:label xml:lang="pt-br">poço termométrico</rdfs:label>
    <rdfs:label xml:lang="en">thermowell</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um poço termométrico é um instrumento que é um receptáculo resistente à pressão adaptado para receber um elemento sensor de temperatura, provido com roscas externas ou outros meios para fixação resistente à pressão a um vaso ou tubulação.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Thermowell has constructive classification basis. The structural differentia (pressure-tight receptacle with process connection) defines necessary conditions, but making these sufficient under OWA could lead to false classifications of other threaded pressure-tight devices that happen to contain receptacles but are not intended as thermowells.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2565"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Thermowell(x) → Instrument(x) ∧ ∃r,c,f (PressureTightReceptacle(r) ∧ ProcessConnection(c) ∧ TemperatureSensorProtectionFunction(f) ∧ hasComponentPartAtAllTimes(x,r) ∧ hasComponentPartAtAllTimes(x,c) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell is an instrument that has a pressure-tight receptacle as component part and has a process connection as component part and is designed for temperature sensing elements.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1536">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
