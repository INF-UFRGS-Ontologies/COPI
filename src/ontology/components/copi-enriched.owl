  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefValve">
    <skos:definition xml:lang="en">A material artifact that constitutes a self-actuating safety valve that opens at a defined set pressure to discharge fluid and protect equipment from overpressure.</skos:definition>
    <rdfs:label xml:lang="en">pressure relief valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de pressão de alívio</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
