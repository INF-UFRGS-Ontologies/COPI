  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirOutlet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">saída de ar</rdfs:label>
    <rdfs:label xml:lang="en">air outlet</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an opening or port through which air is discharged from petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">cooling process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de resfriamento</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which thermal energy is removed from a process stream or equipment component to reduce its temperature in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
