  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TransductionElement">
    <rdfs:label xml:lang="pt-br">elemento de transdução</rdfs:label>
    <rdfs:label xml:lang="en">transduction element</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294">
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1826"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat transfer plate is a MaterialArtifact that bears a HeatTransferFunction and participates in segregating two fluid media in a non-tubular heat exchanger.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma HeatTransferFunction e que é destinado a ser usado em um trocador de calor não tubular para segregar dois meios fluidos enquanto facilita a transferência de energia térmica entre eles.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HeatTransferPlate(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MediaSeparationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">heat transfer plate</rdfs:label>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma HeatTransferFunction e</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEAT TRANSFER PLATE&gt; is a &lt;PLATE&gt; that is intended to be used in a non tubular heat exchanger to segregate the two media</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis requires necessary conditions only. Under OWA, sufficient conditions for 'plate geometry used in non-tubular heat exchangers' could lead to false positives - other components with plate-like surfaces might be incorrectly classified as heat transfer plates without domain expert validation of the structural and application-specific criteria.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000261">
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1166"/>
    <rdfs:label xml:lang="pt-br">gerador elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electric generator</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ELECTRIC GENERATOR&gt; is a &lt;GENERATOR&gt; that transforms non-electric energy into &lt;ELECTRIC ENERGY&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] An energy transducer that transforms non-electric energy into electric energy.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ElectricGenerator(x) ↔ (Assembly(x) ∧ ∃f(ElectricEnergyGenerationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric generator is an assembly that has the function to convert non-electric energy into electric energy</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um gerador elétrico é um conjunto que possui a função de converter energia não-elétrica em energia elétrica</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1379">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameSensingElement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a stator maintains its fixed position relative to rotating components within machinery, providing structural support and housing for electromagnetic windings, guide vanes, or other functional elements that require stable positioning.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de componente estacionário de máquina</rdfs:label>
    <rdfs:label xml:lang="en">stationary machine component process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
