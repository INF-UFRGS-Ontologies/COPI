@prefix copi:     <https://www.inf.ufrgs.br/ontologies/copi/> .
@prefix owl:      <http://www.w3.org/2002/07/owl#> .
@prefix rdf:      <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms:  <http://purl.org/dc/terms/> .
@prefix skos:     <http://www.w3.org/2004/02/skos/core#> .
@prefix obo:      <http://purl.obolibrary.org/obo/> .
@prefix iof-constr: <https://spec.industrialontologies.org/ontology/construct/> .
@prefix iof-av:   <https://spec.industrialontologies.org/ontology/annotation/> .
@prefix iof-ind:  <https://spec.industrialontologies.org/ontology/individual/> .

#==============================================================================
# ONTOLOGY HEADER
#==============================================================================
<https://www.inf.ufrgs.br/ontologies/copi/copi-enriched>
    a owl:Ontology ;
    owl:versionIRI <https://www.inf.ufrgs.br/ontologies/copi/releases/2026-06-15/copi-enriched> ;

    owl:imports <https://www.inf.ufrgs.br/ontologies/copi/copi-vocab> ;

    dcterms:title "COPI Enriched: leaf equipment universals and valve family"@en ,
                  "COPI Enriquecida: universais folha de equipamentos e família válvula"@pt-br ;
    dcterms:creator "Nicolau Oyhenard dos Santos" , "Mara Abel" ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:modified "2026-06-15"^^xsd:date ;
    owl:versionInfo "0.1.0-draft (copi-enriched; migrated from copi-core_4 PREVIEW and copi-edit.owl)" ;
    iof-av:maturity iof-ind:Provisional ;

    rdfs:comment """COPI Enriched is the leaf-level module of COPI. It imports copi-vocab
(which imports copi-core) and provides:
  - 6 leaf designed functions (PumpingFunction … VaporizationFunction)
  - 5 leaf equipment universals (Pump, Compressor, ShellAndTubeHeatExchanger,
    GasAbsorber, TemperatureSensor)
  - The Valve family (Valve + ValveBody, FlowControlElement, Seat)
  - 6 provisional genus stubs (Filter, Separator, …) pending enrichment
  - An ABox demo of a TEG gas-dehydration fragment

This module is the target for COPIeditor pull requests (Phase 2 onwards).
Provisional stubs must be fully enriched before iof-av:maturity is promoted."""@en .

#==============================================================================
# LEAF DESIGNED FUNCTIONS  (moved from copi-core_4 PREVIEW)
#==============================================================================

copi:PumpingFunction a owl:Class ;
    rdfs:subClassOf iof-constr:DesignedFunction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom copi:LiquidPressureIncrease ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:allValuesFrom  copi:LiquidPressureIncrease ] ;
    rdfs:label "pumping function"@en , "função de bombeamento"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "The designed function to raise the pressure of an incompressible liquid; realized only in a liquid-pressure-increase operation."@en ,
        "A função projetada de elevar a pressão de um líquido incompressível; realizada apenas em uma operação de aumento de pressão de líquido."@pt-br ;
    iof-av:firstOrderLogicAxiom "PumpingFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ LiquidPressureIncrease(p)) ∧ ∀p(realizedIn(x,p) → LiquidPressureIncrease(p))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'pumping function' then x is a 'designed function' that is 'realized in' some 'liquid pressure increase' and is 'realized in' only 'liquid pressure increase'"@en ,
        "se x é uma 'função de bombeamento' então x é uma 'função projetada' que é 'realizada em' algum 'aumento de pressão de líquido' e é 'realizada em' apenas 'aumento de pressão de líquido'"@pt-br ;
    iof-av:explanatoryNote "The 'some' restriction is essential: without it an unrealized function would vacuously satisfy the 'only' restriction, and the entailed disjointness of PumpingFunction and CompressionFunction would be lost."@en ,
        "A restrição 'algum' é essencial: sem ela, uma função não realizada satisfaria vacuamente a restrição 'apenas', e a disjunção implicada entre PumpingFunction e CompressionFunction se perderia."@pt-br ;
    iof-av:primitiveRationale "OWL gives only necessary conditions (subclass restrictions); the some+only pair plus the disjointness of the leaf operations entails -- but does not OWL-define -- the function."@en ,
        "OWL fornece apenas condições necessárias (restrições de subclasse); o par algum+apenas mais a disjunção das operações folha implica -- mas não OWL-define -- a função."@pt-br ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:CompressionFunction a owl:Class ;
    rdfs:subClassOf iof-constr:DesignedFunction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom copi:GasPressureIncrease ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:allValuesFrom  copi:GasPressureIncrease ] ;
    rdfs:label "compression function"@en , "função de compressão"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "The designed function to raise the pressure of a compressible gas; realized only in a gas-pressure-increase operation."@en ,
        "A função projetada de elevar a pressão de um gás compressível; realizada apenas em uma operação de aumento de pressão de gás."@pt-br ;
    iof-av:firstOrderLogicAxiom "CompressionFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ GasPressureIncrease(p)) ∧ ∀p(realizedIn(x,p) → GasPressureIncrease(p))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'compression function' then x is a 'designed function' that is 'realized in' some 'gas pressure increase' and is 'realized in' only 'gas pressure increase'"@en ,
        "se x é uma 'função de compressão' então x é uma 'função projetada' que é 'realizada em' algum 'aumento de pressão de gás' e é 'realizada em' apenas 'aumento de pressão de gás'"@pt-br ;
    iof-av:explanatoryNote "Entailed disjoint from PumpingFunction because LiquidPressureIncrease and GasPressureIncrease are disjoint and each function is realized in some-and-only its leaf operation."@en ,
        "Implicada disjunta de PumpingFunction porque LiquidPressureIncrease e GasPressureIncrease são disjuntas e cada função é realizada em alguma-e-apenas sua operação folha."@pt-br ;
    iof-av:primitiveRationale "As for PumpingFunction."@en , "Como em PumpingFunction."@pt-br ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:HeatTransferFunction a owl:Class ;
    rdfs:subClassOf iof-constr:DesignedFunction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom copi:HeatTransfer ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:allValuesFrom  copi:HeatTransfer ] ;
    rdfs:label "heat-transfer function"@en , "função de transferência de calor"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "The designed function to transfer thermal energy to or from a process stream; realized only in a heat-transfer operation."@en ,
        "A função projetada de transferir energia térmica de ou para uma corrente de processo; realizada apenas em uma operação de transferência de calor."@pt-br ;
    iof-av:firstOrderLogicAxiom "HeatTransferFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ HeatTransfer(p)) ∧ ∀p(realizedIn(x,p) → HeatTransfer(p))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'heat-transfer function' then x is a 'designed function' that is 'realized in' some 'heat transfer' and is 'realized in' only 'heat transfer'"@en ,
        "se x é uma 'função de transferência de calor' então x é uma 'função projetada' que é 'realizada em' alguma 'transferência de calor' e é 'realizada em' apenas 'transferência de calor'"@pt-br ;
    iof-av:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ,
        "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:GasAbsorptionFunction a owl:Class ;
    rdfs:subClassOf iof-constr:DesignedFunction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom copi:GasAbsorption ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:allValuesFrom  copi:GasAbsorption ] ;
    rdfs:label "gas-absorption function"@en , "função de absorção de gás"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "The designed function to contact a gas with a solvent so a species migrates gas->liquid; realized only in a gas-absorption operation."@en ,
        "A função projetada de contatar um gás com um solvente de modo que uma espécie migre gás->líquido; realizada apenas em uma operação de absorção de gás."@pt-br ;
    iof-av:firstOrderLogicAxiom "GasAbsorptionFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ GasAbsorption(p)) ∧ ∀p(realizedIn(x,p) → GasAbsorption(p))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'gas-absorption function' then x is a 'designed function' that is 'realized in' some 'gas absorption' and is 'realized in' only 'gas absorption'"@en ,
        "se x é uma 'função de absorção de gás' então x é uma 'função projetada' que é 'realizada em' alguma 'absorção de gás' e é 'realizada em' apenas 'absorção de gás'"@pt-br ;
    iof-av:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ,
        "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ;
    iof-av:adaptedFrom "Treybal, Mass-Transfer Operations." ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:TemperatureSensingFunction a owl:Class ;
    rdfs:subClassOf iof-constr:DesignedFunction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom iof-constr:MeasurementProcess ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:allValuesFrom  iof-constr:MeasurementProcess ] ;
    rdfs:label "temperature-sensing function"@en , "função de medição de temperatura"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "The designed function to determine the temperature of an entity of interest; realized only in an iof-constr:MeasurementProcess."@en ,
        "A função projetada de determinar a temperatura de uma entidade de interesse; realizada apenas em um iof-constr:MeasurementProcess."@pt-br ;
    iof-av:firstOrderLogicAxiom "TemperatureSensingFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ MeasurementProcess(p)) ∧ ∀p(realizedIn(x,p) → MeasurementProcess(p))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'temperature-sensing function' then x is a 'designed function' that is 'realized in' some 'measurement process' and is 'realized in' only 'measurement process'"@en ,
        "se x é uma 'função de medição de temperatura' então x é uma 'função projetada' que é 'realizada em' algum 'processo de medição' e é 'realizada em' apenas 'processo de medição'"@pt-br ;
    iof-av:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ,
        "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:VaporizationFunction a owl:Class ;
    rdfs:subClassOf iof-constr:DesignedFunction ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:someValuesFrom copi:Vaporization ] ,
        [ a owl:Restriction ; owl:onProperty obo:BFO_0000054 ; owl:allValuesFrom  copi:Vaporization ] ;
    rdfs:label "vaporization function"@en , "função de vaporização"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "The designed function to convert a liquid into a vapour; realized only in a vaporization operation."@en ,
        "A função projetada de converter um líquido em vapor; realizada apenas em uma operação de vaporização."@pt-br ;
    iof-av:firstOrderLogicAxiom "VaporizationFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ Vaporization(p)) ∧ ∀p(realizedIn(x,p) → Vaporization(p))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'vaporization function' then x is a 'designed function' that is 'realized in' some 'vaporization' and is 'realized in' only 'vaporization'"@en ,
        "se x é uma 'função de vaporização' então x é uma 'função projetada' que é 'realizada em' alguma 'vaporização' e é 'realizada em' apenas 'vaporização'"@pt-br ;
    iof-av:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ,
        "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

#==============================================================================
# LEAF EQUIPMENT UNIVERSALS  (moved from copi-core_4 PREVIEW)
#==============================================================================

copi:Pump a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ,
        [ a owl:Restriction ; owl:onProperty iof-constr:hasFunction ; owl:someValuesFrom copi:PumpingFunction ] ;
    rdfs:label "pump"@en , "bomba"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "A material artifact whose identity-giving designed function is to raise the pressure of an incompressible liquid."@en ,
        "Um artefato material cuja função projetada identificadora é elevar a pressão de um líquido incompressível."@pt-br ;
    iof-av:firstOrderLogicAxiom "Pump(x) → MaterialArtifact(x) ∧ ∃f(PumpingFunction(f) ∧ hasFunction(x,f))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'pump' then x is a 'material artifact' that 'has function' some 'pumping function'"@en ,
        "se x é uma 'bomba' então x é um 'artefato material' que 'tem função' alguma 'função de bombeamento'"@pt-br ;
    iof-av:explanatoryNote "Inferred to be a MomentumTransferDevice from its function alone, with no asserted subclass link."@en ,
        "Inferida como MomentumTransferDevice apenas a partir de sua função, sem vínculo de subclasse asserido."@pt-br ;
    skos:example "centrifugal pump, positive-displacement pump"@en ,
        "bomba centrífuga, bomba de deslocamento positivo"@pt-br ;
    iof-av:primitiveRationale "An OWL-primitive leaf universal: its identity criterion (the borne designed function) is asserted as a necessary condition, not as an OWL definition."@en ,
        "Um universal folha OWL-primitivo: seu critério de identidade (a função projetada portada) é asserido como condição necessária, não como definição OWL."@pt-br ;
    iof-av:adaptedFrom "ISO 14224 Annex A (rotating equipment)." ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:Compressor a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ,
        [ a owl:Restriction ; owl:onProperty iof-constr:hasFunction ; owl:someValuesFrom copi:CompressionFunction ] ;
    rdfs:label "compressor"@en , "compressor"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "A material artifact whose identity-giving designed function is to raise the pressure of a compressible gas."@en ,
        "Um artefato material cuja função projetada identificadora é elevar a pressão de um gás compressível."@pt-br ;
    iof-av:firstOrderLogicAxiom "Compressor(x) → MaterialArtifact(x) ∧ ∃f(CompressionFunction(f) ∧ hasFunction(x,f))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'compressor' then x is a 'material artifact' that 'has function' some 'compression function'"@en ,
        "se x é um 'compressor' então x é um 'artefato material' que 'tem função' alguma 'função de compressão'"@pt-br ;
    iof-av:explanatoryNote "Inferred to be a MomentumTransferDevice from its function alone. Asserted disjoint from Pump."@en ,
        "Inferida como MomentumTransferDevice apenas a partir de sua função. Asserida disjunta de bomba."@pt-br ;
    skos:example "centrifugal compressor, reciprocating compressor"@en ,
        "compressor centrífugo, compressor alternativo"@pt-br ;
    iof-av:primitiveRationale "As for Pump."@en , "Como em Pump."@pt-br ;
    iof-av:adaptedFrom "ISO 14224 Annex A (rotating equipment)." ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:Pump owl:disjointWith copi:Compressor .

copi:ShellAndTubeHeatExchanger a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ,
        [ a owl:Restriction ; owl:onProperty iof-constr:hasFunction ; owl:someValuesFrom copi:HeatTransferFunction ] ;
    rdfs:label "shell-and-tube heat exchanger"@en , "trocador de calor casco-e-tubo"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "A heat-transfer material artifact in which one fluid flows through a bundle of tubes and another through the surrounding shell."@en ,
        "Um artefato material de transferência de calor no qual um fluido escoa por um feixe de tubos e outro pelo casco circundante."@pt-br ;
    iof-av:firstOrderLogicAxiom "ShellAndTubeHeatExchanger(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ hasFunction(x,f))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'shell-and-tube heat exchanger' then x is a 'material artifact' that 'has function' some 'heat-transfer function'"@en ,
        "se x é um 'trocador de calor casco-e-tubo' então x é um 'artefato material' que 'tem função' alguma 'função de transferência de calor'"@pt-br ;
    iof-av:primitiveRationale "OWL-primitive leaf: the borne heat-transfer function is asserted as a necessary condition; the tube/shell construction is descriptive, not the identity criterion."@en ,
        "Folha OWL-primitiva: a função de transferência de calor portada é asserida como condição necessária; a construção tubo/casco é descritiva, não o critério de identidade."@pt-br ;
    iof-av:synonym "STHE"@en , "trocador casco-tubo"@pt-br ;
    iof-av:adaptedFrom "ISO 14224 Annex A (heat exchangers); TEMA." ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:GasAbsorber a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ,
        [ a owl:Restriction ; owl:onProperty iof-constr:hasFunction ; owl:someValuesFrom copi:GasAbsorptionFunction ] ;
    rdfs:label "gas absorber"@en , "absorvedor de gás"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "A mass-transfer artifact that contacts a gas with a solvent so that a species migrates gas->liquid."@en ,
        "Um artefato de transferência de massa que contata um gás com um solvente de modo que uma espécie migre gás->líquido."@pt-br ;
    iof-av:firstOrderLogicAxiom "GasAbsorber(x) → MaterialArtifact(x) ∧ ∃f(GasAbsorptionFunction(f) ∧ hasFunction(x,f))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'gas absorber' then x is a 'material artifact' that 'has function' some 'gas-absorption function'"@en ,
        "se x é um 'absorvedor de gás' então x é um 'artefato material' que 'tem função' alguma 'função de absorção de gás'"@pt-br ;
    iof-av:explanatoryNote "The TEG contactor of an offshore gas-dehydration unit is a gas absorber."@en ,
        "O contactor de TEG de uma unidade de desidratação de gás offshore é um absorvedor de gás."@pt-br ;
    iof-av:synonym "absorption column"@en , "coluna de absorção"@pt-br ;
    iof-av:adaptedFrom "Treybal, Mass-Transfer Operations; TEG contactor." ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:TemperatureSensor a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ,
        [ a owl:Restriction ; owl:onProperty iof-constr:hasFunction ; owl:someValuesFrom copi:TemperatureSensingFunction ] ;
    rdfs:label "temperature sensor"@en , "sensor de temperatura"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "A measurement artifact whose identity-giving designed function is to determine temperature."@en ,
        "Um artefato de medição cuja função projetada identificadora é determinar temperatura."@pt-br ;
    iof-av:firstOrderLogicAxiom "TemperatureSensor(x) → MaterialArtifact(x) ∧ ∃f(TemperatureSensingFunction(f) ∧ hasFunction(x,f))" ;
    iof-av:semiFormalNaturalLanguageAxiom "if x is a 'temperature sensor' then x is a 'material artifact' that 'has function' some 'temperature-sensing function'"@en ,
        "se x é um 'sensor de temperatura' então x é um 'artefato material' que 'tem função' alguma 'função de medição de temperatura'"@pt-br ;
    iof-av:explanatoryNote "Inferred to be a MeasurementInstrument from its function alone."@en ,
        "Inferido como MeasurementInstrument apenas a partir de sua função."@pt-br ;
    iof-av:synonym "temperature transmitter"@en , "transmissor de temperatura"@pt-br ;
    iof-av:primitiveRationale "OWL-primitive leaf: the borne temperature-sensing function is the asserted necessary condition."@en ,
        "Folha OWL-primitiva: a função de medição de temperatura portada é a condição necessária asserida."@pt-br ;
    iof-av:adaptedFrom "ISO 14224 Annex A (instruments)." ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

#==============================================================================
# VALVE FAMILY  (AMB-1: Valve = MaterialArtifact ⊓ ∃hasFunction.FlowControlFunction;
#                no hasComponentPartAtAllTimes on generic Valve; parts only in
#                definitional subtypes such as ControlValve — to be added in Phase 2)
#==============================================================================

copi:Valve a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ,
        [ a owl:Restriction ; owl:onProperty iof-constr:hasFunction ; owl:someValuesFrom copi:FlowControlFunction ] ;
    rdfs:label "valve"@en , "válvula"@pt-br ;
    iof-av:isPrimitive true ;
    iof-av:naturalLanguageDefinition "A valve is a material artifact that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en ,
        "Uma válvula é um artefato material que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido."@pt-br ;
    iof-av:firstOrderLogicAxiom "∀x(Valve(x) → MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))"@en ;
    iof-av:semiFormalNaturalLanguageAxiom "Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams."@en ;
    iof-av:primitiveRationale "Primitive because being a material artifact with a flow control function is insufficient for full valve individuation; the identity criterion is carried by leaf subtypes (ControlValve etc.). Part axioms (ValveBody, Seat, FlowControlElement) are asserted only on definitional subtypes."@en ,
        "Primitiva porque ser um artefato material com uma função de controle de fluxo é insuficiente para individuar totalmente uma válvula; o critério de identidade é portado por subtipos folha (ControlValve etc.). Axiomas de partes (ValveBody, Seat, FlowControlElement) são asseridos apenas em subtipos definicionais."@pt-br ;
    skos:definition "[ISO 15926-4] A <VALVE> is a <FLUID REGULATOR> that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream"@en ;
    skos:definition "[CFIHOS] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en ;
    skos:definition "[OnePetro] Any of several valves: plug, gate, butterfly, needle, etc., used in oil field operations."@en ;
    skos:definition "[POSC Caesar] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:ValveBody a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "valve body"@en , "corpo de válvula"@pt-br ;
    iof-av:naturalLanguageDefinition "The main structural component of a valve that houses the internal trim and connects to the pipeline."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:FlowControlElement a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "flow control element"@en , "elemento de controle de fluxo"@pt-br ;
    iof-av:naturalLanguageDefinition "A valve trim component whose position controls the area of the flow path (e.g. plug, disc, gate, ball)."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:Seat a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "seat"@en , "assento"@pt-br ;
    iof-av:naturalLanguageDefinition "A valve trim component that forms a sealing interface with the flow control element when the valve is closed."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

# Valve disjointness: Pump and Compressor are ruled out (AMB-5: Turbine removed)
copi:Valve owl:disjointWith copi:Pump .
copi:Valve owl:disjointWith copi:Compressor .

#==============================================================================
# PROVISIONAL GENUS STUBS  (AMB-4: pending enrichment; iof-av:maturity = Provisional)
# NOTE — Transformer IRI may need scope review: it enters from COPIeditor (ODR-A1)
# as an electrical artifact. Scope with respect to petroleum plant boundary TBD.
#==============================================================================

copi:Filter a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "filter"@en ;
    iof-av:maturity iof-ind:Provisional ;
    iof-av:naturalLanguageDefinition "A material artifact that separates solid contaminants or particles from a fluid stream by passing the stream through a porous medium or filter element."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:FlowMeasuringElement a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "flow measuring element"@en ;
    iof-av:maturity iof-ind:Provisional ;
    iof-av:naturalLanguageDefinition "A primary flow element inserted in a fluid stream that creates a differential pressure, velocity, or other measurable effect proportional to the volumetric or mass flow rate."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:FlowModificationAccessory a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "flow modification accessory"@en ;
    iof-av:maturity iof-ind:Provisional ;
    iof-av:naturalLanguageDefinition "A material artifact installed in a pipeline to modify flow characteristics — such as flow rate, pressure drop, or velocity profile — without functioning as a primary flow control device."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:Separator a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "separator"@en ;
    iof-av:maturity iof-ind:Provisional ;
    iof-av:naturalLanguageDefinition "A material artifact that separates a mixed-phase or multi-component stream into distinct streams or phases through mechanical means."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:SightGlass a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "sight glass"@en ;
    iof-av:maturity iof-ind:Provisional ;
    iof-av:naturalLanguageDefinition "A material artifact with a transparent section that permits direct visual observation of the fluid level, condition, or flow inside a vessel or pipeline."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

copi:Transformer a owl:Class ;
    rdfs:subClassOf iof-constr:MaterialArtifact ;
    rdfs:label "transformer"@en ;
    iof-av:maturity iof-ind:Provisional ;
    iof-av:naturalLanguageDefinition "A material artifact that transfers electrical energy between circuits at different voltage or current levels through electromagnetic induction."@en ;
    iof-av:explanatoryNote "Scope note: Transformer enters from COPIeditor ODR-A1 as an electrical utility artifact. Its inclusion in a petroleum-plant boundary ontology requires review (ODR-015 phase 2)."@en ;
    rdfs:isDefinedBy <https://www.inf.ufrgs.br/ontologies/copi/copi-enriched> .

#==============================================================================
#  ABox DEMO -- de-identified TEG gas-dehydration fragment
#  EXPECTED HermiT INFERENCES:
#    :contactor -> MassTransferDevice ; :circulationPump -> MomentumTransferDevice ;
#    :leanRichExchanger -> HeatTransferDevice ; :tempSensor -> MeasurementInstrument ;
#    :reboiler -> HeatTransferDevice AND PhaseChangeDevice.
#==============================================================================
copi:contactor         a copi:GasAbsorber .
copi:circulationPump   a copi:Pump .
copi:leanRichExchanger a copi:ShellAndTubeHeatExchanger .
copi:tempSensor        a copi:TemperatureSensor .

copi:reboiler a iof-constr:MaterialArtifact ;
    iof-constr:hasFunction copi:reboiler_heatFn , copi:reboiler_vapFn .
copi:reboiler_heatFn a copi:HeatTransferFunction .
copi:reboiler_vapFn  a copi:VaporizationFunction .
