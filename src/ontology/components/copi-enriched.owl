  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">differential pressure measurement process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição de pressão diferencial</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a differential pressure measuring element senses the pressure difference between two fluid inputs, producing a mechanical deflection or signal proportional to the differential pressure for measurement purposes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000333">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SecondaryWinding"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2559"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis - the physical configuration (being the secondary winding of a power transformer) provides necessary conditions, but sufficient conditions are harder to assert under OWA without risking false positives for specialized or hybrid transformer configurations.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">power transformer secondary winding</rdfs:label>
    <rdfs:label xml:lang="pt-br">enrolamento secundário de transformador de potência</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma FiatObjectPart que é o enrolamento secundário de um transformador de potência e que possui uma SecondaryWindingFunction consistindo em fornecer energia elétrica transformada no nível de tensão de saída.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerSecondaryWinding(x) → FiatObjectPart(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(SecondaryWindingFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;POWER TRANSFORMER SECONDARY WINDING&gt; is a &lt;TRANSFORMER SECONDARY WINDING&gt; intended to be the secondary winding of a power transformer</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerSecondaryWinding SubClassOf FiatObjectPart and (partOf some PowerTransformer) and (hasFunction some SecondaryWindingFunction)</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2847">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
