  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe">
    <skos:definition xml:lang="en">A material artifact that constitutes a proximity probe that measures the axial displacement of a rotating shaft in petroleum production rotating equipment.</skos:definition>
    <rdfs:label xml:lang="en">axial displacement measuring probe</rdfs:label>
    <rdfs:label xml:lang="pt-br">sonda axial de deslocamento de medição</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
