    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3008">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3010"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasMixturePortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="en">gas mixture portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de gás de mistura</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more gases at a defined point in a petroleum production process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3294">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReinforcedColumnShell"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000376">
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um poço perfurado é um local que fornece um caminho perfurado para acesso subsuperficial e está espacialmente contido dentro de um sistema de poço.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</skos:definition>
    <rdfs:label xml:lang="pt-br">poço perfurado</rdfs:label>
    <rdfs:label xml:lang="en">wellbore</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellbore(x) ↔ Site(x) ∧ ∃f(SubsurfaceAccessFunction(f) ∧ hasFunction(x,f)) ∧ ∃w(Well(w) ∧ spatiallyContainedIn(x,w)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellbore is a site that has the function of providing subsurface access and is spatially contained within a well.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b294">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b289"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b295"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2852">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the fluid level within a vessel is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de nível</rdfs:label>
    <rdfs:label xml:lang="en">level measurement and transmission process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressedGasPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="en">compressed gas portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção comprimido de gás</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas that has been compressed to a higher pressure for transport, storage, or processing in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2056">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2054"/>
