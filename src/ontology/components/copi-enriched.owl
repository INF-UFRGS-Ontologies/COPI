    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b291"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GaseousFuelPortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gaseous fuel—such as natural gas—supplied to combustion equipment in a petroleum production installation.</skos:definition>
    <rdfs:label xml:lang="en">gaseous fuel portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção gasoso de combustível</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3121">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TeeBody">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">tee body</rdfs:label>
    <rdfs:label xml:lang="pt-br">corpo de tê</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the body of a pipe tee fitting that divides or combines flow at a branch point in petroleum production piping.</skos:definition>
  </rdf:Description>
