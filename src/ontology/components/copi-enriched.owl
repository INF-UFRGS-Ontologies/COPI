  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2627"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2628"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de suporte e conexão de coluna de produção</rdfs:label>
    <rdfs:label xml:lang="en">tubing support and connection function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes both the mechanical support of tubing strings within a wellbore and their connection to surface or subsurface equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1013">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1011"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical force or motion is transferred from an input component to an output component through direct physical coupling and mechanical linkage.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">force transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transmissão de força</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical force or motion is transferred from an input component to an output component through direct physical coupling and mechanical linkage.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b258">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
