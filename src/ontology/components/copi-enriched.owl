  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b138"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b139"/>
    <rdfs:label xml:lang="pt-br">aquecedor</rdfs:label>
    <rdfs:label xml:lang="en">heater</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Heater(x) ↔ Assembly(x) ∧ ∃f (HeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b40">
