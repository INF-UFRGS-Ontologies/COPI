  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1910">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicMechanicalConverter">
    <skos:definition xml:lang="en">A material artifact that constitutes an assembly that converts hydraulic pressure and flow into mechanical force or motion in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">conversor hidráulico mecânico</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic mechanical converter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/OutputMechanism">
    <rdfs:label xml:lang="en">output mechanism</rdfs:label>
    <rdfs:label xml:lang="pt-br">mecanismo de saída</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the mechanical assembly through which the output of petroleum production equipment is delivered to the next element in the system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpInlet">
    <skos:definition xml:lang="en">A material artifact that constitutes the suction inlet port through which fluid is drawn into a hydraulic pump in petroleum production hydraulic systems.</skos:definition>
    <rdfs:label xml:lang="en">hydraulic pump inlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">entrada hidráulico de bomba</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">braided conductor</rdfs:label>
    <rdfs:label xml:lang="pt-br">condutor de trançado</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an electrical conductor composed of braided or stranded wires providing flexibility and mechanical strength in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b952">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionIgnitionSystem"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1274">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000269">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de tubos aletados é um trocador de calor que possui tubos aletados como mecanismo primário de aumento da superfície de transferência de calor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A finned tube heat exchanger is a heat exchanger that has finned tubes as the primary heat transfer surface enhancement mechanism.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">trocador de calor de tubos aletados</rdfs:label>
    <rdfs:label xml:lang="en">finned tube heat exchanger</rdfs:label>
    <skos:definition xml:lang="en">A finned tube heat exchanger is a heat exchanger that has finned tubes as the primary heat transfer surface enhancement mechanism.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While finned tubes are the defining structural feature, making sufficient conditions (equivalence) under Open World Assumption could lead to false positives where any assembly containing finned tubes would be classified as this specific heat exchanger type, including complex multi-function equipment or specialized hybrid systems.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FinnedTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃y(FinnedTube(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1304"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1306"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1305"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1307"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every finned tube heat exchanger is a heat exchanger that has finned tubes as component parts at all times</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador é um vaso que possui uma FunçãoDeSeparação - projetado para separar diferentes substâncias ou fases de uma corrente fluida mista em correntes de saída distintas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Separator(x) ↔ (Vessel(x) ∧ ∃f (SeparationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">separador</rdfs:label>
    <rdfs:label xml:lang="en">separator</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every separator is a vessel that has the function of separating mixed fluid streams into distinct phases or components.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2835"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1997">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115">
    <rdfs:label xml:lang="en">fan</rdfs:label>
    <rdfs:label xml:lang="pt-br">ventilador</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every fan is an assembly that bears a gas movement function, and every assembly that bears a gas movement function is a fan.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Fan(x) ↔ (Assembly(x) ∧ ∃f(GasMovementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1235"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ventilador é um conjunto que possui uma função de movimentação de gás para fornecer ou exaurir volumes de vapor ou gás com baixa pressão diferencial.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowGuide">
    <skos:definition xml:lang="en">A material artifact that constitutes a structural element within petroleum production equipment that directs fluid flow along a desired path.</skos:definition>
    <rdfs:label xml:lang="en">flow guide</rdfs:label>
    <rdfs:label xml:lang="pt-br">guia de fluxo</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2719"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b906"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2163"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2952"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2953"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1125"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2162"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b905"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2720"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1848"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b45"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1847"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1126"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b44"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2454"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2453"/>
    <rdfs:label xml:lang="pt-br">função de atuação</rdfs:label>
    <rdfs:label xml:lang="en">actuation function</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HighPressureSignal">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdfs:label xml:lang="en">high pressure signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal alto de pressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An information content entity constituting an electrical or pneumatic signal representing a high-pressure condition in a petroleum production process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1823">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000286">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas turbine is a turbine that has component parts compressor and combustion chamber at all times, and participates in air compression process and fuel combustion process.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma turbina a gás é uma turbina que possui um compressor e câmara de combustão integrados, projetada para comprimir ar ambiente, misturá-lo com combustível para combustão, e expandir os gases quentes resultantes através de uma seção de turbina para gerar energia mecânica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GasTurbine(x) ↔ Turbine(x) ∧ ∃c,h(Compressor(c) ∧ CombustionChamber(h) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃p1,p2(AirCompressionProcess(p1) ∧ FuelCombustionProcess(p2) ∧ participatesIn(x,p1) ∧ participatesIn(x,p2)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1629"/>
    <rdfs:label xml:lang="en">gas turbine</rdfs:label>
    <rdfs:label xml:lang="pt-br">turbina a gás</rdfs:label>
    <skos:definition xml:lang="en">A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101">
    <rdfs:label xml:lang="pt-br">compressor centrífugo</rdfs:label>
    <rdfs:label xml:lang="en">centrifugal compressor</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um compressor centrífugo é um compressor que usa um ou mais impelidores centrífugos para acelerar o gás através de fluxo radial e gerar aumento de pressão por ação centrífuga.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b419"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b418"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because under OWA, any equipment with a centrifugal impeller could be incorrectly classified as a standard centrifugal compressor, including specialized hybrid equipment or multi-stage systems that contain centrifugal elements but should not be forced into this maintenance category. Domain expert validation needed to confirm structural differentia is sufficient.</iof-av:primitiveRationale>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal compressor is a compressor that has component part at all times some centrifugal impeller and participates in some radial flow pattern.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CentrifugalCompressor(x) → Compressor(x) ∧ ∃i(CentrifugalImpeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃p(RadialFlowPattern(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2659">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CylindricalChamber"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b771">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasOutlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314">
    <skos:definition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every mixer is an assembly that bears a mixing function, and every assembly that bears a mixing function is a mixer.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2198"/>
    <rdfs:label xml:lang="pt-br">misturador</rdfs:label>
    <rdfs:label xml:lang="en">mixer</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Mixer(x) ↔ (Assembly(x) ∧ ∃f (MixingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um misturador é um conjunto que tem a função projetada de misturar ou combinar dois ou mais ingredientes fluidos em uma mistura homogênea.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1339">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1340"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1335"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132">
    <skos:definition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LimitSwitch(x) ↔ Instrument(x) ∧ ∃f(PositionLimitDetectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MechanicalMotion(p) ∧ hasInput(x,p)) ∧ ∃s(ElectricalSignal(s) ∧ hasOutput(x,s)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2117"/>
    <rdfs:label xml:lang="en">limit switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">limit switch</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every limit switch is an instrument that has the function to detect position limits and is mechanically operated by object motion to generate electrical switching signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um limit switch é um instrumento que possui uma função de detecção de limite de posição, acionado mecanicamente pelo movimento de objetos para fornecer sinais de chaveamento elétrico quando limites de posição predeterminados são atingidos.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000355">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2990"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2991"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma StationaryMachineComponentFunction e que é o componente estrutural estacionário dentro de máquinas rotativas, fornecendo alojamento e estabilidade posicional para elementos ativos como bobinas, palhetas ou vedações.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma StationaryMachineComponentFunction e</rdfs:label>
    <rdfs:label xml:lang="en">stator</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Stator is a MaterialArtifact that bears a StationaryMachineComponentFunction and is part of some RotatingMachine</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on structural positioning within rotating machinery. Under OWA, any artifact described as stationary within a rotating machine context could be classified as a stator, but this may include specialized hybrid components, mounting structures, or custom configurations that should not be automatically asserted into the standard stator maintenance category. The structural differentia (stationary positioning) is necessary but making it sufficient requires domain expert validation.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Stator(x) → MaterialArtifact(x) ∧ ∃f(StationaryMachineComponentFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(RotatingMachine(m) ∧ partOf(x,m)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b916">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DiaphragmChamber"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1707"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1706"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1705"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1708"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1709"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Gearbox(x) → Assembly(x) ∧ ∃c,g1,g2,i,o (GearCasing(c) ∧ GearWheel(g1) ∧ GearWheel(g2) ∧ g1≠g2 ∧ InputShaft(i) ∧ OutputShaft(o) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,g1) ∧ hasComponentPartAtAllTimes(x,g2) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</skos:definition>
    <rdfs:label xml:lang="en">gearbox</rdfs:label>
    <rdfs:label xml:lang="pt-br">caixa de engrenagens</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because the structural differentia (specific gear casing and gear-wheel arrangement) is complex and making it sufficient under Open World Assumption could lead to false positives - specialized equipment containing gear mechanisms might be incorrectly classified as standard gearboxes.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gearbox is an assembly that has component parts including a gear casing, at least two gear-wheels, an input shaft, and an output shaft, and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma caixa de engrenagens é um conjunto que consiste em um invólucro de engrenagens contendo um arranjo de duas ou mais rodas de engrenagem que transmitem movimento rotativo de um eixo de entrada para um eixo de saída.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b128">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000229">
    <rdfs:label xml:lang="en">chromatograph</rdfs:label>
    <rdfs:label xml:lang="pt-br">cromatógrafo</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A chromatograph is a process analyzer that bears a chromatographic analysis function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cromatógrafo é um analisador de processo que possui uma função de análise cromatográfica.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b525"/>
    <skos:definition xml:lang="en">A chromatograph is a process analyzer that bears a chromatographic analysis function.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every chromatograph is a process analyzer that has the function of chromatographic analysis.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Chromatograph(x) ↔ ProcessAnalyzer(x) ∧ ∃f (ChromatographicAnalysisFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteFeedSystem">
    <rdfs:label xml:lang="en">waste feed system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de resíduo de alimentação</rdfs:label>
    <skos:definition xml:lang="en">An assembly of storage, metering, and feed components that delivers waste material at a controlled rate to a combustion or treatment unit.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">information display process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de exibição de informação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction">
    <rdfs:label xml:lang="pt-br">função de detecção</rdfs:label>
    <rdfs:label xml:lang="en">detection function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b867"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b868"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the sensing and identification of the presence, concentration, or state of a physical or chemical entity.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1470">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContaminatedSurface">
    <skos:definition xml:lang="en">A material artifact that constitutes a surface bearing scale, deposits, or contaminants that are to be removed by a cleaning process in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">superfície contaminado</rdfs:label>
    <rdfs:label xml:lang="en">contaminated surface</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess">
    <rdfs:label xml:lang="pt-br">processo de controle de superfície do poço</rdfs:label>
    <rdfs:label xml:lang="en">well surface control process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which wellbore conditions are controlled from surface to manage production flow, monitor well integrity, and enable intervention operations.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PneumaticMotorFunction">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2467"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2468"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pneumatic motor function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de acionamento pneumático</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of compressed-gas energy into rotational mechanical motion.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContainmentProcess">
    <skos:definition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de contenção</rdfs:label>
    <rdfs:label xml:lang="en">containment process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b281">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b945">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3132">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasOutlet"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1380">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlareStack"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1702">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135">
    <rdfs:label xml:lang="en">on off control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle liga-desliga</rdfs:label>
    <skos:definition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every on-off control valve is a control valve that has a BinaryFlowControlFunction and has component part a BinaryPositioner.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2255"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(OnOffControlValve(x) ↔ ControlValve(x) ∧ ∃f(BinaryFlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle liga-desliga é uma válvula de controle que possui uma função de controle de fluxo binária, tendo apenas duas posições definidas: totalmente aberta e totalmente fechada.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CartridgeHousing">
    <skos:definition xml:lang="en">A material artifact that constitutes the housing that supports and locates a replaceable filter cartridge within a filtration unit in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">carcaça de cartucho</rdfs:label>
    <rdfs:label xml:lang="en">cartridge housing</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um disjuntor é um equipamento elétrico que possui uma função de proteção de circuito e participa em processos de interrupção de corrente em intervalos regulares.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um disjuntor é um dispositivo de chaveamento elétrico que possui uma função de interrupção de corrente elétrica e participa regularmente em processos que interrompem com segurança a corrente elétrica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">circuit breaker</rdfs:label>
    <rdfs:label xml:lang="pt-br">disjuntor</rdfs:label>
    <skos:definition xml:lang="en">A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals.</skos:definition>
    <skos:definition xml:lang="en">A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CircuitBreaker(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(CurrentInterruptionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CircuitBreaker(x) ↔ ElectricalSwitchingDevice(x) ∧ ∃f (ElectricalCurrentInterruptionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p (RegularInterruptionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b552"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b544"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every circuit breaker is an electrical switching device that has the function to interrupt electrical current and participates in regular current interruption processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every circuit-breaker is an electrical equipment that has the function to protect circuits and participates in the process of interrupting electrical current at regular intervals.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b853">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DisplayOrOutputDevice"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3257">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144">
    <rdfs:label xml:lang="pt-br">transmissor de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure transmitter</rdfs:label>
    <skos:definition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2605"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure transmitter is a transmitter that has the function to transmit pressure measurement signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(PressureTransmissionFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão é um transmissor que converte medições de pressão em sinais de saída padronizados para transmissão a sistemas de controle ou monitoramento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3130">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3136"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1587">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Panel">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">painel</rdfs:label>
    <rdfs:label xml:lang="en">panel</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a flat structural panel that provides a mounting surface for instrumentation, controls, or electrical equipment in a petroleum production installation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000275">
    <rdfs:label xml:lang="en">flare tip</rdfs:label>
    <rdfs:label xml:lang="pt-br">queimador de flare</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador de flare é um queimador que especificamente queima gás residual emitido de processos industriais e descarrega os produtos de combustão na atmosfera.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1403"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlareTip(x) ↔ Burner(x) ∧ ∃f(WasteGasDisposalFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare tip is a burner that has the function to dispose of waste gas from processes by burning it into the atmosphere</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b573">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b571"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionFunction">
    <rdfs:label xml:lang="en">fluid distribution function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de distribuição de fluido</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the splitting and delivery of a fluid stream to multiple downstream points in defined proportions.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1760"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2155"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2156"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1761"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
