  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContainmentProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3419"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3374"/>
