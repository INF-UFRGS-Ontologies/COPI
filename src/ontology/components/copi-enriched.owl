  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (BlowDownValve(x) ↔ Valve(x) ∧ ∃f (RapidDepressurizationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de blow down é uma válvula que possui uma função projetada para despressurização rápida de sistemas de alta pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BLOW DOWN VALVE is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; that can be used for rapid depressurizing of a high pressure system</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A valve that can be used for rapid depressurizing of a high pressure system.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every blow down valve is a valve that has the function of rapid depressurization.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb263"/>
    <rdfs:label xml:lang="pt-br">válvula de blow down</rdfs:label>
    <rdfs:label xml:lang="en">blow down valve</rdfs:label>
  </rdf:Description>
