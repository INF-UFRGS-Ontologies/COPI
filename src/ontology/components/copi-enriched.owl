    <rdfs:label xml:lang="en">tubing support process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which downhole tubing strings are mechanically suspended and supported within a wellbore.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
