    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000279">
    <skos:definition xml:lang="en">[CFIHOS] A functional switch that is intended to give a signal when the flow have reached a pre-set value.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOW SWITCH&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;PROCESS SWITCH&gt; and a &lt;FLOW MEASURING INSTRUMENT&gt;, that is specially and exclusively designed for &lt;SWITCHING&gt; at a given &lt;FLOW RATE&gt;</skos:definition>
    <rdfs:label xml:lang="pt-br">interruptor de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow switch</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de fluxo é um instrumento que possui uma função de comutação de fluxo para automaticamente abrir ou fechar circuitos elétricos quando a taxa de fluxo de fluido atinge valores de limiar predeterminados.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow switch is an instrument that bears a flow switching function to automatically open or close electrical circuits when fluid flow rate reaches predetermined threshold values.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1549"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowSwitch(x) ↔ Instrument(x) ∧ ∃f(FlowSwitchingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow switch is an instrument that has the function to switch electrical circuits based on flow rate detection at preset thresholds.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2203">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2460">
    <rdf:first rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2457"/>
    <rdf:rest rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2461"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000265">
    <skos:definition xml:lang="en">[OnePetro] A device in a length of pipe that allows some pipe length expansion or contraction.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] Flexible joint between two pipes to receive expansion from the pipes.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;EXPANSION JOINT&gt; is an &lt;ARTEFACT&gt; and a &lt;JOINT&gt; that makes allowance for thermal expansion of the parts joined without distortion</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device or completion component designed to enable relative movement between two fixed assemblies in the event of thermal expansion or contraction.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma junta de expansão é um artefato material que possui a função projetada de acomodar expansão e contração térmica entre componentes conectados através de flexibilidade inerente, mantendo a integridade estrutural.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every expansion joint is a material artifact that bears a thermal expansion accommodation function and has a flexibility function, and every material artifact that bears a thermal expansion accommodation function and has a flexibility function is an expansion joint.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">expansion joint</rdfs:label>
    <rdfs:label xml:lang="pt-br">junta de expansão</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1251"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ExpansionJoint(x) ↔ (MaterialArtifact(x) ∧ ∃f(ThermalExpansionAccommodationFunction(f) ∧ bearerOf(x,f)) ∧ ∃g(FlexibilityFunction(g) ∧ hasFunction(x,g))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1788">
    <rdf:rest rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1789"/>
    <rdf:first rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1783"/>
  </rdf:Description>
