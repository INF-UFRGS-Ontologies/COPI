  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000309">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(LevelSwitch(x) ↔ (Instrument(x) ∧ ∃f(LevelSwitchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(DiscreteElectricalSignal(s) ∧ hasOutput(x,s))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">interruptor de nível</rdfs:label>
    <rdfs:label xml:lang="en">level switch</rdfs:label>
    <skos:definition xml:lang="en">[POSC Caesar] A functional switch that is intended to give an on/off signal when particulate material or fluid level have reached a preset value.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LEVEL SWITCH&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;LEVEL MEASURING INSTRUMENT&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A functional switch that is intended to give an on/off signal when particulate material or fluid level have reached a pre-set value.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level switch is an instrument that bears a LevelSwitchingFunction, combining level detection with switching capability to provide discrete on/off electrical signals when fluid or particulate material levels reach preset values.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de nível é um instrumento que possui uma Função de Comutação de Nível, combinando detecção de nível com capacidade de comutação para fornecer sinais elétricos discretos ligado/desligado quando níveis de fluidos ou materiais particulados atingem valores predefinidos.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2129"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level switch is an instrument that has the function of level switching and outputs discrete electrical signals based on preset level conditions.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">flash vaporization process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de vaporização flash</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000354">
    <skos:definition xml:lang="en">[SLB Glossary] A viscous fluid used to aid removal of drilling fluids before a primary cementing operation.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is intended to keep other physical objects at a predefined distance and hence having a spacer function.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SPACER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;SPACING&gt;</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] In the context of pumping, a spacer is a fluid used between two fluids to prevent contamination.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Spacer(x) ↔ MaterialArtifact(x) ∧ ∃f(SpacingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b3028"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">espaçador</rdfs:label>
    <rdfs:label xml:lang="en">spacer</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um espaçador é um artefato material que tem a função de manter separação espacial ou distância entre objetos físicos ou fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A spacer is a material artifact that has the function of maintaining spatial separation or distance between physical objects or fluids.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every spacer is a material artifact that bears a spacing function</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
