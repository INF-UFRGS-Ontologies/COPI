  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2528">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical power from one shaft to another through direct mechanical coupling or engagement.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical rotational energy from a driving mechanism to driven components, enabling the transfer of torque and rotational motion through a mechanical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from a prime mover through rotational motion or to generate energy when acting as a driven element.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from one mechanical component to another through rotational or linear motion.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical energy from an external energy source through rotational motion to downstream mechanical components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transfer mechanical energy from a prime mover to one or more driven machines, maintaining rotational motion while potentially modifying torque and speed characteristics.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2886"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2647"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1082"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2887"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2274"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1702"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2648"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1701"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1985"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1083"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1696"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2275"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2851"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1697"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1984"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2852"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical power from one shaft to another through direct mechanical coupling or engagement.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical rotational energy from a driving mechanism to driven components, enabling the transfer of torque and rotational motion through a mechanical system.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from a prime mover through rotational motion or to generate energy when acting as a driven element.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from one mechanical component to another through rotational or linear motion.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical energy from an external energy source through rotational motion to downstream mechanical components.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transfer mechanical energy from a prime mover to one or more driven machines, maintaining rotational motion while potentially modifying torque and speed characteristics.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de transmissão de potência</rdfs:label>
    <rdfs:label xml:lang="en">power transmission function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267">
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on material composition (filter media) and mereological relationship (component of assembly). Under OWA, asserting equivalence could lead to unintended classification of any artifact made from filter media as a filter element, including specialized or hybrid components that contain filter media but serve different primary functions.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">elemento filtrante</rdfs:label>
    <rdfs:label xml:lang="en">filter element</rdfs:label>
    <skos:definition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FilterElement(x) → Filter(x) ∧ ∃m(FilterMedia(m) ∧ madeFrom(x,m)) ∧ ∃a(FilterAssembly(a) ∧ componentPartOf(x,a)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1284"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Filtro que é feito de meio filtrante e que é uma parte componente de um conjunto de filtro.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">FilterElement SubClassOf Filter and (madeFrom some FilterMedia) and (componentPartOf some FilterAssembly)</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215">
    <rdfs:label xml:lang="en">bearing</rdfs:label>
    <rdfs:label xml:lang="pt-br">mancal</rdfs:label>
    <skos:definition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b211"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um mancal é um artefato material que é projetado para suportar e localizar elementos mecânicos móveis ou estáticos enquanto reduz o atrito na conexão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bearing is a material artifact that bears a support function and participates in friction reduction processes</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Bearing(x) ↔ MaterialArtifact(x) ∧ ∃f(SupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(FrictionReductionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000271">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame arrestor is a safety device that has the function of arresting flames and processes gaseous portions while preventing flame propagation.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um arrestador de chama é um dispositivo de segurança que possui uma função de arrestar chama para prevenir que chamas entrem em um sistema através de uma abertura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1334"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">arrestador de chama</rdfs:label>
    <rdfs:label xml:lang="en">flame arrestor</rdfs:label>
    <skos:definition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlameArrestor(x) ↔ SafetyDevice(x) ∧ ∃f(FlameArrestFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1438">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1433"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1439"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de extração de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy extraction process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which useful work or heat is recovered from a process stream, pressure differential, or thermal source in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SuctionPort">
    <skos:definition xml:lang="en">A material artifact that constitutes the port at which fluid enters the suction side of a pump, compressor, or ejector in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">bocal de sucção</rdfs:label>
    <rdfs:label xml:lang="en">suction port</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1766">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPathway"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction">
    <rdfs:label xml:lang="pt-br">função de desidratação</rdfs:label>
    <rdfs:label xml:lang="en">dehydration function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b803"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b804"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of water from a fluid stream by adsorption, absorption, or distillation to meet specification limits.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1749">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1750"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b772">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidInlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149">
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical configuration (self-operating mechanism). Under OWA, any valve with an internal operating mechanism might be classified as self-operating even if it has additional external actuators or specialized applications. Domain expert validation needed to confirm structural differentia is sufficient.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SelfOperatingValve(x) → Valve(x) ∧ ∃m(SelfOperatingMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(EnergyIndependentOperationCapability(c) ∧ bearerOf(x,c)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">válvula auto-operante</rdfs:label>
    <rdfs:label xml:lang="en">self operating valve</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula auto-operante é uma válvula que inclui um mecanismo interno de operação (como mola, gravidade, pressão do fluido ou contrapeso) e não depende de uma fonte externa de energia para seu acionamento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every self-operating valve is a valve that has a self-operating mechanism as component part at all times and bears the capability of energy-independent operation.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2830"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2829"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">bottom hole drilling process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de perfuração de fundo de poço</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which subsurface rock at the bottom of a wellbore is cut and disintegrated by a drill bit to advance the drill hole.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000361">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ThreePhaseSeparator(x) ↔ (Separator(x) ∧ ∃f (ThreePhaseSeparationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">three phase separator</rdfs:label>
    <rdfs:label xml:lang="pt-br">separador trifásico</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador trifásico é um separador que possui uma função de separação trifásica para separar fluidos de poço em fases gasosa, oleosa e aquosa.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3130"/>
    <skos:definition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every three-phase separator is a separator that has the function of separating fluid into gas, oil, and water phases, and has gas outlet, oil outlet, and water outlet as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigFromPipeline">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pig from pipeline</rdfs:label>
    <rdfs:label xml:lang="pt-br">pipeline de pig de proveniente de</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a pipeline pig that has been retrieved from a pipeline after completing its pass and is now held in the pig receiver.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilterHousing">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">filter housing</rdfs:label>
    <rdfs:label xml:lang="pt-br">carcaça de filtro</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the outer casing that contains the filter medium and directs flow through it in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionFunction">
    <rdfs:label xml:lang="pt-br">função de indicação e transmissão de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure indicating and transmission function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of process pressure and both its local display and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2574"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2575"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrumBody">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VesselBody"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the cylindrical pressure-retaining shell of a drum vessel in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">drum body</rdfs:label>
    <rdfs:label xml:lang="pt-br">corpo de tambor</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DiscreteElectricalSignal">
    <skos:definition xml:lang="en">An information content entity constituting an electrical signal that can assume only two defined states—on or off—used in control and safety systems of petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdfs:label xml:lang="en">discrete electrical signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal discreto elétrico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266">
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">cartucho de filtro</rdfs:label>
    <rdfs:label xml:lang="en">filter cartridge</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1276"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1275"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1274"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b121">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
