  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000237">
    <skos:definition xml:lang="en">[POSC Caesar] A mass flow meter that uses the Coriolis principle to measure a mass flow rate through the meter.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A mass flow meter that uses the Coriolis principle to measure a mass flow rate through the meter.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b732"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b734"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b733"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b735"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b736"/>
    <rdfs:label xml:lang="pt-br">medidor de vazão Coriolis</rdfs:label>
    <rdfs:label xml:lang="en">coriolis mass flow meter</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão que utiliza o princípio de Coriolis através de tubos de fluxo oscilantes especializados para medir diretamente a vazão mássica de fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CoriolisMassFlowMeter(x) → FlowMeter(x) ∧ ∃y(CoriolisFlowTube(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CoriolisPrinciple(z) ∧ utilizesPhysicalPrinciple(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under the Open World Assumption, defining sufficient conditions based on Coriolis principle usage could lead to false positives where other devices using Coriolis forces (like gyroscopes or accelerometers) might be incorrectly classified as flow meters. The structural differentia provides necessary conditions that can be validated by domain experts.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coriolis mass flow meter is a flow meter that has component part at all times some Coriolis flow tube and utilizes the Coriolis principle.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSensor">
