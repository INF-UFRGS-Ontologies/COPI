  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b66">
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b67"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314"/>
