  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000350">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SILENCER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;SILENCING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to reduce a noise level.</skos:definition>
    <rdfs:label xml:lang="pt-br">silenciador</rdfs:label>
    <rdfs:label xml:lang="en">silencer</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A silencer is an assembly that bears the designed function of reducing noise levels through acoustic treatment of fluid streams.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um silenciador é uma montagem que possui a função projetada de reduzir níveis de ruído através do tratamento acústico de fluxos de fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Silencer(x) ↔ Assembly(x) ∧ ∃f(NoiseSilencingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every silencer is an assembly that has the function to silence noise, and every assembly that has the function to silence noise is a silencer.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2932"/>
  </rdf:Description>
