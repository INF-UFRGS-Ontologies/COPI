  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalMotion">
    <rdfs:label xml:lang="pt-br">movimento mecânico</rdfs:label>
    <rdfs:label xml:lang="en">mechanical motion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <skos:definition xml:lang="en">A process in which the movement of a mechanical component along a defined path in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceMeasurementProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the phase sequence of an alternating-current electrical supply is measured and verified by petroleum production instrumentation.</skos:definition>
    <rdfs:label xml:lang="en">phase sequence measurement process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição de sequência de fases</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
