    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReinforcedColumnShell"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">[CFIHOS] A container intended for storage and/or processing of fluids.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VESSEL&gt; is a &lt;FLUID CONTAINER&gt;, intended for storage and/or processing of fluids</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] A container intended for storage and/or processing of fluids or solids.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">vessel</rdfs:label>
    <rdfs:label xml:lang="pt-br">vaso</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3354"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel is an assembly that bears a containment function and has a vessel shell and vessel head as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Vessel(x) ↔ Assembly(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(VesselShell(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃h(VesselHead(h) ∧ hasComponentPartAtAllTimes(x,h)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1647">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
