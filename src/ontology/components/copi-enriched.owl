  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation of a liquid mixture into fractions of differing volatilities by successive vaporisation and condensation.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1029"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3288"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3289"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1030"/>
    <rdfs:label xml:lang="en">distillation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de destilação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2989">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RemovedMaterial">
    <skos:definition xml:lang="en">A material artifact that constitutes material—scale, deposits, or cuttings—removed from a surface or stream by a mechanical cleaning process in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">removed material</rdfs:label>
    <rdfs:label xml:lang="pt-br">material de removido</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b235">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b239"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1406">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/IgnitionSystem"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess">
    <rdfs:label xml:lang="en">degassing process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de degaseificação</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which dissolved or entrained gases are removed from a liquid to reduce their concentration below a specified level.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess">
    <rdfs:label xml:lang="pt-br">processo de transdução força-elétrica</rdfs:label>
    <rdfs:label xml:lang="en">force to electrical transduction process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a mechanical force or pressure is converted into a proportional electrical signal by petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1029">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
