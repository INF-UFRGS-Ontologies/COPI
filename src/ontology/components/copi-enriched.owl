    <rdfs:label xml:lang="en">temperature sensor protection process</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3165"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3174"/>
