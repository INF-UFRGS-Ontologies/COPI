  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureElement">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature element is a detecting element that has the function to sense temperature</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de temperatura é um instrumento que possui uma função de sensoreamento de temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature element is an instrument that bears a temperature sensing function.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">elemento de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature element</rdfs:label>
    <skos:definition xml:lang="en">[CFIHOS] A detecting element intended to sense temperature.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A detecting element intended to sense temperature.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3112"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureElement(x) ↔ DetectingElement(x) ∧ ∃f(TemperatureSensingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Tube">
    <rdfs:label xml:lang="pt-br">tubo</rdfs:label>
    <rdfs:label xml:lang="en">tube</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb682">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ComparisonElement"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328">
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2516"/>
    <skos:definition xml:lang="en">[POSC Caesar] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PNEUMATIC MOTOR&gt; is an &lt;AIR MOTOR&gt; that is driven by compressed gas (typically air)</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic motor is a motor that bears a PneumaticMotorFunction.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor pneumático é um motor que converte energia de gás comprimido em energia mecânica rotacional.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PneumaticMotor(x) ↔ Motor(x) ∧ ∃f(PneumaticMotorFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">pneumatic motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor pneumático</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb301">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb296"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2343">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb858">
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb859"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000205">
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ABSOLUTE PRESSURE TRANSMITTER&gt; is a &lt;PRESSURE TRANSMITTER&gt; and an &lt;ABSOLUTE PRESSURE MEASURING INSTRUMENT&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A pressure transmitter where pressure is applied to one side of the sensor while the other side has a vacuum chamber.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb7"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb5"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb6"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber as a component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AbsolutePressureTransmitter(x) → PressureTransmitter(x) ∧ ∃y (VacuumReferenceeChamber(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão absoluta é um transmissor de pressão que possui uma câmara de referência de vácuo de um lado do sensor de pressão enquanto o outro lado recebe a pressão do processo.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">transmissor de pressão absoluta</rdfs:label>
    <rdfs:label xml:lang="en">absolute pressure transmitter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on vacuum reference chamber configuration. Under Open World Assumption, defining sufficient conditions could lead to unintended classification of complex instruments that contain vacuum chambers but serve different primary functions. The structural differentia is necessary but making it sufficient requires domain expert validation.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidInlet">
    <rdfs:label xml:lang="en">liquid inlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">entrada líquido</rdfs:label>
