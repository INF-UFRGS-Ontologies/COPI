    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b389"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1664">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
