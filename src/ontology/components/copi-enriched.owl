  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSensor">
    <skos:definition xml:lang="en">A material artifact that constitutes a sensing element that measures the pressure difference between two process points in petroleum production instrumentation.</skos:definition>
    <rdfs:label xml:lang="en">differential pressure sensor</rdfs:label>
    <rdfs:label xml:lang="pt-br">sensor de diferencial de pressão</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2706">
