  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidOpening">
    <rdfs:label xml:lang="pt-br">abertura de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid opening</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an opening in the body of petroleum production equipment through which fluid enters or exits.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a standardised signal representing a measured pressure value is transmitted to a remote control or monitoring system.</skos:definition>
    <rdfs:label xml:lang="en">pressure transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transmissão de pressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
