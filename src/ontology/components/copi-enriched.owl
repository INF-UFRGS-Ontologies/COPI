    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1276"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1313"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1275"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1298"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1958"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1308"/>
    <rdfs:label xml:lang="en">filtration function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de filtração</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FiltrationProcess and that consists in selectively retaining particles, contaminants, or unwanted substances from a fluid stream while allowing the clean fluid to pass through.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
