    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3208">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConversionElement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteFeedSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="en">waste feed system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de resíduo de alimentação</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000301">
    <skos:definition xml:lang="en">[SLB Glossary] An item of solids-control equipment consisting of an inverted cone, the mud being fed tangentially into the upper (larger diameter) part.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HYDROCYCLONE&gt; is a &lt;CYCLONE&gt; and a &lt;CYLINDRICAL VESSEL&gt;, intended to separate a fluid by hydraulic forces</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A cone shaped device for separating fluids and the solids dispersed in fluids.</skos:definition>
    <rdfs:label xml:lang="en">hydrocyclone</rdfs:label>
    <rdfs:label xml:lang="pt-br">hidrociclone</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hydrocyclone is a separator that separates fluid mixtures using centrifugal forces generated by tangential flow through a conical chamber.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um hidrociclone é um separador que separa misturas de fluidos usando forças centrífugas geradas por fluxo tangencial através de uma câmara cônica.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydrocyclone is a separator that has a conical section as component part at all times and participates in centrifugal separation processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1935"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Hydrocyclone(x) ↔ Separator(x) ∧ ∃c(ConicalSection(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃p(CentrifugalSeparationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1874">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1871"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionFunction">
    <rdfs:label xml:lang="en">drilling fluid conduction function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de condução de fluido de perfuração</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb229"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb230"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000330">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de posição é um transmissor que mede posição ou deslocamento e o converte em um sinal de saída padronizado.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A position transmitter is a transmitter that measures position or displacement and converts it to a standardized output signal.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2542"/>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a position detector.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;POSITION TRANSMITTER&gt;is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;POSITION MEASURING INSTRUMENT&gt;</skos:definition>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'ZT'. First letter 'Z': Position, Dimension. Succeeding letters: 'T' = Transmit.</skos:definition>
    <rdfs:label xml:lang="en">position transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de posição</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PositionTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PositionTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PositionSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every position transmitter is a transmitter that has the function of position transmission and receives position or displacement signals as input.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000249">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb938"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb936"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb937"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIAPHRAGM PUMP&gt; is a &lt;RECIPROCATING PUMP&gt; intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere; flow rate is achieved through reciprocatory motion of the diaphragm</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A reciprocating pump intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diaphragm pump is a reciprocating pump that uses flexible diaphragms to displace liquid and seal the pumped fluid from atmospheric leakage.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de diafragma é uma bomba alternativa que usa diafragmas flexíveis para deslocar líquido e selar o fluido bombeado contra vazamento atmosférico.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diaphragm pump is a reciprocating pump that has flexible diaphragm as component part at all times and participates in diaphragm sealing.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">bomba de diafragma</rdfs:label>
    <rdfs:label xml:lang="en">diaphragm pump</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DiaphragmPump(x) → (ReciprocatingPump(x) ∧ ∃d(FlexibleDiaphragm(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p(DiaphragmSealing(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under OWA, any pump with a flexible diaphragm component could be classified as a diaphragm pump, but there may be hybrid or specialized equipment containing diaphragms that should not be automatically classified into this maintenance category.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226">
    <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
    <rdfs:label xml:lang="en">check valve body</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive identity based on structural design for check valve accommodation. Under OWA, any housing designed for check valves could include specialized configurations, custom manifolds, or hybrid designs that should not be automatically classified as standard check valve bodies without domain expert validation of the structural differentia.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CHECK VALVE BODY&gt; is a &lt;VALVE BODY&gt; of a check valve</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que é especificamente projetado para acomodar e alojar os mecanismos internos de uma válvula de retenção dentro de uma barreira de contenção de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb471"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CheckValveBody subClassOf ValveBody and (designedFor some CheckValve)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveBody(x) → ValveBody(x) ∧ ∃y(CheckValve(y) ∧ designedFor(x,y)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidMixturePortion">
    <rdfs:label xml:lang="en">fluid mixture portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de fluido de mistura</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166">
    <rdfs:label xml:lang="pt-br">função de despressurização rápida</rdfs:label>
    <rdfs:label xml:lang="en">rapid depressurization function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb259"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb258"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1494">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255">
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1055"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DistillationColumn(x) ↔ (Separator(x) ∧ ∃f (DistillationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DISTILLATION COLUMN&gt; is  a &lt;DISTILLATION SEPARATOR&gt; and a &lt;PROCESS COLUMN&gt; and a &lt;DISTILLER&gt; intended to enable a distillation process</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A process column intended to enable a distillation process.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A process column intended to enable a distillation process</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every distillation column is a separator that has the function to perform distillation processes</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de destilação é um separador que possui uma função de destilação para permitir a separação de misturas de fluidos baseada nas diferenças dos pontos de ebulição dos componentes através do equilíbrio vapor-líquido.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">coluna de destilação</rdfs:label>
    <rdfs:label xml:lang="en">distillation column</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalEnergyPortion">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">thermal energy portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção térmico de energia</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000282">
    <skos:definition xml:lang="en">[POSC Caesar] A physical object that by the fusing of one or more of its specially designed and proportioned components, opens the circuit in which it is inserted by breaking the current when this exceeds a given value for a sufficient time.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that by the fusing of one or more of its specially designed and proportioned components, opens the circuit in which it is inserted by breaking the current when this exceeds a given value for a sufficient time.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FUSE&gt; is an &lt;ARTEFACT&gt; and a &lt;PROTECTOR&gt; and an &lt;ELECTRICAL ELEMENT&gt; that opens the circuit in which it is inserted by breaking the current when this exceeds a given value for a sufficient time</skos:definition>
    <rdfs:label xml:lang="pt-br">fusível</rdfs:label>
    <rdfs:label xml:lang="en">fuse</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Fuse(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FuseElement(e) ∧ hasComponentPartAtAllTimes(x,e)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every fuse is an electrical equipment that bears a circuit protection function and has a fuse element that melts under overcurrent conditions.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um fusível é um equipamento elétrico que protege circuitos interrompendo o fluxo de corrente através do derretimento intencional de um elemento fusível quando a corrente excede valores especificados por uma duração suficiente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fuse is an electrical equipment that protects circuits by interrupting current flow through the intentional melting of a fusible element when current exceeds specified values for a sufficient duration.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1612"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1545">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb66">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314"/>
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb67"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid valve is a valve that has a solenoid actuator component and bears an electrical control function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (SolenoidValve(x) → Valve(x) ∧ ∃s (SolenoidActuator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f (ElectricalControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[CFIHOS] A valve that has linear action which is fitted with a solenoid for quick operation.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A valve that has linear action which is fitted with a solenoid for quick operation.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SOLENOID VALVE&gt; is an &lt;ACTUATED VALVE&gt; and an &lt;ELECTRICAL ELEMENT&gt; with a linear action, fitted with a solenoid for quick operation</skos:definition>
    <rdfs:label xml:lang="en">solenoid valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula solenoide</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula solenoide é uma válvula que possui um atuador solenoide para controle elétrico do fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3019"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3018"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3020"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type where the solenoid mechanism is the distinguishing structural feature. Under OWA, making it equivalent could incorrectly classify complex valve assemblies that contain solenoid components but are not standard solenoid valves.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1039">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1035"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000362">
    <iof-av:naturalLanguageDefinition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transdutor é um instrumento que possui uma FunçãoDeTransdução para converter informação de uma forma ou magnitude de energia para outra forma ou magnitude.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every transducer is an instrument that has the designed function to convert energy or signal forms while preserving information content.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TRANSDUCER&gt; is an &lt;ENERGY CONVERTER&gt; that is capable of converting a &lt;PROCESS VARIABLE&gt; in one form or magnitude of energy to another form or magnitude of the same energy</skos:definition>
    <skos:definition xml:lang="en">[isa5_1] a general term for a device, which can be a primary element, transmitter, relay, converter or other device, that receives information in the form of one or more physical quantities, modifies the information or its form, or both if required, and produces a resultant output signal.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An artefact that accepts information in the form of a physical or chemical variable (its input variable) and converts it into an output variable of the same or another nature, according to a definite law.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Transducer(x) ↔ Instrument(x) ∧ ∃f (TransductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">transducer</rdfs:label>
    <rdfs:label xml:lang="pt-br">transdutor</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3205"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2569"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2570"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2568"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de deslocamento positivo é uma bomba que transporta líquido através do princípio de deslocamento alternativo ou rotativo com volume de deslocamento fixo por ciclo.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">bomba de deslocamento positivo</rdfs:label>
    <rdfs:label xml:lang="en">positive displacement pump</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PositiveDisplacementPump(x) → Pump(x) ∧ ∃y(DisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(PositiveDisplacementProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical mechanism. Under OWA, sufficient conditions based on displacement mechanism alone could lead to false positives where specialized equipment containing displacement elements might be incorrectly classified as standard positive displacement pumps.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every positive displacement pump is a pump that has a displacement mechanism as component part at all times and participates in positive displacement processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;POSITIVE DISPLACEMENT PUMP&gt; is an &lt;ARTEFACT&gt; and a &lt;PUMP&gt; intended to transport liquid through the reciprocating or rotary displacement principle and with either fixed or adjustable volume flow rates. NOTE - Combine with either BARE PUMP or PUMP SYSTEM,</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A type of fluid pump in which the displacement volume of the pump is fixed for each rotation of the pump.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AutomaticTransferMechanism">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">automatic transfer mechanism</rdfs:label>
    <rdfs:label xml:lang="pt-br">mecanismo automático de transferência</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectromagneticRadiation">
    <rdfs:label xml:lang="pt-br">radiação eletromagnético</rdfs:label>
    <rdfs:label xml:lang="en">electromagnetic radiation</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2130">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1810">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransferProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000239">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DAMPER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;DAMPING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A device that damps, typically a valve or plate (as in the flue of a furnace) for regulating the draft, or a device to stop vibration, typically a shock absorber or snubber.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A device for suppressing unfavourable characteristics or behavior.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um amortecedor é um conjunto que possui a função projetada de suprimir, regular ou reduzir características dinâmicas desfavoráveis como vibrações, flutuações de pressão ou distúrbios de fluxo.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb758"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every damper is an assembly that bears a damping function, and every assembly that bears a damping function is a damper.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">amortecedor</rdfs:label>
    <rdfs:label xml:lang="en">damper</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Damper(x) ↔ (Assembly(x) ∧ ∃f (DampingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3468">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CasingHanger"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de distribuição de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid distribution process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000286">
    <rdfs:label xml:lang="pt-br">turbina a gás</rdfs:label>
    <rdfs:label xml:lang="en">gas turbine</rdfs:label>
    <skos:definition xml:lang="en">[POSC Caesar] A turbine that compresses air which is then mixed with fuel for combustion and expansion through a turbine section to generate relatively high power output for either mechanical drive or power generation.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GAS TURBINE&gt; is a &lt;TURBINE&gt; that compresses air which is then mixed with fuel for combustion and expansion through a turbine section to generate relatively high power output for either mechanical drive or power generation</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A turbine that compresses air which is then mixed with fuel for combustion and expansion through a turbine section to generate relatively high power output for either mechanical drive or power generation.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GasTurbine(x) ↔ Turbine(x) ∧ ∃c,h(Compressor(c) ∧ CombustionChamber(h) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃p1,p2(AirCompressionProcess(p1) ∧ FuelCombustionProcess(p2) ∧ participatesIn(x,p1) ∧ participatesIn(x,p2)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas turbine is a turbine that has component parts compressor and combustion chamber at all times, and participates in air compression process and fuel combustion process.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1666"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma turbina a gás é uma turbina que possui um compressor e câmara de combustão integrados, projetada para comprimir ar ambiente, misturá-lo com combustível para combustão, e expandir os gases quentes resultantes através de uma seção de turbina para gerar energia mecânica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2403"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2402"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2404"/>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is a long tube or hollow body intended for conduction of liquid, gaseous or finely divided solid materials, or used for structural purposes.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An elementary piece of piping, i.e., not interrupted by any item.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIPE&gt; is an &lt;ARTEFACT&gt; and a &lt;FLUID CONDUCTOR&gt; that is a long tube or hollow body intended for conduction of liquid, gaseous or finely divided solid materials, or used for structural purposes</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An 'artefact' that is a long tube or hollow body intended for conduction of liquid, gaseous or finely divided solid materials, or used for structural purposes.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tubo é um artefato material caracterizado por geometria tubular e extensão longitudinal, projetado para conduzir materiais líquidos, gasosos ou sólidos finamente divididos de um local para outro, ou para servir a propósitos estruturais.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pipe</rdfs:label>
    <rdfs:label xml:lang="pt-br">tubo</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Pipe(x) → MaterialArtifact(x) ∧ ∃f(FluidConductionFunction(f) ∧ hasFunction(x,f)) ∧ ∃g(TubularGeometry(g) ∧ hasPhysicalProperty(x,g)) ∧ ∃h(LongitudinalExtent(h) ∧ hasPhysicalProperty(x,h)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe is a material artifact that has fluid conduction function and has tubular geometry and has longitudinal extent.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because pipe is defined by constructive/geometric properties (tubular geometry, longitudinal extent) rather than purely functional criteria. Under Open World Assumption, asserting sufficient conditions based on geometric properties could lead to unintended classification of complex tubular structures that happen to conduct fluids but should not be categorized as standard pipes.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb16">
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb17"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
  </rdf:Description>
