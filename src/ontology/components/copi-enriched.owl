  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1302">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000369">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de vácuo é uma coluna de destilação projetada para resistir à pressão externa durante operação sob vácuo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[POSC Caesar] A distillation column intended to withstand outside pressure</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VACUUM COLUMN&gt; is an &lt;ARTEFACT&gt; and a &lt;DISTILLATION COLUMN&gt; intended to withstand outside pressure</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A distillation column intended to withstand outside pressure.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VacuumColumn(x) → DistillationColumn(x) ∧ ∃q(VacuumPressureResistanceQuality(q) ∧ bearerOf(x,q)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3352"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3353"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3354"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vacuum column is a distillation column that bears a vacuum pressure resistance quality.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">coluna de vácuo</rdfs:label>
    <rdfs:label xml:lang="en">vacuum column</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural capability. Under OWA, defining sufficient conditions for vacuum-capable design would be complex and could lead to false positives. The structural differentia (vacuum resistance) requires domain expert validation of what constitutes adequate vacuum design capability.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2129">
    <owl:intersectionOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2134"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um acumulador é um vaso que tem a função projetada de acumular (armazenar e liberar de forma controlada) energia ou matéria.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An accumulator is a vessel that has the designed function to accumulate (store and controllably release) energy or matter.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[OnePetro] In context of a pressure control device, accumulators are canisters of hydraulic fluid, pressurized with a nitrogen gas cap of sufficient pressure and volume to operate all the rams on a BOP in case of power failure to the BOP.                  In context of a processing plant, an accumulator is a vessel that receives and temporarily stores a liquid used in the feed stock or the processing of a feed stream in a gas plant or other processing facility.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A functional object capable of storing energy, and which after discharge may be recharged.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device used in a hydraulic system to store energy or, in some applications, dampen pressure fluctuations.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ACCUMULATOR&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;ACCUMULATING&gt; matter and/or energy</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object for storing energy, and which after discharge may be recharged.</skos:definition>
    <rdfs:label xml:lang="pt-br">acumulador</rdfs:label>
    <rdfs:label xml:lang="en">accumulator</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b24"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every accumulator is a vessel that bears an accumulation function</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Accumulator(x) ↔ (Vessel(x) ∧ ∃f (AccumulationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
