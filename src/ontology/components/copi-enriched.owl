  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297">
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions would force any assembly with enclosure and support functions to be classified as a standard housing, potentially misclassifying specialized equipment with housing-like properties but different maintenance categories.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">housing</rdfs:label>
    <rdfs:label xml:lang="pt-br">carcaça</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1842"/>
    <skos:definition xml:lang="en">[SLB Glossary] The outside steel case of a cartridge or a sonde in a wireline logging tool.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HOUSING&gt; is an &lt;ARTEFACT&gt; and an &lt;ENCLOSURE&gt; and a &lt;SUPPORT&gt; that, next to separation, also provides support</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] An enclosure that also provides support.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Housing(x) → Assembly(x) ∧ ∃f₁(EnclosureFunction(f₁) ∧ bearerOf(x,f₁)) ∧ ∃f₂(SupportFunction(f₂) ∧ bearerOf(x,f₂)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Housing SubClassOf Assembly and (bearerOf some EnclosureFunction) and (bearerOf some SupportFunction)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears both an EnclosureFunction and a SupportFunction, providing protective boundaries around internal components while structurally supporting them.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que possui tanto uma EnclosureFunction quanto uma SupportFunction, fornecendo limites protetivos ao redor de componentes internos enquanto os suporta estruturalmente.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2635">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
