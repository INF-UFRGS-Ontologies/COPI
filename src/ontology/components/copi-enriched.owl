<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:apv="http://inf.ufrgs.br/ontologies/apv#"
   xmlns:dcterms="http://purl.org/dc/terms/"
   xmlns:iof-av="https://spec.industrialontologies.org/ontology/annotation/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260">
    <rdfs:label xml:lang="pt-br">atuador elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electric actuator</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador elétrico é um atuador que converte energia elétrica em movimento mecânico através de um componente conversor elétrico-mecânico e opera via entrada de sinal elétrico.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric actuator is an actuator that converts electrical energy to mechanical movement through an electric-to-mechanical converter component and operates via electrical signal input.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab917"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <skos:definition xml:lang="en">An electric actuator is an actuator that converts electrical energy to mechanical movement through an electric-to-mechanical converter component and operates via electrical signal input.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on electrical energy conversion mechanism. Under OWA, asserting equivalence would force any artifact with electrical-to-mechanical conversion into this category, potentially misclassifying specialized hybrid equipment or complex electrical machinery that should not be categorized as standard actuators.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric actuator is an actuator that has an electric-to-mechanical converter component at all times and has electrical signal input.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricActuator(x) → Actuator(x) ∧ ∃y(ElectricToMechanicalConverter(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ElectricalSignal(z) ∧ hasInput(x,z)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2599">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationBearingEntity">
    <rdfs:label xml:lang="pt-br">entidade de informação de mancal</rdfs:label>
    <rdfs:label xml:lang="en">information bearing entity</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <skos:definition xml:lang="en">An information content entity constituting that carries or encodes information representing a process variable, equipment state, or analytical result in petroleum production systems.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2065"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transformador de potência é um transformador que possui uma função de transformação de energia elétrica, realizada por indução eletromagnética para transformar sistemas de tensão e corrente alternadas para diferentes níveis na mesma frequência para fins de transmissão de energia.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">power transformer</rdfs:label>
    <rdfs:label xml:lang="pt-br">transformador de potência</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every power transformer is a transformer that has the function of transforming electrical power through electromagnetic induction, taking alternating current at one voltage level as input and producing alternating current at different voltage level(s) as output for power transmission.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformer(x) ↔ (Transformer(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃r(ElectricalPowerTransmissionRole(r) ∧ bearerOf(x,r))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1773">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1771"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de prevenção de refluxo</rdfs:label>
    <rdfs:label xml:lang="en">backflow prevention process</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab388">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1841">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119">
    <iof-av:primitiveRationale xml:lang="en">This is a constructive subtype where the structural differentia (gate closure mechanism) defines necessary conditions. Under OWA, making this sufficient could force any assembly with a gate closure into this maintenance category, including specialized multi-way valves or custom manifolds that should not be classified as standard gate control valves.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</skos:definition>
    <rdfs:label xml:lang="en">gate control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle tipo gaveta</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate control valve is a control valve that has a gate closure mechanism as component part at all times</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle tipo gaveta é uma válvula de controle que usa um elemento de fechamento tipo gaveta ou cunha movendo-se perpendicular ao caminho do fluxo para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GateControlValve(x) → ControlValve(x) ∧ ∃g(GateClosureMechanism(g) ∧ hasComponentPartAtAllTimes(x,g)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1340"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab92">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de espaçamento</rdfs:label>
    <rdfs:label xml:lang="en">spacing process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a defined spatial separation between components is maintained to ensure correct alignment, clearance, or insulation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1474">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2763"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2764"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">vibration transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de vibração</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and remote transmission of mechanical vibration amplitude or frequency in rotating equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000107">
    <iof-av:naturalLanguageDefinition xml:lang="en">A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um coalescedor é um separador que usa meio de coalescência para promover a fusão de gotículas em misturas líquidas imiscíveis, permitindo separação por gravidade onde a fase líquida menos densa pode ser removida por escumação.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off.</skos:definition>
    <rdfs:label xml:lang="pt-br">coalescedor</rdfs:label>
    <rdfs:label xml:lang="en">coalescer</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab470"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Coalescer(x) ↔ (Separator(x) ∧ ∃f(CoalescenceFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(GravitySeparationProcess(p) ∧ participatesIn(x,p)) ∧ ∃o(SkimmableLiquidPortion(o) ∧ hasOutput(x,o))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coalescer is a separator that bears a coalescence function and participates in gravity separation processes to produce skimmable liquid portions.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidMixturePortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">porção de fluido de mistura</rdfs:label>
    <rdfs:label xml:lang="en">fluid mixture portion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more fluids at a defined point in a petroleum production process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192">
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical rotational energy from a driving mechanism to driven components, enabling the transfer of torque and rotational motion through a mechanical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from a prime mover through rotational motion or to generate energy when acting as a driven element.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical energy from an external energy source through rotational motion to downstream mechanical components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transfer mechanical energy from a prime mover to one or more driven machines, maintaining rotational motion while potentially modifying torque and speed characteristics.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from one mechanical component to another through rotational or linear motion.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical power from one shaft to another through direct mechanical coupling or engagement.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2337"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1852"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1602"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab876"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2363"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2364"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1369"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1851"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1603"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1374"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2165"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1373"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1368"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2338"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab877"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2166"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical energy from an external energy source through rotational motion to downstream mechanical components.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transfer mechanical energy from a prime mover to one or more driven machines, maintaining rotational motion while potentially modifying torque and speed characteristics.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from one mechanical component to another through rotational or linear motion.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical power from one shaft to another through direct mechanical coupling or engagement.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in transmitting mechanical rotational energy from a driving mechanism to driven components, enabling the transfer of torque and rotational motion through a mechanical system.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a PowerTransmissionProcess and that consists in the capacity to transmit mechanical energy from a prime mover through rotational motion or to generate energy when acting as a driven element.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de transmissão de potência</rdfs:label>
    <rdfs:label xml:lang="en">power transmission function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureIndicationProcess">
    <skos:definition xml:lang="en">A planned process in which the temperature of a process stream or equipment surface is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de indicação de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature indication process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000241">
    <rdfs:label xml:lang="pt-br">degaseificador</rdfs:label>
    <rdfs:label xml:lang="en">degasser</rdfs:label>
    <skos:definition xml:lang="en">A degasser is a separator that removes gases from drilling fluids by realizing a degassing function.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab624"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Degasser(x) ↔ (Separator(x) ∧ ∃f (DegassingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A degasser is a separator that removes gases from drilling fluids by realizing a degassing function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um degaseificador é um separador que remove gases de fluidos de perfuração realizando uma função de degaseificação.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every degasser is a separator that bears a degassing function and has drilling fluid as input and degassed drilling fluid plus separated gases as outputs.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143">
    <skos:definition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro é um indicador que possui a função de medir e exibir valores de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureGauge(x) ↔ (Instrument(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2097"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure gauge is an instrument that has the function to measure and display pressure</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">manômetro</rdfs:label>
    <rdfs:label xml:lang="en">pressure gauge</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1316">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1317"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionSignal">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">position signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de posição</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the position of a mechanical component in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab965">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2687">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2689"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000330">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every position transmitter is a transmitter that has the function of position transmission and receives position or displacement signals as input.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A position transmitter is a transmitter that measures position or displacement and converts it to a standardized output signal.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de posição é um transmissor que mede posição ou deslocamento e o converte em um sinal de saída padronizado.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A position transmitter is a transmitter that measures position or displacement and converts it to a standardized output signal.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PositionTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PositionTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PositionSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">transmissor de posição</rdfs:label>
    <rdfs:label xml:lang="en">position transmitter</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2040"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1765"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every manual valve is a valve that has a manual actuator as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on actuation mechanism. Under OWA, any valve with a manual actuator component might be classified as manual valve even if it has additional automated features (hybrid valves). Starting with necessary conditions allows domain experts to validate that manual actuation is both necessary and sufficient before upgrading to equivalent axiom.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula manual é uma válvula que possui um atuador manual que requer força manual para operação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">manual valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula manual</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ManualValve(x) → Valve(x) ∧ ∃y(ManualActuator(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab495">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab493"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionSignal">
    <rdfs:label xml:lang="en">detection signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de detecção</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting a signal generated by a detection element indicating the presence or concentration of a detected entity in petroleum production instrumentation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HighPressureFluidPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">porção alto de pressão de fluido</rdfs:label>
    <rdfs:label xml:lang="en">high pressure fluid portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid maintained at a pressure significantly above the system reference pressure in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess">
    <rdfs:label xml:lang="en">energy extraction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de extração de energia</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which useful work or heat is recovered from a process stream, pressure differential, or thermal source in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which acoustic energy in a fluid stream or mechanical system is attenuated to reduce radiated noise to an acceptable level.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">noise silencing process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de silenciamento de ruído</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1278">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1036">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab77">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab377">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab379"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2479">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CorrosionProducts">
    <rdfs:label xml:lang="en">corrosion products</rdfs:label>
    <rdfs:label xml:lang="pt-br">produtos de corrosão</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the solid products—oxides, hydroxides, or sulfides—formed on a metallic surface as a result of corrosion in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000376">
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um poço perfurado é um local que fornece um caminho perfurado para acesso subsuperficial e está espacialmente contido dentro de um sistema de poço.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</skos:definition>
    <rdfs:label xml:lang="en">wellbore</rdfs:label>
    <rdfs:label xml:lang="pt-br">poço perfurado</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellbore(x) ↔ Site(x) ∧ ∃f(SubsurfaceAccessFunction(f) ∧ hasFunction(x,f)) ∧ ∃w(Well(w) ∧ spatiallyContainedIn(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellbore is a site that has the function of providing subsurface access and is spatially contained within a well.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2186">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab434">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidPortion">
    <rdfs:label xml:lang="en">process fluid portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de processo de fluido</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of the process fluid—hydrocarbon, water, or gas—handled at a defined point in a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PumpChamber">
    <rdfs:label xml:lang="pt-br">câmara de bomba</rdfs:label>
    <rdfs:label xml:lang="en">pump chamber</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the enclosed space within a pump casing in which fluid is pressurised by the impeller or piston.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326">
    <skos:definition xml:lang="en">A pipeline is an engineered system that bears a fluid transport function, consisting of pipes and possibly including pumps, valves, and control devices, designed for conveying liquids, gases, or finely divided solids between locations.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Pipeline(x) ↔ EngineeredSystem(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipeline is an engineered system that bears a fluid transport function, consisting of pipes and possibly including pumps, valves, and control devices, designed for conveying liquids, gases, or finely divided solids between locations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um pipeline é um sistema engenheirado que possui uma função de transporte de fluidos, consistindo de tubos e possivelmente incluindo bombas, válvulas e dispositivos de controle, projetado para transportar líquidos, gases ou sólidos finamente divididos entre locais.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipeline is an engineered system that bears a fluid transport function and has pipe as a component part at some time.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">pipeline</rdfs:label>
    <rdfs:label xml:lang="en">pipeline</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1963"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdfs:label xml:lang="en">pressure signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de pressão</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the pressure of a process stream in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000247">
    <iof-av:naturalLanguageDefinition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de ponto de orvalho é um instrumento que possui uma função de medição de ponto de orvalho.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab710"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dew point analyser is an instrument that has the function to determine the dew point of a substance</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">analisador de ponto de orvalho</rdfs:label>
    <rdfs:label xml:lang="en">dew point analyser</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DewPointAnalyser(x) ↔ Instrument(x) ∧ ∃f(DewPointMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixingProcess">
    <skos:definition xml:lang="en">A planned process in which two or more fluid streams or components are combined and blended to achieve a homogeneous mixture.</skos:definition>
    <rdfs:label xml:lang="en">mixing process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de mistura</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000275">
    <skos:definition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare tip is a burner that has the function to dispose of waste gas from processes by burning it into the atmosphere</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">queimador de flare</rdfs:label>
    <rdfs:label xml:lang="en">flare tip</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador de flare é um queimador que especificamente queima gás residual emitido de processos industriais e descarrega os produtos de combustão na atmosfera.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlareTip(x) ↔ Burner(x) ∧ ∃f(WasteGasDisposalFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1130"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">ball control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab128"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab366">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2454">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000363">
    <rdfs:label xml:lang="en">transmitter housing</rdfs:label>
    <rdfs:label xml:lang="pt-br">invólucro de transmissor</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical structure as housing. Under OWA, sufficient conditions for transmitter housing would require specifying exact structural features (materials, dimensions, sealing mechanisms) that distinguish it from other instrument housings. The necessary conditions establish the core identity without risking false positives from other housing types that might share some structural features.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro de transmissor é uma Assembly que possui uma EnclosureFunction e que tem um circuito eletrônico de transmissor como parte componente em todos os momentos, projetado para fornecer proteção ambiental e contenção física para componentes do transmissor.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2625"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">TransmitterHousing ⊑ Assembly ⊓ ∃bearerOf.EnclosureFunction ⊓ ∃hasComponentPartAtAllTimes.TransmitterElectronicCircuit</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TransmitterHousing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(TransmitterElectronicCircuit(c) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1874">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab930">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab931"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1549">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotatingVanes"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessVariable">
    <rdfs:label xml:lang="pt-br">variável de processo</rdfs:label>
    <rdfs:label xml:lang="en">process variable</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting a measurable variable—pressure, temperature, flow rate, or level—that characterises the state of a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydrocarbonFluid">
    <rdfs:label xml:lang="en">hydrocarbon fluid</rdfs:label>
    <rdfs:label xml:lang="pt-br">fluido de hidrocarboneto</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a fluid consisting primarily of hydrocarbon compounds produced from or processed in a petroleum production system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222">
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing is an assembly that provides structural enclosure with pressure containment capability, characterized by walls that separate internal components or fluids from the external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um casing é um conjunto que fornece invólucro estrutural com capacidade de contenção de pressão, caracterizado por paredes que separam componentes internos ou fluidos do ambiente externo.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab330"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <skos:definition xml:lang="en">A casing is an assembly that provides structural enclosure with pressure containment capability, characterized by walls that separate internal components or fluids from the external environment.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every casing is an assembly that has an enclosure function and has component part some casing wall and has function some pressure containment function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Casing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(CasingWall(w) ∧ hasComponentPartAtAllTimes(x,w)) ∧ ∃p(PressureContainmentFunction(p) ∧ hasFunction(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:label xml:lang="en">casing</rdfs:label>
    <rdfs:label xml:lang="pt-br">casing</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on structural configuration. Under OWA, sufficient conditions for enclosure structure could lead to over-classification of complex assemblies that contain enclosure elements but serve different primary functions (e.g., pressure vessels, housings, containers).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131">
    <skos:definition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1702"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de nível é um transmissor que mede o nível (altura) de material líquido ou sólido a granel em um recipiente e produz um sinal elétrico de saída padronizado proporcional ao nível medido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">transmissor de nível</rdfs:label>
    <rdfs:label xml:lang="en">level transmitter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level transmitter is a transmitter that bears a LevelMeasurementAndTransmissionFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(LevelTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(LevelMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab999">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</skos:definition>
    <rdfs:label xml:lang="pt-br">válvula de segurança de fundo de poço</rdfs:label>
    <rdfs:label xml:lang="en">down hole safety valve</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança de fundo de poço é uma válvula de segurança que possui uma função de segurança subsuperficial para operações de alívio de pressão e controle de fluxo em poços ou outros ambientes subsuperficiais.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab866"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DownHoleSafetyValve(x) ↔ SafetyValve(x) ∧ ∃f(SubsurfaceSafetyFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SubsurfaceOperationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every down hole safety valve is a safety valve that bears a SubsurfaceSafetyFunction and participates in SubsurfaceOperationProcess</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1442">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab643">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2526"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab72"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab73"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2525"/>
    <rdfs:label xml:lang="pt-br">função de indicação de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature indication function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the temperature of a process stream or equipment surface.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000357">
    <iof-av:naturalLanguageDefinition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um quadro de distribuição é um equipamento elétrico que consiste em painéis que acomodam chaves, indicadores e aparatos de controle para conectar, desconectar e controlar vários circuitos de um sistema elétrico.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2492"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Switchboard(x) ↔ ElectricalEquipment(x) ∧ ∃p,s,i(Panel(p) ∧ ElectricalSwitch(s) ∧ ControlIndicator(i) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃f(ElectricalCircuitControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">quadro de distribuição</rdfs:label>
    <rdfs:label xml:lang="en">switchboard</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every switchboard is electrical equipment that has component parts (panels, switches, indicators) and bears the function to control electrical circuits</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1126"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1106"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1127"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1107"/>
    <rdfs:label xml:lang="en">waste gas disposal function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de descarte de gás residual</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the safe disposal of waste or surplus gas streams by combustion, venting, or re-injection into a formation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab538"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab539"/>
    <rdfs:label xml:lang="pt-br">função de controle</rdfs:label>
    <rdfs:label xml:lang="en">control function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the regulation of a process variable by adjusting a manipulated variable in response to a measured deviation from a set point.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000323">
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe elbow is a pipe that has curved geometry enabling directional changes in pipe runs between 0 and 135 degrees.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cotovelo de tubulação é uma tubulação que possui geometria curva permitindo mudanças direcionais em trechos de tubulação entre 0 e 135 graus.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe elbow is a pipe that has curved geometry and enables directional change capacity between 0 and 135 degrees.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A pipe elbow is a pipe that has curved geometry enabling directional changes in pipe runs between 0 and 135 degrees.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">pipe elbow</rdfs:label>
    <rdfs:label xml:lang="pt-br">cotovelo de tubulação</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PipeElbow(x) → (Pipe(x) ∧ ∃g(CurvedGeometry(g) ∧ hasGeometricProperty(x,g)) ∧ ∃p(DirectionalChangeCapacity(p) ∧ hasProperty(x,p))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1938"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type protects against false positives under OWA. Any curved piping component would be forcibly classified as a pipe elbow under equivalent axioms, including specialized equipment like coiled tubing, serpentine heat exchanger tubes, or custom manifold sections that contain curved passages but should not be asserted into the standard pipe elbow maintenance category.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2539">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2540"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000380"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which thermal energy is detected and converted into a measurable signal representing the temperature of a process stream or component.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de sensoriamento de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature sensing process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2626"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2627"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">tubing support function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de suporte de coluna de produção</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical suspension and support of downhole tubing strings within a wellbore.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab404">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador é um vaso que possui uma FunçãoDeSeparação - projetado para separar diferentes substâncias ou fases de uma corrente fluida mista em correntes de saída distintas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">separador</rdfs:label>
    <rdfs:label xml:lang="en">separator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Separator(x) ↔ (Vessel(x) ∧ ∃f (SeparationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2327"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every separator is a vessel that has the function of separating mixed fluid streams into distinct phases or components.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318">
    <rdfs:label xml:lang="en">pig launcher</rdfs:label>
    <rdfs:label xml:lang="pt-br">lançador de pig</rdfs:label>
    <skos:definition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lançador de pig é um vaso que possui função de lançamento de pig para inserir pigs de duto em sistemas de tubulação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PigLauncher(x) ↔ (Vessel(x) ∧ ∃f(PigLaunchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(PipelineConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1873"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig launcher is a vessel that has the function to launch pipeline pigs and has a pipeline connection component.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1591">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidPortion">
    <rdfs:label xml:lang="pt-br">porção de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid portion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a defined portion of fluid at a specified point within a petroleum production process stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000272">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector de chama é um detector que tem a função de detectar a presença de chamas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</skos:definition>
    <rdfs:label xml:lang="en">flame detector</rdfs:label>
    <rdfs:label xml:lang="pt-br">detector de chama</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame detector is a detector that has a flame detection function, and every detector that has a flame detection function is a flame detector.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1088"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlameDetector(x) ↔ Detector(x) ∧ ∃f(FlameDetectionFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionLimitDetectionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the end-of-travel or open or closed position of a moving mechanical component is detected and signalled.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de detecção de limite de posição</rdfs:label>
    <rdfs:label xml:lang="en">position limit detection process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/OilPortion">
    <rdfs:label xml:lang="pt-br">porção de óleo</rdfs:label>
    <rdfs:label xml:lang="en">oil portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of liquid hydrocarbon at a defined point in a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção de sólido</rdfs:label>
    <rdfs:label xml:lang="en">solid portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of solid material at a defined point in a petroleum production process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab353">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess">
    <rdfs:label xml:lang="en">turbomachinery power generation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de geração de energia por turbomáquina</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which fluid enthalpy is converted into shaft power through the interaction of a fluid stream with rotating turbine blades.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab514">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000344">
    <skos:definition xml:lang="en">A scraper is a material artifact that bears a scraping function for mechanically removing deposits, debris, or contaminants from surfaces.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every scraper is a material artifact that has a scraping function, and every material artifact that has a scraping function is a scraper.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Scraper(x) ↔ (MaterialArtifact(x) ∧ ∃f(ScrapingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">scraper</rdfs:label>
    <rdfs:label xml:lang="pt-br">raspador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2287"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A scraper is a material artifact that bears a scraping function for mechanically removing deposits, debris, or contaminants from surfaces.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um raspador é um artefato material que possui uma função de raspagem para remover mecanicamente depósitos, detritos ou contaminantes de superfícies.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionProcess">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
    <rdfs:label xml:lang="pt-br">processo de detecção de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas detection process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A detection process in which the presence or concentration of a specific gas or vapour in the surrounding atmosphere is sensed and identified.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158">
    <skos:definition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</skos:definition>
    <rdfs:label xml:lang="en">vessel</rdfs:label>
    <rdfs:label xml:lang="pt-br">vaso</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2742"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel is an assembly that bears a containment function and has a vessel shell and vessel head as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Vessel(x) ↔ Assembly(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(VesselShell(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃h(VesselHead(h) ∧ hasComponentPartAtAllTimes(x,h)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161">
    <skos:definition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2479"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2478"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2780"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab374"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2781"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1975"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab373"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab385"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab384"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1976"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">backflow prevention function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de prevenção de refluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Panel">
    <skos:definition xml:lang="en">A material artifact that constitutes a flat structural panel that provides a mounting surface for instrumentation, controls, or electrical equipment in a petroleum production installation.</skos:definition>
    <rdfs:label xml:lang="en">panel</rdfs:label>
    <rdfs:label xml:lang="pt-br">painel</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2461">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000333">
    <iof-av:naturalLanguageDefinition xml:lang="en">A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma FiatObjectPart que é o enrolamento secundário de um transformador de potência e que possui uma SecondaryWindingFunction consistindo em fornecer energia elétrica transformada no nível de tensão de saída.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2075"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerSecondaryWinding SubClassOf FiatObjectPart and (partOf some PowerTransformer) and (hasFunction some SecondaryWindingFunction)</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">power transformer secondary winding</rdfs:label>
    <rdfs:label xml:lang="pt-br">enrolamento secundário de transformador de potência</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerSecondaryWinding(x) → FiatObjectPart(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(SecondaryWindingFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis - the physical configuration (being the secondary winding of a power transformer) provides necessary conditions, but sufficient conditions are harder to assert under OWA without risking false positives for specialized or hybrid transformer configurations.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1587">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasDetectionFunction">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1288"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1287"/>
    <rdfs:label xml:lang="pt-br">função de detecção de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas detection function</rdfs:label>
    <skos:definition xml:lang="en">A detection function borne by petroleum production equipment whose realization constitutes the sensing and identification of the presence or concentration of a specific gas or vapour in the surrounding atmosphere.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2163">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000342">
    <rdfs:label xml:lang="en">rotor</rdfs:label>
    <rdfs:label xml:lang="pt-br">rotor</rdfs:label>
    <skos:definition xml:lang="en">An Assembly that participates in rotational motion and has a rotor shaft as an essential component, designed to transfer mechanical energy through rotational motion within a machine assembly.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2245"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Rotor is an Assembly that participates in some RotationalMotionProcess and has some rotor shaft as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que participa em movimento rotacional e tem um eixo do rotor como componente essencial, projetado para transferir energia mecânica através de movimento rotacional dentro de um conjunto de máquina.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that participates in rotational motion and has a rotor shaft as an essential component, designed to transfer mechanical energy through rotational motion within a machine assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Rotor(x) → Assembly(x) ∧ ∃p(RotationalMotionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(RotorShaft(s) ∧ hasComponentPartAtAllTimes(x,s)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration (rotating portion with shaft), providing sufficient conditions under OWA could lead to overclassification. Complex assemblies containing rotating elements might be incorrectly classified as rotors rather than their proper categories (motors, compressors, etc.).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab794">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab796"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de controle de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow control process</rdfs:label>
    <skos:definition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1697">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSignalTransmissionProcess">
    <skos:definition xml:lang="en">A signal transmission process in which a standardised signal representing a measured flow rate is transmitted to a remote control or monitoring system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
    <rdfs:label xml:lang="pt-br">processo de transmissão de sinal de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow signal transmission process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1040"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1036"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1009"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1551"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1550"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1027"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1026"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1035"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1008"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1041"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FiltrationProcess and that consists in selectively retaining particles, contaminants, or unwanted substances from a fluid stream while allowing the clean fluid to pass through.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">função de filtração</rdfs:label>
    <rdfs:label xml:lang="en">filtration function</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a FiltrationProcess and that consists in selectively retaining particles, contaminants, or unwanted substances from a fluid stream while allowing the clean fluid to pass through.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab838">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab840"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095">
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical mechanism, sufficient conditions are omitted to avoid false positives under Open World Assumption. Complex multi-way valves or specialized equipment containing ball mechanisms should not be automatically classified as standard ball valves without domain expert validation.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</skos:definition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula esfera é uma válvula que controla o fluxo de fluidos usando um elemento de fechamento esférico que gira aproximadamente 90 graus para alinhar ou desalinhar sua passagem de fluxo com as portas do corpo da válvula.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallValve(x) → Valve(x) ∧ ∃y(BallClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(RotationalMotionProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">válvula esfera</rdfs:label>
    <rdfs:label xml:lang="en">ball valve</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab142"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every ball valve is a valve that has a ball closure component and participates in rotational motion processes</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">demisting function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de separação de névoa</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the coalescence and removal of entrained liquid droplets from a gas stream.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab661"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab662"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab866">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab868"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2676">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingBundle"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab569">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab571"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1901">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de resfriamento</rdfs:label>
    <rdfs:label xml:lang="en">cooling process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which thermal energy is removed from a process stream or equipment component to reduce its temperature in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialComponent">
    <rdfs:label xml:lang="pt-br">componente de material</rdfs:label>
    <rdfs:label xml:lang="en">material component</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a discrete material component of petroleum production equipment that contributes to its overall function.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab423">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab419"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1760">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1346">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab321">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab317"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000218">
    <skos:definition xml:lang="en">A bottom hole assembly is a drilling component that performs specialized drilling operations at the bottom of the drill string, characterized by including a drill bit and being positioned at the bottom hole location.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bottom hole assembly is a drilling component that has a drill bit as component part at all times and is located at bottom hole location.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BottomHoleAssembly(x) ↔ DrillingComponent(x) ∧ ∃y(DrillBit(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(BottomHoleLocation(z) ∧ locatedAt(x,z)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">conjunto de fundo de poço</rdfs:label>
    <rdfs:label xml:lang="en">bottom hole assembly</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab257"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bottom hole assembly is a drilling component that performs specialized drilling operations at the bottom of the drill string, characterized by including a drill bit and being positioned at the bottom hole location.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um conjunto de fundo de poço é um componente de perfuração que realiza operações especializadas de perfuração na parte inferior da coluna de perfuração, caracterizado por incluir uma broca e estar posicionado no local do fundo do poço.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000362">
    <rdfs:label xml:lang="pt-br">transdutor</rdfs:label>
    <rdfs:label xml:lang="en">transducer</rdfs:label>
    <skos:definition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Transducer(x) ↔ Instrument(x) ∧ ∃f (TransductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every transducer is an instrument that has the designed function to convert energy or signal forms while preserving information content.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2594"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transdutor é um instrumento que possui uma FunçãoDeTransdução para converter informação de uma forma ou magnitude de energia para outra forma ou magnitude.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab620">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000120">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula gaveta é uma válvula que possui um membro de fechamento tipo gaveta ou disco com movimento linear paralelo ao plano dos assentos planos, que são transversais à direção do fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1345"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1346"/>
    <rdfs:label xml:lang="pt-br">válvula gaveta</rdfs:label>
    <rdfs:label xml:lang="en">gate valve</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for structural features like 'linear sliding gate' risks false positives from complex hybrid equipment or custom manifolds that contain gate mechanisms but should not be classified as standard gate valves. Necessary conditions provide safer classification that can be validated by domain experts.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GateValve(x) → (Valve(x) ∧ ∃g(GateClosure(g) ∧ hasComponentPartAtAllTimes(x,g)) ∧ ∃m(LinearActuationMechanism(m) ∧ hasComponentPartAtAllTimes(x,m))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate valve is a valve that has a gate closure component and a linear actuation mechanism.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab913">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138">
    <skos:definition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</skos:definition>
    <rdfs:label xml:lang="pt-br">válvula de retenção tipo pistão</rdfs:label>
    <rdfs:label xml:lang="en">piston check valve</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção tipo pistão é uma válvula de retenção que possui um elemento de fechamento tipo pistão que se move linearmente ao longo do eixo de fluxo sob ação da gravidade ou mola para prevenir refluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PistonCheckValve(x) → CheckValve(x) ∧ ∃y(PistonClosure(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every piston check valve is a check valve that has a piston closure as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1979"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under Open World Assumption, any artifact with a piston closure could potentially be classified as piston check valve, but specialized hybrid valves or custom manifolds containing piston mechanisms should not be automatically asserted into this standard maintenance category without domain expert validation.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000123">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula globo é uma válvula caracterizada por um elemento de fechamento (disco ou tampão) que opera com movimento linear perpendicular a uma sede orientada normal ao caminho do fluxo do fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under OWA, making the structural differentia sufficient could force classification of specialized equipment containing linear motion closures (like complex multi-way valves or custom manifolds) as standard globe valves when they may warrant distinct maintenance categories.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe valve is a valve that has as component part at all times a linear motion closure and a normal seat.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">globe valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula globo</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1403"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GlobeValve(x) → Valve(x) ∧ ∃y,z(hasComponentPartAtAllTimes(x,y) ∧ LinearMotionClosure(y) ∧ hasComponentPartAtAllTimes(x,z) ∧ NormalSeat(z)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2576"/>
    <skos:definition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma Placa que possui geometria de espessura fina e é fabricada através de processos de conformação a frio, tipicamente usada para aplicações de suporte estrutural que requerem peso reduzido ou restrições geométricas específicas.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ThinPlate ⊑ Plate ⊓ ∃hasQuality.ThinThickness ⊓ ∃hasQuality.ColdFormedManufacturing</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThinPlate(x) → Plate(x) ∧ ∃q1(ThinThickness(q1) ∧ hasQuality(x,q1)) ∧ ∃q2(ColdFormedManufacturing(q2) ∧ hasQuality(x,q2)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical geometry (thinness) and manufacturing method (cold forming). Under OWA, sufficient conditions for thin plates are difficult to specify without risking false positives from specialized hybrid structures that contain thin cold-formed elements but should not be classified as standard thin plates.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">Placa que possui geometria de espessura fina e</rdfs:label>
    <rdfs:label xml:lang="en">thin plate</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RemovedMaterial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes material—scale, deposits, or cuttings—removed from a surface or stream by a mechanical cleaning process in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">material de removido</rdfs:label>
    <rdfs:label xml:lang="en">removed material</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1423"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1750"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1749"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1424"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de distribuição de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid distribution function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the splitting and delivery of a fluid stream to multiple downstream points in defined proportions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidMixturePortion">
    <rdfs:label xml:lang="en">liquid mixture portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção líquido de mistura</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more liquid phases at a defined point in a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000239">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab600"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Damper(x) ↔ (Assembly(x) ∧ ∃f (DampingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um amortecedor é um conjunto que possui a função projetada de suprimir, regular ou reduzir características dinâmicas desfavoráveis como vibrações, flutuações de pressão ou distúrbios de fluxo.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">damper</rdfs:label>
    <rdfs:label xml:lang="pt-br">amortecedor</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every damper is an assembly that bears a damping function, and every assembly that bears a damping function is a damper.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionMeasurementAndTransmissionProcess">
    <skos:definition xml:lang="en">A measurement process in which the position of a mechanical component is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de posição</rdfs:label>
    <rdfs:label xml:lang="en">position measurement and transmission process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1598">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1600"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ManualControlSignal">
    <skos:definition xml:lang="en">An information content entity constituting a control signal generated by an operator to adjust the set point or state of petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdfs:label xml:lang="pt-br">sinal manual de controle</rdfs:label>
    <rdfs:label xml:lang="en">manual control signal</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293">
    <skos:definition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Header(x) ↔ (manifold(x) ∧ ∃y(SmallPipe(y) ∧ connects_to(x,y)) ∧ ∃z(MultiStreamDistributionProcess(z) ∧ participatesIn(x,z))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">header</rdfs:label>
    <rdfs:label xml:lang="en">header</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Header ≡ manifold ⊓ ∃connects_to.SmallPipe ⊓ ∃participatesIn.MultiStreamDistributionProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um header é um manifold que se conecta a muitos tubos menores para coletar descarga de múltiplas fontes ou distribuir fluido para múltiplos destinos.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1427"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium.</skos:definition>
    <rdfs:label xml:lang="en">distillation column</rdfs:label>
    <rdfs:label xml:lang="pt-br">coluna de destilação</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de destilação é um separador que possui uma função de destilação para permitir a separação de misturas de fluidos baseada nas diferenças dos pontos de ebulição dos componentes através do equilíbrio vapor-líquido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab838"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every distillation column is a separator that has the function to perform distillation processes</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DistillationColumn(x) ↔ (Separator(x) ∧ ∃f (DistillationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a rotor transfers mechanical energy through its rotational motion, enabling the operation of rotating machinery such as motors, compressors, pumps, and turbines.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">rotational energy transfer process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transferência de energia rotacional</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a rotor transfers mechanical energy through its rotational motion, enabling the operation of rotating machinery such as motors, compressors, pumps, and turbines.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1164">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de transformação de energia elétrica</rdfs:label>
    <rdfs:label xml:lang="en">electrical power transformation process</rdfs:label>
    <skos:definition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1093"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab586"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1092"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab585"/>
    <rdfs:label xml:lang="pt-br">função de conexão</rdfs:label>
    <rdfs:label xml:lang="en">connection function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical or fluid joining of two or more components to allow the transfer of force, fluid, or signal between them.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContaminatedSurface">
    <rdfs:label xml:lang="en">contaminated surface</rdfs:label>
    <rdfs:label xml:lang="pt-br">superfície contaminado</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a surface bearing scale, deposits, or contaminants that are to be removed by a cleaning process in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1195"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeasuringElement(x) ↔ (MeasuringElement(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every FlowMeasuringElement is a MeasuringElement that bears a FlowMeasurementFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MeasuringElement que possui uma FlowMeasurementFunction e que é projetado para determinar e quantificar a taxa de fluxo de fluido através de um sistema.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">MeasuringElement que possui uma FlowMeasurementFunction e</rdfs:label>
    <rdfs:label xml:lang="en">flow measuring element</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the absorption of dimensional changes in piping or structures caused by variations in process temperature.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab986"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab987"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de acomodação de expansão térmica</rdfs:label>
    <rdfs:label xml:lang="en">thermal expansion accommodation function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab249">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess">
    <rdfs:label xml:lang="en">pumping process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de bombeamento</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which mechanical energy is imparted to a fluid to increase its pressure, velocity, or elevation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2374">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubeBundle"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1979">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353">
    <rdfs:label xml:lang="pt-br">atuador solenoide</rdfs:label>
    <rdfs:label xml:lang="en">solenoid actuator</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid actuator is an electric actuator that has a solenoid as component part and has a plunger as component part and converts electrical power to linear mechanical motion.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A solenoid actuator is an electric actuator that utilizes a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador solenoide é um atuador elétrico que utiliza um solenoide linear de serviço contínuo para converter energia elétrica em energia mecânica através de um êmbolo com curso axial em ação de empurrar ou puxar.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2414"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by solenoid mechanism. Under OWA, sufficient conditions would force any device with solenoid and plunger components to be classified as a solenoid actuator, potentially misclassifying complex hybrid devices or specialized equipment containing solenoid components but serving different primary functions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SolenoidActuator(x) → ElectricActuator(x) ∧ ∃s(Solenoid(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃p(Plunger(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A solenoid actuator is an electric actuator that utilizes a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331">
    <skos:definition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2060"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:label xml:lang="en">positive displacement pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba de deslocamento positivo</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every positive displacement pump is a pump that has a displacement mechanism as component part at all times and participates in positive displacement processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de deslocamento positivo é uma bomba que transporta líquido através do princípio de deslocamento alternativo ou rotativo com volume de deslocamento fixo por ciclo.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical mechanism. Under OWA, sufficient conditions based on displacement mechanism alone could lead to false positives where specialized equipment containing displacement elements might be incorrectly classified as standard positive displacement pumps.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PositiveDisplacementPump(x) → Pump(x) ∧ ∃y(DisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(PositiveDisplacementProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2215">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2216"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2379"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2378"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
    <rdfs:label xml:lang="pt-br">função de inspeção visual</rdfs:label>
    <rdfs:label xml:lang="en">visual inspection function</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000234">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every controller is an instrument that has the function to control a process variable by automatic feedback regulation</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</skos:definition>
    <rdfs:label xml:lang="pt-br">controlador</rdfs:label>
    <rdfs:label xml:lang="en">controller</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab543"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Controller(x) ↔ Instrument(x) ∧ ∃f(ControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um controlador é um instrumento que possui uma função de controle, regulando automaticamente uma variável controlada ao medi-la, comparar com um valor de referência e gerar sinais de saída para reduzir o desvio.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CompressorCasing(x) → (Casing(x) ∧ ∃y (Compressor(y) ∧ intendedForUseWith(x,y))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab506"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CompressorCasing ⊑ Casing ⊓ ∃intendedForUseWith.Compressor</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Invólucro que é destinado a abrigar componentes internos do compressor, incluindo o eixo com impulsores e outros componentes mecânicos específicos do compressor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, sufficient conditions for compressor-specific casing identity could lead to false positives where any enclosure intended for compressors might be classified as a standard compressor casing, including specialized or hybrid enclosures that warrant distinct classification.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">Invólucro</rdfs:label>
    <rdfs:label xml:lang="en">compressor casing</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1175">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab580">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000307">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(KettleReboiler(x) → Reboiler(x) ∧ ∃q(HorizontalOrientation(q) ∧ hasQuality(x,q)) ∧ ∃v(SeparateVapourSpace(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A kettle reboiler is a reboiler that has horizontal orientation and contains a separate vapour space for vapor-liquid disengagement.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by specific physical configuration. Under Open World Assumption, sufficient conditions could incorrectly classify equipment with horizontal orientation and vapor space but fundamentally different purposes (e.g., horizontal separators, flash drums) as kettle reboilers. The structural differentia provides necessary conditions for the kettle reboiler maintenance/procurement category.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1623"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1622"/>
    <rdfs:label xml:lang="pt-br">refervedor tipo kettle</rdfs:label>
    <rdfs:label xml:lang="en">kettle reboiler</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um refervedor tipo kettle é um refervedor que possui orientação horizontal e contém um espaço de vapor separado para desengajamento vapor-líquido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A kettle reboiler is a reboiler that has horizontal orientation and contains a separate vapour space for vapor-liquid disengagement.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every kettle reboiler is a reboiler that has horizontal orientation and has a separate vapour space as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpOutlet">
    <skos:definition xml:lang="en">A material artifact that constitutes the discharge outlet port through which pressurised fluid leaves a hydraulic pump in petroleum production hydraulic systems.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
    <rdfs:label xml:lang="pt-br">saída hidráulico de bomba</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic pump outlet</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PumpCasing(x) → Casing(x) ∧ ∃y(Impeller(y) ∧ surrounds(x,y)) ∧ ∃z(SuctionNozzle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃w(DischargeNozzle(w) ∧ hasComponentPartAtAllTimes(x,w)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2164"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under Open World Assumption, structural characteristics are harder to make sufficient - any assembly with an impeller and integral nozzles might be classified as a pump casing even if it serves a different specialized purpose. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">carcaça de bomba</rdfs:label>
    <rdfs:label xml:lang="en">pump casing</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que envolve um impulsor e possui bocais de sucção e descarga integrais como componentes estruturais, tipicamente aplicado em bombas centrífugas.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump casing is a casing that surrounds an impeller and has integral suction and discharge nozzles forming part of its structure.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000151">
    <skos:definition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</skos:definition>
    <skos:altLabel xml:lang="en">tank</skos:altLabel>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tanque de armazenamento é um vaso projetado para armazenar fluidos ou materiais por períodos prolongados sem transformação ou processamento ativo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2453"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">storage tank</rdfs:label>
    <rdfs:label xml:lang="pt-br">tanque de armazenamento</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every storage tank is a tank that has the function to store materials for extended periods.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(StorageTank(x) ↔ (Tank(x) ∧ ∃f(ExtendedStorageFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction">
    <rdfs:label xml:lang="en">density measurement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição de densidade</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab677"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab676"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the mass per unit volume of a fluid stream or substance.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000212">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">ânodo</rdfs:label>
    <rdfs:label xml:lang="en">anode</rdfs:label>
    <skos:definition xml:lang="en">An anode is electrical equipment that bears the function of serving as the positive electrode in electrochemical processes, capable of emitting positive charge carriers to and/or receiving negative charge carriers from a medium of lower conductivity.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ânodo é um equipamento elétrico que possui a função de servir como eletrodo positivo em processos eletroquímicos, capaz de emitir portadores de carga positiva para e/ou receber portadores de carga negativa de um meio de menor condutividade.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An anode is electrical equipment that bears the function of serving as the positive electrode in electrochemical processes, capable of emitting positive charge carriers to and/or receiving negative charge carriers from a medium of lower conductivity.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab98"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Anode(x) ↔ ElectricalEquipment(x) ∧ ∃f(AnodeFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every anode is electrical equipment that has the function of electrochemical oxidation and has electrical connection and active material as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000237">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coriolis mass flow meter is a flow meter that has component part at all times some Coriolis flow tube and utilizes the Coriolis principle.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão que utiliza o princípio de Coriolis através de tubos de fluxo oscilantes especializados para medir diretamente a vazão mássica de fluidos.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab584"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CoriolisMassFlowMeter(x) → FlowMeter(x) ∧ ∃y(CoriolisFlowTube(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CoriolisPrinciple(z) ∧ utilizesPhysicalPrinciple(x,z)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">medidor de vazão Coriolis</rdfs:label>
    <rdfs:label xml:lang="en">coriolis mass flow meter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under the Open World Assumption, defining sufficient conditions based on Coriolis principle usage could lead to false positives where other devices using Coriolis forces (like gyroscopes or accelerometers) might be incorrectly classified as flow meters. The structural differentia provides necessary conditions that can be validated by domain experts.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159">
    <rdfs:label xml:lang="en">vibration transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de vibração</rdfs:label>
    <skos:definition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2767"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de vibração é um transmissor que mede vibrações mecânicas e produz um sinal de saída proporcional aos parâmetros de vibração medidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vibration transmitter is a transmitter that has a vibration signal as input and bears a vibration measurement function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (VibrationTransmitter(x) ↔ (Transmitter(x) ∧ ∃v (VibrationSignal(v) ∧ hasInput(x,v)) ∧ ∃f (VibrationMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature measurement and transmission process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which process temperature is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2364">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignalTransmissionProcess">
    <rdfs:label xml:lang="pt-br">processo de transmissão de sinal de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure signal transmission process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
    <skos:definition xml:lang="en">A signal transmission process in which a standardised signal representing a measured pressure value is transmitted to a remote control or monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000349">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma polia é um artefato material que é uma roda sulcada projetada para transmitir energia mecânica através da interface com correias, cordas, cabos ou tubos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A sheave is a material artifact that is a grooved wheel designed to transmit mechanical power through interface with belts, ropes, wires, or pipes.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A sheave is a material artifact that is a grooved wheel designed to transmit mechanical power through interface with belts, ropes, wires, or pipes.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every sheave is a material artifact that has a grooved rim as component part and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">polia</rdfs:label>
    <rdfs:label xml:lang="en">sheave</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2367"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical structure. Under OWA, defining sufficient conditions based solely on having a grooved rim could lead to false positives where other grooved mechanical elements (like timing belt pulleys with different design intents) are automatically classified as sheaves. The structural differentia provides necessary conditions while allowing domain experts to confirm sufficient conditions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Sheave(x) → MaterialArtifact(x) ∧ ∃y(GroovedRim(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ExpandedGasPortion">
    <rdfs:label xml:lang="en">expanded gas portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção expandido de gás</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas that has undergone expansion and pressure reduction in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab434"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab433"/>
    <rdfs:label xml:lang="pt-br">função de análise cromatográfica</rdfs:label>
    <rdfs:label xml:lang="en">chromatographic analysis function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation and quantification of chemical components in a sample by differential migration through a stationary phase.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipelinePig">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:label xml:lang="pt-br">pig de pipeline</rdfs:label>
    <rdfs:label xml:lang="en">pipeline pig</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a device inserted into and propelled through a pipeline to perform internal inspection, cleaning, or gauging operations.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de indicação de nível</rdfs:label>
    <rdfs:label xml:lang="en">level indication function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1675"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1657"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1656"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1674"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the fluid level within a vessel.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab819">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivergingChannel"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2330">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2328"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2347">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShakingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab262">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab259"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat transfer plate is a MaterialArtifact that bears a HeatTransferFunction and participates in segregating two fluid media in a non-tubular heat exchanger.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma HeatTransferFunction e</rdfs:label>
    <rdfs:label xml:lang="en">heat transfer plate</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1448"/>
    <skos:definition xml:lang="en">A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis requires necessary conditions only. Under OWA, sufficient conditions for 'plate geometry used in non-tubular heat exchangers' could lead to false positives - other components with plate-like surfaces might be incorrectly classified as heat transfer plates without domain expert validation of the structural and application-specific criteria.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma HeatTransferFunction e que é destinado a ser usado em um trocador de calor não tubular para segregar dois meios fluidos enquanto facilita a transferência de energia térmica entre eles.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HeatTransferPlate(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MediaSeparationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207">
    <rdfs:label xml:lang="pt-br">atuador</rdfs:label>
    <rdfs:label xml:lang="en">actuator</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador é um conjunto que possui uma função de atuação para converter energia de uma fonte externa em movimento cinético em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Actuator(x) ↔ Assembly(x) ∧ ∃f (ActuationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab45"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every actuator is an assembly that has the function of converting external energy into controlled kinetic motion.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CableSupportFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab311"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab310"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">cable support function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de suporte de cabos</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical support and routing of cables to maintain their position and protect them from damage.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">fluid distribution process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de distribuição de fluido</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a fluid stream is split and delivered to multiple downstream points in defined proportions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000224">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab352"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing that is specifically designed and dimensioned for structural compatibility with centrifugal compressor mechanisms, providing enclosure and protection for rotating impellers and associated flow components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que é especificamente projetado e dimensionado para compatibilidade estrutural com mecanismos de compressor centrífugo, fornecendo contenção e proteção para impulsores rotativos e componentes de fluxo associados.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal compressor casing is a casing that is intended for use with centrifugal compressors</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A casing that is specifically designed and dimensioned for structural compatibility with centrifugal compressor mechanisms, providing enclosure and protection for rotating impellers and associated flow components.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural compatibility. Under OWA, asserting equivalence could force classification of any casing with centrifugal compressor compatibility, including hybrid or specialized equipment that should not be automatically classified as standard centrifugal compressor casings.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">centrifugal compressor casing</rdfs:label>
    <rdfs:label xml:lang="pt-br">invólucro</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalCompressorCasing(x) → Casing(x) ∧ ∃y(CentrifugalCompressor(y) ∧ intendedFor(x,y)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the flow rate of a process stream crosses a defined threshold.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de chaveamento de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow switching process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalEnergy">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes thermal energy transferred between a process stream and heat exchange surfaces of petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">energia térmico</rdfs:label>
    <rdfs:label xml:lang="en">thermal energy</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2373">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Shell"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266">
    <skos:definition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1031"/>
    <rdfs:label xml:lang="en">filter cartridge</rdfs:label>
    <rdfs:label xml:lang="pt-br">cartucho de filtro</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportFunction">
    <rdfs:label xml:lang="en">fluid transport function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transporte de fluido</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1959"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1249"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1250"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1960"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conveyance of a fluid over distance by exploiting pressure differentials, gravity, or imparted energy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1027">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab796">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab797"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1679">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1519">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000291">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe valve body is a valve body that has globular geometry for perpendicular flow path accommodation.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve body that has a globular geometry designed to accommodate the perpendicular flow path and disc closure mechanism characteristic of globe valve operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que possui geometria globular projetada para acomodar o caminho de fluxo perpendicular e o mecanismo de fechamento por disco característico da operação de válvula globo.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A valve body that has a globular geometry designed to accommodate the perpendicular flow path and disc closure mechanism characteristic of globe valve operation.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural geometry. Under OWA, asserting equivalence based on globular geometry alone could lead to false classifications of complex assemblies or hybrid components that contain globular elements but should not be classified as standard globe valve bodies.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1408"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GlobeValveBody(x) → ValveBody(x) ∧ ∃g (GlobularGeometry(g) ∧ hasDesignCharacteristic(x,g)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">corpo de válvula globo</rdfs:label>
    <rdfs:label xml:lang="en">globe valve body</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlProcess">
    <rdfs:label xml:lang="en">electrical circuit control process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de controle de circuito elétrico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which current in an electrical circuit is switched, routed, or regulated to control connected loads.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de vaporização flash</rdfs:label>
    <rdfs:label xml:lang="en">flash vaporization process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a pressurised liquid stream is partially vaporised as a result of a rapid reduction in pressure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab142">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2804">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000301">
    <rdfs:label xml:lang="en">hydrocyclone</rdfs:label>
    <rdfs:label xml:lang="pt-br">hidrociclone</rdfs:label>
    <skos:definition xml:lang="en">A hydrocyclone is a separator that separates fluid mixtures using centrifugal forces generated by tangential flow through a conical chamber.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um hidrociclone é um separador que separa misturas de fluidos usando forças centrífugas geradas por fluxo tangencial através de uma câmara cônica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hydrocyclone is a separator that separates fluid mixtures using centrifugal forces generated by tangential flow through a conical chamber.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Hydrocyclone(x) ↔ Separator(x) ∧ ∃c(ConicalSection(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃p(CentrifugalSeparationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1540"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydrocyclone is a separator that has a conical section as component part at all times and participates in centrifugal separation processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000286">
    <rdfs:label xml:lang="pt-br">turbina a gás</rdfs:label>
    <rdfs:label xml:lang="en">gas turbine</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma turbina a gás é uma turbina que possui um compressor e câmara de combustão integrados, projetada para comprimir ar ambiente, misturá-lo com combustível para combustão, e expandir os gases quentes resultantes através de uma seção de turbina para gerar energia mecânica.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1313"/>
    <skos:definition xml:lang="en">A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas turbine is a turbine that has component parts compressor and combustion chamber at all times, and participates in air compression process and fuel combustion process.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GasTurbine(x) ↔ Turbine(x) ∧ ∃c,h(Compressor(c) ∧ CombustionChamber(h) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃p1,p2(AirCompressionProcess(p1) ∧ FuelCombustionProcess(p2) ∧ participatesIn(x,p1) ∧ participatesIn(x,p2)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilteredContaminants">
    <rdfs:label xml:lang="en">filtered contaminants</rdfs:label>
    <rdfs:label xml:lang="pt-br">contaminantes filtrado</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the solid or liquid contaminants captured and retained by a filter medium during a filtration process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220">
    <iof-av:naturalLanguageDefinition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador é um aquecedor que libera energia térmica através da queima de uma mistura combustível de combustível e ar.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Burner(x) ↔ (Heater(x) ∧ ∃f (CombustionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every burner is a heater that has the function of combustion, which is realized by burning a fuel-air mixture to release thermal energy.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">queimador</rdfs:label>
    <rdfs:label xml:lang="en">burner</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab277"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000308">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso separador de condensado é um separador projetado para separar quantidades relativamente pequenas de líquido de uma corrente de vapor através de separação de fases gravitacional e baseada em momento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every knock out drum is a separator that bears a knock out separation function, which is realized in processes that separate small quantities of liquid from vapor streams.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(KnockOutDrum(x) ↔ Separator(x) ∧ ∃f(KnockOutSeparationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">vaso separador de condensado</rdfs:label>
    <rdfs:label xml:lang="en">knock out drum</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1629"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000228">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every christmas tree is an assembly that has the function to control well fluids and is connected to a wellhead and has master valves as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">christmas tree</rdfs:label>
    <rdfs:label xml:lang="pt-br">árvore de natal</rdfs:label>
    <skos:definition xml:lang="en">A christmas tree is an assembly that bears a well fluid control function, is connected to a wellhead, and contains master valves for controlling formation fluids from oil and gas wells.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab416"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000228"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma árvore de natal é um conjunto que possui uma função de controle de fluidos de poço, está conectada a uma cabeça de poço, e contém válvulas mestras para controlar fluidos de formação de poços de petróleo e gás.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A christmas tree is an assembly that bears a well fluid control function, is connected to a wellhead, and contains master valves for controlling formation fluids from oil and gas wells.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ChristmasTree(x) ↔ (Assembly(x) ∧ ∃f(WellFluidControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ hasComponentPartAtAllTimes(x,w)) ∧ ∃v(MasterValve(v) ∧ hasComponentPartAtAllTimes(x,v))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the separation of phases of differing densities by the action of gravity in a settling vessel.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1409"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1410"/>
    <rdfs:label xml:lang="en">gravity separation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de separação gravitacional</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2149">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2395">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de transmissão de múltiplos serviços</rdfs:label>
    <rdfs:label xml:lang="en">multi service transmission process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which multiple process variables are simultaneously measured and their corresponding signals transmitted to a remote control or monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100">
    <skos:definition xml:lang="en">A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every butterfly valve is a valve that has a disc-type closure member and has a transverse rotation axis.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">válvula borboleta</rdfs:label>
    <rdfs:label xml:lang="en">butterfly valve</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula borboleta é uma válvula que possui um membro de fechamento tipo disco com haste paralela ao plano do disco e eixo de rotação transversal à direção do fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab300"/>
    <iof-av:primitiveRationale xml:lang="en">This is a constructive classification based on physical mechanism. Under the Open World Assumption, any artifact with a disc-type closure and transverse rotation axis would be forced into the ButterflyValve class, including specialized hybrid equipment or custom manifolds containing butterfly mechanisms that should not be classified as standard butterfly valves for maintenance purposes.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ButterflyValve(x) → Valve(x) ∧ ∃y(DiscTypeClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(TransverseRotationAxis(z) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000320">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PigTrap(x) ↔ Assembly(x) ∧ ∃f(PigLaunchingAndReceivingFunction(f) ∧ bearerOf(x,f)) ∧ ∃l(PigLauncher(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃r(PigReceiver(r) ∧ hasComponentPartAtAllTimes(x,r)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A pig trap is an assembly that bears the function of launching and receiving pipe pigs for pipeline maintenance and has both launcher and receiver components.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1898"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig trap is an assembly that bears a pig launching and receiving function and has component parts that are a pig launcher and a pig receiver.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">pig trap</rdfs:label>
    <rdfs:label xml:lang="pt-br">armadilha de pig</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig trap is an assembly that bears the function of launching and receiving pipe pigs for pipeline maintenance and has both launcher and receiver components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma armadilha de pig é um conjunto que possui a função de lançar e receber pigs de tubulação para manutenção de dutos e possui componentes de lançador e receptor.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000277">
    <skos:definition xml:lang="en">A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where flexibility is a material/structural property. Under OWA, asserting equivalence would force any pipe with flexible qualities to be classified as a flexible riser, even if it serves different functions or has different deployment contexts. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flexible riser is a riser that has a flexible property</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um riser flexível é um riser que possui construção de material flexível permitindo condução de fluido vertical ou quase vertical entre o fundo do mar e a superfície, acomodando o movimento da embarcação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlexibleRiser(x) → Riser(x) ∧ ∃q(FlexibleProperty(q) ∧ hasQuality(x,q)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1168"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339"/>
    <rdfs:label xml:lang="pt-br">riser flexível</rdfs:label>
    <rdfs:label xml:lang="en">flexible riser</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2499">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2500"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2494"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab68">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1303">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1249">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InLineFilter">
    <skos:definition xml:lang="en">An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical installation configuration. Under OWA, any filter with in-line connections and piping support could be classified as in-line filter, but specialized hybrid equipment or custom installations might have these features without belonging to the standard in-line filter maintenance category. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1555"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every in-line filter is a filter that has an in-line installation method and is supported by connected equipment.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">filtro em linha</rdfs:label>
    <rdfs:label xml:lang="en">in line filter</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro em linha é um filtro que é instalado diretamente dentro de uma linha de fluido e suportado por tubulações ou equipamentos conectados, projetado para remover partículas ou contaminantes de correntes de fluido durante operações normais de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (InLineFilter(x) → Filter(x) ∧ ∃m,e (InLineInstallation(m) ∧ ConnectedEquipment(e) ∧ hasInstallationMethod(x,m) ∧ supportedBy(x,e)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab221">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab223"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab480">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1373">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000296">
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical properties (flexibility). Under OWA, asserting equivalence would force any artifact with flexibility and pressure capability to be classified as a hose, potentially including complex equipment with flexible components that should not be categorized as standard hoses.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma mangueira é um tubo flexível projetado para conduzir líquidos sob pressão enquanto acomoda movimento posicional e flexão.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</skos:definition>
    <rdfs:label xml:lang="pt-br">mangueira</rdfs:label>
    <rdfs:label xml:lang="en">hose</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hose is a pipe that has flexibility and is capable of conducting liquids under pressure.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1473"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Hose(x) → Pipe(x) ∧ ∃q(Flexibility(q) ∧ hasQuality(x,q)) ∧ ∃c(PressurizedFluidConduction(c) ∧ capableOf(x,c)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000248">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador de diafragma é um atuador que utiliza um diafragma como componente essencial para converter sinais de controle em movimento mecânico ou força para operar outros equipamentos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diaphragm actuator is an actuator that uses a diaphragm as an essential component for converting control signals into mechanical motion or force to operate other equipment.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">diaphragm actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador de diafragma</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab727"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DiaphragmActuator(x) → (Actuator(x) ∧ ∃y(Diaphragm(y) ∧ hasComponentPartAtAllTimes(x,y))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A diaphragm actuator is an actuator that uses a diaphragm as an essential component for converting control signals into mechanical motion or force to operate other equipment.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Classification basis is constructive - identity given by diaphragm mechanism. Under OWA, sufficient conditions would force any equipment with a diaphragm component to be classified as a diaphragm actuator, potentially including complex hybrid systems or custom equipment where the diaphragm serves auxiliary functions. Starting with necessary conditions protects against such false positives.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DiaphragmActuator ⊑ Actuator ⊓ ∃hasComponentPartAtAllTimes.Diaphragm</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DampingFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab596"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab597"/>
    <rdfs:label xml:lang="pt-br">função de amortecimento</rdfs:label>
    <rdfs:label xml:lang="en">damping function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the absorption and dissipation of mechanical energy to reduce the amplitude of oscillations or vibrations.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2529"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador de temperatura é um indicador que mede temperatura e exibe o valor medido localmente na localização do instrumento.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">indicador de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature indicator</rdfs:label>
    <skos:definition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature indicator is an instrument that has the function of temperature indication and has component parts including a temperature sensing element and a local display.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (TemperatureIndicator(x) ↔ (Instrument(x) ∧ ∃f (TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃s (TemperatureSensingElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃d (LocalDisplay(d) ∧ hasComponentPartAtAllTimes(x,d))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">indicador de controle</rdfs:label>
    <rdfs:label xml:lang="en">control indicator</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a component that displays and enables adjustment of a set point or control parameter in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab835">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell stem is a fiat object part that is part of some thermowell and has hollow cylindrical shape and is located in process medium intrusion zone.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2573"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis. The structural differentia (hollow cylindrical shape, positioning in process medium) is necessary but may not be sufficient under OWA - there could be other specialized parts of thermowells with similar geometry but different specific roles or configurations.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um termowell stem é uma parte de objeto fiducial que é parte de um termowell e que tem uma forma cilíndrica oca posicionada para se projetar no meio do processo, fornecendo habitação protetora para elementos de detecção de temperatura enquanto permite condução térmica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">termowell stem</rdfs:label>
    <rdfs:label xml:lang="en">thermowell stem</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThermowellStem(x) → FiatObjectPart(x) ∧ ∃y(Thermowell(y) ∧ partOf(x,y)) ∧ ∃q(HollowCylindricalShape(q) ∧ hasQuality(x,q)) ∧ ∃l(ProcessMediumIntrusionZone(l) ∧ hasLocation(x,l)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165">
    <rdfs:label xml:lang="en">emergency shut down function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de parada de emergência</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab965"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab966"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic isolation of process equipment upon detection of a hazardous condition.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparateVapourSpace">
    <skos:definition xml:lang="en">A material artifact that constitutes a distinct vapour space within petroleum production equipment where disengaged gas accumulates above the liquid level.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">separate vapour space</rdfs:label>
    <rdfs:label xml:lang="pt-br">espaço separado de vapor</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142">
    <skos:definition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</skos:definition>
    <rdfs:label xml:lang="en">pressure element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de pressão</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureElement(x) ↔ DetectingElement(x) ∧ ∃f(PressureSensingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão é um instrumento que possui uma função de detecção de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2080"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure element is a detecting element that has the function of sensing pressure</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1657">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2707">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de desumidificação</rdfs:label>
    <rdfs:label xml:lang="en">dehumidification function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of water vapour from a gas stream to reduce its relative humidity or dew point.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab634"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab635"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab694">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipePig">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a device propelled through a pipeline by the flow of product to perform internal inspection, cleaning, or product separation.</skos:definition>
    <rdfs:label xml:lang="pt-br">pig de tubo</rdfs:label>
    <rdfs:label xml:lang="en">pipe pig</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2169">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab563"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab551"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab550"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab564"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of thermal energy from a process stream or equipment component to reduce its temperature.</skos:definition>
    <rdfs:label xml:lang="en">cooling function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de resfriamento</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab489">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab584">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000099">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every butterfly control valve is a valve that has-component-part-at-all-times some rotating disc and has-component-part-at-all-times some actuator and bearer-of some process-controlled flow function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ButterflyControlValve(x) → Valve(x) ∧ ∃d(RotatingDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(Actuator(a) ∧ hasComponentPartAtAllTimes(x,a)) ∧ ∃f(ProcessControlledFlowFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula borboleta de controle é uma válvula de controle que possui um mecanismo de fechamento por disco rotativo e possui uma função de fluxo controlado por processo, permitindo modulação automatizada do fluxo em resposta a sinais de controle externos.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab285"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab286"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <skos:definition xml:lang="en">A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">This is a constructive type that combines two existing differentia (butterfly mechanism + control function). Under OWA, providing sufficient conditions could lead to false positives where any valve with both a rotating disc and control capability would be classified as this specific type, even if it has additional specialized features or hybrid mechanisms.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">butterfly control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula borboleta de controle</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000096">
    <rdfs:label xml:lang="en">block and bleed valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de bloqueio e sangria</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de bloqueio e sangria é uma válvula que possui um assento que fornece vedação, e uma linha de sangria e válvula que são conectadas ao castelo da válvula para ventilação controlada da pressão a jusante.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BlockAndBleedValve(x) → Valve(x) ∧ ∃s(SingleSeat(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃l(BleederLine(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃v(BleederValve(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every block and bleed valve is a valve that has component parts: exactly one seat, a bleeder line, and a bleeder valve integrated into the bonnet.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive types require necessary conditions only due to Open World Assumption. The structural differentia (single seat + bleeder system) could theoretically be present in specialized equipment that should not be classified as a standard block and bleed valve without domain expert validation.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab215"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolantPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="en">coolant portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de refrigerante</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of cooling medium used to remove thermal energy from a process stream or equipment component.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess">
    <rdfs:label xml:lang="pt-br">processo de aquecimento</rdfs:label>
    <rdfs:label xml:lang="en">heating process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which thermal energy is transferred to a process stream or vessel to raise its temperature.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219">
    <skos:definition xml:lang="en">A brake is an assembly that bears a braking function to arrest or prevent the motion of an object, typically through friction or electromagnetic force application.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um freio é um conjunto que possui uma função de frenagem para deter ou prevenir o movimento de um objeto, tipicamente através da aplicação de força de atrito ou eletromagnética.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A brake is an assembly that bears a braking function to arrest or prevent the motion of an object, typically through friction or electromagnetic force application.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every brake is an assembly that has the function of braking, and every assembly that has the function of braking is a brake.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">brake</rdfs:label>
    <rdfs:label xml:lang="pt-br">freio</rdfs:label>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Brake(x) ↔ (Assembly(x) ∧ ∃f(BrakingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab267"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de componente estacionário de máquina</rdfs:label>
    <rdfs:label xml:lang="en">stationary machine component process</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a stator maintains its fixed position relative to rotating components within machinery, providing structural support and housing for electromagnetic windings, guide vanes, or other functional elements that require stable positioning.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A PlannedProcess in which a stator maintains its fixed position relative to rotating components within machinery, providing structural support and housing for electromagnetic windings, guide vanes, or other functional elements that require stable positioning.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117">
    <rdfs:label xml:lang="pt-br">indicador de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow indicator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FlowIndicator(x) ↔ (Instrument(x) ∧ ∃f(FlowIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FlowMeasuringElement(e) ∧ hasComponentPartAtSomeTime(x,e)) ∧ ∃d(DisplayElement(d) ∧ hasComponentPartAtAllTimes(x,d))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1182"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador de fluxo é um indicador projetado para indicar taxas de fluxo usando um elemento de medição de fluxo e elemento de exibição.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow indicator is an instrument that bears a flow indication function and has a flow measuring element and display element as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MassFlowRateSignal">
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the mass flow rate of a process stream as measured by petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdfs:label xml:lang="pt-br">sinal de massa de fluxo de taxa</rdfs:label>
    <rdfs:label xml:lang="en">mass flow rate signal</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150">
    <skos:definition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type where the solenoid mechanism is the distinguishing structural feature. Under OWA, making it equivalent could incorrectly classify complex valve assemblies that contain solenoid components but are not standard solenoid valves.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">válvula solenoide</rdfs:label>
    <rdfs:label xml:lang="en">solenoid valve</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula solenoide é uma válvula que possui um atuador solenoide para controle elétrico do fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (SolenoidValve(x) → Valve(x) ∧ ∃s (SolenoidActuator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f (ElectricalControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2421"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2420"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid valve is a valve that has a solenoid actuator component and bears an electrical control function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab609">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab611"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab597">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DampingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab772"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab782"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab773"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab783"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PressureSensingFunction that is realized in a DifferentialPressureMeasurementProcess and that consists in sensing the pressure difference between two fluid media or two points in the same medium to enable measurement of differential pressure.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A PressureSensingFunction that is realized in a DifferentialPressureMeasurementProcess and that consists in sensing the pressure difference between two fluid media or two points in the same medium to enable measurement of differential pressure.</skos:definition>
    <rdfs:label xml:lang="en">differential pressure measurement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição de pressão diferencial</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab680">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab682"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1262">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1263"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SpacingFunction">
    <rdfs:label xml:lang="en">spacing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de espaçamento</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2426"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2425"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the maintenance of a defined spatial separation between components to ensure correct alignment, clearance, or insulation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReboilingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1615"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1616"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">reboiling function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de refervimento</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the partial vaporisation of liquid at the base of a distillation column by supplying heat to drive vapour upward through the column.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionProcess">
    <rdfs:label xml:lang="pt-br">processo de combustão de resíduos</rdfs:label>
    <rdfs:label xml:lang="en">waste combustion process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which waste gases, liquids, or solids are thermally destroyed by controlled combustion in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000316">
    <iof-av:naturalLanguageDefinition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um bocal é um artefato material que possui uma parte protuberante com um orifício moldado projetado para direcionar o fluxo de fluido em um padrão específico.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1820"/>
    <skos:definition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every nozzle is a material artifact that bears a fluid direction function and has a shaped orifice and protruding part as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">bocal</rdfs:label>
    <rdfs:label xml:lang="en">nozzle</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Nozzle(x) ↔ MaterialArtifact(x) ∧ ∃f(FluidDirectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃o(ShapedOrifice(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃p(ProtrudingPart(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestFunction">
    <rdfs:label xml:lang="en">flame arrest function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de contenção de chama</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the prevention of flame propagation through a flammable gas mixture by quenching the flame front in narrow passages.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1073"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1074"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1416">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1414"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1072">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1070"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000256">
    <skos:definition xml:lang="en">A diverter is a material artifact that bears a designed function to divert or redirect materials, fluids, or flows from their expected course to alternative paths or destinations.</skos:definition>
    <rdfs:label xml:lang="pt-br">diverter</rdfs:label>
    <rdfs:label xml:lang="en">diverter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diverter is a material artifact that bears a designed function to divert or redirect materials, fluids, or flows from their expected course to alternative paths or destinations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um diverter é um artefato material que possui uma função projetada para desviar ou redirecionar materiais, fluidos ou fluxos de seu curso esperado para caminhos ou destinos alternativos.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab852"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diverter is a material artifact that has the function of diverting materials or flows from expected paths to alternative destinations.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Diverter(x) ↔ MaterialArtifact(x) ∧ ∃f(DivertingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135">
    <rdfs:label xml:lang="en">on off control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle liga-desliga</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(OnOffControlValve(x) ↔ ControlValve(x) ∧ ∃f(BinaryFlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1832"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle liga-desliga é uma válvula de controle que possui uma função de controle de fluxo binária, tendo apenas duas posições definidas: totalmente aberta e totalmente fechada.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every on-off control valve is a control valve that has a BinaryFlowControlFunction and has component part a BinaryPositioner.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2500">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2501"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2495"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab835"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2697"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab834"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2698"/>
    <rdfs:label xml:lang="pt-br">função de destilação</rdfs:label>
    <rdfs:label xml:lang="en">distillation function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation of a liquid mixture into fractions of differing volatilities by successive vaporisation and condensation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1478"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An Assembly that bears both an EnclosureFunction and a SupportFunction, providing protective boundaries around internal components while structurally supporting them.</skos:definition>
    <rdfs:label xml:lang="en">housing</rdfs:label>
    <rdfs:label xml:lang="pt-br">carcaça</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Housing SubClassOf Assembly and (bearerOf some EnclosureFunction) and (bearerOf some SupportFunction)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions would force any assembly with enclosure and support functions to be classified as a standard housing, potentially misclassifying specialized equipment with housing-like properties but different maintenance categories.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Housing(x) → Assembly(x) ∧ ∃f₁(EnclosureFunction(f₁) ∧ bearerOf(x,f₁)) ∧ ∃f₂(SupportFunction(f₂) ∧ bearerOf(x,f₂)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears both an EnclosureFunction and a SupportFunction, providing protective boundaries around internal components while structurally supporting them.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que possui tanto uma EnclosureFunction quanto uma SupportFunction, fornecendo limites protetivos ao redor de componentes internos enquanto os suporta estruturalmente.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction">
    <rdfs:label xml:lang="en">reactive heating function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de aquecimento reativo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1254"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1255"/>
    <skos:definition xml:lang="en">A heating function borne by petroleum production equipment whose realization constitutes the generation and transfer of thermal energy through an exothermic chemical reaction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess">
    <rdfs:label xml:lang="en">flow indication process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de indicação de fluxo</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the instantaneous flow rate of a process stream is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078">
    <skos:definition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve body is a valve component that contains and supports valve working components and bears the function of fluid and pressure containment.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">valve body</rdfs:label>
    <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2721"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ValveBody(x) → ValveComponent(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃y(WorkingComponent(y) ∧ houses(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type - the structural characteristics of being the main pressure-containing housing component are necessary conditions but may not be sufficient under OWA, as various specialized valve body configurations exist that might contain additional components or have hybrid designs that could lead to false positive classifications.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ValveComponent que porta uma ContainmentFunction e que serve como o principal componente de contenção de fluido e pressão de uma válvula, alojando e suportando os componentes de trabalho.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionFunction">
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a ForceTransmissionProcess and that consists in transmitting mechanical force or motion from one component to another through direct physical coupling.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2733"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2734"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">force transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de força</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a ForceTransmissionProcess and that consists in transmitting mechanical force or motion from one component to another through direct physical coupling.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalRotation">
    <rdfs:label xml:lang="en">mechanical rotation</rdfs:label>
    <rdfs:label xml:lang="pt-br">rotação mecânico</rdfs:label>
    <skos:definition xml:lang="en">A process in which the angular motion of a rotating component about its axis in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction">
    <rdfs:label xml:lang="en">actuation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de atuação</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2411"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2004"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2410"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2005"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2226"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab913"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab724"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab40"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab41"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab723"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1498"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1497"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1757"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2225"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab912"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1756"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000374">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VesselShell(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃f(PressureContainmentFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma parte de objeto por fiat que é o limite estrutural externo de contenção de pressão de um vaso, projetada para encerrar e isolar o conteúdo interno enquanto suporta cargas de pressão interna.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">vessel shell</rdfs:label>
    <rdfs:label xml:lang="pt-br">parte de objeto por fiat</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural configuration as outer pressure-containing part of vessel. Under Open World Assumption, sufficient conditions are difficult to establish - other structural components might also be pressure-containing parts of vessels in specialized designs.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2762"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">VesselShell SubClassOf: FiatObjectPart and partOf some Vessel and bearerOf some PressureContainmentFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280">
    <skos:definition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</skos:definition>
    <rdfs:label xml:lang="en">flowline</rdfs:label>
    <rdfs:label xml:lang="pt-br">linha de fluxo</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flowline is a pipeline that bears a fluid transport function, has a wellhead connection, has a manifold or production facility connection, and transports hydrocarbon fluids.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flowline(x) ↔ Pipeline(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ connectsDirectly(x,w)) ∧ ∃m((Manifold(m) ∨ ProductionFacility(m)) ∧ connectsDirectly(x,m)) ∧ ∃h(HydrocarbonFluid(h) ∧ hasInput(x,h)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma linha de fluxo é um duto que transporta óleo, gás ou água diretamente de uma cabeça de poço para um manifold ou instalação de produção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1253"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="en">gas portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de gás</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas at a defined point in a petroleum production process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2833">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2830"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1632">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1630"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi">
    <dcterms:publisher xml:lang="en">Universidade Federal do Rio Grande do Sul (UFRGS)</dcterms:publisher>
    <dcterms:contributor>Régis Romeu</dcterms:contributor>
    <dcterms:contributor>Haroldo Rojas</dcterms:contributor>
    <dcterms:contributor>Rafael Petry</dcterms:contributor>
    <dcterms:contributor>Cauã Antunes</dcterms:contributor>
    <dcterms:contributor>Mara Abel</dcterms:contributor>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <dcterms:isPartOf rdf:resource="https://inf.ufrgs.br/projetos/OntoKG"/>
    <dcterms:title xml:lang="pt">Ontologia Central de Plantas de Produção de Petróleo (COPI)</dcterms:title>
    <dcterms:title xml:lang="en">Core Ontology for Petroleum Installations (COPI)</dcterms:title>
    <skos:scopeNote xml:lang="en">Material artifacts (bfo:material_entity) that (i) are part of a petroleum production plant, and (ii) bear at least one function whose realization involves the transport (e.g. production and injection), processing (separation and other processes), control, monitoring, measurement, containment or offloading of material or energy.</skos:scopeNote>
    <skos:scopeNote xml:lang="en">COPI provides high-level equipment categories defined by function to demonstrate the defined-class mechanism. Equipment subtypes are annotated with references to CFIHOS and PCA RDL terms. COPI is not a reference data library; organizations should use CFIHOS, PCA RDL, or ISO 14224 for comprehensive equipment classification.</skos:scopeNote>
    <skos:scopeNote xml:lang="pt-br">Artefatos materiais (bfo:material_entity) que (i) fazem parte de uma planta de produção de petróleo, e (ii) possuem ao menos uma função cuja realização envolve o transporte (p. ex. produção e injeção), processamento (separação e outros processos), controle, monitoramento, medição, contenção ou escoamento de material ou energia.</skos:scopeNote>
    <skos:scopeNote xml:lang="pt-br">COPI fornece categorias de alto nível de equipamentos definidas por função para demonstrar o mecanismo de classe definida. Os subtipos de equipamentos são anotados com referências aos termos do CFIHOS e do PCA RDL. COPI não é uma biblioteca de dados de referência; organizações devem utilizar o CFIHOS, o PCA RDL ou a ISO 14224 para classificação abrangente de equipamentos.</skos:scopeNote>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-08</dcterms:created>
    <apv:ClassURIFormationRule>https://www[.]inf[.]ufrgs[.]br/ontologies/copi/(COPI_[0-9]{7}|[A-Z][A-Za-z0-9]*)</apv:ClassURIFormationRule>
    <owl:imports rdf:resource="http://purl.obolibrary.org/obo/bfo/2020/bfo.owl"/>
    <owl:imports rdf:resource="https://spec.industrialontologies.org/ontology/core/Core/"/>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-29</dcterms:modified>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:creator xml:lang="en">Nicolau Oyhenard dos Santos</dcterms:creator>
    <dcterms:description xml:lang="en">BFO/IOF-Core conformant ontology of equipment classes for petroleum production plants, developed using the four-step RDL enrichment method.</dcterms:description>
    <apv:ClassMinAnnotationCoverage>rdfs:label</apv:ClassMinAnnotationCoverage>
    <owl:versionInfo>1.1.0-82-g14c910d</owl:versionInfo>
    <apv:GlobalMinLanguageCoverage>en pt-br</apv:GlobalMinLanguageCoverage>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000111">
    <iof-av:primitiveRationale xml:lang="en">Constructive basis - the structural differentia (dual seats plus bleed port) defines necessary conditions, but under OWA we cannot assert that ANY artifact with these structural components is definitively a double block and bleed valve, as specialized multi-way valves or custom manifolds might contain similar mechanisms without being standard maintenance categories.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab861"/>
    <rdfs:label xml:lang="en">double block and bleed valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de bloqueio duplo e sangria</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DoubleBlockAndBleedValve(x) → (Valve(x) ∧ ∃p,s,b (PrimarySeat(p) ∧ SecondarySeat(s) ∧ BleedPort(b) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,b))))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de bloqueio duplo e sangria é uma válvula que incorpora duas sedes, cada uma proporcionando capacidade de vedação, e inclui um meio de ventilação do espaço entre as sedes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every double block and bleed valve is a valve that has a primary seat and has a secondary seat and has a bleed port.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tubo é um artefato material caracterizado por geometria tubular e extensão longitudinal, projetado para conduzir materiais líquidos, gasosos ou sólidos finamente divididos de um local para outro, ou para servir a propósitos estruturais.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Pipe(x) → MaterialArtifact(x) ∧ ∃f(FluidConductionFunction(f) ∧ hasFunction(x,f)) ∧ ∃g(TubularGeometry(g) ∧ hasPhysicalProperty(x,g)) ∧ ∃h(LongitudinalExtent(h) ∧ hasPhysicalProperty(x,h)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes.</skos:definition>
    <rdfs:label xml:lang="pt-br">tubo</rdfs:label>
    <rdfs:label xml:lang="en">pipe</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe is a material artifact that has fluid conduction function and has tubular geometry and has longitudinal extent.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because pipe is defined by constructive/geometric properties (tubular geometry, longitudinal extent) rather than purely functional criteria. Under Open World Assumption, asserting sufficient conditions based on geometric properties could lead to unintended classification of complex tubular structures that happen to conduct fluids but should not be categorized as standard pipes.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1919"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke valve is a valve that bears a pressure reduction function and has a flow restriction element as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">choke valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula choke</rdfs:label>
    <skos:definition xml:lang="en">A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula choke é uma válvula que possui uma função de redução de pressão, projetada para reduzir a pressão do fluido da entrada para a saída através de restrição controlada do fluxo e dissipação de energia.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ChokeValve(x) ↔ (Valve(x) ∧ ∃f (PressureReductionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab408"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationProcess">
    <rdfs:label xml:lang="en">movement compensation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de compensação de movimentação</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which relative movement between connected components caused by thermal expansion, vibration, or settlement is accommodated without transmitting excessive stress.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000254">
    <iof-av:naturalLanguageDefinition xml:lang="en">A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Display é um Instrumento que possui uma InformationDisplayFunction e que apresenta informações visualmente para operadores ou usuários.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">display</rdfs:label>
    <rdfs:label xml:lang="pt-br">display</rdfs:label>
    <skos:definition xml:lang="en">A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Display is an Instrument that necessarily bears an InformationDisplayFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab830"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Display(x) ↔ Instrument(x) ∧ ∃f(InformationDisplayFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measurement process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1435">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1437"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HumidityMeasurementProcess">
    <rdfs:label xml:lang="pt-br">processo de medição de umidade</rdfs:label>
    <rdfs:label xml:lang="en">humidity measurement process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the moisture content or relative humidity of a gas stream is measured by petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2097">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2099"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2598">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab62">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</skos:definition>
    <rdfs:label xml:lang="en">plate heat exchanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">trocador de calor de placas</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1987"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1988"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de placas é um trocador de calor que possui placas de transferência de calor como sua superfície primária de transferência de calor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the plate-based structure is characteristic, under the Open World Assumption, asserting equivalence could lead to false positives where any equipment with heat transfer plates (e.g., specialized hybrid equipment, multi-function process units) would be automatically classified as a standard plate heat exchanger. Domain expert validation is needed to confirm the structural differentia is sufficient.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every plate heat exchanger is a heat exchanger that has component part heat transfer plates at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PlateHeatExchanger(x) → HeatExchanger(x) ∧ ∃p(HeatTransferPlate(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1404">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab522">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab524"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementProcess">
    <rdfs:label xml:lang="en">density measurement process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição de densidade</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the mass per unit volume of a fluid stream or substance is measured by petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab958">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess">
    <rdfs:label xml:lang="pt-br">processo de transporte de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid transport process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a fluid is conveyed over distance by exploiting pressure differentials, gravity, or energy imparted by petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1462">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245">
    <skos:definition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab680"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um densitômetro é um instrumento que possui uma função de medição de densidade.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every densitometer is an instrument that has the function of measuring density.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">densitômetro</rdfs:label>
    <rdfs:label xml:lang="en">densitometer</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingFunction">
    <rdfs:label xml:lang="pt-br">função de chaveamento de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow switching function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1222"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1223"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the flow rate of a process stream crosses a defined threshold.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab394">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AgitationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">agitation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de agitação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a liquid is mechanically stirred or agitated to promote mixing, heat transfer, or suspension of solids in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationProcess">
    <rdfs:label xml:lang="pt-br">processo de acomodação de expansão térmica</rdfs:label>
    <rdfs:label xml:lang="en">thermal expansion accommodation process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which dimensional changes in piping or structures caused by variations in process temperature are absorbed without transmitting excessive stress to connected equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab697">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab700"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementProcess">
    <skos:definition xml:lang="en">A PlannedProcess in which a differential pressure measuring element senses the pressure difference between two fluid inputs, producing a mechanical deflection or signal proportional to the differential pressure for measurement purposes.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de medição de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure measurement process</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a differential pressure measuring element senses the pressure difference between two fluid inputs, producing a mechanical deflection or signal proportional to the differential pressure for measurement purposes.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000289">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1363"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1364"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <skos:definition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de engrenagem é uma bomba que contém dentes de engrenagem dentro de um invólucro ou carcaça para transportar líquido em pressões de retorno relativamente altas através de ação de engrenamento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">gear pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba de engrenagem</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the gear mechanism is definitionally necessary for gear pumps, making it sufficient under OWA could lead to false positives - any complex equipment containing gears (like gearboxes with integrated pumps or multi-function units) might be incorrectly classified as standard gear pumps for maintenance purposes.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gear pump is a pump that has as component part at all times a gear mechanism and a pump casing, and bears a pumping function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GearPump(x) → Pump(x) ∧ ∃g,c (GearMechanism(g) ∧ PumpCasing(c) ∧ hasComponentPartAtAllTimes(x,g) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab995"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab994"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the movement of a gas stream from a region of lower pressure to a region of higher pressure.</skos:definition>
    <rdfs:label xml:lang="en">gas movement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de movimentação de gás</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab93">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingString">
    <skos:definition xml:lang="en">A material artifact that constitutes the continuous string of tubing that conveys production fluids from the wellbore to the surface or delivers injection fluids downhole.</skos:definition>
    <rdfs:label xml:lang="pt-br">coluna de coluna de produção</rdfs:label>
    <rdfs:label xml:lang="en">tubing string</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000252">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A differential pressure switch is a pressure switch that bears a differential pressure switching function to switch or provide on/off signals when the measured differential pressure between two inputs reaches a pre-set value.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab794"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DifferentialPressureSwitch(x) ↔ PressureSwitch(x) ∧ ∃f(DifferentialPressureSwitchingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">interruptor de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure switch</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A differential pressure switch is a pressure switch that bears a differential pressure switching function to switch or provide on/off signals when the measured differential pressure between two inputs reaches a pre-set value.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de pressão diferencial é um interruptor de pressão que possui uma função de comutação de pressão diferencial para comutar ou fornecer sinais liga/desliga quando a pressão diferencial medida entre duas entradas atinge um valor pré-estabelecido.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure switch is a pressure switch that has the function to switch based on differential pressure measurements between two pressure inputs.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2385">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2383"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab868">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab869"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1966">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1967"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionFunction">
    <rdfs:label xml:lang="en">axial displacement transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de deslocamento axial</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab103"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab102"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of axial displacement of a rotating shaft and the transmission of the corresponding signal to a monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000209">
    <rdfs:label xml:lang="pt-br">trocador de calor resfriado a ar</rdfs:label>
    <rdfs:label xml:lang="en">air cooled heat exchanger</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab68"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <skos:definition xml:lang="en">An air cooled heat exchanger is a heat exchanger that has finned air cooling surfaces and uses ambient air as the cooling medium to transfer thermal energy from process fluids.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor resfriado a ar é um trocador de calor que possui superfícies aletadas de resfriamento a ar e usa ar ambiente como meio de resfriamento para transferir energia térmica de fluidos de processo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An air cooled heat exchanger is a heat exchanger that has finned air cooling surfaces and uses ambient air as the cooling medium to transfer thermal energy from process fluids.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(AirCooledHeatExchanger(x) → HeatExchanger(x) ∧ ∃y(AirFinSystem(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(TubeBundle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃p(AirCoolingProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every air cooled heat exchanger is a heat exchanger that has component parts including an air fin system and tube bundle, and participates in air cooling processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Under the Open World Assumption, defining air cooling constructively as sufficient conditions could lead to false positives. Complex hybrid equipment or specialized configurations with air cooling components might be inappropriately classified. Starting with necessary conditions allows for proper validation by domain experts before upgrading to equivalence.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000287">
    <skos:definition xml:lang="en">A gasket is a material artifact made of deformable material arranged in closed loops that bears a sealing function to prevent leakage between mating surfaces with limited relative movement.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gasket is a material artifact that has component part some deformable material and bears some sealing function and has property some closed loop geometry.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">gasket</rdfs:label>
    <rdfs:label xml:lang="pt-br">junta</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1323"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gasket is a material artifact made of deformable material arranged in closed loops that bears a sealing function to prevent leakage between mating surfaces with limited relative movement.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma junta é um artefato material feito de material deformável arranjado em loops fechados que possui uma função de vedação para prevenir vazamentos entre superfícies de acoplamento com movimento relativo limitado.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Gasket(x) ↔ MaterialArtifact(x) ∧ ∃f(SealingFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(DeformableMaterial(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃g(ClosedLoopGeometry(g) ∧ hasProperty(x,g)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102">
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under Open World Assumption, any equipment with centrifugal impellers and volute casing could be inferred as a standard centrifugal pump, potentially misclassifying specialized hybrid equipment or complex pump systems that contain centrifugal stages but serve different operational roles.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba centrífuga é uma bomba que usa força centrífuga gerada por impulsores rotativos com pás para aumentar a pressão do fluido através de uma carcaça voluta.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab357"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <skos:definition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</skos:definition>
    <rdfs:label xml:lang="en">centrifugal pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba centrífuga</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalPump(x) → Pump(x) ∧ ∃y(CentrifugalImpeller(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(VoluteCasing(z) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal pump is a pump that has a centrifugal impeller as component part at all times and has a volute casing as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000074">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de casco e tubos é um trocador de calor que possui um feixe de tubos contido espacialmente dentro de um casco envolvente.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2373"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2372"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2374"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every shell and tube heat exchanger is a heat exchanger that has a tube bundle as component part and has a shell as component part, where the tube bundle is spatially contained within the shell.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">shell and tube heat exchanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">trocador de calor de casco e tubos</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type to avoid false positives under OWA. Any equipment with a shell and tube bundle could theoretically be classified as a standard shell-and-tube heat exchanger, but specialized variants (like graphite shell-and-tube or custom multi-stream designs) should not be automatically forced into this maintenance category without domain expert validation.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">ShellAndTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃tb(TubeBundle(tb) ∧ hasComponentPartAtAllTimes(x,tb)) ∧ ∃s(Shell(s) ∧ hasComponentPartAtAllTimes(x,s) ∧ spatiallyContains(s,tb))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000271">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame arrestor is a safety device that has the function of arresting flames and processes gaseous portions while preventing flame propagation.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um arrestador de chama é um dispositivo de segurança que possui uma função de arrestar chama para prevenir que chamas entrem em um sistema através de uma abertura.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlameArrestor(x) ↔ SafetyDevice(x) ∧ ∃f(FlameArrestFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</skos:definition>
    <rdfs:label xml:lang="en">flame arrestor</rdfs:label>
    <rdfs:label xml:lang="pt-br">arrestador de chama</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1077"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000348">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every shear ram is a ram that has the function to shear pipe and has shearing blades as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">aríete de corte</rdfs:label>
    <rdfs:label xml:lang="en">shear ram</rdfs:label>
    <skos:definition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aríete de corte é um aríete que possui função de corte de tubulação e tem lâminas de corte endurecidas projetadas para cortar a coluna de perfuração ou tubulação durante operações de prevenção de blowout.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ShearRam(x) ↔ Ram(x) ∧ ∃f(PipeShearingFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ShearingBlade(b) ∧ hasComponentPartAtAllTimes(x,b)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2357"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab8"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab9"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de absorção de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas absorption function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the selective transfer of gaseous components from a gas phase into a liquid absorbent phase.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChristmasTreeConnectionPoint">
    <rdfs:label xml:lang="en">christmas tree connection point</rdfs:label>
    <rdfs:label xml:lang="pt-br">ponto de árvore de natal de árvore de conexão</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a mechanical connection point on a Christmas tree for attachment of flowlines, control lines, or other equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000250">
    <rdfs:label xml:lang="en">diesel engine</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor diesel</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab767"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab768"/>
    <skos:definition xml:lang="en">A diesel engine is an engine that ignites fuel through compression heat rather than spark ignition, requiring compression ignition and fuel injection systems.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While compression ignition is characteristic of diesel engines, under OWA we cannot be certain that any engine with compression ignition systems is necessarily a diesel engine - there could be hybrid or specialized engines with similar mechanisms that should not be auto-classified as standard diesel engines without expert validation.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">DieselEngine(x) → Engine(x) ∧ ∃s(CompressionIgnitionSystem(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f(FuelInjectionSystem(f) ∧ hasComponentPartAtAllTimes(x,f)) ∧ ∃p(CompressionIgnitionProcess(p) ∧ participatesIn(x,p))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">A diesel engine is necessarily an engine that has compression ignition system and fuel injection system and participates in compression ignition process.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor diesel é um motor que inflama combustível através do calor de compressão em vez de ignição por centelha, requerendo sistemas de ignição por compressão e injeção de combustível.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diesel engine is an engine that ignites fuel through compression heat rather than spark ignition, requiring compression ignition and fuel injection systems.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000298">
    <rdfs:label xml:lang="en">hydraulic actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador hidráulico</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hydraulic actuator is an actuator that converts hydraulic fluid pressure into mechanical motion through hydraulic power transmission.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador hidráulico é um atuador que converte pressão de fluido hidráulico em movimento mecânico através de transmissão de potência hidráulica.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on hydraulic power source. Under Open World Assumption, asserting equivalence could incorrectly classify complex hydraulic-mechanical hybrid systems or specialized equipment containing hydraulic actuator components as standard hydraulic actuators.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HydraulicActuator(x) → Actuator(x) ∧ ∃y(HydraulicFluidPortion(y) ∧ hasInput(x,y)) ∧ ∃z(HydraulicToMechanicalEnergyConversionProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A hydraulic actuator is an actuator that converts hydraulic fluid pressure into mechanical motion through hydraulic power transmission.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1503"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic actuator is an actuator that has hydraulic fluid portion as input and participates in hydraulic to mechanical energy conversion process.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab412">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionGasPortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas undergoing or having undergone a combustion reaction in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">combustion gas portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de combustão de gás</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000370">
    <skos:definition xml:lang="en">A MaterialArtifact that is a component part of a valve and that is positioned in the flow stream to permit, obstruct, divert or regulate flow through mechanical positioning.</skos:definition>
    <rdfs:label xml:lang="pt-br">membro de fechamento de válvula</rdfs:label>
    <rdfs:label xml:lang="en">valve closure member</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é uma parte componente de uma válvula e que é posicionado no fluxo para permitir, obstruir, desviar ou regular o fluxo através de posicionamento mecânico.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is a component part of a valve and that is positioned in the flow stream to permit, obstruct, divert or regulate flow through mechanical positioning.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2726"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ValveClosureMember(x) → MaterialArtifact(x) ∧ ∃v (Valve(v) ∧ isComponentPartOf(x,v)) ∧ ∃p (FlowControlProcess(p) ∧ participatesIn(x,p)) ∧ ∃q (PositionableInFlowStream(q) ∧ hasQuality(x,q)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration and mechanical role, the valve closure member should use necessary conditions. The structural differentia (being positioned in flow stream) is harder to make sufficient under OWA - other components or hybrid devices might satisfy the conditions but not be classified as standard valve closure members.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve closure member is a material artifact that is a component part of some valve and participates in flow control processes by being positioned within the flow stream.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab383"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveBody(x) → ValveBody(x) ∧ ∃y(CheckValve(y) ∧ designedFor(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive identity based on structural design for check valve accommodation. Under OWA, any housing designed for check valves could include specialized configurations, custom manifolds, or hybrid designs that should not be automatically classified as standard check valve bodies without domain expert validation of the structural differentia.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</skos:definition>
    <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
    <rdfs:label xml:lang="en">check valve body</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CheckValveBody subClassOf ValveBody and (designedFor some CheckValve)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que é especificamente projetado para acomodar e alojar os mecanismos internos de uma válvula de retenção dentro de uma barreira de contenção de pressão.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DeaerationFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab605"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab604"/>
    <rdfs:label xml:lang="en">deaeration function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de desaeração</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of dissolved oxygen and other non-condensable gases from a liquid stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2358">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab625">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingSystem">
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of seals, gaskets, and packing that prevents leakage between two components of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">sealing system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de vedação</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2093"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2094"/>
    <rdfs:label xml:lang="pt-br">função de medição de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure measurement function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and local display of the pressure of a process stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2220">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HumidAirPortion">
    <rdfs:label xml:lang="en">humid air portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção úmido de ar</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of air carrying a significant concentration of water vapour in a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1215"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1214"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <skos:definition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">função de modificação de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow modification function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2545"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2544"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and remote transmission of the temperature of a process stream or equipment surface.</skos:definition>
    <rdfs:label xml:lang="en">temperature measurement and transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição e transmissão de temperatura</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000373">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2757"/>
    <rdfs:label xml:lang="pt-br">tampo de vaso</rdfs:label>
    <rdfs:label xml:lang="en">vessel head</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma FiatObjectPart que é parte de um vaso e que fecha o casco do vaso fornecendo uma fronteira terminal para contenção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FiatObjectPart that is part of a vessel and that closes a vessel shell by providing an end boundary for containment.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel head is a fiat object part that is part of some vessel and realizes a vessel closure role.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A FiatObjectPart that is part of a vessel and that closes a vessel shell by providing an end boundary for containment.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VesselHead(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃r(VesselClosureRole(r) ∧ realizes(x,r)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, asserting sufficient conditions for vessel head closure would inappropriately classify any part that closes a vessel (including specialized manifolds, complex multi-port heads, or custom closures) as standard vessel heads, potentially creating false positives in maintenance categorization.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de conexão elétrica</rdfs:label>
    <rdfs:label xml:lang="en">electrical connection process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab729"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1359"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2148"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2056"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2149"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1360"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2231"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2232"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab353"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab354"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2171"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab899"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2057"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2170"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab900"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab728"/>
    <rdfs:label xml:lang="pt-br">função de bombeamento</rdfs:label>
    <rdfs:label xml:lang="en">pumping function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the transfer of mechanical energy to a fluid to increase its pressure, velocity, or both.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">continuous base</rdfs:label>
    <rdfs:label xml:lang="pt-br">base contínuo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the base structure that provides continuous support for equipment or pipework in a petroleum production installation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000230">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab484"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um compensador é um artefato material que tem a função projetada de compensar movimento axial ou radial entre dois elementos conectados.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A compensator is a material artifact that has the designed function of compensating for axial or radial movement between two connected elements.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Compensator(x) ↔ MaterialArtifact(x) ∧ ∃f(MovementCompensationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every compensator is a material artifact that bears a movement compensation function and has component parts including a compensation mechanism and connection interfaces.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A compensator is a material artifact that has the designed function of compensating for axial or radial movement between two connected elements.</skos:definition>
    <rdfs:label xml:lang="pt-br">compensador</rdfs:label>
    <rdfs:label xml:lang="en">compensator</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1041">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000205">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AbsolutePressureTransmitter(x) → PressureTransmitter(x) ∧ ∃y (VacuumReferenceeChamber(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab7"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab6"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab5"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on vacuum reference chamber configuration. Under Open World Assumption, defining sufficient conditions could lead to unintended classification of complex instruments that contain vacuum chambers but serve different primary functions. The structural differentia is necessary but making it sufficient requires domain expert validation.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão absoluta é um transmissor de pressão que possui uma câmara de referência de vácuo de um lado do sensor de pressão enquanto o outro lado recebe a pressão do processo.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">absolute pressure transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de pressão absoluta</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber as a component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContainmentProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de contenção</rdfs:label>
    <rdfs:label xml:lang="en">containment process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1898">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1902"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess">
    <rdfs:label xml:lang="en">filtration process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de filtração</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which particles, contaminants, or unwanted substances are selectively retained from a fluid stream by a filter element through mechanical screening or other separation mechanisms while clean fluid passes through.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which particles, contaminants, or unwanted substances are selectively retained from a fluid stream by a filter element through mechanical screening or other separation mechanisms while clean fluid passes through.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1146"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1147"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the partial vaporisation of a pressurised liquid stream caused by a rapid reduction in pressure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de vaporização flash</rdfs:label>
    <rdfs:label xml:lang="en">flash vaporization function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab711">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2498">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2493"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2499"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1107">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000269">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1058"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1057"/>
    <skos:definition xml:lang="en">A finned tube heat exchanger is a heat exchanger that has finned tubes as the primary heat transfer surface enhancement mechanism.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every finned tube heat exchanger is a heat exchanger that has finned tubes as component parts at all times</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While finned tubes are the defining structural feature, making sufficient conditions (equivalence) under Open World Assumption could lead to false positives where any assembly containing finned tubes would be classified as this specific heat exchanger type, including complex multi-function equipment or specialized hybrid systems.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de tubos aletados é um trocador de calor que possui tubos aletados como mecanismo primário de aumento da superfície de transferência de calor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A finned tube heat exchanger is a heat exchanger that has finned tubes as the primary heat transfer surface enhancement mechanism.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FinnedTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃y(FinnedTube(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">finned tube heat exchanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">trocador de calor de tubos aletados</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1218">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1220"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab605">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1147">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
