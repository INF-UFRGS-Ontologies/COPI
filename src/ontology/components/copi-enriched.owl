  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1550">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1039">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000295">
    <skos:definition xml:lang="en">A hopper is a vessel that is designed to store solid materials and dispense them through a controlled discharge opening.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Hopper(x) ↔ (Vessel(x) ∧ ∃f(SolidStorageAndDispensingFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SolidDischargeOpening(p) ∧ hasComponentPartAtAllTimes(x,p))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1465"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um hopper é um vaso projetado para armazenar materiais sólidos e dispensá-los através de uma abertura de descarga controlada.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hopper is a vessel that is designed to store solid materials and dispense them through a controlled discharge opening.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hopper is a vessel that bears a SolidStorageAndDispensingFunction and has a SolidDischargeOpening as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">hopper</rdfs:label>
    <rdfs:label xml:lang="pt-br">hopper</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab94">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilteredFluidPortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid from which particulate or liquid contaminants have been removed by filtration.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">porção filtrado de fluido</rdfs:label>
    <rdfs:label xml:lang="en">filtered fluid portion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction">
    <rdfs:label xml:lang="en">position transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de posição</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2035"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2036"/>
    <skos:definition xml:lang="en">A signal transmission function borne by petroleum production equipment whose realization constitutes the measurement of the position of a mechanical component and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2028">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab890">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DryingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2035">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PositionMeasurementAndTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SelfOperatingValve(x) → Valve(x) ∧ ∃m(SelfOperatingMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(EnergyIndependentOperationCapability(c) ∧ bearerOf(x,c)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">self operating valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula auto-operante</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula auto-operante é uma válvula que inclui um mecanismo interno de operação (como mola, gravidade, pressão do fluido ou contrapeso) e não depende de uma fonte externa de energia para seu acionamento.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2322"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <skos:definition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical configuration (self-operating mechanism). Under OWA, any valve with an internal operating mechanism might be classified as self-operating even if it has additional external actuators or specialized applications. Domain expert validation needed to confirm structural differentia is sufficient.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every self-operating valve is a valve that has a self-operating mechanism as component part at all times and bears the capability of energy-independent operation.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2210">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000232">
    <skos:definition xml:lang="en">A condenser is a heat exchanger that bears a designed function to condense vapor to liquid by removing latent heat of vaporization.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Condenser(x) ↔ (HeatExchanger(x) ∧ ∃f(CondensationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">condenser</rdfs:label>
    <rdfs:label xml:lang="pt-br">condensador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A condenser is a heat exchanger that bears a designed function to condense vapor to liquid by removing latent heat of vaporization.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um condensador é um trocador de calor que possui uma função projetada para condensar vapor em líquido removendo o calor latente de vaporização.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every condenser is a heat exchanger that bears a condensation function, and every heat exchanger that bears a condensation function is a condenser.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab513"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2166">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab994">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2604">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2605"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2625">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the fluid level in a vessel crosses a defined high or low threshold.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de chaveamento de nível</rdfs:label>
    <rdfs:label xml:lang="en">level switching process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab804">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementAndTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000225">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Although functionally defined as a separator, the constructive differentia (centrifugal mechanism) makes sufficient conditions complex under OWA. Any equipment with a rotating drum could potentially be classified as a centrifuge even if designed for other purposes (mixing, drying, etc.). Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab366"/>
    <skos:definition xml:lang="en">A centrifuge is a separator that uses centrifugal force generated by a rotating drum to separate phases of different densities.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Centrifuge(x) → Separator(x) ∧ ∃d (RotatingDrum(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p (CentrifugalForceProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma centrífuga é um separador que usa força centrífuga gerada por um tambor rotativo para separar fases de diferentes densidades.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A centrifuge is a separator that uses centrifugal force generated by a rotating drum to separate phases of different densities.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifuge is a separator that has a rotating drum as component part and participates in centrifugal force processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">centrifuge</rdfs:label>
    <rdfs:label xml:lang="pt-br">centrífuga</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000302">
    <rdfs:label xml:lang="pt-br">impulsor</rdfs:label>
    <rdfs:label xml:lang="en">impeller</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for the rotating vane assembly could lead to false positives where other rotating equipment with vanes (like turbine rotors or fan assemblies) might be incorrectly classified as impellers when they should remain in their specific equipment categories.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">An impeller is an assembly consisting of rotating vanes mounted on a hub that transfers energy to or from fluids through dynamic rotational force within an enclosure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every impeller is an assembly that has rotating vanes and a hub as component parts at all times, participates in rotational motion, and bears an energy transfer function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An impeller is an assembly consisting of rotating vanes mounted on a hub that transfers energy to or from fluids through dynamic rotational force within an enclosure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um impulsor é um conjunto que consiste em pás rotativas montadas em um cubo que transfere energia para ou de fluidos através de força rotacional dinâmica dentro de um invólucro.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1548"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1549"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Impeller(x) → Assembly(x) ∧ ∃v,h(RotatingVanes(v) ∧ Hub(h) ∧ hasComponentPartAtAllTimes(x,v) ∧ hasComponentPartAtAllTimes(x,h) ∧ ∃m(RotationalMotion(m) ∧ participatesIn(x,m)) ∧ ∃f(EnergyTransferFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2232">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1013"/>
    <skos:definition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro é um separador que possui uma função de filtração para remover seletivamente constituintes indesejados de um fluxo de fluido usando um elemento filtrante dentro de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter is a separator that has a filtration function and has a filter element as component part and has a filter housing as component part</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Filter(x) ↔ (Separator(x) ∧ ∃f(FiltrationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilterElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃h(FilterHousing(h) ∧ hasComponentPartAtAllTimes(x,h))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">filtro</rdfs:label>
    <rdfs:label xml:lang="en">filter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab867">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RaisedEdge">
    <rdfs:label xml:lang="en">raised edge</rdfs:label>
    <rdfs:label xml:lang="pt-br">borda saliente</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a raised rim or flange on a component of petroleum production equipment that provides a sealing surface or structural boundary.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1475">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243">
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab648"/>
    <rdfs:label xml:lang="pt-br">desidratador</rdfs:label>
    <rdfs:label xml:lang="en">dehydrator</rdfs:label>
    <skos:definition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehydrator is a separator that has the function of dehydration.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1783">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab729">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1642">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelDetectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000325">
    <rdfs:label xml:lang="en">pipe tee</rdfs:label>
    <rdfs:label xml:lang="pt-br">tê de tubulação</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PipeTee(x) → Pipe(x) ∧ ∃p1,p2,p3(BranchPort(p1) ∧ RunPort(p2) ∧ RunPort(p3) ∧ hasPartAtAllTimes(x,p1) ∧ hasPartAtAllTimes(x,p2) ∧ hasPartAtAllTimes(x,p3) ∧ perpendicularTo(p1,p2) ∧ perpendicularTo(p1,p3)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A pipe tee is a pipe fitting that has three fluid ports arranged in T-shaped configuration, with one branch port perpendicular to two run ports, designed to realize fluid conduction function through flow division or combination.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tê de tubulação é uma conexão de tubulação que possui três portas de fluido dispostas em configuração em formato de T, com uma porta de ramal perpendicular a duas portas de passagem, projetada para realizar função de condução de fluido através de divisão ou combinação de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe tee is a pipe fitting that has three fluid ports arranged in T-shaped configuration, with one branch port perpendicular to two run ports, designed to realize fluid conduction function through flow division or combination.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe tee is a pipe that has exactly three fluid ports arranged in T-configuration and bears a fluid conduction function</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1954"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1955"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. The T-shaped geometric configuration with three specific ports is a structural differentia that is harder to make sufficient under OWA. Custom manifolds or complex fittings might contain T-shaped passages but should not be automatically classified as standard pipe tees without domain expert validation.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2362">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2359"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115">
    <iof-av:naturalLanguageDefinition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ventilador é um conjunto que possui uma função de movimentação de gás para fornecer ou exaurir volumes de vapor ou gás com baixa pressão diferencial.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab998"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every fan is an assembly that bears a gas movement function, and every assembly that bears a gas movement function is a fan.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Fan(x) ↔ (Assembly(x) ∧ ∃f(GasMovementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">ventilador</rdfs:label>
    <rdfs:label xml:lang="en">fan</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção é uma válvula que possui uma função de prevenção de refluxo, permitindo automaticamente que o fluido flua em apenas uma direção enquanto previne o fluxo reverso.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValve(x) ↔ Valve(x) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <rdfs:label xml:lang="pt-br">válvula de retenção</rdfs:label>
    <rdfs:label xml:lang="en">check valve</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab377"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every check valve is a valve that has the function to prevent backflow and automatically allow unidirectional fluid flow.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DiscreteElectricalSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">discrete electrical signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal discreto elétrico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <skos:definition xml:lang="en">An information content entity constituting an electrical signal that can assume only two defined states—on or off—used in control and safety systems of petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor">
    <rdfs:label xml:lang="en">braided conductor</rdfs:label>
    <rdfs:label xml:lang="pt-br">condutor de trançado</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an electrical conductor composed of braided or stranded wires providing flexibility and mechanical strength in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab944">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab945"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1279">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1484"/>
    <skos:definition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every humidity analyser is a process analyzer that has the function to measure humidity content.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (HumidityAnalyser(x) ↔ ProcessAnalyzer(x) ∧ ∃f (HumidityMeasurementFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de umidade é um analisador de processo que é projetado para medir e indicar o conteúdo de umidade ou vapor d'água em correntes de processo ou ambientes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">humidity analyser</rdfs:label>
    <rdfs:label xml:lang="pt-br">analisador de umidade</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1057">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1680">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1681"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000276">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlashDrum(x) ↔ Separator(x) ∧ ∃f(FlashVaporizationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tambor de flash é um separador que realiza vaporização flash para separar componentes mais leves (que vaporizam e são retirados no topo) de componentes mais pesados (que permanecem líquidos e são retirados no fundo).</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flash drum is a separator that performs flash vaporization to separate lighter components (which vaporize and are drawn off at the top) from heavier components (which remain liquid and are drawn off at the bottom).</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1151"/>
    <rdfs:label xml:lang="en">flash drum</rdfs:label>
    <rdfs:label xml:lang="pt-br">tambor de flash</rdfs:label>
    <skos:definition xml:lang="en">A flash drum is a separator that performs flash vaporization to separate lighter components (which vaporize and are drawn off at the top) from heavier components (which remain liquid and are drawn off at the bottom).</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flash drum is a separator that bears a flash vaporization function and has a vapor outlet, liquid outlet, and feed inlet.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingFunction">
    <rdfs:label xml:lang="en">noise silencing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de silenciamento de ruído</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2387"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2386"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the attenuation of acoustic energy in a fluid stream or mechanical system to reduce radiated noise to acceptable levels.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000354">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um espaçador é um artefato material que tem a função de manter separação espacial ou distância entre objetos físicos ou fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A spacer is a material artifact that has the function of maintaining spatial separation or distance between physical objects or fluids.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">espaçador</rdfs:label>
    <rdfs:label xml:lang="en">spacer</rdfs:label>
    <skos:definition xml:lang="en">A spacer is a material artifact that has the function of maintaining spatial separation or distance between physical objects or fluids.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Spacer(x) ↔ MaterialArtifact(x) ∧ ∃f(SpacingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2429"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every spacer is a material artifact that bears a spacing function</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281">
    <skos:definition xml:lang="en">A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every furnace is a heater that has the function to induce reactions in process fluids by heating them.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1260"/>
    <rdfs:label xml:lang="pt-br">forno</rdfs:label>
    <rdfs:label xml:lang="en">furnace</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Furnace(x) ↔ Heater(x) ∧ ∃f(ReactiveHeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um forno é um aquecedor que possui a função de induzir reações químicas em fluidos de processo através do aquecimento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000343">
    <iof-av:naturalLanguageDefinition xml:lang="en">A rupture disc is an instrument that realizes pressure relief through irreversible rupture at a calibrated pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um disco de ruptura é um instrumento que realiza alívio de pressão através de ruptura irreversível em uma pressão calibrada.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A rupture disc is an instrument that realizes pressure relief through irreversible rupture at a calibrated pressure.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every rupture disc is an instrument that has the function to relieve pressure and participates in irreversible rupture processes at calibrated pressure thresholds.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (RuptureDisc(x) ↔ Instrument(x) ∧ ∃f(PressureReliefFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(IrreversibleRuptureProcess(p) ∧ participatesIn(x,p)) ∧ ∃q(CalibrationPressure(q) ∧ hasQuality(x,q)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">disco de ruptura</rdfs:label>
    <rdfs:label xml:lang="en">rupture disc</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2250"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab586">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FlowTransmitter(x) ↔ Transmitter(x) ∧ ∃f(FlowSignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(FlowMeasurement(m) ∧ hasInput(x,m)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow transmitter is a transmitter that has the function of transmitting flow signals and has as input flow measurements.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de fluxo é um transmissor que produz sinais de saída padronizados proporcionais às medições de fluxo provenientes de elementos sensores de fluxo.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1236"/>
    <rdfs:label xml:lang="en">flow transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de fluxo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab876">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab810">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000186"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralDisplacement">
    <rdfs:label xml:lang="pt-br">deslocamento estrutural</rdfs:label>
    <rdfs:label xml:lang="en">structural displacement</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a displacement—elongation, settlement, or lateral movement—of a structural element in a petroleum production installation.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab814">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1984">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSensor">
    <skos:definition xml:lang="en">A material artifact that constitutes a sensing element assembly that measures fluid pressure and converts it into an electrical or pneumatic signal.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="pt-br">sensor de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure sensor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000268">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1046"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1045"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as 'both' functional and constructive. The structural differentia (pressure mechanism and compression process) involves specific mechanical configurations that are harder to make sufficient under Open World Assumption without detailed engineering specifications.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter press is a filter that applies mechanical compression force to enhance the separation of substances through a pressurized filtration process.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma prensa filtrante é um filtro que aplica força de compressão mecânica para melhorar a separação de substâncias através de um processo de filtração pressurizada.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A filter press is a filter that applies mechanical compression force to enhance the separation of substances through a pressurized filtration process.</skos:definition>
    <rdfs:label xml:lang="en">filter press</rdfs:label>
    <rdfs:label xml:lang="pt-br">prensa filtrante</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter press is a filter that has a pressure mechanism as part and participates in mechanical compression processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FilterPress(x) → Filter(x) ∧ ∃p(PressureMechanism(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃proc(MechanicalCompressionProcess(proc) ∧ participatesIn(x,proc)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2393">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2391"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SuctionInlet">
    <skos:definition xml:lang="en">A material artifact that constitutes the inlet through which fluid is drawn into a pump or compressor under suction pressure in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">entrada de sucção</rdfs:label>
    <rdfs:label xml:lang="en">suction inlet</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LowPressureSignal">
    <skos:definition xml:lang="en">An information content entity constituting an electrical or pneumatic signal representing a low-pressure condition in a petroleum production process.</skos:definition>
    <rdfs:label xml:lang="pt-br">sinal baixo de pressão</rdfs:label>
    <rdfs:label xml:lang="en">low pressure signal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess">
    <skos:definition xml:lang="en">A planned process in which a pipeline pig is introduced into a pipeline under operating pressure and subsequently retrieved after completing its passage.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de lançamento e recebimento de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig launching and receiving process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab18">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2386">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2098">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2410">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1389">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PneumaticMotorFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2016"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2015"/>
    <rdfs:label xml:lang="pt-br">função de acionamento pneumático</rdfs:label>
    <rdfs:label xml:lang="en">pneumatic motor function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of compressed-gas energy into rotational mechanical motion.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000261">
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um gerador elétrico é um conjunto que possui a função de converter energia não-elétrica em energia elétrica</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ElectricGenerator(x) ↔ (Assembly(x) ∧ ∃f(ElectricEnergyGenerationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric generator is an assembly that has the function to convert non-electric energy into electric energy</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab928"/>
    <rdfs:label xml:lang="pt-br">gerador elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electric generator</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000299">
    <skos:definition xml:lang="en">A hydraulic motor is a motor that generates mechanical energy by converting high pressure hydraulic oil to rotational motion.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on hydraulic mechanism. Under Open World Assumption, any device with hydraulic input might be misclassified as a hydraulic motor without domain expert validation of the complete structural requirements.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic motor is a motor that has hydraulic fluid input and participates in hydraulic-to-mechanical energy conversion process</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hydraulic motor is a motor that generates mechanical energy by converting high pressure hydraulic oil to rotational motion.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor hidráulico é um motor que gera energia mecânica convertendo óleo hidráulico de alta pressão em movimento rotacional.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1515"/>
    <rdfs:label xml:lang="en">hydraulic motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor hidráulico</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HydraulicMotor(x) → Motor(x) ∧ ∃f,p(HydraulicFluidPortion(f) ∧ hasInput(x,f) ∧ HydraulicToMechanicalEnergyConversionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2378">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationContentEntity">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">information content entity</rdfs:label>
    <rdfs:label xml:lang="pt-br">entidade de informação de conteúdo</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting the informational content—a measurement value, alarm state, or analysis result—encoded in a signal or record within petroleum production systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess">
    <skos:definition xml:lang="en">A planned process in which the chemical components of a sample are separated and quantified by their differential migration through a stationary phase in petroleum production instrumentation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de análise cromatográfica</rdfs:label>
    <rdfs:label xml:lang="en">chromatographic analysis process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312">
    <skos:definition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ManualActuator is an actuator that has input ManualControlSignal and has output MechanicalPower</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1760"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador manual é um atuador que converte entradas de controle operadas por humanos em movimento mecânico ou força através de operação física direta.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ManualActuator(x) ↔ Actuator(x) ∧ ∃s(ManualControlSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">manual actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador manual</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171">
    <rdfs:label xml:lang="en">flow indication function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de indicação de fluxo</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1179"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1178"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the flow rate of a process stream.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1363">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1756">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2080">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2082"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasBurningProcess">
    <rdfs:label xml:lang="en">waste gas burning process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de queima de gás residual</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which surplus or waste gas is combusted in a flare or incinerator to destroy it safely and prevent atmospheric venting.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2675">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableBundle"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000211">
    <skos:definition xml:lang="en">A ValveBody that has an internal flow path geometry where the inlet and outlet axes are positioned at an angle to each other, creating an L-shaped or angled flow configuration.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AngleValveBody(x) → ValveBody(x) ∧ ∃g (AngularFlowPath(g) ∧ hasGeometry(x,g)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab92"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on geometric configuration. Under OWA, sufficient conditions for geometric characteristics like 'angular flow path' are difficult to specify precisely without detailed geometric constraints that could lead to false classification of complex multi-path valve bodies or hybrid designs.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">angle valve body</rdfs:label>
    <rdfs:label xml:lang="pt-br">corpo de válvula angular</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ValveBody that has an internal flow path geometry where the inlet and outlet axes are positioned at an angle to each other, creating an L-shaped or angled flow configuration.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ValveBody que possui uma geometria de caminho de fluxo interno onde os eixos de entrada e saída são posicionados em ângulo um em relação ao outro, criando uma configuração de fluxo em formato de L ou angular.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">AngleValveBody subClassOf ValveBody and hasGeometry some AngularFlowPath</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2763">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000355">
    <skos:definition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2447"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2448"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma StationaryMachineComponentFunction e que é o componente estrutural estacionário dentro de máquinas rotativas, fornecendo alojamento e estabilidade posicional para elementos ativos como bobinas, palhetas ou vedações.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Stator(x) → MaterialArtifact(x) ∧ ∃f(StationaryMachineComponentFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(RotatingMachine(m) ∧ partOf(x,m)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Stator is a MaterialArtifact that bears a StationaryMachineComponentFunction and is part of some RotatingMachine</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">stator</rdfs:label>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma StationaryMachineComponentFunction e</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on structural positioning within rotating machinery. Under OWA, any artifact described as stationary within a rotating machine context could be classified as a stator, but this may include specialized hybrid components, mounting structures, or custom configurations that should not be automatically asserted into the standard stator maintenance category. The structural differentia (stationary positioning) is necessary but making it sufficient requires domain expert validation.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2809">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellheadSpool"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1106">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000122">
    <skos:definition xml:lang="en">A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">válvula de controle globo</rdfs:label>
    <rdfs:label xml:lang="en">globe control valve</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1389"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle globo é uma válvula de controle que possui um corpo em formato de globo e usa um mecanismo de fechamento de movimento linear para modular o fluxo de fluido em resposta a sinais de controle de processo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GlobeControlValve(x) → ControlValve(x) ∧ ∃y,z (GlobeValveBody(y) ∧ LinearMotionClosure(z) ∧ hasComponentPartAtAllTimes(x,y) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive subtype (both classification basis). The structural differentia (globe body + linear closure) provides strong necessary conditions, but declaring sufficiency under OWA could lead to unwanted automatic classification of specialized equipment that contains globe mechanisms but should not be categorized as standard globe control valves.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe control valve is a control valve that has a globe valve body and has a linear motion closure as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1732">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab374">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1765">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab9">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1595"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1594"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1587"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1586"/>
    <rdfs:label xml:lang="pt-br">função de injeção</rdfs:label>
    <rdfs:label xml:lang="en">injection function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the introduction of a fluid, chemical, or material into a process stream, vessel, or wellbore under controlled conditions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2569"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2562"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2570"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2561"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a TemperatureSensorProtectionProcess and that consists in providing a protective enclosure for temperature sensing elements while enabling thermal conductivity from the process medium to the sensor.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de proteção de sensor de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature sensor protection function</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a TemperatureSensorProtectionProcess and that consists in providing a protective enclosure for temperature sensing elements while enabling thermal conductivity from the process medium to the sensor.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2353">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2338">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasDetectingMeasuringElement">
    <rdfs:label xml:lang="en">gas detecting measuring element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de gás de detecção de medição</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a sensing element within petroleum production gas detection equipment that responds to the presence and concentration of a target gas.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MeasuringElement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2831">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2832"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">vibration measurement and transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de vibração</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which the amplitude or frequency of mechanical vibration is measured and the corresponding signal transmitted to a remote monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2033">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2034"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1223">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SurfaceSafetyValve">
    <skos:definition xml:lang="en">A material artifact that constitutes a safety valve installed at the wellhead or surface flowline that automatically closes to prevent uncontrolled flow from the well.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">surface safety valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de superfície de segurança</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2548">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2550"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab544">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DivertingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de desvio de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">diverting process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which fluid flow is redirected from one path to one or more alternative downstream paths by petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the interruption of electrical current flow in a circuit under normal operating or fault conditions.</skos:definition>
    <rdfs:label xml:lang="en">electrical current interruption function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de interrupção de corrente elétrica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab447"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab446"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess">
    <rdfs:label xml:lang="pt-br">processo de transdução força-elétrica</rdfs:label>
    <rdfs:label xml:lang="en">force to electrical transduction process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a mechanical force or pressure is converted into a proportional electrical signal by petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction">
    <rdfs:label xml:lang="pt-br">função de mistura</rdfs:label>
    <rdfs:label xml:lang="en">mixing function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1783"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1784"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the combination and blending of two or more fluid streams or components to achieve a homogeneous mixture.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab698">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000253">
    <rdfs:label xml:lang="en">diffuser</rdfs:label>
    <rdfs:label xml:lang="pt-br">difusor</rdfs:label>
    <skos:definition xml:lang="en">A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um difusor é um conjunto que tem a função projetada de converter energia cinética do fluxo de fluido em energia de pressão através de desaceleração controlada em uma passagem divergente.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diffuser is an assembly that bears an energy diffusion function and has a diverging channel as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab817"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Diffuser(x) ↔ Assembly(x) ∧ ∃f(EnergyDiffusionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2400">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2401"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Detector(x) ↔ Instrument(x) ∧ ∃f(DetectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection.</skos:definition>
    <rdfs:label xml:lang="en">detector</rdfs:label>
    <rdfs:label xml:lang="pt-br">detector</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every detector is an instrument that has a detection function and has component parts including a sensing element and signal generation device.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector é um instrumento que possui uma função de detecção, permitindo-lhe detectar estados, substâncias ou fenômenos e produzir sinais baseados na detecção.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab697"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206">
    <skos:definition xml:lang="en">An accumulator is a vessel that has the designed function to accumulate (store and controllably release) energy or matter.</skos:definition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Accumulator(x) ↔ (Vessel(x) ∧ ∃f (AccumulationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">accumulator</rdfs:label>
    <rdfs:label xml:lang="pt-br">acumulador</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every accumulator is a vessel that bears an accumulation function</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An accumulator is a vessel that has the designed function to accumulate (store and controllably release) energy or matter.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um acumulador é um vaso que tem a função projetada de acumular (armazenar e liberar de forma controlada) energia ou matéria.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab24"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366">
    <rdfs:label xml:lang="en">turbine</rdfs:label>
    <rdfs:label xml:lang="pt-br">turbina</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A turbine is an assembly that bears an energy extraction function and has rotating shaft and fluid-interacting blades that extract energy from flowing fluids and convert it into useful mechanical work.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma turbina é um conjunto que possui uma função de extração de energia e tem eixo rotativo e pás de interação com fluidos que extraem energia de fluidos em movimento e a convertem em trabalho mecânico útil.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A turbine is an assembly that bears an energy extraction function and has rotating shaft and fluid-interacting blades that extract energy from flowing fluids and convert it into useful mechanical work.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Turbine(x) ↔ Assembly(x) ∧ ∃f(EnergyExtractionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(RotatingShaft(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃b(FluidInteractionBlades(b) ∧ hasComponentPartAtAllTimes(x,b)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every turbine is an assembly that bears an energy extraction function and has component parts including a rotating shaft, fluid interaction blades, casing, and bearing system.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2658"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2614">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2616"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1465">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1467"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess">
    <skos:definition xml:lang="en">A planned process in which the flow rate or pressure of a fluid stream is reduced in a controlled manner by introducing a fixed or variable resistance.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">flow restriction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de restrição de fluxo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which the characteristics of fluid flow are altered by a flow modification accessory, resulting in changes to flow patterns, velocity profiles, turbulence levels, or pressure drop characteristics while the fluid passes through or around the device.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">flow modification process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de modificação de fluxo</rdfs:label>
    <skos:definition xml:lang="en">A PlannedProcess in which the characteristics of fluid flow are altered by a flow modification accessory, resulting in changes to flow patterns, velocity profiles, turbulence levels, or pressure drop characteristics while the fluid passes through or around the device.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000305">
    <rdfs:label xml:lang="en">injection well</rdfs:label>
    <rdfs:label xml:lang="pt-br">poço de injeção</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every injection well is a well that has the function to inject materials into a reservoir under pressure.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">An injection well is a well that bears the designed function of injecting materials into a reservoir at pressure higher than formation pressure.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1598"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um poço de injeção é um poço que possui a função projetada de injetar materiais em um reservatório a uma pressão superior à pressão da formação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An injection well is a well that bears the designed function of injecting materials into a reservoir at pressure higher than formation pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (InjectionWell(x) ↔ (Well(x) ∧ ∃f (InjectionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2076"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2077"/>
    <rdfs:label xml:lang="pt-br">função de sensoriamento de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure sensing function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the detection and measurement of the pressure of a process stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199">
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in converting electrical energy from one voltage level to another through electromagnetic induction, enabling power distribution and utilization at appropriate voltage levels.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in changing the voltage and current levels of electrical power through electromagnetic induction while maintaining power transfer efficiency.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2062"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2599"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2061"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2072"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2066"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2598"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2067"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2071"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in converting electrical energy from one voltage level to another through electromagnetic induction, enabling power distribution and utilization at appropriate voltage levels.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in changing the voltage and current levels of electrical power through electromagnetic induction while maintaining power transfer efficiency.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">electrical power transformation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transformação de energia elétrica</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a material is physically or chemically transformed to alter its composition, form, or physical state in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de processamento de material</rdfs:label>
    <rdfs:label xml:lang="en">material processing process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
