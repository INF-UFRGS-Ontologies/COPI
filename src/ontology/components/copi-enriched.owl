  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StatorWinding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">enrolamento de estator</rdfs:label>
    <rdfs:label xml:lang="en">stator winding</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the stationary winding of an electric motor or generator that produces or responds to the rotating magnetic field in petroleum production rotating electrical equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1738">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction">
    <rdfs:label xml:lang="en">position transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de posição</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2023"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A signal transmission function borne by petroleum production equipment whose realization constitutes the measurement of the position of a mechanical component and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b935"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b936"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of electrical energy into rotational or linear mechanical motion.</skos:definition>
    <rdfs:label xml:lang="en">electric to mechanical conversion function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de conversão elétrico-mecânica</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1873">
