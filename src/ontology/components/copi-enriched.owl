    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b216">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143">
    <rdfs:label xml:lang="pt-br">manômetro</rdfs:label>
    <rdfs:label xml:lang="en">pressure gauge</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b61"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro é um indicador que possui a função de medir e exibir valores de pressão.</iof-av:naturalLanguageDefinition>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b62"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureGauge(x) ↔ Indicator(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">válvula de retenção wafer</rdfs:label>
    <rdfs:label xml:lang="en">wafer check valve</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (WaferCheckValve(x) → CheckValve(x) ∧ ∃f (BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b269"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
