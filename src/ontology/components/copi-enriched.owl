  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147">
    <iof-av:naturalLanguageDefinition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança e alívio é uma válvula que possui uma função de alívio de segurança que combina capacidades de proteção de segurança e alívio de pressão.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</skos:definition>
    <rdfs:label xml:lang="en">safety relief valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de segurança e alívio</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2267"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SafetyReliefValve(x) ↔ (Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety relief valve is a valve that has the function of providing both safety protection and pressure relief.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow meter is an instrument that bears a flow measurement function and has component parts including a flow sensing element and signal processing unit</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">flow meter</rdfs:label>
    <rdfs:label xml:lang="pt-br">medidor de vazão</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão é um instrumento que possui uma função de medir taxa de fluxo e produzir sinais ou indicações correspondentes.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeter(x) ↔ Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1201"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1232">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSignalTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BranchPort">
    <rdfs:label xml:lang="pt-br">bocal de ramal</rdfs:label>
    <rdfs:label xml:lang="en">branch port</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a branch outlet port on a manifold or pipe fitting through which flow is diverted to a secondary flow path.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000263">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ElectricalConnector ≡ ElectricalEquipment ⊓ ∃bearerOf.ElectricalConnectionFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">electrical connector</rdfs:label>
    <rdfs:label xml:lang="pt-br">conector elétrico</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnector(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalConnectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab961"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um conector elétrico é um equipamento elétrico que possui uma função de conexão elétrica e que mantém contato elétrico íntimo entre duas ou mais partes de condutor elétrico para permitir fluxo contínuo de corrente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab318">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab319"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1526">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpInlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1279"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2460"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1535"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab361"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2461"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab362"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2298"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2323"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1278"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1536"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2297"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2324"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation of a mixed-phase or mixed-component stream into distinct phases or fractions.</skos:definition>
    <rdfs:label xml:lang="en">separation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de separação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1766"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1767"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">material processing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de processamento de material</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the physical or chemical transformation of a material to alter its composition, form, or physical state.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TransductionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2590"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2591"/>
    <rdfs:label xml:lang="pt-br">função de transdução</rdfs:label>
    <rdfs:label xml:lang="en">transduction function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of one form of physical signal or energy into another form suitable for measurement or transmission.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui um componente de superfície de vedação e participa em processos de fechamento de válvulas, consistindo na parte da válvula contra a qual o elemento de fechamento se apoia para proporcionar vedação hermética.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Seat is a MaterialArtifact that has some sealing surface component at all times and participates in some valve closing process.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions for 'seat' based solely on structural properties could lead to false positives where other valve components with sealing surfaces are incorrectly classified as seats.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2317"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Seat(x) → MaterialArtifact(x) ∧ ∃y(SealingSurface(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ValveClosingProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">assento</rdfs:label>
    <rdfs:label xml:lang="en">seat</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1503">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab330">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1945"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1930"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1164"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1916"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1929"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1165"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1950"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1934"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1951"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1935"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1470"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1915"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1469"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1946"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2220"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2221"/>
    <rdfs:label xml:lang="pt-br">função de condução de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid conduction function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conveyance of a fluid from one location to another while maintaining containment and flow direction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1689">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2303">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1955">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BranchPort"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2298">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess">
    <rdfs:label xml:lang="pt-br">processo de suporte estrutural</rdfs:label>
    <rdfs:label xml:lang="en">structural support process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovingVane">
    <skos:definition xml:lang="en">A material artifact that constitutes a moving blade or vane within a turbine, pump, or separator that interacts with a fluid stream in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">palheta móvel</rdfs:label>
    <rdfs:label xml:lang="en">moving vane</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab47">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab48"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CableSupportProcess">
    <rdfs:label xml:lang="en">cable support process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de suporte de cabos</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which cables are mechanically supported and routed to maintain their position and protect them from damage in a petroleum production installation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1733"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1732"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of a mechanical force or pressure into a proportional electrical signal.</skos:definition>
    <rdfs:label xml:lang="en">force to electrical transduction function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transdução força-elétrica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction">
    <rdfs:label xml:lang="pt-br">função de acumulação</rdfs:label>
    <rdfs:label xml:lang="en">accumulation function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab19"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab18"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the collection and temporary holding of fluid to buffer flow variations or build up inventory.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab789">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab787"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109">
    <skos:definition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureGauge(x) ↔ PressureGauge(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(DifferentialPressureMeasuringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(PressurePortPair(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">differential pressure gauge</rdfs:label>
    <rdfs:label xml:lang="pt-br">manômetro de pressão diferencial</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro de pressão diferencial é um manômetro que mede e indica a diferença entre duas entradas de pressão usando um elemento de medição de pressão diferencial.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab776"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure gauge is a pressure gauge that bears a DifferentialPressureMeasurementFunction and has component parts including a DifferentialPressureMeasuringElement and PressurePortPair.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatingMedium">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">heating medium</rdfs:label>
    <rdfs:label xml:lang="pt-br">meio de aquecimento</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the fluid—steam, hot oil, or heated water—used to supply thermal energy to a process stream in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000244">
    <skos:definition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um demister é um separador que possui uma função de desmistificação para remover gotículas de líquido de correntes gasosas através de mecanismos de coalescência.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">demister</rdfs:label>
    <rdfs:label xml:lang="pt-br">demister</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab666"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Demister(x) ↔ Separator(x) ∧ ∃f(DemistingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every demister is a separator that has the function of demisting gas streams by coalescing and removing entrained liquid droplets.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1131">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1551">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurement">
    <rdfs:label xml:lang="en">flow measurement</rdfs:label>
    <rdfs:label xml:lang="pt-br">medição de fluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting a quantitative value representing the flow rate of a process stream as measured by petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000249">
    <iof-av:naturalLanguageDefinition xml:lang="en">A diaphragm pump is a reciprocating pump that uses flexible diaphragms to displace liquid and seal the pumped fluid from atmospheric leakage.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de diafragma é uma bomba alternativa que usa diafragmas flexíveis para deslocar líquido e selar o fluido bombeado contra vazamento atmosférico.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under OWA, any pump with a flexible diaphragm component could be classified as a diaphragm pump, but there may be hybrid or specialized equipment containing diaphragms that should not be automatically classified into this maintenance category.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A diaphragm pump is a reciprocating pump that uses flexible diaphragms to displace liquid and seal the pumped fluid from atmospheric leakage.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DiaphragmPump(x) → (ReciprocatingPump(x) ∧ ∃d(FlexibleDiaphragm(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p(DiaphragmSealing(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab733"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab732"/>
    <rdfs:label xml:lang="pt-br">bomba de diafragma</rdfs:label>
    <rdfs:label xml:lang="en">diaphragm pump</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diaphragm pump is a reciprocating pump that has flexible diaphragm as component part at all times and participates in diaphragm sealing.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction">
    <rdfs:label xml:lang="en">turbomachinery power generation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de geração de energia por turbomáquina</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1308"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1307"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of fluid enthalpy into shaft power through interaction with rotating turbine blades.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidPortion">
    <rdfs:label xml:lang="en">liquid portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção líquido</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of liquid phase material at a defined point in a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2411">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000378">
    <skos:definition xml:lang="en">A wireline is an electrical cable that bears a wireline logging function for lowering tools into wellbores and transmitting data about wellbore conditions.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2828"/>
    <rdfs:label xml:lang="en">wireline</rdfs:label>
    <rdfs:label xml:lang="pt-br">wireline</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wireline is an electrical cable that has the function to lower tools into wellbores and transmit logging data signals to the surface.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Wireline(x) ↔ ElectricalCable(x) ∧ ∃f (WirelineLoggingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wireline is an electrical cable that bears a wireline logging function for lowering tools into wellbores and transmitting data about wellbore conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um wireline é um cabo elétrico que possui uma função de perfilagem wireline para descer ferramentas em poços e transmitir dados sobre as condições do poço.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1951">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1222">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1968">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1965"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a protective barrier shields a temperature sensing element from direct contact with the process medium while maintaining thermal conductivity to enable accurate temperature measurement.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de proteção de sensor de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature sensor protection process</rdfs:label>
    <skos:definition xml:lang="en">A PlannedProcess in which a protective barrier shields a temperature sensing element from direct contact with the process medium while maintaining thermal conductivity to enable accurate temperature measurement.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000258">
    <rdfs:label xml:lang="en">dryer</rdfs:label>
    <rdfs:label xml:lang="pt-br">secador</rdfs:label>
    <skos:definition xml:lang="en">A dryer is an assembly that bears a drying function to remove moisture from materials.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dryer(x) ↔ Assembly(x) ∧ ∃f(DryingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dryer is an assembly that bears a drying function to remove moisture from materials.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um secador é um conjunto que possui uma função de secagem para remover umidade de materiais.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab889"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dryer is an assembly that has the function of drying materials by removing moisture.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1954">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2075">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DemistingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de separação de névoa</rdfs:label>
    <rdfs:label xml:lang="en">demisting process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which entrained liquid droplets are coalesced and removed from a gas stream by petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasPortion">
    <rdfs:label xml:lang="en">waste gas portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de resíduo de gás</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of waste or surplus gas generated in petroleum production operations that is directed to disposal equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1754">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Chamber"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2514">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2515"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000113">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab942"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">motor elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electric motor</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric motor is an assembly that bears an electric-to-mechanical conversion function and has component parts including a stator and rotor at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor elétrico é um conjunto que possui uma função de conversão de energia elétrica para mecânica e tem tanto um estator quanto um rotor como componentes essenciais.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">ElectricMotor(x) ↔ Assembly(x) ∧ ∃f(ElectricToMechanicalConversionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(Stator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃r(Rotor(r) ∧ hasComponentPartAtAllTimes(x,r))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1603">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2578">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThreePhaseSeparationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab971">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab972"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Manifold(x) → Assembly(x) ∧ ∃c(Chamber(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃o(MultipleFluidOpenings(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃f(FluidDistributionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</skos:definition>
    <rdfs:label xml:lang="pt-br">manifold</rdfs:label>
    <rdfs:label xml:lang="en">manifold</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every manifold is an assembly that has-component-part-at-all-times some chamber and has-component-part-at-all-times some multiple fluid openings and bears some fluid distribution function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1753"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1755"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1754"/>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type, manifolds are defined by structural configuration. Under OWA, asserting equivalence would force any assembly with a chamber and multiple openings to be classified as a manifold, potentially misclassifying complex equipment with manifold-like components (e.g., turbine casings, complex valves). Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manifold é um conjunto que possui uma câmara com múltiplas aberturas de fluido projetada para distribuir o fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess">
    <rdfs:label xml:lang="pt-br">processo de condução elétrica</rdfs:label>
    <rdfs:label xml:lang="en">electrical conduction process</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab198">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab199"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab72">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureIndicationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2141">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MasterValve">
    <rdfs:label xml:lang="en">master valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de principal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the main isolation valve at the base of a Christmas tree that controls fluid flow from the tubing head.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingFunction">
    <rdfs:label xml:lang="en">differential pressure switching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de chaveamento por pressão diferencial</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the differential pressure between two process points crosses a defined threshold.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab791"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab790"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000367">
    <skos:definition xml:lang="en">An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every umbilical is an assembly that has component parts including cable bundles and tubing bundles, and has the qualities of flexibility and easy disconnectability.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um umbilical é uma montagem que é um feixe flexível e facilmente desconectável contendo cabos e tubulação para transmissão de múltiplos serviços incluindo controle, energia, comunicação e injeção química.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2676"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2675"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2674"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Umbilical(x) → Assembly(x) ∧ ∃c,t,s,conn (CableBundle(c) ∧ TubingBundle(t) ∧ ProtectiveSheathing(s) ∧ ConnectorAssembly(conn) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,t) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,conn) ∧ hasQuality(x,Flexibility) ∧ hasQuality(x,EasyDisconnectability)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive basis requires necessary conditions only. Under OWA, any assembly with cables, tubing, flexibility, and disconnectability could be forcibly classified as umbilical, including specialized multi-service bundles, complex wiring harnesses, or custom transmission assemblies that contain these elements but serve different industrial contexts and maintenance categories.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">umbilical</rdfs:label>
    <rdfs:label xml:lang="pt-br">umbilical</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalVariable">
    <skos:definition xml:lang="en">An information content entity constituting a measurable physical property—such as pressure, temperature, or flow rate—of a process stream or equipment state in petroleum production.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdfs:label xml:lang="pt-br">variável físico</rdfs:label>
    <rdfs:label xml:lang="en">physical variable</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072">
    <rdfs:label xml:lang="pt-br">bomba</rdfs:label>
    <rdfs:label xml:lang="en">pump</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump is an assembly that has the function of pumping fluid</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Pump(x) ↔ (Assembly(x) ∧ ∃f (PumpingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba é um conjunto que possui a função projetada de adicionar energia mecânica ao fluido para pressurização e transporte.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2152"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab826">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2534">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1063">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de absorção</rdfs:label>
    <rdfs:label xml:lang="en">absorption process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which one or more gaseous components are transferred from a gas phase into a liquid absorbent phase through contact in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DisturbanceSource">
    <rdfs:label xml:lang="pt-br">fonte de perturbação</rdfs:label>
    <rdfs:label xml:lang="en">disturbance source</rdfs:label>
    <skos:definition xml:lang="en">A process in which a source of unwanted perturbation—vibration, electrical noise, or pressure surge—affecting the performance of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab373">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1186">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1183"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1187"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000259">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab904"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab905"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Eductor(x) → Pump(x) ∧ ∃n(MotiveFluidNozzle(n) ∧ hasComponentPartAtAllTimes(x,n)) ∧ ∃t(VenturaThroat(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(JetEntrainmentProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">edutor</rdfs:label>
    <rdfs:label xml:lang="en">eductor</rdfs:label>
    <skos:definition xml:lang="en">An eductor is a pump that uses a high-pressure motive fluid jet to create a low-pressure zone that entrains and moves a second fluid via momentum transfer.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um edutor é uma bomba que usa um jato de fluido motriz de alta pressão para criar uma zona de baixa pressão que arrasta e move um segundo fluido via transferência de momento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An eductor is a pump that uses a high-pressure motive fluid jet to create a low-pressure zone that entrains and moves a second fluid via momentum transfer.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">The constructive differentia based on jet entrainment mechanism could potentially apply to hybrid or specialized equipment that incorporates eductor principles but should not be automatically classified as a standard eductor type. Under OWA, necessary conditions protect against false positive classifications.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every eductor is a pump that has a motive fluid nozzle and Ventura throat as component parts and participates in a jet entrainment process.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialPortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a defined quantity of a material substance at a specified point in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção de material</rdfs:label>
    <rdfs:label xml:lang="en">material portion</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1720">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2140">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionFunction">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab517"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab518"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A signal transmission function borne by petroleum production equipment whose realization constitutes the measurement of fluid electrical conductivity and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de transmissão de condutividade</rdfs:label>
    <rdfs:label xml:lang="en">conductivity transmission function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab767">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab103">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000283">
    <skos:definition xml:lang="en">A gas cyclone separator is a separator that separates solid particles or liquid droplets from gas using centrifugal force generated by cyclonic flow geometry.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador ciclônico de gás é um separador que separa partículas sólidas ou gotículas líquidas do gás usando força centrífuga gerada pela geometria de fluxo ciclônico.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas cyclone separator is a separator that separates solid particles or liquid droplets from gas using centrifugal force generated by cyclonic flow geometry.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1283"/>
    <rdfs:label xml:lang="pt-br">separador ciclônico de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas cyclone separator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GasCycloneSeparator(x) → Separator(x) ∧ ∃y(CyclonicFlowChamber(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CentrifugalSeparationProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by cyclonic mechanism. Under Open World Assumption, any device with cyclonic flow chamber could be falsely classified as gas cyclone separator, including specialized multi-stage cyclones or hybrid separator designs that should not be forced into this standard maintenance category.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas cyclone separator is a separator that has a cyclonic flow chamber as component part and participates in centrifugal separation processes.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellFluid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">fluido de poço</rdfs:label>
    <rdfs:label xml:lang="en">well fluid</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the fluid—hydrocarbon, water, or gas—produced from or injected into a petroleum production well.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2562">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2314"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1320"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1319"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2313"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a SealingProcess and that consists in providing a tight interface against which a closure element bears to prevent fluid leakage through a valve.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de vedação</rdfs:label>
    <rdfs:label xml:lang="en">sealing function</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a SealingProcess and that consists in providing a tight interface against which a closure element bears to prevent fluid leakage through a valve.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab969">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab971"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1169">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1473">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PneumaticEnergyConversionProcess">
    <rdfs:label xml:lang="en">pneumatic energy conversion process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de conversão de energia pneumática</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which compressed-gas energy is converted into rotational mechanical energy by pneumatic actuators or motors.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which liquid at the base of a distillation column is partially vaporised by the supply of heat to drive vapour upward through the column.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">reboiling process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de refervimento</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab507">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which electrochemical corrosion of a metallic structure is prevented by making it the cathode of an electrochemical cell through the supply of electrical current or sacrificial anodes.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de proteção catódica</rdfs:label>
    <rdfs:label xml:lang="en">cathodic protection process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1624">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction">
    <rdfs:label xml:lang="pt-br">função de aquecimento a combustão</rdfs:label>
    <rdfs:label xml:lang="en">fired heating function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1063"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1062"/>
    <skos:definition xml:lang="en">A heating function borne by petroleum production equipment whose realization constitutes the transfer of thermal energy generated by combustion to a process stream or vessel.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2732"/>
    <iof-av:primitiveRationale xml:lang="en">Valve seat is a constructive type defined by its structural configuration and interface role. Under the Open World Assumption, making this an equivalence class could lead to false positives where any artifact that is part of a valve and adjacent to a closure member gets classified as a valve seat, even if it serves a different structural role (such as guides, stops, or supports).</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ValveSeat ⊑ MaterialArtifact ⊓ ∃partOf.Valve ⊓ ∃adjacentTo.ValveClosureMember ⊓ ∃bearerOf.SealingSurfaceQuality</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ValveSeat(x) → (MaterialArtifact(x) ∧ ∃y(Valve(y) ∧ partOf(x,y)) ∧ ∃z(ValveClosureMember(z) ∧ adjacentTo(x,z)) ∧ ∃q(SealingSurfaceQuality(q) ∧ bearerOf(x,q))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é parte de uma válvula e que fornece a superfície de assentamento contra a qual o membro de fechamento se apoia para alcançar o fechamento e controle do fluxo de fluido de processo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">assento de válvula</rdfs:label>
    <rdfs:label xml:lang="en">valve seat</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1074">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1431">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1851">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1520"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1519"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
    <rdfs:label xml:lang="pt-br">função de bombeamento hidráulico</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic pumping function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A pumping function borne by petroleum production equipment whose realization constitutes the transfer of mechanical energy to a hydraulic fluid to transmit power or actuate hydraulic equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab928">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab930"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressedGasPortion">
    <rdfs:label xml:lang="pt-br">porção comprimido de gás</rdfs:label>
    <rdfs:label xml:lang="en">compressed gas portion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas that has been compressed to a higher pressure for transport, storage, or processing in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FuelPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="en">fuel portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de combustível</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of fuel supplied to a combustion device in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab863"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab862"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
    <skos:definition xml:lang="en">A designed function borne by a downhole safety valve whose realization constitutes the isolation of wellbore flow to prevent uncontrolled release of reservoir fluids to surface.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de segurança subsuperficial</rdfs:label>
    <rdfs:label xml:lang="en">subsurface safety function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2585">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2586"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the reception and re-transmission of a control or monitoring signal to extend its range or provide electrical isolation.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de retransmissão de sinal</rdfs:label>
    <rdfs:label xml:lang="en">signal relay function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2182"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2181"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShakingFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2343"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2342"/>
    <rdfs:label xml:lang="pt-br">função de agitação mecânica</rdfs:label>
    <rdfs:label xml:lang="en">shaking function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the application of oscillating mechanical motion to a screen or separator to promote separation of solids from a fluid.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CableBundle">
    <rdfs:label xml:lang="en">cable bundle</rdfs:label>
    <rdfs:label xml:lang="pt-br">feixe de cabo</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <skos:definition xml:lang="en">An assembly of electrical cables routed together and secured as a group in a petroleum production installation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess">
    <rdfs:label xml:lang="en">bottom hole drilling process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de perfuração de fundo de poço</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which subsurface rock at the bottom of a wellbore is cut and disintegrated by a drill bit to advance the drill hole.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CleanedGasPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">cleaned gas portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção limpo de gás</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas from which impurities have been removed by petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000240">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab609"/>
    <skos:definition xml:lang="en">A deaerator is a separator designed to remove dissolved gases from liquid streams through specialized degassing processes.</skos:definition>
    <rdfs:label xml:lang="pt-br">desaerador</rdfs:label>
    <rdfs:label xml:lang="en">deaerator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Deaerator(x) ↔ (Separator(x) ∧ ∃f(DeaerationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every deaerator is a separator that bears a deaeration function for removing dissolved gases from liquids</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A deaerator is a separator designed to remove dissolved gases from liquid streams through specialized degassing processes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desaerador é um separador projetado para remover gases dissolvidos de correntes líquidas através de processos especializados de desgaseificação.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCable">
    <rdfs:label xml:lang="pt-br">cabo elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electrical cable</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an insulated conductor or assembly of conductors used to transmit electrical power or signals in a petroleum production installation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical power is transferred from one rotating or reciprocating component to another through direct mechanical engagement, resulting in motion transmission and potentially torque or speed modification.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted through rotational motion from one component to another via a rotating shaft, enabling the transfer of torque and angular velocity to mounted components.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from an external energy source through a rotating shaft to downstream mechanical components, enabling power transfer within a mechanical system.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transferred from a prime mover through a rotating shaft to one or more driven machines, typically involving the conversion of torque and rotational speed to match operational requirements.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from a driving component to a driven component through the rotation or linear motion of a shaft, enabling the transfer of torque and rotational speed.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which mechanical rotational energy is transmitted from a prime mover through a shaft to driven components, resulting in the transfer of torque and rotational motion necessary for equipment operation.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical rotational energy is transmitted from a prime mover through a shaft to driven components, resulting in the transfer of torque and rotational motion necessary for equipment operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted through rotational motion from one component to another via a rotating shaft, enabling the transfer of torque and angular velocity to mounted components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical power is transferred from one rotating or reciprocating component to another through direct mechanical engagement, resulting in motion transmission and potentially torque or speed modification.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transferred from a prime mover through a rotating shaft to one or more driven machines, typically involving the conversion of torque and rotational speed to match operational requirements.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from an external energy source through a rotating shaft to downstream mechanical components, enabling power transfer within a mechanical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from a driving component to a driven component through the rotation or linear motion of a shaft, enabling the transfer of torque and rotational speed.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de transmissão de potência</rdfs:label>
    <rdfs:label xml:lang="en">power transmission process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">válvula agulha</rdfs:label>
    <rdfs:label xml:lang="en">needle valve</rdfs:label>
    <skos:definition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(NeedleValve(x) → Valve(x) ∧ ∃y(NeedlePlug(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(SmallOrificeSeat(z) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1815"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every needle valve is a valve that has a needle plug component and has a small orifice seat component.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by specific structural features (needle plug geometry), providing sufficient conditions under the Open World Assumption could lead to over-classification. Complex valve assemblies or custom equipment containing needle-like mechanisms might be incorrectly classified as standard needle valves for maintenance purposes.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula agulha é uma válvula que possui um membro de fechamento cônico em forma de agulha que se assenta em um pequeno orifício para fornecer controle preciso de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab786"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure element that bears a differential pressure measurement function and that consists in sensing the pressure difference between two fluid media or connection points to enable measurement of differential pressure through mechanical deflection proportional to the pressure difference.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão que porta uma função de medição de pressão diferencial e que consiste em detectar a diferença de pressão entre duas mídias fluidas ou pontos de conexão para permitir a medição de pressão diferencial através de deflexão mecânica proporcional à diferença de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DifferentialPressureMeasuringElement(x) ↔ (PressureElement(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">elemento medidor de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure measuring element</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DifferentialPressureMeasuringElement equivalentTo PressureElement and bearerOf some DifferentialPressureMeasurementFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A pressure element that bears a differential pressure measurement function and that consists in sensing the pressure difference between two fluid media or connection points to enable measurement of differential pressure through mechanical deflection proportional to the pressure difference.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101">
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because under OWA, any equipment with a centrifugal impeller could be incorrectly classified as a standard centrifugal compressor, including specialized hybrid equipment or multi-stage systems that contain centrifugal elements but should not be forced into this maintenance category. Domain expert validation needed to confirm structural differentia is sufficient.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</skos:definition>
    <rdfs:label xml:lang="en">centrifugal compressor</rdfs:label>
    <rdfs:label xml:lang="pt-br">compressor centrífugo</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um compressor centrífugo é um compressor que usa um ou mais impelidores centrífugos para acelerar o gás através de fluxo radial e gerar aumento de pressão por ação centrífuga.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab346"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab347"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CentrifugalCompressor(x) → Compressor(x) ∧ ∃i(CentrifugalImpeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃p(RadialFlowPattern(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal compressor is a compressor that has component part at all times some centrifugal impeller and participates in some radial flow pattern.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab732">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab880">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab882"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2661">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2659"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportedElectricalCable">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:label xml:lang="en">supported electrical cable</rdfs:label>
    <rdfs:label xml:lang="pt-br">cabo suportado elétrico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an electrical cable that is mechanically supported and routed by cable support systems in a petroleum production installation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparatedSolidLiquidPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the solid–liquid fraction recovered after a phase separation process in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">porção separado líquido de sólido</rdfs:label>
    <rdfs:label xml:lang="en">separated solid liquid portion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab543">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab545"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000187">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1698"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1697"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de medição e transmissão de nível</rdfs:label>
    <rdfs:label xml:lang="en">level measurement and transmission function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and remote transmission of the fluid level within a vessel.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">coalescence process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de coalescência</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which dispersed droplets of one phase aggregate within another to form larger droplets that can be more readily separated from the continuous phase.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess">
    <skos:definition xml:lang="en">A planned process in which a heterogeneous mixture is divided into two or more fractions of differing composition by exploiting differences in physical properties.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de separação</rdfs:label>
    <rdfs:label xml:lang="en">separation process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab563">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab300">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000364">
    <rdfs:label xml:lang="en">tubing hanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">suporte de coluna de produção</rdfs:label>
    <skos:definition xml:lang="en">A tubing hanger is an assembly that supports tubing strings in wellheads with integrated sealing to isolate tubing conduit from annulus.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um suporte de coluna de produção é um conjunto que suporta colunas de produção em cabeças de poço com vedação integrada para isolar o conduto da coluna do anular.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A tubing hanger is an assembly that supports tubing strings in wellheads with integrated sealing to isolate tubing conduit from annulus.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TubingHanger(x) ↔ (Assembly(x) ∧ ∃f(TubingSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SealingSystem(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(SupportMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(TubingConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every tubing hanger is an assembly that bears a tubing support function and has component parts including a sealing system, support mechanism, and tubing connection.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2630"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000345">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lavador de gases é um separador que limpa gás através da lavagem do fluxo gasoso com líquido para remover contaminantes como poeira, partículas ou substâncias indesejadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</skos:definition>
    <rdfs:label xml:lang="en">scrubber</rdfs:label>
    <rdfs:label xml:lang="pt-br">lavador de gases</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2303"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Scrubber(x) ↔ Separator(x) ∧ ∃f,p,g,l (SeparationFunction(f) ∧ bearerOf(x,f) ∧ LiquidWashingProcess(p) ∧ participatesIn(x,p) ∧ GasPortion(g) ∧ LiquidPortion(l) ∧ hasInput(x,g) ∧ hasInput(x,l)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every scrubber is a separator that has the function of separation and participates in liquid washing processes with both gas and liquid inputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1079">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1080"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction">
    <rdfs:label xml:lang="pt-br">função de lançamento de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig launching function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1867"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1868"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled introduction of a pipeline pig into a pipeline under operating pressure.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2148">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab240">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BoilingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Chamber">
    <skos:definition xml:lang="en">A material artifact that constitutes an enclosed space within petroleum production equipment in which a process such as separation, compression, or storage takes place.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">câmara</rdfs:label>
    <rdfs:label xml:lang="en">chamber</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000288">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">carcaça de caixa de engrenagens</rdfs:label>
    <rdfs:label xml:lang="en">gear casing</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">This is a constructive type defined by its physical configuration as a specific type of casing. Under OWA, declaring equivalence could lead to over-classification where any casing containing gear-like components might be inappropriately classified as a standard gear casing, including custom enclosures or hybrid systems that should not fall into this maintenance category.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1358"/>
    <skos:definition xml:lang="en">A casing that contains and houses the internal components of a gear mechanism, providing protective enclosure and structural support.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que contém e abriga os componentes internos de um mecanismo de engrenagem, fornecendo invólucro protetor e suporte estrutural.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing that contains and houses the internal components of a gear mechanism, providing protective enclosure and structural support.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GearCasing(x) → casing(x) ∧ ∃y(GearMechanism(y) ∧ hasContent(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">GearCasing ⊑ casing ⊓ ∃hasContent.GearMechanism</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1364">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1965">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab417">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1170">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1600">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1601"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000375"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1261">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2810">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2811"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000180">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1479"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1480"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">humidity measurement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição de umidade</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and display of the moisture content or relative humidity of a gas stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215">
    <skos:definition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bearing is a material artifact that bears a support function and participates in friction reduction processes</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">bearing</rdfs:label>
    <rdfs:label xml:lang="pt-br">mancal</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab173"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um mancal é um artefato material que é projetado para suportar e localizar elementos mecânicos móveis ou estáticos enquanto reduz o atrito na conexão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Bearing(x) ↔ MaterialArtifact(x) ∧ ∃f(SupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(FrictionReductionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab817">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab820"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">visual inspection process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de inspeção visual</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DivertingFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the redirection of fluid flow from one path to one or more alternative downstream paths.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab849"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab848"/>
    <rdfs:label xml:lang="en">diverting function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de desvio de fluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257">
    <iof-av:naturalLanguageDefinition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de transmissão é um Assembly que possui uma PowerTransmissionFunction e consiste em um sistema baseado em eixo usado para transferir energia mecânica rotacional de um motor primário para múltiplas máquinas acionadas.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DriveShaft(x) ↔ (Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(RotationalPowerTransferProcess(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">eixo de transmissão</rdfs:label>
    <rdfs:label xml:lang="en">drive shaft</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab880"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DriveShaft ≡ Assembly ⊓ ∃bearerOf.PowerTransmissionFunction ⊓ ∃participatesIn.RotationalPowerTransferProcess</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensePhase">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">fase denso</rdfs:label>
    <rdfs:label xml:lang="en">dense phase</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the denser of two or more phases present in a separation process within petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab200">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab197"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2785">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2674">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DieselFuel">
    <skos:definition xml:lang="en">A material artifact that constitutes diesel fuel used as energy source for engines or combustion equipment in petroleum production installations.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">combustível diesel</rdfs:label>
    <rdfs:label xml:lang="en">diesel fuel</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2786"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2785"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled physical interaction with subsurface formations to enable exploration, drilling, completion, or production activities.</skos:definition>
    <rdfs:label xml:lang="en">subsurface resource interaction function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de interação com recursos subsuperficiais</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1595">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000351">
    <rdfs:label xml:lang="en">silo</rdfs:label>
    <rdfs:label xml:lang="pt-br">silo</rdfs:label>
    <skos:definition xml:lang="en">A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2398"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every silo is a vessel that has the function of storing bulk solids and has a conical bottom component.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um silo é um vaso que possui uma função de armazenamento de sólidos a granel e tem uma seção inferior cônica para facilitar o armazenamento e descarga de materiais sólidos a granel.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Silo(x) ↔ (Vessel(x) ∧ ∃f(SolidBulkStorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(ConicalBottom(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionFunction">
    <rdfs:label xml:lang="pt-br">função de combustão</rdfs:label>
    <rdfs:label xml:lang="en">combustion function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab272"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab271"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the exothermic chemical reaction of a fuel with an oxidant to produce heat and combustion products.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DistillationProcess">
    <rdfs:label xml:lang="pt-br">processo de destilação</rdfs:label>
    <rdfs:label xml:lang="en">distillation process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a liquid mixture is separated into fractions of differing volatilities by successive vaporisation and condensation in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2823"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2822"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">wireline logging function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de perfilagem por wireline</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the acquisition of subsurface formation and wellbore data by lowering measurement tools into the well on a wireline cable.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FinnedTube">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a heat transfer tube with extended surfaces—fins—that increase the external surface area to enhance heat exchange with a gas stream.</skos:definition>
    <rdfs:label xml:lang="pt-br">tubo de aletado</rdfs:label>
    <rdfs:label xml:lang="en">finned tube</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralForce">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="en">structural force</rdfs:label>
    <rdfs:label xml:lang="pt-br">força estrutural</rdfs:label>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a force transmitted through a structural element of petroleum production equipment due to imposed loads.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1788">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every reciprocating pump is a pump that has as component part at all times a reciprocating displacement mechanism and has as component part at all times pistons or plungers and has as component part at all times cylindrical chambers.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2174"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under Open World Assumption, asserting equivalence based on structural differentia could lead to false positives where complex equipment containing reciprocating elements (like reciprocating compressors with auxiliary pumps, or hybrid systems) might be incorrectly classified as standard reciprocating pumps. The structural mechanism is necessary but sufficient conditions require domain expert validation.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">bomba alternativa</rdfs:label>
    <rdfs:label xml:lang="en">reciprocating pump</rdfs:label>
    <skos:definition xml:lang="en">A reciprocating pump is a pump that contains pistons or plungers designed to move in a reciprocating motion within cylindrical chambers to displace fluid through positive displacement action.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba alternativa é uma bomba que contém pistões ou êmbolos projetados para se moverem em movimento alternativo dentro de câmaras cilíndricas para deslocar fluido através de ação de deslocamento positivo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A reciprocating pump is a pump that contains pistons or plungers designed to move in a reciprocating motion within cylindrical chambers to displace fluid through positive displacement action.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ReciprocatingPump(x) → Pump(x) ∧ ∃m(ReciprocatingDisplacementMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p(PistonOrPlunger(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃c(CylindricalChamber(c) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceIndication">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdfs:label xml:lang="en">phase sequence indication</rdfs:label>
    <rdfs:label xml:lang="pt-br">indicação de fase de sequência</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting a displayed or transmitted value representing the phase sequence of an alternating-current electrical supply in a petroleum production installation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236">
    <skos:definition xml:lang="en">A cooling tower is a heat exchanger that incorporates a tall tower structure through which air circulates by convection to remove heat from process fluids.</skos:definition>
    <rdfs:label xml:lang="en">cooling tower</rdfs:label>
    <rdfs:label xml:lang="pt-br">torre de resfriamento</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab569"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cooling tower is a heat exchanger that incorporates a tall tower structure through which air circulates by convection to remove heat from process fluids.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma torre de resfriamento é um trocador de calor que incorpora uma estrutura de torre alta através da qual o ar circula por convecção para remover calor de fluidos de processo.</iof-av:naturalLanguageDefinition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CoolingTower(x) ↔ HeatExchanger(x) ∧ ∃t(Tower(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(ConvectiveAirCirculationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooling tower is a heat exchanger that has a tower structure as component part at all times and participates in convective air circulation processes.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess">
    <skos:definition xml:lang="en">A planned process in which dissolved oxygen and other non-condensable gases are removed from a liquid stream in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">deaeration process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de desaeração</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000186">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab804"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab805"/>
    <rdfs:label xml:lang="en">differential pressure transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de pressão diferencial</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and remote transmission of the differential pressure between two process points.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab956">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab954"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000336">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de bomba é um MaterialArtifact que possui uma PowerTransmissionFunction e que é equipado com impulsor(es), mancais, buchas e elementos de vedação como parte de um conjunto de bomba para transmitir energia mecânica rotacional e possibilitar operações de bombeamento de fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction and that is equipped with impeller(s), bearings, bushings, and sealing elements as part of a pump assembly for transmitting rotational mechanical energy to enable fluid pumping operations.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pump shaft</rdfs:label>
    <rdfs:label xml:lang="pt-br">eixo de bomba</rdfs:label>
    <skos:definition xml:lang="en">A pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction and that is equipped with impeller(s), bearings, bushings, and sealing elements as part of a pump assembly for transmitting rotational mechanical energy to enable fluid pumping operations.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration, sufficient conditions are omitted to avoid false positives under OWA. Any rotating component with an impeller and bearings could theoretically be classified as a pump shaft under sufficient conditions, including hybrid equipment or specialized assemblies that should not be automatically categorized as standard pump shafts.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PumpShaft(x) → MaterialArtifact(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(Impeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃b(Bearing(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃p(Pump(p) ∧ partOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction, has impeller(s) as component parts, has bearings as component parts, and is part of a pump assembly.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2169"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000223">
    <rdfs:label xml:lang="pt-br">sistema de proteção catódica</rdfs:label>
    <rdfs:label xml:lang="en">cathodic protection system</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A cathodic protection system is a corrosion protection system that uses electrochemical cathodic protection mechanisms with anodes to prevent corrosion of carbon and low-alloy steel equipment or structures.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um sistema de proteção catódica é um sistema de proteção contra corrosão que usa mecanismos eletroquímicos de proteção catódica com ânodos para prevenir a corrosão de equipamentos ou estruturas de aço carbono e baixa liga.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cathodic protection system is a corrosion protection system that uses electrochemical cathodic protection mechanisms with anodes to prevent corrosion of carbon and low-alloy steel equipment or structures.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab336"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CathodicProtectionSystem(x) ↔ CorrosionProtectionSystem(x) ∧ ∃f(CathodicProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃a(Anode(a) ∧ hasComponentPartAtSomeTime(x,a)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cathodic protection system is a corrosion protection system that bears a cathodic protection function and has anodes as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1498">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2489"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2488"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the switching, routing, or regulation of current in an electrical circuit to control connected loads.</skos:definition>
    <rdfs:label xml:lang="en">electrical circuit control function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de controle de circuito elétrico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentInterruptionProcess">
    <rdfs:label xml:lang="en">electrical current interruption process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de interrupção de corrente elétrica</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which an electrical circuit is opened to stop the flow of current, either under normal operating conditions or in response to a fault.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1801">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab286">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab285">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="en">drilling fluid portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de perfuração de fluido</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of drilling fluid at a defined point in the drilling circulation system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PolyphaseElectricalSignal">
    <rdfs:label xml:lang="pt-br">sinal polifásico elétrico</rdfs:label>
    <rdfs:label xml:lang="en">polyphase electrical signal</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting a multi-phase electrical signal used to characterise or transmit information about a polyphase alternating-current supply.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluid">
    <rdfs:label xml:lang="pt-br">fluido de perfuração</rdfs:label>
    <rdfs:label xml:lang="en">drilling fluid</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the fluid—water-based, oil-based, or synthetic—circulated during drilling to cool the bit, carry cuttings to surface, and stabilise the wellbore.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DownholeToolAssembly">
    <skos:definition xml:lang="en">A material artifact that constitutes an assembly of tools deployed in a wellbore on a wireline or tubing string to perform measurement, completion, or intervention operations.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">downhole tool assembly</rdfs:label>
    <rdfs:label xml:lang="pt-br">conjunto de fundo de poço de ferramenta</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2545">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2617">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2615"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab707"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab706"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">dew point measurement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição de ponto de orvalho</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the temperature at which a gas mixture begins to condense.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ScrapingFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2282"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2283"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical removal of deposits, scale, or coatings from the interior surface of a pipeline or vessel.</skos:definition>
    <rdfs:label xml:lang="en">scraping function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de raspagem</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2164">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2130">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2128"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidPort">
    <rdfs:label xml:lang="pt-br">bocal de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid port</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a port or connection point through which fluid enters or exits a component of petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab883">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab881"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Heater(x) ↔ Assembly(x) ∧ ∃f(HeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">aquecedor</rdfs:label>
    <rdfs:label xml:lang="en">heater</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heater is an assembly that bears a heating function and has heating elements and housing as component parts at all times</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1454"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab744">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Valve(x) ↔ MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula é um conjunto que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2707"/>
    <rdfs:label xml:lang="en">valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Might be too restrictive to define as sufficient being a material artifact and having a flow control function.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000313">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Mill(x) ↔ (Assembly(x) ∧ ∃f(MaterialProcessingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every mill is an assembly that has the function to process materials, and every assembly that has the function to process materials is a mill.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A mill is an assembly that bears a material processing function to reduce particle size or modify solid materials through mechanical grinding, cutting, or crushing operations.</skos:definition>
    <rdfs:label xml:lang="pt-br">moinho</rdfs:label>
    <rdfs:label xml:lang="en">mill</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A mill is an assembly that bears a material processing function to reduce particle size or modify solid materials through mechanical grinding, cutting, or crushing operations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um moinho é um conjunto que possui uma função de processamento de material para reduzir o tamanho de partículas ou modificar materiais sólidos através de operações mecânicas de moagem, corte ou trituração.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1770"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2250">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2252"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab942">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab944"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab280">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab278"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab94"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab93"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the supply of electrons to a cathodic protection circuit to prevent corrosion of a protected metallic structure.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de proteção anódica</rdfs:label>
    <rdfs:label xml:lang="en">anode function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab316">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1616">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104">
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as 'both' functional and constructive. The constructive differentia (choke geometry) makes it safer to use necessary conditions to avoid forcing all valves with choke components into this specific control category under the Open World Assumption.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">válvula de controle de choke</rdfs:label>
    <rdfs:label xml:lang="en">choke control valve</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab393"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab394"/>
    <skos:definition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle de choke é uma válvula de controle que possui um componente de geometria de choke para redução de pressão através de restrição de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ChokeControlValve(x) → ControlValve(x) ∧ ∃y (ChokeGeometry(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke control valve is a control valve that has a choke geometry component at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportedTubingString">
    <rdfs:label xml:lang="pt-br">coluna suportado de coluna de produção</rdfs:label>
    <rdfs:label xml:lang="en">supported tubing string</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a downhole tubing string that is suspended and supported from the wellhead by a tubing hanger in a petroleum production well.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1520">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de movimentação de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas movement process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which gas is transported from one location to another by imparting kinetic or pressure energy to the gas stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab492">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab494"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1643">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelDetectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1873">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1875"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267">
    <iof-av:naturalLanguageDefinition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Filtro que é feito de meio filtrante e que é uma parte componente de um conjunto de filtro.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1039"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <skos:definition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on material composition (filter media) and mereological relationship (component of assembly). Under OWA, asserting equivalence could lead to unintended classification of any artifact made from filter media as a filter element, including specialized or hybrid components that contain filter media but serve different primary functions.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">filter element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento filtrante</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FilterElement(x) → Filter(x) ∧ ∃m(FilterMedia(m) ∧ madeFrom(x,m)) ∧ ∃a(FilterAssembly(a) ∧ componentPartOf(x,a)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">FilterElement SubClassOf Filter and (madeFrom some FilterMedia) and (componentPartOf some FilterAssembly)</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowElement(x) ↔ (Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">flow element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de vazão</rdfs:label>
    <skos:definition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow element is an instrument that bears a FlowMeasurementFunction and has component parts including a FlowSensingElement and SignalGenerationComponent.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de vazão é um instrumento que tem a função de medir vazões em um fluxo e produzir sinais proporcionais à vazão medida.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1174"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314">
    <skos:definition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">mixer</rdfs:label>
    <rdfs:label xml:lang="pt-br">misturador</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um misturador é um conjunto que tem a função projetada de misturar ou combinar dois ou mais ingredientes fluidos em uma mistura homogênea.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Mixer(x) ↔ (Assembly(x) ∧ ∃f (MixingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1787"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every mixer is an assembly that bears a mixing function, and every assembly that bears a mixing function is a mixer.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1615">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalSupport">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a structural member that bears mechanical loads to maintain the position and alignment of petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">suporte mecânico</rdfs:label>
    <rdfs:label xml:lang="en">mechanical support</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2468">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2466"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab780">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab777"/>
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab781"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208">
    <rdfs:label xml:lang="en">agitator</rdfs:label>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab53"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000369">
    <skos:definition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2702"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de vácuo é uma coluna de destilação projetada para resistir à pressão externa durante operação sob vácuo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">vacuum column</rdfs:label>
    <rdfs:label xml:lang="pt-br">coluna de vácuo</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VacuumColumn(x) → DistillationColumn(x) ∧ ∃q(VacuumPressureResistanceQuality(q) ∧ bearerOf(x,q)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vacuum column is a distillation column that bears a vacuum pressure resistance quality.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural capability. Under OWA, defining sufficient conditions for vacuum-capable design would be complex and could lead to false positives. The structural differentia (vacuum resistance) requires domain expert validation of what constitutes adequate vacuum design capability.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093">
    <iof-av:naturalLanguageDefinition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula angular é uma válvula que tem portas da válvula que não estão alinhadas, mas dispostas em ângulo uma em relação à outra.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by geometric configuration. Under OWA, sufficient conditions for non-inline port arrangement could lead to false positives where complex multi-port manifolds or specialized valves with angular components get incorrectly classified as standard angle valves.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab87"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <skos:definition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every angle valve is a valve that has a non-inline port arrangement.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AngleValve(x) → Valve(x) ∧ ∃p (hasPart(x,p) ∧ NonInlinePortArrangement(p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">angle valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula angular</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2004">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2456">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2454"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellheadSpool">
    <rdfs:label xml:lang="pt-br">spool de cabeçal de poço</rdfs:label>
    <rdfs:label xml:lang="en">wellhead spool</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a spool piece installed between wellhead components to provide the correct bore alignment and connection points.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab777">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess">
    <rdfs:label xml:lang="pt-br">processo de frenagem</rdfs:label>
    <rdfs:label xml:lang="en">braking process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a retarding force is applied to decelerate or hold stationary a rotating or translating mechanical component in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de proteção e invólucro</rdfs:label>
    <rdfs:label xml:lang="en">enclosure process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1485">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000180"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2551">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2549"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086">
    <skos:definition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every transformer is an electrical equipment that bears an electrical power transformation function and has component parts including primary winding, secondary winding, and magnetic core.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">transformer</rdfs:label>
    <rdfs:label xml:lang="pt-br">transformador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2602"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transformador é um equipamento elétrico que transforma energia elétrica de um circuito para outro na mesma frequência através de indução eletromagnética usando enrolamentos e um núcleo magnético.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Transformer(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(PrimaryWinding(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃s(SecondaryWinding(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(MagneticCore(c) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionProcess">
    <rdfs:label xml:lang="en">subsurface resource interaction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de interação com recursos subsuperficiais</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which petroleum production equipment physically interacts with subsurface formations to enable drilling, completion, or production operations.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the removal of entrained liquid droplets from a gas stream by gravity or inertial impingement.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de separação knock-out</rdfs:label>
    <rdfs:label xml:lang="en">knock out separation function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1625"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1624"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2275"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety valve is a valve that has the function to automatically relieve excess pressure for emergency protection</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">safety valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de segurança</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança é uma válvula que possui uma função de ventilação de segurança para alívio automático de pressão por abertura rápida e total para proteção contra condições perigosas de sobrepressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SafetyValve(x) ↔ Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2594">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2596"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionFunction">
    <rdfs:label xml:lang="en">cathodic protection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de proteção catódica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the prevention of electrochemical corrosion of a metallic structure by making it the cathode of an electrochemical cell.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab332"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab331"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab662">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1113">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1111"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction">
    <rdfs:label xml:lang="pt-br">função de desidratação</rdfs:label>
    <rdfs:label xml:lang="en">dehydration function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab644"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab643"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of water from a fluid stream by adsorption, absorption, or distillation to meet specification limits.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AnalogueTemperatureIndicator(x) ↔ Instrument(x) ∧ ∃f(TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃d(AnalogueDial(d) ∧ hasComponentPartAtAllTimes(x,d)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">analogue temperature indicator</rdfs:label>
    <rdfs:label xml:lang="pt-br">indicador analógico de temperatura</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display.</skos:definition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every analogue temperature indicator is an instrument that bears a temperature indication function and has component parts including a temperature sensor, analogue dial, and indicator pointer.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador analógico de temperatura é um instrumento que possui uma função de indicação de temperatura e tem um mostrador analógico para exibição visual da temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab76"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2354"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2353"/>
    <rdfs:label xml:lang="en">pipe shearing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de corte de tubulação</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical cutting of a tubular string within a wellbore to enable emergency well control.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de corte de tubulação</rdfs:label>
    <rdfs:label xml:lang="en">pipe shearing process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a tubular string within a wellbore is mechanically cut to enable emergency well control.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalMotion">
    <rdfs:label xml:lang="en">rotational motion</rdfs:label>
    <rdfs:label xml:lang="pt-br">movimento rotacional</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <skos:definition xml:lang="en">A process in which the angular motion of a rotating component about its axis in petroleum production rotating equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2743">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1841"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1840"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma placa de orifício é um elemento de medição de fluxo que consiste de uma placa fina com um orifício especificado através do qual o fluido flui para criar pressão diferencial para medição da taxa de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">placa de orifício</rdfs:label>
    <rdfs:label xml:lang="en">orifice plate</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical structure. Under OWA, any plate with a hole could potentially be classified as an orifice plate, but many perforated plates serve different purposes (structural, filtering, etc.). The structural differentia alone is not sufficient without industrial context validation.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every orifice plate is a flow measuring element that has a thin plate component and has a specified hole component and bears a flow measurement function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(OrificePlate(x) → FlowMeasuringElement(x) ∧ ∃p,h(ThinPlate(p) ∧ SpecifiedHole(h) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1255">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab17">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab15"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000304">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(InjectionPump(x) ↔ Pump(x) ∧ ∃f(InjectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de injeção é uma bomba especificamente projetada para injetar fluido em reservatórios ou sistemas de produção, tipicamente em pressões relativamente altas.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">bomba de injeção</rdfs:label>
    <rdfs:label xml:lang="en">injection pump</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every injection pump is a pump that bears an injection function for delivering fluids to reservoirs or production systems.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1590"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2313">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000229">
    <skos:definition xml:lang="en">A chromatograph is a process analyzer that bears a chromatographic analysis function.</skos:definition>
    <rdfs:label xml:lang="pt-br">cromatógrafo</rdfs:label>
    <rdfs:label xml:lang="en">chromatograph</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab439"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every chromatograph is a process analyzer that has the function of chromatographic analysis.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A chromatograph is a process analyzer that bears a chromatographic analysis function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cromatógrafo é um analisador de processo que possui uma função de análise cromatográfica.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Chromatograph(x) ↔ ProcessAnalyzer(x) ∧ ∃f (ChromatographicAnalysisFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab314">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab318"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1204">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1202"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000377">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellhead(x) ↔ Assembly(x) ∧ ∃f(WellSurfaceControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃h(CasingHanger(h) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃w(Wellbore(w) ∧ hasConnectionTo(x,w)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">cabeçal de poço</rdfs:label>
    <rdfs:label xml:lang="en">wellhead</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellhead is an assembly that bears a well surface control function and has component parts including casing hangers and connection to wellbore</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cabeçal de poço é um conjunto que porta uma função de controle superficial do poço e fornece a interface estrutural e de controle entre um poço e os equipamentos de superfície.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2807"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção hidráulico de fluido</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic fluid portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of hydraulic fluid at a defined point in the hydraulic circuit of petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1606">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242">
    <skos:definition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</skos:definition>
    <rdfs:label xml:lang="pt-br">desumidificador</rdfs:label>
    <rdfs:label xml:lang="en">dehumidifier</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desumidificador é um conjunto que possui a função de remover umidade do ar.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehumidifier is an assembly that has the function to perform dehumidification.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab639"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000324">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1949"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um redutor de tubulação é um tubo que possui tamanhos nominais diferentes de tubulação em suas duas extremidades, destinado a conectar tubos ou componentes de tubulação de tamanhos diferentes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe reducer is a pipe that has different nominal pipe sizes at its two ends, intended to connect pipes or piping components of different sizes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A pipe reducer is a pipe that has different nominal pipe sizes at its two ends, intended to connect pipes or piping components of different sizes.</skos:definition>
    <rdfs:label xml:lang="en">pipe reducer</rdfs:label>
    <rdfs:label xml:lang="pt-br">redutor de tubulação</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe reducer is a pipe that has an inlet end and outlet end with different nominal pipe sizes</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PipeReducer(x) → Pipe(x) ∧ ∃i,o (InletEnd(i) ∧ OutletEnd(o) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ DifferentNominalPipeSizes(i,o)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by geometric configuration, sufficient conditions are omitted under the Open World Assumption to prevent false positives. Complex assemblies or custom manifolds containing size transitions should not be automatically classified as standard pipe reducers without explicit assertion.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab949">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BoilingFunction">
    <rdfs:label xml:lang="en">boiling function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de ebulição</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab234"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab233"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of a liquid into vapour by supplying heat at or above the liquid's boiling point.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab820">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab821"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1318">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1315"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2526">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureIndicationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000137">
    <skos:definition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PhaseSequenceMeter(x) ↔ ElectricMeasuringInstrument(x) ∧ ∃f(PhaseSequenceMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PolyphaseElectricalSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1860"/>
    <rdfs:label xml:lang="en">phase sequence meter</rdfs:label>
    <rdfs:label xml:lang="pt-br">medidor de sequência de fases</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every phase sequence meter is an electric measuring instrument that has the function to measure phase sequence and has as input polyphase electrical signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de sequência de fases é um instrumento de medição elétrica que possui uma função de medição de sequência de fases para determinar e indicar a sequência na qual as tensões instantâneas dos condutores de fase atingem seu valor máximo em um sistema elétrico polifásico.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab488">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2195">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000110">
    <skos:definition xml:lang="en">A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão diferencial é um transmissor de pressão que possui uma função de transmissão de pressão diferencial, permitindo medir a diferença de pressão entre dois sinais de pressão de entrada e transmitir essa diferença como um sinal de saída padronizado.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureTransmitter(x) ↔ PressureTransmitter(x) ∧ ∃f (DifferentialPressureTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab809"/>
    <rdfs:label xml:lang="pt-br">transmissor de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure transmitter</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1230">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1228"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasMixturePortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">gas mixture portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de gás de mistura</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more gases at a defined point in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab912">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2790">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2538">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab54">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000303">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Incinerator(x) ↔ Furnace(x) ∧ ∃f(WasteCombustionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">incinerador</rdfs:label>
    <rdfs:label xml:lang="en">incinerator</rdfs:label>
    <skos:definition xml:lang="en">An incinerator is a furnace that is designed to combust waste material for disposal purposes.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An incinerator is a furnace that is designed to combust waste material for disposal purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um incinerador é um forno que é projetado para combustir material de resíduo para fins de descarte.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every incinerator is a furnace that bears a waste combustion function.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1562"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab827">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000213">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every axial displacement transmitter is a transmitter that has the function to measure axial displacement and has as component part an axial displacement measuring probe.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">An axial displacement transmitter is a transmitter that measures axial displacement and generates a standardized output signal representing the measured axial displacement.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de deslocamento axial é um transmissor que mede deslocamento axial e gera um sinal de saída padronizado representando o deslocamento axial medido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An axial displacement transmitter is a transmitter that measures axial displacement and generates a standardized output signal representing the measured axial displacement.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab106"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">axial displacement transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de deslocamento axial</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(AxialDisplacementTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(AxialDisplacementTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(AxialDisplacementMeasuringProbe(p) ∧ hasComponentPartAtAllTimes(x,p))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1268">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000358">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de medição de temperatura é um elemento de medição que tem a função de medir temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature measuring element is a measuring element that has the function to measure temperature.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">elemento de medição de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature measuring element</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A temperature measuring element is a measuring element that has the function to measure temperature.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2537"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature measuring element is a measuring element that has a temperature measurement function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureMeasuringElement(x) ↔ MeasuringElement(x) ∧ ∃f(TemperatureMeasurementFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab454"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1267"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab455"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1268"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">circuit protection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de proteção de circuito</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic interruption or limitation of current in an electrical circuit to protect equipment from overload or fault conditions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab53">
    <owl:intersectionOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab56"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab724">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1881"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1880"/>
    <rdfs:label xml:lang="en">pig receiving function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de recebimento de pig</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled retrieval and containment of a pipeline pig after its passage through a pipeline.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which flame propagation through a flammable gas mixture is prevented by quenching the flame front in narrow passages of a flame arrester.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de contenção de chama</rdfs:label>
    <rdfs:label xml:lang="en">flame arrest process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CapturedPig">
    <skos:definition xml:lang="en">A material artifact that constitutes a pipeline pig that has been retrieved and confined in a pig receiver following completion of its pipeline pass.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">captured pig</rdfs:label>
    <rdfs:label xml:lang="pt-br">pig de capturado</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CooledHeatingMedium">
    <rdfs:label xml:lang="en">cooled heating medium</rdfs:label>
    <rdfs:label xml:lang="pt-br">meio de resfriado de aquecimento</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a heating medium that has transferred thermal energy to a process stream and returned to a lower temperature.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2272">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceAccessProcess">
    <skos:definition xml:lang="en">A planned process in which access to subsurface formations is established and maintained through a wellbore to enable exploration, production, or injection activities.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de acesso subsuperficial</rdfs:label>
    <rdfs:label xml:lang="en">subsurface access process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReferenceSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">reference signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de referência</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting a signal representing a reference value—such as a set point or calibration standard—used in control or measurement systems of petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">temperature signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de temperatura</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the temperature of a process stream or equipment surface in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionFunction">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab814"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab813"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the dispersion of thermal, acoustic, or kinetic energy over a larger volume or surface to reduce its local intensity.</skos:definition>
    <rdfs:label xml:lang="en">energy diffusion function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de difusão de energia</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329">
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2031"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma InterfacingFunction e que é capaz de fornecer um ponto de interface para comunicação com outro objeto.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Port ≡ MaterialArtifact ⊓ ∃bearerOf.InterfacingFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma InterfacingFunction e</rdfs:label>
    <rdfs:label xml:lang="en">port</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Port(x) ↔ (MaterialArtifact(x) ∧ ∃f(InterfacingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1821">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDirectionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2072">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2757">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of a vapour into liquid by removing thermal energy until the substance reaches its dew point.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab508"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab507"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">condensation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de condensação</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab972">
    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab970"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000379">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab14"/>
    <rdfs:label xml:lang="en">absorber</rdfs:label>
    <rdfs:label xml:lang="pt-br">absorvedor</rdfs:label>
    <skos:definition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Absorber(x) ↔ (Separator(x) ∧ ∃f(AbsorptionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um absorvedor é um vaso de pressão que realiza uma função de absorção para transferência seletiva de massa de componentes de uma mistura fluida para uma fase absorvente.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every absorber is a separator that has the function to absorb specific components from fluid mixtures through mass transfer to an absorbent phase</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000368">
    <rdfs:label xml:lang="pt-br">unidade UPS</rdfs:label>
    <rdfs:label xml:lang="en">ups unit</rdfs:label>
    <skos:definition xml:lang="en">A UPS unit is electrical equipment that bears the designed function of maintaining uninterrupted AC electric power supply to protected equipment during power disturbances.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(UPSUnit(x) ↔ ElectricalEquipment(x) ∧ ∃f(UninterruptedPowerSupplyFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every UPS unit is electrical equipment that has the function of maintaining uninterrupted AC electric power supply.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A UPS unit is electrical equipment that bears the designed function of maintaining uninterrupted AC electric power supply to protected equipment during power disturbances.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma unidade UPS é um equipamento elétrico que possui a função projetada de manter o fornecimento ininterrupto de energia elétrica AC para equipamentos protegidos durante distúrbios de energia.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2687"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab311">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableSupportProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab225"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab488"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab489"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab343"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab342"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab226"/>
    <rdfs:label xml:lang="en">compression function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de compressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the compression of a gas stream to increase its pressure for transport, injection, or processing.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FormationFluidPortion">
    <rdfs:label xml:lang="pt-br">porção de formação de fluido</rdfs:label>
    <rdfs:label xml:lang="en">formation fluid portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid originating from a subsurface geological formation and produced through a petroleum production well.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
