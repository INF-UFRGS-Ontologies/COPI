  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000304">
    <rdfs:label xml:lang="pt-br">bomba de injeção</rdfs:label>
    <rdfs:label xml:lang="en">injection pump</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2008"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every injection pump is a pump that bears an injection function for delivering fluids to reservoirs or production systems.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(InjectionPump(x) ↔ Pump(x) ∧ ∃f(InjectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de injeção é uma bomba especificamente projetada para injetar fluido em reservatórios ou sistemas de produção, tipicamente em pressões relativamente altas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[SLB Glossary] Any pump used to inject fluid into the reservoir or production system.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;INJECTION PUMP&gt; is a &lt; POSITIVE DISPLACEMENT PUMP&gt; that is typically applied for relatively high pressures in case of injection systems</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
