  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ManualValve(x) → Valve(x) ∧ ∃y(ManualActuator(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on actuation mechanism. Under OWA, any valve with a manual actuator component might be classified as manual valve even if it has additional automated features (hybrid valves). Starting with necessary conditions allows domain experts to validate that manual actuation is both necessary and sufficient before upgrading to equivalent axiom.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula manual é uma válvula que possui um atuador manual que requer força manual para operação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">manual valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula manual</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every manual valve is a valve that has a manual actuator as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A valve that is regulated with hand power.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2187"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2188"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1495">
