  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000275">
    <iof-av:naturalLanguageDefinition xml:lang="en">A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador de flare é um queimador que especificamente queima gás residual emitido de processos industriais e descarrega os produtos de combustão na atmosfera.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLARE TIP&gt; is an &lt;ARTEFACT&gt; and a &lt;BURNER&gt; that burns gas emitted from a process into the atmosphere</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A burner that burns gas emitted from a process into the atmosphere.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A burner that burns gas emitted from a process into the atmosphere.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlareTip(x) ↔ Burner(x) ∧ ∃f(WasteGasDisposalFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare tip is a burner that has the function to dispose of waste gas from processes by burning it into the atmosphere</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">flare tip</rdfs:label>
    <rdfs:label xml:lang="pt-br">queimador de flare</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1431"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
