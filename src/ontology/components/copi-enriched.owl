    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2945"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2320"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2910"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2699"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2944"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2031"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2909"/>
    <rdfs:label xml:lang="en">power transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transmissão de potência</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical power is transferred from one rotating or reciprocating component to another through direct mechanical engagement, resulting in motion transmission and potentially torque or speed modification.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from a driving component to a driven component through the rotation or linear motion of a shaft, enabling the transfer of torque and rotational speed.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical rotational energy is transmitted from a prime mover through a shaft to driven components, resulting in the transfer of torque and rotational motion necessary for equipment operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from an external energy source through a rotating shaft to downstream mechanical components, enabling power transfer within a mechanical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted through rotational motion from one component to another via a rotating shaft, enabling the transfer of torque and angular velocity to mounted components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transferred from a prime mover through a rotating shaft to one or more driven machines, typically involving the conversion of torque and rotational speed to match operational requirements.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportFrame">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">estrutura de suporte</rdfs:label>
    <rdfs:label xml:lang="en">support frame</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess">
    <rdfs:label xml:lang="en">electrical power transformation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transformação de energia elétrica</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2585"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3215"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2574"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2586"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2590"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3216"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2591"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2573"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
