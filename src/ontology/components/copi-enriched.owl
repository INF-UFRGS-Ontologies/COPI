  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3141">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3135"/>
  </rdf:Description>
