  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConicalSection">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">conical section</rdfs:label>
    <rdfs:label xml:lang="pt-br">seção de cônico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a conical transition section connecting pipe or vessel sections of differing diameter in petroleum production equipment.</skos:definition>
  </rdf:Description>
