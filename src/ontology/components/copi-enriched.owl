  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ManualActuator is an actuator that has input ManualControlSignal and has output MechanicalPower</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2210"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:label xml:lang="pt-br">atuador manual</rdfs:label>
    <rdfs:label xml:lang="en">manual actuator</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador manual é um atuador que converte entradas de controle operadas por humanos em movimento mecânico ou força através de operação física direta.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;MANUAL ACTUATOR&gt; is an &lt;ARTEFACT&gt; and an &lt;ACTUATOR&gt; which action has to be trigged manually</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ManualActuator(x) ↔ Actuator(x) ∧ ∃s(ManualControlSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2157"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2158"/>
    <rdfs:label xml:lang="en">position limit detection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de detecção de limite de posição</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3298">
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3292"/>
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3299"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2581">
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2577"/>
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2582"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000259">
    <skos:definition xml:lang="en">[OnePetro] A device that through flow of a power fluid through a nozzle, creates a low pressure area useful for moving fluids.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A form of suction pump; a device using a high pressure jet of water to create partial vacuum at an intake opening to draw liquid from a sump.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;EDUCTOR&gt; is an &lt;ARTEFACT&gt; and a &lt;PUMP&gt; that is a form of suction pump; a device using a high pressure jet of water to create partial vacuum at an intake opening to draw liquid from a sump</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um edutor é uma bomba que usa um jato de fluido motriz de alta pressão para criar uma zona de baixa pressão que arrasta e move um segundo fluido via transferência de momento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An eductor is a pump that uses a high-pressure motive fluid jet to create a low-pressure zone that entrains and moves a second fluid via momentum transfer.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">The constructive differentia based on jet entrainment mechanism could potentially apply to hybrid or specialized equipment that incorporates eductor principles but should not be automatically classified as a standard eductor type. Under OWA, necessary conditions protect against false positive classifications.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1136"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1137"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1140"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1139"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1138"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Eductor(x) → Pump(x) ∧ ∃n(MotiveFluidNozzle(n) ∧ hasComponentPartAtAllTimes(x,n)) ∧ ∃t(VenturaThroat(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(JetEntrainmentProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">edutor</rdfs:label>
    <rdfs:label xml:lang="en">eductor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every eductor is a pump that has a motive fluid nozzle and Ventura throat as component parts and participates in a jet entrainment process.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de vedação</rdfs:label>
    <rdfs:label xml:lang="en">sealing process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a valve seat provides a sealing interface for a closure element (gate, ball, disc) to bear against, preventing fluid passage when the valve is closed.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
