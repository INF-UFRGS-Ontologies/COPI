  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b809">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b807"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b125">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000289">
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the gear mechanism is definitionally necessary for gear pumps, making it sufficient under OWA could lead to false positives - any complex equipment containing gears (like gearboxes with integrated pumps or multi-function units) might be incorrectly classified as standard gear pumps for maintenance purposes.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1355"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1354"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de engrenagem é uma bomba que contém dentes de engrenagem dentro de um invólucro ou carcaça para transportar líquido em pressões de retorno relativamente altas através de ação de engrenamento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</skos:definition>
    <rdfs:label xml:lang="pt-br">bomba de engrenagem</rdfs:label>
    <rdfs:label xml:lang="en">gear pump</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gear pump is a pump that has as component part at all times a gear mechanism and a pump casing, and bears a pumping function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GearPump(x) → Pump(x) ∧ ∃g,c (GearMechanism(g) ∧ PumpCasing(c) ∧ hasComponentPartAtAllTimes(x,g) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2417">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2419"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentFunction">
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a StationaryMachineComponentProcess and that consists in providing a stationary structural foundation and housing for active elements (such as windings, vanes, or seals) within rotating machinery, maintaining positional stability relative to moving components.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a StationaryMachineComponentProcess and that consists in providing a stationary structural foundation and housing for active elements (such as windings, vanes, or seals) within rotating machinery, maintaining positional stability relative to moving components.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2433"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2434"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de componente estacionário de máquina</rdfs:label>
    <rdfs:label xml:lang="en">stationary machine component function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2450">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2452"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b464">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b466"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b90">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222">
    <skos:definition xml:lang="en">A casing is an assembly that provides structural enclosure with pressure containment capability, characterized by walls that separate internal components or fluids from the external environment.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Casing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(CasingWall(w) ∧ hasComponentPartAtAllTimes(x,w)) ∧ ∃p(PressureContainmentFunction(p) ∧ hasFunction(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b324"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing is an assembly that provides structural enclosure with pressure containment capability, characterized by walls that separate internal components or fluids from the external environment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um casing é um conjunto que fornece invólucro estrutural com capacidade de contenção de pressão, caracterizado por paredes que separam componentes internos ou fluidos do ambiente externo.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">casing</rdfs:label>
    <rdfs:label xml:lang="pt-br">casing</rdfs:label>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every casing is an assembly that has an enclosure function and has component part some casing wall and has function some pressure containment function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on structural configuration. Under OWA, sufficient conditions for enclosure structure could lead to over-classification of complex assemblies that contain enclosure elements but serve different primary functions (e.g., pressure vessels, housings, containers).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasurementProcess">
    <rdfs:label xml:lang="en">measurement process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the value of a physical or chemical quantity is determined and expressed as a numerical value with an associated unit.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2004">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PneumaticEnergyConversionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
