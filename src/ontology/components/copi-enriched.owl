  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000306">
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2032"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de entrada é um eixo que serve como ponto de entrada para energia mecânica de uma fonte de energia externa em um sistema de transmissão de potência.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">An InputShaft is a Shaft that participates in mechanical energy reception and is connected to an external energy source.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration as energy entrance point. Under OWA, defining sufficient conditions could lead to false positives where any shaft receiving external energy input would be classified as a standard input shaft, even specialized or hybrid configurations that should remain in different maintenance categories.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">eixo de entrada</rdfs:label>
    <rdfs:label xml:lang="en">input shaft</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(InputShaft(x) → Shaft(x) ∧ ∃p(MechanicalEnergyReceptionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(ExternalEnergySource(s) ∧ connectedTo(x,s)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;INPUT SHAFT&gt; is a &lt;SHAFT&gt; that is the entrance of mechanical energy and driven by an external energy source.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2818">
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2819"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BasinFloor">
    <rdfs:label xml:lang="pt-br">piso de bacia</rdfs:label>
    <rdfs:label xml:lang="en">basin floor</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000299">
    <rdfs:label xml:lang="en">hydraulic motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor hidráulico</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on hydraulic mechanism. Under Open World Assumption, any device with hydraulic input might be misclassified as a hydraulic motor without domain expert validation of the complete structural requirements.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[POSC Caesar] A motor that is intended to generate power by means of high pressure oil.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HYDRAULIC MOTOR&gt; is an &lt;ARTEFACT&gt; and a &lt;MOTOR&gt; and a &lt;HYDRAULIC TO ROTATION ENERGY CONVERTER&gt; that is intended to generate power by means of high pressure oil</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A motor that is intended to generate power by means of high pressure oil.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1906"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1907"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1904"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1908"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1905"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HydraulicMotor(x) → Motor(x) ∧ ∃f,p(HydraulicFluidPortion(f) ∧ hasInput(x,f) ∧ HydraulicToMechanicalEnergyConversionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hydraulic motor is a motor that generates mechanical energy by converting high pressure hydraulic oil to rotational motion.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor hidráulico é um motor que gera energia mecânica convertendo óleo hidráulico de alta pressão em movimento rotacional.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic motor is a motor that has hydraulic fluid input and participates in hydraulic-to-mechanical energy conversion process</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
