  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab16">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab17"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
