  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VibrationSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdfs:label xml:lang="en">vibration signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de vibração</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the amplitude or frequency of mechanical vibration measured in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b810">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
