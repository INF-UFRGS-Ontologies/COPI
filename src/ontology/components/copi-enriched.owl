    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2345"/>
    <rdfs:label xml:lang="en">pig launching and receiving function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de lançamento e recebimento de pig</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilterHousing">
