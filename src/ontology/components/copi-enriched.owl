  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1762">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationChamber"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317">
    <rdfs:label xml:lang="en">output shaft</rdfs:label>
    <rdfs:label xml:lang="pt-br">eixo de saída</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Shaft that participates in mechanical energy output processes, serving as the exit point for mechanical energy transmission from a prime mover to external energy consuming equipment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Eixo que participa em processos de saída de energia mecânica, servindo como ponto de saída para transmissão de energia mecânica de um motor primário para equipamentos consumidores de energia externos.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on positional role within mechanical systems. Under OWA, sufficient conditions would be difficult to specify without risk of misclassifying intermediate shafts or complex multi-shaft arrangements that happen to have output characteristics.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2294"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (OutputShaft(x) → Shaft(x) ∧ ∃p (MechanicalEnergyOutputProcess(p) ∧ participatesIn(x,p)) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every output shaft is a shaft that participates in at least one mechanical energy output process and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;OUTPUT SHAFT&gt; is a &lt;SHAFT&gt; that is the exit of mechanical energy and driver of an external energy consumer.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3019">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000276">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlashDrum(x) ↔ Separator(x) ∧ ∃f(FlashVaporizationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A tank or vessel in which a process stream is charged or pumped and where lighter products flash off or vaporize and are drawn off at the top. The remainder heavier fractions are drawn off at the bottom of the vessel.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLASH DRUM&gt; is an &lt;ARTEFACT&gt; and a &lt;VESSEL&gt; in which a process stream is charged or pumped and where lighter products flash off or vaporize and are drawn off at the top. The remainer heavier fractions are drawn off at the bottom of the vessel</skos:definition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1446"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tambor de flash é um separador que realiza vaporização flash para separar componentes mais leves (que vaporizam e são retirados no topo) de componentes mais pesados (que permanecem líquidos e são retirados no fundo).</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flash drum is a separator that performs flash vaporization to separate lighter components (which vaporize and are drawn off at the top) from heavier components (which remain liquid and are drawn off at the bottom).</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flash drum is a separator that bears a flash vaporization function and has a vapor outlet, liquid outlet, and feed inlet.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">tambor de flash</rdfs:label>
    <rdfs:label xml:lang="en">flash drum</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b976">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b344">
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b345"/>
    <rdf:first rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b339"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2879">
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2883"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000289">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de engrenagem é uma bomba que contém dentes de engrenagem dentro de um invólucro ou carcaça para transportar líquido em pressões de retorno relativamente altas através de ação de engrenamento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GearPump(x) → Pump(x) ∧ ∃g,c (GearMechanism(g) ∧ PumpCasing(c) ∧ hasComponentPartAtAllTimes(x,g) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1707"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1704"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1708"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1705"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1706"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gear pump is a pump that has as component part at all times a gear mechanism and a pump casing, and bears a pumping function.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[POSC Caesar] A rotary pump that contains gear teeth within an casing or enclosure to transport liquid at relatively high back pressures and by which gear meshing serves as reverse flow seal.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GEAR PUMP&gt; is a &lt;ROTARY PUMP&gt; that contains gear teeth within an casing or enclosure to transport liquid at relatively high back pressures</skos:definition>
    <rdfs:label xml:lang="en">gear pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba de engrenagem</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the gear mechanism is definitionally necessary for gear pumps, making it sufficient under OWA could lead to false positives - any complex equipment containing gears (like gearboxes with integrated pumps or multi-function units) might be incorrectly classified as standard gear pumps for maintenance purposes.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2156">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalOutput"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
