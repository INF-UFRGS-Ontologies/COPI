  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b788"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b787"/>
    <rdfs:label xml:lang="en">differential pressure switching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de chaveamento por pressão diferencial</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the differential pressure between two process points crosses a defined threshold.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1110">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1108"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">pressure containment process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de contenção de pressão</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a fluid is held within a defined pressure boundary to prevent uncontrolled release to the environment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1794">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1795"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000365">
    <skos:definition xml:lang="en">A tubing head is a wellhead component that supports the tubing hanger and provides a connection interface for attaching the Christmas tree to the wellhead assembly.</skos:definition>
    <rdfs:label xml:lang="pt-br">cabeça de coluna</rdfs:label>
    <rdfs:label xml:lang="en">tubing head</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TubingHead(x) ↔ WellheadComponent(x) ∧ ∃f(TubingSupportAndConnectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p1(TubingBowl(p1) ∧ hasComponentPartAtAllTimes(x,p1)) ∧ ∃p2(ChristmasTreeConnectionInterface(p2) ∧ hasComponentPartAtAllTimes(x,p2)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma cabeça de coluna é um componente de cabeça de poço que suporta o suspensor de coluna e fornece uma interface de conexão para fixar a árvore de natal ao conjunto de cabeça de poço.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A tubing head is a wellhead component that supports the tubing hanger and provides a connection interface for attaching the Christmas tree to the wellhead assembly.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2632"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every tubing head is a wellhead component that bears a tubing support and connection function, has a tubing bowl as component part, and has a Christmas tree connection interface as component part.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000333">
    <rdfs:label xml:lang="en">power transformer secondary winding</rdfs:label>
    <rdfs:label xml:lang="pt-br">enrolamento secundário de transformador de potência</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerSecondaryWinding(x) → FiatObjectPart(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(SecondaryWindingFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma FiatObjectPart que é o enrolamento secundário de um transformador de potência e que possui uma SecondaryWindingFunction consistindo em fornecer energia elétrica transformada no nível de tensão de saída.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis - the physical configuration (being the secondary winding of a power transformer) provides necessary conditions, but sufficient conditions are harder to assert under OWA without risking false positives for specialized or hybrid transformer configurations.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2063"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerSecondaryWinding SubClassOf FiatObjectPart and (partOf some PowerTransformer) and (hasFunction some SecondaryWindingFunction)</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2719">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b55">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MovingVane"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2413">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b428"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b427"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation and quantification of chemical components in a sample by differential migration through a stationary phase.</skos:definition>
    <rdfs:label xml:lang="en">chromatographic analysis function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de análise cromatográfica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1363">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b125"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
    <rdfs:label xml:lang="en">ball control valve</rdfs:label>
    <skos:definition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1430">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b459"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b460"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de coalescência</rdfs:label>
    <rdfs:label xml:lang="en">coalescence function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the merging of dispersed liquid droplets into a continuous liquid phase to facilitate their subsequent removal.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2632">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2635"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b76"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador analógico de temperatura é um instrumento que possui uma função de indicação de temperatura e tem um mostrador analógico para exibição visual da temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AnalogueTemperatureIndicator(x) ↔ Instrument(x) ∧ ∃f(TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃d(AnalogueDial(d) ∧ hasComponentPartAtAllTimes(x,d)))</iof-av:firstOrderLogicAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every analogue temperature indicator is an instrument that bears a temperature indication function and has component parts including a temperature sensor, analogue dial, and indicator pointer.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">indicador analógico de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">analogue temperature indicator</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2467">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b46">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1533">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144">
    <rdfs:label xml:lang="pt-br">transmissor de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure transmitter</rdfs:label>
    <skos:definition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure transmitter is a transmitter that has the function to transmit pressure measurement signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(PressureTransmissionFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão é um transmissor que converte medições de pressão em sinais de saída padronizados para transmissão a sistemas de controle ou monitoramento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2115"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231">
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, sufficient conditions for compressor-specific casing identity could lead to false positives where any enclosure intended for compressors might be classified as a standard compressor casing, including specialized or hybrid enclosures that warrant distinct classification.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b500"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CompressorCasing ⊑ Casing ⊓ ∃intendedForUseWith.Compressor</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Invólucro que é destinado a abrigar componentes internos do compressor, incluindo o eixo com impulsores e outros componentes mecânicos específicos do compressor.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">compressor casing</rdfs:label>
    <rdfs:label xml:lang="pt-br">Invólucro</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CompressorCasing(x) → (Casing(x) ∧ ∃y (Compressor(y) ∧ intendedForUseWith(x,y))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1588">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000375"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1589"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">tubing support and connection process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de suporte e conexão de coluna de produção</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which downhole tubing strings are mechanically supported within a wellbore and connected to surface or subsurface equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction">
    <rdfs:label xml:lang="en">detection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de detecção</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b690"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b691"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the sensing and identification of the presence, concentration, or state of a physical or chemical entity.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1604">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2789"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2788"/>
    <rdfs:label xml:lang="pt-br">função de controle de superfície do poço</rdfs:label>
    <rdfs:label xml:lang="en">well surface control function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the control of wellbore conditions from surface to manage production flow, monitor integrity, and enable well interventions.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1849">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
