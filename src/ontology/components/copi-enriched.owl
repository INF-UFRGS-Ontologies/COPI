  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243">
    <skos:definition xml:lang="en">[SLB Glossary] A device used to remove water and water vapors from gas.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEHYDRATOR&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEHYDRATING&gt;</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A treating vessel designed to remove water from a process stream.</skos:definition>
    <rdfs:label xml:lang="pt-br">desidratador</rdfs:label>
    <rdfs:label xml:lang="en">dehydrator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b830"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehydrator is a separator that has the function of dehydration.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b826">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000351">
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2988"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um silo é um vaso que possui uma função de armazenamento de sólidos a granel e tem uma seção inferior cônica para facilitar o armazenamento e descarga de materiais sólidos a granel.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A vessel that has a bottom in the shape of a cone and is intended to store solid particles.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] A with a conical shape that is intended to store solids in bulk (from ``_).</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SILO&gt; is a &lt;CONTAINER&gt; with a conical shape that is intended to store solids in bulk</skos:definition>
    <rdfs:label xml:lang="pt-br">silo</rdfs:label>
    <rdfs:label xml:lang="en">silo</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Silo(x) ↔ (Vessel(x) ∧ ∃f(SolidBulkStorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(ConicalBottom(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every silo is a vessel that has the function of storing bulk solids and has a conical bottom component.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
