    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231">
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b612"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">compressor casing</rdfs:label>
    <rdfs:label xml:lang="pt-br">Invólucro</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Invólucro que é destinado a abrigar componentes internos do compressor, incluindo o eixo com impulsores e outros componentes mecânicos específicos do compressor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, sufficient conditions for compressor-specific casing identity could lead to false positives where any enclosure intended for compressors might be classified as a standard compressor casing, including specialized or hybrid enclosures that warrant distinct classification.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;COMPRESSOR CASING&gt; is a  &lt;CASING&gt; that is the typical enclosure for compressors housing the shaft with impeller(s) and other compressor internals</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CompressorCasing(x) → (Casing(x) ∧ ∃y (Compressor(y) ∧ intendedForUseWith(x,y))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CompressorCasing ⊑ Casing ⊓ ∃intendedForUseWith.Compressor</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralForce">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">força estrutural</rdfs:label>
    <rdfs:label xml:lang="en">structural force</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationProcess">
    <rdfs:label xml:lang="en">gravity separation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de separação gravitacional</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317">
    <rdfs:label xml:lang="pt-br">eixo de saída</rdfs:label>
    <rdfs:label xml:lang="en">output shaft</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on positional role within mechanical systems. Under OWA, sufficient conditions would be difficult to specify without risk of misclassifying intermediate shafts or complex multi-shaft arrangements that happen to have output characteristics.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2294"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;OUTPUT SHAFT&gt; is a &lt;SHAFT&gt; that is the exit of mechanical energy and driver of an external energy consumer.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Eixo que participa em processos de saída de energia mecânica, servindo como ponto de saída para transmissão de energia mecânica de um motor primário para equipamentos consumidores de energia externos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Shaft that participates in mechanical energy output processes, serving as the exit point for mechanical energy transmission from a prime mover to external energy consuming equipment.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every output shaft is a shaft that participates in at least one mechanical energy output process and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (OutputShaft(x) → Shaft(x) ∧ ∃p (MechanicalEnergyOutputProcess(p) ∧ participatesIn(x,p)) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingFunction">
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3445"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3446"/>
    <rdfs:label xml:lang="pt-br">função de perfilagem por wireline</rdfs:label>
    <rdfs:label xml:lang="en">wireline logging function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GaseousFuelPortion">
    <rdfs:label xml:lang="en">gaseous fuel portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção gasoso de combustível</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction">
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2660"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b394"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3205"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b464"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b463"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b421"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1838"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3204"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1751"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1698"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b608"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1839"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b420"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1697"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b393"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b609"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2661"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1752"/>
    <rdfs:label xml:lang="en">enclosure function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de proteção e invólucro</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150">
    <rdfs:label xml:lang="en">solenoid valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula solenoide</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula solenoide é uma válvula que possui um atuador solenoide para controle elétrico do fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[CFIHOS] A valve that has linear action which is fitted with a solenoid for quick operation.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SOLENOID VALVE&gt; is an &lt;ACTUATED VALVE&gt; and an &lt;ELECTRICAL ELEMENT&gt; with a linear action, fitted with a solenoid for quick operation</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A valve that has linear action which is fitted with a solenoid for quick operation.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (SolenoidValve(x) → Valve(x) ∧ ∃s (SolenoidActuator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f (ElectricalControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2980"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2979"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2978"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid valve is a valve that has a solenoid actuator component and bears an electrical control function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type where the solenoid mechanism is the distinguishing structural feature. Under OWA, making it equivalent could incorrectly classify complex valve assemblies that contain solenoid components but are not standard solenoid valves.</iof-av:primitiveRationale>
  </rdf:Description>
