  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um header é um manifold que se conecta a muitos tubos menores para coletar descarga de múltiplas fontes ou distribuir fluido para múltiplos destinos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">header</rdfs:label>
    <rdfs:label xml:lang="pt-br">header</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEADER&gt; is an &lt;ARTEFACT&gt; and a &lt;PIPING NETWORK SEGMENT&gt; that is pipe or manifold that is used to collect the discharge from many smaller pipes (a collecting header) , or can be used to distribute fluid to many smaller pipes (distributing header)</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The location, acquisition and processing parameters, and other pertinent information attached to a well log, seismic record and traces.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Header ≡ manifold ⊓ ∃connects_to.SmallPipe ⊓ ∃participatesIn.MultiStreamDistributionProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Header(x) ↔ (manifold(x) ∧ ∃y(SmallPipe(y) ∧ connects_to(x,y)) ∧ ∃z(MultiStreamDistributionProcess(z) ∧ participatesIn(x,z))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1801"/>
  </rdf:Description>
