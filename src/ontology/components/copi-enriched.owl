    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1582"/>
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1588"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000327">
    <rdfs:label xml:lang="en">pneumatic actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador pneumático</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2501"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2504"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2502"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2503"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic actuator is an actuator that has operating medium some pneumatic power.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador pneumático é um atuador que opera usando energia pneumática.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pneumatic actuator is an actuator that operates using pneumatic power.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[CFIHOS] An actuator that is intended to be operated by pneumatic power.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An actuator that is intended to be operated by pneumatic power.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PNEUMATIC ACTUATOR&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROLLED ACTUATOR&gt; that is intended to be operated by pneumatic power</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where pneumatic mechanism is necessary but may not be sufficient under OWA. Specialized pneumatic equipment (pneumatic tools, pneumatic cylinders) might have pneumatic power but should not be classified as actuators without additional validation of their actuation role in control systems.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PneumaticActuator(x) → Actuator(x) ∧ ∃y(PneumaticPower(y) ∧ hasOperatingMedium(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DivertingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">diverting process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de desvio de fluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1139">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SuctionInlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLoadingChamber">
    <rdfs:label xml:lang="pt-br">câmara de pig de carregamento</rdfs:label>
    <rdfs:label xml:lang="en">pig loading chamber</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334">
    <rdfs:label xml:lang="pt-br">transmissor indicador de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure indicating transmitter</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2628"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor indicador de pressão é um transmissor que mede pressão e fornece tanto indicação visual local quanto transmissão de sinal elétrico do valor da pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureIndicatingTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PressureIndicatingAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(PressureSignal(i) ∧ hasInput(x,i)) ∧ ∃o1(ElectricalSignal(o1) ∧ hasOutput(x,o1)) ∧ ∃o2(LocalPressureDisplay(o2) ∧ hasOutput(x,o2)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure indicating transmitter is a transmitter that bears a pressure indicating and transmission function, has pressure signal as input, and has both electrical signal output and local pressure display.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'PIT'. First letter 'P': Pressure. Succeeding letters: 'I' = Indicate, 'T' = Transmit.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction">
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1950"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1951"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de transferência de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy transfer function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
