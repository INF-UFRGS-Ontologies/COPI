  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIG RECEIVER&gt; is a &lt;RECEIVER&gt; that is capable of &lt;RECEIVING&gt; a &lt;PIPE PIG&gt; from a pipeline</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A pressure vessel intended for receiving a pig from a pipeline.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A chamber connected to the end of a pipeline intended for receiving pigs.</skos:definition>
    <rdfs:label xml:lang="en">pig receiver</rdfs:label>
    <rdfs:label xml:lang="pt-br">recebedor de pig</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PigReceiver(x) ↔ (Vessel(x) ∧ ∃f(PigReceivingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig receiver is a vessel that has the function to receive pipe pigs from a pipeline.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um recebedor de pig é um vaso que tem a função de receber pigs de tubulação de um duto.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2360"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig receiver is a vessel that bears a pig receiving function.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208">
    <rdfs:label xml:lang="en">agitator</rdfs:label>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <skos:definition xml:lang="en">[CFIHOS] A propeller like device with agitational or rotational movement located in a tank to prevent the content of the tank to build component segments.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An Agitator is a dynamic mixer that stirs or shakes fluids by reaction force from moving vanes.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;AGITATOR&gt; is a &lt;DYNAMIC MIXER&gt; that stirs or shakes fluids by reaction force from moving vanes</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b61"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
