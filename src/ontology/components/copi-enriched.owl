  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1514"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1484"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2303"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb733"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb734"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1485"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2304"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1515"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1507"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1506"/>
    <rdfs:label xml:lang="pt-br">função de medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measurement function</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073">
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb602"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every compressor is an assembly that bears a compression function and has component parts including a compressor casing, compression element, gas inlet, and gas outlet.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um compressor é um conjunto que possui a função projetada de comprimir gases através da adição de energia mecânica para aumentar sua pressão.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="en">compressor</rdfs:label>
    <rdfs:label xml:lang="pt-br">compressor</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Compressor(x) ↔ Assembly(x) ∧ ∃f(CompressionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is driven by a prime mover by which energy is either constantly or periodically added to an amount of gas in order to increase its pressure.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A 'gas pressure increase device' and an 'artefact' that is driven by a prime mover by which energy is either constantly or periodically added to an amount of gas in order to increase its pressure.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;COMPRESSOR&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;COMPRESSING&gt; a &lt;GAS&gt;</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A type of pump that increases the pressure of gas. Commonly used as a production rate increaser by increasing the gas pressure delivered from low pressure gas wells to enter the pipe line. The intake into the compressor lowers the wellhead pressure creating a larger drawdown.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] A machine that has the capability of compressing a gas.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device that raises the pressure of air or natural gas.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2025">
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2026"/>
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2020"/>
  </rdf:Description>
