    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000352">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[OnePetro] Move a well to a close-by locations with minimum rig down of equipment.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SKID&gt; is an &lt;ARTEFACT&gt; and a &lt;SUPPORT&gt; intended to support items when being manufactured, transported, handled or installed</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A 'support' intended to support items when being manufactured, transported, handled or installed.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A steel frame on which portable equipment is mounted to facilitate handling with cranes or flatbed trucks.</skos:definition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2960"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every skid is an assembly that bears an equipment support function and has a support frame and mounting points as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A skid is an assembly that bears an equipment support function, consisting of a support frame and mounting points, designed to support equipment items during manufacturing, transportation, handling, and installation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um skid é uma montagem que possui uma função de suporte de equipamento, consistindo de uma estrutura de suporte e pontos de montagem, projetada para suportar itens de equipamento durante fabricação, transporte, manuseio e instalação.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Skid(x) ↔ (Assembly(x) ∧ ∃f(EquipmentSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SupportFrame(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(MountingPoint(m) ∧ hasComponentPartAtAllTimes(x,m))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">skid</rdfs:label>
    <rdfs:label xml:lang="en">skid</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b598">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
    <rdfs:label xml:lang="en">fired heating process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de aquecimento a combustão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEHYDRATOR&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEHYDRATING&gt;</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device used to remove water and water vapors from gas.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A treating vessel designed to remove water from a process stream.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">dehydrator</rdfs:label>
    <rdfs:label xml:lang="pt-br">desidratador</rdfs:label>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b824"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehydrator is a separator that has the function of dehydration.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1837">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReinforcementLayer"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2508">
    <rdf:first rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2506"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1479">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
