    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1840"/>
    <rdfs:label xml:lang="pt-br">função de armazenamento e distribuição de sólidos</rdfs:label>
    <rdfs:label xml:lang="en">solid storage and dispensing function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
