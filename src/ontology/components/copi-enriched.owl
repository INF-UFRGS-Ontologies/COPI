    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/OutputMechanism"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidPort">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a port or connection point through which fluid enters or exits a component of petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">bocal de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid port</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1150">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1151"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1145"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1276">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CartridgeHousing"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b636">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b637"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measurement process</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b25">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction">
    <rdfs:label xml:lang="en">reactive heating function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de aquecimento reativo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1555"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1554"/>
    <skos:definition xml:lang="en">A heating function borne by petroleum production equipment whose realization constitutes the generation and transfer of thermal energy through an exothermic chemical reaction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">backflow prevention process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de prevenção de refluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2531">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
