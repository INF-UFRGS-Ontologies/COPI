  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (BlowDownValve(x) ↔ Valve(x) ∧ ∃f (RapidDepressurizationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b263"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de blow down é uma válvula que possui uma função projetada para despressurização rápida de sistemas de alta pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every blow down valve is a valve that has the function of rapid depressurization.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BLOW DOWN VALVE is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; that can be used for rapid depressurizing of a high pressure system</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A valve that can be used for rapid depressurizing of a high pressure system.</skos:definition>
    <rdfs:label xml:lang="pt-br">válvula de blow down</rdfs:label>
    <rdfs:label xml:lang="en">blow down valve</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000284">
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas detector is a detector that has the designed function to sense the presence of a specified concentration of a gas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector de gás é um detector que tem a função projetada de detectar a presença de uma concentração especificada de um gás.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GAS DETECTOR&gt; is a &lt;DETECTOR&gt; and a &lt;GAS DETECTING INSTRUMENT&gt; using a &lt;GAS DETECTING MEASURING ELEMENT&gt; that is intended to sense the presence of a specified concentration of a gas</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A detector that is intended to sense the presence of a specified concentration of a gas.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A detector that is intended to sense the presence of a specified concentration of a gas.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">detector de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas detector</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GasDetector(x) ↔ (Detector(x) ∧ ∃f(GasDetectionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas detector is a detector that bears a GasDetectionFunction and has a GasDetectingMeasuringElement as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1640"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2081">
