  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000309">
    <skos:definition xml:lang="en">[CFIHOS] A functional switch that is intended to give an on/off signal when particulate material or fluid level have reached a pre-set value.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A functional switch that is intended to give an on/off signal when particulate material or fluid level have reached a preset value.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LEVEL SWITCH&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;LEVEL MEASURING INSTRUMENT&gt;</skos:definition>
    <rdfs:label xml:lang="en">level switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">interruptor de nível</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level switch is an instrument that bears a LevelSwitchingFunction, combining level detection with switching capability to provide discrete on/off electrical signals when fluid or particulate material levels reach preset values.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de nível é um instrumento que possui uma Função de Comutação de Nível, combinando detecção de nível com capacidade de comutação para fornecer sinais elétricos discretos ligado/desligado quando níveis de fluidos ou materiais particulados atingem valores predefinidos.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(LevelSwitch(x) ↔ (Instrument(x) ∧ ∃f(LevelSwitchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(DiscreteElectricalSignal(s) ∧ hasOutput(x,s))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2129"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level switch is an instrument that has the function of level switching and outputs discrete electrical signals based on preset level conditions.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2667">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1859">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000270">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FiredHeater(x) ↔ (Heater(x) ∧ ∃f(FiredHeatingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">aquecedor a combustão</rdfs:label>
    <rdfs:label xml:lang="en">fired heater</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fired heater is a heater that burns fuel (solid, liquid, or gas) to generate heat for transfer to a process fluid medium.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor a combustão é um aquecedor que queima combustível (sólido, líquido ou gasoso) para gerar calor para transferência para um fluido de processo.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1346"/>
    <skos:definition xml:lang="en">[CFIHOS] Is a fired heat transfer equipment intended to burn fuel and to transfer the heat of combustion to a liquid without vaporising the liquid.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FIRED HEATER&gt; is an &lt;ARTEFACT&gt; and a &lt;HEATER&gt; in which the heat converted from burning solids, liquids or gas is transferred to a media</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every fired heater is a heater that bears a FiredHeatingFunction</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalOutput">
