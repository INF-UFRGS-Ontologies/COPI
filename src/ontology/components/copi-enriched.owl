  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2499">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3321">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
