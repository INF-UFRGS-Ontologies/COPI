    <rdfs:label xml:lang="pt-br">função de bombeamento</rdfs:label>
    <rdfs:label xml:lang="en">pumping function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2735">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
