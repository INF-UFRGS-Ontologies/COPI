  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077">
    <skos:definition xml:lang="en">[OnePetro] Any of several valves:  plug, gate, butterfly, needle, etc., used in oil field operations.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VALVE&gt; is a &lt;FLUID REGULATOR&gt; that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3317"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3318"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3316"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula é um conjunto que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Might be too restrictive to define as sufficient being a material artifact and having a flow control function.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">válvula</rdfs:label>
    <rdfs:label xml:lang="en">valve</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Valve(x) ↔ MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentBody">
    <rdfs:label xml:lang="pt-br">corpo de pressão de contenção</rdfs:label>
    <rdfs:label xml:lang="en">pressure containment body</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionProcess">
    <rdfs:label xml:lang="en">combustion process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de combustão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LevelIndicator(x) ↔ (Indicator(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">level indicator</rdfs:label>
    <rdfs:label xml:lang="pt-br">indicador de nível</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador de nível é um indicador que mede e exibe localmente o nível de material líquido ou sólido a granel em um vaso ou tanque.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2069"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level indicator is an indicator that has the function to measure and locally indicate level.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[isa5_1] A level indicator (LI) is an instrument that measures and locally displays the level of liquid or bulk solid material in a vessel or tank. It consists of a level sensing element (float, displacer, sight glass, or electronic sensor) and a local display. Unlike a level transmitter, it does not produce a standardized remote output signal; its function is limited to local indication for operator reading at the instrument location.</skos:definition>
  </rdf:Description>
