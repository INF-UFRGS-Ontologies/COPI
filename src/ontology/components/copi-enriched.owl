    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3415"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b393">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PumpChamber">
    <skos:definition xml:lang="en">A material artifact that constitutes the enclosed space within a pump casing in which fluid is pressurised by the impeller or piston.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">câmara de bomba</rdfs:label>
    <rdfs:label xml:lang="en">pump chamber</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1327">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1321"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1328"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3090"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3091"/>
    <rdfs:label xml:lang="en">temperature measurement and transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição e transmissão de temperatura</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and remote transmission of the temperature of a process stream or equipment surface.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3234">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141">
    <skos:definition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</skos:definition>
    <rdfs:label xml:lang="en">power transformer</rdfs:label>
    <rdfs:label xml:lang="pt-br">transformador de potência</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2533"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2531"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2532"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transformador de potência é um transformador que possui uma função de transformação de energia elétrica, realizada por indução eletromagnética para transformar sistemas de tensão e corrente alternadas para diferentes níveis na mesma frequência para fins de transmissão de energia.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformer(x) ↔ (Transformer(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃r(ElectricalPowerTransmissionRole(r) ∧ bearerOf(x,r))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every power transformer is a transformer that has the function of transforming electrical power through electromagnetic induction, taking alternating current at one voltage level as input and producing alternating current at different voltage level(s) as output for power transmission.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilteredFluidPortion">
    <rdfs:label xml:lang="pt-br">porção filtrado de fluido</rdfs:label>
    <rdfs:label xml:lang="en">filtered fluid portion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid from which particulate or liquid contaminants have been removed by filtration.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3122">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2532">
