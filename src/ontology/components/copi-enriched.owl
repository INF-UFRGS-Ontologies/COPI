  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentBody">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the main pressure-retaining structural body of a vessel or piping component in petroleum production equipment.</skos:definition>
