  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000288">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1720"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GEAR CASING&gt; is a &lt;HOUSING&gt; that contains the internal components of a gear.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">This is a constructive type defined by its physical configuration as a specific type of casing. Under OWA, declaring equivalence could lead to over-classification where any casing containing gear-like components might be inappropriately classified as a standard gear casing, including custom enclosures or hybrid systems that should not fall into this maintenance category.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GearCasing(x) → casing(x) ∧ ∃y(GearMechanism(y) ∧ hasContent(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing that contains and houses the internal components of a gear mechanism, providing protective enclosure and structural support.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que contém e abriga os componentes internos de um mecanismo de engrenagem, fornecendo invólucro protetor e suporte estrutural.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">carcaça de caixa de engrenagens</rdfs:label>
    <rdfs:label xml:lang="en">gear casing</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">GearCasing ⊑ casing ⊓ ∃hasContent.GearMechanism</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000274">
    <rdfs:label xml:lang="pt-br">flare</rdfs:label>
    <rdfs:label xml:lang="en">flare</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Flare(x) ↔ (Burner(x) ∧ ∃f (WasteGasDisposalFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[DEXPI] An artefact and waste gas emitter that is intended to burn waste gas in secure distance from the plant or platform.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The burning of unwanted gas through a pipe (also called a flare).</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A burner on a remote line used for disposal of hydrocarbons during clean-up, emergency shut downs and for disposal of small volume waste streams of mixed gasses that cannot easily or safely be separated.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLARE&gt; is a &lt;BURNER&gt; that has a capability of &lt;FLARING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A system that burns waste in an elevated flame in the open air.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um flare é um queimador que descarta com segurança gases indesejados através de combustão controlada em local elevado.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flare is a burner that safely disposes of unwanted gases through controlled combustion at an elevated location.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1405"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare is a burner that bears a waste gas disposal function and has component parts flare tip, flare stack, and pilot system.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
