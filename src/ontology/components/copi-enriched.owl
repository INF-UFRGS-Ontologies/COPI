  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000247">
    <rdfs:label xml:lang="pt-br">analisador de ponto de orvalho</rdfs:label>
    <rdfs:label xml:lang="en">dew point analyser</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de ponto de orvalho é um instrumento que possui uma função de medição de ponto de orvalho.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dew point analyser is an instrument that has the function to determine the dew point of a substance</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEW POINT ANALYSER&gt; is a &lt;PROCESS ANALYSER&gt; intended to determine the dew point of a substance</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] An analysing instrument intended to determine the dew point of a substance.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b908"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DewPointAnalyser(x) ↔ Instrument(x) ∧ ∃f(DewPointMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
