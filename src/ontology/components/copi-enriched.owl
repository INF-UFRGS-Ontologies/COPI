  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyProcess">
    <rdfs:label xml:lang="pt-br">processo de fornecimento ininterrupto de energia</rdfs:label>
    <rdfs:label xml:lang="en">uninterrupted power supply process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which continuous electrical power is provided to critical loads during interruptions to the main power supply.</skos:definition>
