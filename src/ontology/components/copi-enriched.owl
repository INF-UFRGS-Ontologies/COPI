  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasFuelAdmissionSystem">
    <skos:definition xml:lang="en">An assembly of valves, regulators, and control components that admits and controls the flow of gaseous fuel to a combustion device in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="pt-br">sistema de gás de combustível de admissão</rdfs:label>
    <rdfs:label xml:lang="en">gas fuel admission system</rdfs:label>
  </rdf:Description>
