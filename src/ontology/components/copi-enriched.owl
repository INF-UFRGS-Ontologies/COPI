    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000241">
    <rdfs:label xml:lang="en">degasser</rdfs:label>
    <rdfs:label xml:lang="pt-br">degaseificador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEGASSER&gt; is an &lt;ARTEFACT&gt; and a  &lt;FLASH SEPARATOR&gt; that is a device used in drilling to remove gasses from drilling fluid which could otherwise form bubbles</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] Any device that helps remove gas from circulated fluid.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A device that removes air or gases (methane, H2S, CO2 and others) from drilling liquids.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device that removes air or gases (methane, H2S, CO2, and others) from drilling liquids.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Degasser(x) ↔ (Separator(x) ∧ ∃f (DegassingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b784"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every degasser is a separator that bears a degassing function and has drilling fluid as input and degassed drilling fluid plus separated gases as outputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A degasser is a separator that removes gases from drilling fluids by realizing a degassing function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um degaseificador é um separador que remove gases de fluidos de perfuração realizando uma função de degaseificação.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
