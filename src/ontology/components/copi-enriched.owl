  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DivertingFunction">
    <rdfs:label xml:lang="pt-br">função de desvio de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">diverting function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the redirection of fluid flow from one path to one or more alternative downstream paths.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b846"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b845"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
