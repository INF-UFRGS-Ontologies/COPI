    <rdfs:label xml:lang="pt-br">display local de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">local temperature display</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting an instrument mounted locally to a temperature measurement point that visually displays the process temperature.</skos:definition>
