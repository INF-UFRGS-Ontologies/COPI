  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">electrical signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal elétrico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <skos:definition xml:lang="en">An information content entity constituting an electrical signal carrying a measurement, control, or status value within petroleum production instrumentation and control systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1753">
