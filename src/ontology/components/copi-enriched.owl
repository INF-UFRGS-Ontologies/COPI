    <rdfs:label xml:lang="en">standardized electrical signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal padronizado elétrico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1073">
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1075"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PneumaticCylinder">
    <rdfs:label xml:lang="pt-br">cilindro pneumático</rdfs:label>
    <rdfs:label xml:lang="en">pneumatic cylinder</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1061">
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1062"/>
    <rdf:first rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b932">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DiaphragmChamber"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SwitchingElement">
    <rdfs:label xml:lang="pt-br">elemento de chaveamento</rdfs:label>
    <rdfs:label xml:lang="en">switching element</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b767">
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b768"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CoolingTower(x) ↔ HeatExchanger(x) ∧ ∃t(Tower(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(ConvectiveAirCirculationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236"/>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b709"/>
    <skos:definition xml:lang="en">[POSC Caesar] A cooler and an air cooled heat exchanger that is a tall structure through which air circulates by convection</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;COOLING TOWER&gt; is an &lt;AIR COOLED HEAT EXCHANGER&gt; and a &lt;TOWER&gt; that is a tall structure through which air circulates by convection</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A cooler and an air cooled heat exchanger that is a tall structure through which air circulates by convection.</skos:definition>
    <rdfs:label xml:lang="en">cooling tower</rdfs:label>
    <rdfs:label xml:lang="pt-br">torre de resfriamento</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cooling tower is a heat exchanger that incorporates a tall tower structure through which air circulates by convection to remove heat from process fluids.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma torre de resfriamento é um trocador de calor que incorpora uma estrutura de torre alta através da qual o ar circula por convecção para remover calor de fluidos de processo.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooling tower is a heat exchanger that has a tower structure as component part at all times and participates in convective air circulation processes.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1755">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/OutputMechanism">
    <rdfs:label xml:lang="en">output mechanism</rdfs:label>
    <rdfs:label xml:lang="pt-br">mecanismo de saída</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig receiver is a vessel that bears a pig receiving function.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[POSC Caesar] A chamber connected to the end of a pipeline intended for receiving pigs.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A pressure vessel intended for receiving a pig from a pipeline.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIG RECEIVER&gt; is a &lt;RECEIVER&gt; that is capable of &lt;RECEIVING&gt; a &lt;PIPE PIG&gt; from a pipeline</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um recebedor de pig é um vaso que tem a função de receber pigs de tubulação de um duto.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig receiver is a vessel that has the function to receive pipe pigs from a pipeline.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PigReceiver(x) ↔ (Vessel(x) ∧ ∃f(PigReceivingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">recebedor de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig receiver</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2332"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1851">
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1852"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2765">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2766"/>
