  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328">
    <skos:definition xml:lang="en">[POSC Caesar] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PNEUMATIC MOTOR&gt; is an &lt;AIR MOTOR&gt; that is driven by compressed gas (typically air)</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor pneumático é um motor que converte energia de gás comprimido em energia mecânica rotacional.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2516"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PneumaticMotor(x) ↔ Motor(x) ∧ ∃f(PneumaticMotorFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">motor pneumático</rdfs:label>
    <rdfs:label xml:lang="en">pneumatic motor</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic motor is a motor that bears a PneumaticMotorFunction.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
