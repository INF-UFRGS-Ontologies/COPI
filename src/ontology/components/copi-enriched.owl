  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">sinal de posição</rdfs:label>
    <rdfs:label xml:lang="en">position signal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke control valve is a control valve that has a choke geometry component at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">válvula de controle de choke</rdfs:label>
    <rdfs:label xml:lang="en">choke control valve</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ChokeControlValve(x) → ControlValve(x) ∧ ∃y (ChokeGeometry(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A choke valve that is equipped with an actuator that manipulates a stream of fluid in the response to a signal from an external sensing element and with input of energy from an external source.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CHOKE CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;CHOKE VALVE&gt;</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle de choke é uma válvula de controle que possui um componente de geometria de choke para redução de pressão através de restrição de fluxo.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b475"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b476"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as 'both' functional and constructive. The constructive differentia (choke geometry) makes it safer to use necessary conditions to avoid forcing all valves with choke components into this specific control category under the Open World Assumption.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlexibleTubularBody">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">flexible tubular body</rdfs:label>
    <rdfs:label xml:lang="pt-br">corpo flexível tubular</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1446">
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1451"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to be used for fluid mixing processes typically a rotating piece of equipment comprised of a driver such as a motor which rotates an agitator immersed in the fluid(s) that need to be mixed.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An apparatus or machine that has the capability of mixing (from ``_).</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;MIXER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;MIXING&gt;</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A fluid container that mixes two ore more fluid ingredients.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um misturador é um conjunto que tem a função projetada de misturar ou combinar dois ou mais ingredientes fluidos em uma mistura homogênea.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every mixer is an assembly that bears a mixing function, and every assembly that bears a mixing function is a mixer.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Mixer(x) ↔ (Assembly(x) ∧ ∃f (MixingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2214"/>
    <rdfs:label xml:lang="pt-br">misturador</rdfs:label>
    <rdfs:label xml:lang="en">mixer</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1416">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasBurningProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000252">
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b997"/>
    <skos:definition xml:lang="en">[CFIHOS] A pilot switch intended to switch or give an on/off signal when the measured differential pressure has reached a pre-set value.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIFFERENTIAL PRESSURE SWITCH&gt; is a &lt;PRESSURE SWITCH&gt; and a &lt;DIFFERENTIAL PRESSURE MEASURING INSTRUMENT&gt;</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure switch is a pressure switch that has the function to switch based on differential pressure measurements between two pressure inputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">interruptor de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure switch</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DifferentialPressureSwitch(x) ↔ PressureSwitch(x) ∧ ∃f(DifferentialPressureSwitchingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de pressão diferencial é um interruptor de pressão que possui uma função de comutação de pressão diferencial para comutar ou fornecer sinais liga/desliga quando a pressão diferencial medida entre duas entradas atinge um valor pré-estabelecido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A differential pressure switch is a pressure switch that bears a differential pressure switching function to switch or provide on/off signals when the measured differential pressure between two inputs reaches a pre-set value.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000322">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma curva de tubo é um tubo que possui geometria curvada para mudar a direção da tubulação com um raio não padrão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe bend is a pipe that has a curved geometry to change piping direction with a non-standard radius.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2391"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2390"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIPE BEND&gt; is a &lt;PIPING COMPONENT&gt; that is intended to change piping direction with a non-standard radius</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An 'artefact' that is intended to change piping direction with a non-standard radius</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is used to change piping direction with a non-standard radius.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">pipe bend</rdfs:label>
    <rdfs:label xml:lang="pt-br">curva de tubo</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe bend is a pipe that has curved geometry and has non-standard bend radius.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PipeBend(x) → Pipe(x) ∧ ∃g (CurvedGeometry(g) ∧ hasQuality(x,g)) ∧ ∃r (NonStandardBendRadius(r) ∧ hasQuality(x,r)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the curved geometry with non-standard radius is distinctive, making it sufficient under OWA could force classification of complex piping assemblies or custom manifolds containing bent sections into this maintenance category inappropriately.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidInlet">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
    <rdfs:label xml:lang="pt-br">entrada hidráulico de fluido</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic fluid inlet</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2072">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2070"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1588">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000229">
    <rdfs:label xml:lang="pt-br">cromatógrafo</rdfs:label>
    <rdfs:label xml:lang="en">chromatograph</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every chromatograph is a process analyzer that has the function of chromatographic analysis.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CHROMATOGRAPH&gt; is a &lt;PROCESS ANALYSER&gt; that analyses the molecular composition of a substance</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] An analysing instrument that applies the principle of chromatography to analyse the molecular composition of a substance.</skos:definition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b525"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A chromatograph is a process analyzer that bears a chromatographic analysis function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cromatógrafo é um analisador de processo que possui uma função de análise cromatográfica.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Chromatograph(x) ↔ ProcessAnalyzer(x) ∧ ∃f (ChromatographicAnalysisFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2965">
    <rdf:first rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2961"/>
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2966"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000153">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SwingCheckValve(x) → CheckValve(x) ∧ ∃d(HingedDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(SwingArm(a) ∧ hasComponentPartAtAllTimes(x,a)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[SLB Glossary] A check valve in which the closure element is a hinged clapper that swings or rotates about a supporting shaft.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A check valve that is a check valve where the closure member is a disc which swings freely on a hinge and which opens automatically when flow is established and closes automatically when flow ceases or is reversed.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A check valve that is a check valve where the closure member is a disc which swings freely on a hinge and which opens automatically when flow is established and closes automatically when flow ceases or is reversed.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SWING CHECK VALVE&gt; is an &lt;ARTEFACT&gt; and a &lt;CHECK VALVE&gt; where the closure member is a disc which swings freely on a hinge and which opens automatically when flow is established and closes automatically when flow ceases or is reversed</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção basculante é uma válvula de retenção que possui um elemento de fechamento consistindo de um disco que gira livremente em um mecanismo de dobradiça e abre automaticamente quando o fluxo é estabelecido e fecha automaticamente quando o fluxo cessa ou se inverte.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A swing check valve is a check valve that has a closure member consisting of a disc which swings freely on a hinge mechanism and opens automatically when flow is established and closes automatically when flow ceases or reverses.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">swing check valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de retenção basculante</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3042"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3041"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type to avoid false positives under OWA. Any artifact with a hinged disc mechanism should not automatically be classified as a swing check valve without domain expert validation, as specialized equipment may contain swing mechanisms but serve different primary functions.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every swing check valve is a check valve that has a hinged disc as component part and has a swing arm as component part</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000343">
    <iof-av:naturalLanguageDefinition xml:lang="en">A rupture disc is an instrument that realizes pressure relief through irreversible rupture at a calibrated pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um disco de ruptura é um instrumento que realiza alívio de pressão através de ruptura irreversível em uma pressão calibrada.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;RUPTURE DISC&gt; is an &lt;INSTRUMENT COMPONENT&gt; and an &lt;OVERPRESSURE PROTECTOR&gt; that is designed to burst at a certain excess pressure. It is a part of &lt;RUPTURE DISC ASSEMBLY&gt;</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A physical object that is designed to burst at a certain excess pressure. It is part of a rupture disc assembly.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is a pressure relieving device designed to burst at a calibrated pressure to prevent pressure in systems or vessels from reaching unsafe levels.</skos:definition>
    <rdfs:label xml:lang="pt-br">disco de ruptura</rdfs:label>
    <rdfs:label xml:lang="en">rupture disc</rdfs:label>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2761"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every rupture disc is an instrument that has the function to relieve pressure and participates in irreversible rupture processes at calibrated pressure thresholds.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (RuptureDisc(x) ↔ Instrument(x) ∧ ∃f(PressureReliefFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(IrreversibleRuptureProcess(p) ∧ participatesIn(x,p)) ∧ ∃q(CalibrationPressure(q) ∧ hasQuality(x,q)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InterfacingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2502"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2501"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">interfacing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de interfaceamento</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an InterfacingProcess and that consists in providing a standardized point of interface for communication, connection, or interaction with another object or system.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessingChamber">
    <rdfs:label xml:lang="pt-br">câmara de processamento</rdfs:label>
    <rdfs:label xml:lang="en">processing chamber</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
