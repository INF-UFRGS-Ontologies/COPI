  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de medição de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure measurement function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b985"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b975"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b986"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b976"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PressureSensingFunction that is realized in a DifferentialPressureMeasurementProcess and that consists in sensing the pressure difference between two fluid media or two points in the same medium to enable measurement of differential pressure.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicSignal">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">chromatographic signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de cromatográfico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction">
    <rdfs:label xml:lang="pt-br">função de modificação de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow modification function</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1521"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1522"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CylindricalChamber">
    <rdfs:label xml:lang="en">cylindrical chamber</rdfs:label>
    <rdfs:label xml:lang="pt-br">câmara cilíndrico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de geração de energia por turbomáquina</rdfs:label>
    <rdfs:label xml:lang="en">turbomachinery power generation function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1640"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1639"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000263">
    <rdfs:label xml:lang="pt-br">conector elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electrical connector</rdfs:label>
    <skos:definition xml:lang="en">[CFIHOS] A connector for holding two parts of a conductor in intimate contact.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ELECTRICAL CONNECTOR&gt; is an &lt;ARTEFACT&gt; and an &lt;CONNECTOR&gt; for holding two parts of &lt;ELECTRICAL CONDUCTOR&gt; in intimate contact</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ElectricalConnector ≡ ElectricalEquipment ⊓ ∃bearerOf.ElectricalConnectionFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnector(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalConnectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1205"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um conector elétrico é um equipamento elétrico que possui uma função de conexão elétrica e que mantém contato elétrico íntimo entre duas ou mais partes de condutor elétrico para permitir fluxo contínuo de corrente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000285">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GasEngine(x) → Engine(x) ∧ ∃f,s,r(GaseousFuelPortion(f) ∧ SparkIgnitionSystem(s) ∧ ReciprocatingPistonMechanism(r) ∧ hasInput(x,f) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,r)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[CFIHOS] An internal combustion engine that is a reciprocating engine in which gaseous fuel is mixed with air to form a combustible mixture in a cylinder which is fired by spark ignition.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GAS ENGINE&gt; is an &lt;INTERNAL COMBUSTION ENGINE&gt; and a &lt;RECIPROCATING PISTON ENGINE&gt; in which gaseous fuel is mixed with air to form a combustible mixture in a cylinder which is fired by spark ignition</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An internal combustion engine that is a reciprocating engine in which gaseous fuel is mixed with air to form a combustible mixture in a cylinder which is fired by spark ignition.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1631"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1634"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1632"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1635"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1633"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor a gás é um motor que usa combustível gasoso como entrada, emprega um sistema de ignição por centelha e opera com um mecanismo de pistão alternativo para gerar energia mecânica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas engine is an engine that uses gaseous fuel as input, employs a spark ignition system, and operates with a reciprocating piston mechanism to generate mechanical energy.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas engine is an engine that has gaseous fuel portion as input and has spark ignition system as component part at all times and has reciprocating piston mechanism as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">gas engine</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor a gás</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Gas engine is defined by constructive characteristics (gaseous fuel, spark ignition, reciprocating mechanism) rather than a unique function. Under Open World Assumption, making these conditions sufficient could lead to false positives where complex hybrid engines or experimental designs with these features are automatically classified as standard gas engines when they might require different maintenance/operational categories.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b302">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess"/>
  </rdf:Description>
