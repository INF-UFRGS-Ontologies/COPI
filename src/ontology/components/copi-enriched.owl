    <rdfs:label xml:lang="pt-br">processo de acumulação</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which fluid is collected and temporarily held in a vessel to buffer flow variations or build up inventory in a petroleum production system.</skos:definition>
