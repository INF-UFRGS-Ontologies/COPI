  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090">
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso de pressão é um vaso que possui uma função de contenção sob pressão, projetado para suportar com segurança cargas de pressão internas e/ou externas.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure vessel is a vessel that has a pressure containment function, and every vessel with a pressure containment function is a pressure vessel.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2132"/>
    <skos:definition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureVessel(x) ↔ (Vessel(x) ∧ ∃f (PressureContainmentFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">pressure vessel</rdfs:label>
    <rdfs:label xml:lang="pt-br">vaso de pressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b496">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LowPressureSignal">
    <rdfs:label xml:lang="pt-br">sinal baixo de pressão</rdfs:label>
    <rdfs:label xml:lang="en">low pressure signal</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An information content entity constituting an electrical or pneumatic signal representing a low-pressure condition in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">solid bulk storage function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de armazenamento de sólidos a granel</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2382"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2383"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the containment and temporary storage of solid bulk materials such as catalyst, proppant, or chemical reagents.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1286">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1287"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1283"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000272">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector de chama é um detector que tem a função de detectar a presença de chamas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1085"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame detector is a detector that has a flame detection function, and every detector that has a flame detection function is a flame detector.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">detector de chama</rdfs:label>
    <rdfs:label xml:lang="en">flame detector</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlameDetector(x) ↔ Detector(x) ∧ ∃f(FlameDetectionFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b445">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">válvula de alívio</rdfs:label>
    <rdfs:label xml:lang="en">relief valve</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de alívio é uma válvula projetada para abrir automaticamente em um ponto de ajuste de pressão predeterminado para aliviar o excesso de pressão e prevenir níveis de pressão inseguros em um sistema.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ReliefValve(x) ↔ (Valve(x) ∧ ∃f (PressureReliefFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2187"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every relief valve is a valve that bears a pressure relief function, which realizes a pressure relief process that automatically opens the valve when system pressure exceeds a predetermined setpoint.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1282">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1285"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1037">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
  </rdf:Description>
