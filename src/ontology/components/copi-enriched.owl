  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeasuringElement(x) ↔ (MeasuringElement(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">MeasuringElement que possui uma FlowMeasurementFunction e</rdfs:label>
    <rdfs:label xml:lang="en">flow measuring element</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1510"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MeasuringElement que possui uma FlowMeasurementFunction e que é projetado para determinar e quantificar a taxa de fluxo de fluido através de um sistema.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every FlowMeasuringElement is a MeasuringElement that bears a FlowMeasurementFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOW MEASURING ELEMENT&gt; is  a &lt;MEASURING ELEMENT&gt; that is used to measure &lt;FLOW RATE&gt;</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess">
    <rdfs:label xml:lang="pt-br">processo de suporte estrutural</rdfs:label>
