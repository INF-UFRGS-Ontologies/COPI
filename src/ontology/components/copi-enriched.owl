  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionModule">
    <rdfs:label xml:lang="pt-br">módulo de sinal de transmissão</rdfs:label>
    <rdfs:label xml:lang="en">signal transmission module</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a modular component that transmits measurement or control signals over a defined distance in petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess">
    <rdfs:label xml:lang="pt-br">processo de frenagem</rdfs:label>
    <rdfs:label xml:lang="en">braking process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a retarding force is applied to decelerate or hold stationary a rotating or translating mechanical component in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2945">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
