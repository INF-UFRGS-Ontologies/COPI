  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MotiveFluidNozzle">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">bocal de motriz de fluido</rdfs:label>
    <rdfs:label xml:lang="en">motive fluid nozzle</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a nozzle through which a high-velocity motive fluid is discharged to entrain and transport a second fluid in an ejector.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceIndication">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">indicação de fase de sequência</rdfs:label>
    <rdfs:label xml:lang="en">phase sequence indication</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting a displayed or transmitted value representing the phase sequence of an alternating-current electrical supply in a petroleum production installation.</skos:definition>
  </rdf:Description>
