    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2962">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000296">
    <iof-av:naturalLanguageDefinition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma mangueira é um tubo flexível projetado para conduzir líquidos sob pressão enquanto acomoda movimento posicional e flexão.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1820"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1819"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1821"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1818"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical properties (flexibility). Under OWA, asserting equivalence would force any artifact with flexibility and pressure capability to be classified as a hose, potentially including complex equipment with flexible components that should not be categorized as standard hoses.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</skos:definition>
    <rdfs:label xml:lang="en">hose</rdfs:label>
    <rdfs:label xml:lang="pt-br">mangueira</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Hose(x) → Pipe(x) ∧ ∃q(Flexibility(q) ∧ hasQuality(x,q)) ∧ ∃c(PressurizedFluidConduction(c) ∧ capableOf(x,c)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hose is a pipe that has flexibility and is capable of conducting liquids under pressure.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2377">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InnerLining">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">inner lining</rdfs:label>
    <rdfs:label xml:lang="pt-br">revestimento interno</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an internal lining applied to the inner surface of a vessel or pipe to protect against corrosion or abrasion in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ValveSeat(x) → (MaterialArtifact(x) ∧ ∃y(Valve(y) ∧ partOf(x,y)) ∧ ∃z(ValveClosureMember(z) ∧ adjacentTo(x,z)) ∧ ∃q(SealingSurfaceQuality(q) ∧ bearerOf(x,q))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é parte de uma válvula e que fornece a superfície de assentamento contra a qual o membro de fechamento se apoia para alcançar o fechamento e controle do fluxo de fluido de processo.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3327"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">valve seat</rdfs:label>
    <rdfs:label xml:lang="pt-br">assento de válvula</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ValveSeat ⊑ MaterialArtifact ⊓ ∃partOf.Valve ⊓ ∃adjacentTo.ValveClosureMember ⊓ ∃bearerOf.SealingSurfaceQuality</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Valve seat is a constructive type defined by its structural configuration and interface role. Under the Open World Assumption, making this an equivalence class could lead to false positives where any artifact that is part of a valve and adjacent to a closure member gets classified as a valve seat, even if it serves a different structural role (such as guides, stops, or supports).</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b9">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2301">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigLoadingChamber"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every burner is a heater that has the function of combustion, which is realized by burning a fuel-air mixture to release thermal energy.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">burner</rdfs:label>
    <rdfs:label xml:lang="pt-br">queimador</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador é um aquecedor que libera energia térmica através da queima de uma mistura combustível de combustível e ar.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <skos:definition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Burner(x) ↔ (Heater(x) ∧ ∃f (CombustionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b338"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1770">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1771"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1766"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1637">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1631"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1638"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixedFluidPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid formed by the combination of two or more streams in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção misto de fluido</rdfs:label>
    <rdfs:label xml:lang="en">mixed fluid portion</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingBundle">
    <skos:definition xml:lang="en">An assembly of multiple tubing strings grouped and routed together for injection or production purposes in petroleum production wells or risers.</skos:definition>
    <rdfs:label xml:lang="en">tubing bundle</rdfs:label>
    <rdfs:label xml:lang="pt-br">feixe de coluna de produção</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124">
    <rdfs:label xml:lang="en">heater</rdfs:label>
    <rdfs:label xml:lang="pt-br">aquecedor</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Heater(x) ↔ Assembly(x) ∧ ∃f(HeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heater is an assembly that bears a heating function and has heating elements and housing as component parts at all times</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1795"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b495">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2913">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignalTransmissionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pressure signal transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transmissão de sinal de pressão</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
    <skos:definition xml:lang="en">A signal transmission process in which a standardised signal representing a measured pressure value is transmitted to a remote control or monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShakingElement">
    <skos:definition xml:lang="en">A material artifact that constitutes a vibrating element—screen deck or shaker plate—that applies oscillating motion to separate solids from fluid in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">elemento de agitação</rdfs:label>
    <rdfs:label xml:lang="en">shaking element</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b719">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoriolisForceDetector"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2454">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000287">
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1645"/>
    <skos:definition xml:lang="en">A gasket is a material artifact made of deformable material arranged in closed loops that bears a sealing function to prevent leakage between mating surfaces with limited relative movement.</skos:definition>
    <rdfs:label xml:lang="en">gasket</rdfs:label>
    <rdfs:label xml:lang="pt-br">junta</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma junta é um artefato material feito de material deformável arranjado em loops fechados que possui uma função de vedação para prevenir vazamentos entre superfícies de acoplamento com movimento relativo limitado.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gasket is a material artifact made of deformable material arranged in closed loops that bears a sealing function to prevent leakage between mating surfaces with limited relative movement.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gasket is a material artifact that has component part some deformable material and bears some sealing function and has property some closed loop geometry.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Gasket(x) ↔ MaterialArtifact(x) ∧ ∃f(SealingFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(DeformableMaterial(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃g(ClosedLoopGeometry(g) ∧ hasProperty(x,g)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialHandlingSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">sistema de material de manuseio</rdfs:label>
    <rdfs:label xml:lang="en">material handling system</rdfs:label>
    <skos:definition xml:lang="en">An assembly of conveyors, lifts, and transfer equipment used to move solid materials within a petroleum production facility.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VaporOutlet">
    <skos:definition xml:lang="en">A material artifact that constitutes an outlet port through which vapour leaves a vessel or condenser in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">vapor outlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">saída de vapor</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Outlet"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MagneticCore">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the ferromagnetic core of a transformer or electromagnet that concentrates and guides the magnetic flux in petroleum production electrical equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">núcleo magnético</rdfs:label>
    <rdfs:label xml:lang="en">magnetic core</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de corte de tubulação</rdfs:label>
    <rdfs:label xml:lang="en">pipe shearing process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a tubular string within a wellbore is mechanically cut to enable emergency well control.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">temperature measurement and transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de temperatura</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which process temperature is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b454">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2143">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2144"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2138"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2199">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasurementSignal">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdfs:label xml:lang="en">measurement signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de medição</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing a measured process variable value in petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultipleConnections">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionSystem"/>
    <rdfs:label xml:lang="en">multiple connections</rdfs:label>
    <rdfs:label xml:lang="pt-br">conexões múltiplo</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an assembly of multiple fluid or electrical connections that distributes service to several points simultaneously in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b159"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b160"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b158"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <skos:definition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
    <rdfs:label xml:lang="en">ball control valve</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigEntryPort">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">bocal de pig de entrada</rdfs:label>
    <rdfs:label xml:lang="en">pig entry port</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the port through which a pipeline pig enters the pig launcher or pipeline system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatTransferBundle">
    <skos:definition xml:lang="en">A material artifact that constitutes an assembly of heat transfer tubes and baffles that form the core of a shell-and-tube heat exchanger in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">heat transfer bundle</rdfs:label>
    <rdfs:label xml:lang="pt-br">feixe de calor de transferência</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b52">
