  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction">
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1884"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b928"/>
