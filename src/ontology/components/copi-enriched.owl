  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalForce">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="pt-br">força mecânico</rdfs:label>
    <rdfs:label xml:lang="en">mechanical force</rdfs:label>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a force applied to or by a mechanical component in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1648">
