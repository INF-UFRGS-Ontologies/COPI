  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlEquipment">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">equipamento de fluxo de controle</rdfs:label>
    <rdfs:label xml:lang="en">flow control equipment</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RuptureElement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">rupture element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de ruptura</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb496">
    <owl:intersectionOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb498"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000347">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A shaker is an assembly that bears a shaking function, capable of producing vibrating or oscillating motion for material processing, agitation, or separation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um conjunto que possui uma função de agitação, capaz de produzir movimento vibratório ou oscilatório para processamento, agitação ou separação de materiais.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2919"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">Shaker(x) ↔ Assembly(x) ∧ ∃f(ShakingFunction(f) ∧ bearerOf(x,f))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">shaker</rdfs:label>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <skos:definition xml:lang="en">[OnePetro] A piece of drilling equipment, usually with a vibrating screen, where drill cuttings are removed from the flowing mud.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SHAKER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;SHAKING&gt;</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] Abbreviation for shale shaker, the primary and probably most important device on the rig for removing drilled solids from the mud.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every shaker is an assembly that has the capability of shaking and contains a vibration mechanism and a shaking element.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEAT TRANSFER PLATE&gt; is a &lt;PLATE&gt; that is intended to be used in a non tubular heat exchanger to segregate the two media</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HeatTransferPlate(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MediaSeparationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1826"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">heat transfer plate</rdfs:label>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma HeatTransferFunction e</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma HeatTransferFunction e que é destinado a ser usado em um trocador de calor não tubular para segregar dois meios fluidos enquanto facilita a transferência de energia térmica entre eles.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat transfer plate is a MaterialArtifact that bears a HeatTransferFunction and participates in segregating two fluid media in a non-tubular heat exchanger.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis requires necessary conditions only. Under OWA, sufficient conditions for 'plate geometry used in non-tubular heat exchangers' could lead to false positives - other components with plate-like surfaces might be incorrectly classified as heat transfer plates without domain expert validation of the structural and application-specific criteria.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Hub">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">hub</rdfs:label>
    <rdfs:label xml:lang="pt-br">cubo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ValveStem(x) → Assembly(x) ∧ ∃f(ForceTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(ValveStemSeal(s) ∧ hasComponentPartAtAllTimes(x,s)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3389"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3388"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical structure (rod/shaft mechanism). Under Open World Assumption, sufficient conditions would force any assembly with a valve stem seal and force transmission function to be classified as a valve stem, which could include complex multi-component assemblies, manifolds, or specialized valve mechanisms that contain these elements but should not be asserted into the standard valve stem maintenance category.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma ForceTransmissionFunction e que tem um selo de haste de válvula como parte componente, especificamente projetado para transmitir movimento de um operador de válvula para o membro de fechamento da válvula.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ValveStem SubClassOf Assembly and bearerOf some ForceTransmissionFunction and hasComponentPartAtAllTimes some ValveStemSeal</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VALVE STEM&gt; is a &lt;VALVE COMPONENT&gt; and a &lt;TRANSMITTER(force)&gt; that is a rod or shaft which is transmitting motion from an operator to the closure member of a valve</skos:definition>
    <rdfs:label xml:lang="pt-br">haste de válvula</rdfs:label>
    <rdfs:label xml:lang="en">valve stem</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb404">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266">
    <rdfs:label xml:lang="en">filter cartridge</rdfs:label>
    <rdfs:label xml:lang="pt-br">cartucho de filtro</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1304"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1302"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1303"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">[POSC Caesar] A filter element intended to collect particles from a stream in a filter or strainer.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER CARTRIDGE&gt; is an &lt;ARTEFACT&gt; and a &lt;FILTER ELEMENT&gt; intended to collect particles from a stream in a filter or strainer</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A filter element intended to collect particles from a stream in a filter or strainer.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2100">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2098"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2633">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalTerminals"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow meter is an instrument that bears a flow measurement function and has component parts including a flow sensing element and signal processing unit</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[POSC Caesar] A detecting instrument intended to measure and indicate flow rate and/or produce a signal which represents the measured flow rate.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device installed in a pump manifold or treating line to measure the fluid flow rate.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A detecting instrument intended to measure and indicate flow rate and/or produce a signal which represents the measured flow rate.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeter(x) ↔ Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">medidor de vazão</rdfs:label>
    <rdfs:label xml:lang="en">flow meter</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão é um instrumento que possui uma função de medir taxa de fluxo e produzir sinais ou indicações correspondentes.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1519"/>
  </rdf:Description>
