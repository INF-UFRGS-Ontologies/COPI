  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b486">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de acumulação</rdfs:label>
    <rdfs:label xml:lang="en">accumulation process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which fluid is collected and temporarily held in a vessel to buffer flow variations or build up inventory in a petroleum production system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1630">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b555">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterruptingMedium"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1855">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidPort"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000289">
    <rdfs:label xml:lang="pt-br">bomba de engrenagem</rdfs:label>
    <rdfs:label xml:lang="en">gear pump</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1690"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1692"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1691"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1689"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1688"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de engrenagem é uma bomba que contém dentes de engrenagem dentro de um invólucro ou carcaça para transportar líquido em pressões de retorno relativamente altas através de ação de engrenamento.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gear pump is a pump that has as component part at all times a gear mechanism and a pump casing, and bears a pumping function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the gear mechanism is definitionally necessary for gear pumps, making it sufficient under OWA could lead to false positives - any complex equipment containing gears (like gearboxes with integrated pumps or multi-function units) might be incorrectly classified as standard gear pumps for maintenance purposes.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GearPump(x) → Pump(x) ∧ ∃g,c (GearMechanism(g) ∧ PumpCasing(c) ∧ hasComponentPartAtAllTimes(x,g) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b558">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b553"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b559"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1900">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TangentialInlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TransductionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de transdução</rdfs:label>
    <rdfs:label xml:lang="en">transduction process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which one form of physical signal or energy is converted into another form suitable for measurement or transmission.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b658">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WingValve">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:label xml:lang="en">wing valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de ala</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a flow control valve on the side outlet of a Christmas tree that directs well production to a flowline or test separator.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b581"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b580"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the accommodation of relative movement between connected components caused by thermal expansion, vibration, or settlement.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de compensação de movimentação</rdfs:label>
    <rdfs:label xml:lang="en">movement compensation function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/IgnitionSystem">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="en">ignition system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de ignição</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of components that initiates combustion in a fired petroleum production equipment item.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1203">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
