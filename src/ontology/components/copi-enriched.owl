    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SideOutlet"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2855">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the presence, concentration, or state of a physical or chemical entity is sensed and identified by petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de detecção</rdfs:label>
    <rdfs:label xml:lang="en">detection process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThermowellStem(x) → FiatObjectPart(x) ∧ ∃y(Thermowell(y) ∧ partOf(x,y)) ∧ ∃q(HollowCylindricalShape(q) ∧ hasQuality(x,q)) ∧ ∃l(ProcessMediumIntrusionZone(l) ∧ hasLocation(x,l)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell stem is a fiat object part that is part of some thermowell and has hollow cylindrical shape and is located in process medium intrusion zone.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">termowell stem</rdfs:label>
    <rdfs:label xml:lang="en">thermowell stem</rdfs:label>
    <skos:definition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um termowell stem é uma parte de objeto fiducial que é parte de um termowell e que tem uma forma cilíndrica oca posicionada para se projetar no meio do processo, fornecendo habitação protetora para elementos de detecção de temperatura enquanto permite condução térmica.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3120"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis. The structural differentia (hollow cylindrical shape, positioning in process medium) is necessary but may not be sufficient under OWA - there could be other specialized parts of thermowells with similar geometry but different specific roles or configurations.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1946">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CleanedSurface">
    <skos:definition xml:lang="en">A material artifact that constitutes a surface from which scale, deposits, or contaminants have been removed by a cleaning process in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:label xml:lang="pt-br">superfície limpo</rdfs:label>
    <rdfs:label xml:lang="en">cleaned surface</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b17">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b15"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehumidifier is an assembly that has the function to perform dehumidification.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">desumidificador</rdfs:label>
    <rdfs:label xml:lang="en">dehumidifier</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b791"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desumidificador é um conjunto que possui a função de remover umidade do ar.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma Placa que possui geometria de espessura fina e é fabricada através de processos de conformação a frio, tipicamente usada para aplicações de suporte estrutural que requerem peso reduzido ou restrições geométricas específicas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">Placa que possui geometria de espessura fina e</rdfs:label>
    <rdfs:label xml:lang="en">thin plate</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ThinPlate ⊑ Plate ⊓ ∃hasQuality.ThinThickness ⊓ ∃hasQuality.ColdFormedManufacturing</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical geometry (thinness) and manufacturing method (cold forming). Under OWA, sufficient conditions for thin plates are difficult to specify without risking false positives from specialized hybrid structures that contain thin cold-formed elements but should not be classified as standard thin plates.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThinPlate(x) → Plate(x) ∧ ∃q1(ThinThickness(q1) ∧ hasQuality(x,q1)) ∧ ∃q2(ColdFormedManufacturing(q2) ∧ hasQuality(x,q2)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3123"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</skos:definition>
  </rdf:Description>
