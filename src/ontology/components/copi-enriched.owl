    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b402"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b401"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
