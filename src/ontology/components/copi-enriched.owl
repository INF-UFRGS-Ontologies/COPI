    <rdf:first rdf:nodeID="n55b6dbcc703c488db80806efee5015fab485"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab644">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
