  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b745">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialArtifact"/>
