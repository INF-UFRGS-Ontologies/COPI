  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionFunction">
    <iof-av:naturalLanguageDefinition xml:lang="en">A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">electrical connection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de conexão elétrica</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1207"/>
