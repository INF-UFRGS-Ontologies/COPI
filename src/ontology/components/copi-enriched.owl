  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235">
    <rdfs:label xml:lang="pt-br">resfriador</rdfs:label>
    <rdfs:label xml:lang="en">cooler</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab556"/>
    <skos:definition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Cooler(x) ↔ HeatExchanger(x) ∧ ∃f (CoolingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooler is a heat exchanger that has the function of cooling.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um resfriador é um trocador de calor que possui uma FunçãoDeResfriamento.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1827">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pressure relief process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de alívio de pressão</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a flow path is automatically opened to discharge fluid when process pressure exceeds a defined set point, protecting equipment from overpressure.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1291">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
