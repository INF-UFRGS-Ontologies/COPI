  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3147">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1746">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReinforcementLayer">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">reinforcement layer</rdfs:label>
    <rdfs:label xml:lang="pt-br">camada de reforço</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bearing is a material artifact that bears a support function and participates in friction reduction processes</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">mancal</rdfs:label>
    <rdfs:label xml:lang="en">bearing</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb211"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um mancal é um artefato material que é projetado para suportar e localizar elementos mecânicos móveis ou estáticos enquanto reduz o atrito na conexão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to support and locate a moving or static element and capable of reducing friction and transfer forces in a connection.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BEARING&gt; is a &lt;SUPPORT&gt; intended to support and locate a moving or static element</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Bearing(x) ↔ MaterialArtifact(x) ∧ ∃f(SupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(FrictionReductionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillCollar">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">drill collar</rdfs:label>
    <rdfs:label xml:lang="pt-br">broca de perfuração de perfuração</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultipleConnections">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">multiple connections</rdfs:label>
    <rdfs:label xml:lang="pt-br">conexões múltiplo</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionSystem"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb704">
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb705"/>
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb700"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2876"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2877"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1679"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1678"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a SealingProcess and that consists in providing a tight interface against which a closure element bears to prevent fluid leakage through a valve.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">sealing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de vedação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000376">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[OnePetro] In drilling, the drilled hole.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The drilled hole or borehole, including the openhole or uncased portion of the well.</skos:definition>
    <skos:definition xml:lang="en">[ppdm] A Wellbore is a path of drilled footage, from the Well Origin (top/start) to a terminating point (bottom/end). Key concept: Wellbores do not need to be drilled in one continuous operation; they are defined as a path from the Well Origin to a terminating point. Clarification: There are one or more Wellbores in a planned or drilled Well, namely the original Wellbore, and a Wellbore for each intended, actual or accidental sidetrack. Each Wellbore has a unique terminating point. A deepening of an existing Wellbore is considered a new Wellbore with the same Well Origin. Note that in this case, the original terminating point will be located within the new Wellbore. Widening of an existing Wellbore does not constitute a new, separate Wellbore.</skos:definition>
    <rdfs:label xml:lang="en">wellbore</rdfs:label>
    <rdfs:label xml:lang="pt-br">poço perfurado</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellbore is a site that has the function of providing subsurface access and is spatially contained within a well.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellbore(x) ↔ Site(x) ∧ ∃f(SubsurfaceAccessFunction(f) ∧ hasFunction(x,f)) ∧ ∃w(Well(w) ∧ spatiallyContainedIn(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um poço perfurado é um local que fornece um caminho perfurado para acesso subsuperficial e está espacialmente contido dentro de um sistema de poço.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000378">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[SLB Glossary] schlumberger wireline, well logging, well intervention, slickline, formation evaluation</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] Related to any aspect of logging that employs an electrical cable to lower tools into the borehole and to transmit data. Wireline logging is distinct from measurements-while-drilling (MWD) and mud logging.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;WIRELINE&gt; is an &lt;ELECTRICAL CABLE&gt; used to lower tools into and transmit data about the conditions of the wellbore called wireline logs. Usually consisting of braided cables, wirelines are used to perform wireline logging, as well.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Wireline(x) ↔ ElectricalCable(x) ∧ ∃f (WirelineLoggingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">wireline</rdfs:label>
    <rdfs:label xml:lang="pt-br">wireline</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3491"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wireline is an electrical cable that has the function to lower tools into wellbores and transmit logging data signals to the surface.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wireline is an electrical cable that bears a wireline logging function for lowering tools into wellbores and transmitting data about wellbore conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um wireline é um cabo elétrico que possui uma função de perfilagem wireline para descer ferramentas em poços e transmitir dados sobre as condições do poço.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigEntryPort">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">pig entry port</rdfs:label>
    <rdfs:label xml:lang="pt-br">bocal de pig de entrada</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081">
    <skos:definition xml:lang="en">[SLB Glossary] Devices for selecting or excluding data from a data stream or dataset.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An apparatus or machine that is capable of filtering (from ``_).</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A separator intended to remove solids from vapour or liquid.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A separator intended to remove solids from vapour or liquid</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A process or algorithm using a set of limits used to eliminate unwanted portions of seismic data, commonly on the basis of frequency or amplitude, to enhance the signal-to-noise ratio of the data or to achieve deconvolution.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER&gt; is a  &lt;FunctionalObject&gt; that is capable of &lt;FILTERING&gt;</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1280"/>
    <rdfs:label xml:lang="pt-br">filtro</rdfs:label>
    <rdfs:label xml:lang="en">filter</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro é um separador que possui uma função de filtração para remover seletivamente constituintes indesejados de um fluxo de fluido usando um elemento filtrante dentro de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Filter(x) ↔ (Separator(x) ∧ ∃f(FiltrationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilterElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃h(FilterHousing(h) ∧ hasComponentPartAtAllTimes(x,h))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter is a separator that has a filtration function and has a filter element as component part and has a filter housing as component part</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/IgnitionSystem">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="en">ignition system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de ignição</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000316">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Nozzle(x) ↔ MaterialArtifact(x) ∧ ∃f(FluidDirectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃o(ShapedOrifice(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃p(ProtrudingPart(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">bocal</rdfs:label>
    <rdfs:label xml:lang="en">nozzle</rdfs:label>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that has a protruding part through which a stream of fluid is directed.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A shaped orifice for directing fluid flow.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;NOZZLE&gt; is an &lt;ARTEFACT&gt; and a &lt;FLUID PORT&gt; and a &lt;CONNECTOR&gt; that is a protruding part through which a stream of fluid is directed</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] A projecting short piece of pipe that is attached to another (hollow) body.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A physical object that has a protruding part through which a stream of fluid is directed.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every nozzle is a material artifact that bears a fluid direction function and has a shaped orifice and protruding part as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2283"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um bocal é um artefato material que possui uma parte protuberante com um orifício moldado projetado para direcionar o fluxo de fluido em um padrão específico.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360">
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical geometry (thinness) and manufacturing method (cold forming). Under OWA, sufficient conditions for thin plates are difficult to specify without risking false positives from specialized hybrid structures that contain thin cold-formed elements but should not be classified as standard thin plates.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma Placa que possui geometria de espessura fina e é fabricada através de processos de conformação a frio, tipicamente usada para aplicações de suporte estrutural que requerem peso reduzido ou restrições geométricas específicas.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">thin plate</rdfs:label>
    <rdfs:label xml:lang="pt-br">Placa que possui geometria de espessura fina e</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThinPlate(x) → Plate(x) ∧ ∃q1(ThinThickness(q1) ∧ hasQuality(x,q1)) ∧ ∃q2(ColdFormedManufacturing(q2) ∧ hasQuality(x,q2)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3179"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;THIN PLATE&gt; is a &lt;PLATE&gt; that is a thin steel plate format (Sheet plate) Normally made by coldforming</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ThinPlate ⊑ Plate ⊓ ∃hasQuality.ThinThickness ⊓ ∃hasQuality.ColdFormedManufacturing</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
