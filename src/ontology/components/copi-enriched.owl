  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260">
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on electrical energy conversion mechanism. Under OWA, asserting equivalence would force any artifact with electrical-to-mechanical conversion into this category, potentially misclassifying specialized hybrid equipment or complex electrical machinery that should not be categorized as standard actuators.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ELECTRIC ACTUATOR&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROLLED ACTUATOR&gt; and an &lt;ELECTRICAL APPARATUS&gt; and an &lt;ELECTRIC TO MECHANICAL ENERGY CONVERTER&gt; that produces a specified movement when actuated by electrical energy</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] An actuator that produces a specified movement when excited by an electric signal.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An actuator that produces a specified movement when excited by an electric signal.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1152"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1153"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1155"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1154"/>
    <rdfs:label xml:lang="en">electric actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador elétrico</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador elétrico é um atuador que converte energia elétrica em movimento mecânico através de um componente conversor elétrico-mecânico e opera via entrada de sinal elétrico.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric actuator is an actuator that converts electrical energy to mechanical movement through an electric-to-mechanical converter component and operates via electrical signal input.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric actuator is an actuator that has an electric-to-mechanical converter component at all times and has electrical signal input.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricActuator(x) → Actuator(x) ∧ ∃y(ElectricToMechanicalConverter(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ElectricalSignal(z) ∧ hasInput(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1841">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasInput"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidPortion"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2260">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyPortion"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1316">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPortion"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000240">
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b767"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Deaerator(x) ↔ (Separator(x) ∧ ∃f(DeaerationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">desaerador</rdfs:label>
    <rdfs:label xml:lang="en">deaerator</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every deaerator is a separator that bears a deaeration function for removing dissolved gases from liquids</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEAERATOR&gt; is an &lt;ARTEFACT&gt; and a &lt;SEPARATOR&gt; intended to release dissolved gases from a liquid, typically to release oxygen and carbon dioxide from water</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] Devices used to separate gasses from liquids.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desaerador é um separador projetado para remover gases dissolvidos de correntes líquidas através de processos especializados de desgaseificação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A deaerator is a separator designed to remove dissolved gases from liquid streams through specialized degassing processes.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1080">
