  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess">
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2030"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2948"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2701"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1107"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2702"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1735"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2031"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2947"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1740"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2912"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1736"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1741"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2913"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1106"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2324"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2323"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from an external energy source through a rotating shaft to downstream mechanical components, enabling power transfer within a mechanical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted from a driving component to a driven component through the rotation or linear motion of a shaft, enabling the transfer of torque and rotational speed.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transferred from a prime mover through a rotating shaft to one or more driven machines, typically involving the conversion of torque and rotational speed to match operational requirements.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical rotational energy is transmitted from a prime mover through a shaft to driven components, resulting in the transfer of torque and rotational motion necessary for equipment operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical power is transferred from one rotating or reciprocating component to another through direct mechanical engagement, resulting in motion transmission and potentially torque or speed modification.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which mechanical energy is transmitted through rotational motion from one component to another via a rotating shaft, enabling the transfer of torque and angular velocity to mounted components.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de transmissão de potência</rdfs:label>
    <rdfs:label xml:lang="en">power transmission process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000352">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">skid</rdfs:label>
    <rdfs:label xml:lang="pt-br">skid</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every skid is an assembly that bears an equipment support function and has a support frame and mounting points as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Skid(x) ↔ (Assembly(x) ∧ ∃f(EquipmentSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SupportFrame(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(MountingPoint(m) ∧ hasComponentPartAtAllTimes(x,m))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um skid é uma montagem que possui uma função de suporte de equipamento, consistindo de uma estrutura de suporte e pontos de montagem, projetada para suportar itens de equipamento durante fabricação, transporte, manuseio e instalação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A skid is an assembly that bears an equipment support function, consisting of a support frame and mounting points, designed to support equipment items during manufacturing, transportation, handling, and installation.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[POSC Caesar] A 'support' intended to support items when being manufactured, transported, handled or installed.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SKID&gt; is an &lt;ARTEFACT&gt; and a &lt;SUPPORT&gt; intended to support items when being manufactured, transported, handled or installed</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] Move a well to a close-by locations with minimum rig down of equipment.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A steel frame on which portable equipment is mounted to facilitate handling with cranes or flatbed trucks.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3003"/>
  </rdf:Description>
