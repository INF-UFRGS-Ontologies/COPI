    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TangentialInlet"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2149">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328">
    <rdfs:label xml:lang="en">pneumatic motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor pneumático</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PneumaticMotor(x) ↔ Motor(x) ∧ ∃f(PneumaticMotorFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2488"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PNEUMATIC MOTOR&gt; is an &lt;AIR MOTOR&gt; that is driven by compressed gas (typically air)</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor pneumático é um motor que converte energia de gás comprimido em energia mecânica rotacional.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic motor is a motor that bears a PneumaticMotorFunction.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1450">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FeedInlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CasingHanger">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">casing hanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">suspensor de invólucro</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201">
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3133"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3124"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3123"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3132"/>
    <rdfs:label xml:lang="pt-br">função de proteção de sensor de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature sensor protection function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a TemperatureSensorProtectionProcess and that consists in providing a protective enclosure for temperature sensing elements while enabling thermal conductivity from the process medium to the sensor.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2453">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000268">
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1306"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1309"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1308"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1307"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[SLB Glossary] A pressurized cell, fitted with a filter medium, used for evaluating filtration characteristics of a drilling fluid while it is either static or stirred.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER PRESS&gt; is a &lt;FILTER&gt; and a &lt;PRESS(machine)&gt; intended to separate substance through compression</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] Usually a DE filter.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FilterPress(x) → Filter(x) ∧ ∃p(PressureMechanism(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃proc(MechanicalCompressionProcess(proc) ∧ participatesIn(x,proc)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter press is a filter that applies mechanical compression force to enhance the separation of substances through a pressurized filtration process.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma prensa filtrante é um filtro que aplica força de compressão mecânica para melhorar a separação de substâncias através de um processo de filtração pressurizada.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">filter press</rdfs:label>
    <rdfs:label xml:lang="pt-br">prensa filtrante</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as 'both' functional and constructive. The structural differentia (pressure mechanism and compression process) involves specific mechanical configurations that are harder to make sufficient under Open World Assumption without detailed engineering specifications.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter press is a filter that has a pressure mechanism as part and participates in mechanical compression processes.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2034">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LiquidOutlet"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000233">
    <rdfs:label xml:lang="pt-br">transmissor de condutividade</rdfs:label>
    <rdfs:label xml:lang="en">conductivity transmitter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CONDUCTIVITY TRANSMITTER&gt; is an &lt;CONDUCTIVITY METER&gt; and a &lt;PROCESS VARIABLE TRANSMITTER&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that is intended to measure and transmit conductivity.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every conductivity transmitter is a transmitter that has the function to measure and transmit electrical conductivity of process fluids.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de condutividade é um transmissor que possui uma função de medição de condutividade.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A conductivity transmitter is a transmitter that bears a conductivity measurement function.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b632"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ConductivityTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(ConductivityMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1148">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalTerminal"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b160"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b159"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b158"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BALL CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;BALL VALVE&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A ball valve that is equipped with an actuator that manipulates a stream of fluid in the response to a signal from an external sensing element and with input of energy from an external source.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">ball control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000336">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PumpShaft(x) → MaterialArtifact(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(Impeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃b(Bearing(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃p(Pump(p) ∧ partOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PUMP SHAFT&gt; is a &lt;SHAFT&gt; of a pump that is provided with impeller(s), bearings, bushings, sealing elements etc.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction and that is equipped with impeller(s), bearings, bushings, and sealing elements as part of a pump assembly for transmitting rotational mechanical energy to enable fluid pumping operations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de bomba é um MaterialArtifact que possui uma PowerTransmissionFunction e que é equipado com impulsor(es), mancais, buchas e elementos de vedação como parte de um conjunto de bomba para transmitir energia mecânica rotacional e possibilitar operações de bombeamento de fluidos.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pump shaft</rdfs:label>
    <rdfs:label xml:lang="pt-br">eixo de bomba</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical configuration, sufficient conditions are omitted to avoid false positives under OWA. Any rotating component with an impeller and bearings could theoretically be classified as a pump shaft under sufficient conditions, including hybrid equipment or specialized assemblies that should not be automatically categorized as standard pump shafts.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotatingShaft"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2667"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction, has impeller(s) as component parts, has bearings as component parts, and is part of a pump assembly.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121">
    <iof-av:naturalLanguageDefinition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma caixa de engrenagens é um conjunto que consiste em um invólucro de engrenagens contendo um arranjo de duas ou mais rodas de engrenagem que transmitem movimento rotativo de um eixo de entrada para um eixo de saída.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Gearbox(x) → Assembly(x) ∧ ∃c,g1,g2,i,o (GearCasing(c) ∧ GearWheel(g1) ∧ GearWheel(g2) ∧ g1≠g2 ∧ InputShaft(i) ∧ OutputShaft(o) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,g1) ∧ hasComponentPartAtAllTimes(x,g2) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[DEXPI] An artefact that consists of a gear casing with an arrangement of two or more gear-wheels transmitting rotating motion from the input shaft to the output shaft.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GEARBOX&gt; is an &lt;ARTEFACT&gt; and a &lt;TRANSMITTER(force)&gt; and that consistes of a gear casing with an arrangement of two or more gear-wheels transmitting rotating motion from the input shaft to the output shaft</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gearbox is an assembly that has component parts including a gear casing, at least two gear-wheels, an input shaft, and an output shaft, and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">caixa de engrenagens</rdfs:label>
    <rdfs:label xml:lang="en">gearbox</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1725"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1722"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1721"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1724"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1723"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because the structural differentia (specific gear casing and gear-wheel arrangement) is complex and making it sufficient under Open World Assumption could lead to false positives - specialized equipment containing gear mechanisms might be incorrectly classified as standard gearboxes.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SurfaceSafetyValve">
    <rdfs:label xml:lang="pt-br">válvula de superfície de segurança</rdfs:label>
    <rdfs:label xml:lang="en">surface safety valve</rdfs:label>
