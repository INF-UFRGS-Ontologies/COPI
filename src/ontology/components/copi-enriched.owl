    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BLOW DOWN VALVE is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; that can be used for rapid depressurizing of a high pressure system</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A valve that can be used for rapid depressurizing of a high pressure system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (BlowDownValve(x) ↔ Valve(x) ∧ ∃f (RapidDepressurizationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every blow down valve is a valve that has the function of rapid depressurization.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de blow down é uma válvula que possui uma função projetada para despressurização rápida de sistemas de alta pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b263"/>
    <rdfs:label xml:lang="en">blow down valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de blow down</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3106">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DampingFunction">
    <rdfs:label xml:lang="pt-br">função de amortecimento</rdfs:label>
    <rdfs:label xml:lang="en">damping function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b748"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b749"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000277">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">riser flexível</rdfs:label>
    <rdfs:label xml:lang="en">flexible riser</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1470"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1469"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1471"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLEXIBLE RISER&gt; is an &lt;ARTEFACT&gt; and a &lt;RISER&gt; that is a flexible vertical or near vertical pipe for the flow of liquid or gas between the seabed and the surface</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A flexible vertical or near vertical pipe for the flow of liquid or gas between the seabed and the surface.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flexible riser is a riser that has a flexible property</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where flexibility is a material/structural property. Under OWA, asserting equivalence would force any pipe with flexible qualities to be classified as a flexible riser, even if it serves different functions or has different deployment contexts. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um riser flexível é um riser que possui construção de material flexível permitindo condução de fluido vertical ou quase vertical entre o fundo do mar e a superfície, acomodando o movimento da embarcação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlexibleRiser(x) → Riser(x) ∧ ∃q(FlexibleProperty(q) ∧ hasQuality(x,q)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FacilityConnection">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Connection"/>
    <rdfs:label xml:lang="pt-br">conexão de instalação</rdfs:label>
    <rdfs:label xml:lang="en">facility connection</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000332">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um enrolamento de transformador que é parte de um transformador de potência e que serve como enrolamento primário recebendo energia elétrica de entrada para transformação eletromagnética.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PrimaryWinding"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2554"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;POWER TRANSFORMER PRIMARY WINDING&gt; is a &lt;TRANSFORMER PRIMARY WINDING&gt; intended to be the winding of a power transformer</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">enrolamento de transformador</rdfs:label>
    <rdfs:label xml:lang="en">power transformer primary winding</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural position within power transformer. Under OWA, sufficient conditions for primary winding configuration would risk false positives for specialized or hybrid transformer components that contain primary-like windings but should not be classified as standard power transformer primary windings.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerPrimaryWinding is-a TransformerWinding that is-part-of PowerTransformer and has-function PrimaryWindingFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerPrimaryWinding(x) → TransformerWinding(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(PrimaryWindingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyStorageMechanism">
    <rdfs:label xml:lang="pt-br">mecanismo de energia de armazenamento</rdfs:label>
    <rdfs:label xml:lang="en">energy storage mechanism</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000307">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um refervedor tipo kettle é um refervedor que possui orientação horizontal e contém um espaço de vapor separado para desengajamento vapor-líquido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A kettle reboiler is a reboiler that has horizontal orientation and contains a separate vapour space for vapor-liquid disengagement.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2022"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2021"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2023"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2020"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every kettle reboiler is a reboiler that has horizontal orientation and has a separate vapour space as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A reboiler often boils liquid coming from the bottom of a distillation column, after which the resulting vapour is returned to the distillation column.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;KETTLE REBOILER&gt; is a &lt;REBOILER&gt; that is horizontal and has a separate vapour space.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(KettleReboiler(x) → Reboiler(x) ∧ ∃q(HorizontalOrientation(q) ∧ hasQuality(x,q)) ∧ ∃v(SeparateVapourSpace(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by specific physical configuration. Under Open World Assumption, sufficient conditions could incorrectly classify equipment with horizontal orientation and vapor space but fundamentally different purposes (e.g., horizontal separators, flash drums) as kettle reboilers. The structural differentia provides necessary conditions for the kettle reboiler maintenance/procurement category.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">kettle reboiler</rdfs:label>
    <rdfs:label xml:lang="pt-br">refervedor tipo kettle</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1235"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1236"/>
    <rdfs:label xml:lang="pt-br">função de acomodação de expansão térmica</rdfs:label>
    <rdfs:label xml:lang="en">thermal expansion accommodation function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000361">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador trifásico é um separador que possui uma função de separação trifásica para separar fluidos de poço em fases gasosa, oleosa e aquosa.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;THREE-PHASE SEPARATOR&gt; is an &lt;ARTEFACT&gt; and a &lt;FLUID SEPARATOR&gt; intended to separate three fluids in different phases, typically gas and liquid and water</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A separator intended to separate three fluids in different phases, typically gas and liquid and water</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A vessel that separates the well fluids into gas and two types of liquids: oil and water.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ThreePhaseSeparator(x) ↔ (Separator(x) ∧ ∃f (ThreePhaseSeparationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">three phase separator</rdfs:label>
    <rdfs:label xml:lang="pt-br">separador trifásico</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every three-phase separator is a separator that has the function of separating fluid into gas, oil, and water phases, and has gas outlet, oil outlet, and water outlet as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3146"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3150">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WaterOutlet"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FormationFluidPortion">
    <rdfs:label xml:lang="en">formation fluid portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de formação de fluido</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2660">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1768">
    <rdf:first rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1763"/>
    <rdf:rest rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1769"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/OverflowOutlet">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">overflow outlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">saída de transbordamento</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000377">
    <rdfs:label xml:lang="en">wellhead</rdfs:label>
    <rdfs:label xml:lang="pt-br">cabeçal de poço</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cabeçal de poço é um conjunto que porta uma função de controle superficial do poço e fornece a interface estrutural e de controle entre um poço e os equipamentos de superfície.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[CFIHOS] The wellhead is assembled from, or incorporates facilities for, the upper casing and tubing hangers. This effectively provides the upper termination of the wellbore and provides a mounting position for the surface flow-control equipment or Christmas tree.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] The mechanical connection between the tree and the casing. May house tubular hangers, annular access valves. It is connected to the casing by welding, threads, hydraulic forming or set screws.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The system of spools, valves and assorted adapters that provide pressure control of a production well.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;WELLHEAD&gt; is an &lt;ARTEFACT&gt; that is the top of the casing of a production oil well including the attached control and flow valves</skos:definition>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3426"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellhead is an assembly that bears a well surface control function and has component parts including casing hangers and connection to wellbore</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellhead(x) ↔ Assembly(x) ∧ ∃f(WellSurfaceControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃h(CasingHanger(h) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃w(Wellbore(w) ∧ hasConnectionTo(x,w)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">degassing process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de degaseificação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334">
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'PIT'. First letter 'P': Pressure. Succeeding letters: 'I' = Indicate, 'T' = Transmit.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor indicador de pressão é um transmissor que mede pressão e fornece tanto indicação visual local quanto transmissão de sinal elétrico do valor da pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">transmissor indicador de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure indicating transmitter</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureIndicatingTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PressureIndicatingAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(PressureSignal(i) ∧ hasInput(x,i)) ∧ ∃o1(ElectricalSignal(o1) ∧ hasOutput(x,o1)) ∧ ∃o2(LocalPressureDisplay(o2) ∧ hasOutput(x,o2)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure indicating transmitter is a transmitter that bears a pressure indicating and transmission function, has pressure signal as input, and has both electrical signal output and local pressure display.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2595"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000261">
    <skos:definition xml:lang="en">[CFIHOS] An energy transducer that transforms non-electric energy into electric energy.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ELECTRIC GENERATOR&gt; is a &lt;GENERATOR&gt; that transforms non-electric energy into &lt;ELECTRIC ENERGY&gt;</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um gerador elétrico é um conjunto que possui a função de converter energia não-elétrica em energia elétrica</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1160"/>
    <rdfs:label xml:lang="en">electric generator</rdfs:label>
    <rdfs:label xml:lang="pt-br">gerador elétrico</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric generator is an assembly that has the function to convert non-electric energy into electric energy</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ElectricGenerator(x) ↔ (Assembly(x) ∧ ∃f(ElectricEnergyGenerationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243">
    <skos:definition xml:lang="en">[SLB Glossary] A device used to remove water and water vapors from gas.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A treating vessel designed to remove water from a process stream.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEHYDRATOR&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEHYDRATING&gt;</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehydrator is a separator that has the function of dehydration.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">dehydrator</rdfs:label>
    <rdfs:label xml:lang="pt-br">desidratador</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b824"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
