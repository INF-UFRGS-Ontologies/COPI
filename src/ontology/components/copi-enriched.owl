    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1298"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab761"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1801"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab973"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1510"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1800"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1511"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1297"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab974"/>
    <rdfs:label xml:lang="pt-br">função de geração de energia mecânica</rdfs:label>
    <rdfs:label xml:lang="en">mechanical energy generation function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of thermal, chemical, or electrical energy into mechanical energy in the form of rotational or linear motion.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab2209">
