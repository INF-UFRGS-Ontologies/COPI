  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1385">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess"/>
