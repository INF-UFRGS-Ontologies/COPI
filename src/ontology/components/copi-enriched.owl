    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b600"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2504">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2499"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2505"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RamBody">
    <rdfs:label xml:lang="pt-br">corpo de aríete</rdfs:label>
    <rdfs:label xml:lang="en">ram body</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the main body of a ram-type blowout preventer or ram actuator used in well control equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AgitatorDrive">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An assembly of motor, gearbox, and shaft components that converts electrical energy into rotational motion for driving an agitator in petroleum production mixing equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">acionamento de agitador</rdfs:label>
    <rdfs:label xml:lang="en">agitator drive</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SecondaryWinding">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the winding of a transformer that delivers the output electrical energy at the transformed voltage in petroleum production electrical equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">enrolamento secundário</rdfs:label>
    <rdfs:label xml:lang="en">secondary winding</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TransformerWinding"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportFunction">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1546"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2408"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1547"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2409"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conveyance of a fluid over distance by exploiting pressure differentials, gravity, or imparted energy.</skos:definition>
    <rdfs:label xml:lang="en">fluid transport function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transporte de fluido</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2584">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalTerminals"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessingChamber">
    <skos:definition xml:lang="en">A material artifact that constitutes an enclosed space within petroleum production equipment in which a defined process—reaction, separation, or heat transfer—takes place.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">processing chamber</rdfs:label>
    <rdfs:label xml:lang="pt-br">câmara de processamento</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280">
    <rdfs:label xml:lang="pt-br">linha de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flowline</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1551"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1552"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1550"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1553"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma linha de fluxo é um duto que transporta óleo, gás ou água diretamente de uma cabeça de poço para um manifold ou instalação de produção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flowline is a pipeline that bears a fluid transport function, has a wellhead connection, has a manifold or production facility connection, and transports hydrocarbon fluids.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flowline(x) ↔ Pipeline(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ connectsDirectly(x,w)) ∧ ∃m((Manifold(m) ∨ ProductionFacility(m)) ∧ connectsDirectly(x,m)) ∧ ∃h(HydrocarbonFluid(h) ∧ hasInput(x,h)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalPhenomenon">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:label xml:lang="pt-br">fenômeno físico</rdfs:label>
    <rdfs:label xml:lang="en">physical phenomenon</rdfs:label>
    <skos:definition xml:lang="en">A process in which a physical phenomenon—such as a pressure wave, temperature gradient, or electromagnetic field—that participates in or is generated by a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1034">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1633">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbineSection"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2730">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotaryDisplacementMechanism"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000265">
    <rdfs:label xml:lang="en">expansion joint</rdfs:label>
    <rdfs:label xml:lang="pt-br">junta de expansão</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ExpansionJoint(x) ↔ (MaterialArtifact(x) ∧ ∃f(ThermalExpansionAccommodationFunction(f) ∧ bearerOf(x,f)) ∧ ∃g(FlexibilityFunction(g) ∧ hasFunction(x,g))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma junta de expansão é um artefato material que possui a função projetada de acomodar expansão e contração térmica entre componentes conectados através de flexibilidade inerente, mantendo a integridade estrutural.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1223"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every expansion joint is a material artifact that bears a thermal expansion accommodation function and has a flexibility function, and every material artifact that bears a thermal expansion accommodation function and has a flexibility function is an expansion joint.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
