  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled introduction of a pipeline pig into a pipeline under operating pressure.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2293"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2292"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">pig launching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de lançamento de pig</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
