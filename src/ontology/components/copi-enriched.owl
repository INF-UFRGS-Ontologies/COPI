  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000356">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3047"/>
    <rdfs:label xml:lang="pt-br">contato de chave</rdfs:label>
    <rdfs:label xml:lang="en">switch contact</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um contato de chave é um contato elétrico que é uma das partes condutoras que formam um conjunto de contato.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SWITCH CONTACT&gt; is an &lt;ELECTRICAL CONTACT&gt; that is one of the conductive parts forming a contact.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every switch contact is an electrical contact that is part of an electrical contact assembly and bears an electrical conduction function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural role as a conductive part. Under OWA, asserting sufficient conditions could incorrectly classify any conductive part of an electrical contact as a switch contact, when there may be other specialized conductive components (bus bars, terminals, etc.) that serve different structural roles.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (SwitchContact(x) → ElectricalContact(x) ∧ ∃y(ElectricalContact(y) ∧ partOf(x,y)) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b263">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b266"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069">
    <rdfs:label xml:lang="pt-br">função de absorção de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas absorption function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b9"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b8"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000258">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um secador é um conjunto que possui uma função de secagem para remover umidade de materiais.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dryer is an assembly that bears a drying function to remove moisture from materials.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DRYER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;DRYING&gt;</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An object that has the capability of drying (from ``_).</skos:definition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1111"/>
    <rdfs:label xml:lang="en">dryer</rdfs:label>
    <rdfs:label xml:lang="pt-br">secador</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dryer is an assembly that has the function of drying materials by removing moisture.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dryer(x) ↔ Assembly(x) ∧ ∃f(DryingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1864">
