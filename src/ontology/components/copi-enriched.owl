  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionProducts">
    <rdfs:label xml:lang="pt-br">produtos de combustão</rdfs:label>
    <rdfs:label xml:lang="en">combustion products</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the chemical products—primarily carbon dioxide and water vapour—resulting from the combustion of a fuel in petroleum production equipment.</skos:definition>
  </rdf:Description>
