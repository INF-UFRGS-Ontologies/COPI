  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b961">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InLineFilter">
    <iof-av:naturalLanguageDefinition xml:lang="en">An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro em linha é um filtro que é instalado diretamente dentro de uma linha de fluido e suportado por tubulações ou equipamentos conectados, projetado para remover partículas ou contaminantes de correntes de fluido durante operações normais de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every in-line filter is a filter that has an in-line installation method and is supported by connected equipment.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (InLineFilter(x) → Filter(x) ∧ ∃m,e (InLineInstallation(m) ∧ ConnectedEquipment(e) ∧ hasInstallationMethod(x,m) ∧ supportedBy(x,e)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;IN-LINE FILTER&gt; is an &lt;ARTEFACT&gt; and a &lt;FILTER&gt; that is intended to be supported by connected equipment. Typically supported by piping</skos:definition>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1935"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1934"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical installation configuration. Under OWA, any filter with in-line connections and piping support could be classified as in-line filter, but specialized hybrid equipment or custom installations might have these features without belonging to the standard in-line filter maintenance category. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">in line filter</rdfs:label>
    <rdfs:label xml:lang="pt-br">filtro em linha</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1448">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VaporOutlet"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction">
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b302"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b303"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de perfuração de fundo de poço</rdfs:label>
    <rdfs:label xml:lang="en">bottom hole drilling function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280">
    <rdfs:label xml:lang="en">flowline</rdfs:label>
    <rdfs:label xml:lang="pt-br">linha de fluxo</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flowline(x) ↔ Pipeline(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ connectsDirectly(x,w)) ∧ ∃m((Manifold(m) ∨ ProductionFacility(m)) ∧ connectsDirectly(x,m)) ∧ ∃h(HydrocarbonFluid(h) ∧ hasInput(x,h)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1567"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1569"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1568"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1566"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOWLINE&gt; is an &lt;ARTEFACT&gt; and  a &lt;PIPELINE&gt; carrying oil, gas or water that connects the wellhead to a manifold or to production facilities, such as heater-treaters and separators</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] The pipe connection between the well and the separators or tank battery.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The large-diameter metal pipe that connects the bell nipple under the rotary table to the possum belly at the mud tanks.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma linha de fluxo é um duto que transporta óleo, gás ou água diretamente de uma cabeça de poço para um manifold ou instalação de produção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flowline is a pipeline that bears a fluid transport function, has a wellhead connection, has a manifold or production facility connection, and transports hydrocarbon fluids.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportFrame">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
