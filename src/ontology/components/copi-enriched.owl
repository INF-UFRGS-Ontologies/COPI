  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1912">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207">
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b49"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Actuator(x) ↔ Assembly(x) ∧ ∃f (ActuationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A physical object for changing a signal into a corresponding movement.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] An actuator is a type of motor for moving or controlling a mechanism or system. Actuator's are a vital part of offshore operations.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A transducer that is intended to convert energy (electric, mechanical, pneumatic or hydraulic) from an external source into kinetic energy (motion) in response to a signal or or power input.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ACTUATOR&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;ACTUATING&gt;</skos:definition>
    <rdfs:label xml:lang="en">actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every actuator is an assembly that has the function of converting external energy into controlled kinetic motion.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador é um conjunto que possui uma função de atuação para converter energia de uma fonte externa em movimento cinético em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
