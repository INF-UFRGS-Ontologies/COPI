  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess">
    <rdfs:label xml:lang="pt-br">processo de inspeção visual</rdfs:label>
    <rdfs:label xml:lang="en">visual inspection process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2425">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000357">
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3036"/>
    <skos:definition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</skos:definition>
    <rdfs:label xml:lang="pt-br">quadro de distribuição</rdfs:label>
    <rdfs:label xml:lang="en">switchboard</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Switchboard(x) ↔ ElectricalEquipment(x) ∧ ∃p,s,i(Panel(p) ∧ ElectricalSwitch(s) ∧ ControlIndicator(i) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃f(ElectricalCircuitControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um quadro de distribuição é um equipamento elétrico que consiste em painéis que acomodam chaves, indicadores e aparatos de controle para conectar, desconectar e controlar vários circuitos de um sistema elétrico.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every switchboard is electrical equipment that has component parts (panels, switches, indicators) and bears the function to control electrical circuits</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
