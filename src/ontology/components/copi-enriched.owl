  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionInterface">
    <rdfs:label xml:lang="pt-br">interface de conexão</rdfs:label>
    <rdfs:label xml:lang="en">connection interface</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the mating surfaces and seals at which two components are joined in a petroleum production system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma conexão elétrica é um MaterialArtifact que possui uma ElectricalConductionFunction e que fornece um caminho para a corrente elétrica passar de um aparelho elétrico para outro.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnection(x) ↔ (MaterialArtifact(x) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ElectricalConductionProcess(p) ∧ participatesIn(x,p) ∧ ∃y(ElectricalApparatus(y) ∧ has_participant_at_some_time(p,y)))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1181"/>
    <skos:definition xml:lang="en">An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electrical connection is a material artifact that bears an electrical conduction function and participates in processes involving electrical apparatus.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">electrical connection</rdfs:label>
    <rdfs:label xml:lang="pt-br">conexão elétrica</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1075">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1073"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SideOutlet">
    <rdfs:label xml:lang="en">side outlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">saída lateral</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a lateral outlet port on a vessel or pipe fitting through which fluid is discharged from the side of the equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1524">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1525"/>
