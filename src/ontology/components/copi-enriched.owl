    <rdfs:label xml:lang="en">reference signal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DeformableMaterial">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">deformable material</rdfs:label>
    <rdfs:label xml:lang="pt-br">material deformável</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Absorber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um absorvedor é um vaso de pressão que realiza uma função de absorção para transferência seletiva de massa de componentes de uma mistura fluida para uma fase absorvente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">absorvedor</rdfs:label>
    <rdfs:label xml:lang="en">absorber</rdfs:label>
    <skos:definition xml:lang="en">[OnePetro] A vertical, cylindrical vessel that recovers heavier (longer carbon chain) hydrocarbons from a mixture of lighter hydrocarbons.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ABSORBER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;ABSORBING&gt;</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A functional object that absorbs.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every absorber is a separator that has the function to absorb specific components from fluid mixtures through mass transfer to an absorbent phase</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Absorber(x) ↔ (Separator(x) ∧ ∃f(AbsorptionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b14"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b96">
    <rdf:rest rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b97"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2126">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasInput"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPortion"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PNEUMATIC MOTOR&gt; is an &lt;AIR MOTOR&gt; that is driven by compressed gas (typically air)</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2516"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor pneumático é um motor que converte energia de gás comprimido em energia mecânica rotacional.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">motor pneumático</rdfs:label>
    <rdfs:label xml:lang="en">pneumatic motor</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PneumaticMotor(x) ↔ Motor(x) ∧ ∃f(PneumaticMotorFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic motor is a motor that bears a PneumaticMotorFunction.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContainmentProcess">
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3371"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3417"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3393"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3392"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3416"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3370"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de contenção</rdfs:label>
    <rdfs:label xml:lang="en">containment process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b717">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Tower"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2522">
    <rdf:first rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2517"/>
    <rdf:rest rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2523"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238">
    <skos:definition xml:lang="en">[CFIHOS] Connecting with a coupling or coupler.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] An electrical or mechanical device that joins parts of systems and can affect the interaction of, or energy transfer between, parts of systems.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] Connecting with a coupling or coupler</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] &lt;COUPLING&gt; is the &lt;Activity&gt; of connecting with a coupling or coupler</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] The connection point of jointed pipe. It may be a steel shell with female threads to which the pins are connected or a formed female connection (box) on the end of tubing.</skos:definition>
    <rdfs:label xml:lang="en">coupling</rdfs:label>
    <rdfs:label xml:lang="pt-br">acoplamento</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Coupling(x) ↔ MaterialArtifact(x) ∧ ∃f(ConnectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b747"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um acoplamento é um artefato material que possui uma função de conexão para unir partes ou sistemas separados.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coupling is a material artifact that has the function to connect separate parts or systems together.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2016">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasInput"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPortion"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1578">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingFunction">
    <rdfs:label xml:lang="pt-br">função de lançamento e recebimento de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig launching and receiving function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2373"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2374"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2204">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Chamber"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294">
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1826"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma HeatTransferFunction e</rdfs:label>
    <rdfs:label xml:lang="en">heat transfer plate</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEAT TRANSFER PLATE&gt; is a &lt;PLATE&gt; that is intended to be used in a non tubular heat exchanger to segregate the two media</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat transfer plate is a MaterialArtifact that bears a HeatTransferFunction and participates in segregating two fluid media in a non-tubular heat exchanger.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HeatTransferPlate(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MediaSeparationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma HeatTransferFunction e que é destinado a ser usado em um trocador de calor não tubular para segregar dois meios fluidos enquanto facilita a transferência de energia térmica entre eles.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis requires necessary conditions only. Under OWA, sufficient conditions for 'plate geometry used in non-tubular heat exchangers' could lead to false positives - other components with plate-like surfaces might be incorrectly classified as heat transfer plates without domain expert validation of the structural and application-specific criteria.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">bearing</rdfs:label>
    <rdfs:label xml:lang="pt-br">mancal</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um mancal é um artefato material que é projetado para suportar e localizar elementos mecânicos móveis ou estáticos enquanto reduz o atrito na conexão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to support and locate a moving or static element and capable of reducing friction and transfer forces in a connection.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BEARING&gt; is a &lt;SUPPORT&gt; intended to support and locate a moving or static element</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Bearing(x) ↔ MaterialArtifact(x) ∧ ∃f(SupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(FrictionReductionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b211"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bearing is a material artifact that bears a support function and participates in friction reduction processes</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000345">
    <rdfs:label xml:lang="en">scrubber</rdfs:label>
    <rdfs:label xml:lang="pt-br">lavador de gases</rdfs:label>
    <skos:definition xml:lang="en">[SLB Glossary] A device to remove dirt, water, foreign matter, or undesired liquids that are part of the gas flowstream.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SCRUBBER&gt; is an &lt;ARTEFACT&gt; and a &lt;SEPARATOR&gt; intended to clean gas by washing the gas flow with water or with another liquid entering at the top of the vessel and sprayed in the gas. Typically to remove dust and small particles</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A distillation column intended to clean gas by washing the gas flow with water or with another liquid entering at the top of the vessel and sprayed in the gas. Typically to remove dust and small particles.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A distillation column intended to clean gas by washing the gas flow with water or with another liquid entering at the top of the vessel and sprayed in the gas. Typically to remove dust and small particles.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A reactor that removes various components from produced gas.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lavador de gases é um separador que limpa gás através da lavagem do fluxo gasoso com líquido para remover contaminantes como poeira, partículas ou substâncias indesejadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2855"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every scrubber is a separator that has the function of separation and participates in liquid washing processes with both gas and liquid inputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Scrubber(x) ↔ Separator(x) ∧ ∃f,p,g,l (SeparationFunction(f) ∧ bearerOf(x,f) ∧ LiquidWashingProcess(p) ∧ participatesIn(x,p) ∧ GasPortion(g) ∧ LiquidPortion(l) ∧ hasInput(x,g) ∧ hasInput(x,l)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyStorageMechanism">
    <rdfs:label xml:lang="en">energy storage mechanism</rdfs:label>
    <rdfs:label xml:lang="pt-br">mecanismo de energia de armazenamento</rdfs:label>
