    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b412">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MasterValve"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HighPressureSignal">
    <rdfs:label xml:lang="en">high pressure signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal alto de pressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An information content entity constituting an electrical or pneumatic signal representing a high-pressure condition in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b459">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b388">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GravitySeparationFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1400"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1401"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
    <rdfs:label xml:lang="pt-br">função de separação gravitacional</rdfs:label>
    <rdfs:label xml:lang="en">gravity separation function</rdfs:label>
    <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the separation of phases of differing densities by the action of gravity in a settling vessel.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b502">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2135">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2133"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000308">
    <skos:definition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</skos:definition>
    <rdfs:label xml:lang="pt-br">vaso separador de condensado</rdfs:label>
    <rdfs:label xml:lang="en">knock out drum</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso separador de condensado é um separador projetado para separar quantidades relativamente pequenas de líquido de uma corrente de vapor através de separação de fases gravitacional e baseada em momento.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1617"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every knock out drum is a separator that bears a knock out separation function, which is realized in processes that separate small quantities of liquid from vapor streams.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(KnockOutDrum(x) ↔ Separator(x) ∧ ∃f(KnockOutSeparationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementAndTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature measurement and transmission process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which process temperature is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b538">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a pipeline pig is introduced into a pipeline under operating pressure to perform internal cleaning, inspection, or product separation.</skos:definition>
    <rdfs:label xml:lang="en">pig launching process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de lançamento de pig</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000309">
    <rdfs:label xml:lang="en">level switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">interruptor de nível</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A level switch is an instrument that bears a LevelSwitchingFunction, combining level detection with switching capability to provide discrete on/off electrical signals when fluid or particulate material levels reach preset values.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level switch is an instrument that has the function of level switching and outputs discrete electrical signals based on preset level conditions.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de nível é um instrumento que possui uma Função de Comutação de Nível, combinando detecção de nível com capacidade de comutação para fornecer sinais elétricos discretos ligado/desligado quando níveis de fluidos ou materiais particulados atingem valores predefinidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level switch is an instrument that bears a LevelSwitchingFunction, combining level detection with switching capability to provide discrete on/off electrical signals when fluid or particulate material levels reach preset values.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(LevelSwitch(x) ↔ (Instrument(x) ∧ ∃f(LevelSwitchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(DiscreteElectricalSignal(s) ∧ hasOutput(x,s))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1681"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1693">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1691"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2356">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
  </rdf:Description>
