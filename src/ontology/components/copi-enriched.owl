    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1850"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2561">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2607">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignalTransmissionProcess">
    <rdfs:label xml:lang="pt-br">processo de transmissão de sinal de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure signal transmission process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A signal transmission process in which a standardised signal representing a measured pressure value is transmitted to a remote control or monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1426">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1424"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138">
    <skos:definition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under Open World Assumption, any artifact with a piston closure could potentially be classified as piston check valve, but specialized hybrid valves or custom manifolds containing piston mechanisms should not be automatically asserted into this standard maintenance category without domain expert validation.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção tipo pistão é uma válvula de retenção que possui um elemento de fechamento tipo pistão que se move linearmente ao longo do eixo de fluxo sob ação da gravidade ou mola para prevenir refluxo.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1967"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PistonCheckValve(x) → CheckValve(x) ∧ ∃y(PistonClosure(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every piston check valve is a check valve that has a piston closure as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">válvula de retenção tipo pistão</rdfs:label>
    <rdfs:label xml:lang="en">piston check valve</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321">
    <rdfs:label xml:lang="en">pipe</rdfs:label>
    <rdfs:label xml:lang="pt-br">tubo</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tubo é um artefato material caracterizado por geometria tubular e extensão longitudinal, projetado para conduzir materiais líquidos, gasosos ou sólidos finamente divididos de um local para outro, ou para servir a propósitos estruturais.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Pipe(x) → MaterialArtifact(x) ∧ ∃f(FluidConductionFunction(f) ∧ hasFunction(x,f)) ∧ ∃g(TubularGeometry(g) ∧ hasPhysicalProperty(x,g)) ∧ ∃h(LongitudinalExtent(h) ∧ hasPhysicalProperty(x,h)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe is a material artifact that has fluid conduction function and has tubular geometry and has longitudinal extent.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1907"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because pipe is defined by constructive/geometric properties (tubular geometry, longitudinal extent) rather than purely functional criteria. Under Open World Assumption, asserting sufficient conditions based on geometric properties could lead to unintended classification of complex tubular structures that happen to conduct fluids but should not be categorized as standard pipes.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2558">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by geometric configuration. Under OWA, sufficient conditions for non-inline port arrangement could lead to false positives where complex multi-port manifolds or specialized valves with angular components get incorrectly classified as standard angle valves.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">angle valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula angular</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula angular é uma válvula que tem portas da válvula que não estão alinhadas, mas dispostas em ângulo uma em relação à outra.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b84"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AngleValve(x) → Valve(x) ∧ ∃p (hasPart(x,p) ∧ NonInlinePortArrangement(p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every angle valve is a valve that has a non-inline port arrangement.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig launcher is a vessel that has the function to launch pipeline pigs and has a pipeline connection component.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1861"/>
    <skos:definition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lançador de pig é um vaso que possui função de lançamento de pig para inserir pigs de duto em sistemas de tubulação.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">lançador de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig launcher</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PigLauncher(x) ↔ (Vessel(x) ∧ ∃f(PigLaunchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(PipelineConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000302">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for the rotating vane assembly could lead to false positives where other rotating equipment with vanes (like turbine rotors or fan assemblies) might be incorrectly classified as impellers when they should remain in their specific equipment categories.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Impeller(x) → Assembly(x) ∧ ∃v,h(RotatingVanes(v) ∧ Hub(h) ∧ hasComponentPartAtAllTimes(x,v) ∧ hasComponentPartAtAllTimes(x,h) ∧ ∃m(RotationalMotion(m) ∧ participatesIn(x,m)) ∧ ∃f(EnergyTransferFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An impeller is an assembly consisting of rotating vanes mounted on a hub that transfers energy to or from fluids through dynamic rotational force within an enclosure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um impulsor é um conjunto que consiste em pás rotativas montadas em um cubo que transfere energia para ou de fluidos através de força rotacional dinâmica dentro de um invólucro.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every impeller is an assembly that has rotating vanes and a hub as component parts at all times, participates in rotational motion, and bears an energy transfer function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">impulsor</rdfs:label>
    <rdfs:label xml:lang="en">impeller</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1536"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1537"/>
    <skos:definition xml:lang="en">An impeller is an assembly consisting of rotating vanes mounted on a hub that transfers energy to or from fluids through dynamic rotational force within an enclosure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GaseousPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">porção gasoso</rdfs:label>
    <rdfs:label xml:lang="en">gaseous portion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas phase material at a defined point in a petroleum production process.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000253">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um difusor é um conjunto que tem a função projetada de converter energia cinética do fluxo de fluido em energia de pressão através de desaceleração controlada em uma passagem divergente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diffuser is an assembly that bears an energy diffusion function and has a diverging channel as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">difusor</rdfs:label>
    <rdfs:label xml:lang="en">diffuser</rdfs:label>
    <skos:definition xml:lang="en">A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Diffuser(x) ↔ Assembly(x) ∧ ∃f(EnergyDiffusionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b814"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase">
    <skos:definition xml:lang="en">A material artifact that constitutes the base structure that provides continuous support for equipment or pipework in a petroleum production installation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">base contínuo</rdfs:label>
    <rdfs:label xml:lang="en">continuous base</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which the absolute or gauge pressure of a process stream is measured and expressed as a quantitative value.</skos:definition>
    <rdfs:label xml:lang="en">pressure measurement process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição de pressão</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which useful work or heat is recovered from a process stream, pressure differential, or thermal source in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de extração de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy extraction process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000247">
    <skos:definition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DewPointAnalyser(x) ↔ Instrument(x) ∧ ∃f(DewPointMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dew point analyser is an instrument that bears a dew point measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de ponto de orvalho é um instrumento que possui uma função de medição de ponto de orvalho.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">dew point analyser</rdfs:label>
    <rdfs:label xml:lang="pt-br">analisador de ponto de orvalho</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b707"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dew point analyser is an instrument that has the function to determine the dew point of a substance</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220">
    <rdfs:label xml:lang="pt-br">queimador</rdfs:label>
    <rdfs:label xml:lang="en">burner</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every burner is a heater that has the function of combustion, which is realized by burning a fuel-air mixture to release thermal energy.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um queimador é um aquecedor que libera energia térmica através da queima de uma mistura combustível de combustível e ar.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Burner(x) ↔ (Heater(x) ∧ ∃f (CombustionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b271"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b659">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143">
    <rdfs:label xml:lang="en">pressure gauge</rdfs:label>
    <rdfs:label xml:lang="pt-br">manômetro</rdfs:label>
    <skos:definition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureGauge(x) ↔ (Instrument(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro é um indicador que possui a função de medir e exibir valores de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2085"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure gauge is an instrument that has the function to measure and display pressure</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de difusão de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy diffusion function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the dispersion of thermal, acoustic, or kinetic energy over a larger volume or surface to reduce its local intensity.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b810"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b811"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2330">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShakingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2547">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentInterruptionProcess">
    <rdfs:label xml:lang="en">electrical current interruption process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de interrupção de corrente elétrica</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which an electrical circuit is opened to stop the flow of current, either under normal operating conditions or in response to a fault.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transformador de potência é um transformador que possui uma função de transformação de energia elétrica, realizada por indução eletromagnética para transformar sistemas de tensão e corrente alternadas para diferentes níveis na mesma frequência para fins de transmissão de energia.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">power transformer</rdfs:label>
    <rdfs:label xml:lang="pt-br">transformador de potência</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformer(x) ↔ (Transformer(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃r(ElectricalPowerTransmissionRole(r) ∧ bearerOf(x,r))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2053"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every power transformer is a transformer that has the function of transforming electrical power through electromagnetic induction, taking alternating current at one voltage level as input and producing alternating current at different voltage level(s) as output for power transmission.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1708">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251">
    <skos:definition xml:lang="en">A pressure element that bears a differential pressure measurement function and that consists in sensing the pressure difference between two fluid media or connection points to enable measurement of differential pressure through mechanical deflection proportional to the pressure difference.</skos:definition>
    <rdfs:label xml:lang="pt-br">elemento medidor de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure measuring element</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DifferentialPressureMeasuringElement equivalentTo PressureElement and bearerOf some DifferentialPressureMeasurementFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure element that bears a differential pressure measurement function and that consists in sensing the pressure difference between two fluid media or connection points to enable measurement of differential pressure through mechanical deflection proportional to the pressure difference.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão que porta uma função de medição de pressão diferencial e que consiste em detectar a diferença de pressão entre duas mídias fluidas ou pontos de conexão para permitir a medição de pressão diferencial através de deflexão mecânica proporcional à diferença de pressão.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DifferentialPressureMeasuringElement(x) ↔ (PressureElement(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b783"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000332">
    <rdfs:label xml:lang="pt-br">enrolamento de transformador</rdfs:label>
    <rdfs:label xml:lang="en">power transformer primary winding</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2058"/>
    <skos:definition xml:lang="en">A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural position within power transformer. Under OWA, sufficient conditions for primary winding configuration would risk false positives for specialized or hybrid transformer components that contain primary-like windings but should not be classified as standard power transformer primary windings.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerPrimaryWinding is-a TransformerWinding that is-part-of PowerTransformer and has-function PrimaryWindingFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um enrolamento de transformador que é parte de um transformador de potência e que serve como enrolamento primário recebendo energia elétrica de entrada para transformação eletromagnética.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerPrimaryWinding(x) → TransformerWinding(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(PrimaryWindingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ScrapingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which deposits, scale, or coatings are mechanically removed from the interior surface of a pipeline or vessel.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">scraping process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de raspagem</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b758"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b971"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1789"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b759"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1499"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1288"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1788"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b970"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1498"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1289"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of thermal, chemical, or electrical energy into mechanical energy in the form of rotational or linear motion.</skos:definition>
    <rdfs:label xml:lang="en">mechanical energy generation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de geração de energia mecânica</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1795">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1793"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000341">
    <skos:definition xml:lang="en">A rotary pump is a positive displacement pump that contains a chamber with gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing, and which has no separate inlet and outlet valves.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">rotary pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba rotativa</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the rotary mechanism is clearly necessary for rotary pumps, making it sufficient under OWA could lead to false positives where complex equipment containing rotary elements (like gearboxes with pumping side-effects or hybrid machines) might be misclassified as standard rotary pumps. The constructive differentia should be validated by domain experts before upgrading to equivalence.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (RotaryPump(x) → PositiveDisplacementPump(x) ∧ ∃y (RotaryDisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ¬∃z (SeparateInletValve(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ¬∃w (SeparateOutletValve(w) ∧ hasComponentPartAtAllTimes(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba rotativa é uma bomba de deslocamento positivo que contém uma câmara com engrenagens, cames, parafusos, palhetas, êmbolos ou elementos similares acionados pela rotação relativa do eixo de acionamento ou carcaça, e que não possui válvulas separadas de entrada e saída.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A rotary pump is a positive displacement pump that contains a chamber with gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing, and which has no separate inlet and outlet valves.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2223"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2224"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2225"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every rotary pump is a positive displacement pump that has a rotary displacement mechanism as component part and lacks separate inlet and outlet valves.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000137">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every phase sequence meter is an electric measuring instrument that has the function to measure phase sequence and has as input polyphase electrical signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">medidor de sequência de fases</rdfs:label>
    <rdfs:label xml:lang="en">phase sequence meter</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de sequência de fases é um instrumento de medição elétrica que possui uma função de medição de sequência de fases para determinar e indicar a sequência na qual as tensões instantâneas dos condutores de fase atingem seu valor máximo em um sistema elétrico polifásico.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1848"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PhaseSequenceMeter(x) ↔ ElectricMeasuringInstrument(x) ∧ ∃f(PhaseSequenceMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PolyphaseElectricalSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction">
    <rdfs:label xml:lang="pt-br">função de mistura</rdfs:label>
    <rdfs:label xml:lang="en">mixing function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1771"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1772"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the combination and blending of two or more fluid streams or components to achieve a homogeneous mixture.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1298">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264">
    <skos:definition xml:lang="en">An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b976"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor é um motor que converte energia de combustível químico em força mecânica e movimento através de processos de combustão.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Engine is a Motor that has function MechanicalEnergyGenerationFunction and has input ChemicalFuelPortion and participates in CombustionProcess.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Engine(x) ↔ Motor(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ChemicalFuelPortion(p) ∧ hasInput(x,p)) ∧ ∃c(CombustionProcess(c) ∧ participatesIn(x,c)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">engine</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000290">
    <rdfs:label xml:lang="en">gear wheel</rdfs:label>
    <rdfs:label xml:lang="pt-br">roda dentada</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears a PowerTransmissionFunction and that has circumferential teeth for positive mechanical engagement with mating gears or racks to transmit rotational motion and power.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma PowerTransmissionFunction e que possui dentes circunferenciais para engajamento mecânico positivo com engrenagens ou cremalheiras correspondentes para transmitir movimento rotacional e potência.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1363"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive differentia based on physical structure (toothed geometry). Under OWA, asserting equivalence could force classification of complex hybrid mechanisms or specialized toothed components that should not be categorized as standard gear wheels for maintenance purposes.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An Assembly that bears a PowerTransmissionFunction and that has circumferential teeth for positive mechanical engagement with mating gears or racks to transmit rotational motion and power.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GearWheel(x) → Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃t(Tooth(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃w(WheelBody(w) ∧ hasComponentPartAtAllTimes(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">GearWheel SubClassOf Assembly and (bearerOf some PowerTransmissionFunction) and (hasComponentPartAtAllTimes some Tooth) and (hasComponentPartAtAllTimes some WheelBody)</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b257">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess">
    <rdfs:label xml:lang="en">backflow prevention process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de prevenção de refluxo</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b563">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1442">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1444"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b863">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b865"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelInformation">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <skos:definition xml:lang="en">An information content entity constituting a measurement or display value representing the fluid level in a vessel of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">level information</rdfs:label>
    <rdfs:label xml:lang="pt-br">informação de nível</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b947"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2468"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2469"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b946"/>
    <rdfs:label xml:lang="pt-br">função de condução elétrica</rdfs:label>
    <rdfs:label xml:lang="en">electrical conduction function</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission.</skos:definition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000221">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bandeja de cabos é um conjunto que possui função de suporte de cabos e consiste em uma base contínua com bordas elevadas, formando um sistema estrutural rígido para suportar e rotear cabos elétricos de forma segura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cable tray is an assembly that bears a cable support function and consists of a continuous base with raised edges, forming a rigid structural system for securely supporting and routing electrical cables.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A cable tray is an assembly that bears a cable support function and consists of a continuous base with raised edges, forming a rigid structural system for securely supporting and routing electrical cables.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b308"/>
    <rdfs:label xml:lang="en">cable tray</rdfs:label>
    <rdfs:label xml:lang="pt-br">bandeja de cabos</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CableTray(x) ↔ Assembly(x) ∧ ∃f(CableSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ContinuousBase(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃e(RaisedEdge(e) ∧ hasComponentPartAtAllTimes(x,e)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cable tray is an assembly that has the function to support cables and has a continuous base part and raised edge parts.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2775">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceResourceInteractionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1457"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1922"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1159"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1933"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1939"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1904"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2209"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1923"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1918"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1458"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1938"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1903"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1158"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1917"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2208"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1934"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">fluid conduction function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de condução de fluido</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conveyance of a fluid from one location to another while maintaining containment and flow direction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070">
    <rdfs:label xml:lang="en">temperature sensing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de sensoriamento de temperatura</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2494"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2493"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the detection and measurement of the temperature of a process stream or equipment surface.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FinnedTube">
    <rdfs:label xml:lang="pt-br">tubo de aletado</rdfs:label>
    <rdfs:label xml:lang="en">finned tube</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a heat transfer tube with extended surfaces—fins—that increase the external surface area to enhance heat exchange with a gas stream.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1753">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1760">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1761"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1754">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1793">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2325">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000279">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowSwitch(x) ↔ Instrument(x) ∧ ∃f(FlowSwitchingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow switch is an instrument that has the function to switch electrical circuits based on flow rate detection at preset thresholds.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A flow switch is an instrument that bears a flow switching function to automatically open or close electrical circuits when fluid flow rate reaches predetermined threshold values.</skos:definition>
    <rdfs:label xml:lang="en">flow switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">interruptor de fluxo</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1218"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow switch is an instrument that bears a flow switching function to automatically open or close electrical circuits when fluid flow rate reaches predetermined threshold values.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de fluxo é um instrumento que possui uma função de comutação de fluxo para automaticamente abrir ou fechar circuitos elétricos quando a taxa de fluxo de fluido atinge valores de limiar predeterminados.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction">
    <rdfs:label xml:lang="en">injection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de injeção</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1575"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1574"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1583"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1582"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the introduction of a fluid, chemical, or material into a process stream, vessel, or wellbore under controlled conditions.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000363">
    <iof-av:naturalLanguageDefinition xml:lang="en">A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro de transmissor é uma Assembly que possui uma EnclosureFunction e que tem um circuito eletrônico de transmissor como parte componente em todos os momentos, projetado para fornecer proteção ambiental e contenção física para componentes do transmissor.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">transmitter housing</rdfs:label>
    <rdfs:label xml:lang="pt-br">invólucro de transmissor</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TransmitterHousing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(TransmitterElectronicCircuit(c) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical structure as housing. Under OWA, sufficient conditions for transmitter housing would require specifying exact structural features (materials, dimensions, sealing mechanisms) that distinguish it from other instrument housings. The necessary conditions establish the core identity without risking false positives from other housing types that might share some structural features.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2610"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">TransmitterHousing ⊑ Assembly ⊓ ∃bearerOf.EnclosureFunction ⊓ ∃hasComponentPartAtAllTimes.TransmitterElectronicCircuit</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1213"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1214"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">flow switching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de chaveamento de fluxo</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the flow rate of a process stream crosses a defined threshold.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpInlet">
    <rdfs:label xml:lang="pt-br">entrada hidráulico de bomba</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic pump inlet</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the suction inlet port through which fluid is drawn into a hydraulic pump in petroleum production hydraulic systems.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2576">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TransductionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b758">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportFunction">
    <rdfs:label xml:lang="pt-br">função de suporte de equipamento</rdfs:label>
    <rdfs:label xml:lang="en">equipment support function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical support of process equipment to maintain its position and transmit loads to a structural foundation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2390"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2391"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyFunction">
    <rdfs:label xml:lang="pt-br">função de fornecimento ininterrupto de energia</rdfs:label>
    <rdfs:label xml:lang="en">uninterrupted power supply function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2668"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2669"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the provision of continuous electrical power to critical loads during interruptions to the main power supply.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000345">
    <rdfs:label xml:lang="en">scrubber</rdfs:label>
    <rdfs:label xml:lang="pt-br">lavador de gases</rdfs:label>
    <skos:definition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Scrubber(x) ↔ Separator(x) ∧ ∃f,p,g,l (SeparationFunction(f) ∧ bearerOf(x,f) ∧ LiquidWashingProcess(p) ∧ participatesIn(x,p) ∧ GasPortion(g) ∧ LiquidPortion(l) ∧ hasInput(x,g) ∧ hasInput(x,l)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lavador de gases é um separador que limpa gás através da lavagem do fluxo gasoso com líquido para remover contaminantes como poeira, partículas ou substâncias indesejadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2291"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every scrubber is a separator that has the function of separation and participates in liquid washing processes with both gas and liquid inputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2441">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b845">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivertingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the collection and temporary holding of fluid to buffer flow variations or build up inventory.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b18"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b19"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de acumulação</rdfs:label>
    <rdfs:label xml:lang="en">accumulation function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1686">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1005">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnection(x) ↔ (MaterialArtifact(x) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ElectricalConductionProcess(p) ∧ participatesIn(x,p) ∧ ∃y(ElectricalApparatus(y) ∧ has_participant_at_some_time(p,y)))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma conexão elétrica é um MaterialArtifact que possui uma ElectricalConductionFunction e que fornece um caminho para a corrente elétrica passar de um aparelho elétrico para outro.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electrical connection is a material artifact that bears an electrical conduction function and participates in processes involving electrical apparatus.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b950"/>
    <rdfs:label xml:lang="en">electrical connection</rdfs:label>
    <rdfs:label xml:lang="pt-br">conexão elétrica</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1244"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">flowline</rdfs:label>
    <rdfs:label xml:lang="pt-br">linha de fluxo</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma linha de fluxo é um duto que transporta óleo, gás ou água diretamente de uma cabeça de poço para um manifold ou instalação de produção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flowline is a pipeline that bears a fluid transport function, has a wellhead connection, has a manifold or production facility connection, and transports hydrocarbon fluids.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flowline(x) ↔ Pipeline(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ connectsDirectly(x,w)) ∧ ∃m((Manifold(m) ∨ ProductionFacility(m)) ∧ connectsDirectly(x,m)) ∧ ∃h(HydrocarbonFluid(h) ∧ hasInput(x,h)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1591">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasMixturePortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">gas mixture portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção de gás de mistura</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of a mixture of two or more gases at a defined point in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2584">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1771">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b433">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b435"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess">
    <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the fluid level in a vessel crosses a defined high or low threshold.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">level switching process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de chaveamento de nível</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b616">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CuttingsAndFluid">
    <rdfs:label xml:lang="pt-br">fluido de cascalhos de e</rdfs:label>
    <rdfs:label xml:lang="en">cuttings and fluid</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a mixture of rock cuttings and drilling fluid circulated from the wellbore bottom to the surface during drilling operations.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b509">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b510"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000120">
    <skos:definition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</skos:definition>
    <rdfs:label xml:lang="en">gate valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula gaveta</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1336"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1337"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate valve is a valve that has a gate closure component and a linear actuation mechanism.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula gaveta é uma válvula que possui um membro de fechamento tipo gaveta ou disco com movimento linear paralelo ao plano dos assentos planos, que são transversais à direção do fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GateValve(x) → (Valve(x) ∧ ∃g(GateClosure(g) ∧ hasComponentPartAtAllTimes(x,g)) ∧ ∃m(LinearActuationMechanism(m) ∧ hasComponentPartAtAllTimes(x,m))))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for structural features like 'linear sliding gate' risks false positives from complex hybrid equipment or custom manifolds that contain gate mechanisms but should not be classified as standard gate valves. Necessary conditions provide safer classification that can be validated by domain experts.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b265">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CombustionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1824">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess">
    <skos:definition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">electrical power transformation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transformação de energia elétrica</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000373">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VesselHead(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃r(VesselClosureRole(r) ∧ realizes(x,r)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">vessel head</rdfs:label>
    <rdfs:label xml:lang="pt-br">tampo de vaso</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, asserting sufficient conditions for vessel head closure would inappropriately classify any part that closes a vessel (including specialized manifolds, complex multi-port heads, or custom closures) as standard vessel heads, potentially creating false positives in maintenance categorization.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel head is a fiat object part that is part of some vessel and realizes a vessel closure role.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FiatObjectPart that is part of a vessel and that closes a vessel shell by providing an end boundary for containment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma FiatObjectPart que é parte de um vaso e que fecha o casco do vaso fornecendo uma fronteira terminal para contenção.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2742"/>
    <skos:definition xml:lang="en">A FiatObjectPart that is part of a vessel and that closes a vessel shell by providing an end boundary for containment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1676">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b304">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableSupportProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2469">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2813">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2816"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2511"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b73"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b72"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2510"/>
    <rdfs:label xml:lang="en">temperature indication function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de indicação de temperatura</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the temperature of a process stream or equipment surface.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b703">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level indicator is an indicator that has the function to measure and locally indicate level.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LevelIndicator(x) ↔ (Indicator(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">level indicator</rdfs:label>
    <rdfs:label xml:lang="pt-br">indicador de nível</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador de nível é um indicador que mede e exibe localmente o nível de material líquido ou sólido a granel em um vaso ou tanque.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1649"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1306">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbineSection"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b314">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b315"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b310"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b608">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b609"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de fornecimento ininterrupto de energia</rdfs:label>
    <rdfs:label xml:lang="en">uninterrupted power supply process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which continuous electrical power is provided to critical loads during interruptions to the main power supply.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompositionAnalysisData">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdfs:label xml:lang="en">composition analysis data</rdfs:label>
    <rdfs:label xml:lang="pt-br">dados de composição de análise</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting data representing the chemical composition of a process fluid as determined by analytical instrumentation in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b107">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b104"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b108"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b850">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DivertingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalObject">
    <rdfs:label xml:lang="pt-br">objeto físico</rdfs:label>
    <rdfs:label xml:lang="en">physical object</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a discrete physical entity within a petroleum production system that occupies space and has defined material properties.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SuppressedDisturbance">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">perturbação suprimido</rdfs:label>
    <rdfs:label xml:lang="en">suppressed disturbance</rdfs:label>
    <skos:definition xml:lang="en">A process in which an unwanted physical perturbation—vibration, noise, or pressure surge—that has been attenuated or eliminated by petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114">
    <skos:definition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (EmergencyShutDownValve(x) ↔ (Valve(x) ∧ ∃f(EmergencyShutDownFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b966"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every emergency shut down valve is a valve that has an emergency shut down function and has an actuator and has a fail-safe system.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">emergency shut down valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de parada de emergência</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de parada de emergência é uma válvula que possui uma função de parada de emergência, permitindo o isolamento rápido de fluxo em situações de emergência através de mecanismos atuados com capacidade à prova de falhas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b946">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2409">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MassFlowRateSignal">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the mass flow rate of a process stream as measured by petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">sinal de massa de fluxo de taxa</rdfs:label>
    <rdfs:label xml:lang="en">mass flow rate signal</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1420">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DryAirPortion">
    <rdfs:label xml:lang="en">dry air portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção seco de ar</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of air from which water vapour has been removed to a specified dew point.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000306">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1594"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de entrada é um eixo que serve como ponto de entrada para energia mecânica de uma fonte de energia externa em um sistema de transmissão de potência.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">eixo de entrada</rdfs:label>
    <rdfs:label xml:lang="en">input shaft</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(InputShaft(x) → Shaft(x) ∧ ∃p(MechanicalEnergyReceptionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(ExternalEnergySource(s) ∧ connectedTo(x,s)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">An InputShaft is a Shaft that participates in mechanical energy reception and is connected to an external energy source.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration as energy entrance point. Under OWA, defining sufficient conditions could lead to false positives where any shaft receiving external energy input would be classified as a standard input shaft, even specialized or hybrid configurations that should remain in different maintenance categories.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector é um instrumento que possui uma função de detecção, permitindo-lhe detectar estados, substâncias ou fenômenos e produzir sinais baseados na detecção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">detector</rdfs:label>
    <rdfs:label xml:lang="pt-br">detector</rdfs:label>
    <skos:definition xml:lang="en">A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b694"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every detector is an instrument that has a detection function and has component parts including a sensing element and signal generation device.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Detector(x) ↔ Instrument(x) ∧ ∃f(DetectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1579">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2522">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2524"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1485">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b990">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b988"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b351"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under Open World Assumption, any equipment with centrifugal impellers and volute casing could be inferred as a standard centrifugal pump, potentially misclassifying specialized hybrid equipment or complex pump systems that contain centrifugal stages but serve different operational roles.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalPump(x) → Pump(x) ∧ ∃y(CentrifugalImpeller(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(VoluteCasing(z) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">bomba centrífuga</rdfs:label>
    <rdfs:label xml:lang="en">centrifugal pump</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba centrífuga é uma bomba que usa força centrífuga gerada por impulsores rotativos com pás para aumentar a pressão do fluido através de uma carcaça voluta.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal pump is a pump that has a centrifugal impeller as component part at all times and has a volute casing as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b411">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1918">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b810">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1399">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferFunction">
    <rdfs:label xml:lang="pt-br">função de transferência de energia rotacional</rdfs:label>
    <rdfs:label xml:lang="en">rotational energy transfer function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2229"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2230"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a RotationalEnergyTransferProcess and that consists in the capacity to transfer mechanical energy through rotational motion within a machine assembly.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a RotationalEnergyTransferProcess and that consists in the capacity to transfer mechanical energy through rotational motion within a machine assembly.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2316">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1088">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1086"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148">
    <rdfs:label xml:lang="en">safety valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de segurança</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança é uma válvula que possui uma função de ventilação de segurança para alívio automático de pressão por abertura rápida e total para proteção contra condições perigosas de sobrepressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety valve is a valve that has the function to automatically relieve excess pressure for emergency protection</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2263"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SafetyValve(x) ↔ Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every turbine is an assembly that bears an energy extraction function and has component parts including a rotating shaft, fluid interaction blades, casing, and bearing system.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">turbina</rdfs:label>
    <rdfs:label xml:lang="en">turbine</rdfs:label>
    <skos:definition xml:lang="en">A turbine is an assembly that bears an energy extraction function and has rotating shaft and fluid-interacting blades that extract energy from flowing fluids and convert it into useful mechanical work.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma turbina é um conjunto que possui uma função de extração de energia e tem eixo rotativo e pás de interação com fluidos que extraem energia de fluidos em movimento e a convertem em trabalho mecânico útil.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A turbine is an assembly that bears an energy extraction function and has rotating shaft and fluid-interacting blades that extract energy from flowing fluids and convert it into useful mechanical work.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2643"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Turbine(x) ↔ Assembly(x) ∧ ∃f(EnergyExtractionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(RotatingShaft(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃b(FluidInteractionBlades(b) ∧ hasComponentPartAtAllTimes(x,b)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess">
    <rdfs:label xml:lang="en">degassing process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de degaseificação</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which dissolved or entrained gases are removed from a liquid to reduce their concentration below a specified level.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature indicator is an instrument that has the function of temperature indication and has component parts including a temperature sensing element and a local display.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador de temperatura é um indicador que mede temperatura e exibe o valor medido localmente na localização do instrumento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</skos:definition>
    <rdfs:label xml:lang="en">temperature indicator</rdfs:label>
    <rdfs:label xml:lang="pt-br">indicador de temperatura</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2514"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (TemperatureIndicator(x) ↔ (Instrument(x) ∧ ∃f (TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃s (TemperatureSensingElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃d (LocalDisplay(d) ∧ hasComponentPartAtAllTimes(x,d))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2402"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <skos:definition xml:lang="en">A solenoid actuator is an electric actuator that utilizes a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by solenoid mechanism. Under OWA, sufficient conditions would force any device with solenoid and plunger components to be classified as a solenoid actuator, potentially misclassifying complex hybrid devices or specialized equipment containing solenoid components but serving different primary functions.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">solenoid actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador solenoide</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid actuator is an electric actuator that has a solenoid as component part and has a plunger as component part and converts electrical power to linear mechanical motion.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador solenoide é um atuador elétrico que utiliza um solenoide linear de serviço contínuo para converter energia elétrica em energia mecânica através de um êmbolo com curso axial em ação de empurrar ou puxar.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A solenoid actuator is an electric actuator that utilizes a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SolenoidActuator(x) → ElectricActuator(x) ∧ ∃s(Solenoid(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃p(Plunger(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalMovement">
    <rdfs:label xml:lang="pt-br">movimento mecânico</rdfs:label>
    <rdfs:label xml:lang="en">mechanical movement</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <skos:definition xml:lang="en">A process in which the translational or rotational displacement of a mechanical element relative to a reference frame in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2045">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1241"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1948"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1240"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1947"/>
    <rdfs:label xml:lang="pt-br">função de transporte de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid transport function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conveyance of a fluid over distance by exploiting pressure differentials, gravity, or imparted energy.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000271">
    <skos:definition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</skos:definition>
    <rdfs:label xml:lang="en">flame arrestor</rdfs:label>
    <rdfs:label xml:lang="pt-br">arrestador de chama</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1074"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um arrestador de chama é um dispositivo de segurança que possui uma função de arrestar chama para prevenir que chamas entrem em um sistema através de uma abertura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame arrestor is a safety device that has the function of arresting flames and processes gaseous portions while preventing flame propagation.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlameArrestor(x) ↔ SafetyDevice(x) ∧ ∃f(FlameArrestFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1075">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1213">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b725">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000355">
    <skos:definition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2435"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2436"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma StationaryMachineComponentFunction e que é o componente estrutural estacionário dentro de máquinas rotativas, fornecendo alojamento e estabilidade posicional para elementos ativos como bobinas, palhetas ou vedações.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">stator</rdfs:label>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma StationaryMachineComponentFunction e</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Stator is a MaterialArtifact that bears a StationaryMachineComponentFunction and is part of some RotatingMachine</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Stator(x) → MaterialArtifact(x) ∧ ∃f(StationaryMachineComponentFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(RotatingMachine(m) ∧ partOf(x,m)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on structural positioning within rotating machinery. Under OWA, any artifact described as stationary within a rotating machine context could be classified as a stator, but this may include specialized hybrid components, mounting structures, or custom configurations that should not be automatically asserted into the standard stator maintenance category. The structural differentia (stationary positioning) is necessary but making it sufficient requires domain expert validation.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotatingVanes">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">rotating vanes</rdfs:label>
    <rdfs:label xml:lang="pt-br">palhetas rotativo</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an assembly of vanes attached to a rotating element that interacts with a fluid stream in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TransductionFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2576"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2575"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of one form of physical signal or energy into another form suitable for measurement or transmission.</skos:definition>
    <rdfs:label xml:lang="en">transduction function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transdução</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b488">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b489"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValve(x) ↔ Valve(x) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção é uma válvula que possui uma função de prevenção de refluxo, permitindo automaticamente que o fluido flua em apenas uma direção enquanto previne o fluxo reverso.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b371"/>
    <rdfs:label xml:lang="pt-br">válvula de retenção</rdfs:label>
    <rdfs:label xml:lang="en">check valve</rdfs:label>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every check valve is a valve that has the function to prevent backflow and automatically allow unidirectional fluid flow.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2519">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b621">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b623"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CleanedSurface">
    <rdfs:label xml:lang="pt-br">superfície limpo</rdfs:label>
    <rdfs:label xml:lang="en">cleaned surface</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a surface from which scale, deposits, or contaminants have been removed by a cleaning process in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess">
    <rdfs:label xml:lang="pt-br">processo de silenciamento de ruído</rdfs:label>
    <rdfs:label xml:lang="en">noise silencing process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which acoustic energy in a fluid stream or mechanical system is attenuated to reduce radiated noise to an acceptable level.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">porção de material</rdfs:label>
    <rdfs:label xml:lang="en">material portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a defined quantity of a material substance at a specified point in a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ValveStem(x) → Assembly(x) ∧ ∃f(ForceTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(ValveStemSeal(s) ∧ hasComponentPartAtAllTimes(x,s)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ValveStem SubClassOf Assembly and bearerOf some ForceTransmissionFunction and hasComponentPartAtAllTimes some ValveStemSeal</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma ForceTransmissionFunction e que tem um selo de haste de válvula como parte componente, especificamente projetado para transmitir movimento de um operador de válvula para o membro de fechamento da válvula.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">valve stem</rdfs:label>
    <rdfs:label xml:lang="pt-br">haste de válvula</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical structure (rod/shaft mechanism). Under Open World Assumption, sufficient conditions would force any assembly with a valve stem seal and force transmission function to be classified as a valve stem, which could include complex multi-component assemblies, manifolds, or specialized valve mechanisms that contain these elements but should not be asserted into the standard valve stem maintenance category.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2722"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000367">
    <iof-av:naturalLanguageDefinition xml:lang="en">An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um umbilical é uma montagem que é um feixe flexível e facilmente desconectável contendo cabos e tubulação para transmissão de múltiplos serviços incluindo controle, energia, comunicação e injeção química.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2661"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2660"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2659"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:label xml:lang="pt-br">umbilical</rdfs:label>
    <rdfs:label xml:lang="en">umbilical</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive basis requires necessary conditions only. Under OWA, any assembly with cables, tubing, flexibility, and disconnectability could be forcibly classified as umbilical, including specialized multi-service bundles, complex wiring harnesses, or custom transmission assemblies that contain these elements but serve different industrial contexts and maintenance categories.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every umbilical is an assembly that has component parts including cable bundles and tubing bundles, and has the qualities of flexibility and easy disconnectability.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Umbilical(x) → Assembly(x) ∧ ∃c,t,s,conn (CableBundle(c) ∧ TubingBundle(t) ∧ ProtectiveSheathing(s) ∧ ConnectorAssembly(conn) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,t) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,conn) ∧ hasQuality(x,Flexibility) ∧ hasQuality(x,EasyDisconnectability)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b319">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess">
    <rdfs:label xml:lang="en">heating process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de aquecimento</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which thermal energy is transferred to a process stream or vessel to raise its temperature.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2081">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1414">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every transmitter is an instrument that has the function of signal transmission and has a sensor element and signal conditioner and transmission module and receives process variable inputs and produces standardized signal outputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2599"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor é um instrumento que possui uma função de transmissão de sinal, recebendo sinais de variáveis de processo de sensores e convertendo-os em sinais de saída padronizados para transmissão a sistemas de controle.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Transmitter(x) ↔ Instrument(x) ∧ ∃f(SignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SensorElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(SignalConditioner(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃t(TransmissionModule(t) ∧ hasComponentPartAtAllTimes(x,t)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">transmissor</rdfs:label>
    <rdfs:label xml:lang="en">transmitter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1874">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">axial displacement measuring probe</rdfs:label>
    <rdfs:label xml:lang="pt-br">sonda axial de deslocamento de medição</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a proximity probe that measures the axial displacement of a rotating shaft in petroleum production rotating equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2474">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceTransmissionFunction">
    <rdfs:label xml:lang="en">force transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de força</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2718"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2719"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a ForceTransmissionProcess and that consists in transmitting mechanical force or motion from one component to another through direct physical coupling.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a ForceTransmissionProcess and that consists in transmitting mechanical force or motion from one component to another through direct physical coupling.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2174">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b935">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricToMechanicalConversionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlProcess">
    <skos:definition xml:lang="en">A planned process in which current in an electrical circuit is switched, routed, or regulated to control connected loads.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de controle de circuito elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electrical circuit control process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LocalPressureDisplay">
    <rdfs:label xml:lang="pt-br">display local de pressão</rdfs:label>
    <rdfs:label xml:lang="en">local pressure display</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting an instrument mounted locally to a pressure measurement point that visually displays the process pressure.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2264">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentFlow">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:label xml:lang="en">electrical current flow</rdfs:label>
    <rdfs:label xml:lang="pt-br">fluxo elétrico de corrente</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A process in which the directed movement of electric charge carriers through a conductor in petroleum production electrical systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b645">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b647"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SteelPipe">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a pipe made of steel used to convey fluids under pressure in petroleum production piping systems.</skos:definition>
    <rdfs:label xml:lang="pt-br">tubo de de aço</rdfs:label>
    <rdfs:label xml:lang="en">steel pipe</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">cooler</rdfs:label>
    <rdfs:label xml:lang="pt-br">resfriador</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um resfriador é um trocador de calor que possui uma FunçãoDeResfriamento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooler is a heat exchanger that has the function of cooling.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b556"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Cooler(x) ↔ HeatExchanger(x) ∧ ∃f (CoolingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000323">
    <skos:definition xml:lang="en">A pipe elbow is a pipe that has curved geometry enabling directional changes in pipe runs between 0 and 135 degrees.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type protects against false positives under OWA. Any curved piping component would be forcibly classified as a pipe elbow under equivalent axioms, including specialized equipment like coiled tubing, serpentine heat exchanger tubes, or custom manifold sections that contain curved passages but should not be asserted into the standard pipe elbow maintenance category.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">pipe elbow</rdfs:label>
    <rdfs:label xml:lang="pt-br">cotovelo de tubulação</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cotovelo de tubulação é uma tubulação que possui geometria curva permitindo mudanças direcionais em trechos de tubulação entre 0 e 135 graus.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe elbow is a pipe that has curved geometry enabling directional changes in pipe runs between 0 and 135 degrees.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1926"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PipeElbow(x) → (Pipe(x) ∧ ∃g(CurvedGeometry(g) ∧ hasGeometricProperty(x,g)) ∧ ∃p(DirectionalChangeCapacity(p) ∧ hasProperty(x,p))))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe elbow is a pipe that has curved geometry and enables directional change capacity between 0 and 135 degrees.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CarrierFluid">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a fluid used to transport or suspend another substance through petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">carrier fluid</rdfs:label>
    <rdfs:label xml:lang="pt-br">fluido de portador</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216">
    <skos:definition xml:lang="en">A bell nipple is a pipe that conducts drilling fluids in drilling operations and is characterized by an enlarged diameter that serves as a funnel and a location at the wellhead assembly.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b189"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BellNipple(x) ↔ (Pipe(x) ∧ ∃f(DrillingFluidConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(EnlargedDiameter(s) ∧ hasCharacteristicShape(x,s)) ∧ ∃l(WellheadAssembly(l) ∧ hasLocation(x,l))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">bell nipple</rdfs:label>
    <rdfs:label xml:lang="pt-br">bell nipple</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um bell nipple é um tubo que conduz fluidos de perfuração em operações de perfuração e é caracterizado por um diâmetro alargado que serve como funil e uma localização no conjunto da cabeça do poço.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bell nipple is a pipe that conducts drilling fluids in drilling operations and is characterized by an enlarged diameter that serves as a funnel and a location at the wellhead assembly.</iof-av:naturalLanguageDefinition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bell nipple is a pipe that bears a DrillingFluidConductionFunction and has an enlarged diameter shape and is located at a wellhead assembly.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1252">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralForce">
    <rdfs:label xml:lang="pt-br">força estrutural</rdfs:label>
    <rdfs:label xml:lang="en">structural force</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a force transmitted through a structural element of petroleum production equipment due to imposed loads.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2016">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionProducts">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="en">combustion products</rdfs:label>
    <rdfs:label xml:lang="pt-br">produtos de combustão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the chemical products—primarily carbon dioxide and water vapour—resulting from the combustion of a fuel in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b951">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2807">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WirelineLoggingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319">
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1873"/>
    <skos:definition xml:lang="en">A pig receiver is a vessel that has the function to receive pipe pigs from a pipeline.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig receiver is a vessel that bears a pig receiving function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PigReceiver(x) ↔ (Vessel(x) ∧ ∃f(PigReceivingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">recebedor de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig receiver</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um recebedor de pig é um vaso que tem a função de receber pigs de tubulação de um duto.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig receiver is a vessel that has the function to receive pipe pigs from a pipeline.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b256">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b253"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingBowl">
    <skos:definition xml:lang="en">A material artifact that constitutes the bowl at the top of a wellhead housing in which the tubing hanger is seated and sealed.</skos:definition>
    <rdfs:label xml:lang="pt-br">tigela de coluna de produção</rdfs:label>
    <rdfs:label xml:lang="en">tubing bowl</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b851">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b852"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationFunction">
    <skos:definition xml:lang="en">A separation function borne by petroleum production equipment whose realization constitutes the removal of entrained liquid droplets from a gas stream by gravity or inertial impingement.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1612"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1613"/>
    <rdfs:label xml:lang="pt-br">função de separação knock-out</rdfs:label>
    <rdfs:label xml:lang="en">knock out separation function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess">
    <rdfs:label xml:lang="pt-br">processo de condensação</rdfs:label>
    <rdfs:label xml:lang="en">condensation process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a vapour is converted into liquid by removing thermal energy until the substance reaches its dew point in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158">
    <iof-av:naturalLanguageDefinition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel is an assembly that bears a containment function and has a vessel shell and vessel head as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">vaso</rdfs:label>
    <rdfs:label xml:lang="en">vessel</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Vessel(x) ↔ Assembly(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(VesselShell(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃h(VesselHead(h) ∧ hasComponentPartAtAllTimes(x,h)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2727"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b638">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b639"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KineticMotion">
    <rdfs:label xml:lang="pt-br">movimento cinético</rdfs:label>
    <rdfs:label xml:lang="en">kinetic motion</rdfs:label>
    <skos:definition xml:lang="en">A process in which the directed mechanical motion of a component or fluid stream carrying kinetic energy in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess">
    <rdfs:label xml:lang="en">connection process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de conexão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which two or more components or systems are mechanically or fluidly joined to allow the transfer of force, fluid, or signal between them.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2436">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StatorWinding"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1515">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpOutlet"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1028">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000310">
    <skos:definition xml:lang="en">A load cell is an instrument that converts mechanical force (tension, compression, pressure, or torque) into a proportional electrical signal for measurement purposes.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every load cell is an instrument that bears a force-to-electrical transduction function and has a force-receiving element, transduction element, and electrical output.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A load cell is an instrument that converts mechanical force (tension, compression, pressure, or torque) into a proportional electrical signal for measurement purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma célula de carga é um instrumento que converte força mecânica (tração, compressão, pressão ou torque) em um sinal elétrico proporcional para fins de medição.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">load cell</rdfs:label>
    <rdfs:label xml:lang="pt-br">célula de carga</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LoadCell(x) ↔ Instrument(x) ∧ ∃f(ForceToElectricalTransductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1724"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicSignal">
    <rdfs:label xml:lang="en">chromatographic signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de cromatográfico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting a signal generated by a chromatographic detector representing the presence and concentration of chemical components in a process sample.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de suporte estrutural</rdfs:label>
    <rdfs:label xml:lang="en">structural support process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical cutting of a tubular string within a wellbore to enable emergency well control.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de corte de tubulação</rdfs:label>
    <rdfs:label xml:lang="en">pipe shearing function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2342"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2341"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000351">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Silo(x) ↔ (Vessel(x) ∧ ∃f(SolidBulkStorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(ConicalBottom(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2386"/>
    <skos:definition xml:lang="en">A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials.</skos:definition>
    <rdfs:label xml:lang="en">silo</rdfs:label>
    <rdfs:label xml:lang="pt-br">silo</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every silo is a vessel that has the function of storing bulk solids and has a conical bottom component.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um silo é um vaso que possui uma função de armazenamento de sólidos a granel e tem uma seção inferior cônica para facilitar o armazenamento e descarga de materiais sólidos a granel.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000357">
    <iof-av:naturalLanguageDefinition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um quadro de distribuição é um equipamento elétrico que consiste em painéis que acomodam chaves, indicadores e aparatos de controle para conectar, desconectar e controlar vários circuitos de um sistema elétrico.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every switchboard is electrical equipment that has component parts (panels, switches, indicators) and bears the function to control electrical circuits</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">quadro de distribuição</rdfs:label>
    <rdfs:label xml:lang="en">switchboard</rdfs:label>
    <skos:definition xml:lang="en">A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2477"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Switchboard(x) ↔ ElectricalEquipment(x) ∧ ∃p,s,i(Panel(p) ∧ ElectricalSwitch(s) ∧ ControlIndicator(i) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃f(ElectricalCircuitControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2518">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000205">
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on vacuum reference chamber configuration. Under Open World Assumption, defining sufficient conditions could lead to unintended classification of complex instruments that contain vacuum chambers but serve different primary functions. The structural differentia is necessary but making it sufficient requires domain expert validation.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b6"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b7"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b5"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AbsolutePressureTransmitter(x) → PressureTransmitter(x) ∧ ∃y (VacuumReferenceeChamber(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">transmissor de pressão absoluta</rdfs:label>
    <rdfs:label xml:lang="en">absolute pressure transmitter</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber as a component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão absoluta é um transmissor de pressão que possui uma câmara de referência de vácuo de um lado do sensor de pressão enquanto o outro lado recebe a pressão do processo.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2081"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2082"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de medição de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure measurement function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and local display of the pressure of a process stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">flow control process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de controle de fluxo</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThermowellStem(x) → FiatObjectPart(x) ∧ ∃y(Thermowell(y) ∧ partOf(x,y)) ∧ ∃q(HollowCylindricalShape(q) ∧ hasQuality(x,q)) ∧ ∃l(ProcessMediumIntrusionZone(l) ∧ hasLocation(x,l)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2558"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis. The structural differentia (hollow cylindrical shape, positioning in process medium) is necessary but may not be sufficient under OWA - there could be other specialized parts of thermowells with similar geometry but different specific roles or configurations.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um termowell stem é uma parte de objeto fiducial que é parte de um termowell e que tem uma forma cilíndrica oca posicionada para se projetar no meio do processo, fornecendo habitação protetora para elementos de detecção de temperatura enquanto permite condução térmica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell stem is a fiat object part that is part of some thermowell and has hollow cylindrical shape and is located in process medium intrusion zone.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">termowell stem</rdfs:label>
    <rdfs:label xml:lang="en">thermowell stem</rdfs:label>
    <skos:definition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b331">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2271">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ScrapingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationFunction">
    <rdfs:label xml:lang="pt-br">função de compensação de movimentação</rdfs:label>
    <rdfs:label xml:lang="en">movement compensation function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b475"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b474"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the accommodation of relative movement between connected components caused by thermal expansion, vibration, or settlement.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2692">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293">
    <skos:definition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">header</rdfs:label>
    <rdfs:label xml:lang="pt-br">header</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um header é um manifold que se conecta a muitos tubos menores para coletar descarga de múltiplas fontes ou distribuir fluido para múltiplos destinos.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Header(x) ↔ (manifold(x) ∧ ∃y(SmallPipe(y) ∧ connects_to(x,y)) ∧ ∃z(MultiStreamDistributionProcess(z) ∧ participatesIn(x,z))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1418"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Header ≡ manifold ⊓ ∃connects_to.SmallPipe ⊓ ∃participatesIn.MultiStreamDistributionProcess</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1993">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b374">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b372"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b902">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SuctionInlet"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000282">
    <rdfs:label xml:lang="en">fuse</rdfs:label>
    <rdfs:label xml:lang="pt-br">fusível</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A fuse is an electrical equipment that protects circuits by interrupting current flow through the intentional melting of a fusible element when current exceeds specified values for a sufficient duration.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every fuse is an electrical equipment that bears a circuit protection function and has a fuse element that melts under overcurrent conditions.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Fuse(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FuseElement(e) ∧ hasComponentPartAtAllTimes(x,e)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fuse is an electrical equipment that protects circuits by interrupting current flow through the intentional melting of a fusible element when current exceeds specified values for a sufficient duration.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um fusível é um equipamento elétrico que protege circuitos interrompendo o fluxo de corrente através do derretimento intencional de um elemento fusível quando a corrente excede valores especificados por uma duração suficiente.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1262"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1996">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCable">
    <skos:definition xml:lang="en">A material artifact that constitutes an insulated conductor or assembly of conductors used to transmit electrical power or signals in a petroleum production installation.</skos:definition>
    <rdfs:label xml:lang="en">electrical cable</rdfs:label>
    <rdfs:label xml:lang="pt-br">cabo elétrico</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1259"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b448"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1258"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b449"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de proteção de circuito</rdfs:label>
    <rdfs:label xml:lang="en">circuit protection function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic interruption or limitation of current in an electrical circuit to protect equipment from overload or fault conditions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b376">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical stirring of a liquid to promote mixing, suspension of solids, or heat transfer.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b49"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b50"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de agitação</rdfs:label>
    <rdfs:label xml:lang="en">agitation function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000274">
    <skos:definition xml:lang="en">A flare is a burner that safely disposes of unwanted gases through controlled combustion at an elevated location.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um flare é um queimador que descarta com segurança gases indesejados através de combustão controlada em local elevado.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flare is a burner that safely disposes of unwanted gases through controlled combustion at an elevated location.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">flare</rdfs:label>
    <rdfs:label xml:lang="pt-br">flare</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Flare(x) ↔ (Burner(x) ∧ ∃f (WasteGasDisposalFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1107"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flare is a burner that bears a waste gas disposal function and has component parts flare tip, flare stack, and pilot system.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RemovedMaterial">
    <skos:definition xml:lang="en">A material artifact that constitutes material—scale, deposits, or cuttings—removed from a surface or stream by a mechanical cleaning process in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">removed material</rdfs:label>
    <rdfs:label xml:lang="pt-br">material de removido</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b953">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b951"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1473">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000180"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehydrator is a separator that has the function of dehydration.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">dehydrator</rdfs:label>
    <rdfs:label xml:lang="pt-br">desidratador</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b645"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2184">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000217">
    <skos:definition xml:lang="en">A boiler is a heater that brings a liquid to its boiling point through indirect contact heat exchange, producing steam or vapor.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b233"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A boiler is a heater that brings a liquid to its boiling point through indirect contact heat exchange, producing steam or vapor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma caldeira é um aquecedor que leva um líquido ao seu ponto de ebulição através de troca de calor por contato indireto, produzindo vapor.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Boiler(x) ↔ Heater(x) ∧ ∃f(BoilingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every boiler is a heater that bears a BoilingFunction and has component parts including a steam drum and heat exchange surface.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">boiler</rdfs:label>
    <rdfs:label xml:lang="pt-br">caldeira</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b452">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b454"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b139"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical mechanism, sufficient conditions are omitted to avoid false positives under Open World Assumption. Complex multi-way valves or specialized equipment containing ball mechanisms should not be automatically classified as standard ball valves without domain expert validation.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula esfera é uma válvula que controla o fluxo de fluidos usando um elemento de fechamento esférico que gira aproximadamente 90 graus para alinhar ou desalinhar sua passagem de fluxo com as portas do corpo da válvula.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">ball valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula esfera</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallValve(x) → Valve(x) ∧ ∃y(BallClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(RotationalMotionProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every ball valve is a valve that has a ball closure component and participates in rotational motion processes</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334">
    <skos:definition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureIndicatingTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PressureIndicatingAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(PressureSignal(i) ∧ hasInput(x,i)) ∧ ∃o1(ElectricalSignal(o1) ∧ hasOutput(x,o1)) ∧ ∃o2(LocalPressureDisplay(o2) ∧ hasOutput(x,o2)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">transmissor indicador de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure indicating transmitter</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure indicating transmitter is a transmitter that bears a pressure indicating and transmission function, has pressure signal as input, and has both electrical signal output and local pressure display.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2097"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor indicador de pressão é um transmissor que mede pressão e fornece tanto indicação visual local quanto transmissão de sinal elétrico do valor da pressão.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2118">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2116"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b577">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2201">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2203"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1457">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1551">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2669">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1611">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparateVapourSpace"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1975">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b478">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b480"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReboilingFunction">
    <rdfs:label xml:lang="en">reboiling function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de refervimento</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1603"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1604"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the partial vaporisation of liquid at the base of a distillation column by supplying heat to drive vapour upward through the column.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000369">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VacuumColumn(x) → DistillationColumn(x) ∧ ∃q(VacuumPressureResistanceQuality(q) ∧ bearerOf(x,q)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural capability. Under OWA, defining sufficient conditions for vacuum-capable design would be complex and could lead to false positives. The structural differentia (vacuum resistance) requires domain expert validation of what constitutes adequate vacuum design capability.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de vácuo é uma coluna de destilação projetada para resistir à pressão externa durante operação sob vácuo.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</skos:definition>
    <rdfs:label xml:lang="pt-br">coluna de vácuo</rdfs:label>
    <rdfs:label xml:lang="en">vacuum column</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2687"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vacuum column is a distillation column that bears a vacuum pressure resistance quality.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparatedSolidLiquidPortion">
    <rdfs:label xml:lang="en">separated solid liquid portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção separado líquido de sólido</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the solid–liquid fraction recovered after a phase separation process in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectromagneticRadiation">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">electromagnetic radiation</rdfs:label>
    <rdfs:label xml:lang="pt-br">radiação eletromagnético</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <skos:definition xml:lang="en">A process in which electromagnetic energy—such as infrared or ultraviolet radiation—detected or emitted by petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000284">
    <skos:definition xml:lang="en">A gas detector is a detector that has the designed function to sense the presence of a specified concentration of a gas.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas detector is a detector that bears a GasDetectionFunction and has a GasDetectingMeasuringElement as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector de gás é um detector que tem a função projetada de detectar a presença de uma concentração especificada de um gás.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas detector is a detector that has the designed function to sense the presence of a specified concentration of a gas.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">detector de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas detector</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1282"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GasDetector(x) ↔ (Detector(x) ∧ ∃f(GasDetectionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de controle de superfície do poço</rdfs:label>
    <rdfs:label xml:lang="en">well surface control process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which wellbore conditions are controlled from surface to manage production flow, monitor well integrity, and enable intervention operations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1512">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1516"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000185">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1223"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1222"/>
    <rdfs:label xml:lang="en">flow signal transmission function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de transmissão de sinal de fluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and remote transmission of the flow rate of a process stream.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b691">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000376">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um poço perfurado é um local que fornece um caminho perfurado para acesso subsuperficial e está espacialmente contido dentro de um sistema de poço.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000029"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellbore(x) ↔ Site(x) ∧ ∃f(SubsurfaceAccessFunction(f) ∧ hasFunction(x,f)) ∧ ∃w(Well(w) ∧ spatiallyContainedIn(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">wellbore</rdfs:label>
    <rdfs:label xml:lang="pt-br">poço perfurado</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellbore is a site that has the function of providing subsurface access and is spatially contained within a well.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2452">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2453"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281">
    <iof-av:naturalLanguageDefinition xml:lang="en">A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um forno é um aquecedor que possui a função de induzir reações químicas em fluidos de processo através do aquecimento.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1251"/>
    <rdfs:label xml:lang="en">furnace</rdfs:label>
    <rdfs:label xml:lang="pt-br">forno</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Furnace(x) ↔ Heater(x) ∧ ∃f(ReactiveHeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every furnace is a heater that has the function to induce reactions in process fluids by heating them.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b583"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1089"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b582"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1090"/>
    <rdfs:label xml:lang="pt-br">função de conexão</rdfs:label>
    <rdfs:label xml:lang="en">connection function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical or fluid joining of two or more components to allow the transfer of force, fluid, or signal between them.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b399">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehydrationProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which water is removed from a fluid stream by adsorption, absorption, or distillation to meet product specification limits.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de desidratação</rdfs:label>
    <rdfs:label xml:lang="en">dehydration process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226">
    <skos:definition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CheckValveBody subClassOf ValveBody and (designedFor some CheckValve)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que é especificamente projetado para acomodar e alojar os mecanismos internos de uma válvula de retenção dentro de uma barreira de contenção de pressão.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
    <rdfs:label xml:lang="en">check valve body</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveBody(x) → ValveBody(x) ∧ ∃y(CheckValve(y) ∧ designedFor(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b377"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive identity based on structural design for check valve accommodation. Under OWA, any housing designed for check valves could include specialized configurations, custom manifolds, or hybrid designs that should not be automatically classified as standard check valve bodies without domain expert validation of the structural differentia.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b90"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b91"/>
    <rdfs:label xml:lang="en">anode function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de proteção anódica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the supply of electrons to a cathodic protection circuit to prevent corrosion of a protected metallic structure.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2752">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2754"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess">
    <rdfs:label xml:lang="pt-br">processo de proteção catódica</rdfs:label>
    <rdfs:label xml:lang="en">cathodic protection process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which electrochemical corrosion of a metallic structure is prevented by making it the cathode of an electrochemical cell through the supply of electrical current or sacrificial anodes.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow element is an instrument that bears a FlowMeasurementFunction and has component parts including a FlowSensingElement and SignalGenerationComponent.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1168"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de vazão é um instrumento que tem a função de medir vazões em um fluxo e produzir sinais proporcionais à vazão medida.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowElement(x) ↔ (Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">elemento de vazão</rdfs:label>
    <rdfs:label xml:lang="en">flow element</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331">
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical mechanism. Under OWA, sufficient conditions based on displacement mechanism alone could lead to false positives where specialized equipment containing displacement elements might be incorrectly classified as standard positive displacement pumps.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">bomba de deslocamento positivo</rdfs:label>
    <rdfs:label xml:lang="en">positive displacement pump</rdfs:label>
    <skos:definition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every positive displacement pump is a pump that has a displacement mechanism as component part at all times and participates in positive displacement processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2048"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PositiveDisplacementPump(x) → Pump(x) ∧ ∃y(DisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(PositiveDisplacementProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de deslocamento positivo é uma bomba que transporta líquido através do princípio de deslocamento alternativo ou rotativo com volume de deslocamento fixo por ciclo.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalVariable">
    <rdfs:label xml:lang="pt-br">variável físico</rdfs:label>
    <rdfs:label xml:lang="en">physical variable</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An information content entity constituting a measurable physical property—such as pressure, temperature, or flow rate—of a process stream or equipment state in petroleum production.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2659">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurement">
    <skos:definition xml:lang="en">A measurement information content entity constituting a quantitative value representing the flow rate of a process stream as measured by petroleum production instrumentation.</skos:definition>
    <rdfs:label xml:lang="pt-br">medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measurement</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2753">
