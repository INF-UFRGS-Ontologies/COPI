    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000185">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de transmissão de sinal de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow signal transmission function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b127">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b125"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136">
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:label xml:lang="en">orifice plate</rdfs:label>
    <rdfs:label xml:lang="pt-br">placa de orifício</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b187"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (OrificePlate(x) → FlowMeasuringElement(x) ∧ ∃f (FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma placa de orifício é um elemento de medição de fluxo que consiste de uma placa fina com um orifício especificado através do qual o fluido flui para criar pressão diferencial para medição da taxa de fluxo.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157">
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b72"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b71"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor é um instrumento que possui uma função de transmissão de sinal, recebendo sinais de variáveis de processo de sensores e convertendo-os em sinais de saída padronizados para transmissão a sistemas de controle.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">transmissor</rdfs:label>
    <rdfs:label xml:lang="en">transmitter</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Transmitter(x) ↔ Instrument(x) ∧ ∃f (SignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (SignalTransmissionFunction(f) ∧ bearerOf(x,f)) ⊓ ∃hasInput.ProcessVariableSignal ⊓ ∃hasOutput.StandardizedSignal)</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145">
    <rdfs:label xml:lang="en">relief valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de alívio</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b209"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ReliefValve(x) ↔ Valve(x) ∧ ∃f (PressureReliefFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de alívio é uma válvula projetada para abrir automaticamente em um ponto de ajuste de pressão predeterminado para aliviar o excesso de pressão e prevenir níveis de pressão inseguros em um sistema.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b210"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b88">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="N1271512216f0466588cd1a49497d9a5e"/>
    <rdfs:subClassOf rdf:nodeID="N81071ef15d1845e898a266288f13dea9"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
    <rdfs:label xml:lang="en">pumping function</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A designed function that is realized in a liquid pressure increase process.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma função projetada que é realizada em um processo de aumento de pressão de líquido.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b143"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A humidity analyser is a process analyzer that is designed to measure and indicate humidity or moisture content in process streams or environments.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de umidade é um analisador de processo que é projetado para medir e indicar o conteúdo de umidade ou vapor d&amp;#x27;água em correntes de processo ou ambientes.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (HumidityAnalyser(x) ↔ Instrument(x) ∧ ∃f (HumidityMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">analisador de umidade</rdfs:label>
    <rdfs:label xml:lang="en">humidity analyser</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b144"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b147">
    <rdf:first rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b145"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b201">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086"/>
    <rdf:rest rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b202"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b26"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Blower(x) ↔ Compressor(x) ∧ ∃f (CompressionFunction(f) ∧ bearerOf(x,f)) ∧ ∃hasOperatingParameter.MediumPressureRange ⊓ ∃hasOperatingParameter.MediumVolumeFlowRange)</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um soprador é um compressor que comprime e fornece ar ou gás em pressão média e vazão volumétrica média.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b25"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:label xml:lang="en">blower</rdfs:label>
    <rdfs:label xml:lang="pt-br">soprador</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191">
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b1"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">gas movement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de movimentação de gás</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105">
    <rdfs:label xml:lang="pt-br">válvula choke</rdfs:label>
    <rdfs:label xml:lang="en">choke valve</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ChokeValve(x) ↔ Valve(x) ∧ ∃f (PressureReductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b40"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula choke é uma válvula que possui uma função de redução de pressão, projetada para reduzir a pressão do fluido da entrada para a saída através de restrição controlada do fluxo e dissipação de energia.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b41"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000113">
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b103"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:label xml:lang="en">electric motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor elétrico</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor elétrico é um conjunto que possui uma função de conversão de energia elétrica para mecânica e tem tanto um estator quanto um rotor como componentes essenciais.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b104"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ElectricMotor(x) ↔ Assembly(x) ∧ ∃f (ElectricToMechanicalConversionFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (ElectricToMechanicalConversionFunction(f) ∧ bearerOf(x,f)) ⊓ ∃p (Stator(p) ∧ hasComponentPartAtAllTimes(x,p)) ⊓ ∃p (Rotor(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000123">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b137"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula globo é uma válvula caracterizada por um elemento de fechamento (disco ou tampão) que opera com movimento linear perpendicular a uma sede orientada normal ao caminho do fluxo do fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GlobeValve(x) → Valve(x) ∧ ∃f (FlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">válvula globo</rdfs:label>
    <rdfs:label xml:lang="en">globe valve</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b9"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:label xml:lang="pt-br">elemento de medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measuring element</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b54">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b52"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b263">
    <owl:intersectionOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b266"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b26">
    <owl:intersectionOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b28"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:label xml:lang="en">coalescence function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de coalescência</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b6"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152">
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b241"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b242"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro grosso é um artefato material que possui uma função de separação e tem um elemento filtrante, projetado para separar partículas sólidas de fluidos fazendo o fluido passar através de telas ou perfurações.</iof-av:naturalLanguageDefinition>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Strainer(x) ↔ MaterialArtifact(x) ∧ ∃f (SeparationFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (SeparationFunction(f) ∧ bearerOf(x,f)) ⊓ ∃p (FilteringElement(p) ∧ hasComponentPartAtAllTimes(x,p)) ⊓ ∃participatesIn.SolidLiquidSeparationProcess)</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">filtro grosso</rdfs:label>
    <rdfs:label xml:lang="en">strainer</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador de fluxo é um indicador projetado para indicar taxas de fluxo usando um elemento de medição de fluxo e elemento de exibição.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</iof-av:naturalLanguageDefinition>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b123"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:label xml:lang="pt-br">indicador de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow indicator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FlowIndicator(x) ↔ Indicator(x) ∧ ∃f (FlowIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (FlowIndicationFunction(f) ∧ bearerOf(x,f)) ⊓ ∃hasComponentPartAtSomeTime.FlowMeasuringElement)</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b124"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Valve(x) → MaterialArtifact(x) ∧ ∃f (FlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">válvula</rdfs:label>
    <rdfs:label xml:lang="en">valve</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b14"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula é um conjunto que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido.</iof-av:naturalLanguageDefinition>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="N6f81c99e67304a2f980de39ff39ed637">
    <rdf:first rdf:nodeID="Nc79c64d5c60f402f9f036e6fc225f5f9"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b86">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189">
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
    <rdfs:label xml:lang="pt-br">função de transmissão de vibração</rdfs:label>
    <rdfs:label xml:lang="en">vibration transmission function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000202">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:label xml:lang="en">electrical power transmission role</rdfs:label>
    <rdfs:label xml:lang="pt-br">papel de transmissão de potência elétrica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measurement function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b197">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000202"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b17"/>
    <rdfs:label xml:lang="en">ball control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (BallControlValve(x) → ControlValve(x) ∧ ∃f (ProcessControlledFlowFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">transmissor de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow transmitter</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b128"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FlowTransmitter(x) ↔ Transmitter(x) ∧ ∃f (FlowSignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (FlowSignalTransmissionFunction(f) ∧ bearerOf(x,f)) ⊓ ∃hasInput.FlowMeasurement)</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de fluxo é um transmissor que produz sinais de saída padronizados proporcionais às medições de fluxo provenientes de elementos sensores de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b129"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b124">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b126"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:label xml:lang="pt-br">função de indicação de nível</rdfs:label>
    <rdfs:label xml:lang="en">level indication function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CentrifugalCompressor(x) → Compressor(x) ∧ ∃f (CompressionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um compressor centrífugo é um compressor que usa um ou mais impelidores centrífugos para acelerar o gás através de fluxo radial e gerar aumento de pressão por ação centrífuga.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">centrifugal compressor</rdfs:label>
    <rdfs:label xml:lang="pt-br">compressor centrífugo</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b32"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164">
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <rdfs:label xml:lang="pt-br">função de redução de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure reduction function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="N8afe69531f9144579e26f48b7f2879e7"/>
    <rdfs:subClassOf rdf:nodeID="Nd54546fc0a3e4132b3a7d7fef5b55d8a"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
    <rdfs:label xml:lang="en">gas absorption function</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A designed function that is realized in a gas absorption process.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma função projetada que é realizada em um processo de absorção de gás.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115">
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b113"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b114"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ventilador é um conjunto que possui uma função de movimentação de gás para fornecer ou exaurir volumes de vapor ou gás com baixa pressão diferencial.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">ventilador</rdfs:label>
    <rdfs:label xml:lang="en">fan</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Fan(x) ↔ Assembly(x) ∧ ∃f (GasMovementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">piston check valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de retenção tipo pistão</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b193"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PistonCheckValve(x) → CheckValve(x) ∧ ∃f (BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção tipo pistão é uma válvula de retenção que possui um elemento de fechamento tipo pistão que se move linearmente ao longo do eixo de fluxo sob ação da gravidade ou mola para prevenir refluxo.</iof-av:naturalLanguageDefinition>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131">
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b167"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b168"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de nível é um transmissor que mede o nível (altura) de material líquido ou sólido a granel em um recipiente e produz um sinal elétrico de saída padronizado proporcional ao nível medido.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LevelTransmitter(x) ↔ Transmitter(x) ∧ ∃f (LevelMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (LevelMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">transmissor de nível</rdfs:label>
    <rdfs:label xml:lang="en">level transmitter</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b169"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b232">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b230"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro de pressão diferencial é um manômetro que mede e indica a diferença entre duas entradas de pressão usando um elemento de medição de pressão diferencial.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b66"/>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b67"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureGauge(x) ↔ PressureGauge(x) ∧ ∃f (DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f)) ⊓ ∃hasInput.PressurePortPair)</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">manômetro de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure gauge</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119">
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b133"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle tipo gaveta é uma válvula de controle que usa um elemento de fechamento tipo gaveta ou cunha movendo-se perpendicular ao caminho do fluxo para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">gate control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle tipo gaveta</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GateControlValve(x) → ControlValve(x) ∧ ∃f (ProcessControlledFlowFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155">
    <rdfs:label xml:lang="en">temperature transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de temperatura</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de temperatura é um transmissor que mede temperatura e produz um sinal de saída padronizado dependente do sinal de entrada recebido de um elemento de temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b253"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b252"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (TemperatureTransmitter(x) ↔ Transmitter(x) ∧ ∃f (TemperatureMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃f (TemperatureMeasurementCapability(f) ∧ bearerOf(x,f)) ⊓ ∃hasInput.TemperatureSignal)</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b254"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b219">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158">
    <iof-av:naturalLanguageDefinition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento.</iof-av:naturalLanguageDefinition>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Vessel(x) ↔ Assembly(x) ∧ ∃f (ContainmentFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">vessel</rdfs:label>
    <rdfs:label xml:lang="pt-br">vaso</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b229"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b228"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b166">
    <rdf:first rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b164"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116">
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de vazão é um instrumento que tem a função de medir vazões em um fluxo e produzir sinais proporcionais à vazão medida.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">elemento de vazão</rdfs:label>
    <rdfs:label xml:lang="en">flow element</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b119"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b118"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FlowElement(x) ↔ Instrument(x) ∧ ∃f (FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000108">
    <rdfs:label xml:lang="en">diaphragm valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de diafragma</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b55"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DiaphragmValve(x) → Valve(x) ∧ ∃f (FlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de diafragma é uma válvula que usa um diafragma resiliente forçado contra uma porta como seu mecanismo de fechamento para controlar o fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow.</iof-av:naturalLanguageDefinition>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000140">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b195"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PlugValve(x) → Valve(x) ∧ ∃f (FlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">válvula plug</rdfs:label>
    <rdfs:label xml:lang="en">plug valve</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula plug é uma válvula que possui um elemento de fechamento em forma de plugue cilíndrico ou cônico que opera por rotação de um quarto de volta em seu eixo para controlar o fluxo de fluido selando contra um assento.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194">
    <rdfs:label xml:lang="en">filtration function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de filtração</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b4"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n256fe5527e8d4ee2a3860e72eb06a346b13">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
