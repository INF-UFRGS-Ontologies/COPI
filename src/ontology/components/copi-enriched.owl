  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSignal">
    <rdfs:label xml:lang="pt-br">sinal de nível</rdfs:label>
    <rdfs:label xml:lang="en">level signal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the fluid level in a vessel of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FuelSupplySystem">
    <rdfs:label xml:lang="en">fuel supply system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de combustível de suprimento</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An assembly of storage, filtering, and delivery components that supplies fuel to combustion equipment in a petroleum production installation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AnalogueDial">
    <rdfs:label xml:lang="en">analogue dial</rdfs:label>
    <rdfs:label xml:lang="pt-br">mostrador analógico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an analogue display element with a graduated scale and pointer that indicates the value of a measured variable in petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1059">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
