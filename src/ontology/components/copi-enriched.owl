  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;MOTOR&gt; is an &lt;ARTEFACT&gt; and a &lt;DRIVER(function)&gt; that is powered by electricity or internal combustion</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A device that generates rotational kinetic energy.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] A driver that is powered by electricity or internal combustion (from ``_).</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every motor is an assembly that has the function of generating mechanical energy and has as output rotational kinetic energy.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2261"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor é um conjunto que possui uma função de geração de energia mecânica para converter energia elétrica, química, pneumática ou hidráulica em energia mecânica rotacional.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A motor is an assembly that bears a mechanical energy generation function to convert electrical, chemical, pneumatic, or hydraulic energy into rotational mechanical energy.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Motor(x) ↔ Assembly(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(RotationalKineticEnergy(e) ∧ hasOutput(x,e)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
