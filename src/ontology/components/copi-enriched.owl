    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b733"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b734"/>
