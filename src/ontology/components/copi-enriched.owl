  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A meter intended to measure and indicate and/or produce a signal which represents the measured humidity.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (HumidityAnalyser(x) ↔ ProcessAnalyzer(x) ∧ ∃f (HumidityMeasurementFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de umidade é um analisador de processo que é projetado para medir e indicar o conteúdo de umidade ou vapor d'água em correntes de processo ou ambientes.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every humidity analyser is a process analyzer that has the function to measure humidity content.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1869"/>
    <rdfs:label xml:lang="en">humidity analyser</rdfs:label>
    <rdfs:label xml:lang="pt-br">analisador de umidade</rdfs:label>
  </rdf:Description>
