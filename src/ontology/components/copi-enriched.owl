  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262">
    <rdfs:label xml:lang="pt-br">conexão elétrica</rdfs:label>
    <rdfs:label xml:lang="en">electrical connection</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1197"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma conexão elétrica é um MaterialArtifact que possui uma ElectricalConductionFunction e que fornece um caminho para a corrente elétrica passar de um aparelho elétrico para outro.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electrical connection is a material artifact that bears an electrical conduction function and participates in processes involving electrical apparatus.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnection(x) ↔ (MaterialArtifact(x) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ElectricalConductionProcess(p) ∧ participatesIn(x,p) ∧ ∃y(ElectricalApparatus(y) ∧ has_participant_at_some_time(p,y)))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ELECTRICAL CONNECTION&gt; is a &lt;DirectConnection&gt; for letting pass a &lt;CURRENT&gt; from one &lt;ELECTRICAL APPARATUS&gt; to another</skos:definition>
  </rdf:Description>
