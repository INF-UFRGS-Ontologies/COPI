    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3418"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3414"/>
    <rdfs:label xml:lang="en">containment function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de contenção</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a ContainmentProcess and that consists in providing a physical enclosure or housing that contains, supports, and protects internal components or fluids within defined boundaries.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a ContainmentProcess and that consists in providing a pressure-containing boundary to enclose and isolate fluids or materials within a defined volume.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a ContainmentProcess and that consists in the capacity to enclose and contain material within a defined boundary.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
