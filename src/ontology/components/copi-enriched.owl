  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every indicator is an instrument that bears an indication function to display process information in human-perceptible form.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1989"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador é um instrumento que exibe ou mostra o valor ou status de uma variável medida ou condição para torná-la perceptível aos operadores.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[POSC Caesar] An artefact that is a intended to display the value or the status of a condition.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A visible sign of a chemical reaction.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;INDICATOR&gt; is an &lt;INSTRUMENTATION FUNCTION&gt; that has a capability of &lt;INDICATING&gt;</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] In a chemical context, an indicator is a chemical in a titration reaction that changes color at a certain pH.                  In the context of a mechanical load, an indicator is a dial or gauge.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Indicator(x) ↔ (Instrument(x) ∧ ∃f(IndicationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">indicador</rdfs:label>
    <rdfs:label xml:lang="en">indicator</rdfs:label>
  </rdf:Description>
