  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DriveShaft(x) ↔ (Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(RotationalPowerTransferProcess(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DriveShaft ≡ Assembly ⊓ ∃bearerOf.PowerTransmissionFunction ⊓ ∃participatesIn.RotationalPowerTransferProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">drive shaft</rdfs:label>
    <rdfs:label xml:lang="pt-br">eixo de transmissão</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de transmissão é um Assembly que possui uma PowerTransmissionFunction e consiste em um sistema baseado em eixo usado para transferir energia mecânica rotacional de um motor primário para múltiplas máquinas acionadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1108"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DRIVE SHAFT&gt; is an &lt;ARTEFACT&gt; and an &lt;ENERGY TRANSFERRER&gt; that is a shaft used to transfer rotational power from a prime driver to several individual machines by use of drive belts and pulley wheels</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1110">
    <rdf:rest rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1111"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1011">
    <rdf:rest rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1012"/>
    <rdf:first rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1006"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess">
    <rdfs:label xml:lang="en">spacing process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de espaçamento</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000232">
    <skos:definition xml:lang="en">[CFIHOS] A cooler that is intended to change a vapour to liquid.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CONDENSER&gt; is a &lt;COOLER&gt; that has a capability of  &lt;CONDENSING&gt; a &lt;FLUID&gt; from &lt;VAPOUR&gt; to &lt;LIQUID&gt;</skos:definition>
    <rdfs:label xml:lang="en">condenser</rdfs:label>
    <rdfs:label xml:lang="pt-br">condensador</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A condenser is a heat exchanger that bears a designed function to condense vapor to liquid by removing latent heat of vaporization.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um condensador é um trocador de calor que possui uma função projetada para condensar vapor em líquido removendo o calor latente de vaporização.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b625"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every condenser is a heat exchanger that bears a condensation function, and every heat exchanger that bears a condensation function is a condenser.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Condenser(x) ↔ (HeatExchanger(x) ∧ ∃f(CondensationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
