  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000362">
    <rdfs:label xml:lang="pt-br">transdutor</rdfs:label>
    <rdfs:label xml:lang="en">transducer</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TRANSDUCER&gt; is an &lt;ENERGY CONVERTER&gt; that is capable of converting a &lt;PROCESS VARIABLE&gt; in one form or magnitude of energy to another form or magnitude of the same energy</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An artefact that accepts information in the form of a physical or chemical variable (its input variable) and converts it into an output variable of the same or another nature, according to a definite law.</skos:definition>
    <skos:definition xml:lang="en">[isa5_1] a general term for a device, which can be a primary element, transmitter, relay, converter or other device, that receives information in the form of one or more physical quantities, modifies the information or its form, or both if required, and produces a resultant output signal.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every transducer is an instrument that has the designed function to convert energy or signal forms while preserving information content.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transdutor é um instrumento que possui uma FunçãoDeTransdução para converter informação de uma forma ou magnitude de energia para outra forma ou magnitude.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Transducer(x) ↔ Instrument(x) ∧ ∃f (TransductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3208"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2653">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureSignalTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245">
    <rdfs:label xml:lang="pt-br">densitômetro</rdfs:label>
    <rdfs:label xml:lang="en">densitometer</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DENSITOMETER&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;MEASURING INSTRUMENT&gt; that measures the degree of darkness in photographic or semitransparent material. The densitometer is basically a light source aimed at a photoelectric cell which determines the density of the sample from differences in the readings</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A device used for reading the density of a flowing fluid or slurry.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device installed on a mixing or pumping system manifold to measure the density of fluids.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every densitometer is an instrument that has the function of measuring density.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b872"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um densitômetro é um instrumento que possui uma função de medição de densidade.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
