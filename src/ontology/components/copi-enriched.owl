  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000272">
    <skos:definition xml:lang="en">[CFIHOS] A detector that is intended to sense a flame.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLAME DETECTOR&gt; is a &lt;DETECTOR&gt; and a &lt;FLAME DETECTING INSTRUMENT&gt; using a &lt;FLAME DETECTING MEASURING ELEMENT&gt; that is designed to detect the presence of a flame</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A detector that is intended to sense a flame.</skos:definition>
    <rdfs:label xml:lang="en">flame detector</rdfs:label>
    <rdfs:label xml:lang="pt-br">detector de chama</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1377"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector de chama é um detector que tem a função de detectar a presença de chamas.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame detector is a detector that has a flame detection function, and every detector that has a flame detection function is a flame detector.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlameDetector(x) ↔ Detector(x) ∧ ∃f(FlameDetectionFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1597">
    <owl:intersectionOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1601"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DriveSystem">
    <rdfs:label xml:lang="pt-br">sistema de acionamento</rdfs:label>
    <rdfs:label xml:lang="en">drive system</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão é um instrumento que possui uma função de detecção de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[POSC Caesar] A detecting element intended to sense pressure.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A detecting element intended to sense pressure.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure element is a detecting element that has the function of sensing pressure</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">pressure element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de pressão</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureElement(x) ↔ DetectingElement(x) ∧ ∃f(PressureSensingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2597"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
