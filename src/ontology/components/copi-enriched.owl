  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">furnace</rdfs:label>
    <rdfs:label xml:lang="pt-br">forno</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FURNACE&gt; is a &lt;HEATER&gt; that is intended to induce a reaction in a process fluid by heating it</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is intended to induce a reaction in a process fluid by heating it.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Furnace(x) ↔ Heater(x) ∧ ∃f(ReactiveHeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um forno é um aquecedor que possui a função de induzir reações químicas em fluidos de processo através do aquecimento.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every furnace is a heater that has the function to induce reactions in process fluids by heating them.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1576"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction">
    <rdfs:label xml:lang="en">level switching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de chaveamento de nível</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2097"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2096"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1248">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242">
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b807"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desumidificador é um conjunto que possui a função de remover umidade do ar.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEHUMIDIFIER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEHUMIDIFYING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A piece of equipment specifically designed to remove moisture from air.</skos:definition>
    <rdfs:label xml:lang="pt-br">desumidificador</rdfs:label>
    <rdfs:label xml:lang="en">dehumidifier</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehumidifier is an assembly that has the function to perform dehumidification.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PolyphaseElectricalSignal">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">sinal polifásico elétrico</rdfs:label>
    <rdfs:label xml:lang="en">polyphase electrical signal</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2182"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ManualActuator(x) ↔ Actuator(x) ∧ ∃s(ManualControlSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ManualActuator is an actuator that has input ManualControlSignal and has output MechanicalPower</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;MANUAL ACTUATOR&gt; is an &lt;ARTEFACT&gt; and an &lt;ACTUATOR&gt; which action has to be trigged manually</skos:definition>
    <rdfs:label xml:lang="pt-br">atuador manual</rdfs:label>
    <rdfs:label xml:lang="en">manual actuator</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador manual é um atuador que converte entradas de controle operadas por humanos em movimento mecânico ou força através de operação física direta.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de medição de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature measurement process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HumidAirPortion">
    <rdfs:label xml:lang="en">humid air portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção úmido de ar</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226">
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b465"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que é especificamente projetado para acomodar e alojar os mecanismos internos de uma válvula de retenção dentro de uma barreira de contenção de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CHECK VALVE BODY&gt; is a &lt;VALVE BODY&gt; of a check valve</skos:definition>
    <rdfs:label xml:lang="en">check valve body</rdfs:label>
    <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveBody(x) → ValveBody(x) ∧ ∃y(CheckValve(y) ∧ designedFor(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive identity based on structural design for check valve accommodation. Under OWA, any housing designed for check valves could include specialized configurations, custom manifolds, or hybrid designs that should not be automatically classified as standard check valve bodies without domain expert validation of the structural differentia.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CheckValveBody subClassOf ValveBody and (designedFor some CheckValve)</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139">
    <skos:definition xml:lang="en">[CFIHOS] A heat exchanger using plates as the device for separating the two fluids and across which the energy is transferred.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An indirect contact heat exchanger that separates the hot and cold fluids by plates.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PLATE HEAT EXCHANGER&gt; is a &lt;NON-TUBULAR HEAT EXCHANGER&gt; that uses metal plates to transfer heat between two fluids</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2453"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2452"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">plate heat exchanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">trocador de calor de placas</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de placas é um trocador de calor que possui placas de transferência de calor como sua superfície primária de transferência de calor.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PlateHeatExchanger(x) → HeatExchanger(x) ∧ ∃p(HeatTransferPlate(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the plate-based structure is characteristic, under the Open World Assumption, asserting equivalence could lead to false positives where any equipment with heat transfer plates (e.g., specialized hybrid equipment, multi-function process units) would be automatically classified as a standard plate heat exchanger. Domain expert validation is needed to confirm the structural differentia is sufficient.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every plate heat exchanger is a heat exchanger that has component part heat transfer plates at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1427">
    <rdf:first rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1422"/>
    <rdf:rest rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1428"/>
  </rdf:Description>
