    <rdfs:label xml:lang="pt-br">porção de material</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction">
    <rdfs:label xml:lang="en">circuit protection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de proteção de circuito</rdfs:label>
