  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">supporting process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de suporte</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which mechanical loads from attached components or piping are borne by a structural element to maintain their position and integrity.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1759">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1170">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b631">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000356">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2472"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every switch contact is an electrical contact that is part of an electrical contact assembly and bears an electrical conduction function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">switch contact</rdfs:label>
    <rdfs:label xml:lang="pt-br">contato de chave</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um contato de chave é um contato elétrico que é uma das partes condutoras que formam um conjunto de contato.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (SwitchContact(x) → ElectricalContact(x) ∧ ∃y(ElectricalContact(y) ∧ partOf(x,y)) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural role as a conductive part. Under OWA, asserting sufficient conditions could incorrectly classify any conductive part of an electrical contact as a switch contact, when there may be other specialized conductive components (bus bars, terminals, etc.) that serve different structural roles.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2098">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2383">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1600">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DisturbanceSource">
    <skos:definition xml:lang="en">A process in which a source of unwanted perturbation—vibration, electrical noise, or pressure surge—affecting the performance of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <rdfs:label xml:lang="pt-br">fonte de perturbação</rdfs:label>
    <rdfs:label xml:lang="en">disturbance source</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109">
    <rdfs:label xml:lang="pt-br">manômetro de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure gauge</rdfs:label>
    <skos:definition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro de pressão diferencial é um manômetro que mede e indica a diferença entre duas entradas de pressão usando um elemento de medição de pressão diferencial.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b773"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure gauge is a pressure gauge that bears a DifferentialPressureMeasurementFunction and has component parts including a DifferentialPressureMeasuringElement and PressurePortPair.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureGauge(x) ↔ PressureGauge(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(DifferentialPressureMeasuringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(PressurePortPair(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b447">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b445"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b537">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1109">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1110"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1067">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which drilling fluid is circulated from the surface to the drill bit and returned through the wellbore annulus to remove cuttings and cool the bit.</skos:definition>
    <rdfs:label xml:lang="en">drilling fluid conduction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de condução de fluido de perfuração</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Port ≡ MaterialArtifact ⊓ ∃bearerOf.InterfacingFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Port(x) ↔ (MaterialArtifact(x) ∧ ∃f(InterfacingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">port</rdfs:label>
    <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma InterfacingFunction e</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma InterfacingFunction e que é capaz de fornecer um ponto de interface para comunicação com outro objeto.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2019"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1844">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceMeasurementProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2438">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StorageProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyPortion">
    <rdfs:label xml:lang="en">mechanical energy portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção mecânico de energia</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a quantity of mechanical energy—kinetic or potential—present in a component or fluid of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000348">
    <skos:definition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every shear ram is a ram that has the function to shear pipe and has shearing blades as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">aríete de corte</rdfs:label>
    <rdfs:label xml:lang="en">shear ram</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aríete de corte é um aríete que possui função de corte de tubulação e tem lâminas de corte endurecidas projetadas para cortar a coluna de perfuração ou tubulação durante operações de prevenção de blowout.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ShearRam(x) ↔ Ram(x) ∧ ∃f(PipeShearingFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ShearingBlade(b) ∧ hasComponentPartAtAllTimes(x,b)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2345"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b309">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CableSupportFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2749">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b866">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b864"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess">
    <rdfs:label xml:lang="en">chromatographic analysis process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de análise cromatográfica</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the chemical components of a sample are separated and quantified by their differential migration through a stationary phase in petroleum production instrumentation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ThermalEnergy">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">energia térmico</rdfs:label>
    <rdfs:label xml:lang="en">thermal energy</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes thermal energy transferred between a process stream and heat exchange surfaces of petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000296">
    <skos:definition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1461"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma mangueira é um tubo flexível projetado para conduzir líquidos sob pressão enquanto acomoda movimento posicional e flexão.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">mangueira</rdfs:label>
    <rdfs:label xml:lang="en">hose</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hose is a pipe that has flexibility and is capable of conducting liquids under pressure.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical properties (flexibility). Under OWA, asserting equivalence would force any artifact with flexibility and pressure capability to be classified as a hose, potentially including complex equipment with flexible components that should not be categorized as standard hoses.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Hose(x) → Pipe(x) ∧ ∃q(Flexibility(q) ∧ hasQuality(x,q)) ∧ ∃c(PressurizedFluidConduction(c) ∧ capableOf(x,c)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b720">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b780"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b770"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b769"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b779"/>
    <rdfs:label xml:lang="pt-br">função de medição de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure measurement function</rdfs:label>
    <skos:definition xml:lang="en">A PressureSensingFunction that is realized in a DifferentialPressureMeasurementProcess and that consists in sensing the pressure difference between two fluid media or two points in the same medium to enable measurement of differential pressure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PressureSensingFunction that is realized in a DifferentialPressureMeasurementProcess and that consists in sensing the pressure difference between two fluid media or two points in the same medium to enable measurement of differential pressure.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b538"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b539"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the regulation of a process variable by adjusting a manipulated variable in response to a measured deviation from a set point.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de controle</rdfs:label>
    <rdfs:label xml:lang="en">control function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1076">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1077"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b783">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b785"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2398">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1331">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LoggingData">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <skos:definition xml:lang="en">An information content entity constituting data acquired by measurement tools deployed in a wellbore to characterise subsurface formation properties.</skos:definition>
    <rdfs:label xml:lang="en">logging data</rdfs:label>
    <rdfs:label xml:lang="pt-br">dados de perfilagem</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b779">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155">
    <skos:definition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de temperatura é um transmissor que mede temperatura e produz um sinal de saída padronizado dependente do sinal de entrada recebido de um elemento de temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureTransmitter(x) ↔ Transmitter(x) ∧ ∃f(TemperatureMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">temperature transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de temperatura</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature transmitter is a transmitter that has the function to measure temperature and transmit standardized signals based on temperature input.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2533"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which subsurface rock at the bottom of a wellbore is cut and disintegrated by a drill bit to advance the drill hole.</skos:definition>
    <rdfs:label xml:lang="en">bottom hole drilling process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de perfuração de fundo de poço</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubeBundle">
    <rdfs:label xml:lang="en">tube bundle</rdfs:label>
    <rdfs:label xml:lang="pt-br">feixe de tubo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An assembly of heat transfer tubes, baffles, and tube sheets that forms the core of a shell-and-tube heat exchanger in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b446">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b447"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Panel">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">panel</rdfs:label>
    <rdfs:label xml:lang="pt-br">painel</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a flat structural panel that provides a mounting surface for instrumentation, controls, or electrical equipment in a petroleum production installation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1720"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1721"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of a mechanical force or pressure into a proportional electrical signal.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de transdução força-elétrica</rdfs:label>
    <rdfs:label xml:lang="en">force to electrical transduction function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2357">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1545">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2473"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2474"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the switching, routing, or regulation of current in an electrical circuit to control connected loads.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de controle de circuito elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electrical circuit control function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbineSection">
    <rdfs:label xml:lang="pt-br">seção de turbina</rdfs:label>
    <rdfs:label xml:lang="en">turbine section</rdfs:label>
    <skos:definition xml:lang="en">An assembly of rotor blades, stator vanes, and casing components that extracts energy from a fluid stream in a turbine stage of petroleum production turbomachinery.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2065">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureSensingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2683">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DistillationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201">
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a TemperatureSensorProtectionProcess and that consists in providing a protective enclosure for temperature sensing elements while enabling thermal conductivity from the process medium to the sensor.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2547"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2555"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2554"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2546"/>
    <rdfs:label xml:lang="en">temperature sensor protection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de proteção de sensor de temperatura</rdfs:label>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a TemperatureSensorProtectionProcess and that consists in providing a protective enclosure for temperature sensing elements while enabling thermal conductivity from the process medium to the sensor.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b780">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1140">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b817">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b818"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2059">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which fluid enthalpy is converted into shaft power through the interaction of a fluid stream with rotating turbine blades.</skos:definition>
    <rdfs:label xml:lang="en">turbomachinery power generation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de geração de energia por turbomáquina</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b996">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1263">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DriveShaft ≡ Assembly ⊓ ∃bearerOf.PowerTransmissionFunction ⊓ ∃participatesIn.RotationalPowerTransferProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">drive shaft</rdfs:label>
    <rdfs:label xml:lang="pt-br">eixo de transmissão</rdfs:label>
    <skos:definition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de transmissão é um Assembly que possui uma PowerTransmissionFunction e consiste em um sistema baseado em eixo usado para transferir energia mecânica rotacional de um motor primário para múltiplas máquinas acionadas.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DriveShaft(x) ↔ (Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(RotationalPowerTransferProcess(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b877"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AgitationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a liquid is mechanically stirred or agitated to promote mixing, heat transfer, or suspension of solids in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de agitação</rdfs:label>
    <rdfs:label xml:lang="en">agitation process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2235">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b992">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealedJoint">
    <rdfs:label xml:lang="en">sealed joint</rdfs:label>
    <rdfs:label xml:lang="pt-br">junta selado</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a joint between two components in petroleum production equipment that is sealed to prevent leakage of process fluid.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2223">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1262">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1264"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2747">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DriedMaterial">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">dried material</rdfs:label>
    <rdfs:label xml:lang="pt-br">material seco</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a material from which moisture or solvent has been removed by a drying process in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1528">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2162">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1682">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118">
    <skos:definition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de fluxo é um transmissor que produz sinais de saída padronizados proporcionais às medições de fluxo provenientes de elementos sensores de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FlowTransmitter(x) ↔ Transmitter(x) ∧ ∃f(FlowSignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(FlowMeasurement(m) ∧ hasInput(x,m)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">flow transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de fluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1227"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow transmitter is a transmitter that has the function of transmitting flow signals and has as input flow measurements.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SideOutlet">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a lateral outlet port on a vessel or pipe fitting through which fluid is discharged from the side of the equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">saída lateral</rdfs:label>
    <rdfs:label xml:lang="en">side outlet</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b617"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b616"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of dissolved or entrained gases from a liquid to reduce their concentration.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de degaseificação</rdfs:label>
    <rdfs:label xml:lang="en">degassing function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b939">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b941"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000088">
    <skos:definition xml:lang="en">A material artifact that bears a binary flow control function whose realization constitutes the complete opening or closing of a flow path to isolate a process segment in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">válvula de isolamento</rdfs:label>
    <rdfs:label xml:lang="en">isolation valve</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationProcess">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <rdfs:label xml:lang="pt-br">processo de separação knock-out</rdfs:label>
    <rdfs:label xml:lang="en">knock out separation process</rdfs:label>
    <skos:definition xml:lang="en">A separation process in which entrained liquid droplets are removed from a gas stream by gravity or inertial impingement in a knockout vessel.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1438">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteCombustionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">waste combustion process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de combustão de resíduos</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which waste gases, liquids, or solids are thermally destroyed by controlled combustion in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2590">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2588"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1703"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1704"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the detection of a mechanical component reaching a defined travel limit position.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de detecção de limite de posição</rdfs:label>
    <rdfs:label xml:lang="en">position limit detection function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2765">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000295">
    <skos:definition xml:lang="en">A hopper is a vessel that is designed to store solid materials and dispense them through a controlled discharge opening.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hopper is a vessel that bears a SolidStorageAndDispensingFunction and has a SolidDischargeOpening as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hopper is a vessel that is designed to store solid materials and dispense them through a controlled discharge opening.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um hopper é um vaso projetado para armazenar materiais sólidos e dispensá-los através de uma abertura de descarga controlada.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Hopper(x) ↔ (Vessel(x) ∧ ∃f(SolidStorageAndDispensingFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SolidDischargeOpening(p) ∧ hasComponentPartAtAllTimes(x,p))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">hopper</rdfs:label>
    <rdfs:label xml:lang="en">hopper</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1453"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationBearingArtifact">
    <rdfs:label xml:lang="en">information bearing artifact</rdfs:label>
    <rdfs:label xml:lang="pt-br">artefato de informação de mancal</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that bears information—in the form of a signal, display, or record—representing a process variable or equipment state in petroleum production systems.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipelinePig">
    <rdfs:label xml:lang="en">pipeline pig</rdfs:label>
    <rdfs:label xml:lang="pt-br">pig de pipeline</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a device inserted into and propelled through a pipeline to perform internal inspection, cleaning, or gauging operations.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1564">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1562"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2794">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellheadSpool"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2523">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChemicalFuelPortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of chemical fuel consumed in a combustion process in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">chemical fuel portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção químico de combustível</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000377">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cabeçal de poço é um conjunto que porta uma função de controle superficial do poço e fornece a interface estrutural e de controle entre um poço e os equipamentos de superfície.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">cabeçal de poço</rdfs:label>
    <rdfs:label xml:lang="en">wellhead</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellhead(x) ↔ Assembly(x) ∧ ∃f(WellSurfaceControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃h(CasingHanger(h) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃w(Wellbore(w) ∧ hasConnectionTo(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellhead is an assembly that bears a well surface control function and has component parts including casing hangers and connection to wellbore</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2792"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1068">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1069"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator">
    <skos:definition xml:lang="en">A material artifact that constitutes a component that displays and enables adjustment of a set point or control parameter in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">control indicator</rdfs:label>
    <rdfs:label xml:lang="pt-br">indicador de controle</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the instantaneous flow rate of a process stream is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de indicação de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow indication process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasuringElement">
    <rdfs:label xml:lang="pt-br">elemento de medição</rdfs:label>
    <rdfs:label xml:lang="en">measuring element</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a primary measurement element within petroleum production instrumentation that directly responds to the measured variable.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2187">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2189"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1727">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1725"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction">
    <rdfs:label xml:lang="en">cooling function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de resfriamento</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b563"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b551"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b550"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b564"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of thermal energy from a process stream or equipment component to reduce its temperature.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000320">
    <skos:definition xml:lang="en">A pig trap is an assembly that bears the function of launching and receiving pipe pigs for pipeline maintenance and has both launcher and receiver components.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma armadilha de pig é um conjunto que possui a função de lançar e receber pigs de tubulação para manutenção de dutos e possui componentes de lançador e receptor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig trap is an assembly that bears the function of launching and receiving pipe pigs for pipeline maintenance and has both launcher and receiver components.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig trap is an assembly that bears a pig launching and receiving function and has component parts that are a pig launcher and a pig receiver.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">armadilha de pig</rdfs:label>
    <rdfs:label xml:lang="en">pig trap</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PigTrap(x) ↔ Assembly(x) ∧ ∃f(PigLaunchingAndReceivingFunction(f) ∧ bearerOf(x,f)) ∧ ∃l(PigLauncher(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃r(PigReceiver(r) ∧ hasComponentPartAtAllTimes(x,r)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1886"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which pressure within a process system is discharged at an accelerated rate to a safe destination in an emergency.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de despressurização rápida</rdfs:label>
    <rdfs:label xml:lang="en">rapid depressurization process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DistillationFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2682"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b831"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2683"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b832"/>
    <rdfs:label xml:lang="pt-br">função de destilação</rdfs:label>
    <rdfs:label xml:lang="en">distillation function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the separation of a liquid mixture into fractions of differing volatilities by successive vaporisation and condensation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b730">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlexibleDiaphragm"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2673">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/UninterruptedPowerSupplyFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2301">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShearingBlade">
    <rdfs:label xml:lang="en">shearing blade</rdfs:label>
    <rdfs:label xml:lang="pt-br">lâmina de cisalhamento</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the cutting blade of a shear ram in a blowout preventer that severs a tubular string for well control purposes.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b334">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b331"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b335"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula agulha é uma válvula que possui um membro de fechamento cônico em forma de agulha que se assenta em um pequeno orifício para fornecer controle preciso de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1803"/>
    <rdfs:label xml:lang="pt-br">válvula agulha</rdfs:label>
    <rdfs:label xml:lang="en">needle valve</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every needle valve is a valve that has a needle plug component and has a small orifice seat component.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(NeedleValve(x) → Valve(x) ∧ ∃y(NeedlePlug(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(SmallOrificeSeat(z) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by specific structural features (needle plug geometry), providing sufficient conditions under the Open World Assumption could lead to over-classification. Complex valve assemblies or custom equipment containing needle-like mechanisms might be incorrectly classified as standard needle valves for maintenance purposes.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b351">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
  </rdf:Description>
