    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2371"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b808">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b809"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WeightOnBit">
    <rdfs:label xml:lang="pt-br">broca de peso de em</rdfs:label>
    <rdfs:label xml:lang="en">weight on bit</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting the compressive force applied to the drill bit through the drill string during a drilling operation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1347">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteGasPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção de resíduo de gás</rdfs:label>
    <rdfs:label xml:lang="en">waste gas portion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of waste or surplus gas generated in petroleum production operations that is directed to disposal equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2070">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2071"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1933">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1583">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b557">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1186">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingString">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:label xml:lang="en">tubing string</rdfs:label>
    <rdfs:label xml:lang="pt-br">coluna de coluna de produção</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the continuous string of tubing that conveys production fluids from the wellbore to the surface or delivers injection fluids downhole.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b637">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000140">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1982"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1981"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula plug é uma válvula que possui um elemento de fechamento em forma de plugue cilíndrico ou cônico que opera por rotação de um quarto de volta em seu eixo para controlar o fluxo de fluido selando contra um assento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">válvula plug</rdfs:label>
    <rdfs:label xml:lang="en">plug valve</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification requires necessary conditions only. Under OWA, any artifact with a plug closure and quarter-turn mechanism would be forcibly classified as a plug valve, but specialized multi-port valves or custom manifolds containing plug mechanisms should not automatically inherit the standard plug valve classification without domain expert validation.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every plug valve is a valve that has a plug closure component and participates in quarter-turn rotation processes</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PlugValve(x) → Valve(x) ∧ ∃p(PlugClosure(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃r(QuarterTurnRotationProcess(r) ∧ participatesIn(x,r)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115">
    <iof-av:naturalLanguageDefinition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ventilador é um conjunto que possui uma função de movimentação de gás para fornecer ou exaurir volumes de vapor ou gás com baixa pressão diferencial.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">ventilador</rdfs:label>
    <rdfs:label xml:lang="en">fan</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every fan is an assembly that bears a gas movement function, and every assembly that bears a gas movement function is a fan.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b995"/>
    <skos:definition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Fan(x) ↔ (Assembly(x) ∧ ∃f(GasMovementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1169">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoolantPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção de refrigerante</rdfs:label>
    <rdfs:label xml:lang="en">coolant portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of cooling medium used to remove thermal energy from a process stream or equipment component.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CableSupportFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b305"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b304"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de suporte de cabos</rdfs:label>
    <rdfs:label xml:lang="en">cable support function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical support and routing of cables to maintain their position and protect them from damage.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2285">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ExhaustGasPortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of exhaust gas at a defined point in the exhaust system of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção de escapamento de gás</rdfs:label>
    <rdfs:label xml:lang="en">exhaust gas portion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FilterMedium">
    <skos:definition xml:lang="en">A material artifact that constitutes the porous material through which a fluid stream passes to remove suspended particulates or liquid droplets in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">filter medium</rdfs:label>
    <rdfs:label xml:lang="pt-br">meio de filtro</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalRelayProcess">
    <rdfs:label xml:lang="en">signal relay process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de retransmissão de sinal</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which a control or monitoring signal is received and re-transmitted to extend its range or provide electrical isolation between circuits.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1060"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1059"/>
    <skos:definition xml:lang="en">A heating function borne by petroleum production equipment whose realization constitutes the transfer of thermal energy generated by combustion to a process stream or vessel.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de aquecimento a combustão</rdfs:label>
    <rdfs:label xml:lang="en">fired heating function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationSignal">
    <rdfs:label xml:lang="pt-br">sinal de informação</rdfs:label>
    <rdfs:label xml:lang="en">information signal</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting a signal carrying informational content such as a measurement value or status indication within petroleum production instrumentation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2776">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2777"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HumidAirPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">humid air portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção úmido de ar</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of air carrying a significant concentration of water vapour in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2795">
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2796"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b163">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1690">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1692"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b428">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChromatographicAnalysisProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2389">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2387"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1951">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1954"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124">
    <skos:definition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</skos:definition>
    <rdfs:label xml:lang="en">heater</rdfs:label>
    <rdfs:label xml:lang="pt-br">aquecedor</rdfs:label>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1442"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heater is an assembly that bears a heating function and has heating elements and housing as component parts at all times</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Heater(x) ↔ Assembly(x) ∧ ∃f(HeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionFunction">
    <rdfs:label xml:lang="pt-br">função de extração de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy extraction function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the recovery of useful work or heat from a process stream, pressure differential, or thermal source.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2638"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2639"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidDistributionFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1737"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1738"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1415"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1414"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the splitting and delivery of a fluid stream to multiple downstream points in defined proportions.</skos:definition>
    <rdfs:label xml:lang="en">fluid distribution function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de distribuição de fluido</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess">
    <skos:definition xml:lang="en">A planned process in which liquid at the base of a distillation column is partially vaporised by the supply of heat to drive vapour upward through the column.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de refervimento</rdfs:label>
    <rdfs:label xml:lang="en">reboiling process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312">
    <skos:definition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador manual é um atuador que converte entradas de controle operadas por humanos em movimento mecânico ou força através de operação física direta.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ManualActuator(x) ↔ Actuator(x) ∧ ∃s(ManualControlSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">manual actuator</rdfs:label>
    <rdfs:label xml:lang="pt-br">atuador manual</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1748"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ManualActuator is an actuator that has input ManualControlSignal and has output MechanicalPower</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess">
    <skos:definition xml:lang="en">A planned process in which a flow path is automatically opened to discharge fluid when process pressure exceeds a defined set point, protecting equipment from overpressure.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pressure relief process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de alívio de pressão</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b759">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">control process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de controle</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a process variable is regulated by adjusting a manipulated variable in response to a measured deviation from a set point.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2536">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2534"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1553">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1551"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b991">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasMovementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction">
    <rdfs:label xml:lang="pt-br">função de transmissão de múltiplos serviços</rdfs:label>
    <rdfs:label xml:lang="en">multi service transmission function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2653"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2654"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the simultaneous measurement and transmission of multiple process variables to a remote control or monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CooledHeatingMedium">
    <rdfs:label xml:lang="en">cooled heating medium</rdfs:label>
    <rdfs:label xml:lang="pt-br">meio de resfriado de aquecimento</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a heating medium that has transferred thermal energy to a process stream and returned to a lower temperature.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b332">
