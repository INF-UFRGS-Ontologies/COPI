  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1038">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
