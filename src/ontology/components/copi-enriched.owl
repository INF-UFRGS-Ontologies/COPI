  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371">
    <iof-av:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que é parte de uma válvula e que fornece a superfície de assentamento contra a qual o membro de fechamento se apoia para alcançar o fechamento e controle do fluxo de fluido de processo.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">assento de válvula</rdfs:label>
    <rdfs:label xml:lang="en">valve seat</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ValveSeat ⊑ MaterialArtifact ⊓ ∃partOf.Valve ⊓ ∃adjacentTo.ValveClosureMember ⊓ ∃bearerOf.SealingSurfaceQuality</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3343"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ValveSeat(x) → (MaterialArtifact(x) ∧ ∃y(Valve(y) ∧ partOf(x,y)) ∧ ∃z(ValveClosureMember(z) ∧ adjacentTo(x,z)) ∧ ∃q(SealingSurfaceQuality(q) ∧ bearerOf(x,q))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VALVE SEAT&gt; is a &lt;VALVE COMPONENT&gt; that is the part of a valve against which the closure member bears to provide shut-off and throughput of process fluids flows</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Valve seat is a constructive type defined by its structural configuration and interface role. Under the Open World Assumption, making this an equivalence class could lead to false positives where any artifact that is part of a valve and adjacent to a closure member gets classified as a valve seat, even if it serves a different structural role (such as guides, stops, or supports).</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSensingElement">
    <rdfs:label xml:lang="pt-br">elemento de fluxo de sensoriamento</rdfs:label>
    <rdfs:label xml:lang="en">flow sensing element</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033"/>
    <rdfs:label xml:lang="en">binary flow control process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de controle binário de fluxo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245">
    <iof-av:naturalLanguageDefinition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um densitômetro é um instrumento que possui uma função de medição de densidade.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">densitômetro</rdfs:label>
    <rdfs:label xml:lang="en">densitometer</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[SLB Glossary] A device installed on a mixing or pumping system manifold to measure the density of fluids.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DENSITOMETER&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;MEASURING INSTRUMENT&gt; that measures the degree of darkness in photographic or semitransparent material. The densitometer is basically a light source aimed at a photoelectric cell which determines the density of the sample from differences in the readings</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A device used for reading the density of a flowing fluid or slurry.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every densitometer is an instrument that has the function of measuring density.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b866"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3167">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SensingElement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigReceivingFunction">
    <rdfs:label xml:lang="en">pig receiving function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de recebimento de pig</rdfs:label>
