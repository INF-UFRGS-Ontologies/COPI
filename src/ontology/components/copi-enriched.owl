  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER ELEMENT&gt; is a &lt;FILTER&gt; and that is the part of a filter assembly that is made from filter media</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FilterElement(x) → Filter(x) ∧ ∃m(FilterMedia(m) ∧ madeFrom(x,m)) ∧ ∃a(FilterAssembly(a) ∧ componentPartOf(x,a)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1312"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">FilterElement SubClassOf Filter and (madeFrom some FilterMedia) and (componentPartOf some FilterAssembly)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Filtro que é feito de meio filtrante e que é uma parte componente de um conjunto de filtro.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">elemento filtrante</rdfs:label>
    <rdfs:label xml:lang="en">filter element</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on material composition (filter media) and mereological relationship (component of assembly). Under OWA, asserting equivalence could lead to unintended classification of any artifact made from filter media as a filter element, including specialized or hybrid components that contain filter media but serve different primary functions.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb874">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Sensor"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2383">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Closure"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000244">
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to catch fluid droplets.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEMISTER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEMISTING&gt;</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um demister é um separador que possui uma função de desmistificação para remover gotículas de líquido de correntes gasosas através de mecanismos de coalescência.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb854"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every demister is a separator that has the function of demisting gas streams by coalescing and removing entrained liquid droplets.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">demister</rdfs:label>
    <rdfs:label xml:lang="en">demister</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Demister(x) ↔ Separator(x) ∧ ∃f(DemistingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction">
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb619"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb620"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de condensação</rdfs:label>
    <rdfs:label xml:lang="en">condensation function</rdfs:label>
  </rdf:Description>
