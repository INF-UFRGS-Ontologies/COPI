  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000256">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um diverter é um artefato material que possui uma função projetada para desviar ou redirecionar materiais, fluidos ou fluxos de seu curso esperado para caminhos ou destinos alternativos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diverter is a material artifact that bears a designed function to divert or redirect materials, fluids, or flows from their expected course to alternative paths or destinations.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[SLB Glossary] A chemical agent or mechanical device used in injection treatments, such as matrix stimulation, to ensure a uniform distribution of treatment fluid across the treatment interval.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A 'device' that is providing diversion of something from an expected course or direction.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIVERTER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;DIVERTING&gt;</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] In the context of acidizing, a diverter is a material that forces acid to enter another zone by having a higher viscosity or building a filter cake.                  In the context of a wellhead, a diverter is a device in the flowpath at the wellhead that forces fluid to go down a pipe to a pit or tank.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diverter is a material artifact that has the function of diverting materials or flows from expected paths to alternative destinations.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Diverter(x) ↔ MaterialArtifact(x) ∧ ∃f(DivertingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">diverter</rdfs:label>
    <rdfs:label xml:lang="en">diverter</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1079"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1628">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2050">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransferBundle"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000272">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um detector de chama é um detector que tem a função de detectar a presença de chamas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flame detector is a detector that has the function to detect the presence of flames.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">detector de chama</rdfs:label>
    <rdfs:label xml:lang="en">flame detector</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1377"/>
    <skos:definition xml:lang="en">[CFIHOS] A detector that is intended to sense a flame.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A detector that is intended to sense a flame.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLAME DETECTOR&gt; is a &lt;DETECTOR&gt; and a &lt;FLAME DETECTING INSTRUMENT&gt; using a &lt;FLAME DETECTING MEASURING ELEMENT&gt; that is designed to detect the presence of a flame</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlameDetector(x) ↔ Detector(x) ∧ ∃f(FlameDetectionFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flame detector is a detector that has a flame detection function, and every detector that has a flame detection function is a flame detector.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2447">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RunPort"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSwitchingFunction">
    <rdfs:label xml:lang="en">flow switching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de chaveamento de fluxo</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1544"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1545"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000254">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Display is an Instrument that necessarily bears an InformationDisplayFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">display</rdfs:label>
    <rdfs:label xml:lang="en">display</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Display(x) ↔ Instrument(x) ∧ ∃f(InformationDisplayFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Display é um Instrumento que possui uma InformationDisplayFunction e que apresenta informações visualmente para operadores ou usuários.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DISPLAY&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DISPLAYING&gt; something</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A physical object that is intended for presenting information.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1047"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
