  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'PT'. First letter 'P': Pressure. Succeeding letters: 'T' = Transmit.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PRESSURE TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;PRESSURE MEASURING INSTRUMENT&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a pressure element.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão é um transmissor que converte medições de pressão em sinais de saída padronizados para transmissão a sistemas de controle ou monitoramento.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pressure transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de pressão</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2657"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure transmitter is a transmitter that has the function to transmit pressure measurement signals.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(PressureTransmissionFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1990">
