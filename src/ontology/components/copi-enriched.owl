    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressorInternals">
    <skos:definition xml:lang="en">A material artifact that constitutes the internal components—such as impellers, valves, and seals—contained within the casing of a compressor in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">internos de compressor</rdfs:label>
    <rdfs:label xml:lang="en">compressor internals</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
    <skos:definition xml:lang="en">A heating process in which thermal energy is generated by the combustion of fuel and transferred to a process stream or vessel through a fired heater.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">fired heating process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de aquecimento a combustão</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162">
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1828"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
    <rdfs:subClassOf rdf:nodeID="n55b6dbcc703c488db80806efee5015fab1827"/>
    <rdfs:label xml:lang="en">binary flow control function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de controle binário de fluxo</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the complete opening or closing of a flow path to allow or prevent fluid passage.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab811">
    <rdf:rest rdf:nodeID="n55b6dbcc703c488db80806efee5015fab812"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
  </rdf:Description>
