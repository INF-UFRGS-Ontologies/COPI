  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114">
    <skos:definition xml:lang="en">[CFIHOS] A valve that is assigned to act in case of emergency.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;EMERGENCY SHUT DOWN VALVE&gt; is an &lt;ACTUATED VALVE&gt; that is assigned to act in case of emergency</skos:definition>
    <rdfs:label xml:lang="pt-br">válvula de parada de emergência</rdfs:label>
    <rdfs:label xml:lang="en">emergency shut down valve</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every emergency shut down valve is a valve that has an emergency shut down function and has an actuator and has a fail-safe system.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1219"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de parada de emergência é uma válvula que possui uma função de parada de emergência, permitindo o isolamento rápido de fluxo em situações de emergência através de mecanismos atuados com capacidade à prova de falhas.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (EmergencyShutDownValve(x) ↔ (Valve(x) ∧ ∃f(EmergencyShutDownFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b164">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AllDisjointClasses"/>
    <owl:members rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b165"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that adds or removes mechanical energy to a fluid, either constantly or periodically.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PUMP&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;PUMPING&gt; but may require parts and subsystems for that capability; including those turns it into a &lt;PUMP SYSTEM&gt;</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] A machine that is capable of pumping but may require parts and subsystems for that capability.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] IMF purpose entity</skos:definition>
    <rdfs:label xml:lang="pt-br">bomba</rdfs:label>
    <rdfs:label xml:lang="en">pump</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba é um conjunto que possui a função projetada de adicionar energia mecânica ao fluido para pressurização e transporte.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Pump(x) ↔ (Assembly(x) ∧ ∃f (PumpingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2682"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump is an assembly that has the function of pumping fluid</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
