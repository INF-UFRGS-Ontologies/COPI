  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentFunction">
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3004"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3005"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">stationary machine component function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de componente estacionário de máquina</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a StationaryMachineComponentProcess and that consists in providing a stationary structural foundation and housing for active elements (such as windings, vanes, or seals) within rotating machinery, maintaining positional stability relative to moving components.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementProcess">
    <rdfs:label xml:lang="en">density measurement process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de medição de densidade</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1593">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FuseElement"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEADER&gt; is an &lt;ARTEFACT&gt; and a &lt;PIPING NETWORK SEGMENT&gt; that is pipe or manifold that is used to collect the discharge from many smaller pipes (a collecting header) , or can be used to distribute fluid to many smaller pipes (distributing header)</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The location, acquisition and processing parameters, and other pertinent information attached to a well log, seismic record and traces.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Header(x) ↔ (manifold(x) ∧ ∃y(SmallPipe(y) ∧ connects_to(x,y)) ∧ ∃z(MultiStreamDistributionProcess(z) ∧ participatesIn(x,z))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um header é um manifold que se conecta a muitos tubos menores para coletar descarga de múltiplas fontes ou distribuir fluido para múltiplos destinos.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Header ≡ manifold ⊓ ∃connects_to.SmallPipe ⊓ ∃participatesIn.MultiStreamDistributionProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">header</rdfs:label>
    <rdfs:label xml:lang="pt-br">header</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1780"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124">
    <skos:definition xml:lang="en">[DEXPI] An apparatus or machine that has the capability of heating.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] Equipment that transfers heat to the produced gas stream.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEATER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;HEATING&gt;</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every heater is an assembly that bears a heating function and has heating elements and housing as component parts at all times</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">aquecedor</rdfs:label>
    <rdfs:label xml:lang="en">heater</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Heater(x) ↔ Assembly(x) ∧ ∃f(HeatingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1811"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b411">
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b412"/>
    <rdf:first rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b407"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000224">
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing that is specifically designed and dimensioned for structural compatibility with centrifugal compressor mechanisms, providing enclosure and protection for rotating impellers and associated flow components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que é especificamente projetado e dimensionado para compatibilidade estrutural com mecanismos de compressor centrífugo, fornecendo contenção e proteção para impulsores rotativos e componentes de fluxo associados.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalCompressorCasing(x) → Casing(x) ∧ ∃y(CentrifugalCompressor(y) ∧ intendedFor(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal compressor casing is a casing that is intended for use with centrifugal compressors</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CENTRIFUGAL COMPRESSOR CASING&gt; is a &lt;COMPRESSOR CASING&gt; that is intended to be used for a centrifugal compressor.</skos:definition>
    <rdfs:label xml:lang="en">centrifugal compressor casing</rdfs:label>
    <rdfs:label xml:lang="pt-br">invólucro</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural compatibility. Under OWA, asserting equivalence could force classification of any casing with centrifugal compressor compatibility, including hybrid or specialized equipment that should not be automatically classified as standard centrifugal compressor casings.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b424"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266">
    <iof-av:primitiveRationale xml:lang="en">Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">cartucho de filtro</rdfs:label>
    <rdfs:label xml:lang="en">filter cartridge</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[CFIHOS] A filter element intended to collect particles from a stream in a filter or strainer.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER CARTRIDGE&gt; is an &lt;ARTEFACT&gt; and a &lt;FILTER ELEMENT&gt; intended to collect particles from a stream in a filter or strainer</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A filter element intended to collect particles from a stream in a filter or strainer.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1291"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1290"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1292"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
