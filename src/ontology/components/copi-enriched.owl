  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b609">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalCircuitControlFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the switching, routing, or regulation of current in an electrical circuit to control connected loads.</skos:definition>
    <rdfs:label xml:lang="pt-br">função de controle de circuito elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electrical circuit control function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3032"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3033"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">flash vaporization process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de vaporização flash</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a pressurised liquid stream is partially vaporised as a result of a rapid reduction in pressure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BRAKE">
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1384">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1379"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1385"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasOutlet">
    <skos:definition xml:lang="en">A material artifact that constitutes an outlet port through which gas leaves a separator, vessel, or piece of petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">gas outlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">saída de gás</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidOutlet"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction">
    <rdfs:label xml:lang="en">density measurement function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de medição de densidade</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the mass per unit volume of a fluid stream or substance.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b846"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b847"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1975">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000213">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b132"/>
    <skos:definition xml:lang="en">An axial displacement transmitter is a transmitter that measures axial displacement and generates a standardized output signal representing the measured axial displacement.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de deslocamento axial é um transmissor que mede deslocamento axial e gera um sinal de saída padronizado representando o deslocamento axial medido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An axial displacement transmitter is a transmitter that measures axial displacement and generates a standardized output signal representing the measured axial displacement.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">transmissor de deslocamento axial</rdfs:label>
    <rdfs:label xml:lang="en">axial displacement transmitter</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(AxialDisplacementTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(AxialDisplacementTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(AxialDisplacementMeasuringProbe(p) ∧ hasComponentPartAtAllTimes(x,p))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every axial displacement transmitter is a transmitter that has the function to measure axial displacement and has as component part an axial displacement measuring probe.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1641">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b533">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b527"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b534"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2375">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BentPipeSection"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000292">
    <rdfs:label xml:lang="pt-br">separador gravitacional</rdfs:label>
    <rdfs:label xml:lang="en">gravity separator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GravitySeparator(x) ↔ Separator(x) ∧ ∃f(GravitySeparationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A gravity separator is a separator that performs separation based on differences in specific gravity of the substances being separated.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1744"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gravity separator is a separator that bears a GravitySeparationFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um separador gravitacional é um separador que realiza separação baseada nas diferenças de gravidade específica das substâncias sendo separadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gravity separator is a separator that performs separation based on differences in specific gravity of the substances being separated.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1506">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess"/>
