  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112">
    <rdfs:label xml:lang="en">down hole safety valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de segurança de fundo de poço</rdfs:label>
    <skos:definition xml:lang="en">[CFIHOS] A valve that is intended for subsurface control/check operation.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DOWN HOLE SAFETY VALVE&gt; is a &lt;SAFETY VALVE&gt; that is intended for subsurface control/check operation</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DownHoleSafetyValve(x) ↔ SafetyValve(x) ∧ ∃f(SubsurfaceSafetyFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SubsurfaceOperationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every down hole safety valve is a safety valve that bears a SubsurfaceSafetyFunction and participates in SubsurfaceOperationProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</iof-av:naturalLanguageDefinition>
