  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of the temperature at which a gas mixture begins to condense.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b704"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b703"/>
    <rdfs:label xml:lang="pt-br">função de medição de ponto de orvalho</rdfs:label>
    <rdfs:label xml:lang="en">dew point measurement function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalSwitch">
    <skos:definition xml:lang="en">A material artifact that constitutes a device that opens or closes an electrical circuit in response to a manual or automatic input in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">electrical switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">interruptor elétrico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000277">
    <skos:definition xml:lang="en">A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement.</skos:definition>
    <rdfs:label xml:lang="en">flexible riser</rdfs:label>
    <rdfs:label xml:lang="pt-br">riser flexível</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um riser flexível é um riser que possui construção de material flexível permitindo condução de fluido vertical ou quase vertical entre o fundo do mar e a superfície, acomodando o movimento da embarcação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlexibleRiser(x) → Riser(x) ∧ ∃q(FlexibleProperty(q) ∧ hasQuality(x,q)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where flexibility is a material/structural property. Under OWA, asserting equivalence would force any pipe with flexible qualities to be classified as a flexible riser, even if it serves different functions or has different deployment contexts. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1162"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flexible riser is a riser that has a flexible property</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingProcess">
    <skos:definition xml:lang="en">A planned process in which a discrete switching signal is generated when the differential pressure between two process points crosses a defined threshold.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de chaveamento por pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure switching process</rdfs:label>
  </rdf:Description>
