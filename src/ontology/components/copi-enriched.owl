  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wafer check valve is a check valve that has a wafer pattern valve body as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">válvula de retenção wafer</rdfs:label>
    <rdfs:label xml:lang="en">wafer check valve</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(WaferCheckValve(x) → CheckValve(x) ∧ ∃y(WaferPatternValveBody(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive subtype (both functional and structural aspects). The wafer pattern mounting configuration is a structural differentia that, while characteristic, may have edge cases or specialized variants that should not be automatically classified without expert validation. The structural differentia should be confirmed as both necessary and sufficient in industrial practice before upgrading to equivalent mode.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2769"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1187"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1164"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1182"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1825"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1183"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1824"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1188"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1163"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b577"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b576"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FlowMeasurementProcess and that consists in determining and quantifying the rate of fluid flow through a system, providing measurement data for monitoring, control, or recording purposes.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">função de medição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow measurement function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b940">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingProcess">
    <rdfs:label xml:lang="pt-br">processo de bombeamento hidráulico</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic pumping process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A pumping process in which mechanical energy is imparted to a hydraulic fluid to transmit power or actuate hydraulic equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction">
    <rdfs:label xml:lang="en">reactive heating function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de aquecimento reativo</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1246"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1245"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
    <skos:definition xml:lang="en">A heating function borne by petroleum production equipment whose realization constitutes the generation and transfer of thermal energy through an exothermic chemical reaction.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b909">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1856"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1855"/>
    <rdfs:label xml:lang="en">pig launching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de lançamento de pig</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the controlled introduction of a pipeline pig into a pipeline under operating pressure.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingSystem">
    <rdfs:label xml:lang="pt-br">sistema de vedação</rdfs:label>
    <rdfs:label xml:lang="en">sealing system</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of seals, gaskets, and packing that prevents leakage between two components of petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every transformer is an electrical equipment that bears an electrical power transformation function and has component parts including primary winding, secondary winding, and magnetic core.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">transformador</rdfs:label>
    <rdfs:label xml:lang="en">transformer</rdfs:label>
    <skos:definition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transformador é um equipamento elétrico que transforma energia elétrica de um circuito para outro na mesma frequência através de indução eletromagnética usando enrolamentos e um núcleo magnético.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Transformer(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(PrimaryWinding(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃s(SecondaryWinding(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(MagneticCore(c) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2587"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle liga-desliga é uma válvula de controle que possui uma função de controle de fluxo binária, tendo apenas duas posições definidas: totalmente aberta e totalmente fechada.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every on-off control valve is a control valve that has a BinaryFlowControlFunction and has component part a BinaryPositioner.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1820"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</skos:definition>
    <rdfs:label xml:lang="pt-br">válvula de controle liga-desliga</rdfs:label>
    <rdfs:label xml:lang="en">on off control valve</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(OnOffControlValve(x) ↔ ControlValve(x) ∧ ∃f(BinaryFlowControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatingMedium">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">heating medium</rdfs:label>
    <rdfs:label xml:lang="pt-br">meio de aquecimento</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the fluid—steam, hot oil, or heated water—used to supply thermal energy to a process stream in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2414">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2068">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2070"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2305">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208">
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <rdfs:label xml:lang="en">agitator</rdfs:label>
    <skos:definition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b53"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b631"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b632"/>
    <rdfs:label xml:lang="en">dehumidification function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de desumidificação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of water vapour from a gas stream to reduce its relative humidity or dew point.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess">
    <skos:definition xml:lang="en">A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices.</skos:definition>
    <skos:definition xml:lang="en">A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">electrical conduction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de condução elétrica</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2366"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2367"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de inspeção visual</rdfs:label>
    <rdfs:label xml:lang="en">visual inspection function</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1104">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311">
    <iof-av:primitiveRationale xml:lang="en">As a constructive type, manifolds are defined by structural configuration. Under OWA, asserting equivalence would force any assembly with a chamber and multiple openings to be classified as a manifold, potentially misclassifying complex equipment with manifold-like components (e.g., turbine casings, complex valves). Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manifold é um conjunto que possui uma câmara com múltiplas aberturas de fluido projetada para distribuir o fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1741"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1743"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1742"/>
    <rdfs:label xml:lang="en">manifold</rdfs:label>
    <rdfs:label xml:lang="pt-br">manifold</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Manifold(x) → Assembly(x) ∧ ∃c(Chamber(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃o(MultipleFluidOpenings(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃f(FluidDistributionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every manifold is an assembly that has-component-part-at-all-times some chamber and has-component-part-at-all-times some multiple fluid openings and bears some fluid distribution function.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VibrationMeasurementAndTransmissionProcess">
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de vibração</rdfs:label>
    <rdfs:label xml:lang="en">vibration measurement and transmission process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the amplitude or frequency of mechanical vibration is measured and the corresponding signal transmitted to a remote monitoring system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2616">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2310">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which dissolved oxygen and other non-condensable gases are removed from a liquid stream in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">deaeration process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de desaeração</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1305">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2464">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335">
    <skos:definition xml:lang="en">A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump casing is a casing that surrounds an impeller and has integral suction and discharge nozzles forming part of its structure.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2152"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:label xml:lang="pt-br">carcaça de bomba</rdfs:label>
    <rdfs:label xml:lang="en">pump casing</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um invólucro que envolve um impulsor e possui bocais de sucção e descarga integrais como componentes estruturais, tipicamente aplicado em bombas centrífugas.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under Open World Assumption, structural characteristics are harder to make sufficient - any assembly with an impeller and integral nozzles might be classified as a pump casing even if it serves a different specialized purpose. Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PumpCasing(x) → Casing(x) ∧ ∃y(Impeller(y) ∧ surrounds(x,y)) ∧ ∃z(SuctionNozzle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃w(DischargeNozzle(w) ∧ hasComponentPartAtAllTimes(x,w)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalRotation">
    <rdfs:label xml:lang="pt-br">rotação mecânico</rdfs:label>
    <rdfs:label xml:lang="en">mechanical rotation</rdfs:label>
    <skos:definition xml:lang="en">A process in which the angular motion of a rotating component about its axis in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1537">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotatingVanes"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000146">
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2201"/>
    <skos:definition xml:lang="en">A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(RestrictionOrifice(x) ↔ FlowModificationAccessory(x) ∧ ∃f(FlowRestrictionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every restriction orifice is a flow modification accessory that bears a flow restriction function</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um orifício de restrição é um acessório de modificação de fluxo que possui a função de restringir o fluxo de fluido criando queda de pressão controlada através de constrição geométrica.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">orifício de restrição</rdfs:label>
    <rdfs:label xml:lang="en">restriction orifice</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessVariable">
    <skos:definition xml:lang="en">An information content entity constituting a measurable variable—pressure, temperature, flow rate, or level—that characterises the state of a petroleum production process.</skos:definition>
    <rdfs:label xml:lang="pt-br">variável de processo</rdfs:label>
    <rdfs:label xml:lang="en">process variable</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1042">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2204">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2202"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula manual é uma válvula que possui um atuador manual que requer força manual para operação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ManualValve(x) → Valve(x) ∧ ∃y(ManualActuator(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on actuation mechanism. Under OWA, any valve with a manual actuator component might be classified as manual valve even if it has additional automated features (hybrid valves). Starting with necessary conditions allows domain experts to validate that manual actuation is both necessary and sufficient before upgrading to equivalent axiom.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1753"/>
    <rdfs:label xml:lang="en">manual valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula manual</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every manual valve is a valve that has a manual actuator as component part.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2533">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2535"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2445">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2479">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Panel"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2203">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2204"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242">
    <rdfs:label xml:lang="en">dehumidifier</rdfs:label>
    <rdfs:label xml:lang="pt-br">desumidificador</rdfs:label>
    <skos:definition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehumidifier is an assembly that has the function to perform dehumidification.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desumidificador é um conjunto que possui a função de remover umidade do ar.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b636"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de nível é um transmissor que mede o nível (altura) de material líquido ou sólido a granel em um recipiente e produz um sinal elétrico de saída padronizado proporcional ao nível medido.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">transmissor de nível</rdfs:label>
    <rdfs:label xml:lang="en">level transmitter</rdfs:label>
    <skos:definition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(LevelTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(LevelMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level transmitter is a transmitter that bears a LevelMeasurementAndTransmissionFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1690"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1461">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2653">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess">
    <skos:definition xml:lang="en">A planned process in which a fluid is conveyed from one location to another through containment structures while maintaining flow direction and preventing leakage.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de condução de fluido</rdfs:label>
    <rdfs:label xml:lang="en">fluid conduction process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b694">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b697"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2601">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2602"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b410">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b414"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1311">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">FilterElement SubClassOf Filter and (madeFrom some FilterMedia) and (componentPartOf some FilterAssembly)</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1036"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Filtro que é feito de meio filtrante e que é uma parte componente de um conjunto de filtro.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">filter element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento filtrante</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on material composition (filter media) and mereological relationship (component of assembly). Under OWA, asserting equivalence could lead to unintended classification of any artifact made from filter media as a filter element, including specialized or hybrid components that contain filter media but serve different primary functions.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FilterElement(x) → Filter(x) ∧ ∃m(FilterMedia(m) ∧ madeFrom(x,m)) ∧ ∃a(FilterAssembly(a) ∧ componentPartOf(x,a)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1923">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de placas é um trocador de calor que possui placas de transferência de calor como sua superfície primária de transferência de calor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the plate-based structure is characteristic, under the Open World Assumption, asserting equivalence could lead to false positives where any equipment with heat transfer plates (e.g., specialized hybrid equipment, multi-function process units) would be automatically classified as a standard plate heat exchanger. Domain expert validation is needed to confirm the structural differentia is sufficient.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1975"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1976"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every plate heat exchanger is a heat exchanger that has component part heat transfer plates at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">plate heat exchanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">trocador de calor de placas</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PlateHeatExchanger(x) → HeatExchanger(x) ∧ ∃p(HeatTransferPlate(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b576">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1792">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1794"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2534">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1725">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1162">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b550">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2302">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">pressure reduction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de redução de pressão</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the pressure of a fluid is reduced from a higher upstream value to a controlled lower downstream value.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipePig">
    <rdfs:label xml:lang="en">pipe pig</rdfs:label>
    <rdfs:label xml:lang="pt-br">pig de tubo</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a device propelled through a pipeline by the flow of product to perform internal inspection, cleaning, or product separation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WaterVapor">
    <skos:definition xml:lang="en">A material artifact that constitutes water in the vapour phase present in a process stream handled by petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">vapor de água</rdfs:label>
    <rdfs:label xml:lang="en">water vapor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingBundle">
    <skos:definition xml:lang="en">An assembly of multiple tubing strings grouped and routed together for injection or production purposes in petroleum production wells or risers.</skos:definition>
    <rdfs:label xml:lang="pt-br">feixe de coluna de produção</rdfs:label>
    <rdfs:label xml:lang="en">tubing bundle</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1437">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">force to electrical transduction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transdução força-elétrica</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a mechanical force or pressure is converted into a proportional electrical signal by petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b704">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1147">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1148"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1666">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1668"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess">
    <rdfs:label xml:lang="en">level indication process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de indicação de nível</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the fluid level within a vessel or container is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1066">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1068"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1921">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SpacingProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a defined spatial separation between components is maintained to ensure correct alignment, clearance, or insulation.</skos:definition>
    <rdfs:label xml:lang="en">spacing process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de espaçamento</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000244">
    <skos:definition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b663"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um demister é um separador que possui uma função de desmistificação para remover gotículas de líquido de correntes gasosas através de mecanismos de coalescência.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">demister</rdfs:label>
    <rdfs:label xml:lang="en">demister</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every demister is a separator that has the function of demisting gas streams by coalescing and removing entrained liquid droplets.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Demister(x) ↔ Separator(x) ∧ ∃f(DemistingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1603">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1981">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000128">
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1634"/>
    <rdfs:label xml:lang="pt-br">elemento de nível</rdfs:label>
    <rdfs:label xml:lang="en">level element</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de nível é um instrumento que possui uma função de detecção de nível para determinar o nível de fluido em um vaso ou recipiente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LevelElement(x) ↔ Detector(x) ∧ ∃f(LevelDetectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level element is a detector that has the function to detect fluid level</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionFunction">
    <skos:definition xml:lang="en">A detection function borne by petroleum production equipment whose realization constitutes the sensing of the presence of a flame or combustion event by detecting radiant energy or other combustion signatures.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1081"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1082"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionFunction"/>
    <rdfs:label xml:lang="en">flame detection function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de detecção de chama</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RockCuttings">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes rock fragments produced by the drill bit during drilling and transported to surface by the circulating drilling fluid.</skos:definition>
    <rdfs:label xml:lang="pt-br">cascalhos de rocha</rdfs:label>
    <rdfs:label xml:lang="en">rock cuttings</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b324">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266">
    <skos:definition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">filter cartridge</rdfs:label>
    <rdfs:label xml:lang="pt-br">cartucho de filtro</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1028"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b9"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b8"/>
    <rdfs:label xml:lang="pt-br">função de absorção de gás</rdfs:label>
    <rdfs:label xml:lang="en">gas absorption function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the selective transfer of gaseous components from a gas phase into a liquid absorbent phase.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b326"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b325"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de proteção catódica</rdfs:label>
    <rdfs:label xml:lang="en">cathodic protection function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the prevention of electrochemical corrosion of a metallic structure by making it the cathode of an electrochemical cell.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000298">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">atuador hidráulico</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic actuator</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A hydraulic actuator is an actuator that converts hydraulic fluid pressure into mechanical motion through hydraulic power transmission.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1491"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(HydraulicActuator(x) → Actuator(x) ∧ ∃y(HydraulicFluidPortion(y) ∧ hasInput(x,y)) ∧ ∃z(HydraulicToMechanicalEnergyConversionProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador hidráulico é um atuador que converte pressão de fluido hidráulico em movimento mecânico através de transmissão de potência hidráulica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hydraulic actuator is an actuator that converts hydraulic fluid pressure into mechanical motion through hydraulic power transmission.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on hydraulic power source. Under Open World Assumption, asserting equivalence could incorrectly classify complex hydraulic-mechanical hybrid systems or specialized equipment containing hydraulic actuator components as standard hydraulic actuators.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic actuator is an actuator that has hydraulic fluid portion as input and participates in hydraulic to mechanical energy conversion process.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b664">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which process pressure is measured and both displayed locally and transmitted as a standardised signal to a remote monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de indicação e transmissão de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure indicating and transmission process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b896">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b921">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricEnergyGenerationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b98">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b96"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ValveBody(x) → ValveComponent(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃y(WorkingComponent(y) ∧ houses(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
    <rdfs:label xml:lang="en">valve body</rdfs:label>
    <skos:definition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2706"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um ValveComponent que porta uma ContainmentFunction e que serve como o principal componente de contenção de fluido e pressão de uma válvula, alojando e suportando os componentes de trabalho.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type - the structural characteristics of being the main pressure-containing housing component are necessary conditions but may not be sufficient under OWA, as various specialized valve body configurations exist that might contain additional components or have hybrid designs that could lead to false positive classifications.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve body is a valve component that contains and supports valve working components and bears the function of fluid and pressure containment.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1685">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b220">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b976">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2260"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2259"/>
    <rdfs:label xml:lang="en">safety venting function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de ventilação de segurança</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the release of excess pressure from a process system to a safe disposal location.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000362">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every transducer is an instrument that has the designed function to convert energy or signal forms while preserving information content.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transdutor é um instrumento que possui uma FunçãoDeTransdução para converter informação de uma forma ou magnitude de energia para outra forma ou magnitude.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Transducer(x) ↔ Instrument(x) ∧ ∃f (TransductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2579"/>
    <rdfs:label xml:lang="en">transducer</rdfs:label>
    <rdfs:label xml:lang="pt-br">transdutor</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000380">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de temperatura é um instrumento que possui uma função de sensoreamento de temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature element is an instrument that bears a temperature sensing function.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A temperature element is an instrument that bears a temperature sensing function.</skos:definition>
    <rdfs:label xml:lang="pt-br">elemento de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature element</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureElement(x) ↔ DetectingElement(x) ∧ ∃f(TemperatureSensingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2497"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature element is a detecting element that has the function to sense temperature</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess">
    <skos:definition xml:lang="en">A planned process in which energy in the form of heat, work, or electromagnetic radiation is transferred from one medium or system to another.</skos:definition>
    <rdfs:label xml:lang="en">energy transfer process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transferência de energia</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b406">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellFluidControlProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000338">
    <skos:definition xml:lang="en">A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2173"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um relé é um dispositivo de comutação elétrica que possui uma função de relé de sinal, realizada ao transmitir informações ou sinais de um circuito para controlar operações em outro circuito.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">relé</rdfs:label>
    <rdfs:label xml:lang="en">relay</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Relay is an ElectricalSwitchingDevice that bearerOf some SignalRelayFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Relay(x) ↔ (ElectricalSwitchingDevice(x) ∧ ∃f(SignalRelayFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000349">
    <skos:definition xml:lang="en">A sheave is a material artifact that is a grooved wheel designed to transmit mechanical power through interface with belts, ropes, wires, or pipes.</skos:definition>
    <rdfs:label xml:lang="pt-br">polia</rdfs:label>
    <rdfs:label xml:lang="en">sheave</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2355"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A sheave is a material artifact that is a grooved wheel designed to transmit mechanical power through interface with belts, ropes, wires, or pipes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma polia é um artefato material que é uma roda sulcada projetada para transmitir energia mecânica através da interface com correias, cordas, cabos ou tubos.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical structure. Under OWA, defining sufficient conditions based solely on having a grooved rim could lead to false positives where other grooved mechanical elements (like timing belt pulleys with different design intents) are automatically classified as sheaves. The structural differentia provides necessary conditions while allowing domain experts to confirm sufficient conditions.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every sheave is a material artifact that has a grooved rim as component part and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Sheave(x) → MaterialArtifact(x) ∧ ∃y(GroovedRim(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasDetectingMeasuringElement">
    <rdfs:label xml:lang="en">gas detecting measuring element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de gás de detecção de medição</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MeasuringElement"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a sensing element within petroleum production gas detection equipment that responds to the presence and concentration of a target gas.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b690">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DetectionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2010">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2011"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b54">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</skos:definition>
    <rdfs:label xml:lang="en">information display process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de exibição de informação</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000285">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1294"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gas engine is an engine that uses gaseous fuel as input, employs a spark ignition system, and operates with a reciprocating piston mechanism to generate mechanical energy.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor a gás é um motor que usa combustível gasoso como entrada, emprega um sistema de ignição por centelha e opera com um mecanismo de pistão alternativo para gerar energia mecânica.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">gas engine</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor a gás</rdfs:label>
    <skos:definition xml:lang="en">A gas engine is an engine that uses gaseous fuel as input, employs a spark ignition system, and operates with a reciprocating piston mechanism to generate mechanical energy.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Gas engine is defined by constructive characteristics (gaseous fuel, spark ignition, reciprocating mechanism) rather than a unique function. Under Open World Assumption, making these conditions sufficient could lead to false positives where complex hybrid engines or experimental designs with these features are automatically classified as standard gas engines when they might require different maintenance/operational categories.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GasEngine(x) → Engine(x) ∧ ∃f,s,r(GaseousFuelPortion(f) ∧ SparkIgnitionSystem(s) ∧ ReciprocatingPistonMechanism(r) ∧ hasInput(x,f) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,r)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gas engine is an engine that has gaseous fuel portion as input and has spark ignition system as component part at all times and has reciprocating piston mechanism as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1316">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1317"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b988">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ThermalExpansionAccommodationFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1178">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1175"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PositionSignal">
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical signal representing the position of a mechanical component in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">position signal</rdfs:label>
    <rdfs:label xml:lang="pt-br">sinal de posição</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2128"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2129"/>
    <rdfs:label xml:lang="en">pressure containment function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de contenção de pressão</rdfs:label>
    <skos:definition xml:lang="en">A containment function borne by petroleum production equipment whose realization constitutes the retention of fluid within a defined pressure boundary to prevent uncontrolled release.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">válvula de controle tipo gaveta</rdfs:label>
    <rdfs:label xml:lang="en">gate control valve</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate control valve is a control valve that has a gate closure mechanism as component part at all times</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1331"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle tipo gaveta é uma válvula de controle que usa um elemento de fechamento tipo gaveta ou cunha movendo-se perpendicular ao caminho do fluxo para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GateControlValve(x) → ControlValve(x) ∧ ∃g(GateClosureMechanism(g) ∧ hasComponentPartAtAllTimes(x,g)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">This is a constructive subtype where the structural differentia (gate closure mechanism) defines necessary conditions. Under OWA, making this sufficient could force any assembly with a gate closure into this maintenance category, including specialized multi-way valves or custom manifolds that should not be classified as standard gate control valves.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b881">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DryingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalEnergyTransferProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a rotor transfers mechanical energy through its rotational motion, enabling the operation of rotating machinery such as motors, compressors, pumps, and turbines.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a rotor transfers mechanical energy through its rotational motion, enabling the operation of rotating machinery such as motors, compressors, pumps, and turbines.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de transferência de energia rotacional</rdfs:label>
    <rdfs:label xml:lang="en">rotational energy transfer process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2634">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingBowl"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1662">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000234">
    <skos:definition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</skos:definition>
    <rdfs:label xml:lang="pt-br">controlador</rdfs:label>
    <rdfs:label xml:lang="en">controller</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um controlador é um instrumento que possui uma função de controle, regulando automaticamente uma variável controlada ao medi-la, comparar com um valor de referência e gerar sinais de saída para reduzir o desvio.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every controller is an instrument that has the function to control a process variable by automatic feedback regulation</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Controller(x) ↔ Instrument(x) ∧ ∃f(ControlFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b543"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2055">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2086">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b544">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BrakingFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b257"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b258"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="en">braking function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de frenagem</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the application of a retarding force to decelerate or hold stationary a rotating or translating mechanical component.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b786">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b784"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every self-operating valve is a valve that has a self-operating mechanism as component part at all times and bears the capability of energy-independent operation.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2310"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula auto-operante é uma válvula que inclui um mecanismo interno de operação (como mola, gravidade, pressão do fluido ou contrapeso) e não depende de uma fonte externa de energia para seu acionamento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</skos:definition>
    <rdfs:label xml:lang="pt-br">válvula auto-operante</rdfs:label>
    <rdfs:label xml:lang="en">self operating valve</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical configuration (self-operating mechanism). Under OWA, any valve with an internal operating mechanism might be classified as self-operating even if it has additional external actuators or specialized applications. Domain expert validation needed to confirm structural differentia is sufficient.</iof-av:primitiveRationale>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SelfOperatingValve(x) → Valve(x) ∧ ∃m(SelfOperatingMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(EnergyIndependentOperationCapability(c) ∧ bearerOf(x,c)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1815">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b255">
    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b256"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b252"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000230">
    <rdfs:label xml:lang="en">compensator</rdfs:label>
    <rdfs:label xml:lang="pt-br">compensador</rdfs:label>
    <skos:definition xml:lang="en">A compensator is a material artifact that has the designed function of compensating for axial or radial movement between two connected elements.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Compensator(x) ↔ MaterialArtifact(x) ∧ ∃f(MovementCompensationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b478"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um compensador é um artefato material que tem a função projetada de compensar movimento axial ou radial entre dois elementos conectados.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A compensator is a material artifact that has the designed function of compensating for axial or radial movement between two connected elements.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every compensator is a material artifact that bears a movement compensation function and has component parts including a compensation mechanism and connection interfaces.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1803">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1599">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1601"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000273">
    <rdfs:label xml:lang="en">flange</rdfs:label>
    <rdfs:label xml:lang="pt-br">flange</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um flange é um artefato material caracterizado por uma geometria de aro plano projetante, placa, colar ou nervura, projetado para fornecer conexão mecânica entre componentes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1093"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flange is a material artifact that has a projecting flat rim geometry and has the function of mechanically connecting components.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flange(x) → MaterialArtifact(x) ∧ ∃g(ProjectingFlatRimGeometry(g) ∧ hasCharacteristic(x,g)) ∧ ∃f(MechanicalConnectionFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by structural geometry. Under OWA, any artifact with projecting flat rim geometry would be forced into the flange category, which could incorrectly classify specialized equipment or complex assemblies that contain flange-like features but serve different primary functions.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207">
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:label xml:lang="pt-br">atuador</rdfs:label>
    <rdfs:label xml:lang="en">actuator</rdfs:label>
    <skos:definition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every actuator is an assembly that has the function of converting external energy into controlled kinetic motion.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador é um conjunto que possui uma função de atuação para converter energia de uma fonte externa em movimento cinético em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b45"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Actuator(x) ↔ Assembly(x) ∧ ∃f (ActuationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b372">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2276">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ScrapingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ACElectricalPower">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting alternating-current electrical power delivered to petroleum production equipment to drive motors, instrumentation, or control systems.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="pt-br">potência elétrico de CA</rdfs:label>
    <rdfs:label xml:lang="en">a c electrical power</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionGasPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">porção de combustão de gás</rdfs:label>
    <rdfs:label xml:lang="en">combustion gas portion</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas undergoing or having undergone a combustion reaction in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b624">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b622"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b264">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b262"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureMeasurementAndTransmissionProcess">
    <rdfs:label xml:lang="pt-br">processo de medição e transmissão de pressão diferencial</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure measurement and transmission process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
    <skos:definition xml:lang="en">A pressure measurement and transmission process in which the differential pressure between two process points is measured and the corresponding signal transmitted to a remote control or monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b487">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction">
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1206"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1205"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de modificação de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow modification function</rdfs:label>
    <skos:definition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255">
    <skos:definition xml:lang="en">A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">distillation column</rdfs:label>
    <rdfs:label xml:lang="pt-br">coluna de destilação</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every distillation column is a separator that has the function to perform distillation processes</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b835"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de destilação é um separador que possui uma função de destilação para permitir a separação de misturas de fluidos baseada nas diferenças dos pontos de ebulição dos componentes através do equilíbrio vapor-líquido.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DistillationColumn(x) ↔ (Separator(x) ∧ ∃f (DistillationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SurfaceSafetyValve">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:label xml:lang="en">surface safety valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de superfície de segurança</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a safety valve installed at the wellhead or surface flowline that automatically closes to prevent uncontrolled flow from the well.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2788">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a valve seat provides a sealing interface for a closure element (gate, ball, disc) to bear against, preventing fluid passage when the valve is closed.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de vedação</rdfs:label>
    <rdfs:label xml:lang="en">sealing process</rdfs:label>
    <skos:definition xml:lang="en">A PlannedProcess in which a valve seat provides a sealing interface for a closure element (gate, ball, disc) to bear against, preventing fluid passage when the valve is closed.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RaisedEdge">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">borda saliente</rdfs:label>
    <rdfs:label xml:lang="en">raised edge</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a raised rim or flange on a component of petroleum production equipment that provides a sealing surface or structural boundary.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b859">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceSafetyProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2346">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PipeShearingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSignal">
    <rdfs:label xml:lang="pt-br">sinal de nível</rdfs:label>
    <rdfs:label xml:lang="en">level signal</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting an electrical or pneumatic signal representing the fluid level in a vessel of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1742">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Chamber"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1059">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b501">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador de fluxo é um indicador projetado para indicar taxas de fluxo usando um elemento de medição de fluxo e elemento de exibição.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FlowIndicator(x) ↔ (Instrument(x) ∧ ∃f(FlowIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FlowMeasuringElement(e) ∧ hasComponentPartAtSomeTime(x,e)) ∧ ∃d(DisplayElement(d) ∧ hasComponentPartAtAllTimes(x,d))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">flow indicator</rdfs:label>
    <rdfs:label xml:lang="pt-br">indicador de fluxo</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow indicator is an instrument that bears a flow indication function and has a flow measuring element and display element as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1173"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which thermal, acoustic, or kinetic energy is dispersed over a larger volume or surface to reduce its local intensity.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de difusão de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy diffusion process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b261">
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b263"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b183">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillingFluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000151">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every storage tank is a tank that has the function to store materials for extended periods.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">tanque de armazenamento</rdfs:label>
    <rdfs:label xml:lang="en">storage tank</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2441"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
    <skos:definition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um tanque de armazenamento é um vaso projetado para armazenar fluidos ou materiais por períodos prolongados sem transformação ou processamento ativo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(StorageTank(x) ↔ (Tank(x) ∧ ∃f(ExtendedStorageFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:altLabel xml:lang="en">tank</skos:altLabel>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315">
    <skos:definition xml:lang="en">A motor is an assembly that bears a mechanical energy generation function to convert electrical, chemical, pneumatic, or hydraulic energy into rotational mechanical energy.</skos:definition>
    <rdfs:label xml:lang="en">motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every motor is an assembly that has the function of generating mechanical energy and has as output rotational kinetic energy.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Motor(x) ↔ Assembly(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(RotationalKineticEnergy(e) ∧ hasOutput(x,e)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A motor is an assembly that bears a mechanical energy generation function to convert electrical, chemical, pneumatic, or hydraulic energy into rotational mechanical energy.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor é um conjunto que possui uma função de geração de energia mecânica para converter energia elétrica, química, pneumática ou hidráulica em energia mecânica rotacional.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1792"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b360">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2606">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the fluid level in a vessel crosses a defined high or low threshold.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1676"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1677"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de chaveamento de nível</rdfs:label>
    <rdfs:label xml:lang="en">level switching function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualInformation">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An information content entity constituting visual information—such as a colour, indicator state, or display value—conveying process or equipment status to an operator.</skos:definition>
    <rdfs:label xml:lang="en">visual information</rdfs:label>
    <rdfs:label xml:lang="pt-br">informação visual</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2044">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1148">
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1146"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2560">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureIndication">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdfs:label xml:lang="pt-br">indicação de diferencial de pressão</rdfs:label>
    <rdfs:label xml:lang="en">differential pressure indication</rdfs:label>
    <skos:definition xml:lang="en">A measurement information content entity constituting a displayed or transmitted value representing the differential pressure between two process points in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000265">
    <iof-av:naturalLanguageDefinition xml:lang="en">An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma junta de expansão é um artefato material que possui a função projetada de acomodar expansão e contração térmica entre componentes conectados através de flexibilidade inerente, mantendo a integridade estrutural.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ExpansionJoint(x) ↔ (MaterialArtifact(x) ∧ ∃f(ThermalExpansionAccommodationFunction(f) ∧ bearerOf(x,f)) ∧ ∃g(FlexibilityFunction(g) ∧ hasFunction(x,g))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">expansion joint</rdfs:label>
    <rdfs:label xml:lang="pt-br">junta de expansão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b987"/>
    <skos:definition xml:lang="en">An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every expansion joint is a material artifact that bears a thermal expansion accommodation function and has a flexibility function, and every material artifact that bears a thermal expansion accommodation function and has a flexibility function is an expansion joint.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b448">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b377">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillString">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">coluna de perfuração</rdfs:label>
    <rdfs:label xml:lang="en">drill string</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of drill pipe, drill collars, and bottom-hole assembly that transmits rotation and drilling fluid from surface to the drill bit.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317">
    <iof-av:naturalLanguageDefinition xml:lang="en">A Shaft that participates in mechanical energy output processes, serving as the exit point for mechanical energy transmission from a prime mover to external energy consuming equipment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Eixo que participa em processos de saída de energia mecânica, servindo como ponto de saída para transmissão de energia mecânica de um motor primário para equipamentos consumidores de energia externos.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on positional role within mechanical systems. Under OWA, sufficient conditions would be difficult to specify without risk of misclassifying intermediate shafts or complex multi-shaft arrangements that happen to have output characteristics.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A Shaft that participates in mechanical energy output processes, serving as the exit point for mechanical energy transmission from a prime mover to external energy consuming equipment.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1843"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every output shaft is a shaft that participates in at least one mechanical energy output process and bears a power transmission function.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">eixo de saída</rdfs:label>
    <rdfs:label xml:lang="en">output shaft</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (OutputShaft(x) → Shaft(x) ∧ ∃p (MechanicalEnergyOutputProcess(p) ∧ participatesIn(x,p)) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1146">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">liquid portion</rdfs:label>
    <rdfs:label xml:lang="pt-br">porção líquido</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of liquid phase material at a defined point in a petroleum production process.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000254">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Display(x) ↔ Instrument(x) ∧ ∃f(InformationDisplayFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b827"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Display é um Instrumento que possui uma InformationDisplayFunction e que apresenta informações visualmente para operadores ou usuários.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users.</skos:definition>
    <rdfs:label xml:lang="en">display</rdfs:label>
    <rdfs:label xml:lang="pt-br">display</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Display is an Instrument that necessarily bears an InformationDisplayFunction</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Piston">
    <rdfs:label xml:lang="en">piston</rdfs:label>
    <rdfs:label xml:lang="pt-br">pistão</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a sliding disc or cylinder that moves within a cylindrical bore to compress gas or transmit hydraulic force in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1071">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152">
    <skos:definition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2450"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro grosso é um artefato material que possui uma função de separação e tem um elemento filtrante, projetado para separar partículas sólidas de fluidos fazendo o fluido passar através de telas ou perfurações.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Strainer(x) ↔ (MaterialArtifact(x) ∧ ∃f(SeparationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilteringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(SolidLiquidSeparationProcess(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">filtro grosso</rdfs:label>
    <rdfs:label xml:lang="en">strainer</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every strainer is a material artifact that bears a separation function and has a filtering element as component part at all times and participates in solid-liquid separation processes.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b253">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillBit"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a pipeline pig is introduced into a pipeline under operating pressure and subsequently retrieved after completing its passage.</skos:definition>
    <rdfs:label xml:lang="en">pig launching and receiving process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de lançamento e recebimento de pig</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1310">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b708">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DewPointMeasurementFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelDetectionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de detecção de nível</rdfs:label>
    <rdfs:label xml:lang="en">level detection process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the fluid level within a vessel is detected as reaching a defined high or low threshold.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b551">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000108">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DiaphragmValve(x) → Valve(x) ∧ ∃d,p (ResilientDiaphragm(d) ∧ Port(p) ∧ hasComponentPartAtAllTimes(x,d) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">válvula de diafragma</rdfs:label>
    <rdfs:label xml:lang="en">diaphragm valve</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b741"/>
    <rdfs:subClassOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b742"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <skos:definition xml:lang="en">A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow.</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Since this is a constructive type defined by physical mechanism (diaphragm closure), necessary conditions are used to avoid over-classification under the Open World Assumption. Not every equipment with a diaphragm component should automatically be classified as a diaphragm valve - the structural differentia requires domain validation.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diaphragm valve is a valve that has a resilient diaphragm as component part and has a port as component part and participates in diaphragm closure processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de diafragma é uma válvula que usa um diafragma resiliente forçado contra uma porta como seu mecanismo de fechamento para controlar o fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000130">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LevelSightGlass(x) ↔ SightGlass(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every level sight glass is a sight glass that has the function of level indication.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection.</skos:definition>
    <rdfs:label xml:lang="pt-br">visor de nível</rdfs:label>
    <rdfs:label xml:lang="en">level sight glass</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um visor de nível é um visor que possui uma função projetada para indicar o nível de líquido através de inspeção visual.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1666"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a protective barrier shields a temperature sensing element from direct contact with the process medium while maintaining thermal conductivity to enable accurate temperature measurement.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">temperature sensor protection process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de proteção de sensor de temperatura</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A PlannedProcess in which a protective barrier shields a temperature sensing element from direct contact with the process medium while maintaining thermal conductivity to enable accurate temperature measurement.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1450">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentItem">
    <skos:definition xml:lang="en">A material artifact that constitutes a discrete item of petroleum production equipment assembled or installed as a unit within a production system.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:label xml:lang="pt-br">item de equipamento</rdfs:label>
    <rdfs:label xml:lang="en">equipment item</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1467">
