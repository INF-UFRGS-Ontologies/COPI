    <rdfs:label xml:lang="pt-br">capacidade de operação independente de energia</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-equipment"/>
  </rdf:Description>
