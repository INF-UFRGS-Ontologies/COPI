  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/WasteMaterialPortion">
    <rdfs:label xml:lang="pt-br">porção de resíduo de material</rdfs:label>
    <rdfs:label xml:lang="en">waste material portion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of waste material generated by a processing step in petroleum production equipment and requiring disposal.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShapedOrifice">
    <rdfs:label xml:lang="en">shaped orifice</rdfs:label>
    <rdfs:label xml:lang="pt-br">orifício de perfilado</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an orifice of defined geometry in petroleum production equipment through which fluid passes to produce a desired pressure drop or flow characteristic.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b434">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000239">
    <iof-av:naturalLanguageDefinition xml:lang="en">A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um amortecedor é um conjunto que possui a função projetada de suprimir, regular ou reduzir características dinâmicas desfavoráveis como vibrações, flutuações de pressão ou distúrbios de fluxo.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">damper</rdfs:label>
    <rdfs:label xml:lang="pt-br">amortecedor</rdfs:label>
    <skos:definition xml:lang="en">A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b736"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Damper(x) ↔ (Assembly(x) ∧ ∃f (DampingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every damper is an assembly that bears a damping function, and every assembly that bears a damping function is a damper.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b74">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StatorWinding">
    <rdfs:label xml:lang="en">stator winding</rdfs:label>
    <rdfs:label xml:lang="pt-br">enrolamento de estator</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the stationary winding of an electric motor or generator that produces or responds to the rotating magnetic field in petroleum production rotating electrical equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
