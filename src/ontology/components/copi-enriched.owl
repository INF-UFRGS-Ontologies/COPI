  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SupportedTubingString">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">supported tubing string</rdfs:label>
    <rdfs:label xml:lang="pt-br">coluna suportado de coluna de produção</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a downhole tubing string that is suspended and supported from the wellhead by a tubing hanger in a petroleum production well.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000263">
    <skos:definition xml:lang="en">An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ElectricalConnector(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalConnectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ElectricalConnector ≡ ElectricalEquipment ⊓ ∃bearerOf.ElectricalConnectionFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um conector elétrico é um equipamento elétrico que possui uma função de conexão elétrica e que mantém contato elétrico íntimo entre duas ou mais partes de condutor elétrico para permitir fluxo contínuo de corrente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">electrical connector</rdfs:label>
    <rdfs:label xml:lang="pt-br">conector elétrico</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1189"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1492">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1493"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureIndicationProcess">
    <rdfs:label xml:lang="pt-br">processo de indicação de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature indication process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which the temperature of a process stream or equipment surface is measured and displayed locally or transmitted to a remote monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2939">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2935"/>
  </rdf:Description>
