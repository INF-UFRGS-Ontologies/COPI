  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098">
    <rdfs:label xml:lang="en">blower</rdfs:label>
    <rdfs:label xml:lang="pt-br">soprador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098"/>
    <skos:definition xml:lang="en">[POSC Caesar] A physical object intended to compress and supply air or gas at medium pressure and medium volume flow.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to compress and supply air or gas at medium pressure and medium volume flow.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BLOWER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;BLOWING&gt; a medium volume flow</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um soprador é um compressor que comprime e fornece ar ou gás em pressão média e vazão volumétrica média.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Blower(x) ↔ (Compressor(x) ∧ ∃f,p,v (CompressionFunction(f) ∧ bearerOf(x,f) ∧ MediumPressureRange(p) ∧ MediumVolumeFlowRange(v) ∧ hasOperatingParameter(x,p) ∧ hasOperatingParameter(x,v))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every blower is a compressor that has the function of compressing gas and operates at medium pressure and medium volume flow ranges.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b273"/>
  </rdf:Description>
