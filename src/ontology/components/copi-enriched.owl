  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ReducerBody">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the body of a pipe reducer fitting that connects pipe sections of differing diameters in petroleum production piping.</skos:definition>
    <rdfs:label xml:lang="pt-br">corpo de redutor</rdfs:label>
    <rdfs:label xml:lang="en">reducer body</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
