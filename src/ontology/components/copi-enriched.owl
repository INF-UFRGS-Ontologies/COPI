    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1884"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b928"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b44"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2207"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b45"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b3008"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">actuation function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de atuação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Mixer(x) ↔ (Assembly(x) ∧ ∃f (MixingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">mixer</rdfs:label>
    <rdfs:label xml:lang="pt-br">misturador</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;MIXER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;MIXING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to be used for fluid mixing processes typically a rotating piece of equipment comprised of a driver such as a motor which rotates an agitator immersed in the fluid(s) that need to be mixed.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An apparatus or machine that has the capability of mixing (from ``_).</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A fluid container that mixes two ore more fluid ingredients.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um misturador é um conjunto que tem a função projetada de misturar ou combinar dois ou mais ingredientes fluidos em uma mistura homogênea.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every mixer is an assembly that bears a mixing function, and every assembly that bears a mixing function is a mixer.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2242"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportAndConnectionFunction">
    <rdfs:label xml:lang="pt-br">função de suporte e conexão de coluna de produção</rdfs:label>
    <rdfs:label xml:lang="en">tubing support and connection function</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b3270"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b3269"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b597">
    <rdf:first rdf:nodeID="n297d145abb684750972df9e3ef9e1556b593"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThermowellStem(x) → FiatObjectPart(x) ∧ ∃y(Thermowell(y) ∧ partOf(x,y)) ∧ ∃q(HollowCylindricalShape(q) ∧ hasQuality(x,q)) ∧ ∃l(ProcessMediumIntrusionZone(l) ∧ hasLocation(x,l)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">termowell stem</rdfs:label>
    <rdfs:label xml:lang="en">thermowell stem</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b3176"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell stem is a fiat object part that is part of some thermowell and has hollow cylindrical shape and is located in process medium intrusion zone.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um termowell stem é uma parte de objeto fiducial que é parte de um termowell e que tem uma forma cilíndrica oca posicionada para se projetar no meio do processo, fornecendo habitação protetora para elementos de detecção de temperatura enquanto permite condução térmica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;THERMOWELL STEM&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;Feature&gt; and an &lt;ENCLOSURE&gt; that is the hollow cylindrical part of a thermowell that is housing the thermocouple or thermoelement and is protruding into the process medium</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification basis. The structural differentia (hollow cylindrical shape, positioning in process medium) is necessary but may not be sufficient under OWA - there could be other specialized parts of thermowells with similar geometry but different specific roles or configurations.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StorageProcess">
    <rdfs:label xml:lang="pt-br">processo de armazenamento</rdfs:label>
    <rdfs:label xml:lang="en">storage process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Connection">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">conexão</rdfs:label>
    <rdfs:label xml:lang="en">connection</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b967">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SwitchingMechanism">
    <rdfs:label xml:lang="pt-br">mecanismo de chaveamento</rdfs:label>
    <rdfs:label xml:lang="en">switching mechanism</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000338">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Relay is an ElectricalSwitchingDevice that bearerOf some SignalRelayFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;RELAY&gt; is a &lt;SWITCHING DEVICE&gt; that usually is incorporating an electromagnet, whereby a current or signal in one circuit can open or close another circuit</skos:definition>
    <skos:definition xml:lang="en">[isa5_1] a device, whose function is to pass on information in an unchanged form or in some modified form, often used to mean the preferred term computing device.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that can be any electrical device, usually incorporating an electromagnet, whereby a current or signal in one circuit can open or close another circuit.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um relé é um dispositivo de comutação elétrica que possui uma função de relé de sinal, realizada ao transmitir informações ou sinais de um circuito para controlar operações em outro circuito.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">relé</rdfs:label>
    <rdfs:label xml:lang="en">relay</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Relay(x) ↔ (ElectricalSwitchingDevice(x) ∧ ∃f(SignalRelayFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2721"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionFunction">
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b338"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b339"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">combustion function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de combustão</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2922">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ShakingElement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DemistingElement">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">demisting element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de eliminação de névoa</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266">
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1303"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1302"/>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1304"/>
    <rdfs:label xml:lang="pt-br">cartucho de filtro</rdfs:label>
    <rdfs:label xml:lang="en">filter cartridge</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[POSC Caesar] A filter element intended to collect particles from a stream in a filter or strainer.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A filter element intended to collect particles from a stream in a filter or strainer.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER CARTRIDGE&gt; is an &lt;ARTEFACT&gt; and a &lt;FILTER ELEMENT&gt; intended to collect particles from a stream in a filter or strainer</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318">
    <skos:definition xml:lang="en">[CFIHOS] A pressure vessel intended for sending a pig into a pipeline.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIG LAUNCHER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;LAUNCHING&gt; a &lt;PIPE PIG&gt; into a pipeline</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A chamber connected to a pipeline intended for sending pigs into the pipeline.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lançador de pig é um vaso que possui função de lançamento de pig para inserir pigs de duto em sistemas de tubulação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pig launcher</rdfs:label>
    <rdfs:label xml:lang="pt-br">lançador de pig</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2342"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PigLauncher(x) ↔ (Vessel(x) ∧ ∃f(PigLaunchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(PipelineConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig launcher is a vessel that has the function to launch pipeline pigs and has a pipeline connection component.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b795">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CleanFluidOutlet"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma linha de fluxo é um duto que transporta óleo, gás ou água diretamente de uma cabeça de poço para um manifold ou instalação de produção.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flowline is a pipeline that bears a fluid transport function, has a wellhead connection, has a manifold or production facility connection, and transports hydrocarbon fluids.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">flowline</rdfs:label>
    <rdfs:label xml:lang="pt-br">linha de fluxo</rdfs:label>
    <skos:definition xml:lang="en">[OnePetro] The pipe connection between the well and the separators or tank battery.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOWLINE&gt; is an &lt;ARTEFACT&gt; and  a &lt;PIPELINE&gt; carrying oil, gas or water that connects the wellhead to a manifold or to production facilities, such as heater-treaters and separators</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The large-diameter metal pipe that connects the bell nipple under the rotary table to the possum belly at the mud tanks.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flowline(x) ↔ Pipeline(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ connectsDirectly(x,w)) ∧ ∃m((Manifold(m) ∨ ProductionFacility(m)) ∧ connectsDirectly(x,m)) ∧ ∃h(HydrocarbonFluid(h) ∧ hasInput(x,h)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1581"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b2204">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Chamber"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess">
    <rdfs:label xml:lang="pt-br">processo de ebulição</rdfs:label>
    <rdfs:label xml:lang="en">boiling process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b3316">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ProtectiveSheathing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1059">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FeedInlet"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalVariable">
    <rdfs:label xml:lang="en">physical variable</rdfs:label>
    <rdfs:label xml:lang="pt-br">variável físico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000291">
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que possui geometria globular projetada para acomodar o caminho de fluxo perpendicular e o mecanismo de fechamento por disco característico da operação de válvula globo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve body that has a globular geometry designed to accommodate the perpendicular flow path and disc closure mechanism characteristic of globe valve operation.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe valve body is a valve body that has globular geometry for perpendicular flow path accommodation.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:nodeID="n297d145abb684750972df9e3ef9e1556b1776"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural geometry. Under OWA, asserting equivalence based on globular geometry alone could lead to false classifications of complex assemblies or hybrid components that contain globular elements but should not be classified as standard globe valve bodies.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="pt-br">corpo de válvula globo</rdfs:label>
    <rdfs:label xml:lang="en">globe valve body</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GLOBE VALVE BODY&gt; is a &lt;VALVE BODY&gt; of a globe valve</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (GlobeValveBody(x) → ValveBody(x) ∧ ∃g (GlobularGeometry(g) ∧ hasDesignCharacteristic(x,g)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every brake is an assembly that has the function of braking, and every assembly that has the function of braking is a brake.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n297d145abb684750972df9e3ef9e1556b330"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A brake is an assembly that bears a braking function to arrest or prevent the motion of an object, typically through friction or electromagnetic force application.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um freio é um conjunto que possui uma função de frenagem para deter ou prevenir o movimento de um objeto, tipicamente através da aplicação de força de atrito ou eletromagnética.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[SLB Glossary] The mechanism on the drawworks that permits the driller to control the speed and motion of the drilling line and the drillstring.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] In a drillng context, a brake is the main device for stopping the travel of the drawworks of a rig when running or pulling a drill string.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to arrest or prevent the motion of an item. Typically by means of friction.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BRAKE&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;BRAKING&gt;</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Brake(x) ↔ (Assembly(x) ∧ ∃f(BrakingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">brake</rdfs:label>
    <rdfs:label xml:lang="pt-br">freio</rdfs:label>
  </rdf:Description>
