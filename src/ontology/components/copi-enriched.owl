  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000330">
    <rdfs:label xml:lang="pt-br">transmissor de posição</rdfs:label>
    <rdfs:label xml:lang="en">position transmitter</rdfs:label>
    <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation 'ZT'. First letter 'Z': Position, Dimension. Succeeding letters: 'T' = Transmit.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a position detector.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;POSITION TRANSMITTER&gt;is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;POSITION MEASURING INSTRUMENT&gt;</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every position transmitter is a transmitter that has the function of position transmission and receives position or displacement signals as input.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2545"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A position transmitter is a transmitter that measures position or displacement and converts it to a standardized output signal.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de posição é um transmissor que mede posição ou deslocamento e o converte em um sinal de saída padronizado.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PositionTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PositionTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PositionSignal(s) ∧ hasInput(x,s)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1910">
    <rdf:rest rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1911"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000299"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242">
    <rdfs:label xml:lang="en">dehumidifier</rdfs:label>
    <rdfs:label xml:lang="pt-br">desumidificador</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um desumidificador é um conjunto que possui a função de remover umidade do ar.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A dehumidifier is an assembly that bears the function to remove moisture from air.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A piece of equipment specifically designed to remove moisture from air.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEHUMIDIFIER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEHUMIDIFYING&gt;</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehumidifier is an assembly that has the function to perform dehumidification.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b813"/>
  </rdf:Description>
