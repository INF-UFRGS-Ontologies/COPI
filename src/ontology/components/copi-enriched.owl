    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the outer shell of a heat exchanger that contains the shell-side fluid and provides structural support for the tube bundle.</skos:definition>
    <rdfs:label xml:lang="en">heat exchanger casing</rdfs:label>
    <rdfs:label xml:lang="pt-br">invólucro de calor de trocador</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
