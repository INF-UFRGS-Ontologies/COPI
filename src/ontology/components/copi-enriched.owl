  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145">
    <skos:definition xml:lang="en">[CFIHOS] A self operating valve that is set to open at a certain pressure level to prevent the pressure in a container or system from reaching unsafe levels.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A quick-acting, spring-loaded valve that opens to relieve pressure when the pressure exceeds the spring setting.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A valve in a pressurized system that is set to open and relieve pressure at a certain pressure level.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;RELIEF VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;PRESSURE RELIEF DEVICE&gt; that is set to open at a certain pressure level to prevent the pressure in a container or system from reaching unsafe levels</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A self operating valve that is set to open at a certain pressure level to prevent the pressure in a container or system from reaching unsafe levels.</skos:definition>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2706"/>
    <rdfs:label xml:lang="pt-br">válvula de alívio</rdfs:label>
    <rdfs:label xml:lang="en">relief valve</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de alívio é uma válvula projetada para abrir automaticamente em um ponto de ajuste de pressão predeterminado para aliviar o excesso de pressão e prevenir níveis de pressão inseguros em um sistema.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every relief valve is a valve that bears a pressure relief function, which realizes a pressure relief process that automatically opens the valve when system pressure exceeds a predetermined setpoint.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ReliefValve(x) ↔ (Valve(x) ∧ ∃f (PressureReliefFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3187">
    <rdf:rest rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3188"/>
    <rdf:first rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3181"/>
  </rdf:Description>
