  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000316">
    <skos:definition xml:lang="en">[CFIHOS] A physical object that has a protruding part through which a stream of fluid is directed.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A physical object that has a protruding part through which a stream of fluid is directed.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;NOZZLE&gt; is an &lt;ARTEFACT&gt; and a &lt;FLUID PORT&gt; and a &lt;CONNECTOR&gt; that is a protruding part through which a stream of fluid is directed</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] A projecting short piece of pipe that is attached to another (hollow) body.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A shaped orifice for directing fluid flow.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um bocal é um artefato material que possui uma parte protuberante com um orifício moldado projetado para direcionar o fluxo de fluido em um padrão específico.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Nozzle(x) ↔ MaterialArtifact(x) ∧ ∃f(FluidDirectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃o(ShapedOrifice(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃p(ProtrudingPart(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every nozzle is a material artifact that bears a fluid direction function and has a shaped orifice and protruding part as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">nozzle</rdfs:label>
    <rdfs:label xml:lang="pt-br">bocal</rdfs:label>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2283"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000232">
    <iof-av:naturalLanguageDefinition xml:lang="en">A condenser is a heat exchanger that bears a designed function to condense vapor to liquid by removing latent heat of vaporization.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um condensador é um trocador de calor que possui uma função projetada para condensar vapor em líquido removendo o calor latente de vaporização.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">condenser</rdfs:label>
    <rdfs:label xml:lang="pt-br">condensador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Condenser(x) ↔ (HeatExchanger(x) ∧ ∃f(CondensationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every condenser is a heat exchanger that bears a condensation function, and every heat exchanger that bears a condensation function is a condenser.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A cooler that is intended to change a vapour to liquid.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CONDENSER&gt; is a &lt;COOLER&gt; that has a capability of  &lt;CONDENSING&gt; a &lt;FLUID&gt; from &lt;VAPOUR&gt; to &lt;LIQUID&gt;</skos:definition>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b625"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess">
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3440"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2471"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b474"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b475"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b458"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3441"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b457"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3079"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2470"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3080"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de prevenção de refluxo</rdfs:label>
    <rdfs:label xml:lang="en">backflow prevention process</rdfs:label>
  </rdf:Description>
