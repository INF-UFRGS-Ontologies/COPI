   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1639">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TurbomachineryPowerGenerationProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">flow control process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de controle de fluxo</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalMotionPortion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">porção mecânico de movimento</rdfs:label>
    <rdfs:label xml:lang="en">mechanical motion portion</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215">
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to support and locate a moving or static element and capable of reducing friction and transfer forces in a connection.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BEARING&gt; is a &lt;SUPPORT&gt; intended to support and locate a moving or static element</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bearing is a material artifact that bears a support function and participates in friction reduction processes</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">bearing</rdfs:label>
    <rdfs:label xml:lang="pt-br">mancal</rdfs:label>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b211"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um mancal é um artefato material que é projetado para suportar e localizar elementos mecânicos móveis ou estáticos enquanto reduz o atrito na conexão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Bearing(x) ↔ MaterialArtifact(x) ∧ ∃f(SupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(FrictionReductionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/OutletEnd">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">outlet end</rdfs:label>
    <rdfs:label xml:lang="pt-br">extremidade de saída</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161">
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3038"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2440"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3399"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3037"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b450"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b449"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b466"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2441"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b467"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3398"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">função de prevenção de refluxo</rdfs:label>
    <rdfs:label xml:lang="en">backflow prevention function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MetallicStructure">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">metallic structure</rdfs:label>
    <rdfs:label xml:lang="pt-br">estrutura metálico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1645">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1651"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112">
    <skos:definition xml:lang="en">[CFIHOS] A valve that is intended for subsurface control/check operation.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DOWN HOLE SAFETY VALVE&gt; is a &lt;SAFETY VALVE&gt; that is intended for subsurface control/check operation</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança de fundo de poço é uma válvula de segurança que possui uma função de segurança subsuperficial para operações de alívio de pressão e controle de fluxo em poços ou outros ambientes subsuperficiais.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DownHoleSafetyValve(x) ↔ SafetyValve(x) ∧ ∃f(SubsurfaceSafetyFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SubsurfaceOperationProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every down hole safety valve is a safety valve that bears a SubsurfaceSafetyFunction and participates in SubsurfaceOperationProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">down hole safety valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de segurança de fundo de poço</rdfs:label>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1088"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160">
    <skos:definition xml:lang="en">[POSC Caesar] A wafer pattern valve that is a check valve with a wafer pattern valve body.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A wafer pattern valve that is a check valve with a wafer pattern valve body.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;WAFER CHECK VALVE&gt; is a &lt;WAFER PATTERN VALVE&gt; and a &lt;CHECK VALVE&gt;</skos:definition>
    <rdfs:label xml:lang="en">wafer check valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de retenção wafer</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wafer check valve is a check valve that has a wafer pattern valve body as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(WaferCheckValve(x) → CheckValve(x) ∧ ∃y(WaferPatternValveBody(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3403"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3402"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive subtype (both functional and structural aspects). The wafer pattern mounting configuration is a structural differentia that, while characteristic, may have edge cases or specialized variants that should not be automatically classified without expert validation. The structural differentia should be confirmed as both necessary and sufficient in industrial practice before upgrading to equivalent mode.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess">
    <rdfs:label xml:lang="pt-br">processo de exibição de informação</rdfs:label>
    <rdfs:label xml:lang="en">information display process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialPortion">
