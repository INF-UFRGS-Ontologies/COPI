  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationContentEntity">
    <rdfs:label xml:lang="pt-br">entidade de informação de conteúdo</rdfs:label>
    <rdfs:label xml:lang="en">information content entity</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An information content entity constituting the informational content—a measurement value, alarm state, or analysis result—encoded in a signal or record within petroleum production systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameSensingElement">
    <rdfs:label xml:lang="en">flame sensing element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de chama de sensoriamento</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SensingElement"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a sensing element that detects the presence or absence of a flame in a combustion system of petroleum production equipment.</skos:definition>
  </rdf:Description>
