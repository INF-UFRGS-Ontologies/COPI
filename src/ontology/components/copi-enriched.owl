  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1979">
    <rdf:rest rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1980"/>
    <rdf:first rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1973"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326">
    <skos:definition xml:lang="en">[CFIHOS] A fluid conductor that consists of pipe, possibly also including pumps, valves, and control devices, intended for conveying liquids, gases, or finely divided solids.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIPELINE&gt; is a &lt;CONTINOUS FLUID TRANSPORTER&gt; and a &lt;FLUID CONDUCTOR&gt; and a &lt;SYSTEM&gt; that consists of pipe, possibly also including pumps, valves, and control devices, intended for conveying liquids, gases, or finely divided solids</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] The principle underground transport of produced gas and oil.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A fluid conductor that consists of pipe, possibly also including pumps, valves, and control devices, intended for conveying liquids, gases, or finely divided solids.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A tube or system of tubes used for transporting crude oil and natural gas from the field or gathering system to the refinery.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Pipeline(x) ↔ EngineeredSystem(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2456"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">pipeline</rdfs:label>
    <rdfs:label xml:lang="en">pipeline</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipeline is an engineered system that bears a fluid transport function, consisting of pipes and possibly including pumps, valves, and control devices, designed for conveying liquids, gases, or finely divided solids between locations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um pipeline é um sistema engenheirado que possui uma função de transporte de fluidos, consistindo de tubos e possivelmente incluindo bombas, válvulas e dispositivos de controle, projetado para transportar líquidos, gases ou sólidos finamente divididos entre locais.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipeline is an engineered system that bears a fluid transport function and has pipe as a component part at some time.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000279">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um interruptor de fluxo é um instrumento que possui uma função de comutação de fluxo para automaticamente abrir ou fechar circuitos elétricos quando a taxa de fluxo de fluido atinge valores de limiar predeterminados.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow switch is an instrument that bears a flow switching function to automatically open or close electrical circuits when fluid flow rate reaches predetermined threshold values.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[CFIHOS] A functional switch that is intended to give a signal when the flow have reached a pre-set value.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOW SWITCH&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;PROCESS SWITCH&gt; and a &lt;FLOW MEASURING INSTRUMENT&gt;, that is specially and exclusively designed for &lt;SWITCHING&gt; at a given &lt;FLOW RATE&gt;</skos:definition>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1549"/>
    <rdfs:label xml:lang="en">flow switch</rdfs:label>
    <rdfs:label xml:lang="pt-br">interruptor de fluxo</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowSwitch(x) ↔ Instrument(x) ∧ ∃f(FlowSwitchingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow switch is an instrument that has the function to switch electrical circuits based on flow rate detection at preset thresholds.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2623">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1625">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasInput"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasMixturePortion"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b704">
    <rdf:rest rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b705"/>
    <rdf:first rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b700"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000249">
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b938"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b937"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b936"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">diaphragm pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba de diafragma</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIAPHRAGM PUMP&gt; is a &lt;RECIPROCATING PUMP&gt; intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere; flow rate is achieved through reciprocatory motion of the diaphragm</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A reciprocating pump intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DiaphragmPump(x) → (ReciprocatingPump(x) ∧ ∃d(FlexibleDiaphragm(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p(DiaphragmSealing(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diaphragm pump is a reciprocating pump that uses flexible diaphragms to displace liquid and seal the pumped fluid from atmospheric leakage.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de diafragma é uma bomba alternativa que usa diafragmas flexíveis para deslocar líquido e selar o fluido bombeado contra vazamento atmosférico.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under OWA, any pump with a flexible diaphragm component could be classified as a diaphragm pump, but there may be hybrid or specialized equipment containing diaphragms that should not be automatically classified into this maintenance category.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diaphragm pump is a reciprocating pump that has flexible diaphragm as component part at all times and participates in diaphragm sealing.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2991">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SiloWall"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2987">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidPortion"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1460">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VaporOutlet"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DeaeratedLiquidOutlet">
    <rdfs:label xml:lang="pt-br">saída desaerado líquido</rdfs:label>
    <rdfs:label xml:lang="en">deaerated liquid outlet</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000310">
    <iof-av:naturalLanguageDefinition xml:lang="en">A load cell is an instrument that converts mechanical force (tension, compression, pressure, or torque) into a proportional electrical signal for measurement purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma célula de carga é um instrumento que converte força mecânica (tração, compressão, pressão ou torque) em um sinal elétrico proporcional para fins de medição.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (LoadCell(x) ↔ Instrument(x) ∧ ∃f(ForceToElectricalTransductionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LOAD CELL&gt; is an &lt;ARTEFACT&gt; and a &lt;FORCE MEASURING ELEMENT&gt; and a &lt;TRANSDUCER&gt; that converts a force such as tension, compression, pressure, or torque into an electrical signal that can be measured</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A device based on strain gauge technology that helps measure the surface weight of coiled tubing.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A transducer which produces a signal with a defined relationship to the force applied to it.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The sensor component in a weight-indicator system that detects the tensional or compressional forces being imparted to the running string at surface.</skos:definition>
    <rdfs:label xml:lang="pt-br">célula de carga</rdfs:label>
    <rdfs:label xml:lang="en">load cell</rdfs:label>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2180"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every load cell is an instrument that bears a force-to-electrical transduction function and has a force-receiving element, transduction element, and electrical output.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3470">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentBody"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b2326">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceIndication"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000300">
    <skos:definition xml:lang="en">[OnePetro] An artificial lift system that is powered by injected fluid (usually water), that powers a pump similar to the rotating pump used in electrical submersible pumps.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HYDRAULIC PUMP&gt; is a &lt;POSITIVE DISPLACEMENT PUMP&gt; used in hydraulic drive systems and can be hydrostatic or hydrodynamic. It is a mechanical source of power that converts mechanical power into hydraulic energy (hydrostatic energy i.e. flow, pressure). It generates flow with enough power to overcome pressure induced by the load at the pump outlet. When a hydraulic pump operates, creates a vacuum at the pump inlet, which forces liquid from the reservoir into the inlet line to the pump and by mechanical action delivers this liquid to the pump outlet and forces it into the hydraulic system.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every hydraulic pump is a positive displacement pump that bears a hydraulic pumping function and participates in hydraulic power transmission processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba hidráulica é uma bomba de deslocamento positivo que converte energia mecânica em energia hidráulica para sistemas de acionamento hidráulico.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A hydraulic pump is a positive displacement pump that converts mechanical power into hydraulic energy for hydraulic drive systems.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (HydraulicPump(x) ↔ PositiveDisplacementPump(x) ∧ ∃f(HydraulicPumpingFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(HydraulicPowerTransmissionProcess(p) ∧ participatesIn(x,p)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">bomba hidráulica</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic pump</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1917"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1312"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on material composition (filter media) and mereological relationship (component of assembly). Under OWA, asserting equivalence could lead to unintended classification of any artifact made from filter media as a filter element, including specialized or hybrid components that contain filter media but serve different primary functions.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Filtro que é feito de meio filtrante e que é uma parte componente de um conjunto de filtro.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Filter that is made from filter media and that is a component part of a filter assembly.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">FilterElement SubClassOf Filter and (madeFrom some FilterMedia) and (componentPartOf some FilterAssembly)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">filter element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento filtrante</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER ELEMENT&gt; is a &lt;FILTER&gt; and that is the part of a filter assembly that is made from filter media</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FilterElement(x) → Filter(x) ∧ ∃m(FilterMedia(m) ∧ madeFrom(x,m)) ∧ ∃a(FilterAssembly(a) ∧ componentPartOf(x,a)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
