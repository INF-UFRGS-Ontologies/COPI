  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparateVapourSpace">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a distinct vapour space within petroleum production equipment where disengaged gas accumulates above the liquid level.</skos:definition>
    <rdfs:label xml:lang="pt-br">espaço separado de vapor</rdfs:label>
    <rdfs:label xml:lang="en">separate vapour space</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PowerConditioningCircuit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an electrical circuit that converts, regulates, or filters electrical power to meet the supply requirements of petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">power conditioning circuit</rdfs:label>
    <rdfs:label xml:lang="pt-br">circuito de potência de condicionamento</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
