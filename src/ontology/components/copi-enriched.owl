  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000146">
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2720"/>
    <rdfs:label xml:lang="pt-br">orifício de restrição</rdfs:label>
    <rdfs:label xml:lang="en">restriction orifice</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;RESTRICTION ORIFICE&gt; is a &lt;FLOW MODIFICATION ACCESSORY&gt; that is intended for use as a restrictor</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(RestrictionOrifice(x) ↔ FlowModificationAccessory(x) ∧ ∃f(FlowRestrictionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um orifício de restrição é um acessório de modificação de fluxo que possui a função de restringir o fluxo de fluido criando queda de pressão controlada através de constrição geométrica.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every restriction orifice is a flow modification accessory that bears a flow restriction function</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CombustionChamber">
    <rdfs:label xml:lang="pt-br">câmara de combustão</rdfs:label>
    <rdfs:label xml:lang="en">combustion chamber</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3146">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3152"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PRESSURE GAUGE&gt; is a &lt;PROCESS GAUGE&gt; and a &lt;PRESSURE MEASURING INSTRUMENT&gt; using a &lt;PRESSURE MEASURING ELEMENT&gt;</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A 'pressure measuring gauge' intended to measure and display a representation of a measured pressure</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device used to measure pressure.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A gauge intended to measure and display a representation of a measured pressure.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro é um indicador que possui a função de medir e exibir valores de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure gauge is an instrument that has the function to measure and display pressure</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">pressure gauge</rdfs:label>
    <rdfs:label xml:lang="pt-br">manômetro</rdfs:label>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2581"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureGauge(x) ↔ (Instrument(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2332">
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2337"/>
