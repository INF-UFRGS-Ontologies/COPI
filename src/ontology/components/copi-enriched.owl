  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192">
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2699"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1105"/>
