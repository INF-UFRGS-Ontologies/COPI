    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DischargeValve"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which one or more gaseous components are transferred from a gas phase into a liquid absorbent phase through contact in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de absorção</rdfs:label>
    <rdfs:label xml:lang="en">absorption process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000341">
    <rdfs:label xml:lang="en">rotary pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba rotativa</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2731"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2729"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2730"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2732"/>
    <skos:definition xml:lang="en">A rotary pump is a positive displacement pump that contains a chamber with gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing, and which has no separate inlet and outlet valves.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (RotaryPump(x) → PositiveDisplacementPump(x) ∧ ∃y (RotaryDisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ¬∃z (SeparateInletValve(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ¬∃w (SeparateOutletValve(w) ∧ hasComponentPartAtAllTimes(x,w)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every rotary pump is a positive displacement pump that has a rotary displacement mechanism as component part and lacks separate inlet and outlet valves.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A rotary pump is a positive displacement pump that contains a chamber with gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing, and which has no separate inlet and outlet valves.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba rotativa é uma bomba de deslocamento positivo que contém uma câmara com engrenagens, cames, parafusos, palhetas, êmbolos ou elementos similares acionados pela rotação relativa do eixo de acionamento ou carcaça, e que não possui válvulas separadas de entrada e saída.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the rotary mechanism is clearly necessary for rotary pumps, making it sufficient under OWA could lead to false positives where complex equipment containing rotary elements (like gearboxes with pumping side-effects or hybrid machines) might be misclassified as standard rotary pumps. The constructive differentia should be validated by domain experts before upgrading to equivalence.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3316">
