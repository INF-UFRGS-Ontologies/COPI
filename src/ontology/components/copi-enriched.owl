  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Chamber">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">chamber</rdfs:label>
    <rdfs:label xml:lang="pt-br">câmara</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an enclosed space within petroleum production equipment in which a process such as separation, compression, or storage takes place.</skos:definition>
  </rdf:Description>
