  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AutomaticTransferMechanism">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">mecanismo automático de transferência</rdfs:label>
    <rdfs:label xml:lang="en">automatic transfer mechanism</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the mechanical or electrical assembly that automatically transfers an electrical load from one power source to another.</skos:definition>
