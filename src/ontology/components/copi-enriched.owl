  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238">
    <skos:definition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coupling is a material artifact that has the function to connect separate parts or systems together.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="en">coupling</rdfs:label>
    <rdfs:label xml:lang="pt-br">acoplamento</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um acoplamento é um artefato material que possui uma função de conexão para unir partes ou sistemas separados.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n55b6dbcc703c488db80806efee5015fab589"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Coupling(x) ↔ MaterialArtifact(x) ∧ ∃f(ConnectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab217">
