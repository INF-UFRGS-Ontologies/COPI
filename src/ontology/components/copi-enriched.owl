    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1579"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatingMedium">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">heating medium</rdfs:label>
    <rdfs:label xml:lang="pt-br">meio de aquecimento</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the fluid—steam, hot oil, or heated water—used to supply thermal energy to a process stream in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1229">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1230"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1225"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">axial displacement transmission process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de transmissão de deslocamento axial</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which the axial displacement of a rotating shaft is measured and the corresponding signal transmitted to a remote monitoring system.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000365">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every tubing head is a wellhead component that bears a tubing support and connection function, has a tubing bowl as component part, and has a Christmas tree connection interface as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A tubing head is a wellhead component that supports the tubing hanger and provides a connection interface for attaching the Christmas tree to the wellhead assembly.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3218"/>
    <rdfs:label xml:lang="en">tubing head</rdfs:label>
    <rdfs:label xml:lang="pt-br">cabeça de coluna</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A tubing head is a wellhead component that supports the tubing hanger and provides a connection interface for attaching the Christmas tree to the wellhead assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma cabeça de coluna é um componente de cabeça de poço que suporta o suspensor de coluna e fornece uma interface de conexão para fixar a árvore de natal ao conjunto de cabeça de poço.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TubingHead(x) ↔ WellheadComponent(x) ∧ ∃f(TubingSupportAndConnectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p1(TubingBowl(p1) ∧ hasComponentPartAtAllTimes(x,p1)) ∧ ∃p2(ChristmasTreeConnectionInterface(p2) ∧ hasComponentPartAtAllTimes(x,p2)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1692">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DischargePort"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3225">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3220"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3226"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000345">
    <skos:definition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</skos:definition>
    <rdfs:label xml:lang="en">scrubber</rdfs:label>
    <rdfs:label xml:lang="pt-br">lavador de gases</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2806"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2808"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2807"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2810"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2809"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lavador de gases é um separador que limpa gás através da lavagem do fluxo gasoso com líquido para remover contaminantes como poeira, partículas ou substâncias indesejadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Scrubber(x) ↔ Separator(x) ∧ ∃f,p,g,l (SeparationFunction(f) ∧ bearerOf(x,f) ∧ LiquidWashingProcess(p) ∧ participatesIn(x,p) ∧ GasPortion(g) ∧ LiquidPortion(l) ∧ hasInput(x,g) ∧ hasInput(x,l)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every scrubber is a separator that has the function of separation and participates in liquid washing processes with both gas and liquid inputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3261">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ConnectorAssembly"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1280">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparatorInlet">
    <rdfs:label xml:lang="pt-br">entrada de separador</rdfs:label>
    <rdfs:label xml:lang="en">separator inlet</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VesselInlet"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the nozzle through which a multiphase process stream enters a separator vessel in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000377">
    <skos:definition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</skos:definition>
    <rdfs:label xml:lang="en">wellhead</rdfs:label>
    <rdfs:label xml:lang="pt-br">cabeçal de poço</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3410"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every wellhead is an assembly that bears a well surface control function and has component parts including casing hangers and connection to wellbore</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um cabeçal de poço é um conjunto que porta uma função de controle superficial do poço e fornece a interface estrutural e de controle entre um poço e os equipamentos de superfície.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Wellhead(x) ↔ Assembly(x) ∧ ∃f(WellSurfaceControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃h(CasingHanger(h) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃w(Wellbore(w) ∧ hasConnectionTo(x,w)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2581">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureSensor"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2458">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PneumaticCylinder"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b498">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b504"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de transferência de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy transfer process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which energy in the form of heat, work, or electromagnetic radiation is transferred from one medium or system to another.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1536">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1534"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2180">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ProcessingElement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b408">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000212"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialComponent">
    <rdfs:label xml:lang="en">material component</rdfs:label>
    <rdfs:label xml:lang="pt-br">componente de material</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a discrete material component of petroleum production equipment that contributes to its overall function.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3028">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000248">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b909"/>
    <rdfs:label xml:lang="pt-br">atuador de diafragma</rdfs:label>
    <rdfs:label xml:lang="en">diaphragm actuator</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Classification basis is constructive - identity given by diaphragm mechanism. Under OWA, sufficient conditions would force any equipment with a diaphragm component to be classified as a diaphragm actuator, potentially including complex hybrid systems or custom equipment where the diaphragm serves auxiliary functions. Starting with necessary conditions protects against such false positives.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DiaphragmActuator ⊑ Actuator ⊓ ∃hasComponentPartAtAllTimes.Diaphragm</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A diaphragm actuator is an actuator that uses a diaphragm as an essential component for converting control signals into mechanical motion or force to operate other equipment.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diaphragm actuator is an actuator that uses a diaphragm as an essential component for converting control signals into mechanical motion or force to operate other equipment.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um atuador de diafragma é um atuador que utiliza um diafragma como componente essencial para converter sinais de controle em movimento mecânico ou força para operar outros equipamentos.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(DiaphragmActuator(x) → (Actuator(x) ∧ ∃y(Diaphragm(y) ∧ hasComponentPartAtAllTimes(x,y))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3362">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2100">
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2102"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RunPort">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
    <rdfs:label xml:lang="en">run port</rdfs:label>
    <rdfs:label xml:lang="pt-br">bocal de operação</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a port on a pipeline valve or fitting that provides a straight-through bore for passage of a pipeline pig or inspection tool.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2946">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SupportFrame"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralForce">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
    <rdfs:label xml:lang="en">structural force</rdfs:label>
    <rdfs:label xml:lang="pt-br">força estrutural</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A quality inhering in a material entity, constituting a force transmitted through a structural element of petroleum production equipment due to imposed loads.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173">
    <rdfs:label xml:lang="en">temperature indication function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de indicação de temperatura</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the local display of the temperature of a process stream or equipment surface.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b88"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b87"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3069"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3070"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000237">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b717"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b719"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b718"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b720"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b716"/>
    <skos:definition xml:lang="en">A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão que utiliza o princípio de Coriolis através de tubos de fluxo oscilantes especializados para medir diretamente a vazão mássica de fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">medidor de vazão Coriolis</rdfs:label>
    <rdfs:label xml:lang="en">coriolis mass flow meter</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CoriolisMassFlowMeter(x) → FlowMeter(x) ∧ ∃y(CoriolisFlowTube(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CoriolisPrinciple(z) ∧ utilizesPhysicalPrinciple(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coriolis mass flow meter is a flow meter that has component part at all times some Coriolis flow tube and utilizes the Coriolis principle.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under the Open World Assumption, defining sufficient conditions based on Coriolis principle usage could lead to false positives where other devices using Coriolis forces (like gyroscopes or accelerometers) might be incorrectly classified as flow meters. The structural differentia provides necessary conditions that can be validated by domain experts.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1097">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DryingChamber"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1854">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicCylinder"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2950">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2946"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2951"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b87">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureIndicationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2777">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElbowBody">
    <skos:definition xml:lang="en">A material artifact that constitutes the curved body of a pipe elbow that changes the direction of fluid flow in petroleum production piping.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">corpo de cotovelo</rdfs:label>
    <rdfs:label xml:lang="en">elbow body</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2527">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114">
    <skos:definition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</skos:definition>
    <rdfs:label xml:lang="en">emergency shut down valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de parada de emergência</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (EmergencyShutDownValve(x) ↔ (Valve(x) ∧ ∃f(EmergencyShutDownFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1197"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every emergency shut down valve is a valve that has an emergency shut down function and has an actuator and has a fail-safe system.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de parada de emergência é uma válvula que possui uma função de parada de emergência, permitindo o isolamento rápido de fluxo em situações de emergência através de mecanismos atuados com capacidade à prova de falhas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b184"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2993"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b183"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2992"/>
    <rdfs:label xml:lang="en">storage function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de armazenamento</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the temporary or permanent containment of fluids or materials in a defined storage volume.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CarrierFluid">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a fluid used to transport or suspend another substance through petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">fluido de portador</rdfs:label>
    <rdfs:label xml:lang="en">carrier fluid</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DampingFunction">
    <rdfs:label xml:lang="pt-br">função de amortecimento</rdfs:label>
    <rdfs:label xml:lang="en">damping function</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b732"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b733"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the absorption and dissipation of mechanical energy to reduce the amplitude of oscillations or vibrations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InletEnd">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">extremidade de entrada</rdfs:label>
    <rdfs:label xml:lang="en">inlet end</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the inlet end of a pipe, fitting, or piece of petroleum production equipment through which fluid enters.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction">
    <skos:definition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1505"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1506"/>
    <rdfs:label xml:lang="en">flow modification function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de modificação de fluxo</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureSignalPair">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <rdfs:label xml:lang="en">pressure signal pair</rdfs:label>
    <rdfs:label xml:lang="pt-br">par de pressão de sinal</rdfs:label>
    <skos:definition xml:lang="en">An information content entity constituting a pair of pressure signals representing the upstream and downstream pressures at two points of a petroleum production process.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um lançador de pig é um vaso que possui função de lançamento de pig para inserir pigs de duto em sistemas de tubulação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pig launcher is a vessel that has the function to launch pipeline pigs and has a pipeline connection component.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2298"/>
    <rdfs:label xml:lang="en">pig launcher</rdfs:label>
    <rdfs:label xml:lang="pt-br">lançador de pig</rdfs:label>
    <skos:definition xml:lang="en">A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PigLauncher(x) ↔ (Vessel(x) ∧ ∃f(PigLaunchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(PipelineConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245">
    <skos:definition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</skos:definition>
    <rdfs:label xml:lang="pt-br">densitômetro</rdfs:label>
    <rdfs:label xml:lang="en">densitometer</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every densitometer is an instrument that has the function of measuring density.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um densitômetro é um instrumento que possui uma função de medição de densidade.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b850"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1450">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalVariable">
    <rdfs:label xml:lang="pt-br">variável físico</rdfs:label>
    <rdfs:label xml:lang="en">physical variable</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
    <skos:definition xml:lang="en">An information content entity constituting a measurable physical property—such as pressure, temperature, or flow rate—of a process stream or equipment state in petroleum production.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1102">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1098"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TangentialInlet">
    <rdfs:label xml:lang="pt-br">entrada tangencial</rdfs:label>
    <rdfs:label xml:lang="en">tangential inlet</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an inlet nozzle that introduces fluid tangentially into a cyclonic separator to induce rotational flow for phase separation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (HumidityAnalyser(x) ↔ ProcessAnalyzer(x) ∧ ∃f (HumidityMeasurementFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um analisador de umidade é um analisador de processo que é projetado para medir e indicar o conteúdo de umidade ou vapor d'água em correntes de processo ou ambientes.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1832"/>
    <skos:definition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">humidity analyser</rdfs:label>
    <rdfs:label xml:lang="pt-br">analisador de umidade</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every humidity analyser is a process analyzer that has the function to measure humidity content.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2005">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparateVapourSpace"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationFunction">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b786"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b787"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de desumidificação</rdfs:label>
    <rdfs:label xml:lang="en">dehumidification function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the removal of water vapour from a gas stream to reduce its relative humidity or dew point.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidPort">
    <rdfs:label xml:lang="pt-br">bocal hidráulico de fluido</rdfs:label>
    <rdfs:label xml:lang="en">hydraulic fluid port</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a port through which hydraulic fluid enters or exits a hydraulic component of petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionFunction">
    <skos:definition xml:lang="en">A signal transmission function borne by petroleum production equipment whose realization constitutes the measurement of fluid electrical conductivity and the transmission of the corresponding signal to a remote monitoring system.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b627"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b628"/>
    <rdfs:label xml:lang="pt-br">função de transmissão de condutividade</rdfs:label>
    <rdfs:label xml:lang="en">conductivity transmission function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1300">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1099">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1100"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HydrocarbonFluid">
    <skos:definition xml:lang="en">A material artifact that constitutes a fluid consisting primarily of hydrocarbon compounds produced from or processed in a petroleum production system.</skos:definition>
    <rdfs:label xml:lang="pt-br">fluido de hidrocarboneto</rdfs:label>
    <rdfs:label xml:lang="en">hydrocarbon fluid</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3252"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3251"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the simultaneous measurement and transmission of multiple process variables to a remote control or monitoring system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de transmissão de múltiplos serviços</rdfs:label>
    <rdfs:label xml:lang="en">multi service transmission function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MatingSurface">
    <rdfs:label xml:lang="en">mating surface</rdfs:label>
    <rdfs:label xml:lang="pt-br">superfície de encaixe</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a machined surface that mates with a corresponding surface of another component to form a seal or mechanical joint in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalProcessor">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">signal processor</rdfs:label>
    <rdfs:label xml:lang="pt-br">processador de sinal</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a component that processes an input signal—by amplification, filtering, or mathematical transformation—to produce an output signal in petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CylinderBlock">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">bloco de cilindro</rdfs:label>
    <rdfs:label xml:lang="en">cylinder block</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the main structural casting of a reciprocating engine or compressor that houses the cylinders and provides mounting points for associated components.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1408">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1409"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b763">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2194">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2409">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShearingBlade">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">lâmina de cisalhamento</rdfs:label>
    <rdfs:label xml:lang="en">shearing blade</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the cutting blade of a shear ram in a blowout preventer that severs a tubular string for well control purposes.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b571">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226">
    <iof-av:primitiveRationale xml:lang="en">Constructive identity based on structural design for check valve accommodation. Under OWA, any housing designed for check valves could include specialized configurations, custom manifolds, or hybrid designs that should not be automatically classified as standard check valve bodies without domain expert validation of the structural differentia.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um corpo de válvula que é especificamente projetado para acomodar e alojar os mecanismos internos de uma válvula de retenção dentro de uma barreira de contenção de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b465"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CheckValveBody(x) → ValveBody(x) ∧ ∃y(CheckValve(y) ∧ designedFor(x,y)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">check valve body</rdfs:label>
    <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CheckValveBody subClassOf ValveBody and (designedFor some CheckValve)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311">
    <skos:definition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</skos:definition>
    <rdfs:label xml:lang="en">manifold</rdfs:label>
    <rdfs:label xml:lang="pt-br">manifold</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every manifold is an assembly that has-component-part-at-all-times some chamber and has-component-part-at-all-times some multiple fluid openings and bears some fluid distribution function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manifold é um conjunto que possui uma câmara com múltiplas aberturas de fluido projetada para distribuir o fluxo de fluido.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2160"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2159"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2161"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Manifold(x) → Assembly(x) ∧ ∃c(Chamber(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃o(MultipleFluidOpenings(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃f(FluidDistributionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type, manifolds are defined by structural configuration. Under OWA, asserting equivalence would force any assembly with a chamber and multiple openings to be classified as a manifold, potentially misclassifying complex equipment with manifold-like components (e.g., turbine casings, complex valves). Starting with necessary conditions protects against false positives.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BurnerTip">
    <skos:definition xml:lang="en">A material artifact that constitutes the terminal component of a burner through which fuel is discharged and ignited in petroleum production combustion equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">ponta de queimador</rdfs:label>
    <rdfs:label xml:lang="en">burner tip</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2632">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidBulkStorageFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">solid bulk storage function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de armazenamento de sólidos a granel</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2928"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2929"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the containment and temporary storage of solid bulk materials such as catalyst, proppant, or chemical reagents.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085">
    <rdfs:label xml:lang="pt-br">visor</rdfs:label>
    <rdfs:label xml:lang="en">sight glass</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Instrumento que porta uma VisualInspectionFunction e que consiste em uma interface de visualização transparente que permite observação óptica direta de condições internas, propriedades de fluidos ou estados de processo dentro de recipientes, vasos ou sistemas de tubulação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2908"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every sight glass is an instrument that bears a visual inspection function and enables direct optical observation of process internals through a transparent viewing interface.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SightGlass(x) ↔ Instrument(x) ∧ ∃f(VisualInspectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000364">
    <iof-av:naturalLanguageDefinition xml:lang="en">A tubing hanger is an assembly that supports tubing strings in wellheads with integrated sealing to isolate tubing conduit from annulus.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um suporte de coluna de produção é um conjunto que suporta colunas de produção em cabeças de poço com vedação integrada para isolar o conduto da coluna do anular.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every tubing hanger is an assembly that bears a tubing support function and has component parts including a sealing system, support mechanism, and tubing connection.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">A tubing hanger is an assembly that supports tubing strings in wellheads with integrated sealing to isolate tubing conduit from annulus.</skos:definition>
    <rdfs:label xml:lang="en">tubing hanger</rdfs:label>
    <rdfs:label xml:lang="pt-br">suporte de coluna de produção</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TubingHanger(x) ↔ (Assembly(x) ∧ ∃f(TubingSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SealingSystem(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(SupportMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(TubingConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3197"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestElement">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">flame arrest element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de chama de bloqueio</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the porous or narrow-channel internal element of a flame arrester that extinguishes a propagating flame.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2973">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SpacingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DehumidificationProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de desumidificação</rdfs:label>
    <rdfs:label xml:lang="en">dehumidification process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which water vapour is removed from a gas stream to reduce its relative humidity or dew point to a specified level.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3406">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1586">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2637">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2633"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2408">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidTransportProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LocalPressureDisplay">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting an instrument mounted locally to a pressure measurement point that visually displays the process pressure.</skos:definition>
    <rdfs:label xml:lang="en">local pressure display</rdfs:label>
    <rdfs:label xml:lang="pt-br">display local de pressão</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000316">
    <iof-av:naturalLanguageDefinition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um bocal é um artefato material que possui uma parte protuberante com um orifício moldado projetado para direcionar o fluxo de fluido em um padrão específico.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every nozzle is a material artifact that bears a fluid direction function and has a shaped orifice and protruding part as component parts.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">bocal</rdfs:label>
    <rdfs:label xml:lang="en">nozzle</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2239"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Nozzle(x) ↔ MaterialArtifact(x) ∧ ∃f(FluidDirectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃o(ShapedOrifice(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃p(ProtrudingPart(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b314">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DrillCollar"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b890">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationDetector"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b466">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every bell nipple is a pipe that bears a DrillingFluidConductionFunction and has an enlarged diameter shape and is located at a wellhead assembly.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um bell nipple é um tubo que conduz fluidos de perfuração em operações de perfuração e é caracterizado por um diâmetro alargado que serve como funil e uma localização no conjunto da cabeça do poço.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A bell nipple is a pipe that conducts drilling fluids in drilling operations and is characterized by an enlarged diameter that serves as a funnel and a location at the wellhead assembly.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">bell nipple</rdfs:label>
    <rdfs:label xml:lang="pt-br">bell nipple</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b235"/>
    <skos:definition xml:lang="en">A bell nipple is a pipe that conducts drilling fluids in drilling operations and is characterized by an enlarged diameter that serves as a funnel and a location at the wellhead assembly.</skos:definition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BellNipple(x) ↔ (Pipe(x) ∧ ∃f(DrillingFluidConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(EnlargedDiameter(s) ∧ hasCharacteristicShape(x,s)) ∧ ∃l(WellheadAssembly(l) ∧ hasLocation(x,l))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillCollar">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a thick-walled section of the drill string that provides weight on bit and stiffness near the drill bit.</skos:definition>
    <rdfs:label xml:lang="en">drill collar</rdfs:label>
    <rdfs:label xml:lang="pt-br">broca de perfuração de perfuração</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhysicalObject">
    <skos:definition xml:lang="en">A material artifact that constitutes a discrete physical entity within a petroleum production system that occupies space and has defined material properties.</skos:definition>
    <rdfs:label xml:lang="pt-br">objeto físico</rdfs:label>
    <rdfs:label xml:lang="en">physical object</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1465">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3116">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensorProtectionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which dispersed droplets of one phase aggregate within another to form larger droplets that can be more readily separated from the continuous phase.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de coalescência</rdfs:label>
    <rdfs:label xml:lang="en">coalescence process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1572">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b491">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentFunction">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2618"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2619"/>
    <rdfs:label xml:lang="en">pressure containment function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de contenção de pressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A containment function borne by petroleum production equipment whose realization constitutes the retention of fluid within a defined pressure boundary to prevent uncontrolled release.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1593">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TangentialInlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2436"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2437"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de placas é um trocador de calor que possui placas de transferência de calor como sua superfície primária de transferência de calor.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the plate-based structure is characteristic, under the Open World Assumption, asserting equivalence could lead to false positives where any equipment with heat transfer plates (e.g., specialized hybrid equipment, multi-function process units) would be automatically classified as a standard plate heat exchanger. Domain expert validation is needed to confirm the structural differentia is sufficient.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</skos:definition>
    <rdfs:label xml:lang="pt-br">trocador de calor de placas</rdfs:label>
    <rdfs:label xml:lang="en">plate heat exchanger</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every plate heat exchanger is a heat exchanger that has component part heat transfer plates at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PlateHeatExchanger(x) → HeatExchanger(x) ∧ ∃p(HeatTransferPlate(p) ∧ hasComponentPartAtAllTimes(x,p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2844">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2839"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b141">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b136"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1881">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicPumpingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidOutlet">
    <rdfs:label xml:lang="en">fluid outlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">saída de fluido</rdfs:label>
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an outlet port through which fluid leaves a vessel, valve, or piece of petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every positive displacement pump is a pump that has a displacement mechanism as component part at all times and participates in positive displacement processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2526"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2524"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2525"/>
    <rdfs:label xml:lang="pt-br">bomba de deslocamento positivo</rdfs:label>
    <rdfs:label xml:lang="en">positive displacement pump</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical mechanism. Under OWA, sufficient conditions based on displacement mechanism alone could lead to false positives where specialized equipment containing displacement elements might be incorrectly classified as standard positive displacement pumps.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba de deslocamento positivo é uma bomba que transporta líquido através do princípio de deslocamento alternativo ou rotativo com volume de deslocamento fixo por ciclo.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PositiveDisplacementPump(x) → Pump(x) ∧ ∃y(DisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(PositiveDisplacementProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b387">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b383"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b388"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1617">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReciprocatingPistonMechanism"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3027">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DrillString">
    <rdfs:label xml:lang="en">drill string</rdfs:label>
    <rdfs:label xml:lang="pt-br">coluna de perfuração</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the assembly of drill pipe, drill collars, and bottom-hole assembly that transmits rotation and drilling fluid from surface to the drill bit.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2625">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2623"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000374">
    <skos:definition xml:lang="en">A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VesselShell(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃f(PressureContainmentFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma parte de objeto por fiat que é o limite estrutural externo de contenção de pressão de um vaso, projetada para encerrar e isolar o conteúdo interno enquanto suporta cargas de pressão interna.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3362"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">parte de objeto por fiat</rdfs:label>
    <rdfs:label xml:lang="en">vessel shell</rdfs:label>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural configuration as outer pressure-containing part of vessel. Under Open World Assumption, sufficient conditions are difficult to establish - other structural components might also be pressure-containing parts of vessels in specialized designs.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">VesselShell SubClassOf: FiatObjectPart and partOf some Vessel and bearerOf some PressureContainmentFunction</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134">
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by specific structural features (needle plug geometry), providing sufficient conditions under the Open World Assumption could lead to over-classification. Complex valve assemblies or custom equipment containing needle-like mechanisms might be incorrectly classified as standard needle valves for maintenance purposes.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</skos:definition>
    <rdfs:label xml:lang="en">needle valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula agulha</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(NeedleValve(x) → Valve(x) ∧ ∃y(NeedlePlug(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(SmallOrificeSeat(z) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula agulha é uma válvula que possui um membro de fechamento cônico em forma de agulha que se assenta em um pequeno orifício para fornecer controle preciso de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2234"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every needle valve is a valve that has a needle plug component and has a small orifice seat component.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2089">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalOutput"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b728">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b726"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1928">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CombustionChamber"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DisplayOrOutputDevice">
    <rdfs:label xml:lang="pt-br">dispositivo de display de ou de saída</rdfs:label>
    <rdfs:label xml:lang="en">display or output device</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a device that presents process variable values or equipment states in a human-readable or machine-readable form.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081">
    <rdfs:label xml:lang="pt-br">filtro</rdfs:label>
    <rdfs:label xml:lang="en">filter</rdfs:label>
    <skos:definition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Filter(x) ↔ (Separator(x) ∧ ∃f(FiltrationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilterElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃h(FilterHousing(h) ∧ hasComponentPartAtAllTimes(x,h))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1252"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter is a separator that has a filtration function and has a filter element as component part and has a filter housing as component part</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro é um separador que possui uma função de filtração para remover seletivamente constituintes indesejados de um fluxo de fluido usando um elemento filtrante dentro de um alojamento de filtro.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction">
    <rdfs:label xml:lang="en">bottom hole drilling function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de perfuração de fundo de poço</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b303"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b302"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the cutting and disintegration of subsurface rock at the bottom of a wellbore to advance the drill hole.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess">
    <rdfs:label xml:lang="en">flow restriction process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de restrição de fluxo</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the flow rate or pressure of a fluid stream is reduced in a controlled manner by introducing a fixed or variable resistance.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b769">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2302">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LauncherValve"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1776">
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1778"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowlinePipe">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a pipe forming part of a flowline that conveys produced fluids between a wellhead and a gathering or processing facility.</skos:definition>
    <rdfs:label xml:lang="pt-br">tubo de linha de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flowline pipe</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1046">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1039"/>
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2582">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalProcessor"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b313">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BitSub"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b97">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b98"/>
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b92"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3198">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingSupportFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de compressão</rdfs:label>
    <rdfs:label xml:lang="en">compression process</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which the pressure of a gas is increased by reducing its volume through mechanical work applied by petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1095">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1099"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidDischargeOpening">
    <rdfs:label xml:lang="en">solid discharge opening</rdfs:label>
    <rdfs:label xml:lang="pt-br">abertura de sólido de descarga</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an opening at the base of a vessel or separator through which separated solid material is discharged in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VesselOutlet">
    <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the outlet nozzle or connection through which fluid leaves a process vessel in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">saída de vaso</rdfs:label>
    <rdfs:label xml:lang="en">vessel outlet</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConductivitySensor">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">sensor de condutividade</rdfs:label>
    <rdfs:label xml:lang="en">conductivity sensor</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a sensing element that measures the electrical conductivity of a fluid in petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2137">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ForceToElectricalTransductionFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1773">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b67">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b62"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b68"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293">
    <skos:definition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</skos:definition>
    <rdfs:label xml:lang="pt-br">header</rdfs:label>
    <rdfs:label xml:lang="en">header</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Header ≡ manifold ⊓ ∃connects_to.SmallPipe ⊓ ∃participatesIn.MultiStreamDistributionProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um header é um manifold que se conecta a muitos tubos menores para coletar descarga de múltiplas fontes ou distribuir fluido para múltiplos destinos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Header(x) ↔ (manifold(x) ∧ ∃y(SmallPipe(y) ∧ connects_to(x,y)) ∧ ∃z(MultiStreamDistributionProcess(z) ∧ participatesIn(x,z))))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1764"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2661"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2656"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2658"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2657"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2659"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2660"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <skos:definition xml:lang="en">A reciprocating pump is a pump that contains pistons or plungers designed to move in a reciprocating motion within cylindrical chambers to displace fluid through positive displacement action.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba alternativa é uma bomba que contém pistões ou êmbolos projetados para se moverem em movimento alternativo dentro de câmaras cilíndricas para deslocar fluido através de ação de deslocamento positivo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A reciprocating pump is a pump that contains pistons or plungers designed to move in a reciprocating motion within cylindrical chambers to displace fluid through positive displacement action.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ReciprocatingPump(x) → Pump(x) ∧ ∃m(ReciprocatingDisplacementMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p(PistonOrPlunger(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃c(CylindricalChamber(c) ∧ hasComponentPartAtAllTimes(x,c)))</iof-av:firstOrderLogicAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">bomba alternativa</rdfs:label>
    <rdfs:label xml:lang="en">reciprocating pump</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under Open World Assumption, asserting equivalence based on structural differentia could lead to false positives where complex equipment containing reciprocating elements (like reciprocating compressors with auxiliary pumps, or hybrid systems) might be incorrectly classified as standard reciprocating pumps. The structural mechanism is necessary but sufficient conditions require domain expert validation.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every reciprocating pump is a pump that has as component part at all times a reciprocating displacement mechanism and has as component part at all times pistons or plungers and has as component part at all times cylindrical chambers.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MotorHousing">
    <rdfs:label xml:lang="en">motor housing</rdfs:label>
    <rdfs:label xml:lang="pt-br">carcaça de motor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the outer casing of an electric motor that provides mechanical protection and supports the stator and end shields.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3411">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WellSurfaceControlFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1036">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InternalTrays"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de redução de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure reduction process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which the pressure of a fluid is reduced from a higher upstream value to a controlled lower downstream value.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127">
    <skos:definition xml:lang="en">An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1945"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um indicador é um instrumento que exibe ou mostra o valor ou status de uma variável medida ou condição para torná-la perceptível aos operadores.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">indicador</rdfs:label>
    <rdfs:label xml:lang="en">indicator</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every indicator is an instrument that bears an indication function to display process information in human-perceptible form.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Indicator(x) ↔ (Instrument(x) ∧ ∃f(IndicationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b988">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b983"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b989"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000261">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ElectricGenerator(x) ↔ (Assembly(x) ∧ ∃f(ElectricEnergyGenerationFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1144"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um gerador elétrico é um conjunto que possui a função de converter energia não-elétrica em energia elétrica</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">An electric generator is an assembly that bears the function of converting non-electric energy into electric energy</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric generator is an assembly that has the function to convert non-electric energy into electric energy</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">gerador elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electric generator</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DegassingChamber">
    <skos:definition xml:lang="en">A material artifact that constitutes the enclosed space in which dissolved or entrained gases are released from a liquid stream in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">degassing chamber</rdfs:label>
    <rdfs:label xml:lang="pt-br">câmara de degaseificação</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2102">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2103"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1690">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShakingFunction">
    <rdfs:label xml:lang="en">shaking function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de agitação mecânica</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the application of oscillating mechanical motion to a screen or separator to promote separation of solids from a fluid.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2859"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2860"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143">
    <skos:definition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um manômetro é um indicador que possui a função de medir e exibir valores de pressão.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pressure gauge</rdfs:label>
    <rdfs:label xml:lang="pt-br">manômetro</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2565"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure gauge is an instrument that has the function to measure and display pressure</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureGauge(x) ↔ (Instrument(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InstrumentationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">instrumentation process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de instrumentação</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A planned process in which physical process variables are measured, transmitted, or controlled by instrumentation to enable monitoring and regulation of petroleum production operations.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1323">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Stack"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StandardizedElectricalSignal">
    <rdfs:label xml:lang="pt-br">sinal padronizado elétrico</rdfs:label>
    <rdfs:label xml:lang="en">standardized electrical signal</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">An information content entity constituting an electrical signal in a standardised format—such as 4–20 mA or 0–10 V—used to transmit process variable values between petroleum production instrumentation components.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">electrical current interruption function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de interrupção de corrente elétrica</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b541"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b540"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the interruption of electrical current flow in a circuit under normal operating or fault conditions.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2080"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2081"/>
    <rdfs:label xml:lang="pt-br">função de chaveamento de nível</rdfs:label>
    <rdfs:label xml:lang="en">level switching function</rdfs:label>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the fluid level in a vessel crosses a defined high or low threshold.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2713">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1561">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SensingElement">
    <skos:definition xml:lang="en">A material artifact that constitutes a primary element that directly responds to a physical or chemical variable to generate a measurement signal in petroleum production instrumentation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">elemento de sensoriamento</rdfs:label>
    <rdfs:label xml:lang="en">sensing element</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingProcess">
    <rdfs:label xml:lang="en">pig launching process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de lançamento de pig</rdfs:label>
    <skos:definition xml:lang="en">A planned process in which a pipeline pig is introduced into a pipeline under operating pressure to perform internal cleaning, inspection, or product separation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b503">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControlEquipment"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2626">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1784">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158">
    <rdfs:label xml:lang="pt-br">vaso</rdfs:label>
    <rdfs:label xml:lang="en">vessel</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Vessel(x) ↔ Assembly(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(VesselShell(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃h(VesselHead(h) ∧ hasComponentPartAtAllTimes(x,h)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel is an assembly that bears a containment function and has a vessel shell and vessel head as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3338"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirInlet">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes an inlet port through which air enters a combustion device, air supply system, or enclosure in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">entrada de ar</rdfs:label>
    <rdfs:label xml:lang="en">air inlet</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000241">
    <rdfs:label xml:lang="pt-br">degaseificador</rdfs:label>
    <rdfs:label xml:lang="en">degasser</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Degasser(x) ↔ (Separator(x) ∧ ∃f (DegassingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A degasser is a separator that removes gases from drilling fluids by realizing a degassing function.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um degaseificador é um separador que remove gases de fluidos de perfuração realizando uma função de degaseificação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A degasser is a separator that removes gases from drilling fluids by realizing a degassing function.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every degasser is a separator that bears a degassing function and has drilling fluid as input and degassed drilling fluid plus separated gases as outputs.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b768"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b263">
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b266"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278">
    <skos:definition xml:lang="en">A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um medidor de vazão é um instrumento que possui uma função de medir taxa de fluxo e produzir sinais ou indicações correspondentes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">flow meter</rdfs:label>
    <rdfs:label xml:lang="pt-br">medidor de vazão</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeter(x) ↔ Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow meter is an instrument that bears a flow measurement function and has component parts including a flow sensing element and signal processing unit</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1488"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MultiphaseFluidPortion">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of fluid containing two or more distinct phases—gas, liquid hydrocarbon, or water—at a defined point in a petroleum production process.</skos:definition>
    <rdfs:label xml:lang="pt-br">porção multifásico de fluido</rdfs:label>
    <rdfs:label xml:lang="en">multiphase fluid portion</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1870">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RotationalOutput"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ValveStemSeal">
    <rdfs:label xml:lang="en">valve stem seal</rdfs:label>
    <rdfs:label xml:lang="pt-br">vedação de válvula de haste</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the seal assembly around the valve stem that prevents process fluid leaking to atmosphere in petroleum production valves.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208">
    <skos:definition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b61"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <rdfs:label xml:lang="en">agitator</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which a heterogeneous mixture is divided into two or more fractions of differing composition by exploiting differences in physical properties.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de separação</rdfs:label>
    <rdfs:label xml:lang="en">separation process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1980">
    <rdf:first rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1975"/>
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1981"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3040">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1868">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidInlet"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1168">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1373">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/WasteGasDisposalProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073">
    <rdfs:label xml:lang="en">compressor</rdfs:label>
    <rdfs:label xml:lang="pt-br">compressor</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b596"/>
    <skos:definition xml:lang="en">A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure.</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Compressor(x) ↔ Assembly(x) ∧ ∃f(CompressionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um compressor é um conjunto que possui a função projetada de comprimir gases através da adição de energia mecânica para aumentar sua pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every compressor is an assembly that bears a compression function and has component parts including a compressor casing, compression element, gas inlet, and gas outlet.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureInput">
    <rdfs:label xml:lang="pt-br">entrada de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure input</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the pressure applied to a sensing element or control mechanism of petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SilencerHousing">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">carcaça de silenciador</rdfs:label>
    <rdfs:label xml:lang="en">silencer housing</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes the outer housing of a silencer or noise suppressor that contains the acoustic attenuation elements in petroleum production equipment.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BasinFloor">
    <skos:definition xml:lang="en">A material artifact that constitutes the floor structure of a basin or containment pond in a petroleum production installation.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="en">basin floor</rdfs:label>
    <rdfs:label xml:lang="pt-br">piso de bacia</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1453">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095">
    <rdfs:label xml:lang="en">ball valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula esfera</rdfs:label>
    <skos:definition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every ball valve is a valve that has a ball closure component and participates in rotational motion processes</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b174"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b176"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b175"/>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula esfera é uma válvula que controla o fluxo de fluidos usando um elemento de fechamento esférico que gira aproximadamente 90 graus para alinhar ou desalinhar sua passagem de fluxo com as portas do corpo da válvula.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallValve(x) → Valve(x) ∧ ∃y(BallClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(RotationalMotionProcess(z) ∧ participatesIn(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by physical mechanism, sufficient conditions are omitted to avoid false positives under Open World Assumption. Complex multi-way valves or specialized equipment containing ball mechanisms should not be automatically classified as standard ball valves without domain expert validation.</iof-av:primitiveRationale>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PipePig">
    <skos:definition xml:lang="en">A material artifact that constitutes a device propelled through a pipeline by the flow of product to perform internal inspection, cleaning, or product separation.</skos:definition>
    <rdfs:label xml:lang="en">pipe pig</rdfs:label>
    <rdfs:label xml:lang="pt-br">pig de tubo</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1039">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomOutlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the storage of solid materials and their controlled dispensing in metered quantities into a process stream.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1803"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1802"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">solid storage and dispensing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de armazenamento e distribuição de sólidos</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090">
    <rdfs:label xml:lang="pt-br">vaso de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure vessel</rdfs:label>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2622"/>
    <skos:definition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso de pressão é um vaso que possui uma função de contenção sob pressão, projetado para suportar com segurança cargas de pressão internas e/ou externas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PressureVessel(x) ↔ (Vessel(x) ∧ ∃f (PressureContainmentFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure vessel is a vessel that has a pressure containment function, and every vessel with a pressure containment function is a pressure vessel.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000332">
    <rdfs:label xml:lang="en">power transformer primary winding</rdfs:label>
    <rdfs:label xml:lang="pt-br">enrolamento de transformador</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformerPrimaryWinding(x) → TransformerWinding(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(PrimaryWindingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2538"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PrimaryWinding"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">PowerTransformerPrimaryWinding is-a TransformerWinding that is-part-of PowerTransformer and has-function PrimaryWindingFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um enrolamento de transformador que é parte de um transformador de potência e que serve como enrolamento primário recebendo energia elétrica de entrada para transformação eletromagnética.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural position within power transformer. Under OWA, sufficient conditions for primary winding configuration would risk false positives for specialized or hybrid transformer components that contain primary-like windings but should not be classified as standard power transformer primary windings.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/KineticMotion">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
    <skos:definition xml:lang="en">A process in which the directed mechanical motion of a component or fluid stream carrying kinetic energy in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="en">kinetic motion</rdfs:label>
    <rdfs:label xml:lang="pt-br">movimento cinético</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b96">
    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b97"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InformationBearingArtifact">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">artefato de informação de mancal</rdfs:label>
    <rdfs:label xml:lang="en">information bearing artifact</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that bears information—in the form of a signal, display, or record—representing a process variable or equipment state in petroleum production systems.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2071">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104">
    <skos:definition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</skos:definition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="en">choke control valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula de controle de choke</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle de choke é uma válvula de controle que possui um componente de geometria de choke para redução de pressão através de restrição de fluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b475"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b476"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (ChokeControlValve(x) → ControlValve(x) ∧ ∃y (ChokeGeometry(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as 'both' functional and constructive. The constructive differentia (choke geometry) makes it safer to use necessary conditions to avoid forcing all valves with choke components into this specific control category under the Open World Assumption.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke control valve is a control valve that has a choke geometry component at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SealedJoint">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">junta selado</rdfs:label>
    <rdfs:label xml:lang="en">sealed joint</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a joint between two components in petroleum production equipment that is sealed to prevent leakage of process fluid.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b749">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LiquidInlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MixingFunction">
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the combination and blending of two or more fluid streams or components to achieve a homogeneous mixture.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2195"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2194"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:label xml:lang="pt-br">função de mistura</rdfs:label>
    <rdfs:label xml:lang="en">mixing function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SpacingFunction">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2969"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2968"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the maintenance of a defined spatial separation between components to ensure correct alignment, clearance, or insulation.</skos:definition>
    <rdfs:label xml:lang="en">spacing function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de espaçamento</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CathodicProtectionProcess">
    <skos:definition xml:lang="en">A planned process in which electrochemical corrosion of a metallic structure is prevented by making it the cathode of an electrochemical cell through the supply of electrical current or sacrificial anodes.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="en">cathodic protection process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de proteção catódica</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um MeasuringElement que possui uma FlowMeasurementFunction e que é projetado para determinar e quantificar a taxa de fluxo de fluido através de um sistema.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</skos:definition>
    <rdfs:label xml:lang="pt-br">MeasuringElement que possui uma FlowMeasurementFunction e</rdfs:label>
    <rdfs:label xml:lang="en">flow measuring element</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1482"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeasuringElement(x) ↔ (MeasuringElement(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every FlowMeasuringElement is a MeasuringElement that bears a FlowMeasurementFunction</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b847">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SeparatedSolidLiquidPortion">
    <rdfs:label xml:lang="pt-br">porção separado líquido de sólido</rdfs:label>
    <rdfs:label xml:lang="en">separated solid liquid portion</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the solid–liquid fraction recovered after a phase separation process in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147">
    <iof-av:naturalLanguageDefinition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança e alívio é uma válvula que possui uma função de alívio de segurança que combina capacidades de proteção de segurança e alívio de pressão.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2766"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SafetyReliefValve(x) ↔ (Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety relief valve is a valve that has the function of providing both safety protection and pressure relief.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">válvula de segurança e alívio</rdfs:label>
    <rdfs:label xml:lang="en">safety relief valve</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CasingHanger">
    <skos:definition xml:lang="en">A material artifact that constitutes the device that supports and seals a casing string within a wellhead in a petroleum production well.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">suspensor de invólucro</rdfs:label>
    <rdfs:label xml:lang="en">casing hanger</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142">
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2548"/>
    <skos:definition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão é um instrumento que possui uma função de detecção de pressão.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure element is a detecting element that has the function of sensing pressure</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PressureElement(x) ↔ DetectingElement(x) ∧ ∃f(PressureSensingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="en">pressure element</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de pressão</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowSignalTransmissionProcess">
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A signal transmission process in which a standardised signal representing a measured flow rate is transmitted to a remote control or monitoring system.</skos:definition>
    <rdfs:label xml:lang="pt-br">processo de transmissão de sinal de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow signal transmission process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VaporInlet">
    <rdfs:label xml:lang="en">vapor inlet</rdfs:label>
    <rdfs:label xml:lang="pt-br">entrada de vapor</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes an inlet port through which vapour enters a condenser or process vessel in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Inlet"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000306">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">An InputShaft is a Shaft that participates in mechanical energy reception and is connected to an external energy source.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(InputShaft(x) → Shaft(x) ∧ ∃p(MechanicalEnergyReceptionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(ExternalEnergySource(s) ∧ connectedTo(x,s)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on physical configuration as energy entrance point. Under OWA, defining sufficient conditions could lead to false positives where any shaft receiving external energy input would be classified as a standard input shaft, even specialized or hybrid configurations that should remain in different maintenance categories.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1988"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de entrada é um eixo que serve como ponto de entrada para energia mecânica de uma fonte de energia externa em um sistema de transmissão de potência.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">eixo de entrada</rdfs:label>
    <rdfs:label xml:lang="en">input shaft</rdfs:label>
    <skos:definition xml:lang="en">An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102">
    <rdfs:label xml:lang="en">centrifugal pump</rdfs:label>
    <rdfs:label xml:lang="pt-br">bomba centrífuga</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma bomba centrífuga é uma bomba que usa força centrífuga gerada por impulsores rotativos com pás para aumentar a pressão do fluido através de uma carcaça voluta.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b429"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b430"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal pump is a pump that has a centrifugal impeller as component part at all times and has a volute casing as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalPump(x) → Pump(x) ∧ ∃y(CentrifugalImpeller(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(VoluteCasing(z) ∧ hasComponentPartAtAllTimes(x,z)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under Open World Assumption, any equipment with centrifugal impellers and volute casing could be inferred as a standard centrifugal pump, potentially misclassifying specialized hybrid equipment or complex pump systems that contain centrifugal stages but serve different operational roles.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</skos:definition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1709">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b718">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowTubeOscillationDriver"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InjectionPort">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a port through which a fluid, chemical, or material is introduced into a process stream or vessel in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">bocal de injeção</rdfs:label>
    <rdfs:label xml:lang="en">injection port</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b420">
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">Invólucro</rdfs:label>
    <rdfs:label xml:lang="en">compressor casing</rdfs:label>
    <skos:definition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b612"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural configuration. Under OWA, sufficient conditions for compressor-specific casing identity could lead to false positives where any enclosure intended for compressors might be classified as a standard compressor casing, including specialized or hybrid enclosures that warrant distinct classification.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Invólucro que é destinado a abrigar componentes internos do compressor, incluindo o eixo com impulsores e outros componentes mecânicos específicos do compressor.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (CompressorCasing(x) → (Casing(x) ∧ ∃y (Compressor(y) ∧ intendedForUseWith(x,y))))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">CompressorCasing ⊑ Casing ⊓ ∃intendedForUseWith.Compressor</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b455">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b3259">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubingBundle"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator">
    <rdfs:label xml:lang="pt-br">indicador de controle</rdfs:label>
    <rdfs:label xml:lang="en">control indicator</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a component that displays and enables adjustment of a set point or control parameter in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093">
    <iof-av:naturalLanguageDefinition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula angular é uma válvula que tem portas da válvula que não estão alinhadas, mas dispostas em ângulo uma em relação à outra.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every angle valve is a valve that has a non-inline port arrangement.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b109"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b108"/>
    <skos:definition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</skos:definition>
    <rdfs:label xml:lang="en">angle valve</rdfs:label>
    <rdfs:label xml:lang="pt-br">válvula angular</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (AngleValve(x) → Valve(x) ∧ ∃p (hasPart(x,p) ∧ NonInlinePortArrangement(p)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by geometric configuration. Under OWA, sufficient conditions for non-inline port arrangement could lead to false positives where complex multi-port manifolds or specialized valves with angular components get incorrectly classified as standard angle valves.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194">
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1269"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1270"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1248"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1913"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1286"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1281"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1280"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1914"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1247"/>
    <rdfs:subClassOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1285"/>
    <rdfs:label xml:lang="en">filtration function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de filtração</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a FiltrationProcess and that consists in selectively retaining particles, contaminants, or unwanted substances from a fluid stream while allowing the clean fluid to pass through.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A DesignedFunction that is realized in a FiltrationProcess and that consists in selectively retaining particles, contaminants, or unwanted substances from a fluid stream while allowing the clean fluid to pass through.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1802">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SolidStorageAndDispensingProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b661">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/OutputElement"/>
  </rdf:Description>
