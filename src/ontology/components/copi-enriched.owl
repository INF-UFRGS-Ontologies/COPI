  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentItem">
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000030"/>
    <rdfs:label xml:lang="pt-br">item de equipamento</rdfs:label>
    <rdfs:label xml:lang="en">equipment item</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a discrete item of petroleum production equipment assembled or installed as a unit within a production system.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n55b6dbcc703c488db80806efee5015fab773">
