    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b58"/>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b57"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3383"/>
    <skos:definition xml:lang="en">[CFIHOS] A transmitter of which the output is proportional to a measured vibration.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VIBRATION TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;VIBRATION MEASURING INSTRUMENT&gt;</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vibration transmitter is a transmitter that has a vibration signal as input and bears a vibration measurement function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (VibrationTransmitter(x) ↔ (Transmitter(x) ∧ ∃v (VibrationSignal(v) ∧ hasInput(x,v)) ∧ ∃f (VibrationMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">transmissor de vibração</rdfs:label>
    <rdfs:label xml:lang="en">vibration transmitter</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de vibração é um transmissor que mede vibrações mecânicas e produz um sinal de saída proporcional aos parâmetros de vibração medidos.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1885">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HydraulicFluidOutlet"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2196">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ProcessingElement"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314">
    <skos:definition xml:lang="en">[POSC Caesar] A fluid container that mixes two ore more fluid ingredients.</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An apparatus or machine that has the capability of mixing (from ``_).</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;MIXER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;MIXING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to be used for fluid mixing processes typically a rotating piece of equipment comprised of a driver such as a motor which rotates an agitator immersed in the fluid(s) that need to be mixed.</skos:definition>
    <owl:equivalentClass rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2214"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um misturador é um conjunto que tem a função projetada de misturar ou combinar dois ou mais ingredientes fluidos em uma mistura homogênea.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Mixer(x) ↔ (Assembly(x) ∧ ∃f (MixingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">misturador</rdfs:label>
    <rdfs:label xml:lang="en">mixer</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every mixer is an assembly that bears a mixing function, and every assembly that bears a mixing function is a mixer.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1352">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlameArrestElement"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3290">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PowerConditioningCircuit"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by physical geometry (thinness) and manufacturing method (cold forming). Under OWA, sufficient conditions for thin plates are difficult to specify without risking false positives from specialized hybrid structures that contain thin cold-formed elements but should not be classified as standard thin plates.</iof-av:primitiveRationale>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b3139"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">Placa que possui geometria de espessura fina e</rdfs:label>
    <rdfs:label xml:lang="en">thin plate</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:naturalLanguageDefinition xml:lang="en">A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma Placa que possui geometria de espessura fina e é fabricada através de processos de conformação a frio, tipicamente usada para aplicações de suporte estrutural que requerem peso reduzido ou restrições geométricas específicas.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;THIN PLATE&gt; is a &lt;PLATE&gt; that is a thin steel plate format (Sheet plate) Normally made by coldforming</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(ThinPlate(x) → Plate(x) ∧ ∃q1(ThinThickness(q1) ∧ hasQuality(x,q1)) ∧ ∃q2(ColdFormedManufacturing(q2) ∧ hasQuality(x,q2)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">ThinPlate ⊑ Plate ⊓ ∃hasQuality.ThinThickness ⊓ ∃hasQuality.ColdFormedManufacturing</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every piston check valve is a check valve that has a piston closure as component part.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdfs:label xml:lang="pt-br">válvula de retenção tipo pistão</rdfs:label>
    <rdfs:label xml:lang="en">piston check valve</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção tipo pistão é uma válvula de retenção que possui um elemento de fechamento tipo pistão que se move linearmente ao longo do eixo de fluxo sob ação da gravidade ou mola para prevenir refluxo.</iof-av:naturalLanguageDefinition>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b2444"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under Open World Assumption, any artifact with a piston closure could potentially be classified as piston check valve, but specialized hybrid valves or custom manifolds containing piston mechanisms should not be automatically asserted into this standard maintenance category without domain expert validation.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">[CFIHOS] A lift check valve that has a free gravity or spring loaded piston type closure member.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A lift check valve that has a free gravity or spring loaded piston type closure member.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PISTON CHECK VALVE&gt; is a &lt;LIFT CHECK VALVE&gt; and a &lt;PISTON VALVE&gt; that has a free gravity or spring loaded piston type closure member</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(PistonCheckValve(x) → CheckValve(x) ∧ ∃y(PistonClosure(y) ∧ hasComponentPartAtAllTimes(x,y)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b429">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1369">
    <rdf:rest rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1370"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000290">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">GearWheel SubClassOf Assembly and (bearerOf some PowerTransmissionFunction) and (hasComponentPartAtAllTimes some Tooth) and (hasComponentPartAtAllTimes some WheelBody)</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(GearWheel(x) → Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃t(Tooth(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃w(WheelBody(w) ∧ hasComponentPartAtAllTimes(x,w)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:nodeID="nc1a1cc74203240db84b8ecd910de6f90b1716"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An Assembly that bears a PowerTransmissionFunction and that has circumferential teeth for positive mechanical engagement with mating gears or racks to transmit rotational motion and power.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um Assembly que porta uma PowerTransmissionFunction e que possui dentes circunferenciais para engajamento mecânico positivo com engrenagens ou cremalheiras correspondentes para transmitir movimento rotacional e potência.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">roda dentada</rdfs:label>
    <rdfs:label xml:lang="en">gear wheel</rdfs:label>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:primitiveRationale xml:lang="en">Constructive differentia based on physical structure (toothed geometry). Under OWA, asserting equivalence could force classification of complex hybrid mechanisms or specialized toothed components that should not be categorized as standard gear wheels for maintenance purposes.</iof-av:primitiveRationale>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GEAR WHEEL&gt; is an &lt;ARTEFACT&gt; and a &lt;TRANSMITTER(force)&gt; and that is a toothed wheel usend in conjunction with another, or with a rack, to transmit motion</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
