    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2741"/>
    <rdfs:label xml:lang="pt-br">processo de alívio de pressão</rdfs:label>
    <rdfs:label xml:lang="en">pressure relief process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2099">
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
