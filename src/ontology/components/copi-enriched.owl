  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess">
    <skos:definition xml:lang="en">A planned process in which a fluid, chemical, or material is introduced into a process stream, vessel, or wellbore under controlled conditions.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">injection process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de injeção</rdfs:label>
  </rdf:Description>
