    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of water—produced water or injection water—at a defined point in a petroleum production process.</skos:definition>
  </rdf:Description>
