    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b172"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3020"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3357"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b947"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1087"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2217"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b107"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3384"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2280"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000156">
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;THERMOWELL&gt; is an &lt;INSTRUMENT COMPONENT&gt; that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An 'artefact' that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Thermowell(x) → Instrument(x) ∧ ∃r,c,f (PressureTightReceptacle(r) ∧ ProcessConnection(c) ∧ TemperatureSensorProtectionFunction(f) ∧ hasComponentPartAtAllTimes(x,r) ∧ hasComponentPartAtAllTimes(x,c) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">poço termométrico</rdfs:label>
    <rdfs:label xml:lang="en">thermowell</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um poço termométrico é um instrumento que é um receptáculo resistente à pressão adaptado para receber um elemento sensor de temperatura, provido com roscas externas ou outros meios para fixação resistente à pressão a um vaso ou tubulação.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</iof-av:naturalLanguageDefinition>
    <iof-av:primitiveRationale xml:lang="en">Thermowell has constructive classification basis. The structural differentia (pressure-tight receptacle with process connection) defines necessary conditions, but making these sufficient under OWA could lead to false classifications of other threaded pressure-tight devices that happen to contain receptacles but are not intended as thermowells.</iof-av:primitiveRationale>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3171"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3170"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell is an instrument that has a pressure-tight receptacle as component part and has a process connection as component part and is designed for temperature sensing elements.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(SafetyValve(x) ↔ Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:label xml:lang="pt-br">válvula de segurança</rdfs:label>
    <rdfs:label xml:lang="en">safety valve</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety valve is a valve that has the function to automatically relieve excess pressure for emergency protection</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[SLB Glossary] A quick-opening, pop-action valve used for fast relief of excessive pressure.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SAFETY VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;PRESSURE RELIEF DEVICE&gt; that is used in gas service</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] Various. Generally used in describing a surface or subsurface safety valve.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança é uma válvula que possui uma função de ventilação de segurança para alívio automático de pressão por abertura rápida e total para proteção contra condições perigosas de sobrepressão.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2828"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328">
    <iof-av:naturalLanguageDefinition xml:lang="en">A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor pneumático é um motor que converte energia de gás comprimido em energia mecânica rotacional.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PNEUMATIC MOTOR&gt; is an &lt;AIR MOTOR&gt; that is driven by compressed gas (typically air)</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A motor that is driven by compressed gas. Typically air.</skos:definition>
    <rdfs:label xml:lang="en">pneumatic motor</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor pneumático</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pneumatic motor is a motor that bears a PneumaticMotorFunction.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2519"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PneumaticMotor(x) ↔ Motor(x) ∧ ∃f(PneumaticMotorFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000076">
    <rdfs:label xml:lang="en">temperature sensor</rdfs:label>
    <rdfs:label xml:lang="pt-br">elemento de temperatura</rdfs:label>
    <rdfs:label xml:lang="en">temperature element</rdfs:label>
    <rdfs:label xml:lang="pt-br">sensor de temperatura</rdfs:label>
    <skos:definition xml:lang="en">[POSC Caesar] A detecting element intended to sense temperature.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A detecting element intended to sense temperature.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3115"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um elemento de temperatura é um instrumento que possui uma função de sensoreamento de temperatura.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A temperature element is an instrument that bears a temperature sensing function.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature element is a detecting element that has the function to sense temperature</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureElement(x) ↔ DetectingElement(x) ∧ ∃f(TemperatureSensingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
