    <rdf:rest rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2118"/>
    <rdf:first rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b460">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de restrição de fluxo</rdfs:label>
    <rdfs:label xml:lang="en">flow restriction process</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <skos:definition xml:lang="en">A planned process in which the flow rate or pressure of a fluid stream is reduced in a controlled manner by introducing a fixed or variable resistance.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b1938">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidConductionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Coupling(x) ↔ MaterialArtifact(x) ∧ ∃f(ConnectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um acoplamento é um artefato material que possui uma função de conexão para unir partes ou sistemas separados.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">coupling</rdfs:label>
    <rdfs:label xml:lang="pt-br">acoplamento</rdfs:label>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coupling is a material artifact that has the function to connect separate parts or systems together.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b586"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SuctionInlet">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:label xml:lang="pt-br">entrada de sucção</rdfs:label>
    <rdfs:label xml:lang="en">suction inlet</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes the inlet through which fluid is drawn into a pump or compressor under suction pressure in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b58">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="nf266522652ef4baaa16832c599df7f92b55"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2774">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2776"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2391">
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b508">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159">
    <rdfs:label xml:lang="en">vibration transmitter</rdfs:label>
    <rdfs:label xml:lang="pt-br">transmissor de vibração</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (VibrationTransmitter(x) ↔ (Transmitter(x) ∧ ∃v (VibrationSignal(v) ∧ hasInput(x,v)) ∧ ∃f (VibrationMeasurementFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vibration transmitter is a transmitter that has a vibration signal as input and bears a vibration measurement function.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de vibração é um transmissor que mede vibrações mecânicas e produz um sinal de saída proporcional aos parâmetros de vibração medidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2752"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ExpandedGasPortion">
    <skos:definition xml:lang="en">A material artifact that constitutes a portion of gas that has undergone expansion and pressure reduction in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000024"/>
    <rdfs:label xml:lang="pt-br">porção expandido de gás</rdfs:label>
    <rdfs:label xml:lang="en">expanded gas portion</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b556">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:intersectionOf rdf:nodeID="nf266522652ef4baaa16832c599df7f92b558"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de conexão elétrica</rdfs:label>
    <rdfs:label xml:lang="en">electrical connection process</rdfs:label>
    <skos:definition xml:lang="en">A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b139">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="nf266522652ef4baaa16832c599df7f92b2766">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
  </rdf:Description>
