  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which particles, contaminants, or unwanted substances are selectively retained from a fluid stream by a filter element through mechanical screening or other separation mechanisms while clean fluid passes through.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">processo de filtração</rdfs:label>
    <rdfs:label xml:lang="en">filtration process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000344">
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every scraper is a material artifact that has a scraping function, and every material artifact that has a scraping function is a scraper.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Scraper(x) ↔ (MaterialArtifact(x) ∧ ∃f(ScrapingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to mechanically remove a deposit from a surface.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SCRAPER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;SCRAPING&gt;</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] A device that cuts through paraffin, asphaltenes, etc. inside the pipe. Run on wireline.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] Also called a pig, a device with blades or brushes inserted in a pipeline for cleaning purposes.</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A scraper is a material artifact that bears a scraping function for mechanically removing deposits, debris, or contaminants from surfaces.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um raspador é um artefato material que possui uma função de raspagem para remover mecanicamente depósitos, detritos ou contaminantes de superfícies.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">scraper</rdfs:label>
    <rdfs:label xml:lang="pt-br">raspador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2837"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">braided conductor</rdfs:label>
    <rdfs:label xml:lang="pt-br">condutor de trançado</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um instrumento é um artefato material que tem a função projetada de realizar medição, monitoramento ou controle de variáveis de processo.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[isa5_1] a device used for direct or indirect measurement, monitoring, and/or control of a variable, including primary elements, indicators, controllers, final control elements, computing devices, and electrical devices such as annunciators, switches, and pushbuttons.</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every instrument is a material artifact that has an instrumentation function, and every material artifact that has an instrumentation function is an instrument.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Instrument(x) ↔ (Assembly(x) ∧ ∃f(InstrumentationFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2037"/>
    <rdfs:label xml:lang="pt-br">instrumento</rdfs:label>
    <rdfs:label xml:lang="en">instrument</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3138">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
