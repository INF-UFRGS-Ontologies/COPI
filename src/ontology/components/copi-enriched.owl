  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BALL CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;BALL VALVE&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A ball valve that is equipped with an actuator that manipulates a stream of fluid in the response to a signal from an external sensing element and with input of energy from an external source.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb160"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb159"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb158"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
    <rdfs:label xml:lang="en">ball control valve</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2980">
    <rdf:first rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2974"/>
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2981"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000354">
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Spacer(x) ↔ MaterialArtifact(x) ∧ ∃f(SpacingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um espaçador é um artefato material que tem a função de manter separação espacial ou distância entre objetos físicos ou fluidos.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A spacer is a material artifact that has the function of maintaining spatial separation or distance between physical objects or fluids.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="pt-br">espaçador</rdfs:label>
    <rdfs:label xml:lang="en">spacer</rdfs:label>
    <skos:definition xml:lang="en">[OnePetro] In the context of pumping, a spacer is a fluid used between two fluids to prevent contamination.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A viscous fluid used to aid removal of drilling fluids before a primary cementing operation.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is intended to keep other physical objects at a predefined distance and hence having a spacer function.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SPACER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;SPACING&gt;</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every spacer is a material artifact that bears a spacing function</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3028"/>
  </rdf:Description>
