  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction">
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b3084"/>
    <rdfs:subClassOf rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1200"/>
