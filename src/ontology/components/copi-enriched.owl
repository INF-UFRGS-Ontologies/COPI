  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264">
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ENGINE&gt; is a &lt;MOTOR&gt; and a &lt;MACHINE&gt; that converts energy into mechanical force and motion</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] An internal combustion engine that is an induction compression ignition exhaust engine which ignites a fuel air mixture.</skos:definition>
    <rdfs:label xml:lang="en">engine</rdfs:label>
    <rdfs:label xml:lang="pt-br">motor</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um motor é um motor que converte energia de combustível químico em força mecânica e movimento através de processos de combustão.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Engine(x) ↔ Motor(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ChemicalFuelPortion(p) ∧ hasInput(x,p)) ∧ ∃c(CombustionProcess(c) ∧ participatesIn(x,c)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every Engine is a Motor that has function MechanicalEnergyGenerationFunction and has input ChemicalFuelPortion and participates in CombustionProcess.</iof-av:semiFormalNaturalLanguageAxiom>
    <owl:equivalentClass rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b1231"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ne348407d7b87469ea0df345d3a6b7865b401">
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPortion"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasInput"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
