  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000076">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="N3c80d23307af49298df5110a669ad95a"/>
