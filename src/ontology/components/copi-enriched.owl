  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000374">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VESSEL SHELL&gt; is an &lt;ARTEFACT&gt; and a &lt;SHELL(structure)&gt; that is all or part of the pressure containing outer part of a vessel</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma parte de objeto por fiat que é o limite estrutural externo de contenção de pressão de um vaso, projetada para encerrar e isolar o conteúdo interno enquanto suporta cargas de pressão interna.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">vessel shell</rdfs:label>
    <rdfs:label xml:lang="pt-br">parte de objeto por fiat</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3378"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VesselShell(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃f(PressureContainmentFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:primitiveRationale xml:lang="en">Constructive type defined by structural configuration as outer pressure-containing part of vessel. Under Open World Assumption, sufficient conditions are difficult to establish - other structural components might also be pressure-containing parts of vessels in specialized designs.</iof-av:primitiveRationale>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">VesselShell SubClassOf: FiatObjectPart and partOf some Vessel and bearerOf some PressureContainmentFunction</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">pumping process</rdfs:label>
    <rdfs:label xml:lang="pt-br">processo de bombeamento</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GearMechanism">
    <rdfs:label xml:lang="en">gear mechanism</rdfs:label>
    <rdfs:label xml:lang="pt-br">mecanismo de engrenagem</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DriedMaterial">
    <rdfs:label xml:lang="pt-br">material seco</rdfs:label>
    <rdfs:label xml:lang="en">dried material</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235">
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b692"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (Cooler(x) ↔ HeatExchanger(x) ∧ ∃f (CoolingFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[POSC Caesar] A heat exchanger that is intended to cool a physical object.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A heat exchanger that is intended to cool a physical object.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;COOLER&gt; is a &lt;HEAT EXCHANGER&gt; that has a capability of &lt;COOLING&gt;</skos:definition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A cooler is a heat exchanger that bears a CoolingFunction.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um resfriador é um trocador de calor que possui uma FunçãoDeResfriamento.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">cooler</rdfs:label>
    <rdfs:label xml:lang="pt-br">resfriador</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every cooler is a heat exchanger that has the function of cooling.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2130"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2129"/>
    <rdfs:label xml:lang="pt-br">função de detecção de limite de posição</rdfs:label>
    <rdfs:label xml:lang="en">position limit detection function</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000324">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um redutor de tubulação é um tubo que possui tamanhos nominais diferentes de tubulação em suas duas extremidades, destinado a conectar tubos ou componentes de tubulação de tamanhos diferentes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A pipe reducer is a pipe that has different nominal pipe sizes at its two ends, intended to connect pipes or piping components of different sizes.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">pipe reducer</rdfs:label>
    <rdfs:label xml:lang="pt-br">redutor de tubulação</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (PipeReducer(x) → Pipe(x) ∧ ∃i,o (InletEnd(i) ∧ OutletEnd(o) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ DifferentNominalPipeSizes(i,o)))</iof-av:firstOrderLogicAxiom>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2412"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2411"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2409"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2410"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every pipe reducer is a pipe that has an inlet end and outlet end with different nominal pipe sizes</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[CFIHOS] An 'artefact' that has different nominal pipe size at the two ends, intended to connect pipes or piping components.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] An 'artefact' that has different nominal pipe size at the two ends, intended to connect pipes or piping components.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PIPE REDUCER&gt; is a &lt;PIPING COMPONENT&gt; and a &lt;REDUCER&gt; either concentric or eccentric of different  nominal pipe size at the two ends, intended to connect pipes or piping components of different nominal pipe sizes or non standard sizes</skos:definition>
    <iof-av:primitiveRationale xml:lang="en">As a constructive type defined by geometric configuration, sufficient conditions are omitted under the Open World Assumption to prevent false positives. Complex assemblies or custom manifolds containing size transitions should not be automatically classified as standard pipe reducers without explicit assertion.</iof-av:primitiveRationale>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1944">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CombustionChamber"/>
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1922"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1923"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">função de transferência de energia</rdfs:label>
    <rdfs:label xml:lang="en">energy transfer function</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000253">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um difusor é um conjunto que tem a função projetada de converter energia cinética do fluxo de fluido em energia de pressão através de desaceleração controlada em uma passagem divergente.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage.</iof-av:naturalLanguageDefinition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIFFUSER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;DIFFUSING&gt; which is used in pumps to convert kinetic energy imparted by impeller to potential energy i.e. pressure head.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that contains a diverging channel-shaped chamber in which part of the kinetic energy of the fluid is converted into pressure energy.</skos:definition>
    <rdfs:label xml:lang="pt-br">difusor</rdfs:label>
    <rdfs:label xml:lang="en">diffuser</rdfs:label>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1026"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every diffuser is an assembly that bears an energy diffusion function and has a diverging channel as component part at all times.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Diffuser(x) ↔ Assembly(x) ∧ ∃f(EnergyDiffusionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1018">
    <owl:intersectionOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1020"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208">
    <rdfs:label xml:lang="en">agitator</rdfs:label>
    <rdfs:label xml:lang="pt-br">agitador</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b61"/>
    <skos:definition xml:lang="en">[CFIHOS] A propeller like device with agitational or rotational movement located in a tank to prevent the content of the tank to build component segments.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] An &lt;AGITATOR&gt; is a &lt;DYNAMIC MIXER&gt; that stirs or shakes fluids by reaction force from moving vanes</skos:definition>
    <skos:definition xml:lang="en">[DEXPI] An Agitator is a dynamic mixer that stirs or shakes fluids by reaction force from moving vanes.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction">
    <rdfs:label xml:lang="en">electrical conduction function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de condução elétrica</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3044"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1194"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3043"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b1193"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b2216">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MixingElement"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
