  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess">
    <iof-av:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</iof-av:naturalLanguageDefinition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">processo de suporte estrutural</rdfs:label>
    <rdfs:label xml:lang="en">structural support process</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000369">
    <rdfs:label xml:lang="pt-br">coluna de vácuo</rdfs:label>
    <rdfs:label xml:lang="en">vacuum column</rdfs:label>
    <skos:definition xml:lang="en">[POSC Caesar] A distillation column intended to withstand outside pressure</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VACUUM COLUMN&gt; is an &lt;ARTEFACT&gt; and a &lt;DISTILLATION COLUMN&gt; intended to withstand outside pressure</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A distillation column intended to withstand outside pressure.</skos:definition>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3309"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3310"/>
    <rdfs:subClassOf rdf:nodeID="na2a46d8928414473b41f08b70337d4d1b3311"/>
    <iof-av:primitiveRationale xml:lang="en">Constructive type based on structural capability. Under OWA, defining sufficient conditions for vacuum-capable design would be complex and could lead to false positives. The structural differentia (vacuum resistance) requires domain expert validation of what constitutes adequate vacuum design capability.</iof-av:primitiveRationale>
    <iof-av:naturalLanguageDefinition xml:lang="en">A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Uma coluna de vácuo é uma coluna de destilação projetada para resistir à pressão externa durante operação sob vácuo.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(VacuumColumn(x) → DistillationColumn(x) ∧ ∃q(VacuumPressureResistanceQuality(q) ∧ bearerOf(x,q)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every vacuum column is a distillation column that bears a vacuum pressure resistance quality.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
    <rdfs:label xml:lang="pt-br">processo de suporte de equipamento</rdfs:label>
    <rdfs:label xml:lang="en">equipment support process</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
