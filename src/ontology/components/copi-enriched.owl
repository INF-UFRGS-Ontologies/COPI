  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureControlSystem">
    <rdfs:label xml:lang="en">pressure control system</rdfs:label>
    <rdfs:label xml:lang="pt-br">sistema de pressão de controle</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a system of sensors, controllers, and valves working together to maintain process pressure within defined limits in petroleum production equipment.</skos:definition>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/EngineeredSystem"/>
  </rdf:Description>
