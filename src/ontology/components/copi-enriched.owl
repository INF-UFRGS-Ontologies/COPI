    <rdfs:label xml:lang="pt-br">interruptor elétrico</rdfs:label>
    <rdfs:label xml:lang="en">electrical switch</rdfs:label>
    <skos:definition xml:lang="en">A material artifact that constitutes a device that opens or closes an electrical circuit in response to a manual or automatic input in petroleum production equipment.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
