    <rdf:rest rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b318"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1603">
    <owl:intersectionOf rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b1606"/>
