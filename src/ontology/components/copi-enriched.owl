  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">structural support function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de suporte estrutural</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3177"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3178"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a StructuralSupportProcess and that consists in providing mechanical support, load distribution, or structural integrity within an engineered system through a flat, planar configuration.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238">
    <rdfs:label xml:lang="pt-br">acoplamento</rdfs:label>
    <rdfs:label xml:lang="en">coupling</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">A coupling is a material artifact that bears a connection function to join separate parts or systems together.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um acoplamento é um artefato material que possui uma função de conexão para unir partes ou sistemas separados.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every coupling is a material artifact that has the function to connect separate parts or systems together.</iof-av:semiFormalNaturalLanguageAxiom>
    <skos:definition xml:lang="en">[OnePetro] The connection point of jointed pipe. It may be a steel shell with female threads to which the pins are connected or a formed female connection (box) on the end of tubing.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] An electrical or mechanical device that joins parts of systems and can affect the interaction of, or energy transfer between, parts of systems.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] &lt;COUPLING&gt; is the &lt;Activity&gt; of connecting with a coupling or coupler</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] Connecting with a coupling or coupler.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] Connecting with a coupling or coupler</skos:definition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb747"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Coupling(x) ↔ MaterialArtifact(x) ∧ ∃f(ConnectionFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasurementSignal">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">sinal de medição</rdfs:label>
    <rdfs:label xml:lang="en">measurement signal</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152">
    <rdfs:label xml:lang="en">strainer</rdfs:label>
    <rdfs:label xml:lang="pt-br">filtro grosso</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;STRAINER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;STRAINING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A filter that is separating solid particles from a fluid by passing the fluid through a wire mesh, screen or metal plates containing perforations or slits.</skos:definition>
    <skos:definition xml:lang="en">[POSC Caesar] A mechanical separator that is separating solid particles from a fluid by passing the fluid through a wire mesh, screen or metal plates containing perforations or slits.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device used to catch and hold the debris flowing in pipelines.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um filtro grosso é um artefato material que possui uma função de separação e tem um elemento filtrante, projetado para separar partículas sólidas de fluidos fazendo o fluido passar através de telas ou perfurações.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every strainer is a material artifact that bears a separation function and has a filtering element as component part at all times and participates in solid-liquid separation processes.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Strainer(x) ↔ (MaterialArtifact(x) ∧ ∃f(SeparationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilteringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(SolidLiquidSeparationProcess(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb3064"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1434">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/IgnitionSystem"/>
