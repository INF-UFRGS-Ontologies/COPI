  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245">
    <rdfs:label xml:lang="pt-br">densitômetro</rdfs:label>
    <rdfs:label xml:lang="en">densitometer</rdfs:label>
    <skos:definition xml:lang="en">[OnePetro] A device used for reading the density of a flowing fluid or slurry.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A device installed on a mixing or pumping system manifold to measure the density of fluids.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DENSITOMETER&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;MEASURING INSTRUMENT&gt; that measures the degree of darkness in photographic or semitransparent material. The densitometer is basically a light source aimed at a photoelectric cell which determines the density of the sample from differences in the readings</skos:definition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every densitometer is an instrument that has the function of measuring density.</iof-av:semiFormalNaturalLanguageAxiom>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb872"/>
    <iof-av:naturalLanguageDefinition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um densitômetro é um instrumento que possui uma função de medição de densidade.</iof-av:naturalLanguageDefinition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb506">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MasterValve"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb53">
    <rdf:rest rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb54"/>
    <rdf:first rdf:resource="https://spec.industrialontologies.org/ontology/construct/Assembly"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb2975">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AcousticTreatmentElement"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">DriveShaft ≡ Assembly ⊓ ∃bearerOf.PowerTransmissionFunction ⊓ ∃participatesIn.RotationalPowerTransferProcess</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um eixo de transmissão é um Assembly que possui uma PowerTransmissionFunction e consiste em um sistema baseado em eixo usado para transferir energia mecânica rotacional de um motor primário para múltiplas máquinas acionadas.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n77c2a26f99c94a33993b8edf520dd96cb1108"/>
    <rdfs:label xml:lang="en">drive shaft</rdfs:label>
    <rdfs:label xml:lang="pt-br">eixo de transmissão</rdfs:label>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DRIVE SHAFT&gt; is an &lt;ARTEFACT&gt; and an &lt;ENERGY TRANSFERRER&gt; that is a shaft used to transfer rotational power from a prime driver to several individual machines by use of drive belts and pulley wheels</skos:definition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x (DriveShaft(x) ↔ (Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(RotationalPowerTransferProcess(p) ∧ participatesIn(x,p))))</iof-av:firstOrderLogicAxiom>
  </rdf:Description>
