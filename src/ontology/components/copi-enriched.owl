  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureReading">
    <rdfs:label xml:lang="en">pressure reading</rdfs:label>
    <rdfs:label xml:lang="pt-br">leitura de pressão</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition xml:lang="en">A measurement information content entity constituting a quantitative value representing the pressure of a process stream as measured and displayed by petroleum production instrumentation.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelSensor">
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <skos:definition xml:lang="en">A material artifact that constitutes a sensing element that measures the fluid level within a vessel in petroleum production equipment.</skos:definition>
    <rdfs:label xml:lang="pt-br">sensor de nível</rdfs:label>
    <rdfs:label xml:lang="en">level sensor</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2897">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000308">
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um vaso separador de condensado é um separador projetado para separar quantidades relativamente pequenas de líquido de uma corrente de vapor através de separação de fases gravitacional e baseada em momento.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</iof-av:naturalLanguageDefinition>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(KnockOutDrum(x) ↔ Separator(x) ∧ ∃f(KnockOutSeparationFunction(f) ∧ bearerOf(x,f)))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation.</skos:definition>
    <owl:equivalentClass rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b2013"/>
    <rdfs:label xml:lang="en">knock out drum</rdfs:label>
    <rdfs:label xml:lang="pt-br">vaso separador de condensado</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every knock out drum is a separator that bears a knock out separation function, which is realized in processes that separate small quantities of liquid from vapor streams.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n68ef3b2e7f25472abfe6aab750c8adf8b872">
    <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
