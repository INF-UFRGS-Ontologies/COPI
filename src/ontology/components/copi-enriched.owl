  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DifferentialPressureSwitchingFunction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="en">differential pressure switching function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de chaveamento por pressão diferencial</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1000"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b999"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ConicalBottom">
    <rdfs:label xml:lang="en">conical bottom</rdfs:label>
    <rdfs:label xml:lang="pt-br">fundo de cônico</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161">
    <iof-av:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</iof-av:naturalLanguageDefinition>
    <rdfs:label xml:lang="en">backflow prevention function</rdfs:label>
    <rdfs:label xml:lang="pt-br">função de prevenção de refluxo</rdfs:label>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3081"/>
    <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2472"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2471"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3080"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b455"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b472"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3442"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b473"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b456"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3441"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219">
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BRAKE&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;BRAKING&gt;</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object intended to arrest or prevent the motion of an item. Typically by means of friction.</skos:definition>
    <skos:definition xml:lang="en">[OnePetro] In a drillng context, a brake is the main device for stopping the travel of the drawworks of a rig when running or pulling a drill string.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] The mechanism on the drawworks that permits the driller to control the speed and motion of the drilling line and the drillstring.</skos:definition>
    <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:label xml:lang="pt-br">freio</rdfs:label>
    <rdfs:label xml:lang="en">brake</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Brake(x) ↔ (Assembly(x) ∧ ∃f(BrakingFunction(f) ∧ bearerOf(x,f))))</iof-av:firstOrderLogicAxiom>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b330"/>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um freio é um conjunto que possui uma função de frenagem para deter ou prevenir o movimento de um objeto, tipicamente através da aplicação de força de atrito ou eletromagnética.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="en">A brake is an assembly that bears a braking function to arrest or prevent the motion of an object, typically through friction or electromagnetic force application.</iof-av:naturalLanguageDefinition>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every brake is an assembly that has the function of braking, and every assembly that has the function of braking is a brake.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000273">
    <iof-av:naturalLanguageDefinition xml:lang="en">A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um flange é um artefato material caracterizado por uma geometria de aro plano projetante, placa, colar ou nervura, projetado para fornecer conexão mecânica entre componentes.</iof-av:naturalLanguageDefinition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <iof-av:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</iof-av:isPrimitive>
    <skos:definition xml:lang="en">[OnePetro] A common, high pressure wellhead connection, using bolt attached flange plates and metal-to-metal seals.</skos:definition>
    <skos:definition xml:lang="en">[CFIHOS] A physical object that is a projecting flat rim, plate, collar or rib.</skos:definition>
    <skos:definition xml:lang="en">[SLB Glossary] A connection profile used in pipe work and associated equipment to provide a means of assembling and disassembling components.</skos:definition>
    <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLANGE&gt; is an &lt;ARTEFACT&gt; and a &lt;CONNECTOR&gt; that is a projecting flat rim, plate, collar, or rib for strength or for attachment to another object</skos:definition>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1391"/>
    <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1390"/>
    <rdfs:subClassOf rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b1389"/>
    <iof-av:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by structural geometry. Under OWA, any artifact with projecting flat rim geometry would be forced into the flange category, which could incorrectly classify specialized equipment or complex assemblies that contain flange-like features but serve different primary functions.</iof-av:primitiveRationale>
    <rdfs:label xml:lang="en">flange</rdfs:label>
    <rdfs:label xml:lang="pt-br">flange</rdfs:label>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Flange(x) → MaterialArtifact(x) ∧ ∃g(ProjectingFlatRimGeometry(g) ∧ hasCharacteristic(x,g)) ∧ ∃f(MechanicalConnectionFunction(f) ∧ hasFunction(x,f)))</iof-av:firstOrderLogicAxiom>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every flange is a material artifact that has a projecting flat rim geometry and has the function of mechanically connecting components.</iof-av:semiFormalNaturalLanguageAxiom>
  </rdf:Description>
  <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091">
    <rdfs:label xml:lang="pt-br">instrumento</rdfs:label>
    <rdfs:label xml:lang="en">instrument</rdfs:label>
    <iof-av:naturalLanguageDefinition xml:lang="en">An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables.</iof-av:naturalLanguageDefinition>
    <iof-av:naturalLanguageDefinition xml:lang="pt-br">Um instrumento é um artefato material que tem a função projetada de realizar medição, monitoramento ou controle de variáveis de processo.</iof-av:naturalLanguageDefinition>
    <owl:equivalentClass rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b2037"/>
    <iof-av:semiFormalNaturalLanguageAxiom xml:lang="en">Every instrument is a material artifact that has an instrumentation function, and every material artifact that has an instrumentation function is an instrument.</iof-av:semiFormalNaturalLanguageAxiom>
    <iof-av:firstOrderLogicAxiom xml:lang="en">∀x(Instrument(x) ↔ (Assembly(x) ∧ ∃f(InstrumentationFunction(f) ∧ hasFunction(x,f))))</iof-av:firstOrderLogicAxiom>
    <skos:definition xml:lang="en">[isa5_1] a device used for direct or indirect measurement, monitoring, and/or control of a variable, including primary elements, indicators, controllers, final control elements, computing devices, and electrical devices such as annunciators, switches, and pushbuttons.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="n23a17477f6ab465c9b392a22c900a573b3070">
