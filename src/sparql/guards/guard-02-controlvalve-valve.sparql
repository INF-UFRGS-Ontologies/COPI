# Guard 02: ControlValve (if declared) must be entailed as subClassOf Valve
# Violation: ControlValve exists but is NOT a subClassOf* Valve
PREFIX owl:  <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX copi: <https://www.inf.ufrgs.br/ontologies/copi/>

SELECT ?x WHERE {
  BIND(copi:ControlValve AS ?x)
  ?x a owl:Class .
  FILTER NOT EXISTS {
    ?x rdfs:subClassOf* copi:Valve .
  }
}
