# Guard 09: LossOfContainment must NOT be entailed ⊑ iof-constr:PlannedProcess
# (LossOfContainment is explicitly unplanned)
# Violation: LossOfContainment IS subClassOf* PlannedProcess
PREFIX owl:        <http://www.w3.org/2002/07/owl#>
PREFIX rdfs:       <http://www.w3.org/2000/01/rdf-schema#>
PREFIX copi:       <https://www.inf.ufrgs.br/ontologies/copi/>
PREFIX iof-constr: <https://spec.industrialontologies.org/ontology/construct/>

SELECT ?x WHERE {
  BIND(copi:LossOfContainment AS ?x)
  ?x a owl:Class .
  ?x rdfs:subClassOf* iof-constr:PlannedProcess .
}
