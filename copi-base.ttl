###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000126
copi:COPI_0000126 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000081 ;
                  rdfs:comment "An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations."@en ,
                               "Um filtro em linha é um filtro que é instalado diretamente dentro de uma linha de fluido e suportado por tubulações ou equipamentos conectados, projetado para remover partículas ou contaminantes de correntes de fluido durante operações normais de fluxo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "filtro em linha"@pt-br ,
                             "in-line filter"@en ;
                  annotation:firstOrderLogicAxiom "∀x (InLineFilter(x) → Filter(x) ∧ ∃f (FiltrationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations."@en ,
                                                       "Um filtro em linha é um filtro que é instalado diretamente dentro de uma linha de fluido e suportado por tubulações ou equipamentos conectados, projetado para remover partículas ou contaminantes de correntes de fluido durante operações normais de fluxo."@pt-br .


