                                  ] ;
                  rdfs:comment "An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "signal transmission function"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
