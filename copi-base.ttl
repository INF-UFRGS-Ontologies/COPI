                  rdfs:comment "A material artifact that bears a designed function realized in an iof-constr:MeasurementProcess (a planned process yielding an information output)."@en ,
                               "Um artefato material que porta uma função projetada realizada em um iof-constr:MeasurementProcess (um processo planejado que produz uma saída informacional)."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "instrumento de medição"@pt-br ,
                             "measurement instrument"@en ;
                  skos:example "temperature/pressure/flow/level transmitter, composition analyzer"@en ,
                               "transmissor de temperatura/pressão/vazão/nível, analisador de composição"@pt-br ;
                  annotation:adaptedFrom "ISO 14224 Annex A; IEC 81346-2 code B." ;
                  annotation:explanatoryNote "A medição distingue-se das categorias de transformação por produzir uma saída informacional em vez de material; reutiliza iof-constr:MeasurementProcess em vez de cunhar um processo COPI."@pt-br ,
                                             "Measurement stands apart from the transformation categories in yielding an informational rather than a material output; it reuses iof-constr:MeasurementProcess instead of minting a COPI process."@en ;
                  annotation:firstOrderLogicDefinition "∀x (MeasurementInstrument(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MeasurementProcess(p) ∧ realizedIn(f,p))))" ;
