@prefix : <https://www.inf.ufrgs.br/ontologies/copi/copi-base.ttl#> .
@prefix dce: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix copi: <https://www.inf.ufrgs.br/ontologies/copi/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix construct: <https://spec.industrialontologies.org/ontology/construct/> .
@prefix annotation: <https://spec.industrialontologies.org/ontology/annotation/> .
@base <https://www.inf.ufrgs.br/ontologies/copi/copi-base.ttl> .

<https://www.inf.ufrgs.br/ontologies/copi/copi-base.ttl> rdf:type owl:Ontology ;
                                                          owl:versionIRI <https://www.inf.ufrgs.br/ontologies/copi/releases/2026-06-18/copi-base.ttl> ;
                                                          dce:type <http://purl.obolibrary.org/obo/IAO_8000001> ;
                                                          dcterms:contributor "Cauã Antunes" ,
                                                                              "Haroldo Rojas" ,
                                                                              "Mara Abel" ,
                                                                              "Rafael Petry" ,
                                                                              "Régis Romeu" ;
                                                          dcterms:description "BFO/IOF-Core conformant ontology of equipment classes for petroleum production plants."@en ;
                                                          dcterms:license <https://opensource.org/license/mit> ;
                                                          dcterms:title "Core Ontology of Petroleum Installations (COPI)"@en ,
                                                                        "Ontologia Central de Plantas de Produção de Petróleo (COPI)"@pt ;
                                                          owl:versionInfo "2026-06-15" ,
                                                                          "2026-06-18" ;
                                                          skos:scopeNote "Artefatos materiais (bfo:material_entity) que (i) fazem parte de uma planta de produção de petróleo, e (ii) possuem ao menos uma função cuja realização envolve o transporte (p. ex. produção e injeção), processamento (separação e outros processos), controle, monitoramento, medição, contenção ou escoamento de material ou energia."@pt-br ,
                                                                         "COPI fornece categorias de alto nível de equipamentos definidas por função para demonstrar o mecanismo de classe definida. Os subtipos de equipamentos são anotados com referências aos termos do CFIHOS e do PCA RDL. COPI não é uma biblioteca de dados de referência; organizações devem utilizar o CFIHOS, o PCA RDL ou a ISO 14224 para classificação abrangente de equipamentos."@pt-br ,
                                                                         "COPI provides high-level equipment categories defined by function to demonstrate the defined-class mechanism. Equipment subtypes are annotated with references to CFIHOS and PCA RDL terms. COPI is not a reference data library; organizations should use CFIHOS, PCA RDL, or ISO 14224 for comprehensive equipment classification."@en ,
                                                                         "Material artifacts (bfo:material_entity) that (i) are part of a petroleum production plant, and (ii) bear at least one function whose realization involves the transport (e.g. production and injection), processing (separation and other processes), control, monitoring, measurement, containment or offloading of material or energy."@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/type
dce:type rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
dcterms:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dcterms:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dcterms:title rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/adaptedFrom
annotation:adaptedFrom rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/explanatoryNote
annotation:explanatoryNote rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicAxiom
annotation:firstOrderLogicAxiom rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicDefinition
annotation:firstOrderLogicDefinition rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/isPrimitive
annotation:isPrimitive rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/maturity
annotation:maturity rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition
annotation:naturalLanguageDefinition rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/primitiveRationale
annotation:primitiveRationale rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageAxiom
annotation:semiFormalNaturalLanguageAxiom rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageDefinition
annotation:semiFormalNaturalLanguageDefinition rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/synonym
annotation:synonym rdf:type owl:AnnotationProperty .


###  https://www.inf.ufrgs.br/ontologies/copi/cfihosReference
copi:cfihosReference rdf:type owl:AnnotationProperty ;
                     rdfs:comment "Reference to a CFIHOS (Capital Facilities Information Handover Specification) term."@en ;
                     rdfs:label "cfihosReference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/dexpiReference
copi:dexpiReference rdf:type owl:AnnotationProperty ;
                    rdfs:comment "Reference to a DEXPI (Data Exchange in the Process Industry) prototype element."@en ;
                    rdfs:label "dexpiReference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/iso14224Reference
copi:iso14224Reference rdf:type owl:AnnotationProperty ;
                       rdfs:comment "Reference to an ISO 14224 equipment taxonomy entry."@en ;
                       rdfs:label "iso14224Reference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/iso15926Reference
copi:iso15926Reference rdf:type owl:AnnotationProperty ;
                       rdfs:comment "Reference to an ISO 15926 term IRI."@en ;
                       rdfs:label "iso15926Reference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/poscCaesarReference
copi:poscCaesarReference rdf:type owl:AnnotationProperty ;
                         rdfs:comment "Reference to a POSC Caesar RDL IRI."@en ;
                         rdfs:label "poscCaesarReference"@en .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000054
<http://purl.obolibrary.org/obo/BFO_0000054> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000056
<http://purl.obolibrary.org/obo/BFO_0000056> rdf:type owl:ObjectProperty .


###  https://spec.industrialontologies.org/ontology/construct/describes
construct:describes rdf:type owl:ObjectProperty .


###  https://spec.industrialontologies.org/ontology/construct/hasFunction
construct:hasFunction rdf:type owl:ObjectProperty .


###  https://www.inf.ufrgs.br/ontologies/copi/participatesIn
copi:participatesIn rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                    rdfs:isDefinedBy copi:copi-core ;
                    rdfs:label "participa em"@pt-br ,
                               "participates in"@en ;
                    annotation:isPrimitive "false"^^xsd:boolean ;
                    annotation:naturalLanguageDefinition "A material artifact participates in every operation that realizes one of its designed functions; sub-property of bfo:participatesIn (BFO_0000056) that isolates the realization-to-participation bridge within COPI."@en ,
                                                         "Um artefato material participa em toda operação que realiza uma de suas funções projetadas; sub-propriedade de bfo:participatesIn (BFO_0000056) que isola a ponte realização-participação dentro da COPI."@pt-br .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000015
<http://purl.obolibrary.org/obo/BFO_0000015> rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000019
<http://purl.obolibrary.org/obo/BFO_0000019> rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000040
<http://purl.obolibrary.org/obo/BFO_0000040> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/DesignedFunction
construct:DesignedFunction rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/InformationContentEntity
construct:InformationContentEntity rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/MaterialArtifact
construct:MaterialArtifact rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity
construct:MeasurementInformationContentEntity rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/MeasurementProcess
construct:MeasurementProcess rdf:type owl:Class .


###  https://www.inf.ufrgs.br/ontologies/copi/AbsorbentPhase
copi:AbsorbentPhase rdf:type owl:Class ;
                    rdfs:subClassOf copi:PortionOfLiquid ;
                    rdfs:isDefinedBy copi:copi-vocab ;
                    rdfs:label "absorbent phase"@en ;
                    annotation:naturalLanguageDefinition "A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ChemicalReaction
copi:ChemicalReaction rdf:type owl:Class ;
                      rdfs:subClassOf copi:Operation ;
                      rdfs:isDefinedBy copi:copi-core ;
                      rdfs:label "chemical reaction"@en ,
                                 "reação química"@pt-br ;
                      skos:example "Fermentation of sugars to ethanol; combustion; catalytic conversion."@en ,
                                   "Fermentação de açúcares a etanol; combustão; conversão catalítica."@pt-br ;
                      annotation:firstOrderLogicAxiom "ChemicalReaction(x) → Process(x) ∧ ∃o,c(hasOutput(x,o) ∧ hasConstituent(o,c) ∧ ¬∃i,c1(hasInput(x,i) ∧ hasConstituent(i,c1) ∧ sameSubstance(c1,c)))" ;
                      annotation:isPrimitive "true"^^xsd:boolean ;
                      annotation:naturalLanguageDefinition "A process in which chemical species are consumed and new species, present in no input, are formed."@en ,
                                                           "Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas."@pt-br ;
                      annotation:primitiveRationale "Classe de processo unitário; a formação de uma espécie genuinamente nova é parcialmente caracterizada em FOL mas apenas o gênero é asserido em OWL."@pt-br ,
                                                    "Unit-process class; the formation of a genuinely new species is partly characterised in FOL but only the genus is asserted in OWL."@en ;
                      annotation:semiFormalNaturalLanguageAxiom "if x is a 'chemical reaction' then x is a 'process' whose output has a constituent substance that no input has"@en ,
                                                                "se x é uma 'reação química' então x é um 'processo' cuja saída tem uma substância constituinte que nenhuma entrada possui"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/ChemicalReactor
copi:ChemicalReactor rdf:type owl:Class ;
                     owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                [ rdf:type owl:Restriction ;
                                                                  owl:onProperty construct:hasFunction ;
                                                                  owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                              owl:someValuesFrom copi:ChemicalReaction
                                                                                                            ]
                                                                                                          ) ;
                                                                                       rdf:type owl:Class
                                                                                     ]
                                                                ]
                                                              ) ;
                                           rdf:type owl:Class
                                         ] ;
                     rdfs:subClassOf construct:MaterialArtifact ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty construct:hasFunction ;
                                       owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                   owl:someValuesFrom copi:ChemicalReaction
                                                                                 ]
                                                                               ) ;
                                                            rdf:type owl:Class
                                                          ]
                                     ] ;
                     rdfs:isDefinedBy copi:copi-core ;
                     rdfs:label "chemical reactor"@en ,
                                "reator químico"@pt-br ;
                     skos:example "CSTR, plug-flow reactor, fixed-bed catalytic reactor"@en ,
                                  "CSTR, reator de fluxo pistonado, reator catalítico de leito fixo"@pt-br ;
                     annotation:adaptedFrom "Unit-process tradition; ISO 14224 Annex A; IEC 81346-2 code H." ;
                     annotation:firstOrderLogicDefinition "ChemicalReactor(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(ChemicalReaction(p) ∧ realizedIn(f,p)))" ;
                     annotation:isPrimitive "false"^^xsd:boolean ;
                     annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a chemical-reaction operation."@en ,
                                                          "Um artefato material que porta uma função projetada realizada em uma operação de reação química."@pt-br ;
                     annotation:semiFormalNaturalLanguageDefinition "x is a 'chemical reactor' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'chemical reaction'"@en ,
                                                                    "x é um 'reator químico' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'reação química'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/Composition
copi:Composition rdf:type owl:Class ;
                 rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
                 rdfs:isDefinedBy copi:copi-vocab ;
                 rdfs:label "composition"@en ;
                 annotation:naturalLanguageDefinition "A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CompositionMeasurementResult
copi:CompositionMeasurementResult rdf:type owl:Class ;
                                  rdfs:subClassOf construct:MeasurementInformationContentEntity ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty construct:describes ;
                                                    owl:someValuesFrom copi:Composition
                                                  ] ;
                                  rdfs:isDefinedBy copi:copi-vocab ;
                                  rdfs:label "composition measurement result"@en ;
                                  annotation:naturalLanguageDefinition "Measurement information content entity describing the chemical or phase composition quality of a substance."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CompressionFunction
copi:CompressionFunction rdf:type owl:Class ;
                         rdfs:subClassOf construct:DesignedFunction ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:someValuesFrom copi:GasPressureIncrease
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:allValuesFrom copi:GasPressureIncrease
                                         ] ;
                         rdfs:isDefinedBy copi:copi-enriched ;
                         rdfs:label "compression function"@en ,
                                    "função de compressão"@pt-br ;
                         annotation:explanatoryNote "Entailed disjoint from PumpingFunction because LiquidPressureIncrease and GasPressureIncrease are disjoint and each function is realized in some-and-only its leaf operation."@en ,
                                                    "Implicada disjunta de PumpingFunction porque LiquidPressureIncrease e GasPressureIncrease são disjuntas e cada função é realizada em alguma-e-apenas sua operação folha."@pt-br ;
                         annotation:firstOrderLogicAxiom "CompressionFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ GasPressureIncrease(p)) ∧ ∀p(realizedIn(x,p) → GasPressureIncrease(p))" ;
                         annotation:isPrimitive "true"^^xsd:boolean ;
                         annotation:naturalLanguageDefinition "A função projetada de elevar a pressão de um gás compressível; realizada apenas em uma operação de aumento de pressão de gás."@pt-br ,
                                                              "The designed function to raise the pressure of a compressible gas; realized only in a gas-pressure-increase operation."@en ;
                         annotation:primitiveRationale "As for PumpingFunction."@en ,
                                                       "Como em PumpingFunction."@pt-br ;
                         annotation:semiFormalNaturalLanguageAxiom "if x is a 'compression function' then x is a 'designed function' that is 'realized in' some 'gas pressure increase' and is 'realized in' only 'gas pressure increase'"@en ,
                                                                   "se x é uma 'função de compressão' então x é uma 'função projetada' que é 'realizada em' algum 'aumento de pressão de gás' e é 'realizada em' apenas 'aumento de pressão de gás'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/Compressor
copi:Compressor rdf:type owl:Class ;
                rdfs:subClassOf copi:MomentumTransferDevice ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty construct:hasFunction ;
                                  owl:someValuesFrom copi:CompressionFunction
                                ] ;
                owl:disjointWith copi:Pump ,
                                 copi:Valve ;
                rdfs:isDefinedBy copi:copi-enriched ;
                rdfs:label "compressor"@en ,
                           "compressor"@pt-br ;
                skos:example "centrifugal compressor, reciprocating compressor"@en ,
                             "compressor centrífugo, compressor alternativo"@pt-br ;
                annotation:adaptedFrom "ISO 14224 Annex A (rotating equipment)." ;
                annotation:explanatoryNote "Inferida como MomentumTransferDevice apenas a partir de sua função. Asserida disjunta de bomba."@pt-br ,
                                           "Inferred to be a MomentumTransferDevice from its function alone. Asserted disjoint from Pump."@en ;
                annotation:firstOrderLogicAxiom "Compressor(x) → MaterialArtifact(x) ∧ ∃f(CompressionFunction(f) ∧ hasFunction(x,f))" ;
                annotation:isPrimitive "true"^^xsd:boolean ;
                annotation:naturalLanguageDefinition "A material artifact whose identity-giving designed function is to raise the pressure of a compressible gas."@en ,
                                                     "Um artefato material cuja função projetada identificadora é elevar a pressão de um gás compressível."@pt-br ;
                annotation:primitiveRationale "As for Pump."@en ,
                                              "Como em Pump."@pt-br ;
                annotation:semiFormalNaturalLanguageAxiom "if x is a 'compressor' then x is a 'material artifact' that 'has function' some 'compression function'"@en ,
                                                          "se x é um 'compressor' então x é um 'artefato material' que 'tem função' alguma 'função de compressão'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/ContainmentDevice
copi:ContainmentDevice rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty construct:hasFunction ;
                                                                    owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                owl:someValuesFrom copi:MaterialContainment
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ]
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf construct:MaterialArtifact ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty construct:hasFunction ;
                                         owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                     owl:someValuesFrom copi:MaterialContainment
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ]
                                       ] ;
                       rdfs:isDefinedBy copi:copi-core ;
                       rdfs:label "containment device"@en ,
                                  "dispositivo de contenção"@pt-br ;
                       skos:example "storage tank, pressure vessel, accumulator"@en ,
                                    "tanque de armazenamento, vaso de pressão, acumulador"@pt-br ;
                       annotation:adaptedFrom "ISO 14224 Annex A; IEC 81346-2 code C." ;
                       annotation:firstOrderLogicDefinition "ContainmentDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MaterialContainment(p) ∧ realizedIn(f,p)))" ;
                       annotation:isPrimitive "false"^^xsd:boolean ;
                       annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a material-containment operation."@en ,
                                                            "Um artefato material que porta uma função projetada realizada em uma operação de contenção de material."@pt-br ;
                       annotation:semiFormalNaturalLanguageDefinition "x is a 'containment device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'material containment'"@en ,
                                                                      "x é um 'dispositivo de contenção' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'contenção de material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/ContainmentFunction
copi:ContainmentFunction rdf:type owl:Class ;
                         rdfs:subClassOf construct:DesignedFunction ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:someValuesFrom copi:MaterialContainment
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:allValuesFrom copi:MaterialContainment
                                         ] ;
                         rdfs:isDefinedBy copi:copi-vocab ;
                         rdfs:label "containment function"@en ;
                         annotation:isPrimitive "true"^^xsd:boolean ;
                         annotation:naturalLanguageDefinition "An identity-giving designed function realized in a MaterialContainment process; the function of holding a fluid or solid material within a bounded volume."@en ;
                         annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ControlSignal
copi:ControlSignal rdf:type owl:Class ;
                   rdfs:subClassOf construct:InformationContentEntity ;
                   rdfs:isDefinedBy copi:copi-vocab ;
                   rdfs:label "control signal"@en ;
                   annotation:naturalLanguageDefinition "An information content entity that conveys an instruction or set-point to a control device."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/DepletedFluid
copi:DepletedFluid rdf:type owl:Class ;
                   rdfs:subClassOf copi:PortionOfFluid ;
                   rdfs:isDefinedBy copi:copi-vocab ;
                   rdfs:label "depleted fluid"@en ;
                   annotation:naturalLanguageDefinition "A fluid from which target components have been removed or transferred during a treatment process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalPower
copi:ElectricalPower rdf:type owl:Class ;
                     rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
                     rdfs:isDefinedBy copi:copi-vocab ;
                     rdfs:label "electrical power"@en ;
                     annotation:naturalLanguageDefinition "A quality inhering in an electrical system that represents the rate of electrical energy transfer."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Filter
copi:Filter rdf:type owl:Class ;
            rdfs:subClassOf construct:MaterialArtifact ;
            rdfs:isDefinedBy copi:copi-enriched ;
            rdfs:label "filter"@en ;
            annotation:maturity <https://spec.industrialontologies.org/ontology/individual/Provisional> ;
            annotation:naturalLanguageDefinition "A material artifact that separates solid contaminants or particles from a fluid stream by passing the stream through a porous medium or filter element."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControl
copi:FlowControl rdf:type owl:Class ;
                 rdfs:subClassOf copi:Operation ;
                 rdfs:isDefinedBy copi:copi-core ;
                 rdfs:label "controle de fluxo"@pt-br ,
                            "flow control"@en ;
                 skos:example "Estrangular uma corrente por uma válvula de controle; isolar por uma válvula de bloqueio; aliviar sobrepressão."@pt-br ,
                              "Throttling a stream through a control valve; isolating via a shutoff valve; relieving overpressure."@en ;
                 annotation:firstOrderLogicAxiom "FlowControl(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m))" ;
                 annotation:isPrimitive "true"^^xsd:boolean ;
                 annotation:naturalLanguageDefinition "A process that modulates a flow without changing the material's substance, phase, or composition."@en ,
                                                      "Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material."@pt-br ;
                 annotation:primitiveRationale "Auxiliary category; the conservation of substance/phase/composition under modulation is the characterisation and is not a material transformation."@en ,
                                               "Categoria auxiliar; a conservação de substância/fase/composição sob modulação é a caracterização e não é uma transformação material."@pt-br ;
                 annotation:semiFormalNaturalLanguageAxiom "if x is a 'flow control' then x is a 'process' that conserves the substance, phase and composition of its material participant"@en ,
                                                           "se x é um 'controle de fluxo' então x é um 'processo' que conserva a substância, a fase e a composição de seu participante material"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControlDevice
copi:FlowControlDevice rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty construct:hasFunction ;
                                                                    owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                owl:someValuesFrom copi:FlowControl
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ]
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf construct:MaterialArtifact ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty construct:hasFunction ;
                                         owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                     owl:someValuesFrom copi:FlowControl
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ]
                                       ] ;
                       rdfs:isDefinedBy copi:copi-core ;
                       rdfs:label "dispositivo de controle de fluxo"@pt-br ,
                                  "flow-control device"@en ;
                       skos:example "control valve, shutoff valve, relief valve"@en ,
                                    "válvula de controle, válvula de bloqueio, válvula de alívio"@pt-br ;
                       annotation:adaptedFrom "ISO 14224 Annex A; IEC 81346-2 codes Q, R, F." ;
                       annotation:firstOrderLogicDefinition "FlowControlDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(FlowControl(p) ∧ realizedIn(f,p)))" ;
                       annotation:isPrimitive "false"^^xsd:boolean ;
                       annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a flow-control operation."@en ,
                                                            "Um artefato material que porta uma função projetada realizada em uma operação de controle de fluxo."@pt-br ;
                       annotation:semiFormalNaturalLanguageDefinition "x is a 'flow-control device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'flow control'"@en ,
                                                                      "x é um 'dispositivo de controle de fluxo' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' algum 'controle de fluxo'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement
copi:FlowControlElement rdf:type owl:Class ;
                        rdfs:subClassOf construct:MaterialArtifact ;
                        rdfs:isDefinedBy copi:copi-enriched ;
                        rdfs:label "elemento de controle de fluxo"@pt-br ,
                                   "flow control element"@en ;
                        annotation:naturalLanguageDefinition "A valve trim component whose position controls the area of the flow path (e.g. plug, disc, gate, ball)."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction
copi:FlowControlFunction rdf:type owl:Class ;
                         rdfs:subClassOf construct:DesignedFunction ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:someValuesFrom copi:FlowControl
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:allValuesFrom copi:FlowControl
                                         ] ;
                         rdfs:isDefinedBy copi:copi-vocab ;
                         rdfs:label "flow control function"@en ;
                         annotation:isPrimitive "true"^^xsd:boolean ;
                         annotation:naturalLanguageDefinition "An identity-giving designed function realized in a FlowControl process; the function of modulating, regulating, or blocking fluid flow through a conduit or vessel connection."@en ;
                         annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementResult
copi:FlowMeasurementResult rdf:type owl:Class ;
                           rdfs:subClassOf construct:MeasurementInformationContentEntity ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty construct:describes ;
                                             owl:someValuesFrom copi:FlowRate
                                           ] ;
                           rdfs:isDefinedBy copi:copi-vocab ;
                           rdfs:label "flow measurement result"@en ;
                           annotation:naturalLanguageDefinition "Measurement information content entity describing a flow rate quality of a fluid stream."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowMeasuringElement
copi:FlowMeasuringElement rdf:type owl:Class ;
                          rdfs:subClassOf construct:MaterialArtifact ;
                          rdfs:isDefinedBy copi:copi-enriched ;
                          rdfs:label "flow measuring element"@en ;
                          annotation:maturity <https://spec.industrialontologies.org/ontology/individual/Provisional> ;
                          annotation:naturalLanguageDefinition "A primary flow element inserted in a fluid stream that creates a differential pressure, velocity, or other measurable effect proportional to the volumetric or mass flow rate."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowModificationAccessory
copi:FlowModificationAccessory rdf:type owl:Class ;
                               rdfs:subClassOf construct:MaterialArtifact ;
                               rdfs:isDefinedBy copi:copi-enriched ;
                               rdfs:label "flow modification accessory"@en ;
                               annotation:maturity <https://spec.industrialontologies.org/ontology/individual/Provisional> ;
                               annotation:naturalLanguageDefinition "A material artifact installed in a pipeline to modify flow characteristics — such as flow rate, pressure drop, or velocity profile — without functioning as a primary flow control device."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowRate
copi:FlowRate rdf:type owl:Class ;
              rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
              rdfs:isDefinedBy copi:copi-vocab ;
              rdfs:label "flow rate"@en ;
              annotation:naturalLanguageDefinition "A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FluidMixture
copi:FluidMixture rdf:type owl:Class ;
                  rdfs:subClassOf copi:PortionOfFluid ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "fluid mixture"@en ;
                  annotation:naturalLanguageDefinition "A fluid portion consisting of two or more components or phases that have not yet been fully separated."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/GasAbsorber
copi:GasAbsorber rdf:type owl:Class ;
                 rdfs:subClassOf copi:MassTransferDevice ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty construct:hasFunction ;
                                   owl:someValuesFrom copi:GasAbsorptionFunction
                                 ] ;
                 rdfs:isDefinedBy copi:copi-enriched ;
                 rdfs:label "absorvedor de gás"@pt-br ,
                            "gas absorber"@en ;
                 annotation:adaptedFrom "Treybal, Mass-Transfer Operations; TEG contactor." ;
                 annotation:explanatoryNote "O contactor de TEG de uma unidade de desidratação de gás offshore é um absorvedor de gás."@pt-br ,
                                            "The TEG contactor of an offshore gas-dehydration unit is a gas absorber."@en ;
                 annotation:firstOrderLogicAxiom "GasAbsorber(x) → MaterialArtifact(x) ∧ ∃f(GasAbsorptionFunction(f) ∧ hasFunction(x,f))" ;
                 annotation:isPrimitive "true"^^xsd:boolean ;
                 annotation:naturalLanguageDefinition "A mass-transfer artifact that contacts a gas with a solvent so that a species migrates gas->liquid."@en ,
                                                      "Um artefato de transferência de massa que contata um gás com um solvente de modo que uma espécie migre gás->líquido."@pt-br ;
                 annotation:semiFormalNaturalLanguageAxiom "if x is a 'gas absorber' then x is a 'material artifact' that 'has function' some 'gas-absorption function'"@en ,
                                                           "se x é um 'absorvedor de gás' então x é um 'artefato material' que 'tem função' alguma 'função de absorção de gás'"@pt-br ;
                 annotation:synonym "absorption column"@en ,
                                    "coluna de absorção"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/GasAbsorption
copi:GasAbsorption rdf:type owl:Class ;
                   rdfs:subClassOf copi:MassTransfer ;
                   rdfs:isDefinedBy copi:copi-core ;
                   rdfs:label "absorção de gás"@pt-br ,
                              "gas absorption"@en ;
                   annotation:adaptedFrom "Treybal, Mass-Transfer Operations." ;
                   annotation:firstOrderLogicDefinition "GasAbsorption(p) ↔ MassTransfer(p) ∧ ∃g,l,l2,c(hasInput(p,g) ∧ Gas(g) ∧ hasInput(p,l) ∧ Liquid(l) ∧ hasOutput(p,l2) ∧ Liquid(l2) ∧ derivesFrom(l2,l) ∧ hasConstituent(g,c) ∧ ¬∃c1(hasConstituent(l,c1) ∧ sameSubstance(c1,c)) ∧ ∃c2(hasConstituent(l2,c2) ∧ sameSubstance(c2,c)))" ;
                   annotation:isPrimitive "true"^^xsd:boolean ;
                   annotation:naturalLanguageDefinition "A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid."@en ,
                                                        "Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída."@pt-br ;
                   annotation:primitiveRationale "Although a full first-order definition is available, OWL 2 DL carries only the typed-participation envelope; the relational differentia (a constituent migrating gas->liquid) is FOL-only."@en ,
                                                 "Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o envelope de participação tipada; a diferença relacional (um constituinte migrando gás->líquido) é apenas-FOL."@pt-br ;
                   annotation:semiFormalNaturalLanguageDefinition "x is a 'gas absorption' if and only if x is a 'mass transfer' in which a substance carried by the input gas, absent from the input solvent, is a constituent of the output liquid"@en ,
                                                                  "x é uma 'absorção de gás' se e somente se x é uma 'transferência de massa' na qual uma substância transportada pelo gás de entrada, ausente do solvente de entrada, é constituinte do líquido de saída"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/GasAbsorptionFunction
copi:GasAbsorptionFunction rdf:type owl:Class ;
                           rdfs:subClassOf construct:DesignedFunction ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                             owl:someValuesFrom copi:GasAbsorption
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                             owl:allValuesFrom copi:GasAbsorption
                                           ] ;
                           rdfs:isDefinedBy copi:copi-enriched ;
                           rdfs:label "função de absorção de gás"@pt-br ,
                                      "gas-absorption function"@en ;
                           annotation:adaptedFrom "Treybal, Mass-Transfer Operations." ;
                           annotation:firstOrderLogicAxiom "GasAbsorptionFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ GasAbsorption(p)) ∧ ∀p(realizedIn(x,p) → GasAbsorption(p))" ;
                           annotation:isPrimitive "true"^^xsd:boolean ;
                           annotation:naturalLanguageDefinition "A função projetada de contatar um gás com um solvente de modo que uma espécie migre gás->líquido; realizada apenas em uma operação de absorção de gás."@pt-br ,
                                                                "The designed function to contact a gas with a solvent so a species migrates gas->liquid; realized only in a gas-absorption operation."@en ;
                           annotation:primitiveRationale "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ,
                                                         "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ;
                           annotation:semiFormalNaturalLanguageAxiom "if x is a 'gas-absorption function' then x is a 'designed function' that is 'realized in' some 'gas absorption' and is 'realized in' only 'gas absorption'"@en ,
                                                                     "se x é uma 'função de absorção de gás' então x é uma 'função projetada' que é 'realizada em' alguma 'absorção de gás' e é 'realizada em' apenas 'absorção de gás'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/GasPressureIncrease
copi:GasPressureIncrease rdf:type owl:Class ;
                         rdfs:subClassOf copi:MomentumTransfer ;
                         owl:disjointWith copi:LiquidPressureIncrease ;
                         rdfs:isDefinedBy copi:copi-core ;
                         rdfs:label "aumento de pressão de gás"@pt-br ,
                                    "gas pressure increase"@en ;
                         annotation:firstOrderLogicDefinition "GasPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃g(Gas(g) ∧ hasInput(x,g)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Gas(m))" ;
                         annotation:isPrimitive "true"^^xsd:boolean ;
                         annotation:naturalLanguageDefinition "A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas's pressure."@en ,
                                                              "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás."@pt-br ;
                         annotation:primitiveRationale "As for LiquidPressureIncrease: the phase constraint is not expressible in OWL 2 DL; only the genus is asserted."@en ,
                                                       "Como em LiquidPressureIncrease: a restrição de fase não é expressável em OWL 2 DL; apenas o gênero é asserido."@pt-br ;
                         annotation:semiFormalNaturalLanguageDefinition "x is a 'gas pressure increase' if and only if x is a 'momentum transfer' whose fluid input is a 'gas'"@en ,
                                                                        "x é um 'aumento de pressão de gás' se e somente se x é uma 'transferência de quantidade de movimento' cuja entrada fluida é um 'gás'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/HeatTransfer
copi:HeatTransfer rdf:type owl:Class ;
                  rdfs:subClassOf copi:Operation ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "heat transfer"@en ,
                             "transferência de calor"@pt-br ;
                  skos:example "Aquecimento sensível de uma corrente de processo contra uma utilidade quente."@pt-br ,
                               "Sensible heating of a process stream against a hot utility."@en ;
                  annotation:firstOrderLogicAxiom "HeatTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream."@en ,
                                                       "Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a constância de fase e de identidade química que distingue a transferência de calor sensível não é capturada em OWL, de modo que apenas o envelope é asserido."@pt-br ,
                                                "Unit-operations class; the constancy of phase and chemical identity that distinguishes sensible heat transfer is not captured in OWL, so only the envelope is asserted."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'heat transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de calor' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/HeatTransferDevice
copi:HeatTransferDevice rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty construct:hasFunction ;
                                                                     owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                 owl:someValuesFrom copi:HeatTransfer
                                                                                                               ]
                                                                                                             ) ;
                                                                                          rdf:type owl:Class
                                                                                        ]
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf construct:MaterialArtifact ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty construct:hasFunction ;
                                          owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                      owl:someValuesFrom copi:HeatTransfer
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ]
                                        ] ;
                        rdfs:isDefinedBy copi:copi-core ;
                        rdfs:label "dispositivo de transferência de calor"@pt-br ,
                                   "heat-transfer device"@en ;
                        skos:example "shell-and-tube exchanger, fired heater, reboiler"@en ,
                                     "trocador casco-e-tubo, aquecedor a fogo direto, refervedor"@pt-br ;
                        annotation:adaptedFrom "Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 codes E, V." ;
                        annotation:explanatoryNote "Categoria definida; um artefato que porta uma função secundária (e.g. um refervedor que também vaporiza) adquire pertinências adicionais de categoria -- intencional, não um defeito."@pt-br ,
                                                   "Defined category; an artifact bearing a secondary function (e.g. a reboiler that also vaporizes) acquires additional category memberships -- intended, not a defect."@en ;
                        annotation:firstOrderLogicDefinition "HeatTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(HeatTransfer(p) ∧ realizedIn(f,p)))" ;
                        annotation:isPrimitive "false"^^xsd:boolean ;
                        annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a heat-transfer operation."@en ,
                                                             "Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor."@pt-br ;
                        annotation:semiFormalNaturalLanguageDefinition "x is a 'heat-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'heat transfer'"@en ,
                                                                       "x é um 'dispositivo de transferência de calor' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de calor'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/HeatTransferFunction
copi:HeatTransferFunction rdf:type owl:Class ;
                          rdfs:subClassOf construct:DesignedFunction ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:someValuesFrom copi:HeatTransfer
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:allValuesFrom copi:HeatTransfer
                                          ] ;
                          rdfs:isDefinedBy copi:copi-enriched ;
                          rdfs:label "função de transferência de calor"@pt-br ,
                                     "heat-transfer function"@en ;
                          annotation:firstOrderLogicAxiom "HeatTransferFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ HeatTransfer(p)) ∧ ∀p(realizedIn(x,p) → HeatTransfer(p))" ;
                          annotation:isPrimitive "true"^^xsd:boolean ;
                          annotation:naturalLanguageDefinition "A função projetada de transferir energia térmica de ou para uma corrente de processo; realizada apenas em uma operação de transferência de calor."@pt-br ,
                                                               "The designed function to transfer thermal energy to or from a process stream; realized only in a heat-transfer operation."@en ;
                          annotation:primitiveRationale "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ,
                                                        "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ;
                          annotation:semiFormalNaturalLanguageAxiom "if x is a 'heat-transfer function' then x is a 'designed function' that is 'realized in' some 'heat transfer' and is 'realized in' only 'heat transfer'"@en ,
                                                                    "se x é uma 'função de transferência de calor' então x é uma 'função projetada' que é 'realizada em' alguma 'transferência de calor' e é 'realizada em' apenas 'transferência de calor'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/IndicationFunction
copi:IndicationFunction rdf:type owl:Class ;
                        rdfs:subClassOf construct:DesignedFunction ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                          owl:someValuesFrom construct:MeasurementProcess
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                          owl:allValuesFrom construct:MeasurementProcess
                                        ] ;
                        rdfs:isDefinedBy copi:copi-vocab ;
                        rdfs:label "indication function"@en ;
                        annotation:isPrimitive "true"^^xsd:boolean ;
                        annotation:naturalLanguageDefinition "An identity-giving designed function realized in a Measurement process; the function of converting a physical quantity into a locally readable display at the point of measurement."@en ;
                        annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InstrumentationFunction
copi:InstrumentationFunction rdf:type owl:Class ;
                             rdfs:subClassOf construct:DesignedFunction ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                               owl:someValuesFrom construct:MeasurementProcess
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                               owl:allValuesFrom construct:MeasurementProcess
                                             ] ;
                             rdfs:isDefinedBy copi:copi-vocab ;
                             rdfs:label "instrumentation function"@en ;
                             annotation:isPrimitive "true"^^xsd:boolean ;
                             annotation:naturalLanguageDefinition "An identity-giving designed function realized in a sensing or measurement process; the function of detecting and converting a physical quantity into a usable signal or reading."@en ;
                             annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Level
copi:Level rdf:type owl:Class ;
           rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
           rdfs:isDefinedBy copi:copi-vocab ;
           rdfs:label "level"@en ;
           annotation:naturalLanguageDefinition "A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementResult
copi:LevelMeasurementResult rdf:type owl:Class ;
                            rdfs:subClassOf construct:MeasurementInformationContentEntity ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty construct:describes ;
                                              owl:someValuesFrom copi:Level
                                            ] ;
                            rdfs:isDefinedBy copi:copi-vocab ;
                            rdfs:label "level measurement result"@en ;
                            annotation:naturalLanguageDefinition "Measurement information content entity describing a liquid level quality of a vessel or container."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LiquidPressureIncrease
copi:LiquidPressureIncrease rdf:type owl:Class ;
                            rdfs:subClassOf copi:MomentumTransfer ;
                            rdfs:isDefinedBy copi:copi-core ;
                            rdfs:label "aumento de pressão de líquido"@pt-br ,
                                       "liquid pressure increase"@en ;
                            annotation:firstOrderLogicDefinition "LiquidPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Liquid(m))" ;
                            annotation:isPrimitive "true"^^xsd:boolean ;
                            annotation:naturalLanguageDefinition "A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid's pressure."@en ,
                                                                 "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido."@pt-br ;
                            annotation:primitiveRationale "OWL 2 DL cannot express the phase constraint on the fluid input; the OWL form asserts only the genus (MomentumTransfer). The disjointness with GasPressureIncrease is asserted to carry the pump/compressor partition."@en ,
                                                          "OWL 2 DL não consegue expressar a restrição de fase sobre a entrada fluida; a forma OWL assere apenas o gênero (MomentumTransfer). A disjunção com GasPressureIncrease é asserida para sustentar a partição bomba/compressor."@pt-br ;
                            annotation:semiFormalNaturalLanguageDefinition "x is a 'liquid pressure increase' if and only if x is a 'momentum transfer' whose fluid input is a 'liquid'"@en ,
                                                                           "x é um 'aumento de pressão de líquido' se e somente se x é uma 'transferência de quantidade de movimento' cuja entrada fluida é um 'líquido'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/LossOfContainment
copi:LossOfContainment rdf:type owl:Class ;
                       rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                       rdfs:isDefinedBy copi:copi-core ;
                       rdfs:label "loss of containment"@en ,
                                  "perda de contenção"@pt-br ;
                       annotation:explanatoryNote "Relevant to HAZOP and failure-propagation work built over COPI."@en ,
                                                  "Relevante para trabalhos de HAZOP e propagação de falhas construídos sobre o COPI."@pt-br ;
                       annotation:firstOrderLogicAxiom "LossOfContainment(x) → Process(x) ∧ ¬PlannedProcess(x)" ;
                       annotation:isPrimitive "true"^^xsd:boolean ;
                       annotation:naturalLanguageDefinition "A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess."@en ,
                                                            "Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess."@pt-br ;
                       annotation:primitiveRationale "Included to make the bfo:Process rooting concrete: the same boundary-failure kind is failure-relevant (ISO 14224) and cannot be a PlannedProcess; a planned-only hierarchy would exclude it."@en ,
                                                     "Incluída para tornar concreta a ancoragem em bfo:Process: o mesmo tipo de falha de barreira é relevante para falhas (ISO 14224) e não pode ser um PlannedProcess; uma hierarquia só-planejada o excluiria."@pt-br ;
                       annotation:semiFormalNaturalLanguageAxiom "if x is a 'loss of containment' then x is a 'process' and x is not a 'planned process'"@en ,
                                                                 "se x é uma 'perda de contenção' então x é um 'processo' e x não é um 'processo planejado'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MassTransfer
copi:MassTransfer rdf:type owl:Class ;
                  rdfs:subClassOf copi:Operation ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "mass transfer"@en ,
                             "transferência de massa"@pt-br ;
                  skos:example "Absorption of a gas component into a liquid solvent; stripping; distillation."@en ,
                               "Absorção de um componente gasoso em um solvente líquido; esgotamento (stripping); destilação."@pt-br ;
                  annotation:firstOrderLogicAxiom "MassTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference."@en ,
                                                       "Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico)."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a migração interfásica que individua seus membros é declarada para folhas específicas (e.g. GasAbsorption) mas não no nível da categoria em OWL."@pt-br ,
                                                "Unit-operations class; the inter-phase migration that individuates its members is stated for specific leaves (e.g. GasAbsorption) but not at the category level in OWL."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'mass transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de massa' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MassTransferDevice
copi:MassTransferDevice rdf:type owl:Class ;
                        owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                   [ rdf:type owl:Restriction ;
                                                                     owl:onProperty construct:hasFunction ;
                                                                     owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                 owl:someValuesFrom copi:MassTransfer
                                                                                                               ]
                                                                                                             ) ;
                                                                                          rdf:type owl:Class
                                                                                        ]
                                                                   ]
                                                                 ) ;
                                              rdf:type owl:Class
                                            ] ;
                        rdfs:subClassOf construct:MaterialArtifact ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty construct:hasFunction ;
                                          owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                      owl:someValuesFrom copi:MassTransfer
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ]
                                        ] ;
                        rdfs:isDefinedBy copi:copi-core ;
                        rdfs:label "dispositivo de transferência de massa"@pt-br ,
                                   "mass-transfer device"@en ;
                        skos:example "absorber, stripper, distillation column, adsorber"@en ,
                                     "absorvedor, esgotador, coluna de destilação, adsorvedor"@pt-br ;
                        annotation:adaptedFrom "Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V." ;
                        annotation:firstOrderLogicDefinition "MassTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MassTransfer(p) ∧ realizedIn(f,p)))" ;
                        annotation:isPrimitive "false"^^xsd:boolean ;
                        annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a mass-transfer operation."@en ,
                                                             "Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa."@pt-br ;
                        annotation:semiFormalNaturalLanguageDefinition "x is a 'mass-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'mass transfer'"@en ,
                                                                       "x é um 'dispositivo de transferência de massa' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de massa'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MaterialContainment
copi:MaterialContainment rdf:type owl:Class ;
                         rdfs:subClassOf copi:Operation ;
                         rdfs:isDefinedBy copi:copi-core ;
                         rdfs:label "contenção de material"@pt-br ,
                                    "material containment"@en ;
                         skos:example "Armazenar petróleo cru em um tanque; amortecer líquido em um tambor de surto."@pt-br ,
                                      "Holding crude in a storage tank; buffering liquid in a surge drum."@en ;
                         annotation:firstOrderLogicAxiom "MaterialContainment(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m))" ;
                         annotation:isPrimitive "true"^^xsd:boolean ;
                         annotation:naturalLanguageDefinition "A process that maintains a contained material's state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category."@en ,
                                                              "Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação)."@pt-br ;
                         annotation:primitiveRationale "Auxiliary category retained because all plant equipment must be classifiable; the input=output identity is the limiting characterisation, not a transformation."@en ,
                                                       "Categoria auxiliar mantida porque todo equipamento de planta deve ser classificável; a identidade entrada=saída é a caracterização-limite, não uma transformação."@pt-br ;
                         annotation:semiFormalNaturalLanguageAxiom "if x is a 'material containment' then x is a 'process' that 'has input' and 'has output' the same 'material entity'"@en ,
                                                                   "se x é uma 'contenção de material' então x é um 'processo' que 'tem entrada' e 'tem saída' a mesma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MeasurementInstrument
copi:MeasurementInstrument rdf:type owl:Class ;
                           owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty construct:hasFunction ;
                                                                        owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                    owl:someValuesFrom construct:MeasurementProcess
                                                                                                                  ]
                                                                                                                ) ;
                                                                                             rdf:type owl:Class
                                                                                           ]
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                           rdfs:subClassOf construct:MaterialArtifact ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty construct:hasFunction ;
                                             owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                       [ rdf:type owl:Restriction ;
                                                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                         owl:someValuesFrom construct:MeasurementProcess
                                                                                       ]
                                                                                     ) ;
                                                                  rdf:type owl:Class
                                                                ]
                                           ] ;
                           rdfs:isDefinedBy copi:copi-core ;
                           rdfs:label "instrumento de medição"@pt-br ,
                                      "measurement instrument"@en ;
                           skos:example "temperature/pressure/flow/level transmitter, composition analyzer"@en ,
                                        "transmissor de temperatura/pressão/vazão/nível, analisador de composição"@pt-br ;
                           annotation:adaptedFrom "ISO 14224 Annex A; IEC 81346-2 code B." ;
                           annotation:explanatoryNote "A medição distingue-se das categorias de transformação por produzir uma saída informacional em vez de material; reutiliza iof-constr:MeasurementProcess em vez de cunhar um processo COPI."@pt-br ,
                                                      "Measurement stands apart from the transformation categories in yielding an informational rather than a material output; it reuses iof-constr:MeasurementProcess instead of minting a COPI process."@en ;
                           annotation:firstOrderLogicDefinition "MeasurementInstrument(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MeasurementProcess(p) ∧ realizedIn(f,p)))" ;
                           annotation:isPrimitive "false"^^xsd:boolean ;
                           annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in an iof-constr:MeasurementProcess (a planned process yielding an information output)."@en ,
                                                                "Um artefato material que porta uma função projetada realizada em um iof-constr:MeasurementProcess (um processo planejado que produz uma saída informacional)."@pt-br ;
                           annotation:semiFormalNaturalLanguageDefinition "x is a 'measurement instrument' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'measurement process'"@en ,
                                                                          "x é um 'instrumento de medição' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' algum 'processo de medição'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalPower
copi:MechanicalPower rdf:type owl:Class ;
                     rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
                     rdfs:isDefinedBy copi:copi-vocab ;
                     rdfs:label "mechanical power"@en ;
                     annotation:naturalLanguageDefinition "A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparation
copi:MechanicalSeparation rdf:type owl:Class ;
                          rdfs:subClassOf copi:Operation ;
                          rdfs:isDefinedBy copi:copi-core ;
                          rdfs:label "mechanical separation"@en ,
                                     "separação mecânica"@pt-br ;
                          skos:example "Separação gravitacional trifásica; separação ciclônica; filtração; centrifugação."@pt-br ,
                                       "Three-phase gravity separation; cyclonic separation; filtration; centrifugation."@en ;
                          annotation:firstOrderLogicAxiom "MechanicalSeparation(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))" ;
                          annotation:isPrimitive "true"^^xsd:boolean ;
                          annotation:naturalLanguageDefinition "A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction."@en ,
                                                               "Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química."@pt-br ;
                          annotation:primitiveRationale "Classe de operações unitárias; a separação de uma alimentação heterogênea por força mecânica não é formalizada em OWL além do envelope."@pt-br ,
                                                        "Unit-operations class; the partition of a heterogeneous feed by mechanical force is not formalised in OWL beyond the envelope."@en ;
                          annotation:semiFormalNaturalLanguageAxiom "if x is a 'mechanical separation' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                                    "se x é uma 'separação mecânica' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparationDevice
copi:MechanicalSeparationDevice rdf:type owl:Class ;
                                owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                           [ rdf:type owl:Restriction ;
                                                                             owl:onProperty construct:hasFunction ;
                                                                             owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                         owl:someValuesFrom copi:MechanicalSeparation
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ]
                                                                           ]
                                                                         ) ;
                                                      rdf:type owl:Class
                                                    ] ;
                                rdfs:subClassOf construct:MaterialArtifact ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty construct:hasFunction ;
                                                  owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                              owl:someValuesFrom copi:MechanicalSeparation
                                                                                            ]
                                                                                          ) ;
                                                                       rdf:type owl:Class
                                                                     ]
                                                ] ;
                                rdfs:isDefinedBy copi:copi-core ;
                                rdfs:label "dispositivo de separação mecânica"@pt-br ,
                                           "mechanical-separation device"@en ;
                                skos:example "separador trifásico, ciclone, filtro, centrífuga"@pt-br ,
                                             "three-phase separator, cyclone, filter, centrifuge"@en ;
                                annotation:adaptedFrom "Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V." ;
                                annotation:firstOrderLogicDefinition "MechanicalSeparationDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MechanicalSeparation(p) ∧ realizedIn(f,p)))" ;
                                annotation:isPrimitive "false"^^xsd:boolean ;
                                annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a mechanical-separation operation."@en ,
                                                                     "Um artefato material que porta uma função projetada realizada em uma operação de separação mecânica."@pt-br ;
                                annotation:semiFormalNaturalLanguageDefinition "x is a 'mechanical-separation device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'mechanical separation'"@en ,
                                                                               "x é um 'dispositivo de separação mecânica' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'separação mecânica'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MomentumTransfer
copi:MomentumTransfer rdf:type owl:Class ;
                      rdfs:subClassOf copi:Operation ;
                      rdfs:isDefinedBy copi:copi-core ;
                      rdfs:label "momentum transfer"@en ,
                                 "transferência de quantidade de movimento"@pt-br ;
                      skos:example "Elevar a pressão de um líquido de processo; comprimir um gás; circular uma lama."@pt-br ,
                                   "Raising the pressure of a process liquid; compressing a gas; circulating a slurry."@en ;
                      annotation:adaptedFrom "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering (fluid-flow operations)." ;
                      annotation:explanatoryNote "Includes pressure-raising operations on liquids and gases, and bulk transport/mixing. Its leaf operations LiquidPressureIncrease and GasPressureIncrease are disjoint."@en ,
                                                 "Inclui operações de aumento de pressão de líquidos e gases, e transporte/mistura globais. Suas operações folha LiquidPressureIncrease e GasPressureIncrease são disjuntas."@pt-br ;
                      annotation:firstOrderLogicAxiom "MomentumTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))" ;
                      annotation:isPrimitive "true"^^xsd:boolean ;
                      annotation:naturalLanguageDefinition "A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion."@en ,
                                                           "Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global."@pt-br ;
                      annotation:primitiveRationale "A unit-operations class grounded in the McCabe-Smith-Harriott tradition; its members share a typed-participation envelope but no single formally necessary-and-sufficient differentia, so only the envelope is asserted in OWL."@en ,
                                                    "Uma classe de operações unitárias fundamentada na tradição de McCabe-Smith-Harriott; seus membros compartilham um envelope de participação tipada mas nenhuma diferença formal necessária-e-suficiente única, de modo que apenas o envelope é asserido em OWL."@pt-br ;
                      annotation:semiFormalNaturalLanguageAxiom "if x is a 'momentum transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                                "se x é uma 'transferência de quantidade de movimento' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/MomentumTransferDevice
copi:MomentumTransferDevice rdf:type owl:Class ;
                            owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty construct:hasFunction ;
                                                                         owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                     owl:someValuesFrom copi:MomentumTransfer
                                                                                                                   ]
                                                                                                                 ) ;
                                                                                              rdf:type owl:Class
                                                                                            ]
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ] ;
                            rdfs:subClassOf construct:MaterialArtifact ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty construct:hasFunction ;
                                              owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                          owl:someValuesFrom copi:MomentumTransfer
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ]
                                            ] ;
                            rdfs:isDefinedBy copi:copi-core ;
                            rdfs:label "dispositivo de transferência de quantidade de movimento"@pt-br ,
                                       "momentum-transfer device"@en ;
                            skos:example "bomba, compressor, ventilador, tubo, misturador"@pt-br ,
                                         "pump, compressor, fan, pipe, mixer"@en ;
                            annotation:adaptedFrom "Unit-operations tradition (McCabe-Smith-Harriott); cross-checked against IEC 81346-2 codes G, M, W and ISO 14224 Annex A." ;
                            annotation:explanatoryNote "A dispersive (defined) category; a leaf declaring only its designed function is automatically classified here by the reasoner. Not asserted disjoint from the other equipment categories (selective partition)."@en ,
                                                       "Uma categoria dispersiva (definida); uma folha que declara apenas sua função projetada é classificada aqui automaticamente pelo reasoner. Não asserida disjunta das demais categorias de equipamento (partição seletiva)."@pt-br ;
                            annotation:firstOrderLogicDefinition "MomentumTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MomentumTransfer(p) ∧ realizedIn(f,p)))" ;
                            annotation:isPrimitive "false"^^xsd:boolean ;
                            annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a momentum-transfer operation."@en ,
                                                                 "Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento."@pt-br ;
                            annotation:semiFormalNaturalLanguageDefinition "x is a 'momentum-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'momentum transfer'"@en ,
                                                                           "x é um 'dispositivo de transferência de quantidade de movimento' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de quantidade de movimento'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/Operation
copi:Operation rdf:type owl:Class ;
               rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
               rdfs:isDefinedBy copi:copi-core ;
               rdfs:label "operation"@en ,
                          "operação"@pt-br ;
               annotation:firstOrderLogicAxiom "Operation(x) → Process(x)" ;
               annotation:isPrimitive "true"^^xsd:boolean ;
               annotation:naturalLanguageDefinition "A process that an item of process-industry equipment is designed to bring about or take part in."@en ,
                                                    "Um processo que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar."@pt-br ;
               annotation:primitiveRationale "Abstract superclass collecting the nine COPI operation categories; differentiated by its subclasses, not by a single formal condition."@en ,
                                             "Superclasse abstrata que reúne as nove categorias de operação do COPI; diferenciada por suas subclasses, não por uma única condição formal."@pt-br ;
               annotation:semiFormalNaturalLanguageAxiom "if x is an 'operation' then x is a 'process'"@en ,
                                                         "se x é uma 'operação' então x é um 'processo'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/PhaseChange
copi:PhaseChange rdf:type owl:Class ;
                 rdfs:subClassOf copi:Operation ;
                 rdfs:isDefinedBy copi:copi-core ;
                 rdfs:label "mudança de fase"@pt-br ,
                            "phase change"@en ;
                 skos:example "Evaporation; condensation; crystallisation."@en ,
                              "Evaporação; condensação; cristalização."@pt-br ;
                 annotation:firstOrderLogicAxiom "PhaseChange(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))" ;
                 annotation:isPrimitive "true"^^xsd:boolean ;
                 annotation:naturalLanguageDefinition "A process that changes the physical state (phase) of a material without changing its chemical identity."@en ,
                                                      "Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química."@pt-br ;
                 annotation:primitiveRationale "Classe de operações unitárias; a mudança de fase a identidade química constante é declarada para folhas (e.g. Vaporization) mas não no nível da categoria em OWL."@pt-br ,
                                               "Unit-operations class; the change of phase at constant chemical identity is stated for leaves (e.g. Vaporization) but not at category level in OWL."@en ;
                 annotation:semiFormalNaturalLanguageAxiom "if x is a 'phase change' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                           "se x é uma 'mudança de fase' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/PhaseChangeDevice
copi:PhaseChangeDevice rdf:type owl:Class ;
                       owl:equivalentClass [ owl:intersectionOf ( construct:MaterialArtifact
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty construct:hasFunction ;
                                                                    owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                owl:someValuesFrom copi:PhaseChange
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ]
                                                                  ]
                                                                ) ;
                                             rdf:type owl:Class
                                           ] ;
                       rdfs:subClassOf construct:MaterialArtifact ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty construct:hasFunction ;
                                         owl:someValuesFrom [ owl:intersectionOf ( construct:DesignedFunction
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                     owl:someValuesFrom copi:PhaseChange
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ]
                                       ] ;
                       rdfs:isDefinedBy copi:copi-core ;
                       rdfs:label "dispositivo de mudança de fase"@pt-br ,
                                  "phase-change device"@en ;
                       skos:example "evaporador, condensador, cristalizador"@pt-br ,
                                    "evaporator, condenser, crystalliser"@en ;
                       annotation:adaptedFrom "Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V." ;
                       annotation:firstOrderLogicDefinition "PhaseChangeDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(PhaseChange(p) ∧ realizedIn(f,p)))" ;
                       annotation:isPrimitive "false"^^xsd:boolean ;
                       annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a phase-change operation."@en ,
                                                            "Um artefato material que porta uma função projetada realizada em uma operação de mudança de fase."@pt-br ;
                       annotation:semiFormalNaturalLanguageDefinition "x is a 'phase-change device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'phase change'"@en ,
                                                                      "x é um 'dispositivo de mudança de fase' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'mudança de fase'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/PortionOfFluid
copi:PortionOfFluid rdf:type owl:Class ;
                    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                    rdfs:isDefinedBy copi:copi-vocab ;
                    rdfs:label "portion of fluid"@en ;
                    annotation:naturalLanguageDefinition "A bounded portion of matter in a fluid state (gaseous, liquid, or supercritical) that participates in an equipment-realizing process as input, output, or transformed substance."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PortionOfGas
copi:PortionOfGas rdf:type owl:Class ;
                  rdfs:subClassOf copi:PortionOfFluid ;
                  owl:disjointWith copi:PortionOfLiquid ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "portion of gas"@en ;
                  annotation:naturalLanguageDefinition "A portion of fluid in gaseous phase."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PortionOfLiquid
copi:PortionOfLiquid rdf:type owl:Class ;
                     rdfs:subClassOf copi:PortionOfFluid ;
                     rdfs:isDefinedBy copi:copi-vocab ;
                     rdfs:label "portion of liquid"@en ;
                     annotation:naturalLanguageDefinition "A portion of fluid in liquid phase."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PortionOfSolid
copi:PortionOfSolid rdf:type owl:Class ;
                    rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                    rdfs:isDefinedBy copi:copi-vocab ;
                    rdfs:label "portion of solid"@en ;
                    annotation:naturalLanguageDefinition "A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product)."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Pressure
copi:Pressure rdf:type owl:Class ;
              rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
              rdfs:isDefinedBy copi:copi-vocab ;
              rdfs:label "pressure"@en ;
              annotation:naturalLanguageDefinition "A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementAndTransmissionProcess
copi:PressureMeasurementAndTransmissionProcess rdf:type owl:Class ;
                                               rdfs:subClassOf construct:MeasurementProcess ;
                                               rdfs:isDefinedBy copi:copi-vocab ;
                                               rdfs:label "pressure measurement and transmission process"@en ;
                                               annotation:isPrimitive "true"^^xsd:boolean ;
                                               annotation:naturalLanguageDefinition "A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementResult
copi:PressureMeasurementResult rdf:type owl:Class ;
                               rdfs:subClassOf construct:MeasurementInformationContentEntity ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty construct:describes ;
                                                 owl:someValuesFrom copi:Pressure
                                               ] ;
                               rdfs:isDefinedBy copi:copi-vocab ;
                               rdfs:label "pressure measurement result"@en ;
                               annotation:naturalLanguageDefinition "Measurement information content entity describing a pressure quality of some material entity or fluid."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureTransmissionFunction
copi:PressureTransmissionFunction rdf:type owl:Class ;
                                  rdfs:subClassOf copi:SignalTransmissionFunction ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom copi:PressureMeasurementAndTransmissionProcess
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:allValuesFrom copi:PressureMeasurementAndTransmissionProcess
                                                  ] ;
                                  rdfs:isDefinedBy copi:copi-vocab ;
                                  rdfs:label "pressure transmission function"@en ;
                                  annotation:isPrimitive "true"^^xsd:boolean ;
                                  annotation:naturalLanguageDefinition "An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control."@en ;
                                  annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowFunction
copi:ProcessControlledFlowFunction rdf:type owl:Class ;
                                   rdfs:subClassOf copi:FlowControlFunction ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                     owl:someValuesFrom copi:ProcessControlledFlowProcess
                                                   ] ,
                                                   [ rdf:type owl:Restriction ;
                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                     owl:allValuesFrom copi:ProcessControlledFlowProcess
                                                   ] ;
                                   rdfs:isDefinedBy copi:copi-vocab ;
                                   rdfs:label "process-controlled flow function"@en ;
                                   annotation:isPrimitive "true"^^xsd:boolean ;
                                   annotation:naturalLanguageDefinition "An identity-giving designed function realized in a ProcessControlledFlowProcess; the function of opening or shutting a flow path in response to an external process control signal."@en ;
                                   annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowProcess
copi:ProcessControlledFlowProcess rdf:type owl:Class ;
                                  rdfs:subClassOf copi:FlowControl ;
                                  rdfs:isDefinedBy copi:copi-vocab ;
                                  rdfs:label "process-controlled flow process"@en ;
                                  annotation:isPrimitive "true"^^xsd:boolean ;
                                  annotation:naturalLanguageDefinition "A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Pump
copi:Pump rdf:type owl:Class ;
          rdfs:subClassOf copi:MomentumTransferDevice ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty construct:hasFunction ;
                            owl:someValuesFrom copi:PumpingFunction
                          ] ;
          owl:disjointWith copi:Valve ;
          rdfs:isDefinedBy copi:copi-enriched ;
          rdfs:label "bomba"@pt-br ,
                     "pump"@en ;
          skos:example "bomba centrífuga, bomba de deslocamento positivo"@pt-br ,
                       "centrifugal pump, positive-displacement pump"@en ;
          annotation:adaptedFrom "ISO 14224 Annex A (rotating equipment)." ;
          annotation:explanatoryNote "Inferida como MomentumTransferDevice apenas a partir de sua função, sem vínculo de subclasse asserido."@pt-br ,
                                     "Inferred to be a MomentumTransferDevice from its function alone, with no asserted subclass link."@en ;
          annotation:firstOrderLogicAxiom "Pump(x) → MaterialArtifact(x) ∧ ∃f(PumpingFunction(f) ∧ hasFunction(x,f))" ;
          annotation:isPrimitive "true"^^xsd:boolean ;
          annotation:naturalLanguageDefinition "A material artifact whose identity-giving designed function is to raise the pressure of an incompressible liquid."@en ,
                                               "Um artefato material cuja função projetada identificadora é elevar a pressão de um líquido incompressível."@pt-br ;
          annotation:primitiveRationale "An OWL-primitive leaf universal: its identity criterion (the borne designed function) is asserted as a necessary condition, not as an OWL definition."@en ,
                                        "Um universal folha OWL-primitivo: seu critério de identidade (a função projetada portada) é asserido como condição necessária, não como definição OWL."@pt-br ;
          annotation:semiFormalNaturalLanguageAxiom "if x is a 'pump' then x is a 'material artifact' that 'has function' some 'pumping function'"@en ,
                                                    "se x é uma 'bomba' então x é um 'artefato material' que 'tem função' alguma 'função de bombeamento'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/PumpingFunction
copi:PumpingFunction rdf:type owl:Class ;
                     rdfs:subClassOf construct:DesignedFunction ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:someValuesFrom copi:LiquidPressureIncrease
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:allValuesFrom copi:LiquidPressureIncrease
                                     ] ;
                     rdfs:isDefinedBy copi:copi-enriched ;
                     rdfs:label "função de bombeamento"@pt-br ,
                                "pumping function"@en ;
                     annotation:explanatoryNote "A restrição 'algum' é essencial: sem ela, uma função não realizada satisfaria vacuamente a restrição 'apenas', e a disjunção implicada entre PumpingFunction e CompressionFunction se perderia."@pt-br ,
                                                "The 'some' restriction is essential: without it an unrealized function would vacuously satisfy the 'only' restriction, and the entailed disjointness of PumpingFunction and CompressionFunction would be lost."@en ;
                     annotation:firstOrderLogicAxiom "PumpingFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ LiquidPressureIncrease(p)) ∧ ∀p(realizedIn(x,p) → LiquidPressureIncrease(p))" ;
                     annotation:isPrimitive "true"^^xsd:boolean ;
                     annotation:naturalLanguageDefinition "A função projetada de elevar a pressão de um líquido incompressível; realizada apenas em uma operação de aumento de pressão de líquido."@pt-br ,
                                                          "The designed function to raise the pressure of an incompressible liquid; realized only in a liquid-pressure-increase operation."@en ;
                     annotation:primitiveRationale "OWL fornece apenas condições necessárias (restrições de subclasse); o par algum+apenas mais a disjunção das operações folha implica -- mas não OWL-define -- a função."@pt-br ,
                                                   "OWL gives only necessary conditions (subclass restrictions); the some+only pair plus the disjointness of the leaf operations entails -- but does not OWL-define -- the function."@en ;
                     annotation:semiFormalNaturalLanguageAxiom "if x is a 'pumping function' then x is a 'designed function' that is 'realized in' some 'liquid pressure increase' and is 'realized in' only 'liquid pressure increase'"@en ,
                                                               "se x é uma 'função de bombeamento' então x é uma 'função projetada' que é 'realizada em' algum 'aumento de pressão de líquido' e é 'realizada em' apenas 'aumento de pressão de líquido'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/RichAbsorbent
copi:RichAbsorbent rdf:type owl:Class ;
                   rdfs:subClassOf copi:AbsorbentPhase ;
                   rdfs:isDefinedBy copi:copi-vocab ;
                   rdfs:label "rich absorbent"@en ;
                   annotation:naturalLanguageDefinition "An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/RotationalSpeed
copi:RotationalSpeed rdf:type owl:Class ;
                     rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
                     rdfs:isDefinedBy copi:copi-vocab ;
                     rdfs:label "rotational speed"@en ;
                     annotation:naturalLanguageDefinition "A quality inhering in a rotating element that represents the number of complete revolutions per unit time."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefFunction
copi:SafetyReliefFunction rdf:type owl:Class ;
                          rdfs:subClassOf construct:DesignedFunction ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:someValuesFrom copi:SafetyReliefProcess
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:allValuesFrom copi:SafetyReliefProcess
                                          ] ;
                          rdfs:isDefinedBy copi:copi-vocab ;
                          rdfs:label "safety relief function"@en ;
                          annotation:isPrimitive "true"^^xsd:boolean ;
                          annotation:naturalLanguageDefinition "An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe."@en ;
                          annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefProcess
copi:SafetyReliefProcess rdf:type owl:Class ;
                         rdfs:subClassOf copi:FlowControl ;
                         rdfs:isDefinedBy copi:copi-vocab ;
                         rdfs:label "safety relief process"@en ;
                         annotation:isPrimitive "true"^^xsd:boolean ;
                         annotation:naturalLanguageDefinition "A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Seat
copi:Seat rdf:type owl:Class ;
          rdfs:subClassOf construct:MaterialArtifact ;
          rdfs:isDefinedBy copi:copi-enriched ;
          rdfs:label "assento"@pt-br ,
                     "seat"@en ;
          annotation:naturalLanguageDefinition "A valve trim component that forms a sealing interface with the flow control element when the valve is closed."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Separator
copi:Separator rdf:type owl:Class ;
               rdfs:subClassOf construct:MaterialArtifact ;
               rdfs:isDefinedBy copi:copi-enriched ;
               rdfs:label "separator"@en ;
               annotation:maturity <https://spec.industrialontologies.org/ontology/individual/Provisional> ;
               annotation:naturalLanguageDefinition "A material artifact that separates a mixed-phase or multi-component stream into distinct streams or phases through mechanical means."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ShellAndTubeHeatExchanger
copi:ShellAndTubeHeatExchanger rdf:type owl:Class ;
                               rdfs:subClassOf copi:HeatTransferDevice ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty construct:hasFunction ;
                                                 owl:someValuesFrom copi:HeatTransferFunction
                                               ] ;
                               rdfs:isDefinedBy copi:copi-enriched ;
                               rdfs:label "shell-and-tube heat exchanger"@en ,
                                          "trocador de calor casco-e-tubo"@pt-br ;
                               annotation:adaptedFrom "ISO 14224 Annex A (heat exchangers); TEMA." ;
                               annotation:firstOrderLogicAxiom "ShellAndTubeHeatExchanger(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ hasFunction(x,f))" ;
                               annotation:isPrimitive "true"^^xsd:boolean ;
                               annotation:naturalLanguageDefinition "A heat-transfer material artifact in which one fluid flows through a bundle of tubes and another through the surrounding shell."@en ,
                                                                    "Um artefato material de transferência de calor no qual um fluido escoa por um feixe de tubos e outro pelo casco circundante."@pt-br ;
                               annotation:primitiveRationale "Folha OWL-primitiva: a função de transferência de calor portada é asserida como condição necessária; a construção tubo/casco é descritiva, não o critério de identidade."@pt-br ,
                                                             "OWL-primitive leaf: the borne heat-transfer function is asserted as a necessary condition; the tube/shell construction is descriptive, not the identity criterion."@en ;
                               annotation:semiFormalNaturalLanguageAxiom "if x is a 'shell-and-tube heat exchanger' then x is a 'material artifact' that 'has function' some 'heat-transfer function'"@en ,
                                                                         "se x é um 'trocador de calor casco-e-tubo' então x é um 'artefato material' que 'tem função' alguma 'função de transferência de calor'"@pt-br ;
                               annotation:synonym "STHE"@en ,
                                                  "trocador casco-tubo"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/SightGlass
copi:SightGlass rdf:type owl:Class ;
                rdfs:subClassOf construct:MaterialArtifact ;
                rdfs:isDefinedBy copi:copi-enriched ;
                rdfs:label "sight glass"@en ;
                annotation:maturity <https://spec.industrialontologies.org/ontology/individual/Provisional> ;
                annotation:naturalLanguageDefinition "A material artifact with a transparent section that permits direct visual observation of the fluid level, condition, or flow inside a vessel or pipeline."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionFunction
copi:SignalTransmissionFunction rdf:type owl:Class ;
                                rdfs:subClassOf copi:InstrumentationFunction ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:someValuesFrom copi:SignalTransmissionProcess
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:allValuesFrom copi:SignalTransmissionProcess
                                                ] ;
                                rdfs:isDefinedBy copi:copi-vocab ;
                                rdfs:label "signal transmission function"@en ;
                                annotation:isPrimitive "true"^^xsd:boolean ;
                                annotation:naturalLanguageDefinition "An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control."@en ;
                                annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionProcess
copi:SignalTransmissionProcess rdf:type owl:Class ;
                               rdfs:subClassOf construct:MeasurementProcess ;
                               rdfs:isDefinedBy copi:copi-vocab ;
                               rdfs:label "signal transmission process"@en ;
                               annotation:isPrimitive "true"^^xsd:boolean ;
                               annotation:naturalLanguageDefinition "A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Temperature
copi:Temperature rdf:type owl:Class ;
                 rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
                 rdfs:isDefinedBy copi:copi-vocab ;
                 rdfs:label "temperature"@en ;
                 annotation:naturalLanguageDefinition "A quality inhering in a material entity that represents the intensity of thermal energy of that entity."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementResult
copi:TemperatureMeasurementResult rdf:type owl:Class ;
                                  rdfs:subClassOf construct:MeasurementInformationContentEntity ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty construct:describes ;
                                                    owl:someValuesFrom copi:Temperature
                                                  ] ;
                                  rdfs:isDefinedBy copi:copi-vocab ;
                                  rdfs:label "temperature measurement result"@en ;
                                  annotation:naturalLanguageDefinition "Measurement information content entity describing a temperature quality of some material entity."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingFunction
copi:TemperatureSensingFunction rdf:type owl:Class ;
                                rdfs:subClassOf construct:DesignedFunction ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:someValuesFrom construct:MeasurementProcess
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:allValuesFrom construct:MeasurementProcess
                                                ] ;
                                rdfs:isDefinedBy copi:copi-enriched ;
                                rdfs:label "função de medição de temperatura"@pt-br ,
                                           "temperature-sensing function"@en ;
                                annotation:firstOrderLogicAxiom "TemperatureSensingFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ MeasurementProcess(p)) ∧ ∀p(realizedIn(x,p) → MeasurementProcess(p))" ;
                                annotation:isPrimitive "true"^^xsd:boolean ;
                                annotation:naturalLanguageDefinition "A função projetada de determinar a temperatura de uma entidade de interesse; realizada apenas em um iof-constr:MeasurementProcess."@pt-br ,
                                                                     "The designed function to determine the temperature of an entity of interest; realized only in an iof-constr:MeasurementProcess."@en ;
                                annotation:primitiveRationale "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ,
                                                              "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ;
                                annotation:semiFormalNaturalLanguageAxiom "if x is a 'temperature-sensing function' then x is a 'designed function' that is 'realized in' some 'measurement process' and is 'realized in' only 'measurement process'"@en ,
                                                                          "se x é uma 'função de medição de temperatura' então x é uma 'função projetada' que é 'realizada em' algum 'processo de medição' e é 'realizada em' apenas 'processo de medição'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensor
copi:TemperatureSensor rdf:type owl:Class ;
                       rdfs:subClassOf copi:MeasurementInstrument ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty construct:hasFunction ;
                                         owl:someValuesFrom copi:TemperatureSensingFunction
                                       ] ;
                       rdfs:isDefinedBy copi:copi-enriched ;
                       rdfs:label "sensor de temperatura"@pt-br ,
                                  "temperature sensor"@en ;
                       annotation:adaptedFrom "ISO 14224 Annex A (instruments)." ;
                       annotation:explanatoryNote "Inferido como MeasurementInstrument apenas a partir de sua função."@pt-br ,
                                                  "Inferred to be a MeasurementInstrument from its function alone."@en ;
                       annotation:firstOrderLogicAxiom "TemperatureSensor(x) → MaterialArtifact(x) ∧ ∃f(TemperatureSensingFunction(f) ∧ hasFunction(x,f))" ;
                       annotation:isPrimitive "true"^^xsd:boolean ;
                       annotation:naturalLanguageDefinition "A measurement artifact whose identity-giving designed function is to determine temperature."@en ,
                                                            "Um artefato de medição cuja função projetada identificadora é determinar temperatura."@pt-br ;
                       annotation:primitiveRationale "Folha OWL-primitiva: a função de medição de temperatura portada é a condição necessária asserida."@pt-br ,
                                                     "OWL-primitive leaf: the borne temperature-sensing function is the asserted necessary condition."@en ;
                       annotation:semiFormalNaturalLanguageAxiom "if x is a 'temperature sensor' then x is a 'material artifact' that 'has function' some 'temperature-sensing function'"@en ,
                                                                 "se x é um 'sensor de temperatura' então x é um 'artefato material' que 'tem função' alguma 'função de medição de temperatura'"@pt-br ;
                       annotation:synonym "temperature transmitter"@en ,
                                          "transmissor de temperatura"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/Transformer
copi:Transformer rdf:type owl:Class ;
                 rdfs:subClassOf construct:MaterialArtifact ;
                 rdfs:isDefinedBy copi:copi-enriched ;
                 rdfs:label "transformer"@en ;
                 annotation:explanatoryNote "Scope note: Transformer enters from COPIeditor ODR-A1 as an electrical utility artifact. Its inclusion in a petroleum-plant boundary ontology requires review (ODR-015 phase 2)."@en ;
                 annotation:maturity <https://spec.industrialontologies.org/ontology/individual/Provisional> ;
                 annotation:naturalLanguageDefinition "A material artifact that transfers electrical energy between circuits at different voltage or current levels through electromagnetic induction."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Valve
copi:Valve rdf:type owl:Class ;
           rdfs:subClassOf copi:FlowControlDevice ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty construct:hasFunction ;
                             owl:someValuesFrom copi:FlowControlFunction
                           ] ;
           rdfs:isDefinedBy copi:copi-enriched ;
           rdfs:label "valve"@en ,
                      "válvula"@pt-br ;
           skos:definition "[CFIHOS] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en ,
                           "[ISO 15926-4] A <VALVE> is a <FLUID REGULATOR> that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream"@en ,
                           "[OnePetro] Any of several valves: plug, gate, butterfly, needle, etc., used in oil field operations."@en ,
                           "[POSC Caesar] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream."@en ;
           annotation:firstOrderLogicAxiom "∀x(Valve(x) → MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))"@en ;
           annotation:isPrimitive "true"^^xsd:boolean ;
           annotation:naturalLanguageDefinition "A valve is a material artifact that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en ,
                                                "Uma válvula é um artefato material que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido."@pt-br ;
           annotation:primitiveRationale "Primitiva porque ser um artefato material com uma função de controle de fluxo é insuficiente para individuar totalmente uma válvula; o critério de identidade é portado por subtipos folha (ControlValve etc.). Axiomas de partes (ValveBody, Seat, FlowControlElement) são asseridos apenas em subtipos definicionais."@pt-br ,
                                         "Primitive because being a material artifact with a flow control function is insufficient for full valve individuation; the identity criterion is carried by leaf subtypes (ControlValve etc.). Part axioms (ValveBody, Seat, FlowControlElement) are asserted only on definitional subtypes."@en ;
           annotation:semiFormalNaturalLanguageAxiom "Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ValveBody
copi:ValveBody rdf:type owl:Class ;
               rdfs:subClassOf construct:MaterialArtifact ;
               rdfs:isDefinedBy copi:copi-enriched ;
               rdfs:label "corpo de válvula"@pt-br ,
                          "valve body"@en ;
               annotation:naturalLanguageDefinition "The main structural component of a valve that houses the internal trim and connects to the pipeline."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Vaporization
copi:Vaporization rdf:type owl:Class ;
                  rdfs:subClassOf copi:PhaseChange ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "vaporization"@en ,
                             "vaporização"@pt-br ;
                  annotation:firstOrderLogicDefinition "Vaporization(x) ↔ PhaseChange(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∃v(Vapour(v) ∧ hasOutput(x,v) ∧ derivesFrom(v,l))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A phase-change operation in which a liquid input is converted to a vapour output."@en ,
                                                       "Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor."@pt-br ;
                  annotation:primitiveRationale "OWL 2 DL carrega apenas o gênero (PhaseChange); a derivação líquido-para-vapor é apenas-FOL."@pt-br ,
                                                "OWL 2 DL carries only the genus (PhaseChange); the liquid-to-vapour derivation is FOL-only."@en ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'vaporization' if and only if x is a 'phase change' whose liquid input gives rise to a vapour output"@en ,
                                                                 "x é uma 'vaporização' se e somente se x é uma 'mudança de fase' cuja entrada líquida dá origem a uma saída de vapor"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/VaporizationFunction
copi:VaporizationFunction rdf:type owl:Class ;
                          rdfs:subClassOf construct:DesignedFunction ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:someValuesFrom copi:Vaporization
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:allValuesFrom copi:Vaporization
                                          ] ;
                          rdfs:isDefinedBy copi:copi-enriched ;
                          rdfs:label "função de vaporização"@pt-br ,
                                     "vaporization function"@en ;
                          annotation:firstOrderLogicAxiom "VaporizationFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ Vaporization(p)) ∧ ∀p(realizedIn(x,p) → Vaporization(p))" ;
                          annotation:isPrimitive "true"^^xsd:boolean ;
                          annotation:naturalLanguageDefinition "A função projetada de converter um líquido em vapor; realizada apenas em uma operação de vaporização."@pt-br ,
                                                               "The designed function to convert a liquid into a vapour; realized only in a vaporization operation."@en ;
                          annotation:primitiveRationale "OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência."@pt-br ,
                                                        "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en ;
                          annotation:semiFormalNaturalLanguageAxiom "if x is a 'vaporization function' then x is a 'designed function' that is 'realized in' some 'vaporization' and is 'realized in' only 'vaporization'"@en ,
                                                                    "se x é uma 'função de vaporização' então x é uma 'função projetada' que é 'realizada em' alguma 'vaporização' e é 'realizada em' apenas 'vaporização'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/Vibration
copi:Vibration rdf:type owl:Class ;
               rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
               rdfs:isDefinedBy copi:copi-vocab ;
               rdfs:label "vibration"@en ;
               annotation:naturalLanguageDefinition "A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/VisualIndication
copi:VisualIndication rdf:type owl:Class ;
                      rdfs:subClassOf construct:InformationContentEntity ;
                      rdfs:isDefinedBy copi:copi-vocab ;
                      rdfs:label "visual indication"@en ;
                      annotation:naturalLanguageDefinition "An information content entity perceptible through visual representation at the point of measurement or display."@en .


