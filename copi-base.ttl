                                    owl:allValuesFrom copi:DifferentialPressureMeasurementProcess
                                  ] ;
                  rdfs:label "differential pressure measurement function"@en ,
                             "função de medição de pressão diferencial"@pt-br ;
                  annotation:naturalLanguageDefinition "A PressureSensingFunction that is realized in a DifferentialPressureMeasurementProcess and that consists in sensing the pressure difference between two fluid media or two points in the same medium to enable measurement of differential pressure."@en .


