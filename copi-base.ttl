                                       rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ;
                                       rdfs:label "processo de componente estacionário de máquina"@pt-br ,
                                                  "stationary machine component process"@en ;
                                       annotation:naturalLanguageDefinition "A PlannedProcess in which a stator maintains its fixed position relative to rotating components within machinery, providing structural support and housing for electromagnetic windings, guide vanes, or other functional elements that require stable positioning."@en .


