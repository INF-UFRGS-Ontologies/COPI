copi:COPI_0000038 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000037 ;
                  owl:disjointWith copi:COPI_0000039 ;
                  rdfs:comment "A portion of fluid in liquid phase."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "portion of liquid"@en ;
                  annotation:naturalLanguageDefinition "A portion of fluid in liquid phase."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039
copi:COPI_0000039 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000037 ;
                  rdfs:comment "A portion of fluid in gaseous phase."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "portion of gas"@en ;
                  annotation:naturalLanguageDefinition "A portion of fluid in gaseous phase."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000040
copi:COPI_0000040 rdf:type owl:Class ;
                  rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                  rdfs:comment "A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product)."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "portion of solid"@en ;
                  annotation:naturalLanguageDefinition "A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product)."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041
copi:COPI_0000041 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000038 ;
                  rdfs:comment "A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "absorbent phase"@en ;
                  annotation:naturalLanguageDefinition "A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000042
copi:COPI_0000042 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000041 ;
                  rdfs:comment "An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "rich absorbent"@en ;
                  annotation:naturalLanguageDefinition "An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000043
copi:COPI_0000043 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000037 ;
                  rdfs:comment "A fluid from which target components have been removed or transferred during a treatment process."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "depleted fluid"@en ;
                  annotation:naturalLanguageDefinition "A fluid from which target components have been removed or transferred during a treatment process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000044
copi:COPI_0000044 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000037 ;
                  rdfs:comment "A fluid portion consisting of two or more components or phases that have not yet been fully separated."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "fluid mixture"@en ;
                  annotation:naturalLanguageDefinition "A fluid portion consisting of two or more components or phases that have not yet been fully separated."@en .


