###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199
copi:COPI_0000199 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/DesignedFunction> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:ElectricalPowerTransformationProcess
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:ElectricalPowerTransformationProcess
                                  ] ;
                  rdfs:label "electrical power transformation function"@en ,
                             "função de transformação de energia elétrica"@pt-br ;
                  annotation:naturalLanguageDefinition "A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in changing the voltage and current levels of electrical power through electromagnetic induction while maintaining power transfer efficiency."@en ,
                                                       "A DesignedFunction that is realized in an ElectricalPowerTransformationProcess and that consists in converting electrical energy from one voltage level to another through electromagnetic induction, enabling power distribution and utilization at appropriate voltage levels."@en .


