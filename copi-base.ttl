                  annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031
copi:COPI_0000031 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000030 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000036
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:COPI_0000036
                                  ] ;
                  rdfs:comment "An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "pressure transmission function"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control."@en ;
                  annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032
copi:COPI_0000032 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/DesignedFunction> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000034
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:COPI_0000034
                                  ] ;
                  rdfs:comment "An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "safety relief function"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe."@en ;
                  annotation:primitiveRationale "OWL gives only necessary conditions; the some+only pair characterises the function for inference."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033
copi:COPI_0000033 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000010 ;
                  rdfs:comment "A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "process-controlled flow process"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034
copi:COPI_0000034 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000010 ;
                  rdfs:comment "A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "safety relief process"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035
copi:COPI_0000035 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MeasurementProcess> ;
                  rdfs:comment "A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "signal transmission process"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036
copi:COPI_0000036 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MeasurementProcess> ;
                  rdfs:comment "A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "pressure measurement and transmission process"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037
copi:COPI_0000037 rdf:type owl:Class ;
