                  annotation:firstOrderLogicAxiom "∀x (VibrationTransmitter(x) ↔ Transmitter(x) ∧ ∃f (VibrationTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃hasInput.VibrationSignal ⊓ ∃f (VibrationMeasurementFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters."@en ,
                                                       "Um transmissor de vibração é um transmissor que mede vibrações mecânicas e produz um sinal de saída proporcional aos parâmetros de vibração medidos."@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160
copi:COPI_0000160 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000103 ;
                  rdfs:comment "A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges."@en ,
                               "Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "válvula de retenção wafer"@pt-br ,
                             "wafer check valve"@en ;
                  annotation:firstOrderLogicAxiom "∀x (WaferCheckValve(x) → CheckValve(x) ∧ ∃f (BackflowPreventionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges."@en ,
                                                       "Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges."@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161
copi:COPI_0000161 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000026 ;
                  rdfs:comment "A backflow prevention function is a flow control function whose realization prevents the reverse flow of fluid through a conduit."@en ,
                               "Uma função de prevenção de refluxo é uma função de controle de fluxo cuja realização previne o fluxo reverso de fluido em um conduto."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "backflow prevention function"@en ,
                             "função de prevenção de refluxo"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162
copi:COPI_0000162 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000026 ;
                  rdfs:comment "A binary flow control function is a flow control function whose realization switches fluid flow between fully open and fully closed states."@en ,
                               "Uma função de controle binário de fluxo é uma função de controle de fluxo cuja realização alterna o fluxo de fluido entre os estados totalmente aberto e totalmente fechado."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "binary flow control function"@en ,
                             "função de controle de fluxo binário"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163
copi:COPI_0000163 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000026 ;
                  rdfs:comment "A flow restriction function is a flow control function whose realization reduces or limits fluid flow by introducing resistance in a conduit."@en ,
                               "Uma função de restrição de fluxo é uma função de controle de fluxo cuja realização reduz ou limita o fluxo de fluido introduzindo resistência em um conduto."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "flow restriction function"@en ,
                             "função de restrição de fluxo"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164
copi:COPI_0000164 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000026 ;
                  rdfs:comment "A pressure reduction function is a flow control function whose realization reduces the downstream pressure of a fluid to a specified set level."@en ,
                               "Uma função de redução de pressão é uma função de controle de fluxo cuja realização reduz a pressão a jusante de um fluido a um nível definido especificado."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de redução de pressão"@pt-br ,
                             "pressure reduction function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165
copi:COPI_0000165 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000026 ;
                  rdfs:comment "An emergency shut-down function is a flow control function whose realization rapidly isolates a process segment upon detection of an abnormal or hazardous condition."@en ,
                               "Uma função de parada de emergência é uma função de controle de fluxo cuja realização isola rapidamente um segmento de processo ao detectar uma condição anormal ou perigosa."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "emergency shut-down function"@en ,
                             "função de parada de emergência"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166
copi:COPI_0000166 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000026 ;
                  rdfs:comment "A rapid depressurization function is a flow control function whose realization quickly reduces the pressure of a process segment by venting fluid to a safe location."@en ,
                               "Uma função de despressurização rápida é uma função de controle de fluxo cuja realização reduz rapidamente a pressão de um segmento de processo descarregando fluido para um local seguro."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de despressurização rápida"@pt-br ,
                             "rapid depressurization function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000167
copi:COPI_0000167 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000027 ;
                  rdfs:comment "An electrical control function is a process-controlled flow function whose realization modulates fluid flow in response to an electrical signal."@en ,
                               "Uma função de controle elétrico é uma função de fluxo controlada por processo cuja realização modula o fluxo de fluido em resposta a um sinal elétrico."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "electrical control function"@en ,
                             "função de controle elétrico"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168
copi:COPI_0000168 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000032 ;
                  rdfs:comment "A safety venting function is a safety relief function whose realization discharges gas or vapour from a process system to prevent overpressure."@en ,
                               "Uma função de ventilação de segurança é uma função de alívio de segurança cuja realização descarrega gás ou vapor de um sistema de processo para prevenir sobrepressão."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de ventilação de segurança"@pt-br ,
                             "safety venting function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169
copi:COPI_0000169 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000032 ;
                  rdfs:comment "A pressure relief function is a safety relief function whose realization automatically opens a flow path when process pressure exceeds a set limit, protecting equipment from overpressure damage."@en ,
                               "Uma função de alívio de pressão é uma função de alívio de segurança cuja realização abre automaticamente um caminho de fluxo quando a pressão do processo excede um limite definido, protegendo equipamentos de danos por sobrepressão."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de alívio de pressão"@pt-br ,
                             "pressure relief function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170
copi:COPI_0000170 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000032 ;
                  rdfs:comment "A subsurface safety function is a safety relief function whose realization closes a wellbore flow path to prevent uncontrolled flow from a subsurface reservoir."@en ,
                               "Uma função de segurança subsuperficial é uma função de alívio de segurança cuja realização fecha o caminho de fluxo de um poço para prevenir o fluxo não controlado de um reservatório subsuperficial."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de segurança subsuperficial"@pt-br ,
                             "subsurface safety function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171
copi:COPI_0000171 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000028 ;
                  rdfs:comment "A flow indication function is an indication function whose realization displays the flow rate of a fluid to an operator."@en ,
                               "Uma função de indicação de vazão é uma função de indicação cuja realização exibe a taxa de fluxo de um fluido para um operador."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "flow indication function"@en ,
                             "função de indicação de fluxo"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172
copi:COPI_0000172 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000028 ;
                  rdfs:comment "A level indication function is an indication function whose realization displays the fluid level in a vessel to an operator."@en ,
                               "Uma função de indicação de nível é uma função de indicação cuja realização exibe o nível de fluido em um vaso para um operador."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de indicação de nível"@pt-br ,
                             "level indication function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173
copi:COPI_0000173 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000028 ;
                  rdfs:comment "A temperature indication function is an indication function whose realization displays the temperature of a process fluid or surface to an operator."@en ,
                               "Uma função de indicação de temperatura é uma função de indicação cuja realização exibe a temperatura de um fluido de processo ou superfície para um operador."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de indicação de temperatura"@pt-br ,
                             "temperature indication function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174
copi:COPI_0000174 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A flow measurement function is an instrumentation function whose realization determines the volumetric or mass flow rate of a fluid."@en ,
                               "Uma função de medição de vazão é uma função de instrumentação cuja realização determina a taxa de fluxo volumétrico ou mássico de um fluido."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "flow measurement function"@en ,
                             "função de medição de fluxo"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000175
copi:COPI_0000175 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A level measurement function is an instrumentation function whose realization determines the height of a fluid interface within a vessel."@en ,
                               "Uma função de medição de nível é uma função de instrumentação cuja realização determina a altura da interface de um fluido dentro de um vaso."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de medição de nível"@pt-br ,
                             "level measurement function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000176
copi:COPI_0000176 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A level detection function is an instrumentation function whose realization generates a discrete signal when a fluid reaches a specified level within a vessel."@en ,
                               "Uma função de detecção de nível é uma função de instrumentação cuja realização gera um sinal discreto quando um fluido atinge um nível especificado dentro de um vaso."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de detecção de nível"@pt-br ,
                             "level detection function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177
copi:COPI_0000177 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A pressure sensing function is an instrumentation function whose realization detects the pressure of a process fluid."@en ,
                               "Uma função de sensoreamento de pressão é uma função de instrumentação cuja realização detecta a pressão de um fluido de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de sensoreamento de pressão"@pt-br ,
                             "pressure sensing function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178
copi:COPI_0000178 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A pressure measurement function is an instrumentation function whose realization determines and outputs a quantitative value for the pressure of a process fluid."@en ,
                               "Uma função de medição de pressão é uma função de instrumentação cuja realização determina e emite um valor quantitativo da pressão de um fluido de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de medição de pressão"@pt-br ,
                             "pressure measurement function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000179
copi:COPI_0000179 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A differential pressure measurement function is an instrumentation function whose realization determines the pressure difference between two points in a process system."@en ,
                               "Uma função de medição de pressão diferencial é uma função de instrumentação cuja realização determina a diferença de pressão entre dois pontos em um sistema de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "differential pressure measurement function"@en ,
                             "função de medição de pressão diferencial"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000180
copi:COPI_0000180 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A humidity measurement function is an instrumentation function whose realization determines the moisture content or relative humidity of a gas stream."@en ,
                               "Uma função de medição de umidade é uma função de instrumentação cuja realização determina o teor de umidade ou umidade relativa de uma corrente de gás."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de medição de umidade"@pt-br ,
                             "humidity measurement function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000181
copi:COPI_0000181 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A phase sequence measurement function is an instrumentation function whose realization detects the rotational order of phases in a multi-phase electrical supply."@en ,
                               "Uma função de medição de sequência de fases é uma função de instrumentação cuja realização detecta a ordem rotacional das fases em uma alimentação elétrica multifásica."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de medição de sequência de fase"@pt-br ,
                             "phase sequence measurement function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000182
copi:COPI_0000182 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A vibration measurement function is an instrumentation function whose realization quantifies the mechanical oscillation amplitude, velocity, or frequency of a rotating or reciprocating component."@en ,
                               "Uma função de medição de vibração é uma função de instrumentação cuja realização quantifica a amplitude, velocidade ou frequência de oscilação mecânica de um componente rotativo ou alternativo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de medição de vibração"@pt-br ,
                             "vibration measurement function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183
copi:COPI_0000183 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A position limit detection function is an instrumentation function whose realization generates a discrete signal when a moving component reaches a defined travel limit."@en ,
                               "Uma função de detecção de limite de posição é uma função de instrumentação cuja realização gera um sinal discreto quando um componente móvel atinge um limite de curso definido."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de detecção de limite de posição"@pt-br ,
                             "position limit detection function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000184
copi:COPI_0000184 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000029 ;
                  rdfs:comment "A temperature measurement capability is an instrumentation function whose realization determines the temperature of a process fluid or surface."@en ,
                               "Uma capacidade de medição de temperatura é uma função de instrumentação cuja realização determina a temperatura de um fluido de processo ou superfície."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "capacidade de medição de temperatura"@pt-br ,
                             "temperature measurement capability"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000185
copi:COPI_0000185 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000030 ;
                  rdfs:comment "A flow signal transmission function is a signal transmission function whose realization conveys a flow measurement signal from a sensing element to a remote display or control system."@en ,
                               "Uma função de transmissão de sinal de vazão é uma função de transmissão de sinal cuja realização transmite um sinal de medição de vazão de um elemento sensor para um display remoto ou sistema de controle."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "flow signal transmission function"@en ,
                             "função de transmissão de sinal de fluxo"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000186
copi:COPI_0000186 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000030 ;
                  rdfs:comment "A differential pressure transmission function is a signal transmission function whose realization conveys a differential pressure measurement signal to a remote indicator or control system."@en ,
                               "Uma função de transmissão de pressão diferencial é uma função de transmissão de sinal cuja realização transmite um sinal de medição de pressão diferencial para um indicador remoto ou sistema de controle."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "differential pressure transmission function"@en ,
                             "função de transmissão de pressão diferencial"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000187
copi:COPI_0000187 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000030 ;
                  rdfs:comment "A level measurement and transmission function is a signal transmission function whose realization both determines and transmits a fluid level measurement to a remote system."@en ,
                               "Uma função de medição e transmissão de nível é uma função de transmissão de sinal cuja realização determina e transmite uma medição de nível de fluido para um sistema remoto."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de medição e transmissão de nível"@pt-br ,
                             "level measurement and transmission function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188
copi:COPI_0000188 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000030 ;
                  rdfs:comment "A temperature measurement and transmission function is a signal transmission function whose realization both determines and transmits a temperature measurement to a remote system."@en ,
                               "Uma função de medição e transmissão de temperatura é uma função de transmissão de sinal cuja realização determina e transmite uma medição de temperatura para um sistema remoto."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de medição e transmissão de temperatura"@pt-br ,
                             "temperature measurement and transmission function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189
copi:COPI_0000189 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000030 ;
                  rdfs:comment "A vibration transmission function is a signal transmission function whose realization conveys a vibration measurement signal to a remote monitor or control system."@en ,
                               "Uma função de transmissão de vibração é uma função de transmissão de sinal cuja realização transmite um sinal de medição de vibração para um monitor remoto ou sistema de controle."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de transmissão de vibração"@pt-br ,
                             "vibration transmission function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190
copi:COPI_0000190 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000068 ;
                  rdfs:comment "A heating function is a heat transfer function whose realization increases the thermal energy of a process fluid or material."@en ,
                               "Uma função de aquecimento é uma função de transferência de calor cuja realização aumenta a energia térmica de um fluido ou material de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de aquecimento"@pt-br ,
                             "heating function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191
copi:COPI_0000191 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/DesignedFunction> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000003
                                  ] ;
                  rdfs:comment "A gas movement function is a designed function whose realization imparts mechanical energy to a gas to induce or sustain its flow."@en ,
                               "Uma função de movimentação de gás é uma função projetada cuja realização fornece energia mecânica a um gás para induzir ou sustentar seu fluxo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de movimentação de gás"@pt-br ,
                             "gas movement function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192
copi:COPI_0000192 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/DesignedFunction> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000003
                                  ] ;
                  rdfs:comment "A power transmission function is a designed function whose realization transfers mechanical power from a prime mover to a driven load."@en ,
                               "Uma função de transmissão de potência é uma função projetada cuja realização transfere potência mecânica de um motor primário para uma carga acionada."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "função de transmissão de potência"@pt-br ,
                             "power transmission function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193
copi:COPI_0000193 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/DesignedFunction> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000003
                                  ] ;
                  rdfs:comment "An electric-to-mechanical conversion function is a designed function whose realization converts electrical energy into rotational or linear mechanical motion."@en ,
                               "Uma função de conversão elétrico-mecânica é uma função projetada cuja realização converte energia elétrica em movimento mecânico rotacional ou linear."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "electric-to-mechanical conversion function"@en ,
                             "função de conversão elétrica-mecânica"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194
copi:COPI_0000194 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/DesignedFunction> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000006
                                  ] ;
                  rdfs:comment "A filtration function is a designed function whose realization removes particulate or contaminant matter from a fluid by passage through a permeable medium."@en ,
                               "Uma função de filtração é uma função projetada cuja realização remove matéria particulada ou contaminante de um fluido por passagem através de um meio permeável."@pt-br ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "filtration function"@en ,
                             "função de filtração"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195
copi:COPI_0000195 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/DesignedFunction> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000006
                                  ] ;
                  rdfs:comment "A separation function is a designed function whose realization divides a fluid mixture into two or more distinct phases or streams."@en ,
