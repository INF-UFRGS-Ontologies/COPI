###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000051
copi:COPI_0000051 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity> ,
                                  [ rdf:type owl:Restriction ;
