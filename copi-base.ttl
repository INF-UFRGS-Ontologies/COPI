                            rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ;
                            rdfs:label "flow measurement process"@en ,
                                       "processo de medição de fluxo"@pt-br ;
                            annotation:naturalLanguageDefinition "A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction
copi:FlowModificationFunction rdf:type owl:Class ;
                              rdfs:subClassOf copi:COPI_0000026 ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:someValuesFrom copi:FlowModificationProcess
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:allValuesFrom copi:FlowModificationProcess
                                              ] ;
                              rdfs:label "flow modification function"@en ,
                                         "função de modificação de fluxo"@pt-br ;
                              annotation:naturalLanguageDefinition "A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess
copi:FlowModificationProcess rdf:type owl:Class ;
                             rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ;
                             rdfs:label "flow modification process"@en ,
                                        "processo de modificação de fluxo"@pt-br ;
                             annotation:naturalLanguageDefinition "A PlannedProcess in which the characteristics of fluid flow are altered by a flow modification accessory, resulting in changes to flow patterns, velocity profiles, turbulence levels, or pressure drop characteristics while the fluid passes through or around the device."@en .


