#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000015
<http://purl.obolibrary.org/obo/BFO_0000015> rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000019
<http://purl.obolibrary.org/obo/BFO_0000019> rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000040
<http://purl.obolibrary.org/obo/BFO_0000040> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/Assembly
<https://spec.industrialontologies.org/ontology/construct/Assembly> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/DesignedFunction
<https://spec.industrialontologies.org/ontology/construct/DesignedFunction> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/InformationContentEntity
<https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/MaterialArtifact
<https://spec.industrialontologies.org/ontology/construct/MaterialArtifact> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity
<https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/MeasurementProcess
<https://spec.industrialontologies.org/ontology/construct/MeasurementProcess> rdf:type owl:Class .


###  https://spec.industrialontologies.org/ontology/construct/PlannedProcess
<https://spec.industrialontologies.org/ontology/construct/PlannedProcess> rdf:type owl:Class .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001
copi:COPI_0000001 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ;
                  dcterms:source "ODR-009 Amendment A (2026-06-18): copi:Operation as explicit root universal; genus correction to iof-constr:PlannedProcess" ;
                  rdfs:comment "A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation."@en ,
                               "Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "operation"@en ,
                             "operação"@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (Operation(x) → PlannedProcess(x))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation."@en ,
                                                       "Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo."@pt-br ;
                  annotation:primitiveRationale "Root universal for process-industry unit operations in the chemical-engineering tradition (cf. each category's adaptedFrom). Members share a typed participation signature (material inputs/outputs) and differ by transformation effected; no single formal condition differentiates Operation from PlannedProcess in OWL — the differentia is OWL-inexpressible, standard for a BFO primitive. (ODR-009 Amendment A, 2026-06-18)"@en ,
                                                "Universal raiz para operações unitárias de indústria de processo na tradição da engenharia química (cf. adaptedFrom de cada categoria). Os membros compartilham uma assinatura de participação tipada (entradas/saídas materiais) e diferem pela transformação efetuada; nenhuma condição formal única diferencia Operation de PlannedProcess em OWL — a diferença é inexpressível em OWL, padrão para um primitivo BFO. (ODR-009 Emenda A, 2026-06-18)"@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is an 'operation' then x is a 'planned process'"@en ,
                                                            "se x é uma 'operação' então x é um 'processo planejado'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003
copi:COPI_0000003 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "Bird, Stewart & Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part I: momentum transport." ,
                                 "ODR-009" ;
                  rdfs:comment "A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion."@en ,
                               "Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "momentum transfer"@en ,
                             "transferência de quantidade de movimento"@pt-br ;
                  skos:example "Elevar a pressão de um líquido de processo; comprimir um gás; circular uma lama."@pt-br ,
                               "Raising the pressure of a process liquid; compressing a gas; circulating a slurry."@en ;
                  annotation:adaptedFrom "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering (fluid-flow operations)." ;
                  annotation:explanatoryNote "Includes pressure-raising operations on liquids and gases, and bulk transport/mixing. Its leaf operations LiquidPressureIncrease and GasPressureIncrease are disjoint."@en ,
                                             "Inclui operações de aumento de pressão de líquidos e gases, e transporte/mistura globais. Suas operações folha LiquidPressureIncrease e GasPressureIncrease são disjuntas."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (MomentumTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion."@en ,
                                                       "Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global."@pt-br ;
                  annotation:primitiveRationale "A unit-operations class grounded in the McCabe-Smith-Harriott tradition; its members share a typed-participation envelope but no single formally necessary-and-sufficient differentia, so only the envelope is asserted in OWL."@en ,
                                                "Uma classe de operações unitárias fundamentada na tradição de McCabe-Smith-Harriott; seus membros compartilham um envelope de participação tipada mas nenhuma diferença formal necessária-e-suficiente única, de modo que apenas o envelope é asserido em OWL."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'momentum transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de quantidade de movimento' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004
copi:COPI_0000004 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "Bird, Stewart & Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part II: energy transport." ,
                                 "ODR-009" ;
                  rdfs:comment "A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream."@en ,
                               "Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "heat transfer"@en ,
                             "transferência de calor"@pt-br ;
                  skos:example "Aquecimento sensível de uma corrente de processo contra uma utilidade quente."@pt-br ,
                               "Sensible heating of a process stream against a hot utility."@en ;
                  annotation:firstOrderLogicAxiom "∀x (HeatTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream."@en ,
                                                       "Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a constância de fase e de identidade química que distingue a transferência de calor sensível não é capturada em OWL, de modo que apenas o envelope é asserido."@pt-br ,
                                                "Unit-operations class; the constancy of phase and chemical identity that distinguishes sensible heat transfer is not captured in OWL, so only the envelope is asserted."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'heat transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de calor' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005
copi:COPI_0000005 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "Bird, Stewart & Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part III: mass transport." ,
                                 "ODR-009" ;
                  rdfs:comment "A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference."@en ,
                               "Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico)."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "mass transfer"@en ,
                             "transferência de massa"@pt-br ;
                  skos:example "Absorption of a gas component into a liquid solvent; stripping; distillation."@en ,
                               "Absorção de um componente gasoso em um solvente líquido; esgotamento (stripping); destilação."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (MassTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference."@en ,
                                                       "Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico)."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a migração interfásica que individua seus membros é declarada para folhas específicas (e.g. GasAbsorption) mas não no nível da categoria em OWL."@pt-br ,
                                                "Unit-operations class; the inter-phase migration that individuates its members is stated for specific leaves (e.g. GasAbsorption) but not at the category level in OWL."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'mass transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de massa' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006
copi:COPI_0000006 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "ODR-009" ;
                  rdfs:comment "A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction."@en ,
                               "Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "mechanical separation"@en ,
                             "separação mecânica"@pt-br ;
                  skos:example "Separação gravitacional trifásica; separação ciclônica; filtração; centrifugação."@pt-br ,
                               "Three-phase gravity separation; cyclonic separation; filtration; centrifugation."@en ;
                  annotation:firstOrderLogicAxiom "∀x (MechanicalSeparation(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction."@en ,
                                                       "Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a separação de uma alimentação heterogênea por força mecânica não é formalizada em OWL além do envelope."@pt-br ,
                                                "Unit-operations class; the partition of a heterogeneous feed by mechanical force is not formalised in OWL beyond the envelope."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'mechanical separation' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'separação mecânica' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000007
copi:COPI_0000007 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "ODR-009" ;
                  rdfs:comment "A process in which chemical species are consumed and new species, present in no input, are formed."@en ,
                               "Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "chemical reaction"@en ,
                             "reação química"@pt-br ;
                  skos:example "Fermentation of sugars to ethanol; combustion; catalytic conversion."@en ,
                               "Fermentação de açúcares a etanol; combustão; conversão catalítica."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (ChemicalReaction(x) → Process(x) ∧ ∃o,c(hasOutput(x,o) ∧ hasConstituent(o,c) ∧ ¬∃i,c1(hasInput(x,i) ∧ hasConstituent(i,c1) ∧ sameSubstance(c1,c))))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process in which chemical species are consumed and new species, present in no input, are formed."@en ,
                                                       "Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas."@pt-br ;
                  annotation:primitiveRationale "Classe de processo unitário; a formação de uma espécie genuinamente nova é parcialmente caracterizada em FOL mas apenas o gênero é asserido em OWL."@pt-br ,
                                                "Unit-process class; the formation of a genuinely new species is partly characterised in FOL but only the genus is asserted in OWL."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'chemical reaction' then x is a 'process' whose output has a constituent substance that no input has"@en ,
                                                            "se x é uma 'reação química' então x é um 'processo' cuja saída tem uma substância constituinte que nenhuma entrada possui"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008
copi:COPI_0000008 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "ODR-009" ;
                  rdfs:comment "A process that changes the physical state (phase) of a material without changing its chemical identity."@en ,
                               "Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "mudança de fase"@pt-br ,
                             "phase change"@en ;
                  skos:example "Evaporation; condensation; crystallisation."@en ,
                               "Evaporação; condensação; cristalização."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (PhaseChange(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that changes the physical state (phase) of a material without changing its chemical identity."@en ,
                                                       "Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a mudança de fase a identidade química constante é declarada para folhas (e.g. Vaporization) mas não no nível da categoria em OWL."@pt-br ,
                                                "Unit-operations class; the change of phase at constant chemical identity is stated for leaves (e.g. Vaporization) but not at category level in OWL."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'phase change' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'mudança de fase' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009
copi:COPI_0000009 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "ODR-009" ;
                  rdfs:comment "A process that maintains a contained material's state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category."@en ,
                               "Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação)."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "contenção de material"@pt-br ,
                             "material containment"@en ;
                  skos:example "Armazenar petróleo cru em um tanque; amortecer líquido em um tambor de surto."@pt-br ,
                               "Holding crude in a storage tank; buffering liquid in a surge drum."@en ;
                  annotation:firstOrderLogicAxiom "∀x (MaterialContainment(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that maintains a contained material's state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category."@en ,
                                                       "Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação)."@pt-br ;
                  annotation:primitiveRationale "Auxiliary category retained because all plant equipment must be classifiable; the input=output identity is the limiting characterisation, not a transformation."@en ,
                                                "Categoria auxiliar mantida porque todo equipamento de planta deve ser classificável; a identidade entrada=saída é a caracterização-limite, não uma transformação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'material containment' then x is a 'process' that 'has input' and 'has output' the same 'material entity'"@en ,
                                                            "se x é uma 'contenção de material' então x é um 'processo' que 'tem entrada' e 'tem saída' a mesma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010
copi:COPI_0000010 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  dcterms:source "ODR-009" ;
                  rdfs:comment "A process that modulates a flow without changing the material's substance, phase, or composition."@en ,
                               "Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "controle de fluxo"@pt-br ,
                             "flow control"@en ;
                  skos:example "Estrangular uma corrente por uma válvula de controle; isolar por uma válvula de bloqueio; aliviar sobrepressão."@pt-br ,
                               "Throttling a stream through a control valve; isolating via a shutoff valve; relieving overpressure."@en ;
                  annotation:firstOrderLogicAxiom "∀x (FlowControl(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that modulates a flow without changing the material's substance, phase, or composition."@en ,
                                                       "Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material."@pt-br ;
                  annotation:primitiveRationale "Auxiliary category; the conservation of substance/phase/composition under modulation is the characterisation and is not a material transformation."@en ,
                                                "Categoria auxiliar; a conservação de substância/fase/composição sob modulação é a caracterização e não é uma transformação material."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'flow control' then x is a 'process' that conserves the substance, phase and composition of its material participant"@en ,
                                                            "se x é um 'controle de fluxo' então x é um 'processo' que conserva a substância, a fase e a composição de seu participante material"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000011
copi:COPI_0000011 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000003 ;
                  owl:disjointWith copi:COPI_0000012 ;
                  dcterms:source "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, pumping)." ,
                                 "ODR-011" ;
                  rdfs:comment "A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid's pressure."@en ,
                               "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "aumento de pressão de líquido"@pt-br ,
                             "liquid pressure increase"@en ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfLiquid> ;
                  annotation:firstOrderLogicDefinition "∀x (LiquidPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Liquid(m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid's pressure."@en ,
                                                       "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido."@pt-br ;
                  annotation:primitiveRationale "OWL 2 DL cannot express the phase constraint on the fluid input; the OWL form asserts only the genus (MomentumTransfer). The disjointness with GasPressureIncrease is asserted to carry the pump/compressor partition."@en ,
                                                "OWL 2 DL não consegue expressar a restrição de fase sobre a entrada fluida; a forma OWL assere apenas o gênero (MomentumTransfer). A disjunção com GasPressureIncrease é asserida para sustentar a partição bomba/compressor."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'liquid pressure increase' if and only if x is a 'momentum transfer' whose fluid input is a 'liquid'"@en ,
                                                                 "x é um 'aumento de pressão de líquido' se e somente se x é uma 'transferência de quantidade de movimento' cuja entrada fluida é um 'líquido'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012
copi:COPI_0000012 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000003 ;
                  dcterms:source "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, compression)." ,
                                 "ODR-011" ;
                  rdfs:comment "A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas's pressure."@en ,
                               "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "aumento de pressão de gás"@pt-br ,
                             "gas pressure increase"@en ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfGas> ;
                  annotation:firstOrderLogicDefinition "∀x (GasPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃g(Gas(g) ∧ hasInput(x,g)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Gas(m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas's pressure."@en ,
                                                       "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás."@pt-br ;
                  annotation:primitiveRationale "As for LiquidPressureIncrease: the phase constraint is not expressible in OWL 2 DL; only the genus is asserted."@en ,
                                                "Como em LiquidPressureIncrease: a restrição de fase não é expressável em OWL 2 DL; apenas o gênero é asserido."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'gas pressure increase' if and only if x is a 'momentum transfer' whose fluid input is a 'gas'"@en ,
                                                                 "x é um 'aumento de pressão de gás' se e somente se x é uma 'transferência de quantidade de movimento' cuja entrada fluida é um 'gás'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000013
copi:COPI_0000013 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000005 ;
                  dcterms:source "Green & Southard (eds.), Perry's Chemical Engineers' Handbook, 9th ed. §14 (absorption and stripping)." ,
                                 "ODR-011" ;
                  rdfs:comment "A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid."@en ,
                               "Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "absorção de gás"@pt-br ,
                             "gas absorption"@en ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Absorption> ;
                  annotation:adaptedFrom "Treybal, Mass-Transfer Operations." ;
                  annotation:firstOrderLogicDefinition "∀p (GasAbsorption(p) ↔ MassTransfer(p) ∧ ∃g,l,l2,c(hasInput(p,g) ∧ Gas(g) ∧ hasInput(p,l) ∧ Liquid(l) ∧ hasOutput(p,l2) ∧ Liquid(l2) ∧ derivesFrom(l2,l) ∧ hasConstituent(g,c) ∧ ¬∃c1(hasConstituent(l,c1) ∧ sameSubstance(c1,c)) ∧ ∃c2(hasConstituent(l2,c2) ∧ sameSubstance(c2,c))))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid."@en ,
                                                       "Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída."@pt-br ;
                  annotation:primitiveRationale "Although a full first-order definition is available, OWL 2 DL carries only the typed-participation envelope; the relational differentia (a constituent migrating gas->liquid) is FOL-only."@en ,
                                                "Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o envelope de participação tipada; a diferença relacional (um constituinte migrando gás->líquido) é apenas-FOL."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'gas absorption' if and only if x is a 'mass transfer' in which a substance carried by the input gas, absent from the input solvent, is a constituent of the output liquid"@en ,
                                                                 "x é uma 'absorção de gás' se e somente se x é uma 'transferência de massa' na qual uma substância transportada pelo gás de entrada, ausente do solvente de entrada, é constituinte do líquido de saída"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000014
copi:COPI_0000014 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000008 ;
                  dcterms:source "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. §16 (evaporation)." ,
                                 "ODR-011" ;
                  rdfs:comment "A phase-change operation in which a liquid input is converted to a vapour output."@en ,
                               "Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "vaporization"@en ,
                             "vaporização"@pt-br ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Vaporization> ;
                  annotation:firstOrderLogicDefinition "∀x (Vaporization(x) ↔ PhaseChange(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∃v(Vapour(v) ∧ hasOutput(x,v) ∧ derivesFrom(v,l)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A phase-change operation in which a liquid input is converted to a vapour output."@en ,
                                                       "Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor."@pt-br ;
                  annotation:primitiveRationale "OWL 2 DL carrega apenas o gênero (PhaseChange); a derivação líquido-para-vapor é apenas-FOL."@pt-br ,
                                                "OWL 2 DL carries only the genus (PhaseChange); the liquid-to-vapour derivation is FOL-only."@en ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'vaporization' if and only if x is a 'phase change' whose liquid input gives rise to a vapour output"@en ,
                                                                 "x é uma 'vaporização' se e somente se x é uma 'mudança de fase' cuja entrada líquida dá origem a uma saída de vapor"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000015
copi:COPI_0000015 rdf:type owl:Class ;
                  rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                  dcterms:source "ODR-009" ;
                  rdfs:comment "A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess."@en ,
                               "Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "loss of containment"@en ,
                             "perda de contenção"@pt-br ;
                  annotation:explanatoryNote "Relevant to HAZOP and failure-propagation work built over COPI."@en ,
                                             "Relevante para trabalhos de HAZOP e propagação de falhas construídos sobre o COPI."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (LossOfContainment(x) → Process(x) ∧ ¬PlannedProcess(x))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess."@en ,
                                                       "Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess."@pt-br ;
                  annotation:primitiveRationale "Included to make the bfo:Process rooting concrete: the same boundary-failure kind is failure-relevant (ISO 14224) and cannot be a PlannedProcess; a planned-only hierarchy would exclude it."@en ,
                                                "Incluída para tornar concreta a ancoragem em bfo:Process: o mesmo tipo de falha de barreira é relevante para falhas (ISO 14224) e não pode ser um PlannedProcess; uma hierarquia só-planejada o excluiria."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'loss of containment' then x is a 'process' and x is not a 'planned process'"@en ,
                                                            "se x é uma 'perda de contenção' então x é um 'processo' e x não é um 'processo planejado'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000016
copi:COPI_0000016 rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/DesignedFunction>
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                           owl:someValuesFrom copi:COPI_0000003
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/DesignedFunction>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                owl:someValuesFrom copi:COPI_0000003
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                  ] ;
                  dcterms:source "ODR-011" ,
                                 "ODR-012" ;
                  rdfs:comment "A material artifact that bears a designed function realized in a momentum-transfer operation."@en ,
                               "Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "dispositivo de transferência de quantidade de movimento"@pt-br ,
                             "momentum-transfer device"@en ;
                  skos:example "bomba, compressor, ventilador, tubo, misturador"@pt-br ,
                               "pump, compressor, fan, pipe, mixer"@en ;
                  annotation:adaptedFrom "Unit-operations tradition (McCabe-Smith-Harriott); cross-checked against IEC 81346-2 codes G, M, W and ISO 14224 Annex A." ;
                  annotation:explanatoryNote "A dispersive (defined) category; a leaf declaring only its designed function is automatically classified here by the reasoner. Not asserted disjoint from the other equipment categories (selective partition)."@en ,
                                             "Uma categoria dispersiva (definida); uma folha que declara apenas sua função projetada é classificada aqui automaticamente pelo reasoner. Não asserida disjunta das demais categorias de equipamento (partição seletiva)."@pt-br ;
                  annotation:firstOrderLogicDefinition "∀x (MomentumTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MomentumTransfer(p) ∧ realizedIn(f,p))))" ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a momentum-transfer operation."@en ,
                                                       "Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'momentum-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'momentum transfer'"@en ,
                                                                 "x é um 'dispositivo de transferência de quantidade de movimento' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de quantidade de movimento'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017
copi:COPI_0000017 rdf:type owl:Class ;
                  owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/DesignedFunction>
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                           owl:someValuesFrom copi:COPI_0000004
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact> ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/DesignedFunction>
                                                                              [ rdf:type owl:Restriction ;
                                                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                owl:someValuesFrom copi:COPI_0000004
                                                                              ]
                                                                            ) ;
                                                         rdf:type owl:Class
                                                       ]
                                  ] ;
                  dcterms:source "ODR-011" ,
                                 "ODR-012" ;
                  rdfs:comment "A material artifact that bears a designed function realized in a heat-transfer operation."@en ,
                               "Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "dispositivo de transferência de calor"@pt-br ,
                             "heat-transfer device"@en ;
                  skos:example "shell-and-tube exchanger, fired heater, reboiler"@en ,
                               "trocador casco-e-tubo, aquecedor a fogo direto, refervedor"@pt-br ;
                  annotation:adaptedFrom "Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 codes E, V." ;
                  annotation:explanatoryNote "Categoria definida; um artefato que porta uma função secundária (e.g. um refervedor que também vaporiza) adquire pertinências adicionais de categoria -- intencional, não um defeito."@pt-br ,
                                             "Defined category; an artifact bearing a secondary function (e.g. a reboiler that also vaporizes) acquires additional category memberships -- intended, not a defect."@en ;
                  annotation:firstOrderLogicDefinition "∀x (HeatTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(HeatTransfer(p) ∧ realizedIn(f,p))))" ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a heat-transfer operation."@en ,
                                                       "Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'heat-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'heat transfer'"@en ,
                                                                 "x é um 'dispositivo de transferência de calor' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de calor'"@pt-br .


