                                      ] ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CleanFluidOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FluidInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasSeparationChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DegassingFunction
                                  ] ;
                  rdfs:label "degaseificador"@pt-br ,
                             "degasser"@en ;
                  skos:definition "[CFIHOS] A device that removes air or gases (methane, H2S, CO2 and others) from drilling liquids."@en ,
                                  "[ISO 15926-4] A <DEGASSER> is an <ARTEFACT> and a  <FLASH SEPARATOR> that is a device used in drilling to remove gasses from drilling fluid which could otherwise form bubbles"@en ,
                                  "[OnePetro] Any device that helps remove gas from circulated fluid."@en ,
                                  "[SLB Glossary] A device that removes air or gases (methane, H2S, CO2, and others) from drilling liquids."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Degasser(x) ↔ (Separator(x) ∧ ∃f (DegassingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A degasser is a separator that removes gases from drilling fluids by realizing a degassing function."@en ,
                                                       "Um degaseificador é um separador que remove gases de fluidos de perfuração realizando uma função de degaseificação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every degasser is a separator that bears a degassing function and has drilling fluid as input and degassed drilling fluid plus separated gases as outputs."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242
