###  https://www.inf.ufrgs.br/ontologies/copi/PowerConditioningCircuit
copi:PowerConditioningCircuit rdf:type owl:Class ;
                              rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact> ;
                              rdfs:label "circuito de potência de condicionamento"@pt-br ,
