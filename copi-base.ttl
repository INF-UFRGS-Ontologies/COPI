###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049
copi:COPI_0000049 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity> ,
