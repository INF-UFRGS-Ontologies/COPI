                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes."@en ,
                                                       "Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento."@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159
