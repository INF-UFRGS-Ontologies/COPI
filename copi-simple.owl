        <rdfs:label>counter example</rdfs:label>
        <skos:definition>example that refutes or disproves a concept in some scenario and is intended to demonstrate how the concept might be misused</skos:definition>
        <annotation:usageNote>Use of this annotation is optional, but recommended if it will help a user understand the intended interpretation(s).
- This annotation should use at most twice with/on a notion.
- Additional examples or more elaborate examples should be placed in the External Documentation (using rdfs:seeAlso).</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/directSource -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/directSource">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">direct source</rdfs:label>
        <skos:definition xml:lang="en-us">definitive source of the subject resource</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/source"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/elucidation -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/elucidation">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">elucidation</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
        <skos:example xml:lang="en-us">&apos;Agent&apos; is a subclass of the BFO class &apos;material entity&apos;, which in turn is a subclass of the BFO class &apos;independent continuant&apos;, which in turn is a subclass of the BFO class &apos;continuant&apos;. So the position of &apos;Agent&apos; is &apos;material entity ← independent continuant ← continuant&apos;.</skos:example>
        <annotation:usageNote xml:lang="en-us">This annotation is no longer used. The isPrimitive annotation is now set to true to indicate a primitive class when necessary and sufficient conditions can not be provided.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/excerptedFrom -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/excerptedFrom">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">excerpted from</rdfs:label>
        <skos:definition>source of a resource that was imported unmodified from an external ontology</skos:definition>
        <annotation:usageNote xml:lang="en-us">This annotation is to be used when an element from a non-IOF ontology is used in an IOF ontology (and the source ontology is not imported in its entirety).</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/source"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/explanatoryNote -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/explanatoryNote">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">explanatory note</rdfs:label>
        <skos:definition xml:lang="en-us">note that provides additional explanatory information about a given notion or resource</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicAxiom -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicAxiom">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">first-order logic axiom</rdfs:label>
        <skos:definition xml:lang="en-us">logic axiom annotation written in first order logic</skos:definition>
        <annotation:usageNote xml:lang="en-us">First-order logic axioms MAY be provided if the term is primitive (&apos;is primitive&apos; is true ) or non-primitive. A construct MAY include more than one first-order logic axiom annotation.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/annotation/logicAxiom"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicDefinition -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicDefinition">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">first order logic definition</rdfs:label>
        <skos:definition>logic definition that expresses the axioms of a class or an object property in first order logic</skos:definition>
        <skos:example xml:lang="en-us">An example of a First Order Logic definition for &apos;Product&apos; might be (again bearing in mind the natural language terms appearing should be regarded as symbols in the IOF signature):
 - Continuant(x) ∧ ¬(SpecificallyDependentContinuant(x) ∨ Person(x) ∨ Organization(x)) ∧ ∃r (ProductRole(r) ∧ hasRole(x, r))</skos:example>
        <annotation:usageNote xml:lang="en-us">The First Order Logic Definition annotation is comprised of the (complete) necessary and sufficient conditions.
 - This annotation is Required for each non-primitive (aka non-axiomatic) class (i.e. unary relation) of a published IOF OWL ontology. This is the most authoritative and comprehensive definition of an IOF element. 
 - IOF Common Logic ontologies do not require this annotation, but if included it must be logically equivalent to the Common Logic definition.
 - A primitive (aka axiomatic) term will not have a First Order Logic definition in either an OWL or Common Logic IOF ontology.
 - There should be at most one First Order Logic definition.
 - The specific symbols to be used for existential and universal quantification along with those for conjunction, disjunction, negation, conditional (i.e. if-then), and equivalence will be those commonly used in the mathematical formulas and statement.
 - Conjunction - ∧; Disjunction - ∨; Negation - ¬; Existential Quantification - ∃; Universal Quantification - ∀; Conditional - →; Equivalence - ↔; Left/Right Parentheses - (,); Left/Right Brackets - {,}.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/annotation/logicDefinition"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/isPrimitive -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/isPrimitive">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is primitive</rdfs:label>
        <skos:definition xml:lang="en-us">boolean flag indicating that necessary and sufficient conditions are not provided</skos:definition>
        <annotation:usageNote xml:lang="en-us">&apos;is primitive&apos; must be present if the term does not have necessary and sufficient conditions and the value of the annotation must be set to true. When &apos;is primitive&apos; is set to true, a value for a &apos;primitive rationale&apos; annotation must also be provided.</annotation:usageNote>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/logicAxiom -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/logicAxiom">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">logic axiom</rdfs:label>
        <skos:definition xml:lang="en-us">logical statements constraining the interpretation of the notion represented by the construct that do not provide necessary and sufficient conditions</skos:definition>
        <annotation:explanatoryNote xml:lang="en-us">This annotation property is an abstraction of the more specialized logic axiom annotations used in IOF. However, this annotation property can also be used to group together the logic axiom annotation values of different forms (such as FOL and natural language) that express the same meaning for a particular construct.</annotation:explanatoryNote>
        <annotation:usageNote xml:lang="en-us">A first order logic axiom expression and a semi-formal natural language axiom expression should be added as Property values for each logic axiom annotation using 1 of each of the corresponding logic axiom annotation subproperties.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/logicDefinition -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/logicDefinition">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">logic definition</rdfs:label>
        <skos:definition xml:lang="en-us">definition in the form of a logical expression</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/maintainer -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/maintainer">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">maintainer</rdfs:label>
        <skos:definition>entity responsible for maintaining the resource</skos:definition>
        <annotation:usageNote xml:lang="en-us">This annotation applies to an entire IOF ontology (i.e. the file) and not to individual elements.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/contributor"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/maturity -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/maturity">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">maturity</rdfs:label>
        <skos:definition xml:lang="en-us">annotation property used to indicate the development status of a resource</skos:definition>
        <annotation:usageNote xml:lang="en-us">Any value for maturity MUST be an instance of MaturityLevel. All IOF ontologies MUST include exactly one maturity annotation. IOF constructs may include a maturity annotation.</annotation:usageNote>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">natural language definition</rdfs:label>
        <skos:definition xml:lang="en-us">definition written in plain text for human understanding</skos:definition>
        <annotation:usageNote xml:lang="en-us">This annotation is Required for each non-primitive or non-axiomatic class of an IOF (OWL or Common Logic) ontology. 
 - It is optional for primitive (aka axiomatic) classes since such the Elucidation annotation is required and will satisfy the role of a natural language definition.
 - It is optional, but recommended, for relations when the intent of a relation may be misunderstood.
 - There should be at most one.
 - This natural language definition should be subject matter expert friendly and consistent with any formal definition or elucidation.
 - Natural language definitions should use class and relation names with following caveats:
 a) Relations – For those relations whose label (i.e. local identifier) consist of multiple terms hyphenate the terms of the label: e.g. &apos;hasPlan&apos; would be written as &apos;has-plan&apos;
 b) Classes – For classes whose label has multiple distinct terms, e.g, ManufacturingOperationSpecification, separate the terms but bound them with apostrophe marks: &apos;Manufacturing Operation Specification&apos;.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/primitiveRationale -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/primitiveRationale">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">primitive rationale</rdfs:label>
        <skos:definition xml:lang="en-us">reason why necessary and sufficient conditions could not be provided</skos:definition>
        <annotation:usageNote xml:lang="en-us">When &apos;is primitive&apos; is set to true, a value for &apos;primitive rationale&apos; must be provided. The rationale should indicate what is missing if additional work is required to define necessary and sufficient conditions.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/replacedBy -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/replacedBy">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">replaced by</rdfs:label>
        <skos:definition xml:lang="en-us">reference to the IRI of the target of a deprecated construct</skos:definition>
        <annotation:usageNote xml:lang="en-us">The value of an iof-av:replacedBy annotation must be the IRI which replaces the target construct.</annotation:usageNote>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageAxiom -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageAxiom">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">semi-formal natural language axiom</rdfs:label>
        <skos:definition xml:lang="en-us">logic axiom expressed in natural language</skos:definition>
        <annotation:usageNote xml:lang="en-us">Semi-formal natural language axioms MAY be provided if the term is primitive (is primitive is true). A construct MAY include more than one semi-formal natural language axiom annotation.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/annotation/logicAxiom"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageDefinition -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageDefinition">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">semi-formal natural language definition</rdfs:label>
        <skos:definition>logic definition that expresses a first order logic definition or common logic definition in natural language</skos:definition>
        <annotation:usageNote xml:lang="en-us">This annotation is required if an element in an IOF OWL ontology has a First Order Logic definition or in a IOF Common Logic (where the element is defined using Common Logic).
 - The intent of this annotation to provide a transition or bridge from the First Order Logic definition of a notion to the natural language definition. This definition is intended to help a user understand the intended interpretation of the notion.
 - As example using the First Order Logic definition of &apos;Product&apos; above, a semi-formal translation of that might be: 
 - Product =def. Continuant that is not a Person and not an Organization and not a Specifically Dependent Continuant and there is a Product Role that the thing has or bears.</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/annotation/logicDefinition"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/subjectMatterExpertExplanation -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/subjectMatterExpertExplanation">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label>subject matter expert explanation</rdfs:label>
        <skos:definition>definition of the term expressed in natural language that has the minimal usage of ontological terms and is intended to be a self-standing explanation</skos:definition>
        <annotation:usageNote>Usage of this annotation is optional but is recommended in cases where:
- the natural language definition or elucidation rely heavily on the terms defined in the ontology
- there exists an explanation of the term that is more familiar to SMEs that does not coincide with the definition present in the ontology</annotation:usageNote>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#definition"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/symbol -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/symbol">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">symbol</rdfs:label>
        <skos:definition xml:lang="en-us">abbreviation that is a design, mark, or charaters(s) used conventionally to represent something, such as currency, quantity, or variable in an expression</skos:definition>
        <skos:example xml:lang="en-us">Chemical Symbols: H, O, Mg
Units of Measure: Km, Kg, G</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/</annotation:adaptedFrom>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/annotation/abbreviation"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/synonym -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/synonym">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">synonym</rdfs:label>
        <skos:definition xml:lang="en-us">alternative label (designation) used for the resource in some community</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#altLabel"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/usageNote -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/usageNote">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">usage note</rdfs:label>
        <skos:definition xml:lang="en-us">note that provides information about how a given notion or resource is used in the ontology&apos;s context</skos:definition>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2004/02/skos/core#note"/>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/wasDefinedBy -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/wasDefinedBy">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">was defined by</rdfs:label>
        <skos:definition xml:lang="en-us">identifies the occurrence time and former location for a construct, annotation, or individual</skos:definition>
        <annotation:usageNote>This annotation MUST have two sub-annotations iof-av:wasMovedFrom and iof-av:wasMovedOn</annotation:usageNote>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/wasMovedFrom -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/wasMovedFrom">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">was moved from</rdfs:label>
        <skos:definition xml:lang="en-us">part of a iof-av:wasDefinedBy annotation indicating the previous ontology a construct, annotation, or individual was located</skos:definition>
        <annotation:usageNote>This annotation MUST be a sub-annotation of iof-av:wasDefinedBy</annotation:usageNote>
    </owl:AnnotationProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/annotation/wasMovedOn -->

    <owl:AnnotationProperty rdf:about="https://spec.industrialontologies.org/ontology/annotation/wasMovedOn">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">was moved on</rdfs:label>
        <skos:definition xml:lang="en-us">part of a iof-av:wasDefinedBy annotation indicating the date and time a  construct, annotation, or individual’s location was changed</skos:definition>
        <annotation:usageNote>This annotation MUST be a sub-annotation of iof-av:wasDefinedBy</annotation:usageNote>
    </owl:AnnotationProperty>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000061 -->

    <owl:AnnotationProperty rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000061">
        <rdfs:comment xml:lang="en">Reference to an ISO 15926 term IRI.</rdfs:comment>
        <rdfs:label xml:lang="en">iso15926Reference</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000062 -->

    <owl:AnnotationProperty rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000062">
        <rdfs:comment xml:lang="en">Reference to an ISO 14224 equipment taxonomy entry.</rdfs:comment>
        <rdfs:label xml:lang="en">iso14224Reference</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000063 -->

    <owl:AnnotationProperty rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000063">
        <rdfs:comment xml:lang="en">Reference to a CFIHOS (Capital Facilities Information Handover Specification) term.</rdfs:comment>
        <rdfs:label xml:lang="en">cfihosReference</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000064 -->

    <owl:AnnotationProperty rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000064">
        <rdfs:comment xml:lang="en">Reference to a DEXPI (Data Exchange in the Process Industry) prototype element.</rdfs:comment>
        <rdfs:label xml:lang="en">dexpiReference</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000065 -->

    <owl:AnnotationProperty rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000065">
        <rdfs:comment xml:lang="en">Reference to a POSC Caesar RDL IRI.</rdfs:comment>
        <rdfs:label xml:lang="en">poscCaesarReference</rdfs:label>
    </owl:AnnotationProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.obolibrary.org/obo/BFO_0000054 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000054">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
        <dc:identifier>206-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has realization</rdfs:label>
        <skos:altLabel xml:lang="en">realized in</skos:altLabel>
        <skos:definition xml:lang="en">b has realization c =Def c realizes b</skos:definition>
        <skos:example xml:lang="en">As for realizes</skos:example>
        <annotation:synonym xml:lang="en-us">realized in</annotation:synonym>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000055 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000055">
        <dc:identifier>059-BFO</dc:identifier>
        <rdfs:label xml:lang="en">realizes</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) realizes is a relation between a process b and realizable entity c such that c inheres in some d &amp; for all t, if b has participant d then c exists &amp; the type instantiated by b is correlated with the type instantiated by c</skos:definition>
        <skos:example xml:lang="en">A balding process realizes a disposition to go bald; a studying process realizes a student role; a process of pumping blood realizes the pumping function of a heart</skos:example>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000056 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000056">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
        <dc:identifier>250-BFO</dc:identifier>
        <rdfs:label xml:lang="en">participates in</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) participates in holds between some b that is either a specifically dependent continuant or generically dependent continuant or independent continuant that is not a spatial region &amp; some process p such that b participates in p some way</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000057 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000057">
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000117"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000057"/>
        </owl:propertyChainAxiom>
        <dc:identifier>248-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has participant</rdfs:label>
        <skos:definition xml:lang="en">p has participant c =Def c participates in p</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
        <annotation:explanatoryNote>the IOF has decided to include transitive participation as an additional axiom of &apos;has participant at some time&apos; which is reflected in the property chain associated with this property. That is, if A has an &apos;occurent part&apos; B which &apos;has participant at some time&apos; C then A &apos;has participant at some time&apos; C.</annotation:explanatoryNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000058 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000058">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000059"/>
        <dc:identifier>258-BFO</dc:identifier>
        <rdfs:label xml:lang="en">is concretized by</rdfs:label>
        <skos:definition xml:lang="en">c is concretized by b =Def b concretizes c</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000059 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000059">
        <dc:identifier>256-BFO</dc:identifier>
        <rdfs:label xml:lang="en">concretizes</rdfs:label>
        <skos:definition xml:lang="en">b concretizes c =Def b is a process or a specifically dependent continuant &amp; c is a generically dependent continuant &amp; there is some time t such that c is the pattern or content which b shares at t with actual or potential copies</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000062 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000062">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000063"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <dc:identifier>213-BFO</dc:identifier>
        <rdfs:label xml:lang="en">preceded by</rdfs:label>
        <skos:definition xml:lang="en">b preceded by c =Def b precedes c</skos:definition>
        <skos:example xml:lang="en">The temporal region occupied by the second half of the match is preceded by the temporal region occupied by the first half of the match</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000063 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000063">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <dc:identifier>270-BFO</dc:identifier>
        <rdfs:label xml:lang="en">precedes</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) precedes is a relation between occurrents o, o&apos; such that if t is the temporal extent of o &amp; t&apos; is the temporal extent of o&apos; then either the last instant of o is before the first instant of o&apos; or the last instant of o is the first instant of o&apos; &amp; neither o nor o&apos; are temporal instants</skos:definition>
        <skos:example xml:lang="en">The temporal region occupied by Mary&apos;s birth precedes the temporal region occupied by Mary&apos;s death.</skos:example>
        <skos:scopeNote>Each temporal region is its own temporal extent. The temporal extent of a spatiotemporal region is the temporal region it temporally projects onto. The temporal extent of a process or process boundary that occupies temporal region t is t.</skos:scopeNote>
        <skos:scopeNote>Precedes defines a strict partial order on occurrents.</skos:scopeNote>
        <annotation:explanatoryNote xml:lang="en-us">while the scope of BFO: precedes is occurrent, for the purposes of formalization of Allen interval algebra we have added the FOL elaborations for &apos;time instant&apos; &apos;time interval&apos;, &apos;process boundary&apos; and &apos;process&apos;. For the case of other occurrents the formalization already provided by BFO (https://github.com/BFO-ontology/BFO-2020/tree/master/21838-2/pdf) should be followed.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>LA1: precedes(i,j) ∧ process(i) ∧ process(j) → ∃i1∃j1 (TemporalInterval(i1)∧TemporalInterval(j1)∧occupiesTemporalRegion(i,i1)∧occupiesTemporalRegion(j,j1) ∧ precedes(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: precedes(i,j) ∧ ProcessBoundary(i) ∧ ProcessBoundary(j) → ∃i1∃j1 (TemporalInstant(i1)∧TemporalInstant(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ precedes(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: precedes(i,j) ∧TemporalInstant(i) ∧TemporalInterval(j) → ∃j1(hasFirstInstant(j,j1)∧ precedes(i,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA4: precedes(i,j) ∧ TemporalInterval(i) ∧ TemporalInstant(j) → ∃i1(hasLastInstant(i,i1) ∧ precedes(i1,j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA5: precedes (i,j) ∧TemporalInstant (i) ∧ TemporalInstant(j) → ∃k∃l(hasValueExpressionAtAllTimes(i,k) ∧ hasValueExpressionAtAllTimes(j,l) ∧ ∃v1∃v2(hasDateTimeInstantValue(k,v1) ∧ hasDateTimeInstantValue(l,v2) ∧ (v1 &lt; v2)))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA6: precedes(i,j) ∧ TemporalInterval(i) ∧ TemporalInterval(j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ hasLastInstant(i,i1) ∧ hasFirstInstant(j,j1) ∧ (precedes(i1,j1) ∨ occursSimultaneouslyWith(i1,j1)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">comes before (something) in time</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If i and j are both ‘process’ and i &apos;precedes&apos; j then the ‘temporal instant’ that i occupies &apos;precedes&apos; ‘temporal instant’ that j occupies</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If i and j are both ‘process boundary’ and i &apos;precedes&apos; j then the ‘temporal instant’ that i occupies &apos;precedes&apos; ‘temporal instant’ that j occupies</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: if i is ‘temporal instant’ and j is ‘temporal interval’ and i &apos;precedes&apos; j then i &apos;precedes&apos; the &apos;first instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA4: if i is ‘temporal interval’ and j is ‘temporal instant’ and i &apos;precedes&apos; j then the &apos;last instant of&apos; i &apos;precedes&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA5: If i and j are both ‘temporal instant’ and i &apos;precedes&apos; j then the &apos;temporal instant value expression&apos; of i is less than the &apos;temporal instant value expression&apos; of j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA6: If both i and j are &apos;temporal intervals&apos; and i is &apos;precedes&apos; j then the &apos;last instant of&apos; i &apos;precedes&apos; the &apos;first instant of&apos; j or the &apos;last instant of&apos; i &apos;occurs simultaneously with&apos; the &apos;first instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000066 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000066">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000183"/>
        <dc:identifier>143-BFO</dc:identifier>
        <rdfs:label xml:lang="en">occurs in</rdfs:label>
        <skos:definition xml:lang="en">b occurs in c =Def b is a process or a process boundary &amp; c is a material entity or site &amp; there exists a spatiotemporal region r &amp; b occupies spatiotemporal region r &amp; for all time t, if b exists at t then c exists at t &amp; there exist spatial regions s and s&apos; where b spatially projects onto s at t &amp; c occupies spatial region s&apos; at t &amp; s is a continuant part of s&apos; at t</skos:definition>
        <skos:example xml:lang="en">A process of digestion occurs in the interior of an organism; a process of loading artillery rounds into a tank cannon occurs in the interior of the tank</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000082 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000082"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000084 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000084">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000101"/>
        <dc:identifier>252-BFO</dc:identifier>
        <rdfs:label xml:lang="en">generically depends on</rdfs:label>
        <skos:altLabel xml:lang="en">g-depends on</skos:altLabel>
        <skos:definition xml:lang="en">b generically depends on c =Def b is a generically dependent continuant &amp; c is an independent continuant that is not a spatial region &amp; at some time t there inheres in c a specifically dependent continuant which concretizes b at t</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000101 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000101">
        <dc:identifier>254-BFO</dc:identifier>
        <rdfs:label xml:lang="en">is carrier of</rdfs:label>
        <skos:definition xml:lang="en">b is carrier of c =Def there is some time t such that c generically depends on b at t</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000108 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000108">
        <dc:identifier>118-BFO</dc:identifier>
        <rdfs:label xml:lang="en">exists at</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) exists at is a relation between a particular and some temporal region at which the particular exists</skos:definition>
        <skos:example xml:lang="en">First World War exists at 1914-1916; Mexico exists at January 1, 2000</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000110 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000110"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000111 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000111"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000115 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000115">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000129"/>
        <dc:identifier>230-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has member part</rdfs:label>
        <skos:definition xml:lang="en">b has member part c =Def c member part of b</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000117 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000117">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <dc:identifier>202-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has occurrent part</rdfs:label>
        <skos:definition xml:lang="en">b has occurrent part c =Def c occurrent part of b</skos:definition>
        <skos:example xml:lang="en">Mary&apos;s life has occurrent part Mary&apos;s 5th birthday</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000118 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000118"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000121 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000121">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000117"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000139"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <dc:identifier>211-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has temporal part</rdfs:label>
        <skos:definition xml:lang="en">b has temporal part c =Def c temporal part of b</skos:definition>
        <skos:example xml:lang="en">Your life has temporal part the first year of your life</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000124 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000124">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000171"/>
        <dc:identifier>236-BFO</dc:identifier>
        <rdfs:label xml:lang="en">location of</rdfs:label>
        <skos:definition xml:lang="en">b location of c =Def c located in b</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000127 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000127">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000218"/>
        <dc:identifier>244-BFO</dc:identifier>
        <rdfs:label xml:lang="en">material basis of</rdfs:label>
        <skos:definition xml:lang="en">b material basis of c =Def c has material basis b</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000129 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000129">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000176"/>
        <dc:identifier>228-BFO</dc:identifier>
        <rdfs:label xml:lang="en">member part of</rdfs:label>
        <skos:definition xml:lang="en">b member part of c =Def b is an object &amp; c is a material entity &amp; there is some time t such that b continuant part of c at t &amp; there is a mutually exhaustive and pairwise disjoint partition of c into objects x1, ..., xn (for some n ≠ 1) with b = xi (for some 1 &lt;= i &lt;= n)</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000132 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000132">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <dc:identifier>003-BFO</dc:identifier>
        <rdfs:label xml:lang="en">occurrent part of</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) occurrent part of is a relation between occurrents b and c when b is part of c</skos:definition>
        <skos:example xml:lang="en">Mary&apos;s 5th birthday is an occurrent part of Mary&apos;s life; the first set of the tennis match is an occurrent part of the tennis match</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000137 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000137"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000138 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000138"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000139 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000139">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000132"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <dc:identifier>078-BFO</dc:identifier>
        <rdfs:label xml:lang="en">temporal part of</rdfs:label>
        <skos:definition xml:lang="en">b temporal part of c =Def b occurrent part of c &amp; (b and c are temporal regions) or (b and c are spatiotemporal regions &amp; b temporally projects onto an occurrent part of the temporal region that c temporally projects onto) or (b and c are processes or process boundaries &amp; b occupies a temporal region that is an occurrent part of the temporal region that c occupies)</skos:definition>
        <skos:example xml:lang="en">Your heart beating from 4pm to 5pm today is a temporal part of the process of your heart beating; the 4th year of your life is a temporal part of your life, as is the process boundary which separates the 3rd and 4th years of your life; the first quarter of a game of football is a temporal part of the whole game</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000153 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000153">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <dc:identifier>080-BFO</dc:identifier>
        <rdfs:label xml:lang="en">temporally projects onto</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) temporally projects onto is a relation between a spatiotemporal region s and some temporal region which is the temporal extent of s</skos:definition>
        <skos:example xml:lang="en">The world line of a particle temporally projects onto the temporal region extending from the beginning to the end of the existence of the particle</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000167 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000167"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000170 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000170"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000171 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000171">
        <dc:identifier>234-BFO</dc:identifier>
        <rdfs:label xml:lang="en">located in</rdfs:label>
        <skos:definition xml:lang="en">b located in c =Def b is an independent continuant &amp; c is an independent &amp; neither is a spatial region &amp; there is some time t such that the spatial region which b occupies at t is continuant part of the spatial region which c occupies at t</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000172 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000172"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000174 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000174"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000175 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000175"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000176 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000176">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
        <dc:identifier>221-BFO</dc:identifier>
        <rdfs:label xml:lang="en">continuant part of</rdfs:label>
        <skos:definition xml:lang="en">b continuant part of c =Def b and c are continuants &amp; there is some time t such that b and c exist at t &amp; b continuant part of c at t</skos:definition>
        <skos:example xml:lang="en">Milk teeth continuant part of human; surgically removed tumour continuant part of organism</skos:example>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000177 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000177"/>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000178 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000178">
        <dc:identifier>271-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has continuant part</rdfs:label>
        <skos:definition xml:lang="en">b has continuant part c =Def c continuant part of b</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000183 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000183">
        <dc:identifier>267-BFO</dc:identifier>
        <rdfs:label xml:lang="en">environs</rdfs:label>
        <skos:altLabel xml:lang="en">contains process</skos:altLabel>
        <skos:definition xml:lang="en">b environs c =Def c occurs in b</skos:definition>
        <skos:example xml:lang="en">Mouth environs process of mastication; city environs traffic</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000184 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000184">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000185"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <dc:identifier>144-BFO</dc:identifier>
        <rdfs:label xml:lang="en">history of</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) history of is a relation between history b and material entity c such that b is the unique history of c</skos:definition>
        <skos:example xml:lang="en">This life is the history of this organism</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000185 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000185">
        <dc:identifier>145-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has history</rdfs:label>
        <skos:definition xml:lang="en">b has history c =Def c history of b</skos:definition>
        <skos:example xml:lang="en">This organism has history this life</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000194 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000194">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000195"/>
        <dc:identifier>260-BFO</dc:identifier>
        <rdfs:label xml:lang="en">specifically depended on by</rdfs:label>
        <skos:altLabel xml:lang="en">s-depended on by</skos:altLabel>
        <skos:definition xml:lang="en">b specifically depended on by c =Def c specifically depends on b</skos:definition>
        <skos:example xml:lang="en">Coloured object specifically depended on by colour</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000195 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000195">
        <dc:identifier>012-BFO</dc:identifier>
        <rdfs:label xml:lang="en">specifically depends on</rdfs:label>
        <skos:altLabel xml:lang="en">s-depends on</skos:altLabel>
        <skos:definition xml:lang="en">(Elucidation) specifically depends on is a relation between a specifically dependent continuant b and specifically dependent continuant or independent continuant that is not a spatial region c such that b and c share no parts in common &amp; b is of a nature such that at all times t it cannot exist unless c exists &amp; b is not a boundary of c</skos:definition>
        <skos:example xml:lang="en">A shape specifically depends on the shaped object; hue, saturation and brightness of a colour sample specifically depends on each other</skos:example>
        <skos:scopeNote xml:lang="en">The analogue of specifically depends on for occurrents is has participant.</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000196 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000196">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000194"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
        <dc:identifier>053-BFO</dc:identifier>
        <rdfs:label xml:lang="en">bearer of</rdfs:label>
        <skos:definition xml:lang="en">b bearer of c =Def c inheres in b</skos:definition>
        <skos:example xml:lang="en">A patch of ink is the bearer of a colour quality; an organism is the bearer of a temperature quality</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000197 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000197">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000195"/>
        <dc:identifier>051-BFO</dc:identifier>
        <rdfs:label xml:lang="en">inheres in</rdfs:label>
        <skos:definition xml:lang="en">b inheres in c =Def b is a specifically dependent continuant &amp; c is an independent continuant that is not a spatial region &amp; b specifically depends on c</skos:definition>
        <skos:example xml:lang="en">A shape inheres in a shaped object; a mass inheres in a material entity</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000199 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000199">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <dc:identifier>132-BFO</dc:identifier>
        <rdfs:label xml:lang="en">occupies temporal region</rdfs:label>
        <skos:definition xml:lang="en">p occupies temporal region t =Def p is a process or process boundary &amp; the spatiotemporal region occupied by p temporally projects onto t</skos:definition>
        <skos:example xml:lang="en">The Second World War occupies the temporal region September 1, 1939 - September 2, 1945</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000200 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000200">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <dc:identifier>082-BFO</dc:identifier>
        <rdfs:label xml:lang="en">occupies spatiotemporal region</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) occupies spatiotemporal region is a relation between a process or process boundary p and the spatiotemporal region s which is its spatiotemporal extent</skos:definition>
        <skos:example xml:lang="en">A particle emitted by a nuclear reactor occupies the spatiotemporal region which is its trajectory</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000210 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000210">
        <dc:identifier>232-BFO</dc:identifier>
        <rdfs:label xml:lang="en">occupies spatial region</rdfs:label>
        <skos:definition xml:lang="en">b occupies spatial region r =Def b is an independent continuant that is not a spatial region &amp; r is a spatial region &amp; there is some time t such that every continuant part of b occupies some continuant part of r at t and no continuant part of b occupies any spatial region that is not a continuant part of r at t</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000216 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000216">
        <dc:identifier>246-BFO</dc:identifier>
        <rdfs:label xml:lang="en">spatially projects onto</rdfs:label>
        <skos:definition xml:lang="en">(Elucidation) spatially projects onto is a relation between some spatiotemporal region b and spatial region c such that at some time t, c is the spatial extent of b at t</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000218 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000218">
        <dc:identifier>242-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has material basis</rdfs:label>
        <skos:definition xml:lang="en">b has material basis c =Def b is a disposition &amp; c is a material entity &amp; there is some d bearer of b &amp; there is some time t such that c is a continuant part of d at t &amp; d has disposition b because c is a continuant part of d at t</skos:definition>
        <skos:scopeNote xml:lang="en">Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: &lt;Link&gt;</skos:scopeNote>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000221 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000221">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000222"/>
        <dc:identifier>268-BFO</dc:identifier>
        <rdfs:label xml:lang="en">first instant of</rdfs:label>
        <skos:definition xml:lang="en">t first instant of t&apos; =Def t is a temporal instant &amp; t&apos; is a temporal region t&apos; &amp; t precedes all temporal parts of t&apos; other than t</skos:definition>
        <skos:example xml:lang="en">An hour starting at midnight yesterday has first instant midnight yesterday</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000222 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000222">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <dc:identifier>261-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has first instant</rdfs:label>
        <skos:definition xml:lang="en">t has first instant t&apos; =Def t&apos; first instant of t</skos:definition>
        <skos:example xml:lang="en">The first hour of a year has first instant midnight on December 31</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000223 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000223">
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000224"/>
        <dc:identifier>269-BFO</dc:identifier>
        <rdfs:label xml:lang="en">last instant of</rdfs:label>
        <skos:definition xml:lang="en">t last instant of t&apos; =Def t is a temporal instant &amp; t&apos; is a temporal region &amp; all temporal parts of t&apos; other than t precede t</skos:definition>
        <skos:example xml:lang="en">Last midnight is the last instant of yesterday</skos:example>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/BFO_0000224 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/BFO_0000224">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <dc:identifier>215-BFO</dc:identifier>
        <rdfs:label xml:lang="en">has last instant</rdfs:label>
        <skos:definition xml:lang="en">t has last instant t&apos; =Def t&apos; last instant of t</skos:definition>
        <skos:example xml:lang="en">The last hour of a year has last instant midnight December 31</skos:example>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/achievesAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/achievesAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000059"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">achieves at some time</rdfs:label>
        <skos:example xml:lang="en-us">The staffing and ramping up of production to 2 shifts per work day acheives the company plan of satisfying a surge in demand for its products.</skos:example>
        <annotation:firstOrderLogicAxiom>achievesAtSomeTime(x,y) → Process(x) ∧ InformationContentEntity(y) ∧ (concretizesAtSomeTime(x,y) ∨ ∃z(continuantPartOfAtAllTimes(z,y) ∧ InformationContentEntity(z) ∧ concretizesAtSomeTime(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a process to an information content entity wherein the process partially or fully concretizes the information content entity</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x achieves at some time y holds when x is a &apos;process&apos; and y is an &apos;information content entity&apos; and x &apos;concretizes at some time&apos; y or a &apos;continuant part of at all times&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">acts on behalf of at some time</rdfs:label>
        <skos:example xml:lang="en-us">An agent acts on behalf of a business organization. A laywer acts on behalf of a person.</skos:example>
        <annotation:firstOrderLogicAxiom>actsOnBehalfOfAtSomeTime(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (Person(y) ∨ GroupOfAgents(y) ∨ EngineeredSystem(y)) ∧ ∃p∃d(PlannedProcess(p) ∧ ObjectiveSpecification(d) ∧ participatesInAtSomeTime(x,p) ∧achievesAtSomeTime(p,d) ∧ genericallyDependsOnAtSomeTime(d,y))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a material entity to a person or a group of agents or engineered system that holds when the material entity participates in some planned process in order to fulfill an objective for the person or group of agents or engineered system</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x acts on behalf of at some time y holds when x is a &apos;material entity&apos; (that is not a &apos;fiat object part&apos;) and y is some &apos;person&apos; or &apos;group of agents&apos; or &apos;engineered system&apos; and at some time t, there exists a &apos;planned process&apos; p such that x &apos;participates in&apos; p and p &apos;achieves at some time&apos; some &apos;objective specification&apos; d that &apos;generically depends on at some time&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/after -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/after">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000062"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/before"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">after</rdfs:label>
        <skos:example xml:lang="en-us">A metal surface is polished after the surface is cleaned to make it free from dust or grease; a product is manufactured after it is designed; March comes after January.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>after(x,y) ↔ before(y,x)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is later than the first instant of the temporal extent of j</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>&apos;before&apos; and &apos;after&apos; are inverse relations</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/before -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/before">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000063"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">before</rdfs:label>
        <skos:example xml:lang="en-us">The surface of the metal is cleaned to make it free from dust or grease before polishing; a product is designed before it can be manufactured; January comes before March.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>LA1: before(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ before(i,j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ hasLastInstant(i,i1) ∧ hasFirstInstant(j,j1) ∧ precedes(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: Process(i) ∧ Process(j) ∧ ∃i1∃j1(TemporalInterval(i1) ∧ before(i,j) → TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ before(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is earlier than the first instant of the temporal extent of j</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If i is &apos;before&apos; j then either both are &apos;temporal intervals&apos; or both are &apos;process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If both i and j are &apos;temporal intervals&apos; and i is &apos;before&apos; j then the &apos;last instant of&apos; i &apos;precedes&apos; the &apos;first instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: If both i and j are &apos;process&apos; and i is &apos;before&apos; j then the &apos;temporal interval&apos; that i occupies is &apos;before&apos; the &apos;temporal interval&apos; that j occupies</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/capabilityOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/capabilityOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasCapability"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">capability of</rdfs:label>
        <skos:example xml:lang="en-us">turning at the maximal speed of 4000RPM is the capability of a lathe; temperature sensor has the capability to measuring temperature with a 0.01C precision is the capability of a temperature sensor; measuring pH in the range of 0-14 is the capability of a pH meter</skos:example>
        <annotation:firstOrderLogicAxiom>capabilityOf(x,y) → Capability(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a capability to an independent continuant (the bearer), in which the capability specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x capability of y holds when x is a &apos;capability&apos; and y is a &apos;independent continuant&apos; and x is &apos;inheres in&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/categorizedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/categorizedBy">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/classifiedBy"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/categorizes"/>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">categorized by</rdfs:label>
        <annotation:explanatoryNote>see the explanation under categorizes</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>categorizedBy(c1, c2) ↔ categorizes(c2, c1)</annotation:firstOrderLogicDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between a lower-order classifier by a higher-order classifier such that the latter classifier categorizes the former</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition>c1 is &apos;categorized by&apos; c2 iff c2 categorizes c1</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/categorizes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/categorizes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/classifies"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/categorizes"/>
            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/generalizes"/>
        </owl:propertyChainAxiom>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">categorizes</rdfs:label>
        <skos:example>classifiers such as SUV, hatchback, and sedan are categorized under a higher-order classifier body style; classifiers like internal combustion, electric, and hybrid vehicles are categorized by fuel type; classifiers such as small, medium, and large are categorized by size; specific plasmid classifiers (e.g., pSEVA191) may be generalized by a classifier such as Ap, which is categorized by antibiotic resistance</skos:example>
        <annotation:explanatoryNote>1. The terms lower-order and higher-order are relative. In this pattern, a lower-order classifier is used to classify entities of a particular kind, whereas a higher-order classifier indicates a general basis on which the lower-order classifier classifies

2. The definition of categorizes uses &apos;Set&apos; and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough set and a ‘set member of’ constructs are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, setMemberOf(x, s) is to be understood as x∈s.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>categorizes(c1, c2) ∧ generalizes(c2, c3) → categorizes(c1, c3)</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicDefinition>categorizes(c1, c2) ↔ (classifies(c1, c2) ∧ ∃s1, s2 (designates(c1, s1) ∧ designates(c2, s2) ∧ setMemberOf(s2, s1))))</annotation:firstOrderLogicDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between classifiers in which a higher-order classifier classifies a lower-order classifier and designates a set that has as members only sets designated by lower-order classifiers that it organizes</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>if c1 &apos;categorizes&apos; c2 and c2 &apos;generalizes&apos; c3, then c1 also &apos;categorizes&apos; c3</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageDefinition>c1 ‘categorizes’ c2 if and only if c1 ‘classifies’ c2 and there exists some s1 and some s2 such that c1 ‘designates’ s1, c2 ‘designates’ s2, and s2 is a set member of s1</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/classifiedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/classifiedBy">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/denotedBy"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/classifies"/>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">classified by</rdfs:label>
        <annotation:explanatoryNote>See the explanatory note and detailed FOL formalization under classifies</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>classifiedBy(x,c) ↔ classifies(c,x)</annotation:firstOrderLogicDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between an entity y and an information content entity x when the information content entity designates a set whose members are all the entities of a particular type and y is a member of that set</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition>x is &apos;classified by&apos; c iff c classfies x</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/classifies -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/classifies">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/denotes"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/generalizes"/>
            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/classifies"/>
        </owl:propertyChainAxiom>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">classifies</rdfs:label>
        <skos:example>UNSPSC code 44121706 classifies a wooden pencil</skos:example>
        <annotation:explanatoryNote>1. Any two entities classified by the same classifier are instances of a single, uniquely determined class; while the classifier classifies multiple entities, it designates one class (through a set instance) that fixes their common type.

2. The set designated by a classifier corresponds to a class means that every instance of the class is a member of that set. In this sense, the set is treated as a punned individual of the class, sharing the same IRI while remaining semantically distinct.

3. The definition of classifies uses &apos;Set&apos; and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough set and a ‘set member of’ constructs are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, setMemberOf(x, s) is to be understood as x∈s.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>LA1: classifies(c,x) → ∃s (Set(s) ∧ designates(c,s) ∧ setMemberOf(x, s))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: classifies(c,x) ∧ designates(c,s) → ∃C(Class(C) ∧ instanceOf(x,C) ∧ sameIRI(s,C) ∧ ∀y((setMemberOf(y,s) → instanceOf(y,C)) ∧ (setMemberOf(y,s)  → classifies(c,y))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between an information content entity x and an entity y when the information content entity designates a set whose members are instances of a particular type and y is a member of that set</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: if c &apos;classifies&apos; x, then there exists a set s such that c &apos;designates&apos; s and x &apos;is a member of&apos; s</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: if a classifier c classifies an entity x and designates a set s, then there exists a class C such that x is an instance of C, s and C share the same IRI, and, for every entity y, if y is a member of s then y is an instance of C and if y is a set member of s then c classifies y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/componentPartOfAtAllTimes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/componentPartOfAtAllTimes">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000137"/>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">component part of at all times</rdfs:label>
        <skos:example xml:lang="en-us">transmission assembly is a component part of a car; engine control ;sparger is a component part of a bioreactor</skos:example>
        <annotation:firstOrderLogicAxiom>componentPartOfAtAllTimes(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ properContinuantPartOfAtAllTimes(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a material entity to another material entity that it is a proper part of at all times it exists</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x component part of at all times y holds when x is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and y is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and x is &apos;proper continuant part of at all times&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000175"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">component part of at some time</rdfs:label>
        <skos:example xml:lang="en-us">a particular chromatography column is a component part of a chromatography system during several purification cycles; a particular tool is a component part of a CNC machine while it is being used for manufacturing a particular part</skos:example>
        <annotation:explanatoryNote>The IOF does not consider as component part of material entities that are delineated by a non-physical (fiat) boundary from the material entity they are a part of.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>componentPartOfAtSomeTime(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ properContinuantPartOfAtSomeTime(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a material entity to another material entity that it is a proper part of at some time</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x component part of at some time y holds when x is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and y is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and x is &apos;proper continuant part of at some time&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/containsOccurrenceOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/containsOccurrenceOf">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/occursDuring"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">contains occurence of</rdfs:label>
        <skos:example xml:lang="en-us">The grinding of metal contains occurrence of sparking; a storm contains occurrences of lightning.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>containsOccurrenceOf(x,y) ↔ occursDuring(y,x)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the first instant of the temporal extent of j is later than the first instant of the temporal extent of i and the last instant of the temporal extent of j is earlier than the last instant of the temporal extent of i</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>&apos;contains occurrence of&apos; and &apos;occurs during&apos; are inverse relations</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/denotedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/denotedBy">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isSubjectOf"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/denotes"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">denoted by</rdfs:label>
        <skos:example xml:lang="en-us">one or more individuals are denoted by the name &apos;John&apos;; vehicle is denoted by a &apos;vehicle identification number&apos;; molecules with the structure CH3-CH2-OH is denoted by &apos;ethanol&apos;</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to an information content entity that distinguishes the entity</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/denotes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/denotes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isAbout"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">denotes</rdfs:label>
        <skos:example xml:lang="en-us">the name &apos;John&apos; denotes one or more individuals that have that name; &apos;vehicle identification number&apos; denotes a vehicle; &apos;ethanol&apos; is a name given by IUPAC which denotes molecules with the structure CH3-CH2-OH</skos:example>
        <annotation:explanatoryNote>The distinguishment implied by denotes is not necessarily unique, which is why this property is not made functional. For example, a name can, at one point, &apos;denote&apos; multiple individuals.</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an information content entity to an entity that the information content entity distinguishes</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/describedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/describedBy">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isSubjectOf"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">described by</rdfs:label>
        <skos:example xml:lang="en-us">some current event is described by the content of a newspaper article; some facility visit is described by the content of a visitor&apos;s log; some accident is described by the content of an accident report</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to an information content entity that characterizes the entity</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/describes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/describes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isAbout"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">describes</rdfs:label>
        <skos:example xml:lang="en-us">the content of a newspaper article describes some current event; the content of a visitor&apos;s log describes some facility visit; the content of an accident report describes some accident</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an information content entity to an entity that the information content entity characterizes</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/designatedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/designatedBy">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/denotedBy"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/designates"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">designated by</rdfs:label>
        <skos:example xml:lang="en-us">a Web Page&apos;s location on the internet is designated by an URL; an individual in USA is designated by SSN ; a particular lot of product is designated by a &apos;lot number&apos;</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to an information content entity that uniquely distinguishes the entity from other entities</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/designates -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/designates">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/denotes"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">designates</rdfs:label>
        <skos:example xml:lang="en-us">a URL designates the location of a Web Page on the internet;SSN designates an individual; &apos;lot number&apos; designates a particular lot of product</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:explanatoryNote>1. To ensure uniqueness, each information content entity can designate exactly one entity. As such, this property is made functional.
2. The uniqueness of the entity is typically within a particular context that is represented in the identification scheme that conveys the meaning of the assignment.</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an information content entity to an entity that the information content entity uniquely distinguishes from other entities</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/dispositionOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/dispositionOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasDisposition"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">disposition of</rdfs:label>
        <skos:example xml:lang="en-us">the disposition to decay to an atom of element Y is the disposition of an atom of element X; the disposition to break apart is the disposition of a poorly assembled item</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000092</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>dispositionOf(x,y) → Disposition(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a disposition to an independent continuant (the bearer), in which the disposition specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x disposition of y holds when x is a &apos;disposition&apos; and y is a &apos;independent continuant&apos; and x is &apos;inheres in&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/functionOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/functionOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">function of</rdfs:label>
        <skos:example xml:lang="en-us">this catalysis function is a function of this enzyme</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000079</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>functionOf(x,y) → Function(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a function to an independent continuant (the bearer), in which the function specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x function of y holds when x is a &apos;function&apos; and y is a &apos;independent continuant&apos; and x is &apos;inheres in&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/generalizes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/generalizes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/denotes"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/specializes"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">generalizes</rdfs:label>
        <skos:example>UNSPSC classifier code 26101500 for engines genralizes commodity classifier code 26101507 for turboshaft engines.</skos:example>
        <annotation:explanatoryNote>1. Since the set designated by a classifier corresponds to a class, a subset relation between designated sets implies a subclass relation between the corresponding classes: if s2 is a subset of s1, then the class corresponding to s2 is a subclass of the class corresponding to s1. In this sense, the classifier being generalized is associated with a more specific class, while the classifier that generalizes it is associated with a more general class.

2. For further details on what it means for a set to correspond to a class, see the FOL formalization and explanatory note for classifier.

3. Generalizes is asymmetric and transitive. Accordingly, if one classifier generalizes a second classifier, the second does not generalize the first; and if a first classifier generalizes a second and the second generalizes a third, then the first also generalizes the third.

4. The definition of generalizes uses &apos;Set&apos; and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough Set and subset of are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, subSetOf(s2, s1) is understood as s2 ⊆ s1.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>LA1: generalizes(c1, c2) ∧ designates(c1, s1) ∧ designates(c2,s2) → subSetOf(s2, s1)</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: generalizes(p, c) ∧ classifies(c, x)) → classifies(p, x)</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicDefinition>generalizes(c2​, c1​) ↔ ∀x(classifies(c2​, x) → classifies(c1​, x))</annotation:firstOrderLogicDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between two classifiers such that everything classified by the latter is also classified by the former</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If a &apos;classifier&apos; c1 &apos;generalizes&apos; a &apos;classifier&apos; c2, and c1 and c2 &apos;designate&apos; sets s1 and s2  then s2 &apos;is subset of&apos; s1</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: if p &apos;generalizes&apos; c and c &apos;classifies&apos; x, then p also &apos;classifies&apos; x</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageDefinition>‘c2’ generalizes ‘c1’ if and only if for every instance ‘x’, if ‘c2’ classifies ‘x’, then ‘c1’ classifies ‘x’.</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasCapability -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasCapability">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has capability</rdfs:label>
        <skos:example xml:lang="en-us">a lathe has a capability to turn at the maximal speed of 4000RPM; temperature sensor has the capability to measure temperature with a 0.01C precision; pH meter has the capability to measure pH in the range of 0-14</skos:example>
        <annotation:firstOrderLogicAxiom>hasCapability(x,y) → IndependentContinuant(x) ∧ Capability(y) ∧ bearerOf(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an independent continuant (the bearer) to a capability, in which the capability specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x has capability y holds when x is a &apos;independent continuant&apos; and y is a &apos;capability&apos; and x is &apos;bearer of&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000111"/>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has component part at all times</rdfs:label>
        <skos:example xml:lang="en-us">car has component part a chasy; a bioractor has component part a stainless steel vessel</skos:example>
        <annotation:firstOrderLogicAxiom>hasComponentPartAtAllTimes(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ hasProperContinuantPartAtAllTimes(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a material entity to another material entity that it has as a proper part at all times it exists</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x has component part at all times y holds when x is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and y is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and x &apos;has proper continuant part at all times&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000174"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has component part at some time</rdfs:label>
        <skos:example xml:lang="en-us">a particular chromatography column is a component part of a chromatography system has a component part a particular chromatography column during several purification cycles; a CNC machine has component part a particular tool while it is being used for manufacturing a particular part</skos:example>
        <annotation:firstOrderLogicAxiom>hasComponentPartAtSomeTime(y,x) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ properContinuantPartOfAtSomeTime(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a material entity to another material entity that it has as a proper part at some time</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>y has component part at some time x holds when x is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and y is a &apos;material entity&apos; that is not a &apos;fiat object part&apos; and x is &apos;proper continuant part of at some time&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasDisposition -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasDisposition">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has disposition</rdfs:label>
        <skos:example xml:lang="en-us">An atom of element X has the disposition to decay to an atom of element Y; a poorly assembled item has the disposition to break apart</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000091</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>hasDisposition(x,y) → IndependentContinuant(x) ∧ Disposition(y) ∧ bearerOf(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an independent continuant (the bearer) to a disposition, in which the disposition specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x has disposition y holds when x is a &apos;independent continuant&apos; and y is a &apos;disposition&apos; and x is &apos;bearer of&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasFunction -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasFunction">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has function</rdfs:label>
        <skos:example xml:lang="en-us">this enzyme has function this catalysis function (more colloquially: this enzyme has this catalysis function)</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000085</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en-us">A bearer can have many functions, and its functions can exist for different periods of time, but none of its functions can exist when the bearer does not exist. A function need not be realized at all the times that the function exists.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>hasFunction(x,y) → IndependentContinuant(x) ∧ Function(y) ∧ bearerOf(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an independent continuant (the bearer) to a function, in which the function specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x has function y holds when x is a &apos;independent continuant&apos; and y is a &apos;function&apos; and x is &apos;bearer of&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasInput -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasInput">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isInputOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has input</rdfs:label>
        <skos:example xml:lang="en-us">machine learning execution process has input a dataset;fermentation process has input growth medium; additive manufacturing process has input metal powder;</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a process to someone or something physical or digital (continuant) that is a necessary precondition for the process to start</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasMeasuredValueAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasMeasuredValueAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has measured value at some time</rdfs:label>
        <skos:example xml:lang="en-us">&apos;80kg&apos; is the value of the weight of a male human on the 5th of October 2022; &apos;37C&apos; is the temperature inside a bioreactor in the 30th min from the process start</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to a value expression that contains the value of the entity measured at some time t</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasOutput -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasOutput">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000057"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isOutputOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has output</rdfs:label>
        <skos:example xml:lang="en-us">chemical manufacturing process has output a wastestream; toluene manufacturing process has output a certain quantity of toluene; car manufacturing process has output a car</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology</annotation:adaptedFrom>
        <annotation:explanatoryNote>By introducing the condition that it must exist at the end of the process materials that only transitively exist during the process (e.g., reaction intermediary) are excluded from being considered the output.</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a process to someone or something physical or digital (continuant) that participates in the process such that it is generated or modified during the process, and that it exists at the end of the process</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasProcessCharacteristic -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasProcessCharacteristic">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has process characteristic</rdfs:label>
        <skos:example xml:lang="en-us">the water flowing through a pipe during a given period has the average flow rate as a process characteristic, the heating process has the total energy consumed as a process characteristic, the batch sterilization process has the peak temperature as a process characteristic.</skos:example>
        <annotation:firstOrderLogicDefinition>hasProcessCharacteristics(p, c) → processCharacteristicsOf(c, p)</annotation:firstOrderLogicDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between a process and its characteristic</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition>if p &apos;has process characteristics&apos; c, then c is &apos;process characteristics of&apos; p</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasProcessProfile -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasProcessProfile">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000118"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/processProfileOf"/>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has process profile</rdfs:label>
        <skos:example>The pH profile is a process profile of the cell culture growth process, the spindle speed profile is a process profile of the milling process, the flow rate profile is a process profile of the pipeline transport process.</skos:example>
        <annotation:firstOrderLogicDefinition>hasProcessProfile(p, x) → processProfileOf(x, p)</annotation:firstOrderLogicDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between a process and a process profile that is part of the process such that the part is temporally coextensive with another proper part that is mutually dependent on it and has no parts in common with it</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition>if p &apos;has process profile&apos; x, then x is &apos;process profile of&apos; p</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasQuality -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasQuality">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/qualityOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has quality</rdfs:label>
        <skos:example xml:lang="en-us">this apple has quality this red color</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000086</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en-us">A bearer can have many qualities, and its qualities can exist for different periods of time, but none of its qualities can exist when the bearer does not exist.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>hasQuality(x,y) → IndependentContinuant(x) ∧ Quality(y) ∧ bearerOf(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an independent continuant (the bearer) to a quality, in which the quality specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x has function y holds when x is a &apos;independent continuant&apos; and y is a &apos;quality&apos; and x is &apos;bearer of&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasRole -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasRole">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000196"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/roleOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has role</rdfs:label>
        <skos:example xml:lang="en-us">this person has role this investigator role (more colloquially: this person has this role of investigator)</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000087</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en-us">A bearer can have many roles, and its roles can exist for different periods of time, but none of its roles can exist when the bearer does not exist. A role need not be realized at all the times that the role exists.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>hasRole(x,y) → IndependentContinuant(x) ∧ Role(y) ∧ bearerOf(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an independent continuant (the bearer) to a role, in which the role specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x has role y holds when x is a &apos;independent continuant&apos; and y is a &apos;role&apos; and x is &apos;bearer of&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasOutput"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has specified output</rdfs:label>
        <skos:example xml:lang="en-us">biopharmaceutical production process has specified output an antibody solution of 99.999% purity; a simulation execution has specified output a prediction of part porosity; a temperature measurement process has specified output a temperature measurement result; a car manufacturing process has specified output a car</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/OBI_0000299</annotation:adaptedFrom>
        <annotation:explanatoryNote>this relation was added to specifically model the outputs that are not byproducts/wasteproducts</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>hasSpecifiedOutput(x,y) → PlannedProcess(x) ∧ Continuant(y) ∧ ∃o(ObjectiveSpecification(o) ∧ prescribes(o,y) ∧ achievesAtSomeTime(x,o) ∧ hasOutput(x,y))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a planned process to someone or something physical or digital (continuant) that is produced or modified in the planned process as prescribed by an objective</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x &apos;has specified output&apos; y holds when x is a &apos;planned process&apos; and y is a &apos;continuant&apos; and x &apos;has output&apos; y and y is &apos;prescribed by&apos; some &apos;objective specification&apos; which x &apos;achieves at some time&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:synonym xml:lang="en-us">has intended output</annotation:synonym>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtAllTimes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtAllTimes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has value expression at all times</rdfs:label>
        <skos:example xml:lang="en-us">speed of light in a vacuum has value expression 3×10^8 m/s ; electric charge carried by a single proton has the value expression 1.602176634×10−19 coulombs</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to a value expression that contains the value of the entity which does not change during the entire existence of the entity</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/describedBy"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">has value expression at some time</rdfs:label>
        <skos:example xml:lang="en-us">the diameter of a screw head has value expression 1cm that is specified in its design; a bioreactor has value expression 37C that was measured during the production process; &quot;low risk&quot; is the value expression of a process parameter &quot;low risk&quot; that is based on the risk analysis classification scheme; an antibody has value expression 3 g/l that was generated by a process simulation</skos:example>
        <annotation:explanatoryNote>determined in this context can be interpreted as either being simulated or being measured</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to a value expression that contains the value of the entity determined or set at some time t</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/has_participant_at_some_time -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/has_participant_at_some_time"/>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isAbout -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isAbout">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isSubjectOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is about</rdfs:label>
        <skos:example xml:lang="en-us">a temperature recording is about temperature; SSN is about a particular individual; commercial service agreement is about a commercial service</skos:example>
        <annotation:adaptedFrom>IAO:http://purl.obolibrary.org/obo/IAO_0000136 and CCO:http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">primitive, generic relationship between an information content entity and some entity</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000058"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is achieved by at some time</rdfs:label>
        <skos:example xml:lang="en-us">The company plan of satisfying a surge in demand for its products is achieved by the staffing and ramping up of production to 2 shifts per work day.</skos:example>
        <annotation:firstOrderLogicAxiom>isAchievedByAtSomeTime(y,x) → Process(x) ∧ InformationContentEntity(y) ∧ (concretizesAtSomeTime(x,y) ∨ ∃z(continuantPartOf(z,y) ∧ InformationContentEntity(z) ∧ concretizesAtSomeTime(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an information content entity to a process that partially or fully concretizes the information content entity</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>y is achieved by at some time x holds when x is a &apos;process&apos; and y is an &apos;information content entity&apos; and x &apos;concretizes&apos; y or a &apos;continuant part of&apos; y, at some time t</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isAvailableToAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isAvailableToAtSomeTime">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is available to at some time</rdfs:label>
        <skos:example xml:lang="en-us">a roll of aluminum (resource) is avaiable to an agent to use in a forming process, a milling workstation (resource) is available to a manufacturer to produce some parts</skos:example>
        <annotation:explanatoryNote>this definition of &apos;is available to&apos; is not the same as the state of availability e.g a machine is idle hence it is in the available state</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>isAvailableToAtSomeTime(x,y) → (MaterialEntity(x) ∨ Site(x)) ∧ Agent(y) ∧ ∃p∃o∃c(Process(p) ∧ ObjectiveSpecification(o) ∧ Capability(c) ∧ hasCapability(x,c) ∧ genericallyDependsOnAtSomeTime(o,y) ∧ (realizes(p,c) ∧ participatesInAtSomeTime(y,p)→ AchievesAtSomeTime(p,o)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a material entity or physical location to an agent that holds when the material entity or physical location have a capability that is needed by the agent to fulfil some objective carried by the agent</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x is available at some time y holds when x is a &apos;material entity&apos; or &apos;site&apos; and y is an &apos;agent&apos; and x &apos;has capability&apos; some &apos;capability&apos; which when &apos;realized in&apos; some &apos;process&apos; p that y &apos;participates in at some time&apos; implies that p &apos;achieves at some time&apos; some &apos;objective specification&apos; that &apos;generically depends on at some time&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isInputOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isInputOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000056"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is input of</rdfs:label>
        <skos:example xml:lang="en-us">a dataset is an input of a machine learning execution process; growth medium is an input of a fermentation process; metal powder is an input of an additive manufacturing process;</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relates someone or something physical or digital (continuant) to a process that it is a necessary precondition for the process to start</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isMadeOfAtAllTimes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isMadeOfAtAllTimes">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000110"/>
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is made of at all times</rdfs:label>
        <skos:example>A glass bottle is made of glass at all times during its existence as that bottle; A polymer tube is made of polymer at all times during its existence as that tube</skos:example>
        <annotation:explanatoryNote>This relation is asserted with an ‘at all times’ condition. It therefore implies that, for every time at which a exists, a has b as a continuant part. Equivalently, there is no time during the existence of a at which a fully lacks b as a part while still remaining the same material entity</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between material entity b and material entity that is not a fiat object c such that b has continuant part at all times c and if portion of c is removed from b, that portion stops being part of b, while the remaining c continues to exist as the same material entity and b remains to have continuant part c</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000178"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is made of at some time</rdfs:label>
        <skos:example>A bottle is made of glass; a bioreactor vessel is made of stainless steel; a capsule shell is made of gelatin; a wooden tabletop is made of oak</skos:example>
        <annotation:counterExample>A car is not made of wheels; a bioreactor is not made of sensors; a computer is not made of circuit boards; an aircraft is not made of engines; a building is not made of windows; a pipeline is not made of valves</annotation:counterExample>
        <annotation:explanatoryNote>1) This relation captures the continuous material composition of an entity rather than its structural or component assembly. It depends on the presence of some quantity of the material, not on the exact total amount. The identity of b remains unchanged when its portions are removed; only the quantity of the material within a varies. The relation continues to hold as long as any remainder of b remains materially present in a.
2) It applies to continuous substances or amounts of matter such as glass, steel, polymer, or wood. It should not be used for discrete parts, modules, or components such as wheels, valves, or bolts. The material may be homogeneous or composite; chemical uniformity is not required.
3) The relation has the following characteristics: irreflexive, asymmetric, non-functional, non-transitive</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between material entity b and material entity that is not a fiat object c such that b has continuant part at some time c and if portion of c is removed from b, that portion stops being part of b, while the remaining c continues to exist as the same material entity and b remains to have continuant part c</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is measured value of at some time</rdfs:label>
        <skos:example xml:lang="en-us">&apos;80kg&apos; is the measured weight of a particular male human</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a value expression to the entity indicating that the value expression contains the value of the entity measured at some time t</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isOutputOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isOutputOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000056"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is output of</rdfs:label>
        <skos:example xml:lang="en-us">wastestream is an output of a chemical manufacturing process; a certain quantity of toluene is an output of a toluene manufacturing process; a car is an output of a car manufacturing process</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from someone or something physical or digital (continuant) to a process that it participates in such that it is generated or modified during the process, and it exists at the end of the process</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isOutputOf"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is specified output of</rdfs:label>
        <skos:example xml:lang="en-us">antibody solution of 99.999% purity is the specified output of a biopharmaceutical production process; prediction of part porosity is a specified output of a simulation execution; temperature measurement result is the specified output of a temperature measurement process; a car is the specified output of a car manufacturing process</skos:example>
        <annotation:firstOrderLogicAxiom>isSpecifiedOutputOf(y,x) → PlannedProcess(x) ∧ Continuant(y) ∧ ∃o(ObjectiveSpecification(o) ∧ prescribes(o,y) ∧ achievesAtSomeTime(x,o) ∧ hasOutput(x,y))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from someone or something physical or digital (continuant) to a planned process in which it is produced or modified as prescribed by some objective</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>y &apos;has specified output&apos; x holds when x is a &apos;planned process&apos; and y is a &apos;continuant&apos; and x &apos;has output&apos; y and y is &apos;prescribed by&apos; some &apos;objective specification&apos; which x &apos;achieves at some time&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:synonym xml:lang="en-us">is intended output of</annotation:synonym>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isSubjectOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isSubjectOf">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is subject of</rdfs:label>
        <skos:example xml:lang="en-us">temperature is subject of temperature recording; particular individual is subject of SSN; commercial service is subject of commercial service agreement</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">primitive, generic relationship between an entity and some information content entity</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isTemporallyOverlappedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isTemporallyOverlappedBy">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is temporally overlapped by</rdfs:label>
        <skos:example xml:lang="en-us">When two plates are being welded at a joint, the heating of current point being welded is temporally overlapped by the cooling of a previously welded point; the receiving process is temporally overlapped by the sending process in a transaction process; Sumerian civilization (c. 3500 BCE - c. 2000 BCE) in Mesopotamia was temporally overlapped by Ancient Egyptian civilization (c. 3000 BCE - 30 BCE).</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>isTemporallyOverlappedBy(x,y) ↔ temporallyOverlaps(y,x)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals and processes i and j when the first instant of the temporal extent of j is earlier than and the last instant of the temporal extent of j is later than the first instant of the temporal extent of i, and the last instance of the temporal extent of j is earlier than the last instant of the temporal extent of i</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>&apos;is temporally overlapped by&apos; and &apos;temporally overlaps&apos; are inverse relations</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is value expression of at all times</rdfs:label>
        <skos:example xml:lang="en-us">3×10^8 m/s is the value expression of the speed of light in a vacuum; 1.602176634×10−19 coulombs is the value expression of the electric charge carried by a single proton</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a value expression to an entity indicating that the value expression contains the value of the entity which does not change during the entire existence of the entity</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">is value expression of at some time</rdfs:label>
        <skos:example xml:lang="en-us">1cm is the value expression of the diameter of a screw head that is specified in its design; 37C is the value expression of the temperature of a bioreactor measured during the production process; &quot;low risk&quot; is the value expression of a process parameter based on the risk analysis classification scheme; 3 g/l is the value expression of titer of an antibody generated by a process simulation</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/OBI_0001938</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a value expression to the entity indicating that the value expression contains the value of the entity determined or set at some time t</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/measuredByAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/measuredByAtSomeTime">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">measured by at some time</rdfs:label>
        <skos:example xml:lang="en-us">the temperature within a production vessel is measured by a temperature sensor at certain points in time during a chemical production process; the weight of a material bulk is measured by a scale</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to a material entity with a measurement capability that got realized to determine the value of the entity, at some time</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">measures at some time</rdfs:label>
        <skos:example xml:lang="en-us">a tempearture sensor measures the temperature within a production vessel at certain points in time during the chemical production process; a scale measures the weight of a material bulk</skos:example>
        <annotation:explanatoryNote>In this context, value is always determined relative to some classification scheme or on a quantitative scale</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a material entity to an entity indicating that the measurement capability of the material entity got realized to determine the value of the entity, at some time</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/meets -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/meets">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000063"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/metBy"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">meets</rdfs:label>
        <skos:example xml:lang="en-us">When an item is placed on a moving conveyor by a robotic arm, the process of placing the item meets the process of moving the item; summer meets fall; January meets February; the Christmas holiday period meets New Year’s holiday period.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>LA1: meets(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ meets(i,j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ hasLastInstant(i,i1) ∧ hasFirstInstant(j,j1) ∧ occursSimultaneouslyWith(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: Process(i) ∧ Process(j) ∧ meets(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ meets(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is the same as the first instant of the temporal extent of j</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If i &apos;meets&apos; j then either both are &apos;temporal intervals&apos; or both are &apos;process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If both i and j are &apos;temporal intervals&apos; and i &apos;meets&apos; j then the &apos;last instant of&apos; i &apos;occurs simultaneously with&apos; the &apos;first instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: If both i and j are &apos;process&apos; and i &apos;meets&apos; j then the &apos;temporal interval&apos; that i occupies &apos;meets&apos; the &apos;temporal interval&apos; that j occupies</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/metBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/metBy">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000062"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">met by</rdfs:label>
        <skos:example xml:lang="en-us">When an item is placed on a moving conveyor by a robotic arm, the process of moving of the item is met by the process of placing the item; fall is met by summer; February is met by January; the New Year’s holiday period is met by the Christmas holiday period.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>metBy(x,y) ↔ meets(y,x)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the last instant of the temporal extent of j is the same as the first instant of the temporal extent of i</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>&apos;met by&apos; and &apos;meets&apos; are inverse relations</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/observedByAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/observedByAtSomeTime">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">observed by at some time</rdfs:label>
        <skos:example xml:lang="en-us">a chemical reaction in an experiment is observed by a scientist, a machining process is observed by an operator, a group of COVID patients are observed by a doctor</skos:example>
        <annotation:firstOrderLogicAxiom>observedByAtSomeTime (y, x) → Agent(x) ∧ Entity(y) ∧ ∃p∃i(Process(p) ∧ InformationContentEntity(i) ∧ participatesInAtSomeTime(x,p) ∧ hasOutput(p,i) ∧ isAbout(i,y))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to an agent indicating that the agent participates in some process that outputs information about the entity, at some time</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>p is observed by b at some time t holds when p is an &apos;entity&apos; and b is an &apos;agent&apos; and there is a &apos;process&apos; in which b &apos;participates in at some time&apos; and that &apos;has output&apos; some &apos;information content entity&apos; that &apos;is about&apos; p</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">observes at some time</rdfs:label>
        <skos:example xml:lang="en-us">a scientist observing a chemical reaction in an experiment, an operator observes a machining process, a doctor observes a group of COVID patients</skos:example>
        <annotation:explanatoryNote>this property was not put under participates in at some time because the target of observation can be continuant or an occurent and in the case of an occurent an agent that observes the occurent might not participate in that occurent</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>observesAtSomeTime (x, y) → Agent(x) ∧ Entity(y) ∧ ∃p∃i(Process(p) ∧ InformationContentEntity(i) ∧ participatesInAtSomeTime(x,p) ∧ hasOutput(p,i) ∧ isAbout(i,y))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an agent to an entity indicating that the agent participates in some process that outputs information about the entity, at some time</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>b observes p at some time t when b is an &apos;agent&apos; and p is an &apos;entity and there is a &apos;process&apos; in which b &apos;participates in at some time&apos; and that &apos;has output&apos; some &apos;information content entity&apos; that &apos;is about&apos; p</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/occursDuring -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/occursDuring">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">occurs during</rdfs:label>
        <skos:example xml:lang="en-us">The final inspection and removal of defective products occur during the product is being moved to the packaging station by a conveyor belt; a sensor measures the thickness of the wall during the sand-grinding process; turkey is traditionally served during dinners on Thanksgiving In the United States.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>LA1: occursDuring(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ occursDuring(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ precedes(j1,i1) ∧ precedes(i2,j2))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: Process(i) ∧ Process(j) ∧ occursDuring(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ occursDuring(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA4: occursDuring(i,j) ↔ ∃k(temporallyFinishes(i,k) ∧ temporallyStarts(k,j))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the first instant of the temporal extent of i is later than the first instant of the temporal extent of j and the last instant of the temporal extent of i is earlier than the last instant of the temporal extent of j</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If i &apos;occurs during&apos; j then either both are &apos;temporal intervals&apos; or both are &apos;process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If both i and j are &apos;temporal intervals&apos; and i &apos;occurs during&apos; j&apos; then first instant of&apos; j ‘precedes’ the &apos;first instant of&apos; i and the &apos;last instant of&apos; i ‘precedes’ the &apos;last instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: If both i and j are &apos;process&apos; and i &apos;occurs during&apos; j then the &apos;temporal interval&apos; that i occupies &apos;occurs during&apos; the &apos;temporal interval&apos; that j occupies</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA4: i &apos;occurs during&apos; j if and only if there exists k such that i temporally finishes k and k temporally starts j</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/occursSimultaneouslyWith -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/occursSimultaneouslyWith">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">occurs simultaneously with</rdfs:label>
        <skos:example xml:lang="en-us">The rotation of the chuck in a lathe occurs simultaneously with the running of the motor.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>LA1: occursSimultaneouslyWith(i,j) → (TemporalInstant(i) ∧ TemporalInstant(j)) ∨ (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j)) ∧ (ProcessBoundary(i) ∧ ProcessBoundary(j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: TemporalInstant(i) ∧ TemporalInstant(j) ∧ occursSimultaneouslyWith(i,j) → ∃k∃l(TemporalInstantValueExpression(k) ∧ TemporalInstantValueExpression(l) ∧ hasValueExpressionAtAllTimes(i,k) ∧ hasValueExpressionAtAllTimes(j,l) ∧ ∃v1∃v2(hasDateTimeInstantValue(k,v1) ∧ hasDateTimeInstantValue(l,v2) ∧ (v1 = v2)))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: TemporalInterval(i) ∧ TemporalInterval(j) ∧ occursSimultaneouslyWith(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ occursSimultaneouslyWith(i1,j1) ∧ occursSimultaneouslyWith(i2,j2))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA4: Process(i) ∧ Process(j) ∧ occursSimultaneouslyWith(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ occursSimultaneouslyWith(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA5: ProcessBoundary(i) ∧ ProcessBoundary(j) ∧ occursSimultaneouslyWith(i,j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ occursSimultaneouslyWith(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two time instants when they are simultaneous or between two intervals when they have same first and last instants or between two processes or two process boundaries when their temporal extents are the same</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: if i &apos;occurs simultaneously with&apos; j then either i and j are both ‘temporal instant’, or both are ‘temporal interval’ or both are ‘process’ or both are ‘process boundary’</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If both i and j are both ‘temporal instant’ and i &apos;occurs simoultaneously with&apos; j then &apos;temporal instant value expression&apos; of i is equal to the &apos;temporal instant value expression&apos; of j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: If i and j are both ‘temporal interval’ and i &apos;occurs simoultaneously with&apos; j then the &apos;first instant of&apos; i &apos;occurs simoultaneously with&apos; the &apos;first instant of&apos; j and the &apos;last instant of&apos; i &apos;occurs simoultaneously with&apos; the &apos;last instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA4: If both i and j are ‘process’ and i &apos;occurs simoultaneously with&apos; j then the ‘temporal interval’ occupied by i ‘occurs simoultaneously with’ the ‘temporal interval’ occupied by j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA5: If i and j are both ‘process boundary’ and i &apos;occurs simoultaneously with&apos; j then the ‘temporal instant’ that i occupies &apos;occurs simoultaneously with&apos; ‘temporal instant’ that j occupies</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/prescribedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/prescribedBy">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isSubjectOf"/>
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/prescribes"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">prescribed by</rdfs:label>
        <skos:example xml:lang="en-us">some Artifact or Facility is modeled by a blueprint; a set of rules to be followed while acting in a role within a profession are prescribed by a professional code of conduct; tasks that need to be performed to achieve the Objectives of the Operation are prescribed by the Operation Plan</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to an information content entity that the information content entity serves as a collection of rules or guide for if the entity is something that unfolds in time (occurrent), or as a model if the entity is someone or something physical or digital (continuant)</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/prescribes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/prescribes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/isAbout"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">prescribes</rdfs:label>
        <skos:example xml:lang="en-us">a blueprint serves as a model of some Artifact or Facility; a professional code of conduct serves as a set of rules to be followed while acting in a role within that profession; an Operations Plan serves as a guide for the tasks that need to be performed to achieve the Objectives of the Operation</skos:example>
        <annotation:adaptedFrom rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology</annotation:adaptedFrom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an information content entity to an entity such that the information content entity serves as a collection of rules or guide for the entity if the entity is something that unfolds in time (occurrent), or as a model if the entity is someone or something physical or digital (continuant)</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">process characteristic of</rdfs:label>
        <skos:example>The average flow rate is a process characteristic of the water flowing through a pipe during a given period, the total energy consumed is a process characteristic of the heating process, the peak temperature is a process characteristic of the batch sterilization process.</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between a characteristic and the process it is a characteristic of</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/processProfileOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/processProfileOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000138"/>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">process profile of</rdfs:label>
        <skos:example>pH profile is a process profile of culture growth, agitation speed profile is a process profile of a mixing process, tool vibration profile is a process profile of a engine running</skos:example>
        <annotation:adaptedFrom>axiom label in BFO2 Reference (094-005) in http://purl.obolibrary.org/obo/BFO_0000144 from BFO 2.0</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>∀x, y (processProfileOf(x,y) → (properOccurrentPartOf(x,y) ∧ ∃z, t (properOccurrentPartOf(z,y) ∧ TemporalRegion(t) ∧ occupiesSpatioTemporalRegion(x,t) ∧ occupiesSpatioTemporalRegion(y,t) ∧ occupiesSpatioTemporalRegion(z,t) ∧ ¬∃w(occurrentPartOf(w,x) ∧ occurrentPartOf(w,z)))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between a process profile and a process that it is part of such that the source process is a proper part of the target process and is temporally coextensive with another proper part of the target process that is mutually dependent on it and shares no parts with it.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>if x is &apos;process profile of&apos; y, then x is a &apos;proper occurrent part of&apos; y that shares a &apos;spatiotemporal region&apos; with some other &apos;proper occurrent part&apos; z of y such that x and z have no common &apos;occurrent part&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/qualityOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/qualityOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">quality of</rdfs:label>
        <skos:example xml:lang="en-us">this red color is a quality of this apple</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000080</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>qualityOf(x,y) → Quality(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a quality to an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x disposition of y holds when x is a &apos;quality&apos; and y is a &apos;independent continuant&apos; and x is &apos;inheres in&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/recognizedByAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/recognizedByAtSomeTime">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">recognized by at some time</rdfs:label>
        <skos:example xml:lang="en-us">a failure event is recognized by an operator that results in information about the event such as the time of occurrence and the description about the failure; a defect on a part is recognized by a quality control engineer that results in information about the defect such as the nature of the defect and the cause of the defect</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to an agent that is able to describe the entity or is able to associate an information content entity that describes the entity, at some time</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">recognizes at some time</rdfs:label>
        <skos:example xml:lang="en-us">operator recognizes a failure event that results in information about the event such as the time of occurrence and the description about the failure, a quality control engineer recognizes a defect on a part that results in information about the defect such as the nature of the defect and the cause of the defect</skos:example>
        <annotation:explanatoryNote>Recognition is preceded by an observation of an entity that is related to the entity being recognized or the entity being recognized is an entity that is an attribute of the entity being observed</annotation:explanatoryNote>
        <annotation:explanatoryNote>this property was not put under participates in at some time because the target of recognition can be continuant or an occurent and in the case of an occurent an agent that recognizes the occurent might not participate in that occurent</annotation:explanatoryNote>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an agent to an entity that the agent is able to describe the entity or is able to associate an information content entity that describes the entity, at some time</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/requirementSatisfiedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/requirementSatisfiedBy">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">requirement satisfied by</rdfs:label>
        <skos:example xml:lang="en-us">a UML requirement specification is satisfied by a a piece of software; functional requirement specification of a car is satisfied by its desgn specification</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a requirement specification to an entity that conforms to the requirement specification</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/roleOf -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/roleOf">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000197"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">role of</rdfs:label>
        <skos:example xml:lang="en-us">this investigator role is a role of this person</skos:example>
        <annotation:adaptedFrom>http://purl.obolibrary.org/obo/RO_0000081</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>roleOf(x,y) → Role(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from a role to an independent continuant (the bearer), in which the role specifically depends on the bearer for its existence</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>x disposition of y holds when x is a &apos;role&apos; and y is a &apos;independent continuant&apos; and x is &apos;inheres in&apos; y</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">satisfies requirement</rdfs:label>
        <skos:example xml:lang="en-us">a piece of software satisfies a UML requirement specification, a design specification of a car satisfies its functional requirement specification</skos:example>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation from an entity to a requirement specification that the entity conforms to</annotation:naturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/specializes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/specializes">
        <rdfs:subPropertyOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/denotedBy"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy>https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">specializes</rdfs:label>
        <annotation:explanatoryNote>See the expanded formalization and explanation under generalizes</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>specializes(c1, c2) ↔ generalizes(c2, c1)</annotation:firstOrderLogicDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation between two classifiers such that everything classified by the former is also classified by the latter</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition>c1 is &apos;specializes&apos; c2 iff c2 generalizes c1</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/temporallyFinishedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/temporallyFinishedBy">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/temporallyFinishes"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">temporally finished by</rdfs:label>
        <skos:example xml:lang="en-us">A delivery process is temporally finished by the generation of “proof of delivery”; a football match is temporally finished by the Referee’s final whistle; every week is temporally finished by a Sunday.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>temporallyFinishedBy(x,y) ↔ temporallyFinishes(y,x)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the last instant of the temporal extent of j is the same as the last instant of the temporal extent of i and the first instant of i is preceded by the first instant of j</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>&apos;temporally finished by&apos; and &apos;temporally finishes&apos; are inverse relations</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/temporallyFinishes -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/temporallyFinishes">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">temporally finishes</rdfs:label>
        <skos:example xml:lang="en-us">The generation of “proof of delivery” temporally finishes the delivery process; Referee’s final whistle temporally finishes the football match; Sunday temporally finishes the week.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>LA1: temporallyFinishes(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ temporallyFinishes(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ occursSimultaneouslyWith(i2,j2) ∧ precedes(j1,i1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: Process(i) ∧ Process(j) ∧ temporallyFinishes(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ temporallyFinishes(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA4: temporallyFinishes(i,j) ↔ ∃k∃l(meets(i,k)∧meets(j,k) ∧ before(l,i) ∧ meets(l,j))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is the same as the last instant of the temporal extent of j and the first instant of j precedes the first instant of i</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If i &apos;temporally finishes&apos; j then either both are &apos;temporal intervals&apos; or both are &apos;process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If both i and j are &apos;temporal intervals&apos; and i &apos;temporally finishes&apos; j then the &apos;last instant’ of i ‘occurs simultaneously with’ the &apos;last instant of&apos; j and the &apos;first instant of&apos; j &apos;precedes&apos; the &apos;first instant’ of i</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: If both i and j are &apos;process&apos; and i &apos;temporally finishes&apos; j then the &apos;temporal interval&apos; that i occupies &apos;temporally finishes&apos; the &apos;temporal interval&apos; that j occupies</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA4: i &apos;temporally finishes&apos; j if and only if there exists k such that i &apos;meets&apos; k and j &apos;meets&apos; k, and there exists l that is &apos;before&apos; i and &apos;meets&apos; j</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps">
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">temporally overlaps</rdfs:label>
        <skos:example xml:lang="en-us">When two plates are being welded at a joint, the cooling of a previously welded point temporally overlaps the heating of the point which is currently being welded; the sending process temporally overlaps the receiving process in a transaction process; Ancient Egyptian civilization (c. 3000 BCE - 30 BCE) temporally overlapped the Sumerian civilization (c. 3500 BCE - c. 2000 BCE) in Mesopotamia and the Indus Valley Civilization (c. 2600 BCE - c. 1900 BCE) in South Asia.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>LA1: temporallyOverlaps(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ temporallyOverlaps(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ precedes(j1,i2) ∧ precedes(i1,j1) ∧ precedes(i2,j2))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: Process(i) ∧ Process(j) ∧ temporallyOverlaps(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ temporallyOverlaps(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA4: temporallyOverlaps(i,j) ↔ ∃k(temporallyFinishes(k,i) ∧ starts(k,j))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals and processes i and j when the first instant of the temporal extent of i is earlier than and the last instant of the temporal extent of i is later than the first instant of the temporal extent of j, and the last instance of the temporal extent of i is earlier than the last instant of the temporal extent of j</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If i &apos;temporally overlaps&apos; j then either both are &apos;temporal intervals&apos; or both are &apos;process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If both i and j are &apos;temporal intervals&apos; and i &apos;temporally overlaps&apos; j then the &apos;first instant’ of j ‘precedes’ the &apos;last instant of&apos; i and the &apos;first instant of&apos; i ‘precedes’ the &apos;first instant’ of j and the &apos;last instant of&apos; i ‘precedes’ the &apos;last instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: If both i and j are &apos;process&apos; and i &apos;temporally overlaps&apos; j then the &apos;temporal interval&apos; that i occupies &apos;temporally overlaps&apos; the &apos;temporal interval&apos; that j occupies</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA4: i &apos;temporally overlaps&apos; j if and only if there exists k that &apos;temporally finishes&apos; i and &apos;temporally starts&apos; j</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/temporallyStartedBy -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/temporallyStartedBy">
        <owl:inverseOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/temporallyStarts"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">temporally started by</rdfs:label>
        <skos:example xml:lang="en-us">An internal combustion engine is temporally started (running) by the process of cranking; some machine is temporally started (running) by pressing a switch; every year is temporally started by the New Year’s Day.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>temporallyStartedBy(x,y) ↔ temporallyStarts(y,x)</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the first instant of the temporal extent of j is the same as first the instant of the temporal extent of i and the last instant of j precedes the last instant of i</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>&apos;temporally started by&apos; and &apos;temporally starts&apos; are inverse relations</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://spec.industrialontologies.org/ontology/construct/temporallyStarts -->

    <owl:ObjectProperty rdf:about="https://spec.industrialontologies.org/ontology/construct/temporallyStarts">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:isDefinedBy rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://spec.industrialontologies.org/ontology/core/Core/</rdfs:isDefinedBy>
        <rdfs:label xml:lang="en-us">temporally starts</rdfs:label>
        <skos:example xml:lang="en-us">the process of cranking temporally starts (the running of) an internal combustion engine; the pressing of a switch temporally starts (the running of) some machine; the New Year’s Day temporally starts a year.</skos:example>
        <annotation:adaptedFrom>https://dl.acm.org/doi/10.1145/182.358434</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>LA1: temporallyStarts(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ temporallyStarts(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ occursSimultaneouslyWith(i1,j1) ∧ precedes(i2,j2))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA3: Process(i) ∧ Process(j) ∧ temporallyStarts(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ temporallyStarts(i1,j1))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>LA4: temporallyStarts(i,j) ↔ ∃k∃l(meets(k,i) ∧ meets(k,j) ∧ before(i,l) ∧ meets(j,l))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en-us">relation that holds between two intervals or processes i and j when the first instant of the temporal extent of i is the same as first the instant of the temporal extent of j and the last instant of i precedes the last instant of j</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom>LA1: If i &apos;temporally starts&apos; j then either both are &apos;temporal intervals&apos; or both are &apos;process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA2: If both i and j are &apos;temporal intervals&apos; and i &apos;temporally starts&apos; j then the &apos;first instant’ of i ‘occurs simultaneously with’ the &apos;first instant of&apos; j and the &apos;last instant of&apos; i &apos;precedes&apos; the &apos;last instant of&apos; j</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA3: If both i and j are &apos;process&apos; and i &apos;temporally starts&apos; j then the &apos;temporal interval&apos; that i occupies &apos;temporally starts&apos; the &apos;temporal interval&apos; that j occupies</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom>LA4: i &apos;temporally starts&apos; j if and only if there exists k that &apos;meets&apos; i and j and there exists l such that i is &apos;before&apos; l and j &apos;meets&apos; l</annotation:semiFormalNaturalLanguageAxiom>
    </owl:ObjectProperty>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000002 -->

    <owl:ObjectProperty rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000002">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000056"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/BFO_0000054"/>
        </owl:propertyChainAxiom>
        <terms:source>ODR-011 §4</terms:source>
        <rdfs:comment xml:lang="pt-br">A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ∘ obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas funções projetadas.</rdfs:comment>
        <rdfs:comment xml:lang="en">The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ∘ obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">functionally participates in</rdfs:label>
        <rdfs:label xml:lang="pt-br">participa funcionalmente em</rdfs:label>
        <annotation:explanatoryNote xml:lang="pt-br">Distingue a participação mediada por função da participação geral: obo:BFO_0000056 (participa em) vale sempre que um continuante toma parte em algum processo por qualquer razão; copi:participatesIn é entailada apenas pela cadeia hasFunction ∘ BFO_0000054 (tem realização). Uma bomba participa funcionalmente em toda operação de aumento de pressão de líquido que realiza sua função de bombeamento; BFO_0000056 vale adicionalmente para qualquer outro envolvimento.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Distinguishes function-mediated from general participation: obo:BFO_0000056 (participates in) holds whenever a continuant takes part in any process for any reason; copi:participatesIn is entailed only via the chain hasFunction ∘ BFO_0000054 (has realization). A pump functionally participates in every liquid-pressure-increase operation that realizes its pumping function; BFO_0000056 additionally covers any other process involvement.</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition xml:lang="en">∀x∀y (functionallyParticipatesIn(x,y) ↔ ∃f(hasFunction(x,f) ∧ hasRealization(f,y)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ∘ obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas funções projetadas.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ∘ obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x &apos;functionally participates in&apos; y if and only if there exists a function f such that x &apos;has function&apos; f and f &apos;has realization&apos; y</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x &apos;participa funcionalmente em&apos; y se e somente se existe uma função f tal que x &apos;tem função&apos; f e f &apos;tem realização&apos; y</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ACElectricalPower -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ACElectricalPower">
        <rdfs:label xml:lang="en">a c electrical power</rdfs:label>
        <rdfs:label xml:lang="pt-br">potência elétrico de CA</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes alternating-current electrical power delivered to petroleum production equipment to drive motors, instrumentation, or control systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Absorber -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Absorber">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">absorber</rdfs:label>
        <rdfs:label xml:lang="pt-br">absorvedor</rdfs:label>
        <skos:definition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ABSORBER&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;ABSORBING&gt;</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A vertical, cylindrical vessel that recovers heavier (longer carbon chain) hydrocarbons from a mixture of lighter hydrocarbons.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A functional object that absorbs.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Absorber(x) ↔ (Separator(x) ∧ ∃f(AbsorptionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An absorber is a pressure vessel that realizes an absorption function for selective mass transfer of components from a fluid mixture into an absorbent phase.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um absorvedor é um vaso de pressão que realiza uma função de absorção para transferência seletiva de massa de componentes de uma mistura fluida para uma fase absorvente.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every absorber is a separator that has the function to absorb specific components from fluid mixtures through mass transfer to an absorbent phase</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess">
        <rdfs:label xml:lang="en">absorption process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de absorção</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which one or more gaseous components are transferred from a gas phase into a liquid absorbent phase through contact in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">accumulation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de acumulação</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the collection and temporary holding of fluid to buffer flow variations or build up inventory.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess">
        <rdfs:label xml:lang="en">accumulation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de acumulação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which fluid is collected and temporarily held in a vessel to buffer flow variations or build up inventory in a petroleum production system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AcousticTreatmentElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AcousticTreatmentElement">
        <rdfs:label xml:lang="en">acoustic treatment element</rdfs:label>
        <rdfs:label xml:lang="pt-br">elemento acústico de tratamento</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a component of petroleum production equipment designed to absorb or attenuate acoustic energy to reduce noise.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ActiveMaterial -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActiveMaterial">
        <rdfs:label xml:lang="en">active material</rdfs:label>
        <rdfs:label xml:lang="pt-br">material ativo</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a chemically or electrochemically reactive substance participating in a process reaction within petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ActuatingMechanism -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuatingMechanism">
        <rdfs:label xml:lang="en">actuating mechanism</rdfs:label>
        <rdfs:label xml:lang="pt-br">mecanismo de atuação</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the mechanical assembly that converts a control signal into physical movement to operate a valve or other device in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">actuation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de atuação</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</skos:definition>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess">
        <rdfs:label xml:lang="en">actuation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de atuação</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which a control signal or energy input is converted by an actuator into mechanical motion or force that operates or positions another piece of equipment according to control requirements.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which an actuator converts a control input signal to mechanical movement or force, enabling the positioning or operation of controlled equipment such as valves, dampers, or switches.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which an actuator converts input energy (electrical, pneumatic, or hydraulic) into mechanical motion to operate valves, dampers, or other control devices.</skos:definition>
        <skos:definition xml:lang="en">A PlannedProcess in which an actuator converts input energy into controlled mechanical motion to operate valves, dampers, or other equipment requiring remote or automated positioning.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a control signal or energy input is converted by an actuator into mechanical motion or force that operates or positions another piece of equipment according to control requirements.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an actuator converts a control input signal to mechanical movement or force, enabling the positioning or operation of controlled equipment such as valves, dampers, or switches.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an actuator converts input energy (electrical, pneumatic, or hydraulic) into mechanical motion to operate valves, dampers, or other control devices.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which an actuator converts input energy into controlled mechanical motion to operate valves, dampers, or other equipment requiring remote or automated positioning.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AgitationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AgitationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">agitation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de agitação</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the mechanical stirring of a liquid to promote mixing, suspension of solids, or heat transfer.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AgitationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AgitationProcess">
        <rdfs:label xml:lang="en">agitation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de agitação</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a liquid is mechanically stirred or agitated to promote mixing, heat transfer, or suspension of solids in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AgitatorDrive -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AgitatorDrive">
        <rdfs:label xml:lang="pt-br">acionamento de agitador</rdfs:label>
        <rdfs:label xml:lang="en">agitator drive</rdfs:label>
        <skos:definition xml:lang="en">An assembly of motor, gearbox, and shaft components that converts electrical energy into rotational motion for driving an agitator in petroleum production mixing equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AirFinSystem -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirFinSystem">
        <rdfs:label xml:lang="en">air fin system</rdfs:label>
        <rdfs:label xml:lang="pt-br">sistema de ar de aleta</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an air-cooled heat exchange system in which fans drive ambient air across finned tube surfaces to cool a process stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AirInlet -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirInlet">
        <rdfs:label xml:lang="en">air inlet</rdfs:label>
        <rdfs:label xml:lang="pt-br">entrada de ar</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an inlet port through which air enters a combustion device, air supply system, or enclosure in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AirIntake -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirIntake">
        <rdfs:label xml:lang="pt-br">admissão de ar</rdfs:label>
        <rdfs:label xml:lang="en">air intake</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the opening and duct through which combustion air or instrument air is drawn into petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AirIntakeSystem -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirIntakeSystem">
        <rdfs:label xml:lang="en">air intake system</rdfs:label>
        <rdfs:label xml:lang="pt-br">sistema de ar de admissão</rdfs:label>
        <skos:definition xml:lang="en">An assembly of filters, ducts, and silencers that conditions and delivers combustion air to a gas turbine or engine in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AirOutlet -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirOutlet">
        <rdfs:label xml:lang="en">air outlet</rdfs:label>
        <rdfs:label xml:lang="pt-br">saída de ar</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an opening or port through which air is discharged from petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AirPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirPortion">
        <rdfs:label xml:lang="en">air portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção de ar</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of air participating as an oxidant, carrier, or motive fluid in a petroleum production process.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AirSupplySystem -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AirSupplySystem">
        <rdfs:label xml:lang="en">air supply system</rdfs:label>
        <rdfs:label xml:lang="pt-br">sistema de ar de suprimento</rdfs:label>
        <skos:definition xml:lang="en">An assembly of compressors, dryers, filters, and distribution piping that provides instrument or utility air to petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AlternatingCurrentPortion -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AlternatingCurrentPortion">
        <rdfs:label xml:lang="en">alternating current portion</rdfs:label>
        <rdfs:label xml:lang="pt-br">porção alternado de corrente</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a portion of alternating electrical current flowing in a circuit of petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AlternatingElectricalCurrent -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AlternatingElectricalCurrent">
        <rdfs:label xml:lang="en">alternating electrical current</rdfs:label>
        <rdfs:label xml:lang="pt-br">corrente alternado elétrico</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an alternating electrical current that periodically reverses direction and is used to power petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AnalogueDial -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AnalogueDial">
        <rdfs:label xml:lang="en">analogue dial</rdfs:label>
        <rdfs:label xml:lang="pt-br">mostrador analógico</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an analogue display element with a graduated scale and pointer that indicates the value of a measured variable in petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">anode function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de proteção anódica</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the supply of electrons to a cathodic protection circuit to prevent corrosion of a protected metallic structure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AutomaticTransferMechanism -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AutomaticTransferMechanism">
        <rdfs:label xml:lang="en">automatic transfer mechanism</rdfs:label>
        <rdfs:label xml:lang="pt-br">mecanismo automático de transferência</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the mechanical or electrical assembly that automatically transfers an electrical load from one power source to another.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe">
        <rdfs:label xml:lang="en">axial displacement measuring probe</rdfs:label>
        <rdfs:label xml:lang="pt-br">sonda axial de deslocamento de medição</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a proximity probe that measures the axial displacement of a rotating shaft in petroleum production rotating equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">axial displacement transmission function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transmissão de deslocamento axial</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement of axial displacement of a rotating shaft and the transmission of the corresponding signal to a monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess">
        <rdfs:label xml:lang="en">axial displacement transmission process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transmissão de deslocamento axial</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which the axial displacement of a rotating shaft is measured and the corresponding signal transmitted to a remote monitoring system.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess">
        <rdfs:label xml:lang="en">backflow prevention process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de prevenção de refluxo</rdfs:label>
        <skos:definition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BackupEnergyStorage -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BackupEnergyStorage">
        <rdfs:label xml:lang="pt-br">armazenamento de reserva de energia</rdfs:label>
        <rdfs:label xml:lang="en">backup energy storage</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an energy storage device—battery or capacitor bank—that provides reserve electrical energy to critical petroleum production systems during a power failure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BasinFloor -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BasinFloor">
        <rdfs:label xml:lang="en">basin floor</rdfs:label>
        <rdfs:label xml:lang="pt-br">piso de bacia</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the floor structure of a basin or containment pond in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BasinWall -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BasinWall">
        <rdfs:label xml:lang="en">basin wall</rdfs:label>
        <rdfs:label xml:lang="pt-br">parede de bacia</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a wall structure forming the boundary of a basin or containment area in a petroleum production installation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BearingSystem -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BearingSystem">
        <rdfs:label xml:lang="en">bearing system</rdfs:label>
        <rdfs:label xml:lang="pt-br">sistema de mancal</rdfs:label>
        <skos:definition xml:lang="en">An assembly of bearings, housings, and lubrication components that support and reduce friction of rotating shafts in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BentPipeSection -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BentPipeSection">
        <rdfs:label xml:lang="en">bent pipe section</rdfs:label>
        <rdfs:label xml:lang="pt-br">seção curvado de tubo</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a curved section of pipe that changes the direction of fluid flow in petroleum production piping systems.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033"/>
        <rdfs:label xml:lang="en">binary flow control process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de controle binário de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A process-controlled flow process in which a flow path is completely opened or closed to allow or prevent fluid passage through petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BitSub -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BitSub">
        <rdfs:label xml:lang="en">bit sub</rdfs:label>
        <rdfs:label xml:lang="pt-br">sub de broca</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a short threaded sub connecting the drill bit to the bottom hole assembly in a petroleum production drilling string.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BoilingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BoilingFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">boiling function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de ebulição</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the conversion of a liquid into vapour by supplying heat at or above the liquid&apos;s boiling point.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess">
        <rdfs:label xml:lang="en">boiling process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de ebulição</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a liquid is converted into vapour by supplying thermal energy at or above its boiling point in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BoltHole -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BoltHole">
        <rdfs:label xml:lang="en">bolt hole</rdfs:label>
        <rdfs:label xml:lang="pt-br">furo de parafuso</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a hole in a flange, frame, or structural element through which a bolt is inserted to create a mechanical joint in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">bottom hole drilling function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de perfuração de fundo de poço</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the cutting and disintegration of subsurface rock at the bottom of a wellbore to advance the drill hole.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess">
        <rdfs:label xml:lang="en">bottom hole drilling process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de perfuração de fundo de poço</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which subsurface rock at the bottom of a wellbore is cut and disintegrated by a drill bit to advance the drill hole.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BottomOutlet -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BottomOutlet">
        <rdfs:label xml:lang="en">bottom outlet</rdfs:label>
        <rdfs:label xml:lang="pt-br">saída de fundo</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an outlet at the base of a vessel through which heavy phase fluid or settled solids are discharged in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor">
        <rdfs:label xml:lang="en">braided conductor</rdfs:label>
        <rdfs:label xml:lang="pt-br">condutor de trançado</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes an electrical conductor composed of braided or stranded wires providing flexibility and mechanical strength in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BrakingElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BrakingElement">
        <rdfs:label xml:lang="en">braking element</rdfs:label>
        <rdfs:label xml:lang="pt-br">elemento de frenagem</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the component that applies a retarding force to decelerate or hold stationary a rotating element in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BrakingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BrakingFunction">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">braking function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de frenagem</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the application of a retarding force to decelerate or hold stationary a rotating or translating mechanical component.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess">
        <rdfs:label xml:lang="en">braking process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de frenagem</rdfs:label>
        <skos:definition xml:lang="en">A planned process in which a retarding force is applied to decelerate or hold stationary a rotating or translating mechanical component in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BranchPort -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BranchPort">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FluidPort"/>
        <rdfs:label xml:lang="pt-br">bocal de ramal</rdfs:label>
        <rdfs:label xml:lang="en">branch port</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a branch outlet port on a manifold or pipe fitting through which flow is diverted to a secondary flow path.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/BurnerTip -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/BurnerTip">
        <rdfs:label xml:lang="en">burner tip</rdfs:label>
        <rdfs:label xml:lang="pt-br">ponta de queimador</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes the terminal component of a burner through which fuel is discharged and ignited in petroleum production combustion equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001">
        <terms:source>ODR-009 Amendment A (2026-06-18): copi:Operation as explicit root universal; genus correction to iof-constr:PlannedProcess</terms:source>
        <rdfs:comment xml:lang="en">A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">operation</rdfs:label>
        <rdfs:label xml:lang="pt-br">operação</rdfs:label>
        <annotation:firstOrderLogicAxiom>∀x (Operation(x) → PlannedProcess(x))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Root universal for process-industry unit operations in the chemical-engineering tradition (cf. each category&apos;s adaptedFrom). Members share a typed participation signature (material inputs/outputs) and differ by transformation effected; no single formal condition differentiates Operation from PlannedProcess in OWL — the differentia is OWL-inexpressible, standard for a BFO primitive. (ODR-009 Amendment A, 2026-06-18)</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Universal raiz para operações unitárias de indústria de processo na tradição da engenharia química (cf. adaptedFrom de cada categoria). Os membros compartilham uma assinatura de participação tipada (entradas/saídas materiais) e diferem pela transformação efetuada; nenhuma condição formal única diferencia Operation de PlannedProcess em OWL — a diferença é inexpressível em OWL, padrão para um primitivo BFO. (ODR-009 Emenda A, 2026-06-18)</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is an &apos;operation&apos; then x is a &apos;planned process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;operação&apos; então x é um &apos;processo planejado&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>Bird, Stewart &amp; Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part I: momentum transport.</terms:source>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">momentum transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de quantidade de movimento</rdfs:label>
        <skos:example xml:lang="pt-br">Elevar a pressão de um líquido de processo; comprimir um gás; circular uma lama.</skos:example>
        <skos:example xml:lang="en">Raising the pressure of a process liquid; compressing a gas; circulating a slurry.</skos:example>
        <annotation:adaptedFrom>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering (fluid-flow operations).</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en">Includes pressure-raising operations on liquids and gases, and bulk transport/mixing. Its leaf operations LiquidPressureIncrease and GasPressureIncrease are disjoint.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Inclui operações de aumento de pressão de líquidos e gases, e transporte/mistura globais. Suas operações folha LiquidPressureIncrease e GasPressureIncrease são disjuntas.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>∀x (MomentumTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">A unit-operations class grounded in the McCabe-Smith-Harriott tradition; its members share a typed-participation envelope but no single formally necessary-and-sufficient differentia, so only the envelope is asserted in OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Uma classe de operações unitárias fundamentada na tradição de McCabe-Smith-Harriott; seus membros compartilham um envelope de participação tipada mas nenhuma diferença formal necessária-e-suficiente única, de modo que apenas o envelope é asserido em OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;momentum transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de quantidade de movimento&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>Bird, Stewart &amp; Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part II: energy transport.</terms:source>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">heat transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de calor</rdfs:label>
        <skos:example xml:lang="pt-br">Aquecimento sensível de uma corrente de processo contra uma utilidade quente.</skos:example>
        <skos:example xml:lang="en">Sensible heating of a process stream against a hot utility.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (HeatTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a constância de fase e de identidade química que distingue a transferência de calor sensível não é capturada em OWL, de modo que apenas o envelope é asserido.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the constancy of phase and chemical identity that distinguishes sensible heat transfer is not captured in OWL, so only the envelope is asserted.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;heat transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de calor&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>Bird, Stewart &amp; Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part III: mass transport.</terms:source>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">mass transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de massa</rdfs:label>
        <skos:example xml:lang="en">Absorption of a gas component into a liquid solvent; stripping; distillation.</skos:example>
        <skos:example xml:lang="pt-br">Absorção de um componente gasoso em um solvente líquido; esgotamento (stripping); destilação.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (MassTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico).</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a migração interfásica que individua seus membros é declarada para folhas específicas (e.g. GasAbsorption) mas não no nível da categoria em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the inter-phase migration that individuates its members is stated for specific leaves (e.g. GasAbsorption) but not at the category level in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;mass transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de massa&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">mechanical separation</rdfs:label>
        <rdfs:label xml:lang="pt-br">separação mecânica</rdfs:label>
        <skos:example xml:lang="pt-br">Separação gravitacional trifásica; separação ciclônica; filtração; centrifugação.</skos:example>
        <skos:example xml:lang="en">Three-phase gravity separation; cyclonic separation; filtration; centrifugation.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (MechanicalSeparation(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a separação de uma alimentação heterogênea por força mecânica não é formalizada em OWL além do envelope.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the partition of a heterogeneous feed by mechanical force is not formalised in OWL beyond the envelope.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;mechanical separation&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;separação mecânica&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000007 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000007">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process in which chemical species are consumed and new species, present in no input, are formed.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">chemical reaction</rdfs:label>
        <rdfs:label xml:lang="pt-br">reação química</rdfs:label>
        <skos:example xml:lang="en">Fermentation of sugars to ethanol; combustion; catalytic conversion.</skos:example>
        <skos:example xml:lang="pt-br">Fermentação de açúcares a etanol; combustão; conversão catalítica.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (ChemicalReaction(x) → Process(x) ∧ ∃o,c(hasOutput(x,o) ∧ hasConstituent(o,c) ∧ ¬∃i,c1(hasInput(x,i) ∧ hasConstituent(i,c1) ∧ sameSubstance(c1,c))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which chemical species are consumed and new species, present in no input, are formed.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de processo unitário; a formação de uma espécie genuinamente nova é parcialmente caracterizada em FOL mas apenas o gênero é asserido em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-process class; the formation of a genuinely new species is partly characterised in FOL but only the genus is asserted in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;chemical reaction&apos; then x is a &apos;process&apos; whose output has a constituent substance that no input has</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;reação química&apos; então x é um &apos;processo&apos; cuja saída tem uma substância constituinte que nenhuma entrada possui</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process that changes the physical state (phase) of a material without changing its chemical identity.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">mudança de fase</rdfs:label>
        <rdfs:label xml:lang="en">phase change</rdfs:label>
        <skos:example xml:lang="en">Evaporation; condensation; crystallisation.</skos:example>
        <skos:example xml:lang="pt-br">Evaporação; condensação; cristalização.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (PhaseChange(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that changes the physical state (phase) of a material without changing its chemical identity.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a mudança de fase a identidade química constante é declarada para folhas (e.g. Vaporization) mas não no nível da categoria em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the change of phase at constant chemical identity is stated for leaves (e.g. Vaporization) but not at category level in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;phase change&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;mudança de fase&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process that maintains a contained material&apos;s state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">contenção de material</rdfs:label>
        <rdfs:label xml:lang="en">material containment</rdfs:label>
        <skos:example xml:lang="pt-br">Armazenar petróleo cru em um tanque; amortecer líquido em um tambor de surto.</skos:example>
        <skos:example xml:lang="en">Holding crude in a storage tank; buffering liquid in a surge drum.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (MaterialContainment(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that maintains a contained material&apos;s state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação).</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Auxiliary category retained because all plant equipment must be classifiable; the input=output identity is the limiting characterisation, not a transformation.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Categoria auxiliar mantida porque todo equipamento de planta deve ser classificável; a identidade entrada=saída é a caracterização-limite, não uma transformação.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;material containment&apos; then x is a &apos;process&apos; that &apos;has input&apos; and &apos;has output&apos; the same &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;contenção de material&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; e &apos;tem saída&apos; a mesma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process that modulates a flow without changing the material&apos;s substance, phase, or composition.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">controle de fluxo</rdfs:label>
        <rdfs:label xml:lang="en">flow control</rdfs:label>
        <skos:example xml:lang="pt-br">Estrangular uma corrente por uma válvula de controle; isolar por uma válvula de bloqueio; aliviar sobrepressão.</skos:example>
        <skos:example xml:lang="en">Throttling a stream through a control valve; isolating via a shutoff valve; relieving overpressure.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (FlowControl(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that modulates a flow without changing the material&apos;s substance, phase, or composition.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Auxiliary category; the conservation of substance/phase/composition under modulation is the characterisation and is not a material transformation.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Categoria auxiliar; a conservação de substância/fase/composição sob modulação é a caracterização e não é uma transformação material.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;flow control&apos; then x is a &apos;process&apos; that conserves the substance, phase and composition of its material participant</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;controle de fluxo&apos; então x é um &apos;processo&apos; que conserva a substância, a fase e a composição de seu participante material</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000011 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000011">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012"/>
        <terms:source>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, pumping).</terms:source>
        <terms:source>ODR-011</terms:source>
        <rdfs:comment xml:lang="en">A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid&apos;s pressure.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">aumento de pressão de líquido</rdfs:label>
        <rdfs:label xml:lang="en">liquid pressure increase</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfLiquid"/>
        <annotation:firstOrderLogicDefinition>∀x (LiquidPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Liquid(m)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid&apos;s pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL 2 DL cannot express the phase constraint on the fluid input; the OWL form asserts only the genus (MomentumTransfer). The disjointness with GasPressureIncrease is asserted to carry the pump/compressor partition.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">OWL 2 DL não consegue expressar a restrição de fase sobre a entrada fluida; a forma OWL assere apenas o gênero (MomentumTransfer). A disjunção com GasPressureIncrease é asserida para sustentar a partição bomba/compressor.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;liquid pressure increase&apos; if and only if x is a &apos;momentum transfer&apos; whose fluid input is a &apos;liquid&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;aumento de pressão de líquido&apos; se e somente se x é uma &apos;transferência de quantidade de movimento&apos; cuja entrada fluida é um &apos;líquido&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
        <terms:source>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, compression).</terms:source>
        <terms:source>ODR-011</terms:source>
        <rdfs:comment xml:lang="en">A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas&apos;s pressure.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">aumento de pressão de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas pressure increase</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfGas"/>
        <annotation:firstOrderLogicDefinition>∀x (GasPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃g(Gas(g) ∧ hasInput(x,g)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Gas(m)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas&apos;s pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As for LiquidPressureIncrease: the phase constraint is not expressible in OWL 2 DL; only the genus is asserted.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Como em LiquidPressureIncrease: a restrição de fase não é expressável em OWL 2 DL; apenas o gênero é asserido.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;gas pressure increase&apos; if and only if x is a &apos;momentum transfer&apos; whose fluid input is a &apos;gas&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;aumento de pressão de gás&apos; se e somente se x é uma &apos;transferência de quantidade de movimento&apos; cuja entrada fluida é um &apos;gás&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000013 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000013">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005"/>
        <terms:source>Green &amp; Southard (eds.), Perry&apos;s Chemical Engineers&apos; Handbook, 9th ed. §14 (absorption and stripping).</terms:source>
        <terms:source>ODR-011</terms:source>
        <rdfs:comment xml:lang="en">A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">absorção de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas absorption</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Absorption"/>
        <annotation:adaptedFrom>Treybal, Mass-Transfer Operations.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀p (GasAbsorption(p) ↔ MassTransfer(p) ∧ ∃g,l,l2,c(hasInput(p,g) ∧ Gas(g) ∧ hasInput(p,l) ∧ Liquid(l) ∧ hasOutput(p,l2) ∧ Liquid(l2) ∧ derivesFrom(l2,l) ∧ hasConstituent(g,c) ∧ ¬∃c1(hasConstituent(l,c1) ∧ sameSubstance(c1,c)) ∧ ∃c2(hasConstituent(l2,c2) ∧ sameSubstance(c2,c))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Although a full first-order definition is available, OWL 2 DL carries only the typed-participation envelope; the relational differentia (a constituent migrating gas-&gt;liquid) is FOL-only.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o envelope de participação tipada; a diferença relacional (um constituinte migrando gás-&gt;líquido) é apenas-FOL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;gas absorption&apos; if and only if x is a &apos;mass transfer&apos; in which a substance carried by the input gas, absent from the input solvent, is a constituent of the output liquid</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;absorção de gás&apos; se e somente se x é uma &apos;transferência de massa&apos; na qual uma substância transportada pelo gás de entrada, ausente do solvente de entrada, é constituinte do líquido de saída</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000014 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000014">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008"/>
        <terms:source>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §16 (evaporation).</terms:source>
        <terms:source>ODR-011</terms:source>
        <rdfs:comment xml:lang="en">A phase-change operation in which a liquid input is converted to a vapour output.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">vaporization</rdfs:label>
        <rdfs:label xml:lang="pt-br">vaporização</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Vaporization"/>
        <annotation:firstOrderLogicDefinition>∀x (Vaporization(x) ↔ PhaseChange(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∃v(Vapour(v) ∧ hasOutput(x,v) ∧ derivesFrom(v,l)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A phase-change operation in which a liquid input is converted to a vapour output.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL 2 DL carrega apenas o gênero (PhaseChange); a derivação líquido-para-vapor é apenas-FOL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL 2 DL carries only the genus (PhaseChange); the liquid-to-vapour derivation is FOL-only.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;vaporization&apos; if and only if x is a &apos;phase change&apos; whose liquid input gives rise to a vapour output</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;vaporização&apos; se e somente se x é uma &apos;mudança de fase&apos; cuja entrada líquida dá origem a uma saída de vapor</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000015 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000015">
        <terms:source>ODR-009</terms:source>
        <rdfs:comment xml:lang="en">A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">loss of containment</rdfs:label>
        <rdfs:label xml:lang="pt-br">perda de contenção</rdfs:label>
        <annotation:explanatoryNote xml:lang="en">Relevant to HAZOP and failure-propagation work built over COPI.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Relevante para trabalhos de HAZOP e propagação de falhas construídos sobre o COPI.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>∀x (LossOfContainment(x) → Process(x) ∧ ¬PlannedProcess(x))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Included to make the bfo:Process rooting concrete: the same boundary-failure kind is failure-relevant (ISO 14224) and cannot be a PlannedProcess; a planned-only hierarchy would exclude it.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Incluída para tornar concreta a ancoragem em bfo:Process: o mesmo tipo de falha de barreira é relevante para falhas (ISO 14224) e não pode ser um PlannedProcess; uma hierarquia só-planejada o excluiria.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;loss of containment&apos; then x is a &apos;process&apos; and x is not a &apos;planned process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;perda de contenção&apos; então x é um &apos;processo&apos; e x não é um &apos;processo planejado&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000016 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000016">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a momentum-transfer operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de quantidade de movimento</rdfs:label>
        <rdfs:label xml:lang="en">momentum-transfer device</rdfs:label>
        <skos:example xml:lang="pt-br">bomba, compressor, ventilador, tubo, misturador</skos:example>
        <skos:example xml:lang="en">pump, compressor, fan, pipe, mixer</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition (McCabe-Smith-Harriott); cross-checked against IEC 81346-2 codes G, M, W and ISO 14224 Annex A.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en">A dispersive (defined) category; a leaf declaring only its designed function is automatically classified here by the reasoner. Not asserted disjoint from the other equipment categories (selective partition).</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Uma categoria dispersiva (definida); uma folha que declara apenas sua função projetada é classificada aqui automaticamente pelo reasoner. Não asserida disjunta das demais categorias de equipamento (partição seletiva).</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>∀x (MomentumTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MomentumTransfer(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a momentum-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;momentum-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;momentum transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de quantidade de movimento&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de quantidade de movimento&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a heat-transfer operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de calor</rdfs:label>
        <rdfs:label xml:lang="en">heat-transfer device</rdfs:label>
        <skos:example xml:lang="en">shell-and-tube exchanger, fired heater, reboiler</skos:example>
        <skos:example xml:lang="pt-br">trocador casco-e-tubo, aquecedor a fogo direto, refervedor</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 codes E, V.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">Categoria definida; um artefato que porta uma função secundária (e.g. um refervedor que também vaporiza) adquire pertinências adicionais de categoria -- intencional, não um defeito.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Defined category; an artifact bearing a secondary function (e.g. a reboiler that also vaporizes) acquires additional category memberships -- intended, not a defect.</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>∀x (HeatTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(HeatTransfer(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a heat-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;heat-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;heat transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de calor&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de calor&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000018 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000018">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a mass-transfer operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de massa</rdfs:label>
        <rdfs:label xml:lang="en">mass-transfer device</rdfs:label>
        <skos:example xml:lang="en">absorber, stripper, distillation column, adsorber</skos:example>
        <skos:example xml:lang="pt-br">absorvedor, esgotador, coluna de destilação, adsorvedor</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (MassTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MassTransfer(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a mass-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;mass-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;mass transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de massa&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de massa&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000019 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000019">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a mechanical-separation operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de separação mecânica.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de separação mecânica</rdfs:label>
        <rdfs:label xml:lang="en">mechanical-separation device</rdfs:label>
        <skos:example xml:lang="pt-br">separador trifásico, ciclone, filtro, centrífuga</skos:example>
        <skos:example xml:lang="en">three-phase separator, cyclone, filter, centrifuge</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (MechanicalSeparationDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MechanicalSeparation(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a mechanical-separation operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de separação mecânica.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;mechanical-separation device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;mechanical separation&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de separação mecânica&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;separação mecânica&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000020 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000020">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a chemical-reaction operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de reação química.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">chemical reactor</rdfs:label>
        <rdfs:label xml:lang="pt-br">reator químico</rdfs:label>
        <skos:example xml:lang="en">CSTR, plug-flow reactor, fixed-bed catalytic reactor</skos:example>
        <skos:example xml:lang="pt-br">CSTR, reator de fluxo pistonado, reator catalítico de leito fixo</skos:example>
        <annotation:adaptedFrom>Unit-process tradition; ISO 14224 Annex A; IEC 81346-2 code H.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (ChemicalReactor(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(ChemicalReaction(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a chemical-reaction operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de reação química.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;chemical reactor&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;chemical reaction&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;reator químico&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;reação química&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000021 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000021">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a phase-change operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de mudança de fase.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de mudança de fase</rdfs:label>
        <rdfs:label xml:lang="en">phase-change device</rdfs:label>
        <skos:example xml:lang="pt-br">evaporador, condensador, cristalizador</skos:example>
        <skos:example xml:lang="en">evaporator, condenser, crystalliser</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (PhaseChangeDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(PhaseChange(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a phase-change operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de mudança de fase.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;phase-change device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;phase change&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de mudança de fase&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;mudança de fase&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a material-containment operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de contenção de material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">containment device</rdfs:label>
        <rdfs:label xml:lang="pt-br">dispositivo de contenção</rdfs:label>
        <skos:example xml:lang="en">storage tank, pressure vessel, accumulator</skos:example>
        <skos:example xml:lang="pt-br">tanque de armazenamento, vaso de pressão, acumulador</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A; IEC 81346-2 code C.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (ContainmentDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MaterialContainment(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a material-containment operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de contenção de material.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;containment device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;material containment&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de contenção&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;contenção de material&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a flow-control operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de controle de fluxo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de controle de fluxo</rdfs:label>
        <rdfs:label xml:lang="en">flow-control device</rdfs:label>
        <skos:example xml:lang="en">control valve, shutoff valve, relief valve</skos:example>
        <skos:example xml:lang="pt-br">válvula de controle, válvula de bloqueio, válvula de alívio</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A; IEC 81346-2 codes Q, R, F.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (FlowControlDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(FlowControl(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a flow-control operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de controle de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;flow-control device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;flow control&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de controle de fluxo&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; algum &apos;controle de fluxo&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024">
        <terms:source>ODR-011</terms:source>
        <terms:source>ODR-012</terms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in an iof-constr:MeasurementProcess (a planned process yielding an information output).</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em um iof-constr:MeasurementProcess (um processo planejado que produz uma saída informacional).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">instrumento de medição</rdfs:label>
        <rdfs:label xml:lang="en">measurement instrument</rdfs:label>
        <skos:example xml:lang="en">temperature/pressure/flow/level transmitter, composition analyzer</skos:example>
        <skos:example xml:lang="pt-br">transmissor de temperatura/pressão/vazão/nível, analisador de composição</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A; IEC 81346-2 code B.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">A medição distingue-se das categorias de transformação por produzir uma saída informacional em vez de material; reutiliza iof-constr:MeasurementProcess em vez de cunhar um processo COPI.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Measurement stands apart from the transformation categories in yielding an informational rather than a material output; it reuses iof-constr:MeasurementProcess instead of minting a COPI process.</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>∀x (MeasurementInstrument(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MeasurementProcess(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in an iof-constr:MeasurementProcess (a planned process yielding an information output).</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em um iof-constr:MeasurementProcess (um processo planejado que produz uma saída informacional).</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;measurement instrument&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;measurement process&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;instrumento de medição&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; algum &apos;processo de medição&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a MaterialContainment process; the function of holding a fluid or solid material within a bounded volume.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">containment function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a MaterialContainment process; the function of holding a fluid or solid material within a bounded volume.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a FlowControl process; the function of modulating, regulating, or blocking fluid flow through a conduit or vessel connection.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow control function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a FlowControl process; the function of modulating, regulating, or blocking fluid flow through a conduit or vessel connection.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a ProcessControlledFlowProcess; the function of opening or shutting a flow path in response to an external process control signal.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">process-controlled flow function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a ProcessControlledFlowProcess; the function of opening or shutting a flow path in response to an external process control signal.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028">
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a Measurement process; the function of converting a physical quantity into a locally readable display at the point of measurement.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">indication function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a Measurement process; the function of converting a physical quantity into a locally readable display at the point of measurement.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029">
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a sensing or measurement process; the function of detecting and converting a physical quantity into a usable signal or reading.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">instrumentation function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a sensing or measurement process; the function of detecting and converting a physical quantity into a usable signal or reading.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
        <rdfs:comment xml:lang="en">A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">process-controlled flow process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
        <rdfs:comment xml:lang="en">A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035">
        <rdfs:comment xml:lang="en">A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036">
        <rdfs:comment xml:lang="en">A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement and transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037">
        <rdfs:comment xml:lang="en">A bounded portion of matter in a fluid state (gaseous, liquid, or supercritical) that participates in an equipment-realizing process as input, output, or transformed substance.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a fluid state (gaseous, liquid, or supercritical) that participates in an equipment-realizing process as input, output, or transformed substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039"/>
        <rdfs:comment xml:lang="en">A portion of fluid in liquid phase.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of liquid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in liquid phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:comment xml:lang="en">A portion of fluid in gaseous phase.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of gas</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in gaseous phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000040 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000040">
        <rdfs:comment xml:lang="en">A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of solid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product).</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038"/>
        <rdfs:comment xml:lang="en">A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">absorbent phase</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000042 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000042">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041"/>
        <rdfs:comment xml:lang="en">An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rich absorbent</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000043 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000043">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:comment xml:lang="en">A fluid from which target components have been removed or transferred during a treatment process.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">depleted fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid from which target components have been removed or transferred during a treatment process.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000044 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000044">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:comment xml:lang="en">A fluid portion consisting of two or more components or phases that have not yet been fully separated.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">fluid mixture</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid portion consisting of two or more components or phases that have not yet been fully separated.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045">
        <rdfs:comment xml:lang="en">An information content entity that conveys an instruction or set-point to a control device.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">control signal</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity that conveys an instruction or set-point to a control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046">
        <rdfs:comment xml:lang="en">An information content entity perceptible through visual representation at the point of measurement or display.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">visual indication</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity perceptible through visual representation at the point of measurement or display.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a temperature quality of some material entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a temperature quality of some material entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a pressure quality of some material entity or fluid.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a pressure quality of some material entity or fluid.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a flow rate quality of a fluid stream.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a flow rate quality of a fluid stream.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000050 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000050">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing a liquid level quality of a vessel or container.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a liquid level quality of a vessel or container.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000051 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000051">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Measurement information content entity describing the chemical or phase composition quality of a substance.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing the chemical or phase composition quality of a substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052">
        <rdfs:comment xml:lang="en">A quality inhering in a material entity that represents the intensity of thermal energy of that entity.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a material entity that represents the intensity of thermal energy of that entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053">
        <rdfs:comment xml:lang="en">A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054">
        <rdfs:comment xml:lang="en">A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow rate</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055">
        <rdfs:comment xml:lang="en">A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056">
        <rdfs:comment xml:lang="en">A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057">
        <rdfs:comment xml:lang="en">A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">vibration</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058">
        <rdfs:comment xml:lang="en">A quality inhering in an electrical system that represents the rate of electrical energy transfer.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">electrical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in an electrical system that represents the rate of electrical energy transfer.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000059 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000059">
        <rdfs:comment xml:lang="en">A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">mechanical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060">
        <rdfs:comment xml:lang="en">A quality inhering in a rotating element that represents the number of complete revolutions per unit time.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rotational speed</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating element that represents the number of complete revolutions per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de bombeamento</rdfs:label>
        <rdfs:label xml:lang="en">pumping function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the transfer of mechanical energy to a fluid to increase its pressure, velocity, or both.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">compression function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de compressão</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the compression of a gas stream to increase its pressure for transport, injection, or processing.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de transferência de calor</rdfs:label>
        <rdfs:label xml:lang="en">heat transfer function</rdfs:label>
        <skos:definition xml:lang="en">A DesignedFunction that is realized in a HeatTransferProcess and that consists in facilitating the transfer of thermal energy between two or more fluid media while maintaining their physical separation.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a HeatTransferProcess and that consists in facilitating the transfer of thermal energy between two or more fluid media while maintaining their physical separation.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de absorção de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas absorption function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the selective transfer of gaseous components from a gas phase into a liquid absorbent phase.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de sensoriamento de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the detection and measurement of the temperature of a process stream or equipment surface.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba</rdfs:label>
        <rdfs:label xml:lang="en">pump</rdfs:label>
        <skos:definition xml:lang="en">A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that adds or removes mechanical energy to a fluid, either constantly or periodically.</skos:definition>
        <skos:definition xml:lang="en">[DEXPI] A machine that is capable of pumping but may require parts and subsystems for that capability.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PUMP&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;PUMPING&gt; but may require parts and subsystems for that capability; including those turns it into a &lt;PUMP SYSTEM&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] IMF purpose entity</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Pump(x) ↔ (Assembly(x) ∧ ∃f (PumpingFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba é um conjunto que possui a função projetada de adicionar energia mecânica ao fluido para pressurização e transporte.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pump is an assembly that has the function of pumping fluid</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">compressor</rdfs:label>
        <rdfs:label xml:lang="pt-br">compressor</rdfs:label>
        <skos:definition xml:lang="en">A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that is driven by a prime mover by which energy is either constantly or periodically added to an amount of gas in order to increase its pressure.</skos:definition>
        <skos:definition xml:lang="en">[DEXPI] A machine that has the capability of compressing a gas.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;COMPRESSOR&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;COMPRESSING&gt; a &lt;GAS&gt;</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A type of pump that increases the pressure of gas. Commonly used as a production rate increaser by increasing the gas pressure delivered from low pressure gas wells to enter the pipe line. The intake into the compressor lowers the wellhead pressure creating a larger drawdown.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A &apos;gas pressure increase device&apos; and an &apos;artefact&apos; that is driven by a prime mover by which energy is either constantly or periodically added to an amount of gas in order to increase its pressure.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A device that raises the pressure of air or natural gas.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Compressor(x) ↔ Assembly(x) ∧ ∃f(CompressionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um compressor é um conjunto que possui a função projetada de comprimir gases através da adição de energia mecânica para aumentar sua pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every compressor is an assembly that bears a compression function and has component parts including a compressor casing, compression element, gas inlet, and gas outlet.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000074 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000074">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Shell"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Tube"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TubeBundle"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">shell and tube heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor de casco e tubos</rdfs:label>
        <skos:definition xml:lang="en">A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A tubular heat exchanger in which a tube bundle is surrounded by a shell.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SHELL AND TUBE HEAT EXCHANGER&gt; is a &lt;TUBULAR HEAT EXCHANGER&gt; in which a tube bundle is surrounded by a shell</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A tubular heat exchanger in which a tube bundle is surrounded by a shell.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">ShellAndTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃tb(TubeBundle(tb) ∧ hasComponentPartAtAllTimes(x,tb)) ∧ ∃s(Shell(s) ∧ hasComponentPartAtAllTimes(x,s) ∧ spatiallyContains(s,tb))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de casco e tubos é um trocador de calor que possui um feixe de tubos contido espacialmente dentro de um casco envolvente.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type to avoid false positives under OWA. Any equipment with a shell and tube bundle could theoretically be classified as a standard shell-and-tube heat exchanger, but specialized variants (like graphite shell-and-tube or custom multi-stream designs) should not be automatically forced into this maintenance category without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every shell and tube heat exchanger is a heat exchanger that has a tube bundle as component part and has a shell as component part, where the tube bundle is spatially contained within the shell.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000076 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000076">
        <rdfs:label xml:lang="pt-br">sensor de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensor</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that constitutes a sensing device that detects the temperature of a process stream or equipment surface and converts the measurement into an electrical signal in petroleum production instrumentation.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000023"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula</rdfs:label>
        <skos:definition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VALVE&gt; is a &lt;FLUID REGULATOR&gt; that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] Any of several valves:  plug, gate, butterfly, needle, etc., used in oil field operations.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Valve(x) ↔ MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula é um conjunto que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Might be too restrictive to define as sufficient being a material artifact and having a flow control function.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
        <rdfs:label xml:lang="en">valve body</rdfs:label>
        <skos:definition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VALVE BODY&gt; is a &lt;VALVE COMPONENT&gt; and a &lt;CONTAINER&gt; that is the main fluid or pressure containing component of a valve, housing and supporting the working components</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ValveBody(x) → ValveComponent(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃y(WorkingComponent(y) ∧ houses(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um ValveComponent que porta uma ContainmentFunction e que serve como o principal componente de contenção de fluido e pressão de uma válvula, alojando e suportando os componentes de trabalho.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type - the structural characteristics of being the main pressure-containing housing component are necessary conditions but may not be sufficient under OWA, as various specialized valve body configurations exist that might contain additional components or have hybrid designs that could lead to false positive classifications.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve body is a valve component that contains and supports valve working components and bears the function of fluid and pressure containment.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SealingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">assento</rdfs:label>
        <rdfs:label xml:lang="en">seat</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] That part of a valve against which the closure element (gate, ball) affects a tight shutoff.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Seat(x) → MaterialArtifact(x) ∧ ∃y(SealingSurface(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ValveClosingProcess(z) ∧ participatesIn(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui um componente de superfície de vedação e participa em processos de fechamento de válvulas, consistindo na parte da válvula contra a qual o elemento de fechamento se apoia para proporcionar vedação hermética.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type based on physical configuration. Under OWA, sufficient conditions for &apos;seat&apos; based solely on structural properties could lead to false positives where other valve components with sealing surfaces are incorrectly classified as seats.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every Seat is a MaterialArtifact that has some sealing surface component at all times and participates in some valve closing process.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">filter</rdfs:label>
        <rdfs:label xml:lang="pt-br">filtro</rdfs:label>
        <skos:definition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A separator intended to remove solids from vapour or liquid.</skos:definition>
        <skos:definition xml:lang="en">[DEXPI] An apparatus or machine that is capable of filtering (from ``_).</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FILTER&gt; is a  &lt;FunctionalObject&gt; that is capable of &lt;FILTERING&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A separator intended to remove solids from vapour or liquid</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A process or algorithm using a set of limits used to eliminate unwanted portions of seismic data, commonly on the basis of frequency or amplitude, to enhance the signal-to-noise ratio of the data or to achieve deconvolution.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] Devices for selecting or excluding data from a data stream or dataset.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Filter(x) ↔ (Separator(x) ∧ ∃f(FiltrationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilterElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃h(FilterHousing(h) ∧ hasComponentPartAtAllTimes(x,h))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um filtro é um separador que possui uma função de filtração para remover seletivamente constituintes indesejados de um fluxo de fluido usando um elemento filtrante dentro de um alojamento de filtro.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every filter is a separator that has a filtration function and has a filter element as component part and has a filter housing as component part</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116"/>
        <rdfs:label xml:lang="pt-br">MeasuringElement que possui uma FlowMeasurementFunction e</rdfs:label>
        <rdfs:label xml:lang="en">flow measuring element</rdfs:label>
        <skos:definition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOW MEASURING ELEMENT&gt; is  a &lt;MEASURING ELEMENT&gt; that is used to measure &lt;FLOW RATE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowMeasuringElement(x) ↔ (MeasuringElement(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MeasuringElement que possui uma FlowMeasurementFunction e que é projetado para determinar e quantificar a taxa de fluxo de fluido através de um sistema.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every FlowMeasuringElement is a MeasuringElement that bears a FlowMeasurementFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083"/>
        <rdfs:label xml:lang="pt-br">MaterialArtifact que possui uma FlowModificationFunction e</rdfs:label>
        <rdfs:label xml:lang="en">flow modification accessory</rdfs:label>
        <skos:definition xml:lang="en">A MaterialArtifact that bears a FlowModificationFunction and that is used as a component in flow control assemblies to alter the characteristics of fluid flow such as velocity profile, turbulence, or pressure distribution.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A&lt;FLOW MODIFICATION ACCESSORY&gt; is a &lt;FINAL CONTROL ASSEMBLY COMPONENT&gt; and a &lt;MODIFIER&gt; that is used to modify the characteristics of fluid flow</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowModificationAccessory(x) ↔ (MaterialArtifact(x) ∧ ∃f(FlowModificationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A MaterialArtifact that bears a FlowModificationFunction and that is used as a component in flow control assemblies to alter the characteristics of fluid flow such as velocity profile, turbulence, or pressure distribution.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um MaterialArtifact que possui uma FlowModificationFunction e que é usado como componente em conjuntos de controle de fluxo para alterar as características do fluxo de fluido, como perfil de velocidade, turbulência ou distribuição de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow modification accessory is a MaterialArtifact that bears a FlowModificationFunction and participates in processes that alter fluid flow characteristics.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparationChamber"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparatorInlet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SeparatorOutlet"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">separador</rdfs:label>
        <rdfs:label xml:lang="en">separator</rdfs:label>
        <skos:definition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A &apos;device&apos; intended to separate different types of substances.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SEPARATOR&gt; is a &lt;FunctionalObject&gt; that has a capability of &lt;SEPARATING&gt;</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A production treating vessel designed to facilitate the separation of gas, oil, and/or water from a produced fluid stream.                  Also                  The term separator in oilfield terminology designates a pressure vessel used for separating well fluids produced from oil and gas wells into gaseous and liquid components. A separator for petroleum production is a large vessel designed to separate production fluids into their constituent components of oil, gas and water. Separators include related process control components, like pneumatic controllers, and may contain a heater to enhance phase separation or prevent freezing during cold weather. A separating vessel may be referred to in the following ways: Oil and gas separator, Separator, Stage separator, Trap, Knockout vessel (Knockout drum, knockout trap, water knockout, or liquid knockout), Flash chamber (flash vessel or flash trap), Expansion separator or expansion vessel, Scrubber (gas scrubber), Filter (gas filter). These separating vessels are normally used on a producing lease or platform near the wellhead, manifold, or tank battery to separate fluids produced from oil and gas wells into oil and gas or liquid and gas. https://www.mines.edu/global-energy-future/wp-content/uploads/sites/361/2024/05/Payne_Institute_Responsible_Gas_Glossary_of_Terminology_211022_version-9.pdf</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A cylindrical or spherical vessel used to separate oil, gas and water from the total fluid stream produced by a well. Separators can be either horizontal or vertical.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Separator(x) ↔ (Vessel(x) ∧ ∃f (SeparationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um separador é um vaso que possui uma FunçãoDeSeparação - projetado para separar diferentes substâncias ou fases de uma corrente fluida mista em correntes de saída distintas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every separator is a vessel that has the function of separating mixed fluid streams into distinct phases or components.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">sight glass</rdfs:label>
        <rdfs:label xml:lang="pt-br">visor</rdfs:label>
        <skos:definition xml:lang="en">An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that is transparent and intended for viewing a vessel or piping system interior.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SIGHT GLASS&gt; is a &lt;FunctionalObject&gt; whose purpose is to enable seeing the internals of a &lt;CONTAINER&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SightGlass(x) ↔ Instrument(x) ∧ ∃f(VisualInspectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um Instrumento que porta uma VisualInspectionFunction e que consiste em uma interface de visualização transparente que permite observação óptica direta de condições internas, propriedades de fluidos ou estados de processo dentro de recipientes, vasos ou sistemas de tubulação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every sight glass is an instrument that bears a visual inspection function and enables direct optical observation of process internals through a transparent viewing interface.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MagneticCore"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PrimaryWinding"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SecondaryWinding"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TransformerCasing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">transformador</rdfs:label>
        <rdfs:label xml:lang="en">transformer</rdfs:label>
        <skos:definition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A transformer that, by electromagnetic induction, transforms a system of alternating voltage and current into another system of voltage and current usually of different values and at the same frequency for the purpose of transmitting electrical power.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TRANSFORMER&gt; is an &lt;ELECTRIC TO ELECTRIC ENERGY CONVERTER&gt; that is capable of &lt;TRANSFORMING&gt; power from one circuit to another without changing frequency and works on the principle of mutual induction</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A physical object that transforms continuous currents from one voltage to another, or continuous into alternating currents or vice versa.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Transformer(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(PrimaryWinding(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃s(SecondaryWinding(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(MagneticCore(c) ∧ hasComponentPartAtAllTimes(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transformador é um equipamento elétrico que transforma energia elétrica de um circuito para outro na mesma frequência através de indução eletromagnética usando enrolamentos e um núcleo magnético.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every transformer is an electrical equipment that bears an electrical power transformation function and has component parts including primary winding, secondary winding, and magnetic core.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle</rdfs:label>
        <skos:definition xml:lang="en">A control valve is a valve that is equipped with an actuator and regulates fluid flow rate in response to control signals from a process control system.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that can be used to modify (regulate) the fluid flow rate in a process control system. It usually includes an actuator, which responds to a signal from the controlling system and changes the position of the flow controlling element in the valve.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CONTROL VALVE&gt; is a &lt;VALVE&gt; and an &lt;FINAL CONTROL FUNCTION&gt;, operated by an &lt;ACTUATOR&gt; that can be used to modify the fluid flow rate in response to a signal from a &lt;CONTROLLER&gt;</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] Modulating valve that controls either the flow rate, liquid level, or pressure in process equipment. In the latter case, it is often referred to as a (pressure) regulator.                   (Note - Typically, high pressure gas from the pipeline is used as the supply medium needed to energize the valve actuator.) https://www.ipieca.org/resources/methane-emissions-glossary</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A valve that can be used to modify (regulate)  the fluid flow rate in a process control system. It usually includes an actuator, which responds to a signal from the controlling system and changes the position of the flow controlling element in the valve.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A valve that controls a process variable, such as pressure, flow or temperature, by modulating its opening in response to a signal from a controller.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] a device, other than a common, hand-actuated process block valve or self-actuated check valve, that directly manipulates the flow of one or more fluid process streams.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">ControlValve(x) → Valve(x) ∧ ∃a(Actuator(a) ∧ hasComponentPartAtAllTimes(x,a)) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)) ∧ ∀p(participatesIn(x,p) ∧ FlowControlProcess(p) → ∃s(ControlSignal(s) ∧ hasInput(p,s)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A control valve is a valve that is equipped with an actuator and regulates fluid flow rate in response to control signals from a process control system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle é uma válvula que é equipada com um atuador e regula a vazão de fluido em resposta a sinais de controle de um sistema de controle de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Control valve is a functional type where identity is grounded in the designed function to regulate flow in response to control signals. This functional identity cannot be reduced to structural checklists as the same function can be realized through many different physical mechanisms (ball, butterfly, globe, gate, etc.). The presence of actuator and flow control element are necessary but not sufficient - the key is the integration for automated flow modulation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every control valve is a valve that has an actuator as component part and has a flow control function and participates in flow control processes by receiving control signals and modulating fluid flow.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000088 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000088">
        <rdfs:label xml:lang="en">isolation valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de isolamento</rdfs:label>
        <skos:definition xml:lang="en">A material artifact that bears a binary flow control function whose realization constitutes the complete opening or closing of a flow path to isolate a process segment in petroleum production equipment.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000089 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000089">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
        <terms:source>Green &amp; Southard (eds.), Perry&apos;s Chemical Engineers&apos; Handbook, 9th ed. §11 (heat transfer).</terms:source>
        <terms:source>ODR-016 §A (HeatExchange leaf, Nível 2 Incremento 1a)</terms:source>
        <rdfs:comment xml:lang="en">A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de calor na qual energia térmica é trocada entre dois ou mais fluidos, tipicamente separados por uma superfície sólida de troca de calor, sem mistura dessas correntes.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">heat exchange</rdfs:label>
        <rdfs:label xml:lang="pt-br">troca de calor</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#TemperatureChange"/>
        <annotation:adaptedFrom>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §11–12 (heat transfer without/with phase change).</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (HeatExchange(x) ↔ HeatTransfer(x) ∧ ∃f1,f2,f3,f4(hasInput(x,f1) ∧ Fluid(f1) ∧ hasInput(x,f2) ∧ Fluid(f2) ∧ f1≠f2 ∧ hasOutput(x,f3) ∧ Fluid(f3) ∧ hasOutput(x,f4) ∧ Fluid(f4) ∧ f3≠f4 ∧ derivesFrom(f3,f1) ∧ derivesFrom(f4,f2) ∧ ¬∃c3(hasConstituent(f3,c3) ∧ ¬∃c1(hasConstituent(f1,c1) ∧ sameSubstance(c1,c3))) ∧ ¬∃c4(hasConstituent(f4,c4) ∧ ¬∃c2(hasConstituent(f2,c2) ∧ sameSubstance(c2,c4)))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de calor na qual energia térmica é trocada entre dois ou mais fluidos, tipicamente separados por uma superfície sólida de troca de calor, sem mistura dessas correntes.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Although a full first-order definition is available, OWL 2 DL carries only the genus (HeatTransfer); the pair-wise input–output correspondence (derivesFrom linking each output to its source input) and the cross-stream composition conservation (no constituent transferred between streams) are FOL-only constructs that exceed OWL 2 DL expressivity.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o gênero (HeatTransfer); a correspondência par-a-par entrada–saída (derivesFrom ligando cada saída à sua entrada de origem) e a conservação de composição entre correntes (nenhum constituinte transferido entre as correntes) são construtos apenas-FOL que excedem a expressividade do OWL 2 DL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;heat exchange&apos; if and only if x is a &apos;heat transfer&apos; in which two distinct fluid inputs each give rise to a corresponding fluid output of identical composition, with no constituent transferred between streams</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;troca de calor&apos; se e somente se x é uma &apos;transferência de calor&apos; na qual dois fluidos de entrada distintos dão origem cada um a um fluido de saída correspondente de composição idêntica, sem transferência de constituinte entre as correntes</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>ODR-018</terms:source>
        <rdfs:comment xml:lang="en">A closed assembly designed to hold fluids at a pressure substantially different from ambient, with a shell rated to withstand the resulting mechanical stress.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um conjunto fechado projetado para conter fluidos a uma pressão substancialmente diferente da ambiente, com casco classificado para suportar a tensão mecânica resultante.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">pressure vessel</rdfs:label>
        <rdfs:label xml:lang="pt-br">vaso de pressão</rdfs:label>
        <skos:definition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A vessel intended to withstand external and/or internal pressure</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PressureVessel(x) ↔ (Vessel(x) ∧ ∃f (PressureContainmentFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>∀x (PressureVessel(x) → Assembly(x))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A closed assembly designed to hold fluids at a pressure substantially different from ambient, with a shell rated to withstand the resulting mechanical stress.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um conjunto fechado projetado para conter fluidos a uma pressão substancialmente diferente da ambiente, com casco classificado para suportar a tensão mecânica resultante.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um vaso de pressão é um vaso que possui uma função de contenção sob pressão, projetado para suportar com segurança cargas de pressão internas e/ou externas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">A diferença estrutural de contenção de pressão (casco classificado, especificação de tensão mecânica) é expressa informalmente na NLD; OWL carrega apenas o gênero (Assembly). Axiomas estruturais são adiados ao Incremento 2b.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">The pressure-containing structural differentia (rated shell, mechanical stress specification) is expressed informally in the NLD; OWL carries only the genus (Assembly). Structural axioms are deferred to Incremento 2b.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure vessel is a vessel that has a pressure containment function, and every vessel with a pressure containment function is a pressure vessel.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;pressure vessel&apos; then x is an &apos;assembly&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;vaso de pressão&apos;, então x é um &apos;conjunto&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000024"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000029"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>ODR-018</terms:source>
        <rdfs:comment xml:lang="en">A material artifact designed to sense, measure, or indicate a physical quantity of a process stream or plant item.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material projetado para detectar, medir ou indicar uma grandeza física de uma corrente de processo ou item de planta.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">instrument</rdfs:label>
        <rdfs:label xml:lang="pt-br">instrumento</rdfs:label>
        <skos:definition xml:lang="en">An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] a device used for direct or indirect measurement, monitoring, and/or control of a variable, including primary elements, indicators, controllers, final control elements, computing devices, and electrical devices such as annunciators, switches, and pushbuttons.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Instrument(x) ↔ (Assembly(x) ∧ ∃f(InstrumentationFunction(f) ∧ hasFunction(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>∀x (Instrument(x) → MaterialArtifact(x))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact designed to sense, measure, or indicate a physical quantity of a process stream or plant item.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material projetado para detectar, medir ou indicar uma grandeza física de uma corrente de processo ou item de planta.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um instrumento é um artefato material que tem a função projetada de realizar medição, monitoramento ou controle de variáveis de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">A diferença estrutural de detecção-ou-medição é expressa informalmente na NLD; OWL carrega apenas o gênero (MaterialArtifact). O eixo estrutural (Instrument) é ortogonal ao eixo funcional (MeasurementInstrument); um artefato é ambos simultaneamente — intencional (ODR-018).</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">The sensing-or-measuring structural differentia is expressed informally in the NLD; OWL carries only the genus (MaterialArtifact). The structural axis (Instrument) is orthogonal to the functional axis (MeasurementInstrument); an artifact is both simultaneously — intended (ODR-018).</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every instrument is a material artifact that has an instrumentation function, and every material artifact that has an instrumentation function is an instrument.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is an &apos;instrument&apos; then x is a &apos;material artifact&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;instrumento&apos;, então x é um &apos;artefato material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <terms:source>ODR-018, ODR-019</terms:source>
        <rdfs:comment xml:lang="en">A pressure vessel in which two fluid circuits are separated by a solid heat-transfer surface, so that thermal energy passes between them without the circuits mixing.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um vaso de pressão no qual dois circuitos de fluido são separados por uma superfície sólida de transferência de calor, de modo que energia térmica passa entre eles sem mistura dos circuitos.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor</rdfs:label>
        <skos:definition xml:lang="en">A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that is intended to transfer heat from one object to another.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEAT EXCHANGER&gt; is an &lt;EXCHANGER&gt; that has the capability of &lt;HEAT EXCHANGING&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (HeatExchanger(x) ↔ (Assembly(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom>∀x (HeatExchanger(x) → PressureVessel(x) ∧ ∃s(SolidHeatTransferSurface(s) ∧ hasComponentPartAtAllTimes(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure vessel in which two fluid circuits are separated by a solid heat-transfer surface, so that thermal energy passes between them without the circuits mixing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor é um vaso de pressão que possui a função projetada de transferir energia térmica entre duas ou mais correntes de fluido mantendo sua separação.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um vaso de pressão no qual dois circuitos de fluido são separados por uma superfície sólida de transferência de calor, de modo que energia térmica passa entre eles sem mistura dos circuitos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">SolidHeatTransferSurface is a FOL-only predicate (no OWL IRI), analogous to Fluid and sameSubstance in operation axioms; OWL carries only the genus (PressureVessel). The two-circuit-separation and no-mixing differentia are in the NLD. Full equivalentClass axiomatisation is deferred to Incremento 2c.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">SolidHeatTransferSurface é um predicado somente-FOL (sem IRI OWL), análogo a Fluid e sameSubstance nos axiomas de operação; OWL carrega apenas o gênero (PressureVessel). A differentia de separação de dois circuitos e não-mistura está na NLD. Axiomatização plena equivalentClass adiada ao Incremento 2c.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every heat exchanger is an assembly that has the function of heat transfer and has component parts including heat transfer surfaces and fluid passages for separated streams.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;heat exchanger&apos; then x is a &apos;pressure vessel&apos; that has a &apos;solid heat-transfer surface&apos; as a component part at all times</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;trocador de calor&apos;, então x é um &apos;vaso de pressão&apos; que tem uma &apos;superfície sólida de transferência de calor&apos; como parte componente em todo momento</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000211"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">angle valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula angular</rdfs:label>
        <skos:definition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ANGLE VALVE&gt; is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; that has valve ports which are not in-line</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A variation of the globe valve in which the end connections are at right angles to each other, rather than being in line.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (AngleValve(x) → Valve(x) ∧ ∃p (hasPart(x,p) ∧ NonInlinePortArrangement(p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula angular é uma válvula que tem portas da válvula que não estão alinhadas, mas dispostas em ângulo uma em relação à outra.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive type defined by geometric configuration. Under OWA, sufficient conditions for non-inline port arrangement could lead to false positives where complex multi-port manifolds or specialized valves with angular components get incorrectly classified as standard angle valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every angle valve is a valve that has a non-inline port arrangement.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000340"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">ball control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle esférica</rdfs:label>
        <skos:definition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A ball valve that is equipped with an actuator that manipulates a stream of fluid in the response to a signal from an external sensing element and with input of energy from an external source.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BALL CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;BALL VALVE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">ball valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula esfera</rdfs:label>
        <skos:definition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A rotary valve that has a ball closure member.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BALL VALVE&gt; is a &lt;ROTARY VALVE&gt; which uses a hollow, perforated or pivoting ball, of either &quot;floating&quot; design or &quot;trunnion&quot; mounted design to provide fluid flow control. The open position is when the ball hole is in line with the flow and closed when it is pivoted 90-degrees by the stem operator</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] Any of several valves that rotate a ball with a flow passage to allow or deny flow.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A rotary valve that has a ball closure member.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A valve using a spherical closure element (ball) which is rotated through 90° to open and close the valve.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BallValve(x) → Valve(x) ∧ ∃y(BallClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(RotationalMotionProcess(z) ∧ participatesIn(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula esfera é uma válvula que controla o fluxo de fluidos usando um elemento de fechamento esférico que gira aproximadamente 90 graus para alinhar ou desalinhar sua passagem de fluxo com as portas do corpo da válvula.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by physical mechanism, sufficient conditions are omitted to avoid false positives under Open World Assumption. Complex multi-way valves or specialized equipment containing ball mechanisms should not be automatically classified as standard ball valves without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every ball valve is a valve that has a ball closure component and participates in rotational motion processes</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000096 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000096">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">block and bleed valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de bloqueio e sangria</rdfs:label>
        <skos:definition xml:lang="en">A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the block valve&apos;s bonnet.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BLOCK AND BLEED VALVE&gt; is a &lt;BLOCK VALVE&gt; and a &lt;BLEED VALVE&gt; that has one seat which provides a seal, and a bleeder line and valve that are tapped into the block valves bonnet</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(BlockAndBleedValve(x) → Valve(x) ∧ ∃s(SingleSeat(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃l(BleederLine(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃v(BleederValve(v) ∧ hasComponentPartAtAllTimes(x,v)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de bloqueio e sangria é uma válvula que possui um assento que fornece vedação, e uma linha de sangria e válvula que são conectadas ao castelo da válvula para ventilação controlada da pressão a jusante.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive types require necessary conditions only due to Open World Assumption. The structural differentia (single seat + bleeder system) could theoretically be present in specialized equipment that should not be classified as a standard block and bleed valve without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every block and bleed valve is a valve that has component parts: exactly one seat, a bleeder line, and a bleeder valve integrated into the bonnet.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">blow down valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de blow down</rdfs:label>
        <skos:definition xml:lang="en">A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that can be used for rapid depressurizing of a high pressure system.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BLOW DOWN VALVE is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; that can be used for rapid depressurizing of a high pressure system</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (BlowDownValve(x) ↔ Valve(x) ∧ ∃f (RapidDepressurizationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de blow down é uma válvula que possui uma função projetada para despressurização rápida de sistemas de alta pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every blow down valve is a valve that has the function of rapid depressurization.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000302"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">blower</rdfs:label>
        <rdfs:label xml:lang="pt-br">soprador</rdfs:label>
        <skos:definition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object intended to compress and supply air or gas at medium pressure and medium volume flow.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BLOWER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;BLOWING&gt; a medium volume flow</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A physical object intended to compress and supply air or gas at medium pressure and medium volume flow.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Blower(x) ↔ (Compressor(x) ∧ ∃f,p,v (CompressionFunction(f) ∧ bearerOf(x,f) ∧ MediumPressureRange(p) ∧ MediumVolumeFlowRange(v) ∧ hasOperatingParameter(x,p) ∧ hasOperatingParameter(x,v))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um soprador é um compressor que comprime e fornece ar ou gás em pressão média e vazão volumétrica média.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every blower is a compressor that has the function of compressing gas and operates at medium pressure and medium volume flow ranges.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000099 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000099">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:label xml:lang="en">butterfly control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula borboleta de controle</rdfs:label>
        <skos:definition xml:lang="en">A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A butterfly valve that is equipped with an actuator that manipulates a stream of fluid in the response to a signal from an external sensing element and with input of energy from an external source.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BUTTERFLY CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;BUTTERFLY VALVE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ButterflyControlValve(x) → Valve(x) ∧ ∃d(RotatingDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(Actuator(a) ∧ hasComponentPartAtAllTimes(x,a)) ∧ ∃f(ProcessControlledFlowFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula borboleta de controle é uma válvula de controle que possui um mecanismo de fechamento por disco rotativo e possui uma função de fluxo controlado por processo, permitindo modulação automatizada do fluxo em resposta a sinais de controle externos.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">This is a constructive type that combines two existing differentia (butterfly mechanism + control function). Under OWA, providing sufficient conditions could lead to false positives where any valve with both a rotating disc and control capability would be classified as this specific type, even if it has additional specialized features or hybrid mechanisms.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every butterfly control valve is a valve that has-component-part-at-all-times some rotating disc and has-component-part-at-all-times some actuator and bearer-of some process-controlled flow function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">butterfly valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula borboleta</rdfs:label>
        <skos:definition xml:lang="en">A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A rotary valve that has a closure member of a disc type with a shaft parallel, or near parallel, to the plane of the disc, with an axis of rotation transverse to the flow direction.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;BUTTERFLY VALVE&gt; is a &lt;ROTARY VALVE&gt; that has a closure member of a disc type with a shaft parallel, or near parallel, to the plane of the disc, with an axis of rotation transverse to the flow direction</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A quick opening, low pressure valve, common on large openings through which solids will move, that allows high flow rate when open.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A rotary valve that has a closure member of a disc type with a shaft parallel, or near parallel, to the plane of the disc, with an axis of rotation transverse to the flow direction.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A short face-to-face valve that has a movable vane in the center of the flow stream, which rotates 90° as the butterfly valve opens and closes.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ButterflyValve(x) → Valve(x) ∧ ∃y(DiscTypeClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(TransverseRotationAxis(z) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula borboleta é uma válvula que possui um membro de fechamento tipo disco com haste paralela ao plano do disco e eixo de rotação transversal à direção do fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">This is a constructive classification based on physical mechanism. Under the Open World Assumption, any artifact with a disc-type closure and transverse rotation axis would be forced into the ButterflyValve class, including specialized hybrid equipment or custom manifolds containing butterfly mechanisms that should not be classified as standard butterfly valves for maintenance purposes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every butterfly valve is a valve that has a disc-type closure member and has a transverse rotation axis.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000224"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">centrifugal compressor</rdfs:label>
        <rdfs:label xml:lang="pt-br">compressor centrífugo</rdfs:label>
        <skos:definition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A dynamic compressor in which one ore more impellers accelerate the gas and where the main flow through the impeller is radial.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CENTRIFUGAL COMPRESSOR&gt; is an &lt;ARTEFACT&gt; and a &lt;COMPRESSOR&gt; in which one ore more impellers accelerate the gas and where the main flow through the impeller is radial, and generates pressure increase by means of centrifugal action and a volute or diffuser casing.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A dynamic compressor in which one ore more impellers accelerate the gas and where the main flow through the impeller is radial.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (CentrifugalCompressor(x) → Compressor(x) ∧ ∃i(CentrifugalImpeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃p(RadialFlowPattern(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um compressor centrífugo é um compressor que usa um ou mais impelidores centrífugos para acelerar o gás através de fluxo radial e gerar aumento de pressão por ação centrífuga.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because under OWA, any equipment with a centrifugal impeller could be incorrectly classified as a standard centrifugal compressor, including specialized hybrid equipment or multi-stage systems that contain centrifugal elements but should not be forced into this maintenance category. Domain expert validation needed to confirm structural differentia is sufficient.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal compressor is a compressor that has component part at all times some centrifugal impeller and participates in some radial flow pattern.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000072"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000336"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">bomba centrífuga</rdfs:label>
        <rdfs:label xml:lang="en">centrifugal pump</rdfs:label>
        <skos:definition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A dynamic pump that contains impellers provided with vanes to generate centrifugal force to achieve the required pressure head.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CENTRIFUGAL PUMP&gt; is an &lt;ARTEFACT&gt; and a &lt;PUMP&gt; in which centrifugal force imparted by impeller is convered to pressure in the volute casing. NOTE - Combine with either  BARE PUMP or PUMP SYSTEM,</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] Pump with an impeller or rotor that spins in a housing and the drag forces on the fluids cause them to flow.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A dynamic pump utilizing impellers provided with vanes generating centrifugal force to achieve the required pressure head.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A type of pump commonly used in the handling and mixing of oilfield fluids.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CentrifugalPump(x) → Pump(x) ∧ ∃y(CentrifugalImpeller(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(VoluteCasing(z) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma bomba centrífuga é uma bomba que usa força centrífuga gerada por impulsores rotativos com pás para aumentar a pressão do fluido através de uma carcaça voluta.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under Open World Assumption, any equipment with centrifugal impellers and volute casing could be inferred as a standard centrifugal pump, potentially misclassifying specialized hybrid equipment or complex pump systems that contain centrifugal stages but serve different operational roles.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every centrifugal pump is a pump that has a centrifugal impeller as component part at all times and has a volute casing as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000227"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">check valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de retenção</rdfs:label>
        <skos:definition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that permits fluid to flow in one direction only.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CHECK VALVE&gt; is a &lt;VALVE&gt; that permits fluid to flow in one direction only</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A valve that only allows flow in one direction.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A valve that permits fluid to flow in one direction only.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A mechanical device that permits fluid to flow or pressure to act in one direction only.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CheckValve(x) ↔ Valve(x) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção é uma válvula que possui uma função de prevenção de refluxo, permitindo automaticamente que o fluido flua em apenas uma direção enquanto previne o fluxo reverso.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every check valve is a valve that has the function to prevent backflow and automatically allow unidirectional fluid flow.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:label xml:lang="en">choke control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle de choke</rdfs:label>
        <skos:definition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A choke valve that is equipped with an actuator that manipulates a stream of fluid in the response to a signal from an external sensing element and with input of energy from an external source.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CHOKE CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;CHOKE VALVE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ChokeControlValve(x) → ControlValve(x) ∧ ∃y (ChokeGeometry(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle de choke é uma válvula de controle que possui um componente de geometria de choke para redução de pressão através de restrição de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is classified as &apos;both&apos; functional and constructive. The constructive differentia (choke geometry) makes it safer to use necessary conditions to avoid forcing all valves with choke components into this specific control category under the Open World Assumption.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke control valve is a control valve that has a choke geometry component at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">choke valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula choke</rdfs:label>
        <skos:definition xml:lang="en">A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that can be used to obstruct the fluid passing inside, and has the ability to reduce the pressure from the inlet port to the outlet port.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CHOKE VALVE&gt; is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; in which a solid cylinder is raised and lowered, and which is placed around or inside another cylinder that has holes or slots. The design of a choke valve means fluids flowing through the cage are coming from all sides and that the streams of flow (through the holes or slots) collide with each other at the center of the cage cylinder, thereby dissipating the energy of the fluid through flow impingement. The main advantage of choke valves is that they can be designed to be totally linear in their flow rate</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A valve that can be used to obstruct the fluid passing inside, and has the ability to reduce the pressure from the inlet port to the outlet port.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ChokeValve(x) ↔ (Valve(x) ∧ ∃f (PressureReductionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula choke é uma válvula que possui uma função de redução de pressão, projetada para reduzir a pressão do fluido da entrada para a saída através de restrição controlada do fluxo e dissipação de energia.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every choke valve is a valve that bears a pressure reduction function and has a flow restriction element as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ActuatingMechanism"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ElectricalContact"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InterruptingMedium"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">circuit breaker</rdfs:label>
        <rdfs:label xml:lang="pt-br">disjuntor</rdfs:label>
        <skos:definition xml:lang="en">A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current.</skos:definition>
        <skos:definition xml:lang="en">A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A mechanical switching device that at regular intervals interrupts an electric current.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;CIRCUIT BREAKER&gt; is an &lt;ELECTRICAL APPARATUS&gt; and a &lt;SWITCHING DEVICE&gt; that at regular intervals interrupts an electric current</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A mechanical switching device that at regular intervals interrupts an electric current.</skos:definition>
        <skos:exactMatch rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106"/>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (CircuitBreaker(x) ↔ ElectricalSwitchingDevice(x) ∧ ∃f (ElectricalCurrentInterruptionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p (RegularInterruptionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(CircuitBreaker(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(CurrentInterruptionProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um disjuntor é um dispositivo de chaveamento elétrico que possui uma função de interrupção de corrente elétrica e participa regularmente em processos que interrompem com segurança a corrente elétrica.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um disjuntor é um equipamento elétrico que possui uma função de proteção de circuito e participa em processos de interrupção de corrente em intervalos regulares.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every circuit breaker is an electrical switching device that has the function to interrupt electrical current and participates in regular current interruption processes.</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every circuit-breaker is an electrical equipment that has the function to protect circuits and participates in the process of interrupting electrical current at regular intervals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000107 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000107">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">coalescedor</rdfs:label>
        <rdfs:label xml:lang="en">coalescer</rdfs:label>
        <skos:definition xml:lang="en">A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A gravity separator where two liquid substances separates and where the substance with the less gravity can be skimmed off.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;COALESCER&gt; is a &lt;GRAVITY SEPARATOR&gt; where two liquid substances separates and where the substance with the less gravity can be skimmed off.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A gravity separator where two liquid substances separates and where the substance with the less gravity can be skimmed off.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Coalescer(x) ↔ (Separator(x) ∧ ∃f(CoalescenceFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(GravitySeparationProcess(p) ∧ participatesIn(x,p)) ∧ ∃o(SkimmableLiquidPortion(o) ∧ hasOutput(x,o))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um coalescedor é um separador que usa meio de coalescência para promover a fusão de gotículas em misturas líquidas imiscíveis, permitindo separação por gravidade onde a fase líquida menos densa pode ser removida por escumação.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every coalescer is a separator that bears a coalescence function and participates in gravity separation processes to produce skimmable liquid portions.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000108 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000108">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000248"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">diaphragm valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de diafragma</rdfs:label>
        <skos:definition xml:lang="en">A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A membrane valve that is a membrane valve where the closure member is a resilient diaphragm being forced against a port.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIAPHRAGM VALVE&gt; is a &lt;MEMBRANE VALVE&gt; where the closure member is a resilient diaphragm being forced against a port</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DiaphragmValve(x) → Valve(x) ∧ ∃d,p (ResilientDiaphragm(d) ∧ Port(p) ∧ hasComponentPartAtAllTimes(x,d) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de diafragma é uma válvula que usa um diafragma resiliente forçado contra uma porta como seu mecanismo de fechamento para controlar o fluxo de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Since this is a constructive type defined by physical mechanism (diaphragm closure), necessary conditions are used to avoid over-classification under the Open World Assumption. Not every equipment with a diaphragm component should automatically be classified as a diaphragm valve - the structural differentia requires domain validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every diaphragm valve is a valve that has a resilient diaphragm as component part and has a port as component part and participates in diaphragm closure processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">differential pressure gauge</rdfs:label>
        <rdfs:label xml:lang="pt-br">manômetro de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A gauge that is intended for measuring and indicating pressure differences.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIFFERENTIAL PRESSURE GAUGE&gt; is a &lt;PRESSURE GAUGE&gt; and a &lt;DIFFERENTIAL PRESSURE MEASURING INSTRUMENT&gt; using a &lt;DIFFERENTIAL PRESSURE MEASURING ELEMENT&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureGauge(x) ↔ PressureGauge(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(DifferentialPressureMeasuringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(PressurePortPair(p) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um manômetro de pressão diferencial é um manômetro que mede e indica a diferença entre duas entradas de pressão usando um elemento de medição de pressão diferencial.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure gauge is a pressure gauge that bears a DifferentialPressureMeasurementFunction and has component parts including a DifferentialPressureMeasuringElement and PressurePortPair.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000110 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000110">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000186"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">differential pressure transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de pressão diferencial</rdfs:label>
        <skos:definition xml:lang="en">A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A pressure transmitter that is producing a standardized output signal dependent of a received pressure difference signal.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DIFFERENTIAL PRESSURE TRANSMITTER&gt; is a &lt;PRESSURE TRANSMITTER&gt; and a &lt;DIFFERENTIAL PRESSURE MEASURING INSTRUMENT&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DifferentialPressureTransmitter(x) ↔ PressureTransmitter(x) ∧ ∃f (DifferentialPressureTransmissionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão diferencial é um transmissor de pressão que possui uma função de transmissão de pressão diferencial, permitindo medir a diferença de pressão entre dois sinais de pressão de entrada e transmitir essa diferença como um sinal de saída padronizado.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000111 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000111">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">double block and bleed valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de bloqueio duplo e sangria</rdfs:label>
        <skos:definition xml:lang="en">A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A block and bleed valve that is incorporating two seats, each of which provides a seal, and a means of venting the space between the seats. The seats may isolate with the pressure differential acting in the same or in opposite directions depending on the design.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DOUBLE BLOCK AND BLEED VALVE&gt; is a &lt;BLOCK AND BLEED VALVE&gt; and a &lt;DOUBLE BLOCK VALVE&gt; that is incorporating two seats, each of which provides a seal, and a means of venting the space between the seats. The seats may isolate with the pressure differential acting in the same or in opposite directions depending on the design</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (DoubleBlockAndBleedValve(x) → (Valve(x) ∧ ∃p,s,b (PrimarySeat(p) ∧ SecondarySeat(s) ∧ BleedPort(b) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,b))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de bloqueio duplo e sangria é uma válvula que incorpora duas sedes, cada uma proporcionando capacidade de vedação, e inclui um meio de ventilação do espaço entre as sedes.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive basis - the structural differentia (dual seats plus bleed port) defines necessary conditions, but under OWA we cannot assert that ANY artifact with these structural components is definitively a double block and bleed valve, as specialized multi-way valves or custom manifolds might contain similar mechanisms without being standard maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every double block and bleed valve is a valve that has a primary seat and has a secondary seat and has a bleed port.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">down hole safety valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de segurança de fundo de poço</rdfs:label>
        <skos:definition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that is intended for subsurface control/check operation.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DOWN HOLE SAFETY VALVE&gt; is a &lt;SAFETY VALVE&gt; that is intended for subsurface control/check operation</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(DownHoleSafetyValve(x) ↔ SafetyValve(x) ∧ ∃f(SubsurfaceSafetyFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SubsurfaceOperationProcess(p) ∧ participatesIn(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança de fundo de poço é uma válvula de segurança que possui uma função de segurança subsuperficial para operações de alívio de pressão e controle de fluxo em poços ou outros ambientes subsuperficiais.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every down hole safety valve is a safety valve that bears a SubsurfaceSafetyFunction and participates in SubsurfaceOperationProcess</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000113 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000113">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000342"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000355"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electric motor</rdfs:label>
        <rdfs:label xml:lang="pt-br">motor elétrico</rdfs:label>
        <skos:definition xml:lang="en">An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] An electric machine for transforming electric energy into mechanical energy.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ELECTRIC MOTOR&gt; is an &lt;ELECTRIC ROTATING MACHINE&gt; and a &lt;MOTOR&gt; and an &lt;ELECTRIC TO MECHANICAL ENERGY CONVERTER&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] An electric machine for transforming electric energy into mechanical energy</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">ElectricMotor(x) ↔ Assembly(x) ∧ ∃f(ElectricToMechanicalConversionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(Stator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃r(Rotor(r) ∧ hasComponentPartAtAllTimes(x,r))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um motor elétrico é um conjunto que possui uma função de conversão de energia elétrica para mecânica e tem tanto um estator quanto um rotor como componentes essenciais.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every electric motor is an assembly that bears an electric-to-mechanical conversion function and has component parts including a stator and rotor at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">emergency shut down valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de parada de emergência</rdfs:label>
        <skos:definition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that is assigned to act in case of emergency.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] An &lt;EMERGENCY SHUT DOWN VALVE&gt; is an &lt;ACTUATED VALVE&gt; that is assigned to act in case of emergency</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (EmergencyShutDownValve(x) ↔ (Valve(x) ∧ ∃f(EmergencyShutDownFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de parada de emergência é uma válvula que possui uma função de parada de emergência, permitindo o isolamento rápido de fluxo em situações de emergência através de mecanismos atuados com capacidade à prova de falhas.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every emergency shut down valve is a valve that has an emergency shut down function and has an actuator and has a fail-safe system.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000302"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">fan</rdfs:label>
        <rdfs:label xml:lang="pt-br">ventilador</rdfs:label>
        <skos:definition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that is intended to deliver or exhaust volumes of vapour or gas at low differential pressure.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FAN&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DELIVERING&gt; or &lt;EXHAUSTING&gt; volumes of vapour or gas at low differential pressure</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] An &apos;artefact&apos; and a &apos;gas pressure increase device&apos; that is intended to deliver or exhaust volumes of vapour or gas at low differential pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Fan(x) ↔ (Assembly(x) ∧ ∃f(GasMovementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um ventilador é um conjunto que possui uma função de movimentação de gás para fornecer ou exaurir volumes de vapor ou gás com baixa pressão diferencial.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every fan is an assembly that bears a gas movement function, and every assembly that bears a gas movement function is a fan.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000174"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">elemento de vazão</rdfs:label>
        <rdfs:label xml:lang="en">flow element</rdfs:label>
        <skos:definition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A detecting element that is producing a signal that is proportional to a flow rate.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A device located in a flowstream measuring the flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(FlowElement(x) ↔ (Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de vazão é um instrumento que tem a função de medir vazões em um fluxo e produzir sinais proporcionais à vazão medida.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow element is an instrument that bears a FlowMeasurementFunction and has component parts including a FlowSensingElement and SignalGenerationComponent.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow indicator</rdfs:label>
        <rdfs:label xml:lang="pt-br">indicador de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOW INDICATOR&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;FLOW MEASURING INSTRUMENT&gt; and a &lt;INDICATOR&gt; that, using a &lt;FLOW MEASURING ELEMENT&gt;, is specially and exclusively designed for &lt;INDICATING&gt; a &lt;FLOW RATE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (FlowIndicator(x) ↔ (Instrument(x) ∧ ∃f(FlowIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FlowMeasuringElement(e) ∧ hasComponentPartAtSomeTime(x,e)) ∧ ∃d(DisplayElement(d) ∧ hasComponentPartAtAllTimes(x,d))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador de fluxo é um indicador projetado para indicar taxas de fluxo usando um elemento de medição de fluxo e elemento de exibição.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow indicator is an instrument that bears a flow indication function and has a flow measuring element and display element as component parts.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000185"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A flow transmitter providing an output signal that is proportional to the flow inputs from a flow element.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;FLOW TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;FLOW MEASURING INSTRUMENT&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A transmitter that is producing a standardized output signal dependent of a received input signal from a flow sensor.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation &apos;FT&apos;. First letter &apos;F&apos;: Flow, Flow Rate. Succeeding letters: &apos;T&apos; = Transmit.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (FlowTransmitter(x) ↔ Transmitter(x) ∧ ∃f(FlowSignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(FlowMeasurement(m) ∧ hasInput(x,m)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de fluxo é um transmissor que produz sinais de saída padronizados proporcionais às medições de fluxo provenientes de elementos sensores de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every flow transmitter is a transmitter that has the function of transmitting flow signals and has as input flow measurements.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gate control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle tipo gaveta</rdfs:label>
        <skos:definition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A control valve that is a gate valve and an actuated valve.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GATE CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;GATE VALVE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GateControlValve(x) → ControlValve(x) ∧ ∃g(GateClosureMechanism(g) ∧ hasComponentPartAtAllTimes(x,g)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle tipo gaveta é uma válvula de controle que usa um elemento de fechamento tipo gaveta ou cunha movendo-se perpendicular ao caminho do fluxo para modular o fluxo de fluido em resposta a sinais de controle.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">This is a constructive subtype where the structural differentia (gate closure mechanism) defines necessary conditions. Under OWA, making this sufficient could force any assembly with a gate closure into this maintenance category, including specialized multi-way valves or custom manifolds that should not be classified as standard gate control valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate control valve is a control valve that has a gate closure mechanism as component part at all times</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000120 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000120">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">gate valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula gaveta</rdfs:label>
        <skos:definition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that is a valve where the closure member is a gate or disc with a linear motion parallel, or nearly parallel, to the plane of flat seats, which are transverse to the direction of flow.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GATE VALVE&gt; is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; that is a valve where the closure member is a gate or disc with a linear motion parallel, or nearly parallel, to the plane of flat seats, which are transverse to the direction of flow</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A valve with a sliding bar – common in the oilfield as tree valves.                  Gate valve is defined in API SPEC 6A as a valve assembly with a closure mechanism operating within the body, 90° to the conduit, to affect a closure. Gate valves are commonly used in the wellhead section of the well either as a side outlet valve in the spools or in the Christmas tree.                  Gate valves have two modes, either fully open or fully closed. This distinguish the gate valve from the chole valve. The gate valve will allow the fluid to follow or it will completely stop it. On the other hand, a choke valve will restrict the flow.                  Gate valves have several components including but not limited to:                  * Gate                  * Seat                  * Stem                  * Stem Packing (Seal)                  * Bearings                  * Grease fitting                  * Studs and nuts                  * Hand wheel</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A valve that is a valve where the closure member is a gate or disc with a linear motion parallel, or nearly parallel, to the plane of flat seats, which are transverse to the direction of flow.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A type of valve that incorporates a sliding gate to block fluid flow.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (GateValve(x) → (Valve(x) ∧ ∃g(GateClosure(g) ∧ hasComponentPartAtAllTimes(x,g)) ∧ ∃m(LinearActuationMechanism(m) ∧ hasComponentPartAtAllTimes(x,m))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula gaveta é uma válvula que possui um membro de fechamento tipo gaveta ou disco com movimento linear paralelo ao plano dos assentos planos, que são transversais à direção do fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for structural features like &apos;linear sliding gate&apos; risks false positives from complex hybrid equipment or custom manifolds that contain gate mechanisms but should not be classified as standard gate valves. Necessary conditions provide safer classification that can be validated by domain experts.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gate valve is a valve that has a gate closure component and a linear actuation mechanism.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000290"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">caixa de engrenagens</rdfs:label>
        <rdfs:label xml:lang="en">gearbox</rdfs:label>
        <skos:definition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</skos:definition>
        <skos:definition xml:lang="en">[DEXPI] An artefact that consists of a gear casing with an arrangement of two or more gear-wheels transmitting rotating motion from the input shaft to the output shaft.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GEARBOX&gt; is an &lt;ARTEFACT&gt; and a &lt;TRANSMITTER(force)&gt; and that consistes of a gear casing with an arrangement of two or more gear-wheels transmitting rotating motion from the input shaft to the output shaft</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Gearbox(x) → Assembly(x) ∧ ∃c,g1,g2,i,o (GearCasing(c) ∧ GearWheel(g1) ∧ GearWheel(g2) ∧ g1≠g2 ∧ InputShaft(i) ∧ OutputShaft(o) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,g1) ∧ hasComponentPartAtAllTimes(x,g2) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma caixa de engrenagens é um conjunto que consiste em um invólucro de engrenagens contendo um arranjo de duas ou mais rodas de engrenagem que transmitem movimento rotativo de um eixo de entrada para um eixo de saída.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type because the structural differentia (specific gear casing and gear-wheel arrangement) is complex and making it sufficient under Open World Assumption could lead to false positives - specialized equipment containing gear mechanisms might be incorrectly classified as standard gearboxes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every gearbox is an assembly that has component parts including a gear casing, at least two gear-wheels, an input shaft, and an output shaft, and bears a power transmission function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000122 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000122">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000291"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">globe control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle globo</rdfs:label>
        <skos:definition xml:lang="en">A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A control valve that is a globe valve and an actuated valve.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GLOBE CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; and a &lt;GLOBE VALVE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (GlobeControlValve(x) → ControlValve(x) ∧ ∃y,z (GlobeValveBody(y) ∧ LinearMotionClosure(z) ∧ hasComponentPartAtAllTimes(x,y) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle globo é uma válvula de controle que possui um corpo em formato de globo e usa um mecanismo de fechamento de movimento linear para modular o fluxo de fluido em resposta a sinais de controle de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive subtype (both classification basis). The structural differentia (globe body + linear closure) provides strong necessary conditions, but declaring sufficiency under OWA could lead to unwanted automatic classification of specialized equipment that contains globe mechanisms but should not be categorized as standard globe control valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe control valve is a control valve that has a globe valve body and has a linear motion closure as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000123 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000123">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">globe valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula globo</rdfs:label>
        <skos:definition xml:lang="en">A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that is a valve where the closure member is a disc or piston operating with linear motion normal to the flat or shaped seat.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;GLOBE VALVE&gt; is an &lt;ARTEFACT&gt; and a &lt;VALVE&gt; where the closure member is a disc or piston operating with linear motion normal to the flat or shaped seat</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A valve that is a valve where the closure member is a disc or piston operating with linear motion normal to the flat or shaped seat.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A valve whose closure element is a flat disc or conical plug sealing on a seat that is usually parallel to the flow axis.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(GlobeValve(x) → Valve(x) ∧ ∃y,z(hasComponentPartAtAllTimes(x,y) ∧ LinearMotionClosure(y) ∧ hasComponentPartAtAllTimes(x,z) ∧ NormalSeat(z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula globo é uma válvula caracterizada por um elemento de fechamento (disco ou tampão) que opera com movimento linear perpendicular a uma sede orientada normal ao caminho do fluxo do fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. Under OWA, making the structural differentia sufficient could force classification of specialized equipment containing linear motion closures (like complex multi-way valves or custom manifolds) as standard globe valves when they may warrant distinct maintenance categories.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every globe valve is a valve that has as component part at all times a linear motion closure and a normal seat.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">aquecedor</rdfs:label>
        <rdfs:label xml:lang="en">heater</rdfs:label>
        <skos:definition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</skos:definition>
        <skos:definition xml:lang="en">[DEXPI] An apparatus or machine that has the capability of heating.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;HEATER&gt; is a &lt;FunctionalObject&gt; that has the capability of &lt;HEATING&gt;</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] Equipment that transfers heat to the produced gas stream.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Heater(x) ↔ Assembly(x) ∧ ∃f(HeatingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A heater is an assembly that bears a heating function to add thermal energy to a medium.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every heater is an assembly that bears a heating function and has heating elements and housing as component parts at all times</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000180"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">analisador de umidade</rdfs:label>
        <rdfs:label xml:lang="en">humidity analyser</rdfs:label>
        <skos:definition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A meter intended to measure and indicate and/or produce a signal which represents the measured humidity.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (HumidityAnalyser(x) ↔ ProcessAnalyzer(x) ∧ ∃f (HumidityMeasurementFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um analisador de umidade é um analisador de processo que é projetado para medir e indicar o conteúdo de umidade ou vapor d&apos;água em correntes de processo ou ambientes.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every humidity analyser is a process analyzer that has the function to measure humidity content.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000254"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">indicador</rdfs:label>
        <rdfs:label xml:lang="en">indicator</rdfs:label>
        <skos:definition xml:lang="en">An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] An &lt;INDICATOR&gt; is an &lt;INSTRUMENTATION FUNCTION&gt; that has a capability of &lt;INDICATING&gt;</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] In a chemical context, an indicator is a chemical in a titration reaction that changes color at a certain pH.                  In the context of a mechanical load, an indicator is a dial or gauge.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] An artefact that is a intended to display the value or the status of a condition.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A visible sign of a chemical reaction.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Indicator(x) ↔ (Instrument(x) ∧ ∃f(IndicationFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador é um instrumento que exibe ou mostra o valor ou status de uma variável medida ou condição para torná-la perceptível aos operadores.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every indicator is an instrument that bears an indication function to display process information in human-perceptible form.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000128 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000128">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000176"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">elemento de nível</rdfs:label>
        <rdfs:label xml:lang="en">level element</rdfs:label>
        <skos:definition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A detecting element that is intended to determine a level.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LevelElement(x) ↔ Detector(x) ∧ ∃f(LevelDetectionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de nível é um instrumento que possui uma função de detecção de nível para determinar o nível de fluido em um vaso ou recipiente.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level element is a detector that has the function to detect fluid level</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">indicador de nível</rdfs:label>
        <rdfs:label xml:lang="en">level indicator</rdfs:label>
        <skos:definition xml:lang="en">A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] A level indicator (LI) is an instrument that measures and locally displays the level of liquid or bulk solid material in a vessel or tank. It consists of a level sensing element (float, displacer, sight glass, or electronic sensor) and a local display. Unlike a level transmitter, it does not produce a standardized remote output signal; its function is limited to local indication for operator reading at the instrument location.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LevelIndicator(x) ↔ (Indicator(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador de nível é um indicador que mede e exibe localmente o nível de material líquido ou sólido a granel em um vaso ou tanque.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level indicator is an indicator that has the function to measure and locally indicate level.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000130 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000130">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000172"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">level sight glass</rdfs:label>
        <rdfs:label xml:lang="pt-br">visor de nível</rdfs:label>
        <skos:definition xml:lang="en">A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LEVEL SIGHT GLASS&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;SIGHT GLASS&gt; mounted in or on a pipe or vessel to see inside for liquid level inspection</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LevelSightGlass(x) ↔ SightGlass(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um visor de nível é um visor que possui uma função projetada para indicar o nível de líquido através de inspeção visual.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level sight glass is a sight glass that has the function of level indication.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000187"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">level transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de nível</rdfs:label>
        <skos:definition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A transmitter that produces a continuous standardized output signal dependent of a received input signal from a level sensor.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LEVEL TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;LEVEL MEASURING INSTRUMENT&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A transmitter that is producing a continuous standardized output signal dependent of a received input signal from a level sensor.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation &apos;LT&apos;. First letter &apos;L&apos;: Level. Succeeding letters: &apos;T&apos; = Transmit.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(LevelTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(LevelMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de nível é um transmissor que mede o nível (altura) de material líquido ou sólido a granel em um recipiente e produz um sinal elétrico de saída padronizado proporcional ao nível medido.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every level transmitter is a transmitter that bears a LevelMeasurementAndTransmissionFunction</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000356"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000183"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">limit switch</rdfs:label>
        <rdfs:label xml:lang="pt-br">limit switch</rdfs:label>
        <skos:definition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;LIMIT SWITCH&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;POSITION SWITCH&gt; that is a switch preventing the travel of an object in a mechanism past some predetermined point, mechanically operated by the motion of the object itself</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A position switch having a positive opening operation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (LimitSwitch(x) ↔ Instrument(x) ∧ ∃f(PositionLimitDetectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MechanicalMotion(p) ∧ hasInput(x,p)) ∧ ∃s(ElectricalSignal(s) ∧ hasOutput(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um limit switch é um instrumento que possui uma função de detecção de limite de posição, acionado mecanicamente pelo movimento de objetos para fornecer sinais de chaveamento elétrico quando limites de posição predeterminados são atingidos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every limit switch is an instrument that has the function to detect position limits and is mechanically operated by object motion to generate electrical switching signals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">manual valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula manual</rdfs:label>
        <skos:definition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that is regulated with hand power.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(ManualValve(x) → Valve(x) ∧ ∃y(ManualActuator(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A manual valve is a valve that has a manual actuator requiring hand power for operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula manual é uma válvula que possui um atuador manual que requer força manual para operação.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on actuation mechanism. Under OWA, any valve with a manual actuator component might be classified as manual valve even if it has additional automated features (hybrid valves). Starting with necessary conditions allows domain experts to validate that manual actuation is both necessary and sufficient before upgrading to equivalent axiom.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every manual valve is a valve that has a manual actuator as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">needle valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula agulha</rdfs:label>
        <skos:definition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A globe valve that has a closure member with the shape of a conical plug (needle) which closes into a small seat.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;NEEDLE VALVE&gt; is a &lt;GLOBE VALVE&gt; that has a closure member with the shape of a conical plug (needle) which closes into a small seat</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A low volume, small orifice, high pressure bleed valve.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A globe valve that has a closure member with the shape of a conical plug (needle) which closes into a small seat.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A type of small valve used for flow metering, having a tapered needlepoint plug or closure element and a seat having a small orifice.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(NeedleValve(x) → Valve(x) ∧ ∃y(NeedlePlug(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(SmallOrificeSeat(z) ∧ hasComponentPartAtAllTimes(x,z)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula agulha é uma válvula que possui um membro de fechamento cônico em forma de agulha que se assenta em um pequeno orifício para fornecer controle preciso de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As a constructive type defined by specific structural features (needle plug geometry), providing sufficient conditions under the Open World Assumption could lead to over-classification. Complex valve assemblies or custom equipment containing needle-like mechanisms might be incorrectly classified as standard needle valves for maintenance purposes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every needle valve is a valve that has a needle plug component and has a small orifice seat component.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">on off control valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de controle liga-desliga</rdfs:label>
        <skos:definition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] An &lt;ON-OFF CONTROL VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;CONTROL VALVE&gt; that only has two defined positions, being fully open and fully closed</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(OnOffControlValve(x) ↔ ControlValve(x) ∧ ∃f(BinaryFlowControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de controle liga-desliga é uma válvula de controle que possui uma função de controle de fluxo binária, tendo apenas duas posições definidas: totalmente aberta e totalmente fechada.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every on-off control valve is a control valve that has a BinaryFlowControlFunction and has component part a BinaryPositioner.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">orifice plate</rdfs:label>
        <rdfs:label xml:lang="pt-br">placa de orifício</rdfs:label>
        <skos:definition xml:lang="en">An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that is a thin plate with a specified hole in the middle. It is usually placed in a pipe to measure the rate of fluid flow.</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] Part of an orifice metering system. A plate with a hole through which a single phase flow produces a pressure drop.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(OrificePlate(x) → FlowMeasuringElement(x) ∧ ∃p,h(ThinPlate(p) ∧ SpecifiedHole(h) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma placa de orifício é um elemento de medição de fluxo que consiste de uma placa fina com um orifício especificado através do qual o fluido flui para criar pressão diferencial para medição da taxa de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification based on physical structure. Under OWA, any plate with a hole could potentially be classified as an orifice plate, but many perforated plates serve different purposes (structural, filtering, etc.). The structural differentia alone is not sufficient without industrial context validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every orifice plate is a flow measuring element that has a thin plate component and has a specified hole component and bears a flow measurement function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000137 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000137">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000263"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000181"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">medidor de sequência de fases</rdfs:label>
        <rdfs:label xml:lang="en">phase sequence meter</rdfs:label>
        <skos:definition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PHASE SEQUENCE METER&gt; is an &lt;ELECTRIC VARIABLE MEASURING INSTRUMENT&gt; that indicates, on a polyphase system, the sequence in which the instantaneous voltage of the phase conductors reach their maximum value</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PhaseSequenceMeter(x) ↔ ElectricMeasuringInstrument(x) ∧ ∃f(PhaseSequenceMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PolyphaseElectricalSignal(s) ∧ hasInput(x,s)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um medidor de sequência de fases é um instrumento de medição elétrica que possui uma função de medição de sequência de fases para determinar e indicar a sequência na qual as tensões instantâneas dos condutores de fase atingem seu valor máximo em um sistema elétrico polifásico.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every phase sequence meter is an electric measuring instrument that has the function to measure phase sequence and has as input polyphase electrical signals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <rdfs:label xml:lang="en">piston check valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de retenção tipo pistão</rdfs:label>
        <skos:definition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A lift check valve that has a free gravity or spring loaded piston type closure member.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PISTON CHECK VALVE&gt; is a &lt;LIFT CHECK VALVE&gt; and a &lt;PISTON VALVE&gt; that has a free gravity or spring loaded piston type closure member</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A lift check valve that has a free gravity or spring loaded piston type closure member.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PistonCheckValve(x) → CheckValve(x) ∧ ∃y(PistonClosure(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção tipo pistão é uma válvula de retenção que possui um elemento de fechamento tipo pistão que se move linearmente ao longo do eixo de fluxo sob ação da gravidade ou mola para prevenir refluxo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical mechanism. Under Open World Assumption, any artifact with a piston closure could potentially be classified as piston check valve, but specialized hybrid valves or custom manifolds containing piston mechanisms should not be automatically asserted into this standard maintenance category without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every piston check valve is a check valve that has a piston closure as component part.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">plate heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor de placas</rdfs:label>
        <skos:definition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A heat exchanger using plates as the device for separating the two fluids and across which the energy is transferred.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PLATE HEAT EXCHANGER&gt; is a &lt;NON-TUBULAR HEAT EXCHANGER&gt; that uses metal plates to transfer heat between two fluids</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] An indirect contact heat exchanger that separates the hot and cold fluids by plates.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PlateHeatExchanger(x) → HeatExchanger(x) ∧ ∃p(HeatTransferPlate(p) ∧ hasComponentPartAtAllTimes(x,p)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um trocador de calor de placas é um trocador de calor que possui placas de transferência de calor como sua superfície primária de transferência de calor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type. While the plate-based structure is characteristic, under the Open World Assumption, asserting equivalence could lead to false positives where any equipment with heat transfer plates (e.g., specialized hybrid equipment, multi-function process units) would be automatically classified as a standard plate heat exchanger. Domain expert validation is needed to confirm the structural differentia is sufficient.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every plate heat exchanger is a heat exchanger that has component part heat transfer plates at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000140 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000140">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">plug valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula plug</rdfs:label>
        <skos:definition xml:lang="en">A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A rotary valve that has a quarter turn action in which the closure member is a cylindrical or tapered plug which operates by rotating on its axis and sealing against a downstream seat.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PLUG VALVE&gt; is a &lt;ROTARY VALVE&gt; that has a quarter turn action in which the closure member is a cylindrical or tapered plug which operates by rotating on its axis and sealing against a downstream seat</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A high pressure valve with a rotatable plug that allows or denies flow.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A rotary valve that has a quarter turn action in which the closure member is a cylindrical or tapered plug which operates by rotating on its axis and sealing against a downstream seat.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A quarter-turn valve whose closure element is usually a tapered plug having a rectangular port.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PlugValve(x) → Valve(x) ∧ ∃p(PlugClosure(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃r(QuarterTurnRotationProcess(r) ∧ participatesIn(x,r)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula plug é uma válvula que possui um elemento de fechamento em forma de plugue cilíndrico ou cônico que opera por rotação de um quarto de volta em seu eixo para controlar o fluxo de fluido selando contra um assento.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Constructive classification requires necessary conditions only. Under OWA, any artifact with a plug closure and quarter-turn mechanism would be forcibly classified as a plug valve, but specialized multi-port valves or custom manifolds containing plug mechanisms should not automatically inherit the standard plug valve classification without domain expert validation.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every plug valve is a valve that has a plug closure component and participates in quarter-turn rotation processes</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000332"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000333"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">power transformer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transformador de potência</rdfs:label>
        <skos:definition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;POWER TRANSFORMER&gt; is an &lt;ARTEFACT&gt; and a &lt;TRANSFORMER&gt; and an &lt;ELECTRIC POWER CONVERTER&gt; that, by electromagnetic induction, transforms a system of alternating voltage and current into another system of voltage and current usually of different values and at the same frequency for the purpose of transmitting electrical power</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A transformer that, by electromagnetic induction, transforms a system of alternating voltage and current into another system of voltage and current usually of different values and at the same frequency for the purpose of transmitting electrical power.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PowerTransformer(x) ↔ (Transformer(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃r(ElectricalPowerTransmissionRole(r) ∧ bearerOf(x,r))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transformador de potência é um transformador que possui uma função de transformação de energia elétrica, realizada por indução eletromagnética para transformar sistemas de tensão e corrente alternadas para diferentes níveis na mesma frequência para fins de transmissão de energia.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every power transformer is a transformer that has the function of transforming electrical power through electromagnetic induction, taking alternating current at one voltage level as input and producing alternating current at different voltage level(s) as output for power transmission.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000177"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">elemento de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure element</rdfs:label>
        <skos:definition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A detecting element intended to sense pressure.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A detecting element intended to sense pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PressureElement(x) ↔ DetectingElement(x) ∧ ∃f(PressureSensingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure element is an instrument that bears a pressure sensing function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um elemento de pressão é um instrumento que possui uma função de detecção de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure element is a detecting element that has the function of sensing pressure</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">manômetro</rdfs:label>
        <rdfs:label xml:lang="en">pressure gauge</rdfs:label>
        <skos:definition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A gauge intended to measure and display a representation of a measured pressure.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PRESSURE GAUGE&gt; is a &lt;PROCESS GAUGE&gt; and a &lt;PRESSURE MEASURING INSTRUMENT&gt; using a &lt;PRESSURE MEASURING ELEMENT&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A &apos;pressure measuring gauge&apos; intended to measure and display a representation of a measured pressure</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A device used to measure pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (PressureGauge(x) ↔ (Instrument(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure gauge is an indicator that bears the function of measuring and displaying pressure values.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um manômetro é um indicador que possui a função de medir e exibir valores de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure gauge is an instrument that has the function to measure and display pressure</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">pressure transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de pressão</rdfs:label>
        <skos:definition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a pressure element.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;PRESSURE TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;PRESSURE MEASURING INSTRUMENT&gt;</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation &apos;PT&apos;. First letter &apos;P&apos;: Pressure. Succeeding letters: &apos;T&apos; = Transmit.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(PressureTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(PressureTransmissionFunction(f) ∧ hasFunction(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de pressão é um transmissor que converte medições de pressão em sinais de saída padronizados para transmissão a sistemas de controle ou monitoramento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every pressure transmitter is a transmitter that has the function to transmit pressure measurement signals.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">relief valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de alívio</rdfs:label>
        <skos:definition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A self operating valve that is set to open at a certain pressure level to prevent the pressure in a container or system from reaching unsafe levels.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;RELIEF VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;PRESSURE RELIEF DEVICE&gt; that is set to open at a certain pressure level to prevent the pressure in a container or system from reaching unsafe levels</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A valve in a pressurized system that is set to open and relieve pressure at a certain pressure level.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A self operating valve that is set to open at a certain pressure level to prevent the pressure in a container or system from reaching unsafe levels.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A quick-acting, spring-loaded valve that opens to relieve pressure when the pressure exceeds the spring setting.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (ReliefValve(x) ↔ (Valve(x) ∧ ∃f (PressureReliefFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de alívio é uma válvula projetada para abrir automaticamente em um ponto de ajuste de pressão predeterminado para aliviar o excesso de pressão e prevenir níveis de pressão inseguros em um sistema.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every relief valve is a valve that bears a pressure relief function, which realizes a pressure relief process that automatically opens the valve when system pressure exceeds a predetermined setpoint.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000146 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000146">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">orifício de restrição</rdfs:label>
        <rdfs:label xml:lang="en">restriction orifice</rdfs:label>
        <skos:definition xml:lang="en">A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;RESTRICTION ORIFICE&gt; is a &lt;FLOW MODIFICATION ACCESSORY&gt; that is intended for use as a restrictor</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(RestrictionOrifice(x) ↔ FlowModificationAccessory(x) ∧ ∃f(FlowRestrictionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um orifício de restrição é um acessório de modificação de fluxo que possui a função de restringir o fluxo de fluido criando queda de pressão controlada através de constrição geométrica.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every restriction orifice is a flow modification accessory that bears a flow restriction function</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">safety relief valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de segurança e alívio</rdfs:label>
        <skos:definition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SAFETY RELIEF VALVE&gt; is a &lt;SAFETY VALVE&gt; and a &lt;RELIEF VALVE&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SafetyReliefValve(x) ↔ (Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança e alívio é uma válvula que possui uma função de alívio de segurança que combina capacidades de proteção de segurança e alívio de pressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety relief valve is a valve that has the function of providing both safety protection and pressure relief.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">safety valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de segurança</rdfs:label>
        <skos:definition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SAFETY VALVE&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;PRESSURE RELIEF DEVICE&gt; that is used in gas service</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] Various. Generally used in describing a surface or subsurface safety valve.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A quick-opening, pop-action valve used for fast relief of excessive pressure.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SafetyValve(x) ↔ Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de segurança é uma válvula que possui uma função de ventilação de segurança para alívio automático de pressão por abertura rápida e total para proteção contra condições perigosas de sobrepressão.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every safety valve is a valve that has the function to automatically relieve excess pressure for emergency protection</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:label xml:lang="en">self operating valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula auto-operante</rdfs:label>
        <skos:definition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that includes a means of operation (e.g. spring / gravity / fluid pressure / counter balance), and is not depending on an external source of energy.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SELF-OPERATING VALVE&gt; is an &lt;INSTRUMENTATION FUNCTION&gt; and a &lt;VALVE&gt; that includes a means of operation (e.g. spring / gravity / fluid pressure / counter balance), and is not depending on an external source of energy</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SelfOperatingValve(x) → Valve(x) ∧ ∃m(SelfOperatingMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(EnergyIndependentOperationCapability(c) ∧ bearerOf(x,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula auto-operante é uma válvula que inclui um mecanismo interno de operação (como mola, gravidade, pressão do fluido ou contrapeso) e não depende de uma fonte externa de energia para seu acionamento.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type defined by physical configuration (self-operating mechanism). Under OWA, any valve with an internal operating mechanism might be classified as self-operating even if it has additional external actuators or specialized applications. Domain expert validation needed to confirm structural differentia is sufficient.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every self-operating valve is a valve that has a self-operating mechanism as component part at all times and bears the capability of energy-independent operation.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">solenoid valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula solenoide</rdfs:label>
        <skos:definition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A valve that has linear action which is fitted with a solenoid for quick operation.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SOLENOID VALVE&gt; is an &lt;ACTUATED VALVE&gt; and an &lt;ELECTRICAL ELEMENT&gt; with a linear action, fitted with a solenoid for quick operation</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A valve that has linear action which is fitted with a solenoid for quick operation.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (SolenoidValve(x) → Valve(x) ∧ ∃s (SolenoidActuator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f (ElectricalControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula solenoide é uma válvula que possui um atuador solenoide para controle elétrico do fluxo de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive type where the solenoid mechanism is the distinguishing structural feature. Under OWA, making it equivalent could incorrectly classify complex valve assemblies that contain solenoid components but are not standard solenoid valves.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every solenoid valve is a valve that has a solenoid actuator component and bears an electrical control function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000151 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000151">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">storage tank</rdfs:label>
        <rdfs:label xml:lang="pt-br">tanque de armazenamento</rdfs:label>
        <skos:altLabel xml:lang="en">tank</skos:altLabel>
        <skos:definition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;STORAGE TANK&gt; is an &lt;ARTEFACT&gt; and a &lt;TANK&gt; that is intended for storage</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(StorageTank(x) ↔ (Tank(x) ∧ ∃f(ExtendedStorageFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um tanque de armazenamento é um vaso projetado para armazenar fluidos ou materiais por períodos prolongados sem transformação ou processamento ativo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every storage tank is a tank that has the function to store materials for extended periods.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">filtro grosso</rdfs:label>
        <rdfs:label xml:lang="en">strainer</rdfs:label>
        <skos:definition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A filter that is separating solid particles from a fluid by passing the fluid through a wire mesh, screen or metal plates containing perforations or slits.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;STRAINER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;STRAINING&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A mechanical separator that is separating solid particles from a fluid by passing the fluid through a wire mesh, screen or metal plates containing perforations or slits.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A device used to catch and hold the debris flowing in pipelines.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Strainer(x) ↔ (MaterialArtifact(x) ∧ ∃f(SeparationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilteringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(SolidLiquidSeparationProcess(p) ∧ participatesIn(x,p))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um filtro grosso é um artefato material que possui uma função de separação e tem um elemento filtrante, projetado para separar partículas sólidas de fluidos fazendo o fluido passar através de telas ou perfurações.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every strainer is a material artifact that bears a separation function and has a filtering element as component part at all times and participates in solid-liquid separation processes.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000153 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000153">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <rdfs:label xml:lang="en">swing check valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula de retenção basculante</rdfs:label>
        <skos:definition xml:lang="en">A swing check valve is a check valve that has a closure member consisting of a disc which swings freely on a hinge mechanism and opens automatically when flow is established and closes automatically when flow ceases or reverses.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A check valve that is a check valve where the closure member is a disc which swings freely on a hinge and which opens automatically when flow is established and closes automatically when flow ceases or is reversed.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;SWING CHECK VALVE&gt; is an &lt;ARTEFACT&gt; and a &lt;CHECK VALVE&gt; where the closure member is a disc which swings freely on a hinge and which opens automatically when flow is established and closes automatically when flow ceases or is reversed</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A check valve that is a check valve where the closure member is a disc which swings freely on a hinge and which opens automatically when flow is established and closes automatically when flow ceases or is reversed.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A check valve in which the closure element is a hinged clapper that swings or rotates about a supporting shaft.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(SwingCheckValve(x) → CheckValve(x) ∧ ∃d(HingedDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(SwingArm(a) ∧ hasComponentPartAtAllTimes(x,a)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A swing check valve is a check valve that has a closure member consisting of a disc which swings freely on a hinge mechanism and opens automatically when flow is established and closes automatically when flow ceases or reverses.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção basculante é uma válvula de retenção que possui um elemento de fechamento consistindo de um disco que gira livremente em um mecanismo de dobradiça e abre automaticamente quando o fluxo é estabelecido e fecha automaticamente quando o fluxo cessa ou se inverte.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions for this constructive type to avoid false positives under OWA. Any artifact with a hinged disc mechanism should not automatically be classified as a swing check valve without domain expert validation, as specialized equipment may contain swing mechanisms but serve different primary functions.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every swing check valve is a check valve that has a hinged disc as component part and has a swing arm as component part</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000173"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">indicador de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature indicator</rdfs:label>
        <skos:definition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] A temperature indicator (TI) is an instrument that measures temperature and displays the measured value locally at the instrument location. It typically consists of a temperature sensing element (thermocouple, RTD, or bimetal), a transmitting or mechanical linkage, and a local display. Unlike a temperature transmitter, it does not produce a standardized remote output signal; its function is limited to local indication for operator reading.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (TemperatureIndicator(x) ↔ (Instrument(x) ∧ ∃f (TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃s (TemperatureSensingElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃d (LocalDisplay(d) ∧ hasComponentPartAtAllTimes(x,d))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um indicador de temperatura é um indicador que mede temperatura e exibe o valor medido localmente na localização do instrumento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature indicator is an instrument that has the function of temperature indication and has component parts including a temperature sensing element and a local display.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">temperature transmitter</rdfs:label>
        <rdfs:label xml:lang="pt-br">transmissor de temperatura</rdfs:label>
        <skos:definition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a temperature element.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TEMPERATURE TRANSMITTER&gt;is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;TEMPERATURE MEASURING INSTRUMENT&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A &apos;transmitter&apos; that is producing a standardized output signal dependent of a received input signal from a &apos;temperature element&apos;.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] ISA 5.1 tag abbreviation &apos;TT&apos;. First letter &apos;T&apos;: Temperature. Succeeding letters: &apos;T&apos; = Transmit.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(TemperatureTransmitter(x) ↔ Transmitter(x) ∧ ∃f(TemperatureMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de temperatura é um transmissor que mede temperatura e produz um sinal de saída padronizado dependente do sinal de entrada recebido de um elemento de temperatura.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every temperature transmitter is a transmitter that has the function to measure temperature and transmit standardized signals based on temperature input.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000156 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000156">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">poço termométrico</rdfs:label>
        <rdfs:label xml:lang="en">thermowell</rdfs:label>
        <skos:definition xml:lang="en">A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;THERMOWELL&gt; is an &lt;INSTRUMENT COMPONENT&gt; that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] An &apos;artefact&apos; that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Thermowell(x) → Instrument(x) ∧ ∃r,c,f (PressureTightReceptacle(r) ∧ ProcessConnection(c) ∧ TemperatureSensorProtectionFunction(f) ∧ hasComponentPartAtAllTimes(x,r) ∧ hasComponentPartAtAllTimes(x,c) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um poço termométrico é um instrumento que é um receptáculo resistente à pressão adaptado para receber um elemento sensor de temperatura, provido com roscas externas ou outros meios para fixação resistente à pressão a um vaso ou tubulação.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Thermowell has constructive classification basis. The structural differentia (pressure-tight receptacle with process connection) defines necessary conditions, but making these sufficient under OWA could lead to false classifications of other threaded pressure-tight devices that happen to contain receptacles but are not intended as thermowells.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every thermowell is an instrument that has a pressure-tight receptacle as component part and has a process connection as component part and is designed for temperature sensing elements.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">transmissor</rdfs:label>
        <rdfs:label xml:lang="en">transmitter</rdfs:label>
        <skos:definition xml:lang="en">A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A physical object that is an element that receives a process variable signal from a sensor and converts it into an output signal.</skos:definition>
        <skos:definition xml:lang="en">[DEXPI] A detecting instrument that generates a process variable signal and converts it into an output signal.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;TRANSMITTER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;TRANSMITTING&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A &apos;detecting instrument&apos; that generates a process variable signal and converts it into an output signal.</skos:definition>
        <skos:definition xml:lang="en">[isa5_1] a device that senses a process variable through the medium of a sensor or measuring element and has an output whose steady-state value varies only as a predetermined function of the process variable.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Transmitter(x) ↔ Instrument(x) ∧ ∃f(SignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SensorElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(SignalConditioner(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃t(TransmissionModule(t) ∧ hasComponentPartAtAllTimes(x,t)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor é um instrumento que possui uma função de transmissão de sinal, recebendo sinais de variáveis de processo de sensores e convertendo-os em sinais de saída padronizados para transmissão a sistemas de controle.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every transmitter is an instrument that has the function of signal transmission and has a sensor element and signal conditioner and transmission module and receives process variable inputs and produces standardized signal outputs.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000373"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000374"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000025"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">vaso</rdfs:label>
        <rdfs:label xml:lang="en">vessel</rdfs:label>
        <skos:definition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A container intended for storage and/or processing of fluids.</skos:definition>
        <skos:definition xml:lang="en">[DEXPI] A container intended for storage and/or processing of fluids or solids.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VESSEL&gt; is a &lt;FLUID CONTAINER&gt;, intended for storage and/or processing of fluids</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Vessel(x) ↔ Assembly(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(VesselShell(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃h(VesselHead(h) ∧ hasComponentPartAtAllTimes(x,h)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every vessel is an assembly that bears a containment function and has a vessel shell and vessel head as component parts at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000363"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">transmissor de vibração</rdfs:label>
        <rdfs:label xml:lang="en">vibration transmitter</rdfs:label>
        <skos:definition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A transmitter of which the output is proportional to a measured vibration.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VIBRATION TRANSMITTER&gt; is a &lt;PROCESS VARIABLE TRANSMITTER&gt; and a &lt;VIBRATION MEASURING INSTRUMENT&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (VibrationTransmitter(x) ↔ (Transmitter(x) ∧ ∃v (VibrationSignal(v) ∧ hasInput(x,v)) ∧ ∃f (VibrationMeasurementFunction(f) ∧ bearerOf(x,f))))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um transmissor de vibração é um transmissor que mede vibrações mecânicas e produz um sinal de saída proporcional aos parâmetros de vibração medidos.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every vibration transmitter is a transmitter that has a vibration signal as input and bears a vibration measurement function.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103"/>
        <rdfs:label xml:lang="pt-br">válvula de retenção wafer</rdfs:label>
        <rdfs:label xml:lang="en">wafer check valve</rdfs:label>
        <skos:definition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</skos:definition>
        <skos:definition xml:lang="en">[CFIHOS] A wafer pattern valve that is a check valve with a wafer pattern valve body.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;WAFER CHECK VALVE&gt; is a &lt;WAFER PATTERN VALVE&gt; and a &lt;CHECK VALVE&gt;</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A wafer pattern valve that is a check valve with a wafer pattern valve body.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(WaferCheckValve(x) → CheckValve(x) ∧ ∃y(WaferPatternValveBody(y) ∧ hasComponentPartAtAllTimes(x,y)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Using necessary conditions because this is a constructive subtype (both functional and structural aspects). The wafer pattern mounting configuration is a structural differentia that, while characteristic, may have edge cases or specialized variants that should not be automatically classified without expert validation. The structural differentia should be confirmed as both necessary and sufficient in industrial practice before upgrading to equivalent mode.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every wafer check valve is a check valve that has a wafer pattern valve body as component part at all times.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000026"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">backflow prevention function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de prevenção de refluxo</rdfs:label>
        <skos:definition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</skos:definition>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000027"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">binary flow control function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de controle binário de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the complete opening or closing of a flow path to allow or prevent fluid passage.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000163">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">flow restriction function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de restrição de fluxo</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the reduction of fluid flow rate by creating a controlled resistance in the flow path.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000164">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de redução de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure reduction function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the reduction of fluid pressure from a higher upstream value to a controlled downstream value.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000165">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">emergency shut down function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de parada de emergência</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic isolation of process equipment upon detection of a hazardous condition.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000166">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de despressurização rápida</rdfs:label>
        <rdfs:label xml:lang="en">rapid depressurization function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the rapid controlled release of process pressure to a safe disposal system to prevent catastrophic failure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000168">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de ventilação de segurança</rdfs:label>
        <rdfs:label xml:lang="en">safety venting function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the release of excess pressure from a process system to a safe disposal location.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000169">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de alívio de pressão</rdfs:label>
        <rdfs:label xml:lang="en">pressure relief function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the automatic release of process fluid when pressure exceeds a defined set point to protect equipment from overpressure.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000170">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceSafetyProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SubsurfaceSafetyProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de segurança subsuperficial</rdfs:label>
        <rdfs:label xml:lang="en">subsurface safety function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by a downhole safety valve whose realization constitutes the isolation of wellbore flow to prevent uncontrolled release of reservoir fluids to surface.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000171">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000028"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
