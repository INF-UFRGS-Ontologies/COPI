    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000188">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
        <rdfs:comment xml:lang="en">A temperature measurement and transmission function is a signal transmission function whose realization both determines and transmits a temperature measurement to a remote system.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de medição e transmissão de temperatura é uma função de transmissão de sinal cuja realização determina e transmite uma medição de temperatura para um sistema remoto.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de medição e transmissão de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature measurement and transmission function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000189">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
        <rdfs:comment xml:lang="en">A vibration transmission function is a signal transmission function whose realization conveys a vibration measurement signal to a remote monitor or control system.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de transmissão de vibração é uma função de transmissão de sinal cuja realização transmite um sinal de medição de vibração para um monitor remoto ou sistema de controle.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de transmissão de vibração</rdfs:label>
        <rdfs:label xml:lang="en">vibration transmission function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000190">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068"/>
        <rdfs:comment xml:lang="en">A heating function is a heat transfer function whose realization increases the thermal energy of a process fluid or material.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de aquecimento é uma função de transferência de calor cuja realização aumenta a energia térmica de um fluido ou material de processo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de aquecimento</rdfs:label>
        <rdfs:label xml:lang="en">heating function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000191">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A gas movement function is a designed function whose realization imparts mechanical energy to a gas to induce or sustain its flow.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de movimentação de gás é uma função projetada cuja realização fornece energia mecânica a um gás para induzir ou sustentar seu fluxo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de movimentação de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas movement function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000192">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A power transmission function is a designed function whose realization transfers mechanical power from a prime mover to a driven load.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de transmissão de potência é uma função projetada cuja realização transfere potência mecânica de um motor primário para uma carga acionada.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de transmissão de potência</rdfs:label>
        <rdfs:label xml:lang="en">power transmission function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000193">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">An electric-to-mechanical conversion function is a designed function whose realization converts electrical energy into rotational or linear mechanical motion.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de conversão elétrico-mecânica é uma função projetada cuja realização converte energia elétrica em movimento mecânico rotacional ou linear.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">electric-to-mechanical conversion function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de conversão elétrica-mecânica</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000194">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A filtration function is a designed function whose realization removes particulate or contaminant matter from a fluid by passage through a permeable medium.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de filtração é uma função projetada cuja realização remove matéria particulada ou contaminante de um fluido por passagem através de um meio permeável.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">filtration function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de filtração</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000195">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A separation function is a designed function whose realization divides a fluid mixture into two or more distinct phases or streams.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de separação é uma função projetada cuja realização divide uma mistura fluida em duas ou mais fases ou correntes distintas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de separação</rdfs:label>
        <rdfs:label xml:lang="en">separation function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000196">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A coalescence function is a designed function whose realization promotes the merging of dispersed droplets into larger droplets or a continuous phase to facilitate separation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de coalescência é uma função projetada cuja realização promove a fusão de gotículas dispersas em gotículas maiores ou em uma fase contínua para facilitar a separação.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">coalescence function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de coalescência</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A storage function is a designed function whose realization accumulates and holds a quantity of fluid or material for subsequent use or transfer.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de armazenamento é uma função projetada cuja realização acumula e mantém uma quantidade de fluido ou material para uso ou transferência subsequente.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de armazenamento</rdfs:label>
        <rdfs:label xml:lang="en">storage function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000198 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000198">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000197"/>
        <rdfs:comment xml:lang="en">An extended storage function is a storage function whose realization maintains a quantity of fluid or material over an extended duration, providing buffer capacity beyond immediate operational needs.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de armazenamento prolongado é uma função de armazenamento cuja realização mantém uma quantidade de fluido ou material por uma duração prolongada, fornecendo capacidade de reserva além das necessidades operacionais imediatas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">extended storage function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de armazenamento prolongado</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000199">
        <rdfs:comment xml:lang="en">An electrical power transformation function is a designed function whose realization changes the voltage or current characteristics of an electrical supply.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de transformação de potência elétrica é uma função projetada cuja realização altera as características de tensão ou corrente de uma alimentação elétrica.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">electrical power transformation function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de transformação de potência elétrica</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000200">
        <rdfs:comment xml:lang="en">An electrical current interruption function is a designed function whose realization opens or closes an electrical circuit to control or protect electrical equipment.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de interrupção de corrente elétrica é uma função projetada cuja realização abre ou fecha um circuito elétrico para controlar ou proteger equipamentos elétricos.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">electrical current interruption function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de interrupção de corrente elétrica</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000201">
        <rdfs:comment xml:lang="en">A temperature sensor protection function is a designed function whose realization shields a temperature sensing element from direct contact with a process fluid while enabling thermal conduction.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função de proteção de sensor de temperatura é uma função projetada cuja realização protege um elemento sensor de temperatura do contato direto com um fluido de processo, permitindo a condução térmica.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de proteção de sensor de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensor protection function</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000202 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000202">
        <rdfs:comment xml:lang="en">An electrical power transmission role is a designed function whose realization conducts electrical energy between generation, transformation, and consumption points in a power system.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um papel de transmissão de potência elétrica é uma função projetada cuja realização conduz energia elétrica entre os pontos de geração, transformação e consumo em um sistema de potência.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">electrical power transmission role</rdfs:label>
        <rdfs:label xml:lang="pt-br">papel de transmissão de potência elétrica</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000203 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000203">
        <rdfs:comment xml:lang="en">A subsurface deployment role is a designed function whose realization enables operation of an artifact within a wellbore below the surface of the earth.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um papel de implantação subsuperficial é uma função projetada cuja realização permite a operação de um artefato dentro de um poço abaixo da superfície terrestre.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">papel de implantação subsuperficial</rdfs:label>
        <rdfs:label xml:lang="en">subsurface deployment role</rdfs:label>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000204 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000204">
        <rdfs:comment xml:lang="en">An energy-independent operation capability is a designed function whose realization maintains the functional state of an artifact without reliance on an external power supply.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma capacidade de operação independente de energia é uma função projetada cuja realização mantém o estado funcional de um artefato sem dependência de uma fonte de energia externa.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">capacidade de operação independente de energia</rdfs:label>
        <rdfs:label xml:lang="en">energy-independent operation capability</rdfs:label>
    </owl:Class>
