    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070">
        <rdfs:comment xml:lang="en">A designed function that is realized in a temperature measurement process.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma função projetada que é realizada em um processo de medição de temperatura.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
