    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060">
        <rdfs:comment xml:lang="en">A quality inhering in a rotating element that represents the number of complete revolutions per unit time.</rdfs:comment>
