            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="pt-br">função de medição de umidade</rdfs:label>
        <rdfs:label xml:lang="en">humidity measurement function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the measurement and display of the moisture content or relative humidity of a gas stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000181 -->

