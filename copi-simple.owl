    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053">
        <rdfs:comment xml:lang="en">A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary.</rdfs:comment>
