    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057">
        <rdfs:comment xml:lang="en">A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position.</rdfs:comment>
