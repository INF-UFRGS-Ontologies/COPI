        <rdfs:label xml:lang="en">pressure sensing function</rdfs:label>
        <skos:definition xml:lang="en">A designed function borne by petroleum production equipment whose realization constitutes the detection and measurement of the pressure of a process stream.</skos:definition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000178">
