###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000089
copi:COPI_0000089 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000004 ;
                  dcterms:source "Green & Southard (eds.), Perry's Chemical Engineers' Handbook, 9th ed. ¬ß11 (heat transfer)." ,
                                 "ODR-016 ¬ßA (HeatExchange leaf, N√≠vel 2 Incremento 1a)" ;
                  rdfs:comment "A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams."@en ,
                               "Uma opera√ß√£o de transfer√™ncia de calor na qual energia t√©rmica √© trocada entre dois ou mais fluidos, tipicamente separados por uma superf√≠cie s√≥lida de troca de calor, sem mistura dessas correntes."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "heat exchange"@en ,
                             "troca de calor"@pt-br ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#TemperatureChange> ;
                  annotation:adaptedFrom "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. ¬ß11‚Äì12 (heat transfer without/with phase change)." ;
                  annotation:firstOrderLogicDefinition "‚àÄx (HeatExchange(x) ‚Üî HeatTransfer(x) ‚àß ‚àÉf1,f2,f3,f4(hasInput(x,f1) ‚àß Fluid(f1) ‚àß hasInput(x,f2) ‚àß Fluid(f2) ‚àß f1‚âÝf2 ‚àß hasOutput(x,f3) ‚àß Fluid(f3) ‚àß hasOutput(x,f4) ‚àß Fluid(f4) ‚àß f3‚âÝf4 ‚àß derivesFrom(f3,f1) ‚àß derivesFrom(f4,f2) ‚àß ¬¨‚àÉc3(hasConstituent(f3,c3) ‚àß ¬¨‚àÉc1(hasConstituent(f1,c1) ‚àß sameSubstance(c1,c3))) ‚àß ¬¨‚àÉc4(hasConstituent(f4,c4) ‚àß ¬¨‚àÉc2(hasConstituent(f2,c2) ‚àß sameSubstance(c2,c4)))))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams."@en ,
                                                       "Uma opera√ß√£o de transfer√™ncia de calor na qual energia t√©rmica √© trocada entre dois ou mais fluidos, tipicamente separados por uma superf√≠cie s√≥lida de troca de calor, sem mistura dessas correntes."@pt-br ;
                  annotation:primitiveRationale "Although a full first-order definition is available, OWL 2 DL carries only the genus (HeatTransfer); the pair-wise input‚Äìoutput correspondence (derivesFrom linking each output to its source input) and the cross-stream composition conservation (no constituent transferred between streams) are FOL-only constructs that exceed OWL 2 DL expressivity."@en ,
                                                "Embora exista uma defini√ß√£o de primeira ordem completa, o OWL 2 DL carrega apenas o g√™nero (HeatTransfer); a correspond√™ncia par-a-par entrada‚Äìsa√≠da (derivesFrom ligando cada sa√≠da √Ý sua entrada de origem) e a conserva√ß√£o de composi√ß√£o entre correntes (nenhum constituinte transferido entre as correntes) s√£o construtos apenas-FOL que excedem a expressividade do OWL 2 DL."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'heat exchange' if and only if x is a 'heat transfer' in which two distinct fluid inputs each give rise to a corresponding fluid output of identical composition, with no constituent transferred between streams"@en ,
                                                                 "x √© uma 'troca de calor' se e somente se x √© uma 'transfer√™ncia de calor' na qual dois fluidos de entrada distintos d√£o origem cada um a um fluido de sa√≠da correspondente de composi√ß√£o id√™ntica, sem transfer√™ncia de constituinte entre as correntes"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090
