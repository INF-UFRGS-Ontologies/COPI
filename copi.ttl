###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081
copi:COPI_0000081 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Assembly> ,
                                  copi:COPI_0000019 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000194
                                  ] ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "filter"@en ,
                             "filtro"@pt-br ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  AnnotationVocabulary:firstOrderLogicAxiom "‚àÄx (Filter(x) ‚Üí Assembly(x) ‚àß ‚àÉf (FiltrationFunction(f) ‚àß bearerOf(x,f)))"@en ;
                  AnnotationVocabulary:naturalLanguageDefinition "A filter is an assembly that has a filtration function to remove solid particles or contaminants from a fluid stream by passing the fluid through a porous medium."@en ,
                                                                 "Um filtro √© um conjunto que possui uma fun√ß√£o de filtra√ß√£o para remover part√≠culas s√≥lidas ou contaminantes de uma corrente de fluido ao faz√™-la passar por um meio poroso."@pt-br ;
                  AnnotationVocabulary:primitiveRationale "O meio filtrante poroso e o mecanismo espec√≠fico de reten√ß√£o de part√≠culas (classifica√ß√£o absoluta vs. nominal) s√£o predicados apenas-FOL; o OWL 2 DL carrega apenas o g√™nero (Assembly) e a restri√ß√£o funcional (‚àÉhasFunction.FiltrationFunction)."@pt-br ,
                                                          "The porous filtration medium and the specific particle retention mechanism (absolute vs. nominal rating) are FOL-only predicates; OWL 2 DL carries only the genus (Assembly) and the functional restriction (‚àÉhasFunction.FiltrationFunction)."@en ;
                  AnnotationVocabulary:semiFormalNaturalLanguageAxiom "Every filter is an assembly that has the function to remove solid particles or contaminants from a fluid stream by passing the fluid through a porous medium."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082
copi:COPI_0000082 rdf:type owl:Class ;
                  rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Assembly> ,
                                  copi:COPI_0000116 ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "elemento de medi√ß√£o de fluxo"@pt-br ,
                             "flow measuring element"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  AnnotationVocabulary:firstOrderLogicAxiom "‚àÄx (FlowMeasuringElement(x) ‚Üí Assembly(x) ‚àß Instrument(x) ‚àß ‚àÉf (FlowMeasurementFunction(f) ‚àß bearerOf(x,f)))"@en ;
                  AnnotationVocabulary:naturalLanguageDefinition "A flow measuring element is an instrument and assembly inserted into a fluid stream to produce a measurable signal ‚Äî differential pressure, frequency, or velocity ‚Äî proportional to the volumetric or mass flow rate."@en ,
                                                                 "Um elemento de medi√ß√£o de fluxo √© um instrumento e conjunto inserido em uma corrente de fluido para produzir um sinal mensur√°vel ‚Äî press√£o diferencial, frequ√™ncia ou velocidade ‚Äî proporcional √Ý vaz√£o volum√©trica ou m√°ssica."@pt-br ;
                  AnnotationVocabulary:primitiveRationale "O princ√≠pio de sensoriamento espec√≠fico (press√£o diferencial, Coriolis, turbina, v√≥rtice) e o tipo de sinal prim√°rio distinguem subtipos, mas s√£o predicados apenas-FOL n√£o expressos em OWL 2 DL; o OWL carrega apenas o g√™nero (Assembly ‚äì Instrument) e a restri√ß√£o funcional."@pt-br ,
                                                          "The specific sensing principle (differential pressure, Coriolis, turbine, vortex) and the primary signal type distinguish subtypes but are FOL-only predicates not expressible in OWL 2 DL; OWL carries only the genus (Assembly ‚äì Instrument) and the functional restriction."@en ;
                  AnnotationVocabulary:semiFormalNaturalLanguageAxiom "Every flow measuring element is an assembly and an instrument that has the function to produce a measurable signal proportional to the flow rate of the fluid passing through it."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083
copi:COPI_0000083 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000163
                                  ] ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "acess√≥rio de modifica√ß√£o de fluxo"@pt-br ,
                             "flow modification accessory"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  AnnotationVocabulary:firstOrderLogicAxiom "‚àÄx (FlowModificationAccessory(x) ‚Üí MaterialArtifact(x) ‚àß ‚àÉf (FlowRestrictionFunction(f) ‚àß bearerOf(x,f)))"@en ;
                  AnnotationVocabulary:naturalLanguageDefinition "A flow modification accessory is a material artifact that has a flow restriction function to reduce or condition fluid flow by creating a controlled pressure drop across a fixed orifice or flow-conditioning geometry."@en ,
                                                                 "Um acess√≥rio de modifica√ß√£o de fluxo √© um artefato material que possui uma fun√ß√£o de restri√ß√£o de fluxo para reduzir ou condicionar o escoamento de fluido ao criar uma queda de press√£o controlada em um orif√≠cio fixo ou geometria condicionadora de fluxo."@pt-br ;
                  AnnotationVocabulary:primitiveRationale "A geometria do orif√≠cio, o coeficiente de descarga e a presen√ßa ou aus√™ncia de uma placa condicionadora de fluxo s√£o differentia apenas-FOL que distinguem o orif√≠cio de restri√ß√£o da placa de orif√≠cio; o OWL 2 DL carrega apenas o g√™nero (MaterialArtifact) e a restri√ß√£o funcional."@pt-br ,
                                                          "The orifice geometry, discharge coefficient, and the presence or absence of a flow-conditioning plate are FOL-only differentia that distinguish restriction orifice from orifice plate; OWL 2 DL carries only the genus (MaterialArtifact) and the functional restriction."@en ;
                  AnnotationVocabulary:semiFormalNaturalLanguageAxiom "Every flow modification accessory is a material artifact that has the function to reduce or condition fluid flow by creating a controlled pressure drop through a fixed orifice or flow-conditioning geometry."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084
copi:COPI_0000084 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000152 ;
                  rdfs:isDefinedBy copi:copi-enriched ;
                  rdfs:label "separador"@pt-br ,
                             "separator"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  AnnotationVocabulary:firstOrderLogicAxiom "‚àÄx (Separator(x) ‚Üí Assembly(x) ‚àß ‚àÉf (SeparationFunction(f) ‚àß bearerOf(x,f)))"@en ;
                  AnnotationVocabulary:naturalLanguageDefinition "A separator is an assembly that has a separation function to divide a fluid mixture into two or more phases or streams based on differences in physical properties such as density, particle size, or surface tension."@en ,
                                                                 "Um separador √© um conjunto que possui uma fun√ß√£o de separa√ß√£o para dividir uma mistura de fluidos em duas ou mais fases ou correntes com base em diferen√ßas em propriedades f√≠sicas como densidade, tamanho de part√≠cula ou tens√£o superficial."@pt-br ;
                  AnnotationVocabulary:primitiveRationale "O mecanismo de separa√ß√£o (sedimenta√ß√£o gravitacional, a√ß√£o cicl√¥nica, coalesc√™ncia, flota√ß√£o) e o n√∫mero e identidade das fases de sa√≠da s√£o differentia apenas-FOL; o OWL 2 DL carrega apenas o g√™nero (Assembly) e a restri√ß√£o funcional."@pt-br ,
                                                          "The separation mechanism (gravity settling, cyclonic action, coalescence, flotation) and the number and identity of output phases are FOL-only differentia; OWL 2 DL carries only the genus (Assembly) and the functional restriction."@en ;
                  AnnotationVocabulary:semiFormalNaturalLanguageAxiom "Every separator is an assembly that has the function to divide a fluid mixture into two or more distinct phases or streams based on differences in physical properties."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085
