                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000006> ;
                                             dce:identifier "246-BFO" ;
                                             rdfs:label "spatially projects onto"@en ;
                                             skos:definition "(Elucidation) spatially projects onto is a relation between some spatiotemporal region b and spatial region c such that at some time t, c is the spatial extent of b at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000218
<http://purl.obolibrary.org/obo/BFO_0000218> rdf:type owl:ObjectProperty ;
                                             rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000016> ;
                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                             dce:identifier "242-BFO" ;
                                             rdfs:label "has material basis"@en ;
                                             skos:definition "b has material basis c =Def b is a disposition & c is a material entity & there is some d bearer of b & there is some time t such that c is a continuant part of d at t & d has disposition b because c is a continuant part of d at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000221
<http://purl.obolibrary.org/obo/BFO_0000221> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000222> ;
                                             rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000203> ;
                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000008> ;
                                             dce:identifier "268-BFO" ;
                                             rdfs:label "first instant of"@en ;
                                             skos:definition "t first instant of t' =Def t is a temporal instant & t' is a temporal region t' & t precedes all temporal parts of t' other than t"@en ;
                                             skos:example "An hour starting at midnight yesterday has first instant midnight yesterday"@en .


###  http://purl.obolibrary.org/obo/BFO_0000222
<http://purl.obolibrary.org/obo/BFO_0000222> rdf:type owl:ObjectProperty ,
                                                      owl:FunctionalProperty ;
                                             rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000008> ;
                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000203> ;
                                             dce:identifier "261-BFO" ;
                                             rdfs:label "has first instant"@en ;
                                             skos:definition "t has first instant t' =Def t' first instant of t"@en ;
                                             skos:example "The first hour of a year has first instant midnight on December 31"@en .


###  http://purl.obolibrary.org/obo/BFO_0000223
<http://purl.obolibrary.org/obo/BFO_0000223> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000224> ;
                                             rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000203> ;
                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000008> ;
                                             dce:identifier "269-BFO" ;
                                             rdfs:label "last instant of"@en ;
                                             skos:definition "t last instant of t' =Def t is a temporal instant & t' is a temporal region & all temporal parts of t' other than t precede t"@en ;
                                             skos:example "Last midnight is the last instant of yesterday"@en .


###  http://purl.obolibrary.org/obo/BFO_0000224
<http://purl.obolibrary.org/obo/BFO_0000224> rdf:type owl:ObjectProperty ,
                                                      owl:FunctionalProperty ;
                                             rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000008> ;
                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000203> ;
                                             dce:identifier "215-BFO" ;
                                             rdfs:label "has last instant"@en ;
                                             skos:definition "t has last instant t' =Def t' last instant of t"@en ;
                                             skos:example "The last hour of a year has last instant midnight December 31"@en .


###  https://spec.industrialontologies.org/ontology/construct/achievesAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/achievesAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000059> ;
                                                                              owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime> ;
                                                                              rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                              rdfs:range <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "achieves at some time"@en-us ;
                                                                              skos:example "The staffing and ramping up of production to 2 shifts per work day acheives the company plan of satisfying a surge in demand for its products."@en-us ;
                                                                              annotation:firstOrderLogicAxiom "achievesAtSomeTime(x,y) ‚Üí Process(x) ‚àß InformationContentEntity(y) ‚àß (concretizesAtSomeTime(x,y) ‚à® ‚àÉz(continuantPartOfAtAllTimes(z,y) ‚àß InformationContentEntity(z) ‚àß concretizesAtSomeTime(x,z)))" ;
                                                                              annotation:naturalLanguageDefinition "relation from a process to an information content entity wherein the process partially or fully concretizes the information content entity"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "x achieves at some time y holds when x is a 'process' and y is an 'information content entity' and x 'concretizes at some time' y or a 'continuant part of at all times' y" .


###  https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:domain [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                       [ rdf:type owl:Class ;
                                                                                                                         owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ] ;
                                                                                    rdfs:range [ rdf:type owl:Class ;
                                                                                                 owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/EngineeredSystem>
                                                                                                               <https://spec.industrialontologies.org/ontology/construct/GroupOfAgents>
                                                                                                               <https://spec.industrialontologies.org/ontology/construct/Person>
                                                                                                             )
                                                                                               ] ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "acts on behalf of at some time"@en-us ;
                                                                                    skos:example "An agent acts on behalf of a business organization. A laywer acts on behalf of a person."@en-us ;
                                                                                    annotation:firstOrderLogicAxiom "actsOnBehalfOfAtSomeTime(x,y) ‚Üí (MaterialEntity(x) ‚àß ¬¨(FiatObjectPart(x))) ‚àß (Person(y) ‚à® GroupOfAgents(y) ‚à® EngineeredSystem(y)) ‚àß ‚àÉp‚àÉd(PlannedProcess(p) ‚àß ObjectiveSpecification(d) ‚àß participatesInAtSomeTime(x,p) ‚àßachievesAtSomeTime(p,d) ‚àß genericallyDependsOnAtSomeTime(d,y))" ;
                                                                                    annotation:naturalLanguageDefinition "relation from a material entity to a person or a group of agents or engineered system that holds when the material entity participates in some planned process in order to fulfill an objective for the person or group of agents or engineered system"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageAxiom "x acts on behalf of at some time y holds when x is a 'material entity' (that is not a 'fiat object part') and y is some 'person' or 'group of agents' or 'engineered system' and at some time t, there exists a 'planned process' p such that x 'participates in' p and p 'achieves at some time' some 'objective specification' d that 'generically depends on at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/after
<https://spec.industrialontologies.org/ontology/construct/after> rdf:type owl:ObjectProperty ;
                                                                 rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000062> ;
                                                                 owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/before> ;
                                                                 rdf:type owl:TransitiveProperty ;
                                                                 rdfs:domain [ rdf:type owl:Class ;
                                                                               owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                             <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                           )
                                                                             ] ;
                                                                 rdfs:range [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                            <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                          )
                                                                            ] ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "after"@en-us ;
                                                                 skos:example "A metal surface is polished after the surface is cleaned to make it free from dust or grease; a product is manufactured after it is designed; March comes after January."@en-us ;
                                                                 annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                 annotation:firstOrderLogicAxiom "after(x,y) ‚Üî before(y,x)" ;
                                                                 annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is later than the first instant of the temporal extent of j"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageAxiom "'before' and 'after' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/before
<https://spec.industrialontologies.org/ontology/construct/before> rdf:type owl:ObjectProperty ;
                                                                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000063> ;
                                                                  rdf:type owl:TransitiveProperty ;
                                                                  rdfs:domain [ rdf:type owl:Class ;
                                                                                owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                              <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                            )
                                                                              ] ;
                                                                  rdfs:range [ rdf:type owl:Class ;
                                                                               owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                             <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                           )
                                                                             ] ;
                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                  rdfs:label "before"@en-us ;
                                                                  skos:example "The surface of the metal is cleaned to make it free from dust or grease before polishing; a product is designed before it can be manufactured; January comes before March."@en-us ;
                                                                  annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                  annotation:firstOrderLogicAxiom "LA1: before(i,j) ‚Üí (TemporalInterval(i) ‚àß TemporalInterval(j)) ‚à® (Process(i) ‚àß Process(j))" ,
                                                                                                  "LA2: TemporalInterval(i) ‚àß TemporalInterval(j) ‚àß before(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInstant(i1) ‚àß TemporalInstant(j1) ‚àß hasLastInstant(i,i1) ‚àß hasFirstInstant(j,j1) ‚àß precedes(i1,j1))" ,
                                                                                                  "LA3: Process(i) ‚àß Process(j) ‚àß ‚àÉi1‚àÉj1(TemporalInterval(i1) ‚àß before(i,j) ‚Üí TemporalInterval(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß before(i1,j1))" ;
                                                                  annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is earlier than the first instant of the temporal extent of j"@en-us ;
                                                                  annotation:semiFormalNaturalLanguageAxiom "LA1: If i is 'before' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                            "LA2: If both i and j are 'temporal intervals' and i is 'before' j then the 'last instant of' i 'precedes' the 'first instant of' j" ,
                                                                                                            "LA3: If both i and j are 'process' and i is 'before' j then the 'temporal interval' that i occupies is 'before' the 'temporal interval' that j occupies" .


###  https://spec.industrialontologies.org/ontology/construct/capabilityOf
<https://spec.industrialontologies.org/ontology/construct/capabilityOf> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasCapability> ;
                                                                        rdfs:domain <https://spec.industrialontologies.org/ontology/construct/Capability> ;
                                                                        rdfs:range <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "capability of"@en-us ;
                                                                        skos:example "turning at the maximal speed of 4000RPM is the capability of a lathe; temperature sensor has the capability to measuring temperature with a 0.01C precision is the capability of a temperature sensor; measuring pH in the range of 0-14 is the capability of a pH meter"@en-us ;
                                                                        annotation:firstOrderLogicAxiom "capabilityOf(x,y) ‚Üí Capability(x) ‚àß IndependentContinuant(y) ‚àß inheresIn(x,y)" ;
                                                                        annotation:naturalLanguageDefinition "relation from a capability to an independent continuant (the bearer), in which the capability specifically depends on the bearer for its existence"@en-us ;
                                                                        annotation:semiFormalNaturalLanguageAxiom "x capability of y holds when x is a 'capability' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/categorizedBy
<https://spec.industrialontologies.org/ontology/construct/categorizedBy> rdf:type owl:ObjectProperty ;
                                                                         rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/classifiedBy> ;
                                                                         owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/categorizes> ;
                                                                         rdfs:domain <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                         rdfs:range <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                         rdfs:label "categorized by"@en-us ;
                                                                         annotation:explanatoryNote "see the explanation under categorizes" ;
                                                                         annotation:firstOrderLogicDefinition "categorizedBy(c1, c2) ‚Üî categorizes(c2, c1)" ;
                                                                         annotation:naturalLanguageDefinition "relation between a lower-order classifier by a higher-order classifier such that the latter classifier categorizes the former"@en-us ;
                                                                         annotation:semiFormalNaturalLanguageDefinition "c1 is 'categorized by' c2 iff c2 categorizes c1" .


###  https://spec.industrialontologies.org/ontology/construct/categorizes
<https://spec.industrialontologies.org/ontology/construct/categorizes> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/classifies> ;
                                                                       rdfs:domain <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                       rdfs:range <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                       owl:propertyChainAxiom ( <https://spec.industrialontologies.org/ontology/construct/categorizes>
                                                                                                <https://spec.industrialontologies.org/ontology/construct/generalizes>
                                                                                              ) ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                       rdfs:label "categorizes"@en-us ;
                                                                       skos:example "classifiers such as SUV, hatchback, and sedan are categorized under a higher-order classifier body style; classifiers like internal combustion, electric, and hybrid vehicles are categorized by fuel type; classifiers such as small, medium, and large are categorized by size; specific plasmid classifiers (e.g., pSEVA191) may be generalized by a classifier such as Ap, which is categorized by antibiotic resistance" ;
                                                                       annotation:explanatoryNote """1. The terms lower-order and higher-order are relative. In this pattern, a lower-order classifier is used to classify entities of a particular kind, whereas a higher-order classifier indicates a general basis on which the lower-order classifier classifies

2. The definition of categorizes uses 'Set' and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough set and a ‚Äòset member of‚Äô constructs are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, setMemberOf(x, s) is to be understood as x‚ààs.""" ;
                                                                       annotation:firstOrderLogicAxiom "categorizes(c1, c2) ‚àß generalizes(c2, c3) ‚Üí categorizes(c1, c3)" ;
                                                                       annotation:firstOrderLogicDefinition "categorizes(c1, c2) ‚Üî (classifies(c1, c2) ‚àß ‚àÉs1, s2 (designates(c1, s1) ‚àß designates(c2, s2) ‚àß setMemberOf(s2, s1))))" ;
                                                                       annotation:naturalLanguageDefinition "relation between classifiers in which a higher-order classifier classifies a lower-order classifier and designates a set that has as members only sets designated by lower-order classifiers that it organizes"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageAxiom "if c1 'categorizes' c2 and c2 'generalizes' c3, then c1 also 'categorizes' c3" ;
                                                                       annotation:semiFormalNaturalLanguageDefinition "c1 ‚Äòcategorizes‚Äô c2 if and only if c1 ‚Äòclassifies‚Äô c2 and there exists some s1 and some s2 such that c1 ‚Äòdesignates‚Äô s1, c2 ‚Äòdesignates‚Äô s2, and s2 is a set member of s1" .


###  https://spec.industrialontologies.org/ontology/construct/classifiedBy
<https://spec.industrialontologies.org/ontology/construct/classifiedBy> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotedBy> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/classifies> ;
                                                                        rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                        rdfs:range <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                        rdfs:label "classified by"@en-us ;
                                                                        annotation:explanatoryNote "See the explanatory note and detailed FOL formalization under classifies" ;
                                                                        annotation:firstOrderLogicDefinition "classifiedBy(x,c) ‚Üî classifies(c,x)" ;
                                                                        annotation:naturalLanguageDefinition "relation that holds between an entity y and an information content entity x when the information content entity designates a set whose members are all the entities of a particular type and y is a member of that set"@en-us ;
                                                                        annotation:semiFormalNaturalLanguageDefinition "x is 'classified by' c iff c classfies x" .


###  https://spec.industrialontologies.org/ontology/construct/classifies
<https://spec.industrialontologies.org/ontology/construct/classifies> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                      rdfs:domain <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                      rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                      owl:propertyChainAxiom ( <https://spec.industrialontologies.org/ontology/construct/generalizes>
                                                                                               <https://spec.industrialontologies.org/ontology/construct/classifies>
                                                                                             ) ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                      rdfs:label "classifies"@en-us ;
                                                                      skos:example "UNSPSC code 44121706 classifies a wooden pencil" ;
                                                                      annotation:explanatoryNote """1. Any two entities classified by the same classifier are instances of a single, uniquely determined class; while the classifier classifies multiple entities, it designates one class (through a set instance) that fixes their common type.

2. The set designated by a classifier corresponds to a class means that every instance of the class is a member of that set. In this sense, the set is treated as a punned individual of the class, sharing the same IRI while remaining semantically distinct.

3. The definition of classifies uses 'Set' and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough set and a ‚Äòset member of‚Äô constructs are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, setMemberOf(x, s) is to be understood as x‚ààs.""" ;
                                                                      annotation:firstOrderLogicAxiom "LA1: classifies(c,x) ‚Üí ‚àÉs (Set(s) ‚àß designates(c,s) ‚àß setMemberOf(x, s))" ,
                                                                                                      "LA2: classifies(c,x) ‚àß designates(c,s) ‚Üí ‚àÉC(Class(C) ‚àß instanceOf(x,C) ‚àß sameIRI(s,C) ‚àß ‚àÄy((setMemberOf(y,s) ‚Üí instanceOf(y,C)) ‚àß (setMemberOf(y,s)  ‚Üí classifies(c,y))))" ;
                                                                      annotation:naturalLanguageDefinition "relation that holds between an information content entity x and an entity y when the information content entity designates a set whose members are instances of a particular type and y is a member of that set"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageAxiom "LA1: if c 'classifies' x, then there exists a set s such that c 'designates' s and x 'is a member of' s" ,
                                                                                                                "LA2: if a classifier c classifies an entity x and designates a set s, then there exists a class C such that x is an instance of C, s and C share the same IRI, and, for every entity y, if y is a member of s then y is an instance of C and if y is a set member of s then c classifies y" .


###  https://spec.industrialontologies.org/ontology/construct/componentPartOfAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/componentPartOfAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000137> ,
                                                                                                        <https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime> ;
                                                                                     rdf:type owl:TransitiveProperty ;
                                                                                     rdfs:domain [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                        [ rdf:type owl:Class ;
                                                                                                                          owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ] ;
                                                                                     rdfs:range [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                       [ rdf:type owl:Class ;
                                                                                                                         owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ] ;
                                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                     rdfs:label "component part of at all times"@en-us ;
                                                                                     skos:example "transmission assembly is a component part of a car; engine control ;sparger is a component part of a bioreactor"@en-us ;
                                                                                     annotation:firstOrderLogicAxiom "componentPartOfAtAllTimes(x,y) ‚Üí (MaterialEntity(x) ‚àß ¬¨(FiatObjectPart(x))) ‚àß (MaterialEntity(y) ‚àß ¬¨(FiatObjectPart(y))) ‚àß properContinuantPartOfAtAllTimes(x,y)" ;
                                                                                     annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it is a proper part of at all times it exists"@en-us ;
                                                                                     annotation:semiFormalNaturalLanguageAxiom "x component part of at all times y holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x is 'proper continuant part of at all times' y" .


###  https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000175> ;
                                                                                     owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                                                                     rdfs:domain [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                        [ rdf:type owl:Class ;
                                                                                                                          owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ] ;
                                                                                     rdfs:range [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                       [ rdf:type owl:Class ;
                                                                                                                         owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ] ;
                                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                     rdfs:label "component part of at some time"@en-us ;
                                                                                     skos:example "a particular chromatography column is a component part of a chromatography system during several purification cycles; a particular tool is a component part of a CNC machine while it is being used for manufacturing a particular part"@en-us ;
                                                                                     annotation:explanatoryNote "The IOF does not consider as component part of material entities that are delineated by a non-physical (fiat) boundary from the material entity they are a part of." ;
                                                                                     annotation:firstOrderLogicAxiom "componentPartOfAtSomeTime(x,y) ‚Üí (MaterialEntity(x) ‚àß ¬¨(FiatObjectPart(x))) ‚àß (MaterialEntity(y) ‚àß ¬¨(FiatObjectPart(y))) ‚àß properContinuantPartOfAtSomeTime(x,y)" ;
                                                                                     annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it is a proper part of at some time"@en-us ;
                                                                                     annotation:semiFormalNaturalLanguageAxiom "x component part of at some time y holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x is 'proper continuant part of at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/containsOccurrenceOf
<https://spec.industrialontologies.org/ontology/construct/containsOccurrenceOf> rdf:type owl:ObjectProperty ;
                                                                                rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/occursDuring> ;
                                                                                rdf:type owl:TransitiveProperty ;
                                                                                rdfs:domain [ rdf:type owl:Class ;
                                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                            <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                          )
                                                                                            ] ;
                                                                                rdfs:range [ rdf:type owl:Class ;
                                                                                             owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                           <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                         )
                                                                                           ] ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "contains occurence of"@en-us ;
                                                                                skos:example "The grinding of metal contains occurrence of sparking; a storm contains occurrences of lightning."@en-us ;
                                                                                annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                annotation:firstOrderLogicAxiom "containsOccurrenceOf(x,y) ‚Üî occursDuring(y,x)" ;
                                                                                annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of j is later than the first instant of the temporal extent of i and the last instant of the temporal extent of j is earlier than the last instant of the temporal extent of i"@en-us ;
                                                                                annotation:semiFormalNaturalLanguageAxiom "'contains occurrence of' and 'occurs during' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/denotedBy
<https://spec.industrialontologies.org/ontology/construct/denotedBy> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                     owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                     rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                     rdfs:range <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "denoted by"@en-us ;
                                                                     skos:example "one or more individuals are denoted by the name 'John'; vehicle is denoted by a 'vehicle identification number'; molecules with the structure CH3-CH2-OH is denoted by 'ethanol'"@en-us ;
                                                                     annotation:naturalLanguageDefinition "relation from an entity to an information content entity that distinguishes the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/denotes
<https://spec.industrialontologies.org/ontology/construct/denotes> rdf:type owl:ObjectProperty ;
                                                                   rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isAbout> ;
                                                                   rdfs:domain <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                   rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                   rdfs:label "denotes"@en-us ;
                                                                   skos:example "the name 'John' denotes one or more individuals that have that name; 'vehicle identification number' denotes a vehicle; 'ethanol' is a name given by IUPAC which denotes molecules with the structure CH3-CH2-OH"@en-us ;
                                                                   annotation:explanatoryNote "The distinguishment implied by denotes is not necessarily unique, which is why this property is not made functional. For example, a name can, at one point, 'denote' multiple individuals." ;
                                                                   annotation:naturalLanguageDefinition "relation from an information content entity to an entity that the information content entity distinguishes"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/describedBy
<https://spec.industrialontologies.org/ontology/construct/describedBy> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                       owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/describes> ;
                                                                       rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                       rdfs:range <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                       rdfs:label "described by"@en-us ;
                                                                       skos:example "some current event is described by the content of a newspaper article; some facility visit is described by the content of a visitor's log; some accident is described by the content of an accident report"@en-us ;
                                                                       annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                       annotation:naturalLanguageDefinition "relation from an entity to an information content entity that characterizes the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/describes
<https://spec.industrialontologies.org/ontology/construct/describes> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isAbout> ;
                                                                     rdfs:domain <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                     rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "describes"@en-us ;
                                                                     skos:example "the content of a newspaper article describes some current event; the content of a visitor's log describes some facility visit; the content of an accident report describes some accident"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                     annotation:naturalLanguageDefinition "relation from an information content entity to an entity that the information content entity characterizes"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/designatedBy
<https://spec.industrialontologies.org/ontology/construct/designatedBy> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotedBy> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/designates> ;
                                                                        rdf:type owl:InverseFunctionalProperty ;
                                                                        rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                        rdfs:range <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "designated by"@en-us ;
                                                                        skos:example "a Web Page's location on the internet is designated by an URL; an individual in USA is designated by SSN ; a particular lot of product is designated by a 'lot number'"@en-us ;
                                                                        annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                        annotation:naturalLanguageDefinition "relation from an entity to an information content entity that uniquely distinguishes the entity from other entities"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/designates
<https://spec.industrialontologies.org/ontology/construct/designates> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                      rdf:type owl:FunctionalProperty ;
                                                                      rdfs:domain <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                      rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "designates"@en-us ;
                                                                      skos:example "a URL designates the location of a Web Page on the internet;SSN designates an individual; 'lot number' designates a particular lot of product"@en-us ;
                                                                      annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                      annotation:explanatoryNote """1. To ensure uniqueness, each information content entity can designate exactly one entity. As such, this property is made functional.
2. The uniqueness of the entity is typically within a particular context that is represented in the identification scheme that conveys the meaning of the assignment.""" ;
                                                                      annotation:naturalLanguageDefinition "relation from an information content entity to an entity that the information content entity uniquely distinguishes from other entities"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/dispositionOf
<https://spec.industrialontologies.org/ontology/construct/dispositionOf> rdf:type owl:ObjectProperty ;
                                                                         rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                         owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasDisposition> ;
                                                                         rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000016> ;
                                                                         rdfs:range <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                         rdfs:label "disposition of"@en-us ;
                                                                         skos:example "the disposition to decay to an atom of element Y is the disposition of an atom of element X; the disposition to break apart is the disposition of a poorly assembled item"@en-us ;
                                                                         annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000092" ;
                                                                         annotation:firstOrderLogicAxiom "dispositionOf(x,y) ‚Üí Disposition(x) ‚àß IndependentContinuant(y) ‚àß inheresIn(x,y)" ;
                                                                         annotation:naturalLanguageDefinition "relation from a disposition to an independent continuant (the bearer), in which the disposition specifically depends on the bearer for its existence"@en-us ;
                                                                         annotation:semiFormalNaturalLanguageAxiom "x disposition of y holds when x is a 'disposition' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/functionOf
<https://spec.industrialontologies.org/ontology/construct/functionOf> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                      owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                                                      rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000034> ;
                                                                      rdfs:range <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "function of"@en-us ;
                                                                      skos:example "this catalysis function is a function of this enzyme"@en-us ;
                                                                      annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000079" ;
                                                                      annotation:firstOrderLogicAxiom "functionOf(x,y) ‚Üí Function(x) ‚àß IndependentContinuant(y) ‚àß inheresIn(x,y)" ;
                                                                      annotation:naturalLanguageDefinition "relation from a function to an independent continuant (the bearer), in which the function specifically depends on the bearer for its existence"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageAxiom "x function of y holds when x is a 'function' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/generalizes
<https://spec.industrialontologies.org/ontology/construct/generalizes> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                       owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/specializes> ;
                                                                       rdf:type owl:TransitiveProperty ;
                                                                       rdfs:domain <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                       rdfs:range <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                       rdfs:label "generalizes"@en-us ;
                                                                       skos:example "UNSPSC classifier code 26101500 for engines genralizes commodity classifier code 26101507 for turboshaft engines." ;
                                                                       annotation:explanatoryNote """1. Since the set designated by a classifier corresponds to a class, a subset relation between designated sets implies a subclass relation between the corresponding classes: if s2 is a subset of s1, then the class corresponding to s2 is a subclass of the class corresponding to s1. In this sense, the classifier being generalized is associated with a more specific class, while the classifier that generalizes it is associated with a more general class.

2. For further details on what it means for a set to correspond to a class, see the FOL formalization and explanatory note for classifier.

3. Generalizes is asymmetric and transitive. Accordingly, if one classifier generalizes a second classifier, the second does not generalize the first; and if a first classifier generalizes a second and the second generalizes a third, then the first also generalizes the third.

4. The definition of generalizes uses 'Set' and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough Set and subset of are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, subSetOf(s2, s1) is understood as s2 ‚äÜ s1.""" ;
                                                                       annotation:firstOrderLogicAxiom "LA1: generalizes(c1, c2) ‚àß designates(c1, s1) ‚àß designates(c2,s2) ‚Üí subSetOf(s2, s1)" ,
                                                                                                       "LA2: generalizes(p, c) ‚àß classifies(c, x)) ‚Üí classifies(p, x)" ;
                                                                       annotation:firstOrderLogicDefinition "generalizes(c2‚Äã, c1‚Äã) ‚Üî ‚àÄx(classifies(c2‚Äã, x) ‚Üí classifies(c1‚Äã, x))" ;
                                                                       annotation:naturalLanguageDefinition "relation between two classifiers such that everything classified by the latter is also classified by the former"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageAxiom "LA1: If a 'classifier' c1 'generalizes' a 'classifier' c2, and c1 and c2 'designate' sets s1 and s2  then s2 'is subset of' s1" ,
                                                                                                                 "LA2: if p 'generalizes' c and c 'classifies' x, then p also 'classifies' x" ;
                                                                       annotation:semiFormalNaturalLanguageDefinition "‚Äòc2‚Äô generalizes ‚Äòc1‚Äô if and only if for every instance ‚Äòx‚Äô, if ‚Äòc2‚Äô classifies ‚Äòx‚Äô, then ‚Äòc1‚Äô classifies ‚Äòx‚Äô." .


###  https://spec.industrialontologies.org/ontology/construct/hasCapability
<https://spec.industrialontologies.org/ontology/construct/hasCapability> rdf:type owl:ObjectProperty ;
                                                                         rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                         rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                         rdfs:range <https://spec.industrialontologies.org/ontology/construct/Capability> ;
                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                         rdfs:label "has capability"@en-us ;
                                                                         skos:example "a lathe has a capability to turn at the maximal speed of 4000RPM; temperature sensor has the capability to measure temperature with a 0.01C precision; pH meter has the capability to measure pH in the range of 0-14"@en-us ;
                                                                         annotation:firstOrderLogicAxiom "hasCapability(x,y) ‚Üí IndependentContinuant(x) ‚àß Capability(y) ‚àß bearerOf(x,y)" ;
                                                                         annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a capability, in which the capability specifically depends on the bearer for its existence"@en-us ;
                                                                         annotation:semiFormalNaturalLanguageAxiom "x has capability y holds when x is a 'independent continuant' and y is a 'capability' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000111> ,
                                                                                                         <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                                                                      rdf:type owl:TransitiveProperty ;
                                                                                      rdfs:domain [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                         [ rdf:type owl:Class ;
                                                                                                                           owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                         ]
                                                                                                                       ) ;
                                                                                                    rdf:type owl:Class
                                                                                                  ] ;
                                                                                      rdfs:range [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                        [ rdf:type owl:Class ;
                                                                                                                          owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ] ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "has component part at all times"@en-us ;
                                                                                      skos:example "car has component part a chasy; a bioractor has component part a stainless steel vessel"@en-us ;
                                                                                      annotation:firstOrderLogicAxiom "hasComponentPartAtAllTimes(x,y) ‚Üí (MaterialEntity(x) ‚àß ¬¨(FiatObjectPart(x))) ‚àß (MaterialEntity(y) ‚àß ¬¨(FiatObjectPart(y))) ‚àß hasProperContinuantPartAtAllTimes(x,y)" ;
                                                                                      annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it has as a proper part at all times it exists"@en-us ;
                                                                                      annotation:semiFormalNaturalLanguageAxiom "x has component part at all times y holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x 'has proper continuant part at all times' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000174> ;
                                                                                      rdfs:domain [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                         [ rdf:type owl:Class ;
                                                                                                                           owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                         ]
                                                                                                                       ) ;
                                                                                                    rdf:type owl:Class
                                                                                                  ] ;
                                                                                      rdfs:range [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                        [ rdf:type owl:Class ;
                                                                                                                          owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ] ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "has component part at some time"@en-us ;
                                                                                      skos:example "a particular chromatography column is a component part of a chromatography system has a component part a particular chromatography column during several purification cycles; a CNC machine has component part a particular tool while it is being used for manufacturing a particular part"@en-us ;
                                                                                      annotation:firstOrderLogicAxiom "hasComponentPartAtSomeTime(y,x) ‚Üí (MaterialEntity(x) ‚àß ¬¨(FiatObjectPart(x))) ‚àß (MaterialEntity(y) ‚àß ¬¨(FiatObjectPart(y))) ‚àß properContinuantPartOfAtSomeTime(x,y)" ;
                                                                                      annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it has as a proper part at some time"@en-us ;
                                                                                      annotation:semiFormalNaturalLanguageAxiom "y has component part at some time x holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x is 'proper continuant part of at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasDisposition
<https://spec.industrialontologies.org/ontology/construct/hasDisposition> rdf:type owl:ObjectProperty ;
                                                                          rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                          rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                          rdfs:range <http://purl.obolibrary.org/obo/BFO_0000016> ;
                                                                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                          rdfs:label "has disposition"@en-us ;
                                                                          skos:example "An atom of element X has the disposition to decay to an atom of element Y; a poorly assembled item has the disposition to break apart"@en-us ;
                                                                          annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000091" ;
                                                                          annotation:firstOrderLogicAxiom "hasDisposition(x,y) ‚Üí IndependentContinuant(x) ‚àß Disposition(y) ‚àß bearerOf(x,y)" ;
                                                                          annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a disposition, in which the disposition specifically depends on the bearer for its existence"@en-us ;
                                                                          annotation:semiFormalNaturalLanguageAxiom "x has disposition y holds when x is a 'independent continuant' and y is a 'disposition' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasFunction
<https://spec.industrialontologies.org/ontology/construct/hasFunction> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                       rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                       rdfs:range <http://purl.obolibrary.org/obo/BFO_0000034> ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                       rdfs:label "has function"@en-us ;
                                                                       skos:example "this enzyme has function this catalysis function (more colloquially: this enzyme has this catalysis function)"@en-us ;
                                                                       annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000085" ;
                                                                       annotation:explanatoryNote "A bearer can have many functions, and its functions can exist for different periods of time, but none of its functions can exist when the bearer does not exist. A function need not be realized at all the times that the function exists."@en-us ;
                                                                       annotation:firstOrderLogicAxiom "hasFunction(x,y) ‚Üí IndependentContinuant(x) ‚àß Function(y) ‚àß bearerOf(x,y)" ;
                                                                       annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a function, in which the function specifically depends on the bearer for its existence"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageAxiom "x has function y holds when x is a 'independent continuant' and y is a 'function' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasInput
<https://spec.industrialontologies.org/ontology/construct/hasInput> rdf:type owl:ObjectProperty ;
                                                                    rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                    owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isInputOf> ;
                                                                    rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                    rdfs:range <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                    rdfs:label "has input"@en-us ;
                                                                    skos:example "machine learning execution process has input a dataset;fermentation process has input growth medium; additive manufacturing process has input metal powder;"@en-us ;
                                                                    annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                    annotation:naturalLanguageDefinition "relation from a process to someone or something physical or digital (continuant) that is a necessary precondition for the process to start"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasMeasuredValueAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/hasMeasuredValueAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime> ;
                                                                                      owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime> ;
                                                                                      rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                      rdfs:range <https://spec.industrialontologies.org/ontology/construct/ValueExpression> ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "has measured value at some time"@en-us ;
                                                                                      skos:example "'80kg' is the value of the weight of a male human on the 5th of October 2022; '37C' is the temperature inside a bioreactor in the 30th min from the process start"@en-us ;
                                                                                      annotation:naturalLanguageDefinition "relation from an entity to a value expression that contains the value of the entity measured at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasOutput
<https://spec.industrialontologies.org/ontology/construct/hasOutput> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                     owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isOutputOf> ;
                                                                     rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                     rdfs:range <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "has output"@en-us ;
                                                                     skos:example "chemical manufacturing process has output a wastestream; toluene manufacturing process has output a certain quantity of toluene; car manufacturing process has output a car"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                     annotation:explanatoryNote "By introducing the condition that it must exist at the end of the process materials that only transitively exist during the process (e.g., reaction intermediary) are excluded from being considered the output." ;
                                                                     annotation:naturalLanguageDefinition "relation from a process to someone or something physical or digital (continuant) that participates in the process such that it is generated or modified during the process, and that it exists at the end of the process"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasProcessCharacteristic
<https://spec.industrialontologies.org/ontology/construct/hasProcessCharacteristic> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                    owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf> ;
                                                                                    rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                                    rdfs:range <https://spec.industrialontologies.org/ontology/construct/ProcessCharacteristic> ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "has process characteristic"@en-us ;
                                                                                    skos:example "the water flowing through a pipe during a given period has the average flow rate as a process characteristic, the heating process has the total energy consumed as a process characteristic, the batch sterilization process has the peak temperature as a process characteristic."@en-us ;
                                                                                    annotation:firstOrderLogicDefinition "hasProcessCharacteristics(p, c) ‚Üí processCharacteristicsOf(c, p)" ;
                                                                                    annotation:naturalLanguageDefinition "relation between a process and its characteristic"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageDefinition "if p 'has process characteristics' c, then c is 'process characteristics of' p" .


###  https://spec.industrialontologies.org/ontology/construct/hasProcessProfile
<https://spec.industrialontologies.org/ontology/construct/hasProcessProfile> rdf:type owl:ObjectProperty ;
                                                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000118> ;
                                                                             owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/processProfileOf> ;
                                                                             rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                             rdfs:range <http://purl.obolibrary.org/obo/BFO_0000144> ;
                                                                             rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                             rdfs:label "has process profile"@en-us ;
                                                                             skos:example "The pH profile is a process profile of the cell culture growth process, the spindle speed profile is a process profile of the milling process, the flow rate profile is a process profile of the pipeline transport process." ;
                                                                             annotation:firstOrderLogicDefinition "hasProcessProfile(p, x) ‚Üí processProfileOf(x, p)" ;
                                                                             annotation:naturalLanguageDefinition "relation that holds between a process and a process profile that is part of the process such that the part is temporally coextensive with another proper part that is mutually dependent on it and has no parts in common with it"@en-us ;
                                                                             annotation:semiFormalNaturalLanguageDefinition "if p 'has process profile' x, then x is 'process profile of' p" .


###  https://spec.industrialontologies.org/ontology/construct/hasQuality
<https://spec.industrialontologies.org/ontology/construct/hasQuality> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                      owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/qualityOf> ;
                                                                      rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                      rdfs:range <http://purl.obolibrary.org/obo/BFO_0000019> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "has quality"@en-us ;
                                                                      skos:example "this apple has quality this red color"@en-us ;
                                                                      annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000086" ;
                                                                      annotation:explanatoryNote "A bearer can have many qualities, and its qualities can exist for different periods of time, but none of its qualities can exist when the bearer does not exist."@en-us ;
                                                                      annotation:firstOrderLogicAxiom "hasQuality(x,y) ‚Üí IndependentContinuant(x) ‚àß Quality(y) ‚àß bearerOf(x,y)" ;
                                                                      annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a quality, in which the quality specifically depends on the bearer for its existence"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageAxiom "x has function y holds when x is a 'independent continuant' and y is a 'quality' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasRole
<https://spec.industrialontologies.org/ontology/construct/hasRole> rdf:type owl:ObjectProperty ;
                                                                   rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                   owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                   rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                   rdfs:range <http://purl.obolibrary.org/obo/BFO_0000023> ;
                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                   rdfs:label "has role"@en-us ;
                                                                   skos:example "this person has role this investigator role (more colloquially: this person has this role of investigator)"@en-us ;
                                                                   annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000087" ;
                                                                   annotation:explanatoryNote "A bearer can have many roles, and its roles can exist for different periods of time, but none of its roles can exist when the bearer does not exist. A role need not be realized at all the times that the role exists."@en-us ;
                                                                   annotation:firstOrderLogicAxiom "hasRole(x,y) ‚Üí IndependentContinuant(x) ‚àß Role(y) ‚àß bearerOf(x,y)" ;
                                                                   annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a role, in which the role specifically depends on the bearer for its existence"@en-us ;
                                                                   annotation:semiFormalNaturalLanguageAxiom "x has role y holds when x is a 'independent continuant' and y is a 'role' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput
<https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/hasOutput> ;
                                                                              owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf> ;
                                                                              rdfs:domain <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ;
                                                                              rdfs:range <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "has specified output"@en-us ;
                                                                              skos:example "biopharmaceutical production process has specified output an antibody solution of 99.999% purity; a simulation execution has specified output a prediction of part porosity; a temperature measurement process has specified output a temperature measurement result; a car manufacturing process has specified output a car"@en-us ;
                                                                              annotation:adaptedFrom "http://purl.obolibrary.org/obo/OBI_0000299" ;
                                                                              annotation:explanatoryNote "this relation was added to specifically model the outputs that are not byproducts/wasteproducts" ;
                                                                              annotation:firstOrderLogicAxiom "hasSpecifiedOutput(x,y) ‚Üí PlannedProcess(x) ‚àß Continuant(y) ‚àß ‚àÉo(ObjectiveSpecification(o) ‚àß prescribes(o,y) ‚àß achievesAtSomeTime(x,o) ‚àß hasOutput(x,y))" ;
                                                                              annotation:naturalLanguageDefinition "relation from a planned process to someone or something physical or digital (continuant) that is produced or modified in the planned process as prescribed by an objective"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "x 'has specified output' y holds when x is a 'planned process' and y is a 'continuant' and x 'has output' y and y is 'prescribed by' some 'objective specification' which x 'achieves at some time'" ;
                                                                              annotation:synonym "has intended output"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime> ;
                                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes> ;
                                                                                        rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                        rdfs:range <https://spec.industrialontologies.org/ontology/construct/ValueExpression> ;
                                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                        rdfs:label "has value expression at all times"@en-us ;
                                                                                        skos:example "speed of light in a vacuum has value expression 3√ó10^8 m/s ; electric charge carried by a single proton has the value expression 1.602176634√ó10‚àí19 coulombs"@en-us ;
                                                                                        annotation:naturalLanguageDefinition "relation from an entity to a value expression that contains the value of the entity which does not change during the entire existence of the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/describedBy> ;
                                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> ;
                                                                                        rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                        rdfs:range <https://spec.industrialontologies.org/ontology/construct/ValueExpression> ;
                                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                        rdfs:label "has value expression at some time"@en-us ;
                                                                                        skos:example "the diameter of a screw head has value expression 1cm that is specified in its design; a bioreactor has value expression 37C that was measured during the production process; \"low risk\" is the value expression of a process parameter \"low risk\" that is based on the risk analysis classification scheme; an antibody has value expression 3 g/l that was generated by a process simulation"@en-us ;
                                                                                        annotation:explanatoryNote "determined in this context can be interpreted as either being simulated or being measured" ;
                                                                                        annotation:naturalLanguageDefinition "relation from an entity to a value expression that contains the value of the entity determined or set at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isAbout
<https://spec.industrialontologies.org/ontology/construct/isAbout> rdf:type owl:ObjectProperty ;
                                                                   owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                   rdfs:domain <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                   rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                   rdfs:label "is about"@en-us ;
                                                                   skos:example "a temperature recording is about temperature; SSN is about a particular individual; commercial service agreement is about a commercial service"@en-us ;
                                                                   annotation:adaptedFrom "IAO:http://purl.obolibrary.org/obo/IAO_0000136 and CCO:http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology" ;
                                                                   annotation:naturalLanguageDefinition "primitive, generic relationship between an information content entity and some entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000058> ;
                                                                                  rdfs:domain <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                                  rdfs:range <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                  rdfs:label "is achieved by at some time"@en-us ;
                                                                                  skos:example "The company plan of satisfying a surge in demand for its products is achieved by the staffing and ramping up of production to 2 shifts per work day."@en-us ;
                                                                                  annotation:firstOrderLogicAxiom "isAchievedByAtSomeTime(y,x) ‚Üí Process(x) ‚àß InformationContentEntity(y) ‚àß (concretizesAtSomeTime(x,y) ‚à® ‚àÉz(continuantPartOf(z,y) ‚àß InformationContentEntity(z) ‚àß concretizesAtSomeTime(x,z)))" ;
                                                                                  annotation:naturalLanguageDefinition "relation from an information content entity to a process that partially or fully concretizes the information content entity"@en-us ;
                                                                                  annotation:semiFormalNaturalLanguageAxiom "y is achieved by at some time x holds when x is a 'process' and y is an 'information content entity' and x 'concretizes' y or a 'continuant part of' y, at some time t" .


###  https://spec.industrialontologies.org/ontology/construct/isAvailableToAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isAvailableToAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:domain [ rdf:type owl:Class ;
                                                                                                 owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000029>
                                                                                                               <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                             )
                                                                                               ] ;
                                                                                   rdfs:range <https://spec.industrialontologies.org/ontology/construct/Agent> ;
                                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                   rdfs:label "is available to at some time"@en-us ;
                                                                                   skos:example "a roll of aluminum (resource) is avaiable to an agent to use in a forming process, a milling workstation (resource) is available to a manufacturer to produce some parts"@en-us ;
                                                                                   annotation:explanatoryNote "this definition of 'is available to' is not the same as the state of availability e.g a machine is idle hence it is in the available state" ;
                                                                                   annotation:firstOrderLogicAxiom "isAvailableToAtSomeTime(x,y) ‚Üí (MaterialEntity(x) ‚à® Site(x)) ‚àß Agent(y) ‚àß ‚àÉp‚àÉo‚àÉc(Process(p) ‚àß ObjectiveSpecification(o) ‚àß Capability(c) ‚àß hasCapability(x,c) ‚àß genericallyDependsOnAtSomeTime(o,y) ‚àß (realizes(p,c) ‚àß participatesInAtSomeTime(y,p)‚Üí AchievesAtSomeTime(p,o)))" ;
                                                                                   annotation:naturalLanguageDefinition "relation from a material entity or physical location to an agent that holds when the material entity or physical location have a capability that is needed by the agent to fulfil some objective carried by the agent"@en-us ;
                                                                                   annotation:semiFormalNaturalLanguageAxiom "x is available at some time y holds when x is a 'material entity' or 'site' and y is an 'agent' and x 'has capability' some 'capability' which when 'realized in' some 'process' p that y 'participates in at some time' implies that p 'achieves at some time' some 'objective specification' that 'generically depends on at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/isInputOf
<https://spec.industrialontologies.org/ontology/construct/isInputOf> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                                                                     rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                                                     rdfs:range <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "is input of"@en-us ;
                                                                     skos:example "a dataset is an input of a machine learning execution process; growth medium is an input of a fermentation process; metal powder is an input of an additive manufacturing process;"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                     annotation:naturalLanguageDefinition "relates someone or something physical or digital (continuant) to a process that it is a necessary precondition for the process to start"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isMadeOfAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/isMadeOfAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000110> ,
                                                                                                 <https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime> ;
                                                                              rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                                                              rdfs:range [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                [ rdf:type owl:Class ;
                                                                                                                  owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                ]
                                                                                                              ) ;
                                                                                           rdf:type owl:Class
                                                                                         ] ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "is made of at all times"@en-us ;
                                                                              skos:example "A glass bottle is made of glass at all times during its existence as that bottle; A polymer tube is made of polymer at all times during its existence as that tube" ;
                                                                              annotation:explanatoryNote "This relation is asserted with an ‚Äòat all times‚Äô condition. It therefore implies that, for every time at which a exists, a has b as a continuant part. Equivalently, there is no time during the existence of a at which a fully lacks b as a part while still remaining the same material entity" ;
                                                                              annotation:naturalLanguageDefinition "relation between material entity b and material entity that is not a fiat object c such that b has continuant part at all times c and if portion of c is removed from b, that portion stops being part of b, while the remaining c continues to exist as the same material entity and b remains to have continuant part c"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                                              rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                                                              rdfs:range [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                [ rdf:type owl:Class ;
                                                                                                                  owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                ]
                                                                                                              ) ;
                                                                                           rdf:type owl:Class
                                                                                         ] ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "is made of at some time"@en-us ;
                                                                              skos:example "A bottle is made of glass; a bioreactor vessel is made of stainless steel; a capsule shell is made of gelatin; a wooden tabletop is made of oak" ;
                                                                              annotation:counterExample "A car is not made of wheels; a bioreactor is not made of sensors; a computer is not made of circuit boards; an aircraft is not made of engines; a building is not made of windows; a pipeline is not made of valves" ;
                                                                              annotation:explanatoryNote """1) This relation captures the continuous material composition of an entity rather than its structural or component assembly. It depends on the presence of some quantity of the material, not on the exact total amount. The identity of b remains unchanged when its portions are removed; only the quantity of the material within a varies. The relation continues to hold as long as any remainder of b remains materially present in a.
2) It applies to continuous substances or amounts of matter such as glass, steel, polymer, or wood. It should not be used for discrete parts, modules, or components such as wheels, valves, or bolts. The material may be homogeneous or composite; chemical uniformity is not required.
3) The relation has the following characteristics: irreflexive, asymmetric, non-functional, non-transitive""" ;
                                                                              annotation:naturalLanguageDefinition "relation between material entity b and material entity that is not a fiat object c such that b has continuant part at some time c and if portion of c is removed from b, that portion stops being part of b, while the remaining c continues to exist as the same material entity and b remains to have continuant part c"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> ;
                                                                                       rdfs:domain <https://spec.industrialontologies.org/ontology/construct/ValueExpression> ;
                                                                                       rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                       rdfs:label "is measured value of at some time"@en-us ;
                                                                                       skos:example "'80kg' is the measured weight of a particular male human"@en-us ;
                                                                                       annotation:naturalLanguageDefinition "relation from a value expression to the entity indicating that the value expression contains the value of the entity measured at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isOutputOf
<https://spec.industrialontologies.org/ontology/construct/isOutputOf> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                                                                      rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                                                      rdfs:range <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "is output of"@en-us ;
                                                                      skos:example "wastestream is an output of a chemical manufacturing process; a certain quantity of toluene is an output of a toluene manufacturing process; a car is an output of a car manufacturing process"@en-us ;
                                                                      annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                      annotation:naturalLanguageDefinition "relation from someone or something physical or digital (continuant) to a process that it participates in such that it is generated or modified during the process, and it exists at the end of the process"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf
<https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf> rdf:type owl:ObjectProperty ;
                                                                               rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isOutputOf> ;
                                                                               rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                                                               rdfs:range <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ;
                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                               rdfs:label "is specified output of"@en-us ;
                                                                               skos:example "antibody solution of 99.999% purity is the specified output of a biopharmaceutical production process; prediction of part porosity is a specified output of a simulation execution; temperature measurement result is the specified output of a temperature measurement process; a car is the specified output of a car manufacturing process"@en-us ;
                                                                               annotation:firstOrderLogicAxiom "isSpecifiedOutputOf(y,x) ‚Üí PlannedProcess(x) ‚àß Continuant(y) ‚àß ‚àÉo(ObjectiveSpecification(o) ‚àß prescribes(o,y) ‚àß achievesAtSomeTime(x,o) ‚àß hasOutput(x,y))" ;
                                                                               annotation:naturalLanguageDefinition "relation from someone or something physical or digital (continuant) to a planned process in which it is produced or modified as prescribed by some objective"@en-us ;
                                                                               annotation:semiFormalNaturalLanguageAxiom "y 'has specified output' x holds when x is a 'planned process' and y is a 'continuant' and x 'has output' y and y is 'prescribed by' some 'objective specification' which x 'achieves at some time'" ;
                                                                               annotation:synonym "is intended output of"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isSubjectOf
<https://spec.industrialontologies.org/ontology/construct/isSubjectOf> rdf:type owl:ObjectProperty ;
                                                                       rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                       rdfs:range <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                       rdfs:label "is subject of"@en-us ;
                                                                       skos:example "temperature is subject of temperature recording; particular individual is subject of SSN; commercial service is subject of commercial service agreement"@en-us ;
                                                                       annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                       annotation:naturalLanguageDefinition "primitive, generic relationship between an entity and some information content entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isTemporallyOverlappedBy
<https://spec.industrialontologies.org/ontology/construct/isTemporallyOverlappedBy> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                    owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps> ;
                                                                                    rdfs:domain [ rdf:type owl:Class ;
                                                                                                  owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                                <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                              )
                                                                                                ] ;
                                                                                    rdfs:range [ rdf:type owl:Class ;
                                                                                                 owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                               <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                             )
                                                                                               ] ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "is temporally overlapped by"@en-us ;
                                                                                    skos:example "When two plates are being welded at a joint, the heating of current point being welded is temporally overlapped by the cooling of a previously welded point; the receiving process is temporally overlapped by the sending process in a transaction process; Sumerian civilization (c. 3500 BCE - c. 2000 BCE) in Mesopotamia was temporally overlapped by Ancient Egyptian civilization (c. 3000 BCE - 30 BCE)."@en-us ;
                                                                                    annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                    annotation:firstOrderLogicAxiom "isTemporallyOverlappedBy(x,y) ‚Üî temporallyOverlaps(y,x)" ;
                                                                                    annotation:naturalLanguageDefinition "relation that holds between two intervals and processes i and j when the first instant of the temporal extent of j is earlier than and the last instant of the temporal extent of j is later than the first instant of the temporal extent of i, and the last instance of the temporal extent of j is earlier than the last instant of the temporal extent of i"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageAxiom "'is temporally overlapped by' and 'temporally overlaps' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                         rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> ;
                                                                                         rdfs:domain <https://spec.industrialontologies.org/ontology/construct/ValueExpression> ;
                                                                                         rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                         rdfs:label "is value expression of at all times"@en-us ;
                                                                                         skos:example "3√ó10^8 m/s is the value expression of the speed of light in a vacuum; 1.602176634√ó10‚àí19 coulombs is the value expression of the electric charge carried by a single proton"@en-us ;
                                                                                         annotation:naturalLanguageDefinition "relation from a value expression to an entity indicating that the value expression contains the value of the entity which does not change during the entire existence of the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                         rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/describes> ;
                                                                                         rdfs:domain <https://spec.industrialontologies.org/ontology/construct/ValueExpression> ;
                                                                                         rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                         rdfs:label "is value expression of at some time"@en-us ;
                                                                                         skos:example "1cm is the value expression of the diameter of a screw head that is specified in its design; 37C is the value expression of the temperature of a bioreactor measured during the production process; \"low risk\" is the value expression of a process parameter based on the risk analysis classification scheme; 3 g/l is the value expression of titer of an antibody generated by a process simulation"@en-us ;
                                                                                         annotation:adaptedFrom "http://purl.obolibrary.org/obo/OBI_0001938" ;
                                                                                         annotation:naturalLanguageDefinition "relation from a value expression to the entity indicating that the value expression contains the value of the entity determined or set at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/measuredByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/measuredByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime> ;
                                                                                rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                rdfs:range <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "measured by at some time"@en-us ;
                                                                                skos:example "the temperature within a production vessel is measured by a temperature sensor at certain points in time during a chemical production process; the weight of a material bulk is measured by a scale"@en-us ;
                                                                                annotation:naturalLanguageDefinition "relation from an entity to a material entity with a measurement capability that got realized to determine the value of the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf owl:topObjectProperty ;
                                                                              rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                                                              rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "measures at some time"@en-us ;
                                                                              skos:example "a tempearture sensor measures the temperature within a production vessel at certain points in time during the chemical production process; a scale measures the weight of a material bulk"@en-us ;
                                                                              annotation:explanatoryNote "In this context, value is always determined relative to some classification scheme or on a quantitative scale" ;
                                                                              annotation:naturalLanguageDefinition "relation from a material entity to an entity indicating that the measurement capability of the material entity got realized to determine the value of the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/meets
<https://spec.industrialontologies.org/ontology/construct/meets> rdf:type owl:ObjectProperty ;
                                                                 rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000063> ;
                                                                 owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/metBy> ;
                                                                 rdfs:domain [ rdf:type owl:Class ;
                                                                               owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                             <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                           )
                                                                             ] ;
                                                                 rdfs:range [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                            <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                          )
                                                                            ] ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "meets"@en-us ;
                                                                 skos:example "When an item is placed on a moving conveyor by a robotic arm, the process of placing the item meets the process of moving the item; summer meets fall; January meets February; the Christmas holiday period meets New Year‚Äôs holiday period."@en-us ;
                                                                 annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                 annotation:firstOrderLogicAxiom "LA1: meets(i,j) ‚Üí (TemporalInterval(i) ‚àß TemporalInterval(j)) ‚à® (Process(i) ‚àß Process(j))" ,
                                                                                                 "LA2: TemporalInterval(i) ‚àß TemporalInterval(j) ‚àß meets(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInstant(i1) ‚àß TemporalInstant(j1) ‚àß hasLastInstant(i,i1) ‚àß hasFirstInstant(j,j1) ‚àß occursSimultaneouslyWith(i1,j1))" ,
                                                                                                 "LA3: Process(i) ‚àß Process(j) ‚àß meets(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInterval(i1) ‚àß TemporalInterval(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß meets(i1,j1))" ;
                                                                 annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is the same as the first instant of the temporal extent of j"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'meets' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                           "LA2: If both i and j are 'temporal intervals' and i 'meets' j then the 'last instant of' i 'occurs simultaneously with' the 'first instant of' j" ,
                                                                                                           "LA3: If both i and j are 'process' and i 'meets' j then the 'temporal interval' that i occupies 'meets' the 'temporal interval' that j occupies" .


###  https://spec.industrialontologies.org/ontology/construct/metBy
<https://spec.industrialontologies.org/ontology/construct/metBy> rdf:type owl:ObjectProperty ;
                                                                 rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000062> ;
                                                                 rdfs:domain [ rdf:type owl:Class ;
                                                                               owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                             <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                           )
                                                                             ] ;
                                                                 rdfs:range [ rdf:type owl:Class ;
                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                            <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                          )
                                                                            ] ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "met by"@en-us ;
                                                                 skos:example "When an item is placed on a moving conveyor by a robotic arm, the process of moving of the item is met by the process of placing the item; fall is met by summer; February is met by January; the New Year‚Äôs holiday period is met by the Christmas holiday period."@en-us ;
                                                                 annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                 annotation:firstOrderLogicAxiom "metBy(x,y) ‚Üî meets(y,x)" ;
                                                                 annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of j is the same as the first instant of the temporal extent of i"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageAxiom "'met by' and 'meets' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/observedByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/observedByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime> ;
                                                                                rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                rdfs:range <https://spec.industrialontologies.org/ontology/construct/Agent> ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "observed by at some time"@en-us ;
                                                                                skos:example "a chemical reaction in an experiment is observed by a scientist, a machining process is observed by an operator, a group of COVID patients are observed by a doctor"@en-us ;
                                                                                annotation:firstOrderLogicAxiom "observedByAtSomeTime (y, x) ‚Üí Agent(x) ‚àß Entity(y) ‚àß ‚àÉp‚àÉi(Process(p) ‚àß InformationContentEntity(i) ‚àß participatesInAtSomeTime(x,p) ‚àß hasOutput(p,i) ‚àß isAbout(i,y))" ;
                                                                                annotation:naturalLanguageDefinition "relation from an entity to an agent indicating that the agent participates in some process that outputs information about the entity, at some time"@en-us ;
                                                                                annotation:semiFormalNaturalLanguageAxiom "p is observed by b at some time t holds when p is an 'entity' and b is an 'agent' and there is a 'process' in which b 'participates in at some time' and that 'has output' some 'information content entity' that 'is about' p" .


###  https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf owl:topObjectProperty ;
                                                                              rdfs:domain <https://spec.industrialontologies.org/ontology/construct/Agent> ;
                                                                              rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "observes at some time"@en-us ;
                                                                              skos:example "a scientist observing a chemical reaction in an experiment, an operator observes a machining process, a doctor observes a group of COVID patients"@en-us ;
                                                                              annotation:explanatoryNote "this property was not put under participates in at some time because the target of observation can be continuant or an occurent and in the case of an occurent an agent that observes the occurent might not participate in that occurent" ;
                                                                              annotation:firstOrderLogicAxiom "observesAtSomeTime (x, y) ‚Üí Agent(x) ‚àß Entity(y) ‚àß ‚àÉp‚àÉi(Process(p) ‚àß InformationContentEntity(i) ‚àß participatesInAtSomeTime(x,p) ‚àß hasOutput(p,i) ‚àß isAbout(i,y))" ;
                                                                              annotation:naturalLanguageDefinition "relation from an agent to an entity indicating that the agent participates in some process that outputs information about the entity, at some time"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "b observes p at some time t when b is an 'agent' and p is an 'entity and there is a 'process' in which b 'participates in at some time' and that 'has output' some 'information content entity' that 'is about' p" .


###  https://spec.industrialontologies.org/ontology/construct/occursDuring
<https://spec.industrialontologies.org/ontology/construct/occursDuring> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf owl:topObjectProperty ;
                                                                        rdf:type owl:TransitiveProperty ;
                                                                        rdfs:domain [ rdf:type owl:Class ;
                                                                                      owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                    <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                  )
                                                                                    ] ;
                                                                        rdfs:range [ rdf:type owl:Class ;
                                                                                     owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                   <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                 )
                                                                                   ] ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "occurs during"@en-us ;
                                                                        skos:example "The final inspection and removal of defective products occur during the product is being moved to the packaging station by a conveyor belt; a sensor measures the thickness of the wall during the sand-grinding process; turkey is traditionally served during dinners on Thanksgiving In the United States."@en-us ;
                                                                        annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                        annotation:firstOrderLogicAxiom "LA1: occursDuring(i,j) ‚Üí (TemporalInterval(i) ‚àß TemporalInterval(j)) ‚à® (Process(i) ‚àß Process(j))" ,
                                                                                                        "LA2: TemporalInterval(i) ‚àß TemporalInterval(j) ‚àß occursDuring(i,j) ‚Üí ‚àÉi1‚àÉi2‚àÉj1‚àÉj2(TemporalInstant(i1) ‚àß TemporalInstant(i2) ‚àß TemporalInstant(j1) ‚àß TemporalInstant(j2) ‚àß hasFirstInstant(i,i1) ‚àß hasLastInstant(i,i2) ‚àß hasFirstInstant(j,j1) ‚àß hasLastInstant(j,j2) ‚àß precedes(j1,i1) ‚àß precedes(i2,j2))" ,
                                                                                                        "LA3: Process(i) ‚àß Process(j) ‚àß occursDuring(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInterval(i1) ‚àß TemporalInterval(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß occursDuring(i1,j1))" ,
                                                                                                        "LA4: occursDuring(i,j) ‚Üî ‚àÉk(temporallyFinishes(i,k) ‚àß temporallyStarts(k,j))" ;
                                                                        annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of i is later than the first instant of the temporal extent of j and the last instant of the temporal extent of i is earlier than the last instant of the temporal extent of j"@en-us ;
                                                                        annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'occurs during' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                  "LA2: If both i and j are 'temporal intervals' and i 'occurs during' j' then first instant of' j ‚Äòprecedes‚Äô the 'first instant of' i and the 'last instant of' i ‚Äòprecedes‚Äô the 'last instant of' j" ,
                                                                                                                  "LA3: If both i and j are 'process' and i 'occurs during' j then the 'temporal interval' that i occupies 'occurs during' the 'temporal interval' that j occupies" ,
                                                                                                                  "LA4: i 'occurs during' j if and only if there exists k such that i temporally finishes k and k temporally starts j" .


###  https://spec.industrialontologies.org/ontology/construct/occursSimultaneouslyWith
<https://spec.industrialontologies.org/ontology/construct/occursSimultaneouslyWith> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                    rdf:type owl:SymmetricProperty ,
                                                                                             owl:TransitiveProperty ;
                                                                                    rdfs:domain [ rdf:type owl:Class ;
                                                                                                  owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                                <http://purl.obolibrary.org/obo/BFO_0000035>
                                                                                                                <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                                <http://purl.obolibrary.org/obo/BFO_0000203>
                                                                                                              )
                                                                                                ] ;
                                                                                    rdfs:range [ rdf:type owl:Class ;
                                                                                                 owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                               <http://purl.obolibrary.org/obo/BFO_0000035>
                                                                                                               <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                               <http://purl.obolibrary.org/obo/BFO_0000203>
                                                                                                             )
                                                                                               ] ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "occurs simultaneously with"@en-us ;
                                                                                    skos:example "The rotation of the chuck in a lathe occurs simultaneously with the running of the motor."@en-us ;
                                                                                    annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                    annotation:firstOrderLogicAxiom "LA1: occursSimultaneouslyWith(i,j) ‚Üí (TemporalInstant(i) ‚àß TemporalInstant(j)) ‚à® (TemporalInterval(i) ‚àß TemporalInterval(j)) ‚à® (Process(i) ‚àß Process(j)) ‚àß (ProcessBoundary(i) ‚àß ProcessBoundary(j))" ,
                                                                                                                    "LA2: TemporalInstant(i) ‚àß TemporalInstant(j) ‚àß occursSimultaneouslyWith(i,j) ‚Üí ‚àÉk‚àÉl(TemporalInstantValueExpression(k) ‚àß TemporalInstantValueExpression(l) ‚àß hasValueExpressionAtAllTimes(i,k) ‚àß hasValueExpressionAtAllTimes(j,l) ‚àß ‚àÉv1‚àÉv2(hasDateTimeInstantValue(k,v1) ‚àß hasDateTimeInstantValue(l,v2) ‚àß (v1 = v2)))" ,
                                                                                                                    "LA3: TemporalInterval(i) ‚àß TemporalInterval(j) ‚àß occursSimultaneouslyWith(i,j) ‚Üí ‚àÉi1‚àÉi2‚àÉj1‚àÉj2(TemporalInstant(i1) ‚àß TemporalInstant(j1) ‚àß TemporalInstant(i2) ‚àß TemporalInstant(j2) ‚àß hasFirstInstant(i,i1) ‚àß hasLastInstant(i,i2) ‚àß hasFirstInstant(j,j1) ‚àß hasLastInstant(j,j2) ‚àß occursSimultaneouslyWith(i1,j1) ‚àß occursSimultaneouslyWith(i2,j2))" ,
                                                                                                                    "LA4: Process(i) ‚àß Process(j) ‚àß occursSimultaneouslyWith(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInterval(i1) ‚àß TemporalInterval(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß occursSimultaneouslyWith(i1,j1))" ,
                                                                                                                    "LA5: ProcessBoundary(i) ‚àß ProcessBoundary(j) ‚àß occursSimultaneouslyWith(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInstant(i1) ‚àß TemporalInstant(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß occursSimultaneouslyWith(i1,j1))" ;
                                                                                    annotation:naturalLanguageDefinition "relation that holds between two time instants when they are simultaneous or between two intervals when they have same first and last instants or between two processes or two process boundaries when their temporal extents are the same"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageAxiom "LA1: if i 'occurs simultaneously with' j then either i and j are both ‚Äòtemporal instant‚Äô, or both are ‚Äòtemporal interval‚Äô or both are ‚Äòprocess‚Äô or both are ‚Äòprocess boundary‚Äô" ,
                                                                                                                              "LA2: If both i and j are both ‚Äòtemporal instant‚Äô and i 'occurs simoultaneously with' j then 'temporal instant value expression' of i is equal to the 'temporal instant value expression' of j" ,
                                                                                                                              "LA3: If i and j are both ‚Äòtemporal interval‚Äô and i 'occurs simoultaneously with' j then the 'first instant of' i 'occurs simoultaneously with' the 'first instant of' j and the 'last instant of' i 'occurs simoultaneously with' the 'last instant of' j" ,
                                                                                                                              "LA4: If both i and j are ‚Äòprocess‚Äô and i 'occurs simoultaneously with' j then the ‚Äòtemporal interval‚Äô occupied by i ‚Äòoccurs simoultaneously with‚Äô the ‚Äòtemporal interval‚Äô occupied by j" ,
                                                                                                                              "LA5: If i and j are both ‚Äòprocess boundary‚Äô and i 'occurs simoultaneously with' j then the ‚Äòtemporal instant‚Äô that i occupies 'occurs simoultaneously with' ‚Äòtemporal instant‚Äô that j occupies" .


###  https://spec.industrialontologies.org/ontology/construct/prescribedBy
<https://spec.industrialontologies.org/ontology/construct/prescribedBy> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/prescribes> ;
                                                                        rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                        rdfs:range <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "prescribed by"@en-us ;
                                                                        skos:example "some Artifact or Facility is modeled by a blueprint; a set of rules to be followed while acting in a role within a profession are prescribed by a professional code of conduct; tasks that need to be performed to achieve the Objectives of the Operation are prescribed by the Operation Plan"@en-us ;
                                                                        annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                        annotation:naturalLanguageDefinition "relation from an entity to an information content entity that the information content entity serves as a collection of rules or guide for if the entity is something that unfolds in time (occurrent), or as a model if the entity is someone or something physical or digital (continuant)"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/prescribes
<https://spec.industrialontologies.org/ontology/construct/prescribes> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isAbout> ;
                                                                      rdfs:domain <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                      rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "prescribes"@en-us ;
                                                                      skos:example "a blueprint serves as a model of some Artifact or Facility; a professional code of conduct serves as a set of rules to be followed while acting in a role within that profession; an Operations Plan serves as a guide for the tasks that need to be performed to achieve the Objectives of the Operation"@en-us ;
                                                                      annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                      annotation:naturalLanguageDefinition "relation from an information content entity to an entity such that the information content entity serves as a collection of rules or guide for the entity if the entity is something that unfolds in time (occurrent), or as a model if the entity is someone or something physical or digital (continuant)"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf
<https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                   rdfs:domain <https://spec.industrialontologies.org/ontology/construct/ProcessCharacteristic> ;
                                                                                   rdfs:range <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                   rdfs:label "process characteristic of"@en-us ;
                                                                                   skos:example "The average flow rate is a process characteristic of the water flowing through a pipe during a given period, the total energy consumed is a process characteristic of the heating process, the peak temperature is a process characteristic of the batch sterilization process." ;
                                                                                   annotation:naturalLanguageDefinition "relation between a characteristic and the process it is a characteristic of"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/processProfileOf
<https://spec.industrialontologies.org/ontology/construct/processProfileOf> rdf:type owl:ObjectProperty ;
                                                                            rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000138> ;
                                                                            rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000144> ;
                                                                            rdfs:range <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                            rdfs:label "process profile of"@en-us ;
                                                                            skos:example "pH profile is a process profile of culture growth, agitation speed profile is a process profile of a mixing process, tool vibration profile is a process profile of a engine running" ;
                                                                            annotation:adaptedFrom "axiom label in BFO2 Reference (094-005) in http://purl.obolibrary.org/obo/BFO_0000144 from BFO 2.0" ;
                                                                            annotation:firstOrderLogicAxiom "‚àÄx, y (processProfileOf(x,y) ‚Üí (properOccurrentPartOf(x,y) ‚àß ‚àÉz, t (properOccurrentPartOf(z,y) ‚àß TemporalRegion(t) ‚àß occupiesSpatioTemporalRegion(x,t) ‚àß occupiesSpatioTemporalRegion(y,t) ‚àß occupiesSpatioTemporalRegion(z,t) ‚àß ¬¨‚àÉw(occurrentPartOf(w,x) ‚àß occurrentPartOf(w,z)))))" ;
                                                                            annotation:naturalLanguageDefinition "relation that holds between a process profile and a process that it is part of such that the source process is a proper part of the target process and is temporally coextensive with another proper part of the target process that is mutually dependent on it and shares no parts with it."@en-us ;
                                                                            annotation:semiFormalNaturalLanguageAxiom "if x is 'process profile of' y, then x is a 'proper occurrent part of' y that shares a 'spatiotemporal region' with some other 'proper occurrent part' z of y such that x and z have no common 'occurrent part'" .


###  https://spec.industrialontologies.org/ontology/construct/qualityOf
<https://spec.industrialontologies.org/ontology/construct/qualityOf> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                     rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000019> ;
                                                                     rdfs:range <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "quality of"@en-us ;
                                                                     skos:example "this red color is a quality of this apple"@en-us ;
                                                                     annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000080" ;
                                                                     annotation:firstOrderLogicAxiom "qualityOf(x,y) ‚Üí Quality(x) ‚àß IndependentContinuant(y) ‚àß inheresIn(x,y)" ;
                                                                     annotation:naturalLanguageDefinition "relation from a quality to an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence"@en-us ;
                                                                     annotation:semiFormalNaturalLanguageAxiom "x disposition of y holds when x is a 'quality' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/recognizedByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/recognizedByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                  owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime> ;
                                                                                  rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                  rdfs:range <https://spec.industrialontologies.org/ontology/construct/Agent> ;
                                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                  rdfs:label "recognized by at some time"@en-us ;
                                                                                  skos:example "a failure event is recognized by an operator that results in information about the event such as the time of occurrence and the description about the failure; a defect on a part is recognized by a quality control engineer that results in information about the defect such as the nature of the defect and the cause of the defect"@en-us ;
                                                                                  annotation:naturalLanguageDefinition "relation from an entity to an agent that is able to describe the entity or is able to associate an information content entity that describes the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                rdfs:domain <https://spec.industrialontologies.org/ontology/construct/Agent> ;
                                                                                rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "recognizes at some time"@en-us ;
                                                                                skos:example "operator recognizes a failure event that results in information about the event such as the time of occurrence and the description about the failure, a quality control engineer recognizes a defect on a part that results in information about the defect such as the nature of the defect and the cause of the defect"@en-us ;
                                                                                annotation:explanatoryNote "Recognition is preceded by an observation of an entity that is related to the entity being recognized or the entity being recognized is an entity that is an attribute of the entity being observed" ,
                                                                                                           "this property was not put under participates in at some time because the target of recognition can be continuant or an occurent and in the case of an occurent an agent that recognizes the occurent might not participate in that occurent" ;
                                                                                annotation:naturalLanguageDefinition "relation from an agent to an entity that the agent is able to describe the entity or is able to associate an information content entity that describes the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/requirementSatisfiedBy
<https://spec.industrialontologies.org/ontology/construct/requirementSatisfiedBy> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                  owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement> ;
                                                                                  rdfs:domain <https://spec.industrialontologies.org/ontology/construct/RequirementSpecification> ;
                                                                                  rdfs:range <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                  rdfs:label "requirement satisfied by"@en-us ;
                                                                                  skos:example "a UML requirement specification is satisfied by a a piece of software; functional requirement specification of a car is satisfied by its desgn specification"@en-us ;
                                                                                  annotation:naturalLanguageDefinition "relation from a requirement specification to an entity that conforms to the requirement specification"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/roleOf
<https://spec.industrialontologies.org/ontology/construct/roleOf> rdf:type owl:ObjectProperty ;
                                                                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                  rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000023> ;
                                                                  rdfs:range <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                  rdfs:label "role of"@en-us ;
                                                                  skos:example "this investigator role is a role of this person"@en-us ;
                                                                  annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000081" ;
                                                                  annotation:firstOrderLogicAxiom "roleOf(x,y) ‚Üí Role(x) ‚àß IndependentContinuant(y) ‚àß inheresIn(x,y)" ;
                                                                  annotation:naturalLanguageDefinition "relation from a role to an independent continuant (the bearer), in which the role specifically depends on the bearer for its existence"@en-us ;
                                                                  annotation:semiFormalNaturalLanguageAxiom "x disposition of y holds when x is a 'role' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement
<https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement> rdf:type owl:ObjectProperty ;
                                                                                rdfs:domain <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                                                                rdfs:range <https://spec.industrialontologies.org/ontology/construct/RequirementSpecification> ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "satisfies requirement"@en-us ;
                                                                                skos:example "a piece of software satisfies a UML requirement specification, a design specification of a car satisfies its functional requirement specification"@en-us ;
                                                                                annotation:naturalLanguageDefinition "relation from an entity to a requirement specification that the entity conforms to"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/specializes
<https://spec.industrialontologies.org/ontology/construct/specializes> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotedBy> ;
                                                                       rdf:type owl:TransitiveProperty ;
                                                                       rdfs:domain <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                       rdfs:range <https://spec.industrialontologies.org/ontology/construct/Classifier> ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                       rdfs:label "specializes"@en-us ;
                                                                       annotation:explanatoryNote "See the expanded formalization and explanation under generalizes" ;
                                                                       annotation:firstOrderLogicDefinition "specializes(c1, c2) ‚Üî generalizes(c2, c1)" ;
                                                                       annotation:naturalLanguageDefinition "relation between two classifiers such that everything classified by the former is also classified by the latter"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageDefinition "c1 is 'specializes' c2 iff c2 generalizes c1" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyFinishedBy
<https://spec.industrialontologies.org/ontology/construct/temporallyFinishedBy> rdf:type owl:ObjectProperty ;
                                                                                rdfs:subPropertyOf owl:topObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/temporallyFinishes> ;
                                                                                rdf:type owl:TransitiveProperty ;
                                                                                rdfs:domain [ rdf:type owl:Class ;
                                                                                              owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                            <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                          )
                                                                                            ] ;
                                                                                rdfs:range [ rdf:type owl:Class ;
                                                                                             owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                           <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                         )
                                                                                           ] ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "temporally finished by"@en-us ;
                                                                                skos:example "A delivery process is temporally finished by the generation of ‚Äúproof of delivery‚Äù; a football match is temporally finished by the Referee‚Äôs final whistle; every week is temporally finished by a Sunday."@en-us ;
                                                                                annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                annotation:firstOrderLogicAxiom "temporallyFinishedBy(x,y) ‚Üî temporallyFinishes(y,x)" ;
                                                                                annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of j is the same as the last instant of the temporal extent of i and the first instant of i is preceded by the first instant of j"@en-us ;
                                                                                annotation:semiFormalNaturalLanguageAxiom "'temporally finished by' and 'temporally finishes' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyFinishes
<https://spec.industrialontologies.org/ontology/construct/temporallyFinishes> rdf:type owl:ObjectProperty ,
                                                                                       owl:TransitiveProperty ;
                                                                              rdfs:domain [ rdf:type owl:Class ;
                                                                                            owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                          <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                        )
                                                                                          ] ;
                                                                              rdfs:range [ rdf:type owl:Class ;
                                                                                           owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                         <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                       )
                                                                                         ] ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "temporally finishes"@en-us ;
                                                                              skos:example "The generation of ‚Äúproof of delivery‚Äù temporally finishes the delivery process; Referee‚Äôs final whistle temporally finishes the football match; Sunday temporally finishes the week."@en-us ;
                                                                              annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                              annotation:firstOrderLogicAxiom "LA1: temporallyFinishes(i,j) ‚Üí (TemporalInterval(i) ‚àß TemporalInterval(j)) ‚à® (Process(i) ‚àß Process(j))" ,
                                                                                                              "LA2: TemporalInterval(i) ‚àß TemporalInterval(j) ‚àß temporallyFinishes(i,j) ‚Üí ‚àÉi1‚àÉi2‚àÉj1‚àÉj2(TemporalInstant(i1) ‚àß TemporalInstant(i2) ‚àß TemporalInstant(j1) ‚àß TemporalInstant(j2) ‚àß hasFirstInstant(i,i1) ‚àß hasLastInstant(i,i2) ‚àß hasFirstInstant(j,j1) ‚àß hasLastInstant(j,j2) ‚àß occursSimultaneouslyWith(i2,j2) ‚àß precedes(j1,i1))" ,
                                                                                                              "LA3: Process(i) ‚àß Process(j) ‚àß temporallyFinishes(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInterval(i1) ‚àß TemporalInterval(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß temporallyFinishes(i1,j1))" ,
                                                                                                              "LA4: temporallyFinishes(i,j) ‚Üî ‚àÉk‚àÉl(meets(i,k)‚àßmeets(j,k) ‚àß before(l,i) ‚àß meets(l,j))" ;
                                                                              annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is the same as the last instant of the temporal extent of j and the first instant of j precedes the first instant of i"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'temporally finishes' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                        "LA2: If both i and j are 'temporal intervals' and i 'temporally finishes' j then the 'last instant‚Äô of i ‚Äòoccurs simultaneously with‚Äô the 'last instant of' j and the 'first instant of' j 'precedes' the 'first instant‚Äô of i" ,
                                                                                                                        "LA3: If both i and j are 'process' and i 'temporally finishes' j then the 'temporal interval' that i occupies 'temporally finishes' the 'temporal interval' that j occupies" ,
                                                                                                                        "LA4: i 'temporally finishes' j if and only if there exists k such that i 'meets' k and j 'meets' k, and there exists l that is 'before' i and 'meets' j" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps
<https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf owl:topObjectProperty ;
                                                                              rdfs:domain [ rdf:type owl:Class ;
                                                                                            owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                          <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                        )
                                                                                          ] ;
                                                                              rdfs:range [ rdf:type owl:Class ;
                                                                                           owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                         <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                       )
                                                                                         ] ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "temporally overlaps"@en-us ;
                                                                              skos:example "When two plates are being welded at a joint, the cooling of a previously welded point temporally overlaps the heating of the point which is currently being welded; the sending process temporally overlaps the receiving process in a transaction process; Ancient Egyptian civilization (c. 3000 BCE - 30 BCE) temporally overlapped the Sumerian civilization (c. 3500 BCE - c. 2000 BCE) in Mesopotamia and the Indus Valley Civilization (c. 2600 BCE - c. 1900 BCE) in South Asia."@en-us ;
                                                                              annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                              annotation:firstOrderLogicAxiom "LA1: temporallyOverlaps(i,j) ‚Üí (TemporalInterval(i) ‚àß TemporalInterval(j)) ‚à® (Process(i) ‚àß Process(j))" ,
                                                                                                              "LA2: TemporalInterval(i) ‚àß TemporalInterval(j) ‚àß temporallyOverlaps(i,j) ‚Üí ‚àÉi1‚àÉi2‚àÉj1‚àÉj2(TemporalInstant(i1) ‚àß TemporalInstant(i2) ‚àß TemporalInstant(j1) ‚àß TemporalInstant(j2) ‚àß hasFirstInstant(i,i1) ‚àß hasLastInstant(i,i2) ‚àß hasFirstInstant(j,j1) ‚àß hasLastInstant(j,j2) ‚àß precedes(j1,i2) ‚àß precedes(i1,j1) ‚àß precedes(i2,j2))" ,
                                                                                                              "LA3: Process(i) ‚àß Process(j) ‚àß temporallyOverlaps(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInterval(i1) ‚àß TemporalInterval(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß temporallyOverlaps(i1,j1))" ,
                                                                                                              "LA4: temporallyOverlaps(i,j) ‚Üî ‚àÉk(temporallyFinishes(k,i) ‚àß starts(k,j))" ;
                                                                              annotation:naturalLanguageDefinition "relation that holds between two intervals and processes i and j when the first instant of the temporal extent of i is earlier than and the last instant of the temporal extent of i is later than the first instant of the temporal extent of j, and the last instance of the temporal extent of i is earlier than the last instant of the temporal extent of j"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'temporally overlaps' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                        "LA2: If both i and j are 'temporal intervals' and i 'temporally overlaps' j then the 'first instant‚Äô of j ‚Äòprecedes‚Äô the 'last instant of' i and the 'first instant of' i ‚Äòprecedes‚Äô the 'first instant‚Äô of j and the 'last instant of' i ‚Äòprecedes‚Äô the 'last instant of' j" ,
                                                                                                                        "LA3: If both i and j are 'process' and i 'temporally overlaps' j then the 'temporal interval' that i occupies 'temporally overlaps' the 'temporal interval' that j occupies" ,
                                                                                                                        "LA4: i 'temporally overlaps' j if and only if there exists k that 'temporally finishes' i and 'temporally starts' j" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyStartedBy
<https://spec.industrialontologies.org/ontology/construct/temporallyStartedBy> rdf:type owl:ObjectProperty ;
                                                                               rdfs:subPropertyOf owl:topObjectProperty ;
                                                                               owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/temporallyStarts> ;
                                                                               rdf:type owl:TransitiveProperty ;
                                                                               rdfs:domain [ rdf:type owl:Class ;
                                                                                             owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                           <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                         )
                                                                                           ] ;
                                                                               rdfs:range [ rdf:type owl:Class ;
                                                                                            owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                          <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                        )
                                                                                          ] ;
                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                               rdfs:label "temporally started by"@en-us ;
                                                                               skos:example "An internal combustion engine is temporally started (running) by the process of cranking; some machine is temporally started (running) by pressing a switch; every year is temporally started by the New Year‚Äôs Day."@en-us ;
                                                                               annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                               annotation:firstOrderLogicAxiom "temporallyStartedBy(x,y) ‚Üî temporallyStarts(y,x)" ;
                                                                               annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of j is the same as first the instant of the temporal extent of i and the last instant of j precedes the last instant of i"@en-us ;
                                                                               annotation:semiFormalNaturalLanguageAxiom "'temporally started by' and 'temporally starts' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyStarts
<https://spec.industrialontologies.org/ontology/construct/temporallyStarts> rdf:type owl:ObjectProperty ,
                                                                                     owl:TransitiveProperty ;
                                                                            rdfs:domain [ rdf:type owl:Class ;
                                                                                          owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                        <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                      )
                                                                                        ] ;
                                                                            rdfs:range [ rdf:type owl:Class ;
                                                                                         owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                       <http://purl.obolibrary.org/obo/BFO_0000202>
                                                                                                     )
                                                                                       ] ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                            rdfs:label "temporally starts"@en-us ;
                                                                            skos:example "the process of cranking temporally starts (the running of) an internal combustion engine; the pressing of a switch temporally starts (the running of) some machine; the New Year‚Äôs Day temporally starts a year."@en-us ;
                                                                            annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                            annotation:firstOrderLogicAxiom "LA1: temporallyStarts(i,j) ‚Üí (TemporalInterval(i) ‚àß TemporalInterval(j)) ‚à® (Process(i) ‚àß Process(j))" ,
                                                                                                            "LA2: TemporalInterval(i) ‚àß TemporalInterval(j) ‚àß temporallyStarts(i,j) ‚Üí ‚àÉi1‚àÉi2‚àÉj1‚àÉj2(TemporalInstant(i1) ‚àß TemporalInstant(i2) ‚àß TemporalInstant(j1) ‚àß TemporalInstant(j2) ‚àß hasFirstInstant(i,i1) ‚àß hasLastInstant(i,i2) ‚àß hasFirstInstant(j,j1) ‚àß hasLastInstant(j,j2) ‚àß occursSimultaneouslyWith(i1,j1) ‚àß precedes(i2,j2))" ,
                                                                                                            "LA3: Process(i) ‚àß Process(j) ‚àß temporallyStarts(i,j) ‚Üí ‚àÉi1‚àÉj1(TemporalInterval(i1) ‚àß TemporalInterval(j1) ‚àß occupiesTemporalRegion(i,i1) ‚àß occupiesTemporalRegion(j,j1) ‚àß temporallyStarts(i1,j1))" ,
                                                                                                            "LA4: temporallyStarts(i,j) ‚Üî ‚àÉk‚àÉl(meets(k,i) ‚àß meets(k,j) ‚àß before(i,l) ‚àß meets(j,l))" ;
                                                                            annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of i is the same as first the instant of the temporal extent of j and the last instant of i precedes the last instant of j"@en-us ;
                                                                            annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'temporally starts' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                      "LA2: If both i and j are 'temporal intervals' and i 'temporally starts' j then the 'first instant‚Äô of i ‚Äòoccurs simultaneously with‚Äô the 'first instant of' j and the 'last instant of' i 'precedes' the 'last instant of' j" ,
                                                                                                                      "LA3: If both i and j are 'process' and i 'temporally starts' j then the 'temporal interval' that i occupies 'temporally starts' the 'temporal interval' that j occupies" ,
                                                                                                                      "LA4: i 'temporally starts' j if and only if there exists k that 'meets' i and j and there exists l such that i is 'before' l and j 'meets' l" .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000002
copi:COPI_0000002 rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                  owl:propertyChainAxiom ( <https://spec.industrialontologies.org/ontology/construct/hasFunction>
                                           <http://purl.obolibrary.org/obo/BFO_0000054>
                                         ) ;
                  dcterms:source "ODR-011 ¬ß4" ;
                  rdfs:comment "A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ‚àò obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas fun√ß√µes projetadas."@pt-br ,
                               "The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ‚àò obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions."@en ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "functionally participates in"@en ,
                             "participa funcionalmente em"@pt-br ;
                  annotation:explanatoryNote "Distingue a participa√ß√£o mediada por fun√ß√£o da participa√ß√£o geral: obo:BFO_0000056 (participa em) vale sempre que um continuante toma parte em algum processo por qualquer raz√£o; copi:participatesIn √© entailada apenas pela cadeia hasFunction ‚àò BFO_0000054 (√© realizada em). Uma bomba participa funcionalmente em toda opera√ß√£o de aumento de press√£o de l√≠quido que realiza sua fun√ß√£o de bombeamento; BFO_0000056 vale adicionalmente para qualquer outro envolvimento."@pt-br ,
                                             "Distinguishes function-mediated from general participation: obo:BFO_0000056 (participates in) holds whenever a continuant takes part in any process for any reason; copi:participatesIn is entailed only via the chain hasFunction ‚àò BFO_0000054 (is realized in). A pump functionally participates in every liquid-pressure-increase operation that realizes its pumping function; BFO_0000056 additionally covers any other process involvement."@en ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ‚àò obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas fun√ß√µes projetadas."@pt-br ,
                                                       "The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ‚àò obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions."@en .


#################################################################
#    Data properties
#################################################################

###  https://spec.industrialontologies.org/ontology/construct/hasDateTimeInstantValue
<https://spec.industrialontologies.org/ontology/construct/hasDateTimeInstantValue> rdf:type owl:DatatypeProperty ;
                                                                                   rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/hasSimpleExpressionValue> ;
                                                                                   rdfs:domain <https://spec.industrialontologies.org/ontology/construct/TemporalInstantValueExpression> ;
                                                                                   rdfs:range xsd:dateTime ;
                                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                   rdfs:label "has date-time instant value"@en-us ;
                                                                                   skos:example "The time point at 16:30pm at UTC on 3rd March 2023 is asserted by the associated (‚Äòis value expression of at all times‚Äô) ‚Äòtemporal instant value expression‚Äô having date-time value (‚Äòhas date-time instant value‚Äô) 2023-03-03T16:30:00Z."@en-us ;
                                                                                   annotation:explanatoryNote """1. This data property may be used to specify a ‚Äòtemporal instant value expression‚Äô in XSD date-time format (e.g., 2002-10-10T17:00:00Z). For a detailed description of xsd:DateTime, see https://www.w3.org/TR/xmlschema-2/#dateTime. 
2. While comparing two ‚Äòtemporal instant value expression‚Äô, it is important to make sure that their date-time expressions are given in the same calendar and clock system.
3. For detailed expression of date and time in a specific calendar system, use a suitable subclass of TemporalPosition class from Time ontology (https://www.w3.org/TR/owl-time/) instead of ‚Äòtemporal instant value expression‚Äô (see mapping file https://spec.industrialontologies.org/ontology/core/commonstocoremapping/MappingOWLTimeToIOF/)."""@en-us ;
                                                                                   annotation:naturalLanguageDefinition "data property that relates a time instance value to a XSD date-time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasSimpleExpressionValue
<https://spec.industrialontologies.org/ontology/construct/hasSimpleExpressionValue> rdf:type owl:DatatypeProperty ;
                                                                                    rdfs:subPropertyOf owl:topDataProperty ;
                                                                                    rdfs:domain <https://spec.industrialontologies.org/ontology/construct/ValueExpression> ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "has simple expression value"@en-us ;
                                                                                    skos:example "value expression with the unit 'C' that is the value expression of temperature has simple expression value \"37\""@en-us ;
                                                                                    annotation:explanatoryNote """1. the literal represents the magnitude or a
category within a classification scheme of an entity that the value expression is the value expression of
2. The label 'simple expression' was chosen due to the possiblity of introduction of a 'complex expression' object property in the future release that would be utilized for representation of things such as mathematical formulas""" ;
                                                                                    annotation:naturalLanguageDefinition "data property that relates a value expression to a literal"@en-us .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000001
<http://purl.obolibrary.org/obo/BFO_0000001> rdf:type owl:Class ;
                                             dce:identifier "001-BFO" ;
                                             rdfs:label "entity"@en ;
                                             skos:definition "(Elucidation) An entity is anything that exists or has existed or will exist"@en ;
                                             skos:example "Julius Caesar; the Second World War; your body mass index; Verdi's Requiem"@en .


###  http://purl.obolibrary.org/obo/BFO_0000002
<http://purl.obolibrary.org/obo/BFO_0000002> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000001> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000002>
                                                             ] ;
                                             owl:disjointWith <http://purl.obolibrary.org/obo/BFO_0000003> ;
                                             dce:identifier "008-BFO" ;
                                             rdfs:label "continuant"@en ;
                                             skos:definition "(Elucidation) A continuant is an entity that persists, endures, or continues to exist through time while maintaining its identity"@en ;
                                             skos:example "A human being; a tennis ball; a cave; a region of space; someone's temperature"@en .


###  http://purl.obolibrary.org/obo/BFO_0000003
<http://purl.obolibrary.org/obo/BFO_0000003> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000001> ;
                                             dce:identifier "077-BFO" ;
                                             rdfs:label "occurrent"@en ;
                                             skos:definition "(Elucidation) An occurrent is an entity that unfolds itself in time or it is the start or end of such an entity or it is a temporal or spatiotemporal region"@en ;
                                             skos:example "As for process, history, process boundary, spatiotemporal region, zero-dimensional temporal region, one-dimensional temporal region, temporal interval, temporal instant."@en .


###  http://purl.obolibrary.org/obo/BFO_0000004
<http://purl.obolibrary.org/obo/BFO_0000004> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000002> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000004>
                                                             ] ;
                                             dce:identifier "017-BFO" ;
                                             rdfs:label "independent continuant"@en ;
                                             skos:definition "b is an independent continuant =Def b is a continuant & there is no c such that b specifically depends on c or b generically depends on c"@en ;
                                             skos:example "An atom; a molecule; an organism; a heart; a chair; the bottom right portion of a human torso; a leg; the interior of your mouth; a spatial region; an orchestra"@en .


###  http://purl.obolibrary.org/obo/BFO_0000006
<http://purl.obolibrary.org/obo/BFO_0000006> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000141> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000006>
                                                             ] ;
                                             dce:identifier "035-BFO" ;
                                             rdfs:label "spatial region"@en ;
                                             skos:definition "(Elucidation) A spatial region is a continuant entity that is a continuant part of the spatial projection of a portion of spacetime at a given time"@en ;
                                             skos:example "As for zero-dimensional spatial region, one-dimensional spatial region, two-dimensional spatial region, three-dimensional spatial region"@en .


###  http://purl.obolibrary.org/obo/BFO_0000008
<http://purl.obolibrary.org/obo/BFO_0000008> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000003> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000132> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000008>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000139> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000008>
                                                             ] ;
                                             dce:identifier "100-BFO" ;
                                             rdfs:label "temporal region"@en ;
                                             skos:definition "(Elucidation) A temporal region is an occurrent over which processes can unfold"@en ;
                                             skos:example "As for zero-dimensional temporal region and one-dimensional temporal region"@en .


###  http://purl.obolibrary.org/obo/BFO_0000009
<http://purl.obolibrary.org/obo/BFO_0000009> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000006> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000009>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000018>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000026>
                                                                                               )
                                                                                 ]
                                                             ] ;
                                             dce:identifier "039-BFO" ;
                                             rdfs:label "two-dimensional spatial region"@en ;
                                             skos:definition "(Elucidation) A two-dimensional spatial region is a spatial region that is a whole consisting of a surface together with zero or more surfaces which may have spatial regions of lower dimension as parts"@en ;
                                             skos:example "The surface of a sphere-shaped part of space; an infinitely thin plane in space"@en .


###  http://purl.obolibrary.org/obo/BFO_0000011
<http://purl.obolibrary.org/obo/BFO_0000011> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000003> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000132> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000011>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000139> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000011>
                                                             ] ;
                                             dce:identifier "095-BFO" ;
                                             rdfs:label "spatiotemporal region"@en ;
                                             skos:definition "(Elucidation) A spatiotemporal region is an occurrent that is an occurrent part of spacetime"@en ;
                                             skos:example "The spatiotemporal region occupied by the development of a cancer tumour; the spatiotemporal region occupied by an orbiting satellite"@en ;
                                             skos:scopeNote "'Spacetime' here refers to the maximal instance of the universal spatiotemporal region."@en .


###  http://purl.obolibrary.org/obo/BFO_0000015
<http://purl.obolibrary.org/obo/BFO_0000015> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000003> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000117> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000035>
                                                                                               )
                                                                                 ]
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000132> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000015>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000139> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000015>
                                                             ] ;
                                             dce:identifier "083-BFO" ;
                                             rdfs:label "process"@en ;
                                             skos:altLabel "event"@en ;
                                             skos:definition "(Elucidation) p is a process means p is an occurrent that has some temporal proper part and for some time t, p has some material entity as participant"@en ;
                                             skos:example "An act of selling; the life of an organism; a process of sleeping; a process of cell-division; a beating of the heart; a process of meiosis; the taxiing of an aircraft; the programming of a computer"@en .


###  http://purl.obolibrary.org/obo/BFO_0000016
<http://purl.obolibrary.org/obo/BFO_0000016> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000017> ;
                                             owl:disjointWith <http://purl.obolibrary.org/obo/BFO_0000023> ;
                                             dce:identifier "062-BFO" ;
                                             rdfs:label "disposition"@en ;
                                             skos:altLabel "internally-grounded realizable entity"@en ;
                                             skos:definition "(Elucidation) A disposition b is a realizable entity such that if b ceases to exist then its bearer is physically changed & b's realization occurs when and because this bearer is in some special physical circumstances & this realization occurs in virtue of the bearer's physical make-up"@en ;
                                             skos:example "An atom of element X has the disposition to decay to an atom of element Y; the cell wall is disposed to transport cellular material through endocytosis and exocytosis; certain people have a predisposition to colon cancer; children are innately disposed to categorize objects in certain ways"@en .


###  http://purl.obolibrary.org/obo/BFO_0000017
<http://purl.obolibrary.org/obo/BFO_0000017> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000020> ;
                                             owl:disjointWith <http://purl.obolibrary.org/obo/BFO_0000019> ;
                                             dce:identifier "058-BFO" ;
                                             rdfs:label "realizable entity"@en ;
                                             skos:definition "(Elucidation) A realizable entity is a specifically dependent continuant that inheres in some independent continuant which is not a spatial region & which is of a type some instances of which are realized in processes of a correlated type"@en ;
                                             skos:example "The role of being a doctor; the role of this boundary to delineate where Utah and Colorado meet; the function of your reproductive organs; the disposition of your blood to coagulate; the disposition of this piece of metal to conduct electricity"@en .


###  http://purl.obolibrary.org/obo/BFO_0000018
<http://purl.obolibrary.org/obo/BFO_0000018> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000006> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000018>
                                                             ] ;
                                             dce:identifier "037-BFO" ;
                                             rdfs:label "zero-dimensional spatial region"@en ;
                                             skos:definition "(Elucidation) A zero-dimensional spatial region is one or a collection of more than one spatially disjoint points in space"@en ;
                                             skos:example "The spatial region occupied at some time instant by the North Pole"@en .


###  http://purl.obolibrary.org/obo/BFO_0000019
<http://purl.obolibrary.org/obo/BFO_0000019> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000020> ;
                                             dce:identifier "055-BFO" ;
                                             rdfs:label "quality"@en ;
                                             skos:definition "(Elucidation) A quality is a specifically dependent continuant that, in contrast to roles and dispositions, does not require any further process in order to be realized"@en ;
                                             skos:example "The colour of a tomato; the ambient temperature of this portion of air; the length of the circumference of your waist; the shape of your nose; the shape of your nostril; the mass of this piece of gold"@en .


###  http://purl.obolibrary.org/obo/BFO_0000020
<http://purl.obolibrary.org/obo/BFO_0000020> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                             dce:identifier "050-BFO" ;
                                             rdfs:label "specifically dependent continuant"@en ;
                                             skos:definition "b is a specifically dependent continuant =Def b is a continuant & there is some independent continuant c which is not a spatial region & which is such that b specifically depends on c"@en ;
                                             skos:example "(with multiple bearers) John's love for Mary; the ownership relation between John and this statue; the relation of authority between John and his subordinates"@en ,
                                                          "(with one bearer) The mass of this tomato; the pink colour of a medium rare piece of grilled filet mignon at its centre; the smell of this portion of mozzarella; the disposition of this fish to decay; the role of being a doctor; the function of this heart to pump blood; the shape of this hole"@en .


###  http://purl.obolibrary.org/obo/BFO_0000023
<http://purl.obolibrary.org/obo/BFO_0000023> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000017> ;
                                             dce:identifier "061-BFO" ;
                                             rdfs:label "role"@en ;
                                             skos:altLabel "externally-grounded realizable entity"@en ;
                                             skos:definition "(Elucidation) A role b is a realizable entity such that b exists because there is some single bearer that is in some special physical, social, or institutional set of circumstances in which this bearer does not have to be & b is not such that, if it ceases to exist, then the physical make-up of the bearer is thereby changed"@en ;
                                             skos:example "The priest role; the student role; the role of subject in a clinical trial; the role of a stone in marking a property boundary; the role of a boundary to demarcate two neighbouring administrative territories; the role of a building in serving as a military target"@en .


###  http://purl.obolibrary.org/obo/BFO_0000024
<http://purl.obolibrary.org/obo/BFO_0000024> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                             dce:identifier "027-BFO" ;
                                             rdfs:label "fiat object part"@en ;
                                             skos:definition "(Elucidation) A fiat object part b is a material entity & such that if b exists then it is continuant part of some object c & demarcated from the remainder of c by one or more fiat surfaces"@en ;
                                             skos:example "The upper and lower lobes of the left lung; the dorsal and ventral surfaces of the body; the Western hemisphere of the Earth; the FMA:regional parts of an intact human body"@en .


###  http://purl.obolibrary.org/obo/BFO_0000026
<http://purl.obolibrary.org/obo/BFO_0000026> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000006> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000018>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000026>
                                                                                               )
                                                                                 ]
                                                             ] ;
                                             dce:identifier "038-BFO" ;
                                             rdfs:label "one-dimensional spatial region"@en ;
                                             skos:definition "(Elucidation) A one-dimensional spatial region is a whole consisting of a line together with zero or more lines which may have points as parts"@en ;
                                             skos:example "An edge of a cube-shaped portion of space; a line connecting two points; two parallel lines extended in space"@en .


###  http://purl.obolibrary.org/obo/BFO_0000027
<http://purl.obolibrary.org/obo/BFO_0000027> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                             dce:identifier "025-BFO" ;
                                             rdfs:label "object aggregate"@en ;
                                             skos:definition "(Elucidation) An object aggregate is a material entity consisting exactly of a plurality (‚â•1) of objects as member parts which together form a unit"@en ;
                                             skos:example "The aggregate of the musicians in a symphony orchestra and their instruments; the aggregate of bearings in a constant velocity axle joint; the nitrogen atoms in the atmosphere; a collection of cells in a blood biobank"@en ;
                                             skos:scopeNote "'Exactly' means that there are no parts of the object aggregate other than its member parts." ,
                                                            "The unit can, at certain times, consist of exactly one object, for example, when a wolf litter loses all but one of its pups, but it must at some time have a plurality of member parts." .


###  http://purl.obolibrary.org/obo/BFO_0000028
<http://purl.obolibrary.org/obo/BFO_0000028> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000006> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000006>
                                                             ] ;
                                             dce:identifier "040-BFO" ;
                                             rdfs:label "three-dimensional spatial region"@en ;
                                             skos:definition "(Elucidation) A three-dimensional spatial region is a whole consisting of a spatial volume together with zero or more spatial volumes which may have spatial regions of lower dimension as parts"@en ;
                                             skos:example "A cube-shaped region of space; a sphere-shaped region of space; the region of space occupied by all and only the planets in the solar system at some point in time"@en .


###  http://purl.obolibrary.org/obo/BFO_0000029
<http://purl.obolibrary.org/obo/BFO_0000029> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000141> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000029>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                               )
                                                                                 ]
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000029>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000140>
                                                                                               )
                                                                                 ]
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000210> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000028>
                                                             ] ;
                                             dce:identifier "034-BFO" ;
                                             rdfs:label "site"@en ;
                                             skos:definition "(Elucidation) A site is a three-dimensional immaterial entity whose boundaries either (partially or wholly) coincide with the boundaries of one or more material entities or have locations determined in relation to some material entity"@en ;
                                             skos:example "A hole in a portion of cheese; a rabbit hole; the Grand Canyon; the Piazza San Marco; the kangaroo-joey-containing hole of a kangaroo pouch; your left nostril (a fiat part - the opening - of your left nasal cavity); the lumen of your gut; the hold of a ship; the interior of the trunk of your car; hole in an engineered floor joist"@en ,
                                                          "location of a container, floor area in a factory building, location of a machine (relative to the coordinate of a factory floor), location on a shelf in a warehouse"@en-us ;
                                             annotation:explanatoryNote "Even though site (physical location) always refers to a 3D space it is fine to define it practically just through 2D or 1D or 0D spatial region. For example when we want to talk about 2x2m area within a factory floor even though the space specified is 2D it is still ok to assert it as site as there is always the third dimension above the area that is implicit." ;
                                             annotation:synonym "physical location"@en-us .


###  http://purl.obolibrary.org/obo/BFO_0000030
<http://purl.obolibrary.org/obo/BFO_0000030> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ;
                                             dce:identifier "024-BFO" ;
                                             rdfs:label "object"@en ;
                                             skos:definition "(Elucidation) An object is a material entity which manifests causal unity & is of a type instances of which are maximal relative to the sort of causal unity manifested"@en ;
                                             skos:example "An organism; a fish tank; a planet; a laptop; a valve; a block of marble; an ice cube"@en ;
                                             skos:scopeNote "A description of three primary sorts of causal unity is provided in Basic Formal Ontology 2.0. Specification and User Guide"@en .


###  http://purl.obolibrary.org/obo/BFO_0000031
<http://purl.obolibrary.org/obo/BFO_0000031> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000002> ;
                                             dce:identifier "074-BFO" ;
                                             rdfs:label "generically dependent continuant"@en ;
                                             skos:altLabel "g-dependent continuant"@en ;
                                             skos:definition "(Elucidation) A generically dependent continuant is an entity that exists in virtue of the fact that there is at least one of what may be multiple copies which is the content or the pattern that multiple copies would share"@en ;
                                             skos:example "The pdf file on your laptop; the pdf file that is a copy thereof on my laptop; the sequence of this protein molecule; the sequence that is a copy thereof in that protein molecule; the content that is shared by a string of dots and dashes written on a page and the transmitted Morse code signal; the content of a sentence; an engineering blueprint"@en .


###  http://purl.obolibrary.org/obo/BFO_0000034
<http://purl.obolibrary.org/obo/BFO_0000034> rdf:type owl:Class ;
                                             rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Capability> ;
                                             dce:identifier "064-BFO" ;
                                             rdfs:label "function"@en ;
                                             skos:definition "(Elucidation) A function is a disposition that exists in virtue of its bearer's physical make-up & this physical make-up is something the bearer possesses because it came into being either through evolution (in the case of natural biological entities) or through intentional design (in the case of artefacts) in order to realize processes of a certain sort"@en ;
                                             skos:example "The function of a hammer to drive in nails; the function of a heart pacemaker to regulate the beating of a heart through electricity"@en .


###  http://purl.obolibrary.org/obo/BFO_0000035
<http://purl.obolibrary.org/obo/BFO_0000035> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000003> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000117> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000035>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000121> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000035>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000132> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000035>
                                                                                               )
                                                                                 ]
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000139> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000035>
                                                                                               )
                                                                                 ]
                                                             ] ;
                                             dce:identifier "084-BFO" ;
                                             rdfs:label "process boundary"@en ;
                                             skos:definition "p is a process boundary =Def p is a temporal part of a process & p has no proper temporal parts"@en ;
                                             skos:example "The boundary between the 2nd and 3rd year of your life"@en .


###  http://purl.obolibrary.org/obo/BFO_0000038
<http://purl.obolibrary.org/obo/BFO_0000038> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000008> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000121> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000038>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000148>
                                                                                               )
                                                                                 ]
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000139> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000038>
                                                             ] ;
                                             owl:disjointWith <http://purl.obolibrary.org/obo/BFO_0000148> ;
                                             dce:identifier "103-BFO" ;
                                             rdfs:label "one-dimensional temporal region"@en ;
                                             skos:definition "(Elucidation) A one-dimensional temporal region is a temporal region that is a whole that has a temporal interval and zero or more temporal intervals and temporal instants as parts"@en ;
                                             skos:example "The temporal region during which a process occurs"@en .


###  http://purl.obolibrary.org/obo/BFO_0000040
<http://purl.obolibrary.org/obo/BFO_0000040> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000004> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000040>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000029>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000140>
                                                                                               )
                                                                                 ]
                                                             ] ;
                                             owl:disjointWith <http://purl.obolibrary.org/obo/BFO_0000141> ;
                                             dce:identifier "019-BFO" ;
                                             rdfs:label "material entity"@en ;
                                             skos:definition "(Elucidation) A material entity is an independent continuant has some portion of matter as continuant part"@en ;
                                             skos:example "A human being; the undetached arm of a human being; an aggregate of human beings"@en .


###  http://purl.obolibrary.org/obo/BFO_0000140
<http://purl.obolibrary.org/obo/BFO_0000140> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000141> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000124> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000140>
                                                             ] ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000140>
                                                             ] ;
                                             dce:identifier "029-BFO" ;
                                             rdfs:label "continuant fiat boundary"@en ;
                                             skos:definition "(Elucidation) A continuant fiat boundary b is an immaterial entity that is of zero, one or two dimensions & such that there is no time t when b has a spatial region as continuant part & whose location is determined in relation to some material entity"@en ;
                                             skos:example "As for fiat point, fiat line, fiat surface"@en .


###  http://purl.obolibrary.org/obo/BFO_0000141
<http://purl.obolibrary.org/obo/BFO_0000141> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000004> ;
                                             dce:identifier "028-BFO" ;
                                             rdfs:label "immaterial entity"@en ;
                                             skos:definition "b is an immaterial entity =Def b is an independent continuant which is such that there is no time t when it has a material entity as continuant part"@en ;
                                             skos:example "As for fiat point, fiat line, fiat surface, site"@en .


###  http://purl.obolibrary.org/obo/BFO_0000142
<http://purl.obolibrary.org/obo/BFO_0000142> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000140> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000142>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000147>
                                                                                               )
                                                                                 ]
                                                             ] ;
                                             dce:identifier "032-BFO" ;
                                             rdfs:label "fiat line"@en ;
                                             skos:definition "(Elucidation) A fiat line is a one-dimensional continuant fiat boundary that is continuous"@en ;
                                             skos:example "The Equator; all geopolitical boundaries; all lines of latitude and longitude; the median sulcus of your tongue; the line separating the outer surface of the mucosa of the lower lip from the outer surface of the skin of the chin"@en .


###  http://purl.obolibrary.org/obo/BFO_0000144
<http://purl.obolibrary.org/obo/BFO_0000144> rdf:type owl:Class ;
                                             owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty <https://spec.industrialontologies.org/ontology/construct/processProfileOf> ;
                                                                                          owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                        ]
                                                                                      ) ;
                                                                   rdf:type owl:Class
                                                                 ] ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <https://spec.industrialontologies.org/ontology/construct/processProfileOf> ;
                                                               owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000015>
                                                             ] ;
                                             owl:disjointWith <http://purl.obolibrary.org/obo/BFO_0000182> ;
                                             rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                             rdfs:label "process profile"@en ;
                                             skos:example "temperature profile of a heating process, wind speed profile of a turbine, fuel consumption profile of a boiling pricess, RPM profile of a engine, noise profile of a transmission process, profile of daily average throughput of a production process, count-per-minute profile of a pick-n-place process" ;
                                             annotation:counterExample "maximum temperature of a heating process, average speed of a vehicle trip, total energy consumed during a batch, peak pressure in a reactor, overall throughput of a production run, speed of the car at time t" ;
                                             annotation:directSource "http://purl.obolibrary.org/obo (BFO 2.0)" ;
                                             annotation:explanatoryNote """1) Process profiles capture the attributes (called \"structural dimension\") of a process that we may use to compare processes, e.g., how fast something moves or how its temperature changes. Two movement process can be compared by comparing the speed profiles of two processes.

2) Process profile types represent common attributes of many different types of processes.. For example, profile of temperature in any heating process, profile of pressure in a piston cycle or pneumatic system. Domain and application-specific taxonomies of process profile need be developed to catalog these subtypes.""" ;
                                             annotation:firstOrderLogicAxiom "‚àÄp, p', x (processProfileOf(p,x) ‚àß temporalPartOf(p',p) ‚Üí ‚àÉx' (processProfileOf(p',x') ‚àß temporalPartOf(x',x)))" ;
                                             annotation:firstOrderLogicDefinition "ProcessProfile(x) ‚Üî ‚àÉy (Process(y) ‚àß processProfileOf(x, y))" ;
                                             annotation:naturalLanguageDefinition "process that is proper part of another process and that captures the time-dependent behavior of some attribute of that process"@en-us ;
                                             annotation:semiFormalNaturalLanguageAxiom "if p is 'process profile of' x and p‚Ä≤ is a 'temporal part of' p, then there exists some x‚Ä≤ such that p‚Ä≤ is 'process profile of' x‚Ä≤ and x‚Ä≤ is a 'temporal part of' x"@en ;
                                             annotation:semiFormalNaturalLanguageDefinition "every instance of 'process profile' is defined as exactly an instance that is 'process profile of' some 'process'" .


###  http://purl.obolibrary.org/obo/BFO_0000145
<http://purl.obolibrary.org/obo/BFO_0000145> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000019> ;
                                             dce:identifier "057-BFO" ;
                                             rdfs:label "relational quality"@en ;
                                             skos:definition "b is a relational quality =Def b is a quality & there exists c and d such that c and d are not identical & b specifically depends on c & b specifically depends on d"@en ;
                                             skos:example "A marriage bond; an instance of love; an obligation between one person and another"@en .


###  http://purl.obolibrary.org/obo/BFO_0000146
<http://purl.obolibrary.org/obo/BFO_0000146> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000140> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000140>
                                                             ] ;
                                             dce:identifier "033-BFO" ;
                                             rdfs:label "fiat surface"@en ;
                                             skos:definition "(Elucidation) A fiat surface is a two-dimensional continuant fiat boundary that is self-connected"@en ;
                                             skos:example "The surface of the Earth; the plane separating the smoking from the non-smoking zone in a restaurant"@en .


###  http://purl.obolibrary.org/obo/BFO_0000147
<http://purl.obolibrary.org/obo/BFO_0000147> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000140> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000147>
                                                             ] ;
                                             dce:identifier "031-BFO" ;
                                             rdfs:label "fiat point"@en ;
                                             skos:definition "(Elucidation) A fiat point is a zero-dimensional continuant fiat boundary that consists of a single point"@en ;
                                             skos:example "The geographic North Pole; the quadripoint where the boundaries of Colorado, Utah, New Mexico and Arizona meet; the point of origin of some spatial coordinate system"@en .


###  http://purl.obolibrary.org/obo/BFO_0000148
<http://purl.obolibrary.org/obo/BFO_0000148> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000008> ,
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000121> ;
                                                               owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000148>
                                                             ] ;
                                             dce:identifier "102-BFO" ;
                                             rdfs:label "zero-dimensional temporal region"@en ;
                                             skos:definition "(Elucidation) A zero-dimensional temporal region is a temporal region that is a whole consisting of one or more separated temporal instants as parts"@en ;
                                             skos:example "A temporal region that is occupied by a process boundary; the moment at which a finger is detached in an industrial accident"@en .


###  http://purl.obolibrary.org/obo/BFO_0000182
<http://purl.obolibrary.org/obo/BFO_0000182> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000015> ;
                                             dce:identifier "138-BFO" ;
                                             rdfs:label "history"@en ;
                                             skos:definition "(Elucidation) A history is a process that is the sum of the totality of processes taking place in the spatiotemporal region occupied by the material part of a material entity"@en ;
                                             skos:example "The life of an organism from the beginning to the end of its existence"@en .


###  http://purl.obolibrary.org/obo/BFO_0000202
<http://purl.obolibrary.org/obo/BFO_0000202> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000038> ;
                                             dce:identifier "155-BFO" ;
                                             rdfs:label "temporal interval"@en ;
                                             skos:definition "(Elucidation) A temporal interval is a one-dimensional temporal region that is continuous, thus without gaps or breaks"@en ;
                                             skos:example "The year 2018."@en ;
                                             skos:scopeNote "A one-dimensional temporal region can include as parts not only temporal intervals but also temporal instants separated from other parts by gaps."@en ;
                                             annotation:explanatoryNote """1. The ‚Äòfirst instant of‚Äô a ‚Äòtemporal interval‚Äô should ‚Äòprecede‚Äô the ‚Äòlast instant of‚Äô that ‚Äòtemporal interval‚Äô. Therefore, the date-time asserted (i.e., ‚Äòhas date-time instant value‚Äô of the ‚Äòtemporal instant value expression‚Äô that ‚Äòis value expression of at all times‚Äô of the ‚Äòtemporal instant‚Äô) for the first instant should be before the last instant in terms their positions in the corresponding calendar and clock system. For example, the first instant and last instant of a ‚Äòtemporal interval‚Äô are 2002-10-10T17:00:00Z and 2002-10-11T01:40:00Z. 
2. If only one date-time is available for the interval due to lack of data or an interval being smaller than the tick time (the smallest duration by which the time progresses) then the date-time should be asserted either only for first instant or only for last instant of every interval uniformly for the entire knowledge base. For example, Barack Obama gained the role of presidency on 20 January 2009 should be modeled as the process p of type ‚Äògain of role‚Äô ‚Äòoccupies temporal region‚Äô r (a ‚Äòtemporal interval‚Äô) which ‚Äòhas last instant‚Äô i (a ‚Äòtemporal instant‚Äô) which ‚Äòhas value expression at all times‚Äô v (a ‚Äòtemporal instant value expression‚Äô) which ‚Äòhas data-time value‚Äô 2009-01-20T00:00:00Z."""@en-us .


###  http://purl.obolibrary.org/obo/BFO_0000203
<http://purl.obolibrary.org/obo/BFO_0000203> rdf:type owl:Class ;
                                             rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000148> ;
                                             dce:identifier "209-BFO" ;
                                             rdfs:label "temporal instant"@en ;
                                             skos:definition "(Elucidation) A temporal instant is a zero-dimensional temporal region that has no proper temporal part"@en ;
                                             skos:example "The millennium"@en .


###  https://spec.industrialontologies.org/ontology/construct/ActionSpecification
<https://spec.industrialontologies.org/ontology/construct/ActionSpecification> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                               rdfs:label "action specification"@en-us ;
                                                                               skos:example "pour the contents of flask 1 into flask 2; to loosen a screw with a screwdriver, grab the screw driver with your hand, insert the tip into the head of the screw, apply forward pressure into the screwdriver, and rotate the screwdriver counterclockwise."@en-us ;
                                                                               annotation:adaptedFrom "Information Artifact Ontology, http://purl.obolibrary.org/obo/IAO_0000030 and also the Common Core Ontology, http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology (term Action Regulation)" ;
                                                                               annotation:explanatoryNote """1. An action specification is typically a part of some plan specification.

2. All actions change the universe in some fashion. That is, they have outcomes, whether desired ones or not. Since desired outcomes are reasons for the existence of an action specification, we might argue that all action specifications are, in fact, plan specifications, with desired outcomes as objectives. However, our intent here is to capture instances of action specifications wherein objectives or desired outcomes are not explicitly stated and to delinate 'plan specifications' as cases where the objectives and the corresponding actions are explicitly stated. This is why the class is asserted directly under the information content entity.

3. Although not formalized at this stage, an action specification may prescribe a kind of process in more detail by prescribing the sequence of actions one or more participants are to do or by prescribing the actions persons bearing various roles are to do in bringing about the process. The latter would be relevant in situations where a particular participant bears two (or even more roles) in a process. An example of the latter would be a particular shop floor worker bearing and realizing both the role of the operator and that of the inspector as prescribed by some action specification and as realized in today's occurrences of some punch-press process.

4.  Action specification can be used together with plan specification to create a hierarchy of work instruction composition.""" ;
                                                                               annotation:firstOrderLogicAxiom "InformationContentEntity(x) ‚àß ‚àÉp(Process(p) ‚àß prescribes(x,p)) ‚Üí ActionSpecification(x)" ;
                                                                               annotation:isPrimitive "true"^^xsd:boolean ;
                                                                               annotation:naturalLanguageDefinition "information content entity that prescribes what participants shall do in a process"@en-us ;
                                                                               annotation:primitiveRationale "See the rationale provided under information content entity for informational entity types." ;
                                                                               annotation:semiFormalNaturalLanguageAxiom "if x is an 'information content entity' that 'prescribes' some 'process' then x is an 'action specification'" ;
                                                                               annotation:synonym "actionable work instruction"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/Agent
<https://spec.industrialontologies.org/ontology/construct/Agent> rdf:type owl:Class ;
                                                                 owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                              owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/EngineeredSystem>
                                                                                                                            <https://spec.industrialontologies.org/ontology/construct/GroupOfAgents>
                                                                                                                            <https://spec.industrialontologies.org/ontology/construct/Person>
                                                                                                                          )
                                                                                                            ]
                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                              owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                                              owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/AgentRole>
                                                                                                            ]
                                                                                                          ) ;
                                                                                       rdf:type owl:Class
                                                                                     ] ;
                                                                 rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                   owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/AgentRole>
                                                                                 ] ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "agent"@en-us ;
                                                                 skos:example "an employee; a transportation & logistics provider; a robot; a scheduling system"@en-us ;
                                                                 annotation:counterExample """1. Of physical and chemical in nature: Cleaning, vulcanizing, fluxing, indicator, sterilizing, emulisifying, refining.

2. Organisms: animals, cells, parts of organisms (organs, organelles, viruses).""" ;
                                                                 annotation:explanatoryNote """1. See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience.

2. The IOF has elected to exclude material substances often referred to as agents. That is, they realize some specific function that some person desires (e.g., platinum is a reducing agent in various reduction-type reactions -- as used in a catalytic converter to eliminate or reduce various pollutants in exhausts).

3. The IOF has, at this time, excluded non-human agents, such as animals and other organisms (often referred to as biological agents).""" ;
                                                                 annotation:firstOrderLogicDefinition "Agent(x) ‚Üî (Person(x) ‚à® GroupOfAgents(x) ‚à® EngineeredSystem(x)) ‚àß ‚àÉr(AgentRole(r) ‚àß hasRole(x,r))" ;
                                                                 annotation:naturalLanguageDefinition "person, group of persons, or engineered system with an agent role"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageDefinition "every instance of 'agent' is defined as exactly an instance of 'person', 'group of agents', or 'engineered system' when it 'has role' some 'agent role'" .


###  https://spec.industrialontologies.org/ontology/construct/AgentRole
<https://spec.industrialontologies.org/ontology/construct/AgentRole> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ,
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                                       owl:someValuesFrom [ owl:intersectionOf ( [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                                                        [ rdf:type owl:Class ;
                                                                                                                                                          owl:complementOf <http://purl.obolibrary.org/obo/BFO_0000024>
                                                                                                                                                        ]
                                                                                                                                                      ) ;
                                                                                                                                   rdf:type owl:Class
                                                                                                                                 ]
                                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                                   owl:onProperty <https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime> ;
                                                                                                                                   owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                                                        owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/EngineeredSystem>
                                                                                                                                                                      <https://spec.industrialontologies.org/ontology/construct/GroupOfAgents>
                                                                                                                                                                      <https://spec.industrialontologies.org/ontology/construct/Person>
                                                                                                                                                                    )
                                                                                                                                                      ]
                                                                                                                                 ]
                                                                                                                               ) ;
                                                                                                            rdf:type owl:Class
                                                                                                          ]
                                                                                     ] ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "agent role"@en-us ;
                                                                     skos:example "a person has an employee role when he/she acts on behalf of the business organization that employs them"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/AgentOntology" ;
                                                                     annotation:counterExample """Other types of agents we are not including at this stage are: 
1. Those that are physical and chemical in nature: Cleaning, vulcanizing, fluxing, indicator, sterilizing, emulisifying, refining.

2. Organisms: animals, cells, parts of organisms (organs, organelles, viruses).

3. In computing: intelligent, artificial, mobile, & autonomous""" ;
                                                                     annotation:explanatoryNote """1.The IOF has elected to exclude material substances that may, at times, act like or are often referred to as agents, in that they realize some specific function that some person desires (e.g., platinum is a reducing agent in various reduction-type reactions -- as used in a catalytic converter to eliminate or reduce various pollutants in exhausts).

2. The IOF has at this time excluded other types of non-human agents, such as animals and other organisms (often referred to as biological agents).

3. in case the 'material entity' is an engineered system or group of agents or person acting on behalf of oneself is also allowed""" ;
                                                                     annotation:firstOrderLogicAxiom "AgentRole(x) ‚Üí Role(x) ‚àß ‚àÉn‚àÉm((MaterialEntity(m) ‚àß ¬¨FiatObjectPart(x)) ‚àß roleOf(x,m) ‚àß (Person(n) ‚à® GroupOfAgents(n) ‚à® EngineeredSystem(n)) ‚àß actsOnBehalfOfAtSomeTime(m, n))" ;
                                                                     annotation:isPrimitive "true"^^xsd:boolean ;
                                                                     annotation:naturalLanguageDefinition "role that someone or something has when they act on behalf of a person, engineered system or a group of agents"@en-us ;
                                                                     annotation:primitiveRationale "This term is expected to remain primitive. While 'acting on behalf of at some time' captures the essence of being an agent, the realization of the agent role is expected to have too generic of a scope to define a sufficient condition that would not cause conflict (overlap) with the realization of other roles, which can in turn lead to reasoner errors when a specific entity bears multiple roles simoultaneously. Also, no further conditions specific to the role and not to the bearer of the role have been created thus far." ;
                                                                     annotation:semiFormalNaturalLanguageAxiom "if x is an 'agent role' x then x is a 'role' that is the 'role of' some 'material entity' (that is not a 'fiat object part') when it 'acts on behalf of at some time' some 'person' or 'group of agents' or 'engineered system'" .


###  https://spec.industrialontologies.org/ontology/construct/Agreement
<https://spec.industrialontologies.org/ontology/construct/Agreement> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ,
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                                                                       owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/ObjectiveSpecification>
                                                                                     ] ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "agreement"@en-us ;
                                                                     skos:example "prenuptial agreement; memorandum of understanding; non-disclosure agreement; employment agreement; purchase order that has been confirmed by the seller by e-mail; handshake agreement to buy something in the State of Florida, which happens to be legally-binding in that juristiction provided certain evidence can be produced"@en-us ;
                                                                     annotation:adaptedFrom "FIBO https://spec.edmcouncil.org/fibo/ontology/FND/Agreements/Agreements, term by the same name" ;
                                                                     annotation:firstOrderLogicAxiom "Agreement(x) ‚Üí InformationContentEntity(x) ‚àß ‚àÉo(ObjectiveSpecification(o) ‚àß hasContinuantPartAtAllTimes(x,o))" ;
                                                                     annotation:isPrimitive "true"^^xsd:boolean ;
                                                                     annotation:naturalLanguageDefinition "understanding between two or more parties that contains a set of commitments on the part of the parties"@en-us ;
                                                                     annotation:primitiveRationale "In addition to the general discussion provided for information content enty,there are insufficient constructs to create necessary and sufficient conditions. Namely, patterns surrounding commitment and party need to be established" ;
                                                                     annotation:semiFormalNaturalLanguageAxiom "if x is an 'agreement' then x is an 'information content entity' that 'has continuant part at all times' some 'objective specification'" .


###  https://spec.industrialontologies.org/ontology/construct/Algorithm
<https://spec.industrialontologies.org/ontology/construct/Algorithm> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "algorithm"@en-us ;
                                                                     skos:example "pseudo code for sorting data, flowchart for automatic control of a process"@en-us ;
                                                                     annotation:adaptedFrom "http://purl.obolibrary.org/obo/IAO_0000064 and http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology" ;
                                                                     annotation:counterExample "executable code, source code" ;
                                                                     annotation:explanatoryNote """1. to translate in this context means to implement the algorithm such that it is readily executable
2. algorithms in this context should be interpreted as implementation-independent (language-neutral) representations and are typically represented as pseudo-code or a flowchart
3. declarative steps should be interpreted in the context of declarative programming""" ;
                                                                     annotation:firstOrderLogicAxiom "InformationContentEntity(x) ‚àß ‚àÉy(EncodedAlgorithm(y) ‚àß prescribes(x,y)) ‚Üí Algorithm(x)" ;
                                                                     annotation:isPrimitive "true"^^xsd:boolean ;
                                                                     annotation:naturalLanguageDefinition "information content entity that prescribes procedural or declarative steps which can be translated to computer interpretable instructions"@en-us ;
                                                                     annotation:primitiveRationale "See the general discussion and rationale provided under information content entity." ;
                                                                     annotation:semiFormalNaturalLanguageAxiom "If x is an 'information content entity' that 'prescribes' some 'encoded algorithm' then x is an instance of 'algorithm'" .


###  https://spec.industrialontologies.org/ontology/construct/Assembly
<https://spec.industrialontologies.org/ontology/construct/Assembly> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact> ,
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty [ owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/componentPartOfAtAllTimes>
                                                                                                     ] ;
                                                                                      owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/MaterialComponent>
                                                                                    ] ;
                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                    rdfs:label "assembly"@en-us ;
                                                                    skos:example "powertrain assembly; partially-assembled powertrain + transmission assembly lying nearby; driveshaft assembly temporarily disassembled for repair or routine maintenance; separator assembly consisting of variously-shaped separator parts that safeguard wine bottles in a case of wine during transport; a material artifact produced entirely through additive manufacturing (provided it is a component somewhere, and can it can be disassembled without damage/destruction)."@en-us ;
                                                                    annotation:adaptedFrom "APICS 14 ed., 2013, term by the same name; DoD Standard Practice, Identification Marking of US Military Property (MIL-STD-130N Nov. 2012) https://dodprocurementtoolbox.com/cms/sites/default/files/resources/2016-03/MIL-Std130N_Ch1_4.pdf, term by the same name" ;
                                                                    annotation:counterExample "a portion of material; a piece of glass; a rod of aluminum; a roll of aluminum; an engine block" ;
                                                                    annotation:explanatoryNote "Although the term is polysemous and used in a number of other domains beyond manufacturing, it is introduced here as a covering term for any man-made artifact that satisfies the conditions provided, and independent of modality. We expect various subclasses of assembly to be introduced in future along with more precise heuristics for the various modalities in which they exist." ;
                                                                    annotation:firstOrderLogicAxiom "LA1: Assembly(x) ‚Üí MaterialArtifact(x) ‚àß ‚àÉc‚àÉc1(MaterialComponent(c) ‚àß MaterialComponent(c1) ‚àß componentPartOfAtAllTimes(c,x) ‚àß componentPartOfAtAllTimes(c1,x) ‚àß ¬¨(c=c1 ‚à® (componentPartOfAtAllTimes(c,c1) ‚à® componentPartOfAtAllTimes(c1,c))))" ,
                                                                                                    "LA2: MaterialArtifact(x) ‚àß ‚àÉp(AssemblyProcess(p) ‚àß isSpecifiedOutputOf(x,p)) ‚Üí Assembly(x)" ;
                                                                    annotation:isPrimitive "true"^^xsd:boolean ;
                                                                    annotation:naturalLanguageDefinition "material artifact that is composed of material components that are physically connected and that is capable of disassembly"@en-us ;
                                                                    annotation:primitiveRationale "There are insufficient constructs in the ontology to provide necessary and sufficient conditions. Namely, 'disassembly capability' is missing." ;
                                                                    annotation:semiFormalNaturalLanguageAxiom "LA1: if x is an 'assembly' then x is a 'material artifact' and there are at least two distinct 'material component' that are 'component part of at all times' x" ,
                                                                                                              "LA2: Material Artifact x that 'is specified output of' some Assembly Process p implies x is an Assembly" ;
                                                                    annotation:usageNote "Every assembly has a plurality of material components. While this is captured in the FOL, due to reasoning limitations with cardinality restrictions and complex properties, the OWL axiom uses 'some' instead of min 2. Hence, this class should be modeled as having at least two material components on the instance level." .


###  https://spec.industrialontologies.org/ontology/construct/AssemblyProcess
<https://spec.industrialontologies.org/ontology/construct/AssemblyProcess> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/ManufacturingProcess> ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasInput> ;
                                                                                             owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/MaterialComponent>
                                                                                           ] ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput> ;
                                                                                             owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/Assembly>
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                                                                                                                         owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/MaterialComponent>
                                                                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                                                                     owl:onProperty <https://spec.industrialontologies.org/ontology/construct/isInputOf> ;
                                                                                                                                                                                     owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/ManufacturingProcess>
                                                                                                                                                                                   ]
                                                                                                                                                                                 ) ;
                                                                                                                                                              rdf:type owl:Class
                                                                                                                                                            ]
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                           ] ;
                                                                           rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                           rdfs:label "assembly process"@en-us ;
                                                                           skos:example "Driving a lug nut to hold the wheel of a car in place; welding two metal parts into a single object; automated drilling and riveting of a skin panel operation during fuselage assembly;"@en-us ;
                                                                           annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/EventOntology" ;
                                                                           annotation:counterExample "3D printing on an existing part (existing part + a pool of printing material -> new part) -- Note that the pool of material is an object before the process but becomes liquid (there is physical state change) during the \"assembly\" process." ;
                                                                           annotation:firstOrderLogicAxiom "AssemblyProcess(x) ‚Üí ManufacturingProcess(x) ‚àß ‚àÉa‚àÉc (Assembly(a) ‚àß MaterialComponent(c) ‚àß isInputOf(c,x) ‚àß hasComponentPartAtAllTimes(a,c) ‚àß hasSpecifiedOutput(x,a))" ;
                                                                           annotation:isPrimitive "true"^^xsd:boolean ;
                                                                           annotation:naturalLanguageDefinition "manufacturing process in which a number of material components are physically connected to each other to form an assembly"@en-us ;
                                                                           annotation:primitiveRationale "More conditions (differentia) need to be agreed upon by the domain experts as processes like 3D printing can also produce an assembly." ;
                                                                           annotation:semiFormalNaturalLanguageAxiom "if x is an 'assembly process' x then x is a 'manufacturing process' that 'has specified output' some 'assembly' which 'has component part at all times' some 'material component' that 'is input of' x" .


###  https://spec.industrialontologies.org/ontology/construct/BusinessFunction
<https://spec.industrialontologies.org/ontology/construct/BusinessFunction> rdf:type owl:Class ;
                                                                            rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000034> ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://spec.industrialontologies.org/ontology/construct/functionOf> ;
                                                                                              owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Organization>
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribedBy> ;
                                                                                              owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/ObjectiveSpecification>
                                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000084> ;
                                                                                                                                          owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Organization>
                                                                                                                                        ]
                                                                                                                                      ) ;
                                                                                                                   rdf:type owl:Class
                                                                                                                 ]
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                              owl:allValuesFrom <https://spec.industrialontologies.org/ontology/construct/BusinessProcess>
                                                                                            ] ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                            rdfs:label "business function"@en-us ;
                                                                            skos:example "Pfizer has the business function to produce medicines; Airbus has the business function of manufacturing planes"@en-us ;
                                                                            annotation:adaptedFrom "https://en.wikipedia.org/wiki/Business_purpose" ;
                                                                            annotation:counterExample "any function of a non-profit organization" ;
                                                                            annotation:firstOrderLogicAxiom "LA1: BusinessFunction(x) ‚Üí Function(x) ‚àß ‚àÉo‚àÉi(Organization(o) ‚àß ObjectiveSpecification(i) ‚àß functionOf(x,o) ‚àß genericallyDependsOnAtSomeTime(i,o) ‚àß prescribedBy(x,i)) ‚àß ‚àÄy(hasRealization(x,y) ‚Üí BusinessProcess(y))" ,
                                                                                                            "LA2: Function(x) ‚àß ‚àÉo‚àÉi‚àÉp(Organization(o) ‚àß ObjectiveSpecification(i) ‚àß BusinessProcess(p) ‚àß functionOf(x,o) ‚àß genericallyDependsOnAtSomeTime(i,o) ‚àß prescribedBy(x,i) ‚àß hasRealization(x,p)) ‚Üí BusinessFunction(x)" ;
                                                                            annotation:isPrimitive "true"^^xsd:boolean ;
                                                                            annotation:naturalLanguageDefinition "function of an organization to partake in for profit activities as prescribed by the objectives specified by that organization"@en-us ;
                                                                            annotation:primitiveRationale "As a function will come into its existance prior to its realization in given business processes necessary and sufficient conditions can not be created at this point due to a lack of patterns to express process types regardless of the time of their existence" ;
                                                                            annotation:semiFormalNaturalLanguageAxiom "LA1: if x is a 'business function' then x is a 'function' that is 'function of' some 'organization' and that is 'prescribed by' some 'objective specification' and whenever x 'has realization' y that y must be a 'business process'" ,
                                                                                                                      "LA2: if x is a 'function' that is 'function of' some 'organization' and that is 'prescribed by' some 'objective specification' and that 'has realization' some 'business process' then x is a 'business function'" .


###  https://spec.industrialontologies.org/ontology/construct/BusinessOrganization
<https://spec.industrialontologies.org/ontology/construct/BusinessOrganization> rdf:type owl:Class ;
                                                                                owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/Organization>
                                                                                                                           [ rdf:type owl:Restriction ;
                                                                                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                                                                             owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/BusinessFunction>
                                                                                                                           ]
                                                                                                                         ) ;
                                                                                                      rdf:type owl:Class
                                                                                                    ] ;
                                                                                rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Organization> ,
                                                                                                [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                                                  owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/BusinessFunction>
                                                                                                ] ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "business organization"@en-us ;
                                                                                skos:example "Mercedes-Benz, Deloitte, Pfizer, Airbus"@en-us ;
                                                                                annotation:adaptedFrom "https://en.wikipedia.org/wiki/Business" ;
                                                                                annotation:explanatoryNote "Business entities are formally organized according to the laws prevailing in the locales and countries in which it operates or conducts business, and include companies, corporations, partnerships, or sole proprietorships." ;
                                                                                annotation:firstOrderLogicDefinition "BusinessOrganization(x) ‚Üî Organization(x) ‚àß ‚àÉf(BusinessFunction(f) ‚àß hasFunction(x,f))" ;
                                                                                annotation:naturalLanguageDefinition "organization engaging in or planning to engage in any activity of buying and selling goods or services for a profit"@en-us ;
                                                                                annotation:semiFormalNaturalLanguageDefinition "every instance of a business organization' is defined as exactly an instance of 'organization' that 'has function' some 'business function'" .


###  https://spec.industrialontologies.org/ontology/construct/BusinessProcess
<https://spec.industrialontologies.org/ontology/construct/BusinessProcess> rdf:type owl:Class ;
                                                                           rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                                             owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/Agent>
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime> ;
                                                                                                                                         owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/BusinessOrganization>
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                           ] ,
                                                                                           [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribedBy> ;
                                                                                             owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/PlanSpecification>
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000110> ;
                                                                                                                                         owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/ObjectiveSpecification>
                                                                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000084> ;
                                                                                                                                                                                     owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/BusinessOrganization>
                                                                                                                                                                                   ]
                                                                                                                                                                                 ) ;
                                                                                                                                                              rdf:type owl:Class
                                                                                                                                                            ]
                                                                                                                                       ]
                                                                                                                                     ) ;
                                                                                                                  rdf:type owl:Class
                                                                                                                ]
                                                                                           ] ;
                                                                           rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                           rdfs:label "business process"@en-us ;
                                                                           skos:example "product production process; manufacturing enterprise process; finance operation; logistics operation."@en-us ;
                                                                           annotation:adaptedFrom "ISO 15704 and APICS" ;
                                                                           annotation:explanatoryNote "This definition leaves open the possibility that the business entity that carries the plan that prescribes the process, has no direct participation in the process, which would imply that some 3rd-party agent is playing a causal role as the process unfolds, and is acting on behalf of the Business Entity's interests." ;
                                                                           annotation:firstOrderLogicAxiom "BusinessProcess (p) ‚Üí PlannedProcess(p) ‚àß ‚àÉo‚àÉb‚àÉs‚àÉy (ObjectiveSpecification(o) ‚àß BusinessOrganization(b) ‚àß PlanSpecification(s) ‚àß isCarrierOfAtSomeTime(b,o) ‚àß continuantPartofAtAllTimes(o,s) ‚àß Agent(y) ‚àß actsOnBehalfOfAtSomeTime(y,b) ‚àß participatesInAtSomeTime(y,x))" ;
                                                                           annotation:isPrimitive "true"^^xsd:boolean ;
                                                                           annotation:naturalLanguageDefinition "planned process which is prescribed by a plan specification with one or more objectives specified by a business organization"@en-us ;
                                                                           annotation:primitiveRationale "More conditions (differentia) need to be agreed upon by the domain experts." ;
                                                                           annotation:semiFormalNaturalLanguageAxiom "if x is a 'business process' then x is a 'planned process' that 'has participant at some time' some 'agent' that 'acts on behalf of at some time' a 'business organization' that 'is carrier of at some time' some 'objective specification' that is 'continuant part of at all times' a 'plan specification' that 'prescribes' x" .


###  https://spec.industrialontologies.org/ontology/construct/Buyer
<https://spec.industrialontologies.org/ontology/construct/Buyer> rdf:type owl:Class ;
                                                                 owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                              owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/Organization>
                                                                                                                            <https://spec.industrialontologies.org/ontology/construct/Person>
                                                                                                                          )
                                                                                                            ]
                                                                                                            [ rdf:type owl:Restriction ;
                                                                                                              owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                                              owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/BuyerRole>
                                                                                                            ]
                                                                                                          ) ;
                                                                                       rdf:type owl:Class
                                                                                     ] ;
                                                                 rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Agent> ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                   owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/BuyerRole>
                                                                                 ] ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "buyer"@en-us ;
                                                                 skos:example "Pfizer when it buys a bulk of chemicals from MiliporeSigma; a person is when they buy groceries at the supermarket; a manufacturing enterprise when they hire an external organization to do some manufacturing process (manufacturing as a service); a person when they hire someone to repair a broken pipe"@en-us ;
                                                                 annotation:explanatoryNote "See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience." ;
                                                                 annotation:firstOrderLogicDefinition "Buyer(x) ‚Üî Person(x) ‚à® Organization(x) ‚àß ‚àÉr(BuyerRole(r) ‚àß hasRole(x,r))" ;
                                                                 annotation:naturalLanguageDefinition "person or organization which has a buyer role"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageDefinition "every instance of 'buyer' is defined as exactly an instance of 'person' or 'organization' that 'has role' some 'buyer role'" .


###  https://spec.industrialontologies.org/ontology/construct/BuyerRole
<https://spec.industrialontologies.org/ontology/construct/BuyerRole> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/AgentRole> ,
                                                                                     [ rdf:type owl:Restriction ;
                                                                                       owl:onProperty <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                                       owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                                                   owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/Organization>
                                                                                                                                                 <https://spec.industrialontologies.org/ontology/construct/Person>
                                                                                                                                               )
                                                                                                                                 ]
                                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000056> ;
                                                                                                                                   owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/BuyingBusinessProcess>
                                                                                                                                 ]
                                                                                                                               ) ;
                                                                                                            rdf:type owl:Class
                                                                                                          ]
                                                                                     ] ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "buyer role"@en-us ;
                                                                     skos:example "Pfizer has a buyer role when it buys a bulk of chemicals from MiliporeSigma; a person has a buyer role when they buy groceries at the supermarket; a manufacturing enterprise has a buyer role when they hire an external organization to do some manufacturing process (manufacturing as a service); a person has a buyer role when they hire someone to repair a broken pipe"@en-us ;
                                                                     annotation:adaptedFrom "OAGIS" ;
                                                                     annotation:firstOrderLogicAxiom "BuyerRole(x) ‚Üí Role(x) ‚àß ‚àÉy‚àÉp ((Organization(y) ‚à® Person(y)) ‚àß BuyingBusinessProcess(p) ‚àß participatesInAtSomeTime(y,p) ‚àß roleOf(x, y))" ;
                                                                     annotation:isPrimitive "true"^^xsd:boolean ;
                                                                     annotation:naturalLanguageDefinition "agent role held by a person or organization when it buys a product or a service"@en-us ;
                                                                     annotation:primitiveRationale "There are insufficient constructs to create necessary and sufficient conditions. Namely, constructs for economic transactions and ownership are lacking" ;
                                                                     annotation:semiFormalNaturalLanguageAxiom "if x is a 'buyer role' x then x is an 'agent role' that is the 'role of' some 'person' or 'organization' when it 'participates in at some time' some 'buying business process'" .


###  https://spec.industrialontologies.org/ontology/construct/BuyingBusinessProcess
<https://spec.industrialontologies.org/ontology/construct/BuyingBusinessProcess> rdf:type owl:Class ;
                                                                                 rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/BusinessProcess> ,
                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                                                   owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Buyer>
                                                                                                 ] ,
                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                                                   owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                        owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/CommercialServiceAgreement>
                                                                                                                                      <https://spec.industrialontologies.org/ontology/construct/MaterialProduct>
                                                                                                                                    )
                                                                                                                      ]
                                                                                                 ] ;
                                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                 rdfs:label "buying business process"@en-us ;
                                                                                 skos:example "GM buys tires from Good Year to be assembled into its cars; GE Conglomerate (buyer) buys steels for uses in productions by its GE aviation subsidiary (customer) and GE Transportation subsidiary (customer)"@en-us ;
                                                                                 annotation:adaptedFrom """CCO:http://www.ontologyrepository.com/CommonCoreOntologies/ActOfBuying
NL definition: OAGIS and CCO""" ;
                                                                                 annotation:explanatoryNote """1.The agent who uses the finiancial instrument may not own the financial instrument and hence agent may not be the paying agent.
2. It should be noted that we consciously exclude the person-to-person transactions, but person-to-business is not excluded.""" ;
                                                                                 annotation:firstOrderLogicAxiom "BuyingBusinessProcess(x) ‚Üí BusinessProcess(x) ‚àß ‚àÉy‚àÉz((MaterialProduct(y) ‚à® CommercialServiceAgreement(y)) ‚àß Buyer(z) ‚àß hasParticipantAtSomeTIme(x,y) ‚àß hasParticipantAtSomeTime(x,z))" ;
                                                                                 annotation:isPrimitive "true"^^xsd:boolean ;
                                                                                 annotation:naturalLanguageDefinition "business process wherein a financial instrument is used by an agent (buyer) to acquire ownership of a product or commercial service from another agent (seller) for the buyer itself or for another agent (customer)"@en-us ;
                                                                                 annotation:primitiveRationale "There are insufficient constructs to create necessary and sufficient conditions. Namely, ownership and economic transactions require formalization." ;
                                                                                 annotation:semiFormalNaturalLanguageAxiom "if x is a 'buying business process' then x is a 'business process' that 'has participant at some time' some 'buyer' and x 'has participant at some time' some 'material product' or 'commercial service agreement'" .


###  https://spec.industrialontologies.org/ontology/construct/Capability
<https://spec.industrialontologies.org/ontology/construct/Capability> rdf:type owl:Class ;
                                                                      rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000016> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "capability"@en-us ;
                                                                      skos:example "Capability of a person to play chess at the \"master\" level; of a team to play football in the professional league; of a lathe to turn at maximal speed of 4,000 RPM; or of your digestive system to digest tiramisu."@en-us ;
                                                                      annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/AgentOntology" ;
                                                                      annotation:explanatoryNote """1. Whereas the BFO term 'disposition refers to all tendencies, powers, habits, skills, potentials, and so forth, that a material entity may possess, a Capability narrows this down by requiring the existence of an Agent that has an interest in the realization of the capability

2. This definition does not attempt to capture \"task-based\" capabilities that an entity may bear -- e.g., a stone's capability to kill when used by some person. Rather, it captures \"proper capabilities.\" See related discussion of \"proper functions\" in the literature.

3. All functions are capabilities and in a future release BFO:Function will be asserted directly under capability.

4. Not all capabilities are functions. Capabilities are often added to an artifact by the designer/engineer, or to a biological entity through evolution, as \"additional benefits,\" and are differentiated from function (i.e., purpose). Examples: the air conditioner in your car is a capability but not the function of your car. Yet the function of the car air conditioner certainly forms some material basis of your car's ability to provide a comfortable experience. The ability of your heart to beat fast to support your need to run fast to escape a threat. The decaying stick on the forest lawn does not have the function to be used as a tool, but certainly a chimpanzee
 may have an interest in using a stick to extract food from a termite mound.""" ;
                                                                      annotation:firstOrderLogicAxiom "Capability(x) ‚Üí Disposition(x)" ;
                                                                      annotation:isPrimitive "true"^^xsd:boolean ;
                                                                      annotation:naturalLanguageDefinition "disposition in whose realization some agent has an interest"@en-us ;
                                                                      annotation:primitiveRationale "This concept will be further developed and formalized in a future release of BFO." ;
                                                                      annotation:semiFormalNaturalLanguageAxiom "if x is a 'capability' then x is a 'disposition'" ;
                                                                      annotation:synonym "ability"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/Classifier
<https://spec.industrialontologies.org/ontology/construct/Classifier> rdf:type owl:Class ;
                                                                      owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/Denoter>
                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                   owl:onProperty <https://spec.industrialontologies.org/ontology/construct/classifies> ;
                                                                                                                   owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                                 ]
                                                                                                               ) ;
                                                                                            rdf:type owl:Class
                                                                                          ] ;
                                                                      rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Denoter> ,
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <https://spec.industrialontologies.org/ontology/construct/classifies> ;
                                                                                        owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                      ] ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "classifier"@en-us ;
                                                                      skos:example "UNSPSC code 26101507 classifies  turboshaft engine, pBR322 classifies a plasmid" ;
                                                                      annotation:counterExample "serial number of a product, lot number of a lot" ;
                                                                      annotation:firstOrderLogicDefinition "Classifier(x) ‚Üî Denoter(x) ‚àß ‚àÉe(classifies(x, e))" ;
                                                                      annotation:naturalLanguageDefinition "denoter that classifies some entity"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageDefinition "every instance of ‚Äòclassifier‚Äô is defined exactly as an ‚Äòinformation content entity‚Äô that ‚Äòclassifies‚Äô some entity" .


###  https://spec.industrialontologies.org/ontology/construct/CommercialService
<https://spec.industrialontologies.org/ontology/construct/CommercialService> rdf:type owl:Class ;
                                                                             rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/BusinessProcess> ,
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                                               owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/ServiceProvider>
                                                                                             ] ,
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000117> ;
                                                                                               owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/SupplyingBusinessProcess>
                                                                                             ] ,
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                                               owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/CommercialServiceAgreement>
                                                                                             ] ,
                                                                                             [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribedBy> ;
                                                                                               owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/CommercialServiceSpecification>
                                                                                             ] ;
                                                                             rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                             rdfs:label "commercial service"@en-us ;
                                                                             skos:example "Lufthansa Aviation Services maintains airplanes for United Airlines when the plane stops at Frankfurt International Airport."@en-us ;
                                                                             annotation:explanatoryNote """1. A consumption process means using or benefiting.

2.Typically, the service provisioning process and consumption process coincide temporally which is different from a material product that is consumed (used) only after supplied.""" ;
                                                                             annotation:firstOrderLogicAxiom "Commercialervice(x) ‚Üí BusinessProcess(x) ‚àß ‚àÉp‚àÉy‚àÉa‚àÉs(CommercialServiceSpecification(p) ‚àß ServiceProvider(y) ‚àß CommercialServiceAgreement(s) ‚àß SupplyingBusinessProcess(a) ‚àß hasParticipantAtSomeTime(x,y) ‚àß hasOccurentPart(x,a) ‚àß prescribedBy(x,p) ‚àß isSubjectOf(x,s))" ;
                                                                             annotation:isPrimitive "true"^^xsd:boolean ;
                                                                             annotation:naturalLanguageDefinition "business process that consists of a service provisioning process and a consumption process"@en-us ;
                                                                             annotation:primitiveRationale "There are insufficient constructs to create necessary and sufficient conditions. Namely, service consumption needs to be formalized." ;
                                                                             annotation:semiFormalNaturalLanguageAxiom "if x is a 'commercial service' then x is a 'business process' that is 'prescribed by' some 'commercial service specification' and that 'has participant at some time' some 'service provider' 'and x 'has occurent part' some 'supplying business process' and x 'is subject of' some 'commercial service agreement'" .


###  https://spec.industrialontologies.org/ontology/construct/CommercialServiceAgreement
<https://spec.industrialontologies.org/ontology/construct/CommercialServiceAgreement> rdf:type owl:Class ;
                                                                                      rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Agreement> ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "commercial service agreement"@en-us ;
                                                                                      skos:example "a cellphone plan, a maintenance service agreement, equipment lease agreement that includes a maintenance plan"@en-us ;
                                                                                      annotation:adaptedFrom "https://schema.org/, http://www.heppnetz.de/projects/goodrelations/ and http://dini-ag-kim.github.io/service-ontology/service.html" ;
                                                                                      annotation:counterExample "a blanket purchase order, commodity contract" ;
                                                                                      annotation:firstOrderLogicAxiom "Agreement(x) ‚àß ‚àÉc‚àÉy‚àÉz(CommercialService(c) ‚àß ServiceProviderRole(y) ‚àß CustomerRole(z) ‚àß isAbout(x,c) ‚àß prescribes(x,y) ‚àß prescribes(x,z)) ‚Üí CommercialServiceAgreement(x)" ;
                                                                                      annotation:isPrimitive "true"^^xsd:boolean ;
                                                                                      annotation:naturalLanguageDefinition "agreement between a customer and service provider that is about some commercial service to be provided by the service provider in exchange for compensation from the customer"@en-us ;
                                                                                      annotation:primitiveRationale "See the general discussion and rationale provided for informational entities under 'information content entity'." ;
                                                                                      annotation:semiFormalNaturalLanguageAxiom "If x is an 'agreement' that 'is about' some 'commercial service' and that 'prescribes' some 'customer role' and some 'service provider role' then x is a 'commercial service agreement'" .


###  https://spec.industrialontologies.org/ontology/construct/CommercialServiceSpecification
<https://spec.industrialontologies.org/ontology/construct/CommercialServiceSpecification> rdf:type owl:Class ;
                                                                                          rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlanSpecification> ;
                                                                                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                          rdfs:label "commercial service specification"@en-us ;
                                                                                          skos:example "protocol on how maintenance will be conducted on airplanes that is a part of the agreement between Frankfurt Airport and various airlines"@en-us ;
                                                                                          annotation:adaptedFrom "https://schema.org/, http://www.heppnetz.de/projects/goodrelations/ and http://dini-ag-kim.github.io/service-ontology/service.html" ;
                                                                                          annotation:firstOrderLogicAxiom "PlanSpecification(x) ‚àß ‚àÉc(CommercialService(c) ‚àß prescribes(x,c)) ‚Üí CommercialServiceSpecification(x)" ;
                                                                                          annotation:isPrimitive "true"^^xsd:boolean ;
                                                                                          annotation:naturalLanguageDefinition "plan specification that prescribes a commercial service"@en-us ;
                                                                                          annotation:primitiveRationale "See the general discussion and rationale provided for informational entities under 'information content entity'." ;
                                                                                          annotation:semiFormalNaturalLanguageAxiom "if x is a 'plan specification' that 'prescribes' some 'commercial service' then x is a 'commercial service specification'" .


###  https://spec.industrialontologies.org/ontology/construct/ComputingProcess
<https://spec.industrialontologies.org/ontology/construct/ComputingProcess> rdf:type owl:Class ;
                                                                            owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/PlannedProcess>
                                                                                                                       [ rdf:type owl:Class ;
                                                                                                                         owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <https://spec.industrialontologies.org/ontology/construct/achievesAtSomeTime> ;
                                                                                                                                         owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/ObjectiveSpecification>
                                                                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000177> ;
                                                                                                                                                                                     owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                                                                                                          owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/Algorithm>
                                                                                                                                                                                                                        <https://spec.industrialontologies.org/ontology/construct/EncodedAlgorithm>
                                                                                                                                                                                                                      )
                                                                                                                                                                                                        ]
                                                                                                                                                                                   ]
                                                                                                                                                                                 ) ;
                                                                                                                                                              rdf:type owl:Class
                                                                                                                                                            ]
                                                                                                                                       ]
                                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                                         owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput> ;
                                                                                                                                         owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity>
                                                                                                                                       ]
                                                                                                                                     )
                                                                                                                       ]
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                                                                         owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Agent>
                                                                                                                       ]
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000059> ;
                                                                                                                         owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                                                                                     owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/Algorithm>
                                                                                                                                                                                   <https://spec.industrialontologies.org/ontology/construct/EncodedAlgorithm>
                                                                                                                                                                                 )
                                                                                                                                                                   ]
                                                                                                                                                                   [ rdf:type owl:Restriction ;
                                                                                                                                                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000084> ;
                                                                                                                                                                     owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Agent>
                                                                                                                                                                   ]
                                                                                                                                                                 ) ;
                                                                                                                                              rdf:type owl:Class
                                                                                                                                            ]
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ] ;
                                                                            rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlannedProcess> ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                                              owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Agent>
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000059> ;
                                                                                              owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                                                          owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/Algorithm>
                                                                                                                                                        <https://spec.industrialontologies.org/ontology/construct/EncodedAlgorithm>
                                                                                                                                                      )
                                                                                                                                        ]
                                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000084> ;
                                                                                                                                          owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Agent>
                                                                                                                                        ]
                                                                                                                                      ) ;
                                                                                                                   rdf:type owl:Class
                                                                                                                 ]
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasInput> ;
                                                                                              owl:allValuesFrom <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity>
                                                                                            ] ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput> ;
                                                                                              owl:allValuesFrom <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity>
                                                                                            ] ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                            rdfs:label "computing process"@en-us ;
                                                                            skos:example "execution of a neural network implemented in tensorflow to classify a set of images on a specific cluster; running of the MPC algorithm to control pressure during the production process"@en-us ;
                                                                            annotation:adaptedFrom "https://en.wikipedia.org/wiki/Process_(computing) and https://en.wikipedia.org/wiki/Execution_(computing)" ;
                                                                            annotation:explanatoryNote """1. The inputs and specified outputs of 'computing process' are strictly limited to information content entities. 
2. While it is true that algorithms can result in an action by an agent that concretizes it (e.g. controller changes the pressure of a valve), the intermediate step is still an information content entity (e.g. action specification) that is 'concretized' in a separate process that results in the action.""" ;
                                                                            annotation:firstOrderLogicAxiom "ComputingProcess(x) ‚Üí ‚àÄy((hasInput(x,y) ‚à® hasSpecifiedOutput(x,y)) ‚Üí InformationContentEntity(y))" ;
                                                                            annotation:firstOrderLogicDefinition """ComputingProcess(x) ‚Üî PlannedProcess(x) ‚àß ‚àÉy‚àÉa(Agent(y) ‚àß (Algorithm(a) ‚à® EncodedAlgorithm(a)) ‚àß hasParticipantAtSomeTIme(x,y) ‚àß genericallyDependsOnAtSomeTime(a,y) ‚àß concretizesAtSomeTime(x,a) ‚àß (‚àÉo(ObjectiveSpecification(o) ‚àß continuantPartOfAtAllTimes(o,a) ‚àß achievesAtSomeTIme(x,o)) ‚à® 
‚àÉi(InformationContentEntity(i) ‚àß hasSpecifiedOutput(x,i))))""" ;
                                                                            annotation:naturalLanguageDefinition "planned process in which an algorithm or an encoded algorithm is realized by an agent"@en-us ;
                                                                            annotation:semiFormalNaturalLanguageAxiom "if x is a 'computing process' then whenever x 'has input' or 'has specified output' y that y must be an 'information content entity'" ;
                                                                            annotation:semiFormalNaturalLanguageDefinition "every instance of 'computing process' is defined as exactly an instance of 'planned process' that 'concretizes at some time' an 'encoded algorithm' or 'algorithm' y which 'generically depends on at some time' some 'agent' which 'participates in at some time' the 'computing process' and the 'computing process' either 'achieves at some time' some 'objective specification' that is 'continuant part of at all times y or it 'has specified output' some 'information content entity'" .


###  https://spec.industrialontologies.org/ontology/construct/Consumable
<https://spec.industrialontologies.org/ontology/construct/Consumable> rdf:type owl:Class ;
                                                                      owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                 [ rdf:type owl:Restriction ;
                                                                                                                   owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                                                   owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/ConsumableRole>
                                                                                                                 ]
                                                                                                               ) ;
                                                                                            rdf:type owl:Class
                                                                                          ] ;
                                                                      rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000040> ,
                                                                                      [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                        owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/ConsumableRole>
                                                                                      ] ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                      rdfs:label "consumable"@en-us ;
                                                                      skos:example "Deionized water used as a suspension medium in PVC polymerization and partially lost through evaporation; Sterile filter used for media sterilization and discarded after use; Coolant/antifreeze used as a heat-transfer fluid in cooling system maintenance and replaced during servicing; Cleaning solvent used as a cleaning agent in equipment cleaning and disposed after use; Packing tape used as a sealing material in case sealing and incorporated into the sealed package; Dry ice used as a refrigerant medium in cold-chain shipping and sublimed during transport" ;
                                                                      annotation:explanatoryNote "See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience." ;
                                                                      annotation:firstOrderLogicDefinition "Consumable(x) ‚Üî MaterialEntity(x) ‚àß ‚àÉr(ConsumableRole(r) ‚àß hasRole(x, r))" ;
                                                                      annotation:naturalLanguageDefinition "material entity which has the consumable role"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageDefinition "every instance of 'consumable' is defined as exactly an instance of 'material entity' that 'has role' some 'consumable role'" .


###  https://spec.industrialontologies.org/ontology/construct/ConsumableRole
<https://spec.industrialontologies.org/ontology/construct/ConsumableRole> rdf:type owl:Class ;
                                                                          rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ,
                                                                                          [ rdf:type owl:Class ;
                                                                                            owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                                                            owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                                                      [ rdf:type owl:Class ;
                                                                                                                                                        owl:unionOf ( [ rdf:type owl:Restriction ;
                                                                                                                                                                        owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasCapability> ;
                                                                                                                                                                        owl:someValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/Capability>
                                                                                                                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                                                                                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                                                                                                                                                    owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/PlannedProcess>
                                                                                                                                                                                                                  ]
                                                                                                                                                                                                                ) ;
                                                                                                                                                                                             rdf:type owl:Class
                                                                                                                                                                                           ]
                                                                                                                                                                      ]
                                                                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                                                                        owl:onProperty <https://spec.industrialontologies.org/ontology/construct/isInputOf> ;
                                                                                                                                                                        owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/PlannedProcess>
                                                                                                                                                                      ]
                                                                                                                                                                    )
                                                                                                                                                      ]
                                                                                                                                                    ) ;
                                                                                                                                 rdf:type owl:Class
                                                                                                                               ]
                                                                                                          ]
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                                                            owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000040>
                                                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                                                        owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribedBy> ;
                                                                                                                                                        owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/InputSpecification>
                                                                                                                                                      ]
                                                                                                                                                    ) ;
                                                                                                                                 rdf:type owl:Class
                                                                                                                               ]
                                                                                                          ]
                                                                                                        )
                                                                                          ] ,
                                                                                          [ rdf:type owl:Restriction ;
                                                                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                            owl:allValuesFrom <https://spec.industrialontologies.org/ontology/construct/PlannedProcess>
                                                                                          ] ;
                                                                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                          rdfs:label "consumable role"@en-us ;
                                                                          skos:example "Deionized water in the role of a consumable in PVC polymerization as a suspension medium; Sterile filter in the role of a consumable in media sterilization; Coolant/antifreeze in the role of a consumable in cooling system maintenance as a heat-transfer fluid; Cleaning solvent in the role of a consumable in equipment cleaning as a cleaning agent; Packing tape in the role of a consumable in case sealing as a sealing material; Dry ice in the role of a consumable in cold-chain shipping as a refrigerant medium" ;
                                                                          annotation:adaptedFrom "https://en.wikipedia.org/wiki/Consumables" ;
                                                                          annotation:explanatoryNote "'Used up' (consumed) in this context means  that either a) the material entity no longer exist at the end of the process or b) the material entity has reduced or lost capability as a result of the process." ;
                                                                          annotation:firstOrderLogicAxiom "ConsumableRole(x) ‚Üí Role(x) ‚àß ‚àÄy(hasRealization(x,y) ‚Üí PlannedProcess(y)) ‚àß (‚àÉa(roleOf(x,a) ‚àß MaterialEntity(a) ‚àß (‚àÉf(hasCapability(a,f) ‚àß Capability(f) ‚àß ‚àÉp(hasRealization(f,p) ‚àß PlannedProcess(p))) ‚à® ‚àÉp(isInputOf(a,p) ‚àß PlannedProcess(p)))) ‚à® ‚àÉa(roleOf(x,a) ‚àß MaterialEntity(a) ‚àß ‚àÉb(prescribedBy(a,b) ‚àß InputSpecification(b))))" ;
                                                                          annotation:isPrimitive "true"^^xsd:boolean ;
                                                                          annotation:naturalLanguageDefinition "role held by a material entity when it is planned to be, or is partially or fully used up in a planned process"@en-us ;
                                                                          annotation:primitiveRationale "There are insufficient constructs to define necessary and sufficient conditions. Specifically constructs that fully model capability loss or degradation are missing." ;
                                                                          annotation:semiFormalNaturalLanguageAxiom "if x is a 'consumable role' then x is a 'role' that  'has realization' only 'planned process' and x is a 'role of' either a 'material entity' that is 'prescribed by' some 'input specification', or a 'material entity' that 'is input of' some 'planned process', or a 'material entity' that 'has capability' some 'capability' that 'has realization' in some 'planned process'" .


###  https://spec.industrialontologies.org/ontology/construct/Customer
<https://spec.industrialontologies.org/ontology/construct/Customer> rdf:type owl:Class ;
                                                                    owl:equivalentClass [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                                 owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/Organization>
                                                                                                                               <https://spec.industrialontologies.org/ontology/construct/Person>
                                                                                                                             )
                                                                                                               ]
                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                 owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                                                 owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/CustomerRole>
                                                                                                               ]
                                                                                                             ) ;
                                                                                          rdf:type owl:Class
                                                                                        ] ;
                                                                    rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Agent> ,
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasRole> ;
                                                                                      owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/CustomerRole>
                                                                                    ] ;
                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                    rdfs:label "customer"@en-us ;
                                                                    skos:example "GE aviation subsidiary and GE Transportation subsidiary when they utilize the steel bought for them by the GE Conglomerate; a person when they utilize a lap top that they bought from Target; a person when they subscribe for a phone plan"@en-us ;
                                                                    annotation:explanatoryNote "See the expanded definition under the corresponding role class. The term is formalized here as a defined class by referring to its corresponding role class and exists primarily for ontological modeling and implementation convenience." ;
                                                                    annotation:firstOrderLogicDefinition "Customer(x) ‚Üî (Person(x) ‚à® Organization(x)) ‚àß ‚àÉr(CustomerRole(r) ‚àß hasRole(x,r))" ;
                                                                    annotation:naturalLanguageDefinition "person or organization which has a customer role"@en-us ;
                                                                    annotation:semiFormalNaturalLanguageDefinition "every instance of 'customer' is defined as exactly an instance of 'person' or 'organization' that 'has role' some 'customer role'" .


###  https://spec.industrialontologies.org/ontology/construct/CustomerRole
<https://spec.industrialontologies.org/ontology/construct/CustomerRole> rdf:type owl:Class ;
                                                                        rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/AgentRole> ,
                                                                                        [ rdf:type owl:Restriction ;
                                                                                          owl:onProperty <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                                          owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                               owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/Organization>
                                                                                                                             <https://spec.industrialontologies.org/ontology/construct/Person>
                                                                                                                           )
                                                                                                             ]
                                                                                        ] ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "customer role"@en-us ;
                                                                        skos:example "GE aviation subsidiary and GE Transportation subsidiary have the customer role when they utilize the steel bought for them by the GE Conglomerate; a person has a customer role when they utilize a lap top that they bought from Target; a person has a customer role when they subscribe for a phone plan"@en-us ;
                                                                        annotation:adaptedFrom "OAGIS" ;
                                                                        annotation:firstOrderLogicAxiom "CustomerRole(x) ‚Üí AgentRole(x) ‚àß ‚àÉy((Person(y) ‚à® Organization(y)) ‚àß roleOf(x,y))" ;
                                                                        annotation:isPrimitive "true"^^xsd:boolean ;
                                                                        annotation:naturalLanguageDefinition "agent role held by a person or organization when it utilizes the product or receives the service or subscribes to the commercial service agreement"@en-us ;
                                                                        annotation:primitiveRationale "There are insufficient constructs to create necessary and sufficient conditions. Namely, constructs for 'utilizing the product' and 'subscribing to an agreement' need to be formalized." ;
                                                                        annotation:semiFormalNaturalLanguageAxiom "if x is a 'customer role' then x is an 'agent role' that is the 'role of' a 'person' or 'organization'" .


###  https://spec.industrialontologies.org/ontology/construct/Denoter
<https://spec.industrialontologies.org/ontology/construct/Denoter> rdf:type owl:Class ;
                                                                   owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity>
                                                                                                              [ rdf:type owl:Restriction ;
                                                                                                                owl:onProperty <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                                                                owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                              ]
                                                                                                            ) ;
                                                                                         rdf:type owl:Class
                                                                                       ] ;
                                                                   rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ,
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                                     owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                   ] ;
                                                                   rdfs:isDefinedBy <https://spec.industrialontologies.org/ontology/core/Core/> ;
                                                                   rdfs:label "denoter"@en-us ;
                                                                   skos:example "'vehicle identification number' denotes a vehicle; 'ethanol' is a name given by IUPAC which denotes molecules with the structure CH3-CH2-OH; 50-99-7 is a CAS registry number that denotes glucose; the lot identifier assigned to a batch of rivets just received from China by the Airbus final assembly plant in Toulouse, FR; URI of a website" ;
                                                                   annotation:explanatoryNote "A denoter is an information content entity used to distinguish an entity in a particular context. The relation denotes does not require uniqueness at either the individual level or the type level. More specific subclasses, such as identifier and classifier, should be used where stronger forms of distinction are needed. Identifier is used for individual-level uniqueness. Classifier is used for type-level uniqueness." ;
                                                                   annotation:firstOrderLogicDefinition "Denoter(x) ‚Üî InformationContentEntity(x) ‚àß ‚àÉe(Entity(e) ‚àß denotes(x,e))" ;
                                                                   annotation:naturalLanguageDefinition "information content entity that denotes some entity"@en-us ;
                                                                   annotation:semiFormalNaturalLanguageDefinition "every instance of 'denoter' is defined as exactly an instance of 'information content entity' that 'denotes' some 'entity'" .


###  https://spec.industrialontologies.org/ontology/construct/DescriptiveInformationContentEntity
<https://spec.industrialontologies.org/ontology/construct/DescriptiveInformationContentEntity> rdf:type owl:Class ;
                                                                                               owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity>
                                                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                                                            owl:onProperty <https://spec.industrialontologies.org/ontology/construct/describes> ;
                                                                                                                                            owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                                                          ]
                                                                                                                                        ) ;
                                                                                                                     rdf:type owl:Class
                                                                                                                   ] ;
                                                                                               rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ,
                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                 owl:onProperty <https://spec.industrialontologies.org/ontology/construct/describes> ;
                                                                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                               ] ;
                                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                               rdfs:label "descriptive information content entity"@en-us ;
                                                                                               skos:example "a description of a product in a product catalogue, the wheelbase of this car is 3m, digital copy of a Mona Lisa drawing"@en-us ;
                                                                                               annotation:abbreviation "descriptive ICE"@en-us ;
                                                                                               annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                                               annotation:explanatoryNote "This class is intended to be a defined class used for axiomatization and assertion convenience. It is not expected nor recommended that entities will be asserted as a subclass of this class."@en-us ;
                                                                                               annotation:firstOrderLogicDefinition "DescriptiveInformationContentEntity(x) ‚Üî InformationContentEntity(x) ‚àß ‚àÉe(Entity(e) ‚àß describes(x,e))" ;
                                                                                               annotation:naturalLanguageDefinition "information content entity that characterizes (gives a description of) an entity"@en-us ;
                                                                                               annotation:semiFormalNaturalLanguageDefinition "every instance of 'descriptive information content entity ' is defined as exactly an instance of 'information content entity' that 'describes' some 'entity'" .


###  https://spec.industrialontologies.org/ontology/construct/DesignSpecification
<https://spec.industrialontologies.org/ontology/construct/DesignSpecification> rdf:type owl:Class ;
                                                                               rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ,
                                                                                               [ rdf:type owl:Restriction ;
                                                                                                 owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribes> ;
                                                                                                 owl:allValuesFrom <http://purl.obolibrary.org/obo/BFO_0000002>
                                                                                               ] ;
                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                               rdfs:label "design specification"@en-us ;
                                                                               skos:example "document specifying the characteristics of a pharmaceutical product; the design of a software program to schedule the work orders in a factory"@en-us ;
                                                                               annotation:adaptedFrom "http://en.wikipedia.org/wiki/Design and from http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology, term under the name 'artifact design'" ;
                                                                               annotation:counterExample "process design" ;
                                                                               annotation:explanatoryNote """1. Design specification may be a model or a textual or graphical specification.

2. This class is not intended to be used to represent the design of planned processes. For this purpose, plan specification should be used.

3. Something 'man-made' comprehends those physical and non-physical things that are intentionally created by human beings. Hence the thing specified by a design specification may be either BFO:GDC or BFO:Material Entity.

4. A design specification specifies what the thing should be, such as its shape, size, tolerance, and performance but not necessarily how the thing should be made. If it contains information on how a thing should be made, this should be modeled separately through a 'plan specification' that is 'part of' the design specification

5. Typically, a design specification satisfies a set of requirements""" ;
                                                                               annotation:firstOrderLogicAxiom "LA1: DesignSpecification(x) ‚Üí InformationContentEntity(x) ‚àß ‚àÄc (prescribes(x,c) ‚Üí Continuant(c))" ,
                                                                                                               "LA2: InformationContentEntity(x) ‚àß ‚àÉc‚àÉr(Continuant(c) ‚àß RequirementSpecification(r) ‚àß satisfiesRequirement(x,r) ‚àß prescribes(x,c)) ‚àß ‚àÄc1(prescribes(x,c1) ‚Üí Continuant(c1)) ‚Üí DesignSpecification(x)" ;
                                                                               annotation:isPrimitive "true"^^xsd:boolean ;
                                                                               annotation:naturalLanguageDefinition "information content entity that prescribes something man-made"@en-us ;
                                                                               annotation:primitiveRationale "See the general discussion and rationale provided for informational entities under 'information content entity'." ;
                                                                               annotation:semiFormalNaturalLanguageAxiom "LA1: if d is a 'design specification' then d is an 'information content entity' and whenever d 'prescribes' y that y must be a 'continuant'" ,
                                                                                                                         "LA2: if d is an 'information content entity' that 'prescribes' some 'continuant' and that 'satisfies requirement' some 'requirement specification' and if all y that d 'presribes' are instance of 'continuant' then d is a 'design specification'" .


###  https://spec.industrialontologies.org/ontology/construct/DesignativeInformationContentEntity
<https://spec.industrialontologies.org/ontology/construct/DesignativeInformationContentEntity> rdf:type owl:Class ;
                                                                                               owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity>
                                                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                                                            owl:onProperty <https://spec.industrialontologies.org/ontology/construct/designates> ;
                                                                                                                                            owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                                                          ]
                                                                                                                                        ) ;
                                                                                                                     rdf:type owl:Class
                                                                                                                   ] ;
                                                                                               rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/Denoter> ,
                                                                                                               [ rdf:type owl:Restriction ;
                                                                                                                 owl:onProperty <https://spec.industrialontologies.org/ontology/construct/designates> ;
                                                                                                                 owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                               ] ;
                                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                               rdfs:label "designative information content entity"@en-us ;
                                                                                               skos:example "uri of a website, social security number of a person, lot number of a batch of products, a serial number on a machine, a credit card number, a combination of data in a database table uniquely identify each record in the table"@en-us ;
                                                                                               annotation:abbreviation "designative ICE"@en-us ;
                                                                                               annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                                               annotation:explanatoryNote """1. This class is intended to be a defined class used for axiomatization and assertion convenience. It is not expected nor recommended that entities will be asserted as a subclass of this class.

2. Since the relation 'designates' is defined as a functional property, uniqueness is enforced in the term's formalization.""" ;
                                                                                               annotation:firstOrderLogicDefinition "DesignativeInformationContentEntity(x) ‚Üî InformationContentEntity(x) ‚àß ‚àÉe(Entity(e) ‚àß designates(x,e))" ;
                                                                                               annotation:naturalLanguageDefinition "information content entity that uniquely identifies an entity"@en-us ;
                                                                                               annotation:semiFormalNaturalLanguageDefinition "every instance of 'designative information content entity' is defined as exactly an instance of 'information content entity' that 'designates' some 'entity'" .


###  https://spec.industrialontologies.org/ontology/construct/DesignedFunction
<https://spec.industrialontologies.org/ontology/construct/DesignedFunction> rdf:type owl:Class ;
                                                                            owl:equivalentClass [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000034>
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribedBy> ;
                                                                                                                         owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/DesignSpecification>
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ] ;
                                                                            rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000034> ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribedBy> ;
                                                                                              owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/DesignSpecification>
                                                                                            ] ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                            rdfs:label "designed function"@en-us ;
                                                                            skos:example "the function of a oil pump to pump oil, the function of a knife to cut things" ;
                                                                            annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ArtifactOntology"@en-us ;
                                                                            annotation:firstOrderLogicDefinition "ArtifactFunction(x) ‚Üî Function(x) ‚àß ‚àÉd(DesignSpecification(m)‚àß prescribedBy(x,d))" ;
                                                                            annotation:naturalLanguageDefinition "function that is intentionally designed"@en-us ;
                                                                            annotation:semiFormalNaturalLanguageDefinition "every instance of 'designed function' is exactly an instance of 'function' that is 'prescribed by' some 'design specification'" .


###  https://spec.industrialontologies.org/ontology/construct/DirectiveInformationContentEntity
<https://spec.industrialontologies.org/ontology/construct/DirectiveInformationContentEntity> rdf:type owl:Class ;
                                                                                             owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity>
                                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                                          owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribes> ;
                                                                                                                                          owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                                                        ]
                                                                                                                                      ) ;
                                                                                                                   rdf:type owl:Class
                                                                                                                 ] ;
                                                                                             rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/InformationContentEntity> ,
                                                                                                             [ rdf:type owl:Restriction ;
                                                                                                               owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribes> ;
                                                                                                               owl:someValuesFrom <http://purl.obolibrary.org/obo/BFO_0000001>
                                                                                                             ] ;
                                                                                             rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                             rdfs:label "directive information content entity"@en-us ;
                                                                                             skos:example "blueprint of a building, process plan, software functional requirement"@en-us ;
                                                                                             annotation:abbreviation "directive ICE"@en-us ;
                                                                                             annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                                             annotation:explanatoryNote "This class is intended to be a defined class used for axiomatization and assertion convenience. It is not expected nor recommended that entities will be asserted as a subclass of this class." ;
                                                                                             annotation:firstOrderLogicDefinition "DirectiveInformationContentEntity(x) ‚Üî InformationContentEntity(x) ‚àß ‚àÉe(Entity(e) ‚àß prescribes(x,e))" ;
                                                                                             annotation:naturalLanguageDefinition "information content entity that prescribes a set of rules or guidelines for a process or a model of something man-made"@en-us ;
                                                                                             annotation:semiFormalNaturalLanguageDefinition "every instance of 'directive information content entity' is defined as exactly an instance of 'information content entity' that 'prescribes' some 'entity'" .


###  https://spec.industrialontologies.org/ontology/construct/EncodedAlgorithm
<https://spec.industrialontologies.org/ontology/construct/EncodedAlgorithm> rdf:type owl:Class ;
                                                                            rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/PlanSpecification> ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                            rdfs:label "encoded algorithm"@en-us ;
                                                                            skos:example "source code encoded in Java that implements a sorting algorithm; Python script that implements a decision tree and that has the objective to classify melt pool images"@en-us ;
                                                                            annotation:adaptedFrom "http://www.ebi.ac.uk/swo/SWO_0000001" ;
                                                                            annotation:counterExample "flowchart, pseudocode" ;
                                                                            annotation:explanatoryNote "Readily executable means that it can be 1) concretized by a computing process which is prescribed by the encoded algorithm or 2) in case of source code concretized by a compiling process" ;
                                                                            annotation:firstOrderLogicAxiom "PlanSpecification(x) ‚àß ‚àÉy(ComputingProcess(y) ‚àß prescribes(x,y)) ‚Üí EncodedAlgorithm(x)" ;
                                                                            annotation:isPrimitive "true"^^xsd:boolean ;
                                                                            annotation:naturalLanguageDefinition "plan specification that is the implementation of an algorithm encoded in a specific programming language or framework and that is readily executable"@en-us ;
                                                                            annotation:primitiveRationale "In addition to the general discussion provided for information content enty,there are insufficient constructs to create necessary and sufficient conditions. Namely constructs for 'encoded in', 'implementation of' and 'programming language' or 'framework' as well as 'compiling process' are still missing." ;
                                                                            annotation:semiFormalNaturalLanguageAxiom "If x is a 'plan specification' that 'prescribes' some 'computing process' then x is an instance of 'encoded algorithm'" .


###  https://spec.industrialontologies.org/ontology/construct/EngineeredSystem
<https://spec.industrialontologies.org/ontology/construct/EngineeredSystem> rdf:type owl:Class ;
                                                                            owl:equivalentClass [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/System>
                                                                                                                       [ rdf:type owl:Restriction ;
                                                                                                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                                                                         owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/DesignedFunction>
                                                                                                                       ]
                                                                                                                     ) ;
                                                                                                  rdf:type owl:Class
                                                                                                ] ;
                                                                            rdfs:subClassOf <https://spec.industrialontologies.org/ontology/construct/System> ,
                                                                                            [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                                              owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/DesignedFunction>
                                                                                            ] ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                            rdfs:label "engineered system"@en-us ;
                                                                            skos:example "machine, laptop, traffic light system"@en-us ;
                                                                            annotation:adaptedFrom "www.incose.com, term by the same name" ;
                                                                            annotation:firstOrderLogicDefinition "EngineeredSystem(x) ‚Üî System(x) ‚àß ‚àÉf(DesignedFunction(f) ‚àß bearerOf(x,f))" ;
                                                                            annotation:naturalLanguageDefinition "system that is deliberately created to have a certain function"@en-us ;
                                                                            annotation:semiFormalNaturalLanguageDefinition "every instance of 'engineered system' is defined as exactly an instance of 'system' that is the 'bearer of' some 'designed function'" .


###  https://spec.industrialontologies.org/ontology/construct/EquipmentRole
<https://spec.industrialontologies.org/ontology/construct/EquipmentRole> rdf:type owl:Class ;
                                                                         rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000023> ,
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                                           owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Class ;
                                                                                                                                       owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/EngineeredSystem>
                                                                                                                                                     <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>
                                                                                                                                                   )
                                                                                                                                     ]
                                                                                                                                     [ rdf:type owl:Restriction ;
                                                                                                                                       owl:onProperty <https://spec.industrialontologies.org/ontology/construct/prescribedBy> ;
                                                                                                                                       owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                                                            owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/PlanSpecification>
                                                                                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                                                                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000177> ;
                                                                                                                                                                            owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/PlanSpecification>
                                                                                                                                                                          ]
                                                                                                                                                                        )
                                                                                                                                                          ]
                                                                                                                                     ]
                                                                                                                                   ) ;
                                                                                                                rdf:type owl:Class
                                                                                                              ]
                                                                                         ] ,
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                                           owl:allValuesFrom [ owl:intersectionOf ( <https://spec.industrialontologies.org/ontology/construct/PlannedProcess>
                                                                                                                                    [ rdf:type owl:Restriction ;
                                                                                                                                      owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000055> ;
                                                                                                                                      owl:someValuesFrom [ owl:intersectionOf ( <http://purl.obolibrary.org/obo/BFO_0000034>
                                                                                                                                                                                [ rdf:type owl:Restriction ;
                                                                                                                                                                                  owl:onProperty <https://spec.industrialontologies.org/ontology/construct/functionOf> ;
                                                                                                                                                                                  owl:someValuesFrom [ rdf:type owl:Class ;
                                                                                                                                                                                                       owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/EngineeredSystem>
                                                                                                                                                                                                                     <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>
                                                                                                                                                                                                                   )
                                                                                                                                                                                                     ]
                                                                                                                                                                                ]
                                                                                                                                                                              ) ;
                                                                                                                                                           rdf:type owl:Class
                                                                                                                                                         ]
                                                                                                                                    ]
                                                                                                                                  ) ;
                                                                                                               rdf:type owl:Class
                                                                                                             ]
                                                                                         ] ,
                                                                                         [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                                           owl:allValuesFrom [ rdf:type owl:Class ;
                                                                                                               owl:unionOf ( <https://spec.industrialontologies.org/ontology/construct/EngineeredSystem>
                                                                                                                             <https://spec.industrialontologies.org/ontology/construct/MaterialArtifact>
                                                                                                                           )
                                                                                                             ]
                                                                                         ] ;
                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                         rdfs:label "equipment role"@en-us ;
                                                                         skos:example "role of a wrench when it is used in the maintenance process of a car; role of a chromatography column that is planned to be used in a protein purification process; role of a truck that is used to transport goods to the buyer; role of a single-use bioreactor when it is planned to be used in the upstream phase of a biomanufacturing process"@en-us ;
                                                                         annotation:adaptedFrom "adapted from Oxford Languages, term by the name ‚Äòequipment‚Äô" ;
                                                                         annotation:explanatoryNote """1. By including in the definition that the material artifact or engineered system is not consumed in the process, the equipment role intentionally excludes entities such as consumables and reagents, which should be modeled separately.

2. In the definition, \"utilized for carrying out\" implies that the function of the given material artifact or the engineered system needs to be realized in the process. That is, entities with the equipment role should not passively participate in the prescribed process. This differentiates 'material entities with the equipment role' (a piece of equipment) from material entities that are acted upon (transformed or modified) in the given process.""" ;
                                                                         annotation:firstOrderLogicAxiom "LA1: EquipmentRole(x) ‚Üí ‚àÄy (hasRealization(x,y) ‚Üí (PlannedProcess(y) ‚àß ‚àÉf (Function(f) ‚àß realizes(y,f) ‚àß ‚àÉz ((EngineeredSystem(z) ‚à® MaterialArtifact(z)) ‚àß functionOf(f,z)))))" ,
                                                                                                         "LA2: EquipmentRole(x) ‚Üí ‚àÄy (roleOf(x,y) ‚Üí (EngineeredSystem(y) ‚à® MaterialArtifact(y)))" ,
                                                                                                         "LA3: EquipmentRole(x) ‚Üí ‚àÉy ( roleOf(x,y) ‚àß (EngineeredSystem(y) ‚à® MaterialArtifact(y)) ‚àß ‚àÉz ( prescribedBy(y,z) ‚àß ( PlanSpecification(z) ‚à® ‚àÉp ( PlanSpecification(p) ‚àß continuantPartOfAtAllTimes(z,p) ) ) ) )" ;
                                                                         annotation:isPrimitive "true"^^xsd:boolean ;
                                                                         annotation:naturalLanguageDefinition "role held by a material artifact or an engineered system when it is planned to be involved in or is involved in carrying out some part of a planned process and that is not consumed in that planned process"@en-us ;
                                                                         annotation:primitiveRationale "There are insufficient constructs to define necessary and sufficient conditions. Namely, patterns for utilized in carrying out and not consumed need to be developed further." ;
                                                                         annotation:semiFormalNaturalLanguageAxiom "LA1: if x is an ‚Äòequipment role‚Äô then whenever x ‚Äòhas realization‚Äô y, y is a ‚Äòplanned process‚Äô that ‚Äòrealizes‚Äô some ‚Äòfunction‚Äô that is ‚Äòfunction of‚Äô some ‚Äòengineered system‚Äô or ‚Äòmaterial artifact‚Äô" ,
                                                                                                                   "LA2: if x is an ‚Äòequipment role‚Äô then whenever x ‚Äòrole of‚Äô y, y must be an ‚Äòengineered system‚Äô or a ‚Äòmaterial artifact‚Äô" ,
                                                                                                                   "LA3: if x is an ‚Äòequipment role‚Äô then x is ‚Äòrole of‚Äô some y such that y is an ‚Äòengineered system‚Äô or a ‚Äòmaterial artifact‚Äô, and y is ‚Äòprescribed by‚Äô some entity that is either a ‚Äòplan specification‚Äô or something that is ‚Äòcontinuant part of at all times‚Äô some ‚Äòplan specification‚Äô" .


###  https://spec.industrialontologies.org/ontology/construct/Event
<https://spec.industrialontologies.org/ontology/construct/Event> rdf:type owl:Class ;
                                                                 rdfs:subClassOf <http://purl.obolibrary.org/obo/BFO_0000003> ,
                                                                                 [ rdf:type owl:Class ;
                                                                                   owl:unionOf ( <http://purl.obolibrary.org/obo/BFO_0000015>
                                                                                                 <http://purl.obolibrary.org/obo/BFO_0000035>
                                                                                               )
                                                                                 ] ,
                                                                                 [ rdf:type owl:Restriction ;
                                                                                   owl:onProperty <https://spec.industrialontologies.org/ontology/construct/recognizedByAtSomeTime> ;
                                                                                   owl:someValuesFrom <https://spec.industrialontologies.org/ontology/construct/Agent>
                                                                                 ] ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "event"@en-us ;
                                                                 skos:example "a machine failure event, the amount of cells in a bioreactor reaches a certain threshold"@en-us ;
                                                                 annotation:adaptedFrom "Oxford Languages, term by the same name" ;
                                                                 annotation:counterExample "an event in discrete event simulation is too generic and that notion of event is just BFO:Occurrent" ;
                                                                 annotation:firstOrderLogicAxiom "Event(x) ‚Üí (Process(x) ‚à® ProcessBoundary(x)) ‚àß ‚àÉy(Agent(y) ‚àß recognizedByAtSomeTime(x,y))" ;
                                                                 annotation:isPrimitive "true"^^xsd:boolean ;
                                                                 annotation:naturalLanguageDefinition "phenomena (process or process boundary) that is recognized by an agent and typically recorded"@en-us ;
                                                                 annotation:primitiveRationale "More conditions (differentia) need to be agreed upon by the domain experts as not all occurrents recognized by an agent are events." ;
                                                                 annotation:semiFormalNaturalLanguageAxiom "if x is an 'event' then x is a 'process' or 'process boundary' and there is some 'agent' that 'recognizes at some time' x" .


