    <!-- https://www.inf.ufrgs.br/ontologies/copi/AbsorbentPhase -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/AbsorbentPhase">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PortionOfLiquid"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">absorbent phase</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ChemicalReaction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChemicalReaction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">chemical reaction</rdfs:label>
        <rdfs:label xml:lang="pt-br">reação química</rdfs:label>
        <skos:example xml:lang="en">Fermentation of sugars to ethanol; combustion; catalytic conversion.</skos:example>
        <skos:example xml:lang="pt-br">Fermentação de açúcares a etanol; combustão; conversão catalítica.</skos:example>
        <annotation:firstOrderLogicAxiom>ChemicalReaction(x) → Process(x) ∧ ∃o,c(hasOutput(x,o) ∧ hasConstituent(o,c) ∧ ¬∃i,c1(hasInput(x,i) ∧ hasConstituent(i,c1) ∧ sameSubstance(c1,c)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which chemical species are consumed and new species, present in no input, are formed.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de processo unitário; a formação de uma espécie genuinamente nova é parcialmente caracterizada em FOL mas apenas o gênero é asserido em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-process class; the formation of a genuinely new species is partly characterised in FOL but only the genus is asserted in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;chemical reaction&apos; then x is a &apos;process&apos; whose output has a constituent substance that no input has</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;reação química&apos; então x é um &apos;processo&apos; cuja saída tem uma substância constituinte que nenhuma entrada possui</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ChemicalReactor -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ChemicalReactor">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChemicalReaction"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ChemicalReaction"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">chemical reactor</rdfs:label>
        <rdfs:label xml:lang="pt-br">reator químico</rdfs:label>
        <skos:example xml:lang="en">CSTR, plug-flow reactor, fixed-bed catalytic reactor</skos:example>
        <skos:example xml:lang="pt-br">CSTR, reator de fluxo pistonado, reator catalítico de leito fixo</skos:example>
        <annotation:adaptedFrom>Unit-process tradition; ISO 14224 Annex A; IEC 81346-2 code H.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>ChemicalReactor(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(ChemicalReaction(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a chemical-reaction operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de reação química.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;chemical reactor&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;chemical reaction&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;reator químico&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;reação química&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Composition -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Composition">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CompositionMeasurementResult -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompositionMeasurementResult">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Composition"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing the chemical or phase composition quality of a substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/CompressionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/CompressionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasPressureIncrease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasPressureIncrease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">compression function</rdfs:label>
        <rdfs:label xml:lang="pt-br">função de compressão</rdfs:label>
        <annotation:explanatoryNote xml:lang="en">Entailed disjoint from PumpingFunction because LiquidPressureIncrease and GasPressureIncrease are disjoint and each function is realized in some-and-only its leaf operation.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Implicada disjunta de PumpingFunction porque LiquidPressureIncrease e GasPressureIncrease são disjuntas e cada função é realizada em alguma-e-apenas sua operação folha.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>CompressionFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ GasPressureIncrease(p)) ∧ ∀p(realizedIn(x,p) → GasPressureIncrease(p))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A função projetada de elevar a pressão de um gás compressível; realizada apenas em uma operação de aumento de pressão de gás.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The designed function to raise the pressure of a compressible gas; realized only in a gas-pressure-increase operation.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As for PumpingFunction.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Como em PumpingFunction.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;compression function&apos; then x is a &apos;designed function&apos; that is &apos;realized in&apos; some &apos;gas pressure increase&apos; and is &apos;realized in&apos; only &apos;gas pressure increase&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;função de compressão&apos; então x é uma &apos;função projetada&apos; que é &apos;realizada em&apos; algum &apos;aumento de pressão de gás&apos; e é &apos;realizada em&apos; apenas &apos;aumento de pressão de gás&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Compressor -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Compressor">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransferDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/CompressionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Pump"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Valve"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">compressor</rdfs:label>
        <rdfs:label xml:lang="pt-br">compressor</rdfs:label>
        <skos:example xml:lang="en">centrifugal compressor, reciprocating compressor</skos:example>
        <skos:example xml:lang="pt-br">compressor centrífugo, compressor alternativo</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A (rotating equipment).</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">Inferida como MomentumTransferDevice apenas a partir de sua função. Asserida disjunta de bomba.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Inferred to be a MomentumTransferDevice from its function alone. Asserted disjoint from Pump.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>Compressor(x) → MaterialArtifact(x) ∧ ∃f(CompressionFunction(f) ∧ hasFunction(x,f))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact whose identity-giving designed function is to raise the pressure of a compressible gas.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material cuja função projetada identificadora é elevar a pressão de um gás compressível.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As for Pump.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Como em Pump.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;compressor&apos; then x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;compression function&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;compressor&apos; então x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função de compressão&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ContainmentDevice -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContainmentDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialContainment"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialContainment"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">containment device</rdfs:label>
        <rdfs:label xml:lang="pt-br">dispositivo de contenção</rdfs:label>
        <skos:example xml:lang="en">storage tank, pressure vessel, accumulator</skos:example>
        <skos:example xml:lang="pt-br">tanque de armazenamento, vaso de pressão, acumulador</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A; IEC 81346-2 code C.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>ContainmentDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MaterialContainment(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a material-containment operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de contenção de material.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;containment device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;material containment&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de contenção&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;contenção de material&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ContainmentFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ContainmentFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialContainment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MaterialContainment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">containment function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a MaterialContainment process; the function of holding a fluid or solid material within a bounded volume.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ControlSignal -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ControlSignal">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">control signal</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity that conveys an instruction or set-point to a control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/DepletedFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/DepletedFluid">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PortionOfFluid"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">depleted fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid from which target components have been removed or transferred during a treatment process.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalPower -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPower">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">electrical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in an electrical system that represents the rate of electrical energy transfer.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Filter -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Filter">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">filter</rdfs:label>
        <annotation:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that separates solid contaminants or particles from a fluid stream by passing the stream through a porous medium or filter element.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowControl -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControl">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">controle de fluxo</rdfs:label>
        <rdfs:label xml:lang="en">flow control</rdfs:label>
        <skos:example xml:lang="pt-br">Estrangular uma corrente por uma válvula de controle; isolar por uma válvula de bloqueio; aliviar sobrepressão.</skos:example>
        <skos:example xml:lang="en">Throttling a stream through a control valve; isolating via a shutoff valve; relieving overpressure.</skos:example>
        <annotation:firstOrderLogicAxiom>FlowControl(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that modulates a flow without changing the material&apos;s substance, phase, or composition.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Auxiliary category; the conservation of substance/phase/composition under modulation is the characterisation and is not a material transformation.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Categoria auxiliar; a conservação de substância/fase/composição sob modulação é a caracterização e não é uma transformação material.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;flow control&apos; then x is a &apos;process&apos; that conserves the substance, phase and composition of its material participant</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;controle de fluxo&apos; então x é um &apos;processo&apos; que conserva a substância, a fase e a composição de seu participante material</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowControlDevice -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControl"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControl"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de controle de fluxo</rdfs:label>
        <rdfs:label xml:lang="en">flow-control device</rdfs:label>
        <skos:example xml:lang="en">control valve, shutoff valve, relief valve</skos:example>
        <skos:example xml:lang="pt-br">válvula de controle, válvula de bloqueio, válvula de alívio</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A; IEC 81346-2 codes Q, R, F.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>FlowControlDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(FlowControl(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a flow-control operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de controle de fluxo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;flow-control device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;flow control&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de controle de fluxo&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; algum &apos;controle de fluxo&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlElement">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">elemento de controle de fluxo</rdfs:label>
        <rdfs:label xml:lang="en">flow control element</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A valve trim component whose position controls the area of the flow path (e.g. plug, disc, gate, ball).</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControl"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControl"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow control function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a FlowControl process; the function of modulating, regulating, or blocking fluid flow through a conduit or vessel connection.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementResult -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementResult">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowRate"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a flow rate quality of a fluid stream.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowMeasuringElement -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowMeasuringElement">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">flow measuring element</rdfs:label>
        <annotation:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
        <annotation:naturalLanguageDefinition xml:lang="en">A primary flow element inserted in a fluid stream that creates a differential pressure, velocity, or other measurable effect proportional to the volumetric or mass flow rate.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowModificationAccessory -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowModificationAccessory">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">flow modification accessory</rdfs:label>
        <annotation:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact installed in a pipeline to modify flow characteristics — such as flow rate, pressure drop, or velocity profile — without functioning as a primary flow control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FlowRate -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FlowRate">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow rate</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/FluidMixture -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/FluidMixture">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PortionOfFluid"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">fluid mixture</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid portion consisting of two or more components or phases that have not yet been fully separated.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasAbsorber -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasAbsorber">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MassTransferDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasAbsorptionFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">absorvedor de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas absorber</rdfs:label>
        <annotation:adaptedFrom>Treybal, Mass-Transfer Operations; TEG contactor.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">O contactor de TEG de uma unidade de desidratação de gás offshore é um absorvedor de gás.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">The TEG contactor of an offshore gas-dehydration unit is a gas absorber.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>GasAbsorber(x) → MaterialArtifact(x) ∧ ∃f(GasAbsorptionFunction(f) ∧ hasFunction(x,f))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A mass-transfer artifact that contacts a gas with a solvent so that a species migrates gas-&gt;liquid.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato de transferência de massa que contata um gás com um solvente de modo que uma espécie migre gás-&gt;líquido.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;gas absorber&apos; then x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;gas-absorption function&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;absorvedor de gás&apos; então x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função de absorção de gás&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:synonym xml:lang="en">absorption column</annotation:synonym>
        <annotation:synonym xml:lang="pt-br">coluna de absorção</annotation:synonym>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasAbsorption -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasAbsorption">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MassTransfer"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">absorção de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas absorption</rdfs:label>
        <annotation:adaptedFrom>Treybal, Mass-Transfer Operations.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>GasAbsorption(p) ↔ MassTransfer(p) ∧ ∃g,l,l2,c(hasInput(p,g) ∧ Gas(g) ∧ hasInput(p,l) ∧ Liquid(l) ∧ hasOutput(p,l2) ∧ Liquid(l2) ∧ derivesFrom(l2,l) ∧ hasConstituent(g,c) ∧ ¬∃c1(hasConstituent(l,c1) ∧ sameSubstance(c1,c)) ∧ ∃c2(hasConstituent(l2,c2) ∧ sameSubstance(c2,c)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Although a full first-order definition is available, OWL 2 DL carries only the typed-participation envelope; the relational differentia (a constituent migrating gas-&gt;liquid) is FOL-only.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o envelope de participação tipada; a diferença relacional (um constituinte migrando gás-&gt;líquido) é apenas-FOL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;gas absorption&apos; if and only if x is a &apos;mass transfer&apos; in which a substance carried by the input gas, absent from the input solvent, is a constituent of the output liquid</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;absorção de gás&apos; se e somente se x é uma &apos;transferência de massa&apos; na qual uma substância transportada pelo gás de entrada, ausente do solvente de entrada, é constituinte do líquido de saída</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasAbsorptionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasAbsorptionFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasAbsorption"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/GasAbsorption"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de absorção de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas-absorption function</rdfs:label>
        <annotation:adaptedFrom>Treybal, Mass-Transfer Operations.</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>GasAbsorptionFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ GasAbsorption(p)) ∧ ∀p(realizedIn(x,p) → GasAbsorption(p))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A função projetada de contatar um gás com um solvente de modo que uma espécie migre gás-&gt;líquido; realizada apenas em uma operação de absorção de gás.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The designed function to contact a gas with a solvent so a species migrates gas-&gt;liquid; realized only in a gas-absorption operation.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;gas-absorption function&apos; then x is a &apos;designed function&apos; that is &apos;realized in&apos; some &apos;gas absorption&apos; and is &apos;realized in&apos; only &apos;gas absorption&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;função de absorção de gás&apos; então x é uma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;absorção de gás&apos; e é &apos;realizada em&apos; apenas &apos;absorção de gás&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/GasPressureIncrease -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/GasPressureIncrease">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransfer"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LiquidPressureIncrease"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">aumento de pressão de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas pressure increase</rdfs:label>
        <annotation:firstOrderLogicDefinition>GasPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃g(Gas(g) ∧ hasInput(x,g)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Gas(m))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas&apos;s pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As for LiquidPressureIncrease: the phase constraint is not expressible in OWL 2 DL; only the genus is asserted.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Como em LiquidPressureIncrease: a restrição de fase não é expressável em OWL 2 DL; apenas o gênero é asserido.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;gas pressure increase&apos; if and only if x is a &apos;momentum transfer&apos; whose fluid input is a &apos;gas&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;aumento de pressão de gás&apos; se e somente se x é uma &apos;transferência de quantidade de movimento&apos; cuja entrada fluida é um &apos;gás&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HeatTransfer -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatTransfer">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">heat transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de calor</rdfs:label>
        <skos:example xml:lang="pt-br">Aquecimento sensível de uma corrente de processo contra uma utilidade quente.</skos:example>
        <skos:example xml:lang="en">Sensible heating of a process stream against a hot utility.</skos:example>
        <annotation:firstOrderLogicAxiom>HeatTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a constância de fase e de identidade química que distingue a transferência de calor sensível não é capturada em OWL, de modo que apenas o envelope é asserido.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the constancy of phase and chemical identity that distinguishes sensible heat transfer is not captured in OWL, so only the envelope is asserted.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;heat transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de calor&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HeatTransferDevice -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatTransferDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransfer"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransfer"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de calor</rdfs:label>
        <rdfs:label xml:lang="en">heat-transfer device</rdfs:label>
        <skos:example xml:lang="en">shell-and-tube exchanger, fired heater, reboiler</skos:example>
        <skos:example xml:lang="pt-br">trocador casco-e-tubo, aquecedor a fogo direto, refervedor</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 codes E, V.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">Categoria definida; um artefato que porta uma função secundária (e.g. um refervedor que também vaporiza) adquire pertinências adicionais de categoria -- intencional, não um defeito.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Defined category; an artifact bearing a secondary function (e.g. a reboiler that also vaporizes) acquires additional category memberships -- intended, not a defect.</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>HeatTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(HeatTransfer(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a heat-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;heat-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;heat transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de calor&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de calor&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/HeatTransferFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/HeatTransferFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransfer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransfer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de transferência de calor</rdfs:label>
        <rdfs:label xml:lang="en">heat-transfer function</rdfs:label>
        <annotation:firstOrderLogicAxiom>HeatTransferFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ HeatTransfer(p)) ∧ ∀p(realizedIn(x,p) → HeatTransfer(p))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A função projetada de transferir energia térmica de ou para uma corrente de processo; realizada apenas em uma operação de transferência de calor.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The designed function to transfer thermal energy to or from a process stream; realized only in a heat-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;heat-transfer function&apos; then x is a &apos;designed function&apos; that is &apos;realized in&apos; some &apos;heat transfer&apos; and is &apos;realized in&apos; only &apos;heat transfer&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;função de transferência de calor&apos; então x é uma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de calor&apos; e é &apos;realizada em&apos; apenas &apos;transferência de calor&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/IndicationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/IndicationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">indication function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a Measurement process; the function of converting a physical quantity into a locally readable display at the point of measurement.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/InstrumentationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/InstrumentationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">instrumentation function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a sensing or measurement process; the function of detecting and converting a physical quantity into a usable signal or reading.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Level -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Level">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementResult -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementResult">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Level"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a liquid level quality of a vessel or container.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LiquidPressureIncrease -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LiquidPressureIncrease">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransfer"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">aumento de pressão de líquido</rdfs:label>
        <rdfs:label xml:lang="en">liquid pressure increase</rdfs:label>
        <annotation:firstOrderLogicDefinition>LiquidPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Liquid(m))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid&apos;s pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL 2 DL cannot express the phase constraint on the fluid input; the OWL form asserts only the genus (MomentumTransfer). The disjointness with GasPressureIncrease is asserted to carry the pump/compressor partition.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">OWL 2 DL não consegue expressar a restrição de fase sobre a entrada fluida; a forma OWL assere apenas o gênero (MomentumTransfer). A disjunção com GasPressureIncrease é asserida para sustentar a partição bomba/compressor.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;liquid pressure increase&apos; if and only if x is a &apos;momentum transfer&apos; whose fluid input is a &apos;liquid&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;aumento de pressão de líquido&apos; se e somente se x é uma &apos;transferência de quantidade de movimento&apos; cuja entrada fluida é um &apos;líquido&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/LossOfContainment -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/LossOfContainment">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">loss of containment</rdfs:label>
        <rdfs:label xml:lang="pt-br">perda de contenção</rdfs:label>
        <annotation:explanatoryNote xml:lang="en">Relevant to HAZOP and failure-propagation work built over COPI.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Relevante para trabalhos de HAZOP e propagação de falhas construídos sobre o COPI.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>LossOfContainment(x) → Process(x) ∧ ¬PlannedProcess(x)</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Included to make the bfo:Process rooting concrete: the same boundary-failure kind is failure-relevant (ISO 14224) and cannot be a PlannedProcess; a planned-only hierarchy would exclude it.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Incluída para tornar concreta a ancoragem em bfo:Process: o mesmo tipo de falha de barreira é relevante para falhas (ISO 14224) e não pode ser um PlannedProcess; uma hierarquia só-planejada o excluiria.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;loss of containment&apos; then x is a &apos;process&apos; and x is not a &apos;planned process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;perda de contenção&apos; então x é um &apos;processo&apos; e x não é um &apos;processo planejado&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MassTransfer -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MassTransfer">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">mass transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de massa</rdfs:label>
        <skos:example xml:lang="en">Absorption of a gas component into a liquid solvent; stripping; distillation.</skos:example>
        <skos:example xml:lang="pt-br">Absorção de um componente gasoso em um solvente líquido; esgotamento (stripping); destilação.</skos:example>
        <annotation:firstOrderLogicAxiom>MassTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico).</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a migração interfásica que individua seus membros é declarada para folhas específicas (e.g. GasAbsorption) mas não no nível da categoria em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the inter-phase migration that individuates its members is stated for specific leaves (e.g. GasAbsorption) but not at the category level in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;mass transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de massa&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MassTransferDevice -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MassTransferDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MassTransfer"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MassTransfer"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de massa</rdfs:label>
        <rdfs:label xml:lang="en">mass-transfer device</rdfs:label>
        <skos:example xml:lang="en">absorber, stripper, distillation column, adsorber</skos:example>
        <skos:example xml:lang="pt-br">absorvedor, esgotador, coluna de destilação, adsorvedor</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>MassTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MassTransfer(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a mass-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;mass-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;mass transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de massa&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de massa&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MaterialContainment -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MaterialContainment">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">contenção de material</rdfs:label>
        <rdfs:label xml:lang="en">material containment</rdfs:label>
        <skos:example xml:lang="pt-br">Armazenar petróleo cru em um tanque; amortecer líquido em um tambor de surto.</skos:example>
        <skos:example xml:lang="en">Holding crude in a storage tank; buffering liquid in a surge drum.</skos:example>
        <annotation:firstOrderLogicAxiom>MaterialContainment(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that maintains a contained material&apos;s state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação).</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Auxiliary category retained because all plant equipment must be classifiable; the input=output identity is the limiting characterisation, not a transformation.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Categoria auxiliar mantida porque todo equipamento de planta deve ser classificável; a identidade entrada=saída é a caracterização-limite, não uma transformação.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;material containment&apos; then x is a &apos;process&apos; that &apos;has input&apos; and &apos;has output&apos; the same &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;contenção de material&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; e &apos;tem saída&apos; a mesma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MeasurementInstrument -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MeasurementInstrument">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">instrumento de medição</rdfs:label>
        <rdfs:label xml:lang="en">measurement instrument</rdfs:label>
        <skos:example xml:lang="en">temperature/pressure/flow/level transmitter, composition analyzer</skos:example>
        <skos:example xml:lang="pt-br">transmissor de temperatura/pressão/vazão/nível, analisador de composição</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A; IEC 81346-2 code B.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">A medição distingue-se das categorias de transformação por produzir uma saída informacional em vez de material; reutiliza iof-constr:MeasurementProcess em vez de cunhar um processo COPI.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Measurement stands apart from the transformation categories in yielding an informational rather than a material output; it reuses iof-constr:MeasurementProcess instead of minting a COPI process.</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>MeasurementInstrument(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MeasurementProcess(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in an iof-constr:MeasurementProcess (a planned process yielding an information output).</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em um iof-constr:MeasurementProcess (um processo planejado que produz uma saída informacional).</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;measurement instrument&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;measurement process&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;instrumento de medição&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; algum &apos;processo de medição&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalPower -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalPower">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">mechanical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparation -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparation">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">mechanical separation</rdfs:label>
        <rdfs:label xml:lang="pt-br">separação mecânica</rdfs:label>
        <skos:example xml:lang="pt-br">Separação gravitacional trifásica; separação ciclônica; filtração; centrifugação.</skos:example>
        <skos:example xml:lang="en">Three-phase gravity separation; cyclonic separation; filtration; centrifugation.</skos:example>
        <annotation:firstOrderLogicAxiom>MechanicalSeparation(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a separação de uma alimentação heterogênea por força mecânica não é formalizada em OWL além do envelope.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the partition of a heterogeneous feed by mechanical force is not formalised in OWL beyond the envelope.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;mechanical separation&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;separação mecânica&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparationDevice -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparationDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparation"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MechanicalSeparation"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de separação mecânica</rdfs:label>
        <rdfs:label xml:lang="en">mechanical-separation device</rdfs:label>
        <skos:example xml:lang="pt-br">separador trifásico, ciclone, filtro, centrífuga</skos:example>
        <skos:example xml:lang="en">three-phase separator, cyclone, filter, centrifuge</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>MechanicalSeparationDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MechanicalSeparation(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a mechanical-separation operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de separação mecânica.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;mechanical-separation device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;mechanical separation&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de separação mecânica&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;separação mecânica&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MomentumTransfer -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransfer">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">momentum transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de quantidade de movimento</rdfs:label>
        <skos:example xml:lang="pt-br">Elevar a pressão de um líquido de processo; comprimir um gás; circular uma lama.</skos:example>
        <skos:example xml:lang="en">Raising the pressure of a process liquid; compressing a gas; circulating a slurry.</skos:example>
        <annotation:adaptedFrom>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering (fluid-flow operations).</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en">Includes pressure-raising operations on liquids and gases, and bulk transport/mixing. Its leaf operations LiquidPressureIncrease and GasPressureIncrease are disjoint.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Inclui operações de aumento de pressão de líquidos e gases, e transporte/mistura globais. Suas operações folha LiquidPressureIncrease e GasPressureIncrease são disjuntas.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>MomentumTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">A unit-operations class grounded in the McCabe-Smith-Harriott tradition; its members share a typed-participation envelope but no single formally necessary-and-sufficient differentia, so only the envelope is asserted in OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Uma classe de operações unitárias fundamentada na tradição de McCabe-Smith-Harriott; seus membros compartilham um envelope de participação tipada mas nenhuma diferença formal necessária-e-suficiente única, de modo que apenas o envelope é asserido em OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;momentum transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de quantidade de movimento&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/MomentumTransferDevice -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransferDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransfer"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransfer"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de quantidade de movimento</rdfs:label>
        <rdfs:label xml:lang="en">momentum-transfer device</rdfs:label>
        <skos:example xml:lang="pt-br">bomba, compressor, ventilador, tubo, misturador</skos:example>
        <skos:example xml:lang="en">pump, compressor, fan, pipe, mixer</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition (McCabe-Smith-Harriott); cross-checked against IEC 81346-2 codes G, M, W and ISO 14224 Annex A.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en">A dispersive (defined) category; a leaf declaring only its designed function is automatically classified here by the reasoner. Not asserted disjoint from the other equipment categories (selective partition).</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Uma categoria dispersiva (definida); uma folha que declara apenas sua função projetada é classificada aqui automaticamente pelo reasoner. Não asserida disjunta das demais categorias de equipamento (partição seletiva).</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>MomentumTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MomentumTransfer(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a momentum-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;momentum-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;momentum transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de quantidade de movimento&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de quantidade de movimento&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Operation -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Operation">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">operation</rdfs:label>
        <rdfs:label xml:lang="pt-br">operação</rdfs:label>
        <annotation:firstOrderLogicAxiom>Operation(x) → Process(x)</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that an item of process-industry equipment is designed to bring about or take part in.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Abstract superclass collecting the nine COPI operation categories; differentiated by its subclasses, not by a single formal condition.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Superclasse abstrata que reúne as nove categorias de operação do COPI; diferenciada por suas subclasses, não por uma única condição formal.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is an &apos;operation&apos; then x is a &apos;process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;operação&apos; então x é um &apos;processo&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PhaseChange -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhaseChange">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Operation"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">mudança de fase</rdfs:label>
        <rdfs:label xml:lang="en">phase change</rdfs:label>
        <skos:example xml:lang="en">Evaporation; condensation; crystallisation.</skos:example>
        <skos:example xml:lang="pt-br">Evaporação; condensação; cristalização.</skos:example>
        <annotation:firstOrderLogicAxiom>PhaseChange(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that changes the physical state (phase) of a material without changing its chemical identity.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a mudança de fase a identidade química constante é declarada para folhas (e.g. Vaporization) mas não no nível da categoria em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the change of phase at constant chemical identity is stated for leaves (e.g. Vaporization) but not at category level in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;phase change&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;mudança de fase&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PhaseChangeDevice -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PhaseChangeDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PhaseChange"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PhaseChange"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de mudança de fase</rdfs:label>
        <rdfs:label xml:lang="en">phase-change device</rdfs:label>
        <skos:example xml:lang="pt-br">evaporador, condensador, cristalizador</skos:example>
        <skos:example xml:lang="en">evaporator, condenser, crystalliser</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>PhaseChangeDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(PhaseChange(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a phase-change operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de mudança de fase.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;phase-change device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;phase change&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de mudança de fase&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;mudança de fase&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PortionOfFluid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PortionOfFluid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a fluid state (gaseous, liquid, or supercritical) that participates in an equipment-realizing process as input, output, or transformed substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PortionOfGas -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PortionOfGas">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PortionOfFluid"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PortionOfLiquid"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of gas</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in gaseous phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PortionOfLiquid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PortionOfLiquid">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PortionOfFluid"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of liquid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in liquid phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PortionOfSolid -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PortionOfSolid">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of solid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product).</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Pressure -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Pressure">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementAndTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementAndTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement and transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementResult -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementResult">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Pressure"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a pressure quality of some material entity or fluid.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PressureTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PressureTransmissionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementAndTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">process-controlled flow function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a ProcessControlledFlowProcess; the function of opening or shutting a flow path in response to an external process control signal.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ProcessControlledFlowProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControl"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">process-controlled flow process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Pump -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Pump">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MomentumTransferDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PumpingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Valve"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">bomba</rdfs:label>
        <rdfs:label xml:lang="en">pump</rdfs:label>
        <skos:example xml:lang="pt-br">bomba centrífuga, bomba de deslocamento positivo</skos:example>
        <skos:example xml:lang="en">centrifugal pump, positive-displacement pump</skos:example>
        <annotation:adaptedFrom>ISO 14224 Annex A (rotating equipment).</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">Inferida como MomentumTransferDevice apenas a partir de sua função, sem vínculo de subclasse asserido.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Inferred to be a MomentumTransferDevice from its function alone, with no asserted subclass link.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>Pump(x) → MaterialArtifact(x) ∧ ∃f(PumpingFunction(f) ∧ hasFunction(x,f))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact whose identity-giving designed function is to raise the pressure of an incompressible liquid.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material cuja função projetada identificadora é elevar a pressão de um líquido incompressível.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">An OWL-primitive leaf universal: its identity criterion (the borne designed function) is asserted as a necessary condition, not as an OWL definition.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Um universal folha OWL-primitivo: seu critério de identidade (a função projetada portada) é asserido como condição necessária, não como definição OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;pump&apos; then x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;pumping function&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;bomba&apos; então x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função de bombeamento&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/PumpingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/PumpingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LiquidPressureIncrease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/LiquidPressureIncrease"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de bombeamento</rdfs:label>
        <rdfs:label xml:lang="en">pumping function</rdfs:label>
        <annotation:explanatoryNote xml:lang="pt-br">A restrição &apos;algum&apos; é essencial: sem ela, uma função não realizada satisfaria vacuamente a restrição &apos;apenas&apos;, e a disjunção implicada entre PumpingFunction e CompressionFunction se perderia.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">The &apos;some&apos; restriction is essential: without it an unrealized function would vacuously satisfy the &apos;only&apos; restriction, and the entailed disjointness of PumpingFunction and CompressionFunction would be lost.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>PumpingFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ LiquidPressureIncrease(p)) ∧ ∀p(realizedIn(x,p) → LiquidPressureIncrease(p))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A função projetada de elevar a pressão de um líquido incompressível; realizada apenas em uma operação de aumento de pressão de líquido.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The designed function to raise the pressure of an incompressible liquid; realized only in a liquid-pressure-increase operation.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL fornece apenas condições necessárias (restrições de subclasse); o par algum+apenas mais a disjunção das operações folha implica -- mas não OWL-define -- a função.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions (subclass restrictions); the some+only pair plus the disjointness of the leaf operations entails -- but does not OWL-define -- the function.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;pumping function&apos; then x is a &apos;designed function&apos; that is &apos;realized in&apos; some &apos;liquid pressure increase&apos; and is &apos;realized in&apos; only &apos;liquid pressure increase&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;função de bombeamento&apos; então x é uma &apos;função projetada&apos; que é &apos;realizada em&apos; algum &apos;aumento de pressão de líquido&apos; e é &apos;realizada em&apos; apenas &apos;aumento de pressão de líquido&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RichAbsorbent -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RichAbsorbent">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AbsorbentPhase"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rich absorbent</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/RotationalSpeed -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/RotationalSpeed">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rotational speed</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating element that represents the number of complete revolutions per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SafetyReliefProcess">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControl"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Seat -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Seat">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">assento</rdfs:label>
        <rdfs:label xml:lang="en">seat</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A valve trim component that forms a sealing interface with the flow control element when the valve is closed.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Separator -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Separator">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">separator</rdfs:label>
        <annotation:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that separates a mixed-phase or multi-component stream into distinct streams or phases through mechanical means.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ShellAndTubeHeatExchanger -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ShellAndTubeHeatExchanger">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransferDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/HeatTransferFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">shell-and-tube heat exchanger</rdfs:label>
        <rdfs:label xml:lang="pt-br">trocador de calor casco-e-tubo</rdfs:label>
        <annotation:adaptedFrom>ISO 14224 Annex A (heat exchangers); TEMA.</annotation:adaptedFrom>
        <annotation:firstOrderLogicAxiom>ShellAndTubeHeatExchanger(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ hasFunction(x,f))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A heat-transfer material artifact in which one fluid flows through a bundle of tubes and another through the surrounding shell.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material de transferência de calor no qual um fluido escoa por um feixe de tubos e outro pelo casco circundante.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Folha OWL-primitiva: a função de transferência de calor portada é asserida como condição necessária; a construção tubo/casco é descritiva, não o critério de identidade.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL-primitive leaf: the borne heat-transfer function is asserted as a necessary condition; the tube/shell construction is descriptive, not the identity criterion.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;shell-and-tube heat exchanger&apos; then x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;heat-transfer function&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;trocador de calor casco-e-tubo&apos; então x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função de transferência de calor&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:synonym xml:lang="en">STHE</annotation:synonym>
        <annotation:synonym xml:lang="pt-br">trocador casco-tubo</annotation:synonym>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SightGlass -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SightGlass">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">sight glass</rdfs:label>
        <annotation:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact with a transparent section that permits direct visual observation of the fluid level, condition, or flow inside a vessel or pipeline.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionFunction">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/InstrumentationFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/SignalTransmissionProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Temperature -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Temperature">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a material entity that represents the intensity of thermal energy of that entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementResult -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureMeasurementResult">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Temperature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a temperature quality of some material entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de medição de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature-sensing function</rdfs:label>
        <annotation:firstOrderLogicAxiom>TemperatureSensingFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ MeasurementProcess(p)) ∧ ∀p(realizedIn(x,p) → MeasurementProcess(p))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A função projetada de determinar a temperatura de uma entidade de interesse; realizada apenas em um iof-constr:MeasurementProcess.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The designed function to determine the temperature of an entity of interest; realized only in an iof-constr:MeasurementProcess.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;temperature-sensing function&apos; then x is a &apos;designed function&apos; that is &apos;realized in&apos; some &apos;measurement process&apos; and is &apos;realized in&apos; only &apos;measurement process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;função de medição de temperatura&apos; então x é uma &apos;função projetada&apos; que é &apos;realizada em&apos; algum &apos;processo de medição&apos; e é &apos;realizada em&apos; apenas &apos;processo de medição&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensor -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensor">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/MeasurementInstrument"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TemperatureSensingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">sensor de temperatura</rdfs:label>
        <rdfs:label xml:lang="en">temperature sensor</rdfs:label>
        <annotation:adaptedFrom>ISO 14224 Annex A (instruments).</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">Inferido como MeasurementInstrument apenas a partir de sua função.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Inferred to be a MeasurementInstrument from its function alone.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>TemperatureSensor(x) → MaterialArtifact(x) ∧ ∃f(TemperatureSensingFunction(f) ∧ hasFunction(x,f))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A measurement artifact whose identity-giving designed function is to determine temperature.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato de medição cuja função projetada identificadora é determinar temperatura.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Folha OWL-primitiva: a função de medição de temperatura portada é a condição necessária asserida.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL-primitive leaf: the borne temperature-sensing function is the asserted necessary condition.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;temperature sensor&apos; then x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;temperature-sensing function&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;sensor de temperatura&apos; então x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função de medição de temperatura&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:synonym xml:lang="en">temperature transmitter</annotation:synonym>
        <annotation:synonym xml:lang="pt-br">transmissor de temperatura</annotation:synonym>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Transformer -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Transformer">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">transformer</rdfs:label>
        <annotation:explanatoryNote xml:lang="en">Scope note: Transformer enters from COPIeditor ODR-A1 as an electrical utility artifact. Its inclusion in a petroleum-plant boundary ontology requires review (ODR-015 phase 2).</annotation:explanatoryNote>
        <annotation:maturity rdf:resource="https://spec.industrialontologies.org/ontology/individual/Provisional"/>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that transfers electrical energy between circuits at different voltage or current levels through electromagnetic induction.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Valve -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Valve">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControlDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/FlowControlFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">valve</rdfs:label>
        <rdfs:label xml:lang="pt-br">válvula</rdfs:label>
        <skos:definition xml:lang="en">[CFIHOS] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;VALVE&gt; is a &lt;FLUID REGULATOR&gt; that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] Any of several valves: plug, gate, butterfly, needle, etc., used in oil field operations.</skos:definition>
        <skos:definition xml:lang="en">[POSC Caesar] A fluid regulator that can be used to control (i.e. permit, obstruct, regulate or divert) a fluid stream.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Valve(x) → MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A valve is a material artifact that bears a flow control function to permit, obstruct, regulate, or divert fluid streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma válvula é um artefato material que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Primitiva porque ser um artefato material com uma função de controle de fluxo é insuficiente para individuar totalmente uma válvula; o critério de identidade é portado por subtipos folha (ControlValve etc.). Axiomas de partes (ValveBody, Seat, FlowControlElement) são asseridos apenas em subtipos definicionais.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Primitive because being a material artifact with a flow control function is insufficient for full valve individuation; the identity criterion is carried by leaf subtypes (ControlValve etc.). Part axioms (ValveBody, Seat, FlowControlElement) are asserted only on definitional subtypes.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/ValveBody -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ValveBody">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">corpo de válvula</rdfs:label>
        <rdfs:label xml:lang="en">valve body</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">The main structural component of a valve that houses the internal trim and connects to the pipeline.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Vaporization -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Vaporization">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/PhaseChange"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">vaporization</rdfs:label>
        <rdfs:label xml:lang="pt-br">vaporização</rdfs:label>
        <annotation:firstOrderLogicDefinition>Vaporization(x) ↔ PhaseChange(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∃v(Vapour(v) ∧ hasOutput(x,v) ∧ derivesFrom(v,l))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A phase-change operation in which a liquid input is converted to a vapour output.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL 2 DL carrega apenas o gênero (PhaseChange); a derivação líquido-para-vapor é apenas-FOL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL 2 DL carries only the genus (PhaseChange); the liquid-to-vapour derivation is FOL-only.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;vaporization&apos; if and only if x is a &apos;phase change&apos; whose liquid input gives rise to a vapour output</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;vaporização&apos; se e somente se x é uma &apos;mudança de fase&apos; cuja entrada líquida dá origem a uma saída de vapor</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VaporizationFunction -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VaporizationFunction">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Vaporization"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Vaporization"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="pt-br">função de vaporização</rdfs:label>
        <rdfs:label xml:lang="en">vaporization function</rdfs:label>
        <annotation:firstOrderLogicAxiom>VaporizationFunction(x) → DesignedFunction(x) ∧ ∃p(realizedIn(x,p) ∧ Vaporization(p)) ∧ ∀p(realizedIn(x,p) → Vaporization(p))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A função projetada de converter um líquido em vapor; realizada apenas em uma operação de vaporização.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The designed function to convert a liquid into a vapour; realized only in a vaporization operation.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL fornece apenas condições necessárias; o par algum+apenas caracteriza a função para inferência.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;vaporization function&apos; then x is a &apos;designed function&apos; that is &apos;realized in&apos; some &apos;vaporization&apos; and is &apos;realized in&apos; only &apos;vaporization&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;função de vaporização&apos; então x é uma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;vaporização&apos; e é &apos;realizada em&apos; apenas &apos;vaporização&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/Vibration -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/Vibration">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">vibration</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/VisualIndication -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/VisualIndication">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">visual indication</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity perceptible through visual representation at the point of measurement or display.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


