                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SignalTransmissionProcess; the function of converting a sensed physical quantity into a standardized electrical or pneumatic signal for remote reading, recording, or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000031">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000030"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure transmission function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function specialized to pressure measurement and transmission; the function of converting a sensed pressure value into a proportional standardized signal for remote reading or control.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000032">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief function</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">An identity-giving designed function realized in a SafetyReliefProcess; the function of preventing over-pressure conditions by automatically relieving fluid at a pre-set pressure set-point, or of isolating wellbore flow when conditions are unsafe.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL gives only necessary conditions; the some+only pair characterises the function for inference.</annotation:primitiveRationale>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000033">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">process-controlled flow process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which flow through a conduit is opened, closed, or throttled in response to an external control signal from a process control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000034">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">safety relief process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A FlowControl process in which excess pressure is relieved by opening a flow path at a pre-set set-point, or in which wellbore flow is isolated to prevent blowout.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000035">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">signal transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which a sensed physical quantity is converted into a standardized signal and transmitted to a remote display, recorder, or control system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000036">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementProcess"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement and transmission process</rdfs:label>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A MeasurementProcess (hence planned) in which differential or gauge pressure is sensed, converted to a proportional standardized signal, and transmitted to a remote reading or control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a fluid state (gaseous, liquid, or supercritical) that participates in an equipment-realizing process as input, output, or transformed substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of liquid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in liquid phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000039">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of gas</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A portion of fluid in gaseous phase.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000040 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">portion of solid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A bounded portion of matter in a solid state that participates in an equipment-realizing process (filtered contaminants, particulate input, solid product).</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000038"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">absorbent phase</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A liquid phase whose function is to absorb target components from a gas stream by physical or chemical means.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000042 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000042">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000041"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rich absorbent</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An absorbent phase that has absorbed target components from a gas stream and is loaded for regeneration.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000043 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000043">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">depleted fluid</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid from which target components have been removed or transferred during a treatment process.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000044 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000044">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000037"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">fluid mixture</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A fluid portion consisting of two or more components or phases that have not yet been fully separated.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000045">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">control signal</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity that conveys an instruction or set-point to a control device.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000046">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/InformationContentEntity"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">visual indication</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">An information content entity perceptible through visual representation at the point of measurement or display.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000047">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a temperature quality of some material entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000048">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a pressure quality of some material entity or fluid.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000049">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a flow rate quality of a fluid stream.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000050 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000050">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing a liquid level quality of a vessel or container.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000051 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000051">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MeasurementInformationContentEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/describes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition measurement result</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">Measurement information content entity describing the chemical or phase composition quality of a substance.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">temperature</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a material entity that represents the intensity of thermal energy of that entity.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">pressure</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">flow rate</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">level</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">composition</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">vibration</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">electrical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in an electrical system that represents the rate of electrical energy transfer.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000059 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000059">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">mechanical power</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000019"/>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-vocab"/>
        <rdfs:label xml:lang="en">rotational speed</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A quality inhering in a rotating element that represents the number of complete revolutions per unit time.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066 -->

