                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical connection process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de conexão elétrica</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


