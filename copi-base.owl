        <rdfs:label xml:lang="en">structural support function</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A DesignedFunction that is realized in a StructuralSupportProcess and that consists in providing mechanical support, load distribution, or structural integrity within an engineered system through a flat, planar configuration.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/StructuralSupportProcess -->

