                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>ODR-011</dcterms:source>
        <dcterms:source>ODR-012</dcterms:source>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de mudança de fase</rdfs:label>
        <rdfs:label xml:lang="en">phase-change device</rdfs:label>
        <skos:example xml:lang="pt-br">evaporador, condensador, cristalizador</skos:example>
        <skos:example xml:lang="en">evaporator, condenser, crystalliser</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>PhaseChangeDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(PhaseChange(p) ∧ realizedIn(f,p)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a phase-change operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de mudança de fase.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;phase-change device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;phase change&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de mudança de fase&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;mudança de fase&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000022">
