        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/OutletConnection"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/TreatingVessel"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DehydrationFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">dehydrator</rdfs:label>
        <rdfs:label xml:lang="pt-br">desidratador</rdfs:label>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEHYDRATOR&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEHYDRATING&gt;</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A treating vessel designed to remove water from a process stream.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A device used to remove water and water vapors from gas.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every dehydrator is a separator that has the function of dehydration.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000244 -->

