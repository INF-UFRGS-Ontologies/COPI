    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <dcterms:source>ODR-009 Amendment A (2026-06-18): copi:Operation as explicit root universal; genus correction to iof-constr:PlannedProcess</dcterms:source>
        <rdfs:comment xml:lang="en">A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">operation</rdfs:label>
        <rdfs:label xml:lang="pt-br">operação</rdfs:label>
        <annotation:firstOrderLogicAxiom>∀x (Operation(x) → PlannedProcess(x))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Root universal for process-industry unit operations in the chemical-engineering tradition (cf. each category&apos;s adaptedFrom). Members share a typed participation signature (material inputs/outputs) and differ by transformation effected; no single formal condition differentiates Operation from PlannedProcess in OWL — the differentia is OWL-inexpressible, standard for a BFO primitive. (ODR-009 Amendment A, 2026-06-18)</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Universal raiz para operações unitárias de indústria de processo na tradição da engenharia química (cf. adaptedFrom de cada categoria). Os membros compartilham uma assinatura de participação tipada (entradas/saídas materiais) e diferem pela transformação efetuada; nenhuma condição formal única diferencia Operation de PlannedProcess em OWL — a diferença é inexpressível em OWL, padrão para um primitivo BFO. (ODR-009 Emenda A, 2026-06-18)</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is an &apos;operation&apos; then x is a &apos;planned process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;operação&apos; então x é um &apos;processo planejado&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>Bird, Stewart &amp; Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part I: momentum transport.</dcterms:source>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">momentum transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de quantidade de movimento</rdfs:label>
        <skos:example xml:lang="pt-br">Elevar a pressão de um líquido de processo; comprimir um gás; circular uma lama.</skos:example>
        <skos:example xml:lang="en">Raising the pressure of a process liquid; compressing a gas; circulating a slurry.</skos:example>
        <annotation:adaptedFrom>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering (fluid-flow operations).</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en">Includes pressure-raising operations on liquids and gases, and bulk transport/mixing. Its leaf operations LiquidPressureIncrease and GasPressureIncrease are disjoint.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Inclui operações de aumento de pressão de líquidos e gases, e transporte/mistura globais. Suas operações folha LiquidPressureIncrease e GasPressureIncrease são disjuntas.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>∀x (MomentumTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">A unit-operations class grounded in the McCabe-Smith-Harriott tradition; its members share a typed-participation envelope but no single formally necessary-and-sufficient differentia, so only the envelope is asserted in OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Uma classe de operações unitárias fundamentada na tradição de McCabe-Smith-Harriott; seus membros compartilham um envelope de participação tipada mas nenhuma diferença formal necessária-e-suficiente única, de modo que apenas o envelope é asserido em OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;momentum transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de quantidade de movimento&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>Bird, Stewart &amp; Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part II: energy transport.</dcterms:source>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">heat transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de calor</rdfs:label>
        <skos:example xml:lang="pt-br">Aquecimento sensível de uma corrente de processo contra uma utilidade quente.</skos:example>
        <skos:example xml:lang="en">Sensible heating of a process stream against a hot utility.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (HeatTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a constância de fase e de identidade química que distingue a transferência de calor sensível não é capturada em OWL, de modo que apenas o envelope é asserido.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the constancy of phase and chemical identity that distinguishes sensible heat transfer is not captured in OWL, so only the envelope is asserted.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;heat transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de calor&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>Bird, Stewart &amp; Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part III: mass transport.</dcterms:source>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">mass transfer</rdfs:label>
        <rdfs:label xml:lang="pt-br">transferência de massa</rdfs:label>
        <skos:example xml:lang="en">Absorption of a gas component into a liquid solvent; stripping; distillation.</skos:example>
        <skos:example xml:lang="pt-br">Absorção de um componente gasoso em um solvente líquido; esgotamento (stripping); destilação.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (MassTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico).</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a migração interfásica que individua seus membros é declarada para folhas específicas (e.g. GasAbsorption) mas não no nível da categoria em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the inter-phase migration that individuates its members is stated for specific leaves (e.g. GasAbsorption) but not at the category level in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;mass transfer&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;transferência de massa&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">mechanical separation</rdfs:label>
        <rdfs:label xml:lang="pt-br">separação mecânica</rdfs:label>
        <skos:example xml:lang="pt-br">Separação gravitacional trifásica; separação ciclônica; filtração; centrifugação.</skos:example>
        <skos:example xml:lang="en">Three-phase gravity separation; cyclonic separation; filtration; centrifugation.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (MechanicalSeparation(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a separação de uma alimentação heterogênea por força mecânica não é formalizada em OWL além do envelope.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the partition of a heterogeneous feed by mechanical force is not formalised in OWL beyond the envelope.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;mechanical separation&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;separação mecânica&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000007 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000007">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process in which chemical species are consumed and new species, present in no input, are formed.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">chemical reaction</rdfs:label>
        <rdfs:label xml:lang="pt-br">reação química</rdfs:label>
        <skos:example xml:lang="en">Fermentation of sugars to ethanol; combustion; catalytic conversion.</skos:example>
        <skos:example xml:lang="pt-br">Fermentação de açúcares a etanol; combustão; conversão catalítica.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (ChemicalReaction(x) → Process(x) ∧ ∃o,c(hasOutput(x,o) ∧ hasConstituent(o,c) ∧ ¬∃i,c1(hasInput(x,i) ∧ hasConstituent(i,c1) ∧ sameSubstance(c1,c))))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which chemical species are consumed and new species, present in no input, are formed.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de processo unitário; a formação de uma espécie genuinamente nova é parcialmente caracterizada em FOL mas apenas o gênero é asserido em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-process class; the formation of a genuinely new species is partly characterised in FOL but only the genus is asserted in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;chemical reaction&apos; then x is a &apos;process&apos; whose output has a constituent substance that no input has</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;reação química&apos; então x é um &apos;processo&apos; cuja saída tem uma substância constituinte que nenhuma entrada possui</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process that changes the physical state (phase) of a material without changing its chemical identity.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">mudança de fase</rdfs:label>
        <rdfs:label xml:lang="en">phase change</rdfs:label>
        <skos:example xml:lang="en">Evaporation; condensation; crystallisation.</skos:example>
        <skos:example xml:lang="pt-br">Evaporação; condensação; cristalização.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (PhaseChange(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that changes the physical state (phase) of a material without changing its chemical identity.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">Classe de operações unitárias; a mudança de fase a identidade química constante é declarada para folhas (e.g. Vaporization) mas não no nível da categoria em OWL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">Unit-operations class; the change of phase at constant chemical identity is stated for leaves (e.g. Vaporization) but not at category level in OWL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;phase change&apos; then x is a &apos;process&apos; that &apos;has input&apos; some &apos;material entity&apos; and &apos;has output&apos; some &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;mudança de fase&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; alguma &apos;entidade material&apos; e &apos;tem saída&apos; alguma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process that maintains a contained material&apos;s state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">contenção de material</rdfs:label>
        <rdfs:label xml:lang="en">material containment</rdfs:label>
        <skos:example xml:lang="pt-br">Armazenar petróleo cru em um tanque; amortecer líquido em um tambor de surto.</skos:example>
        <skos:example xml:lang="en">Holding crude in a storage tank; buffering liquid in a surge drum.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (MaterialContainment(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that maintains a contained material&apos;s state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação).</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Auxiliary category retained because all plant equipment must be classifiable; the input=output identity is the limiting characterisation, not a transformation.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Categoria auxiliar mantida porque todo equipamento de planta deve ser classificável; a identidade entrada=saída é a caracterização-limite, não uma transformação.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;material containment&apos; then x is a &apos;process&apos; that &apos;has input&apos; and &apos;has output&apos; the same &apos;material entity&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;contenção de material&apos; então x é um &apos;processo&apos; que &apos;tem entrada&apos; e &apos;tem saída&apos; a mesma &apos;entidade material&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001"/>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process that modulates a flow without changing the material&apos;s substance, phase, or composition.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">controle de fluxo</rdfs:label>
        <rdfs:label xml:lang="en">flow control</rdfs:label>
        <skos:example xml:lang="pt-br">Estrangular uma corrente por uma válvula de controle; isolar por uma válvula de bloqueio; aliviar sobrepressão.</skos:example>
        <skos:example xml:lang="en">Throttling a stream through a control valve; isolating via a shutoff valve; relieving overpressure.</skos:example>
        <annotation:firstOrderLogicAxiom>∀x (FlowControl(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process that modulates a flow without changing the material&apos;s substance, phase, or composition.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Auxiliary category; the conservation of substance/phase/composition under modulation is the characterisation and is not a material transformation.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Categoria auxiliar; a conservação de substância/fase/composição sob modulação é a caracterização e não é uma transformação material.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;flow control&apos; then x is a &apos;process&apos; that conserves the substance, phase and composition of its material participant</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é um &apos;controle de fluxo&apos; então x é um &apos;processo&apos; que conserva a substância, a fase e a composição de seu participante material</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000011 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000011">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
        <owl:disjointWith rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012"/>
        <dcterms:source>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, pumping).</dcterms:source>
        <dcterms:source>ODR-011</dcterms:source>
        <rdfs:comment xml:lang="en">A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid&apos;s pressure.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">aumento de pressão de líquido</rdfs:label>
        <rdfs:label xml:lang="en">liquid pressure increase</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfLiquid"/>
        <annotation:firstOrderLogicDefinition>∀x (LiquidPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Liquid(m)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid&apos;s pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">OWL 2 DL cannot express the phase constraint on the fluid input; the OWL form asserts only the genus (MomentumTransfer). The disjointness with GasPressureIncrease is asserted to carry the pump/compressor partition.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">OWL 2 DL não consegue expressar a restrição de fase sobre a entrada fluida; a forma OWL assere apenas o gênero (MomentumTransfer). A disjunção com GasPressureIncrease é asserida para sustentar a partição bomba/compressor.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;liquid pressure increase&apos; if and only if x is a &apos;momentum transfer&apos; whose fluid input is a &apos;liquid&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;aumento de pressão de líquido&apos; se e somente se x é uma &apos;transferência de quantidade de movimento&apos; cuja entrada fluida é um &apos;líquido&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
        <dcterms:source>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, compression).</dcterms:source>
        <dcterms:source>ODR-011</dcterms:source>
        <rdfs:comment xml:lang="en">A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas&apos;s pressure.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">aumento de pressão de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas pressure increase</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfGas"/>
        <annotation:firstOrderLogicDefinition>∀x (GasPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃g(Gas(g) ∧ hasInput(x,g)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Gas(m)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas&apos;s pressure.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">As for LiquidPressureIncrease: the phase constraint is not expressible in OWL 2 DL; only the genus is asserted.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Como em LiquidPressureIncrease: a restrição de fase não é expressável em OWL 2 DL; apenas o gênero é asserido.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;gas pressure increase&apos; if and only if x is a &apos;momentum transfer&apos; whose fluid input is a &apos;gas&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;aumento de pressão de gás&apos; se e somente se x é uma &apos;transferência de quantidade de movimento&apos; cuja entrada fluida é um &apos;gás&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000013 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000013">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005"/>
        <dcterms:source>Green &amp; Southard (eds.), Perry&apos;s Chemical Engineers&apos; Handbook, 9th ed. §14 (absorption and stripping).</dcterms:source>
        <dcterms:source>ODR-011</dcterms:source>
        <rdfs:comment xml:lang="en">A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">absorção de gás</rdfs:label>
        <rdfs:label xml:lang="en">gas absorption</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Absorption"/>
        <annotation:adaptedFrom>Treybal, Mass-Transfer Operations.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀p (GasAbsorption(p) ↔ MassTransfer(p) ∧ ∃g,l,l2,c(hasInput(p,g) ∧ Gas(g) ∧ hasInput(p,l) ∧ Liquid(l) ∧ hasOutput(p,l2) ∧ Liquid(l2) ∧ derivesFrom(l2,l) ∧ hasConstituent(g,c) ∧ ¬∃c1(hasConstituent(l,c1) ∧ sameSubstance(c1,c)) ∧ ∃c2(hasConstituent(l2,c2) ∧ sameSubstance(c2,c))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Although a full first-order definition is available, OWL 2 DL carries only the typed-participation envelope; the relational differentia (a constituent migrating gas-&gt;liquid) is FOL-only.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o envelope de participação tipada; a diferença relacional (um constituinte migrando gás-&gt;líquido) é apenas-FOL.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;gas absorption&apos; if and only if x is a &apos;mass transfer&apos; in which a substance carried by the input gas, absent from the input solvent, is a constituent of the output liquid</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;absorção de gás&apos; se e somente se x é uma &apos;transferência de massa&apos; na qual uma substância transportada pelo gás de entrada, ausente do solvente de entrada, é constituinte do líquido de saída</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000014 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000014">
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008"/>
        <dcterms:source>McCabe, Smith &amp; Harriott, Unit Operations of Chemical Engineering, 8th ed. §16 (evaporation).</dcterms:source>
        <dcterms:source>ODR-011</dcterms:source>
        <rdfs:comment xml:lang="en">A phase-change operation in which a liquid input is converted to a vapour output.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">vaporization</rdfs:label>
        <rdfs:label xml:lang="pt-br">vaporização</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Vaporization"/>
        <annotation:firstOrderLogicDefinition>∀x (Vaporization(x) ↔ PhaseChange(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∃v(Vapour(v) ∧ hasOutput(x,v) ∧ derivesFrom(v,l)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A phase-change operation in which a liquid input is converted to a vapour output.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="pt-br">OWL 2 DL carrega apenas o gênero (PhaseChange); a derivação líquido-para-vapor é apenas-FOL.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="en">OWL 2 DL carries only the genus (PhaseChange); the liquid-to-vapour derivation is FOL-only.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;vaporization&apos; if and only if x is a &apos;phase change&apos; whose liquid input gives rise to a vapour output</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é uma &apos;vaporização&apos; se e somente se x é uma &apos;mudança de fase&apos; cuja entrada líquida dá origem a uma saída de vapor</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000015 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <dcterms:source>ODR-009</dcterms:source>
        <rdfs:comment xml:lang="en">A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">loss of containment</rdfs:label>
        <rdfs:label xml:lang="pt-br">perda de contenção</rdfs:label>
        <annotation:explanatoryNote xml:lang="en">Relevant to HAZOP and failure-propagation work built over COPI.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Relevante para trabalhos de HAZOP e propagação de falhas construídos sobre o COPI.</annotation:explanatoryNote>
        <annotation:firstOrderLogicAxiom>∀x (LossOfContainment(x) → Process(x) ∧ ¬PlannedProcess(x))</annotation:firstOrderLogicAxiom>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess.</annotation:naturalLanguageDefinition>
        <annotation:primitiveRationale xml:lang="en">Included to make the bfo:Process rooting concrete: the same boundary-failure kind is failure-relevant (ISO 14224) and cannot be a PlannedProcess; a planned-only hierarchy would exclude it.</annotation:primitiveRationale>
        <annotation:primitiveRationale xml:lang="pt-br">Incluída para tornar concreta a ancoragem em bfo:Process: o mesmo tipo de falha de barreira é relevante para falhas (ISO 14224) e não pode ser um PlannedProcess; uma hierarquia só-planejada o excluiria.</annotation:primitiveRationale>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">if x is a &apos;loss of containment&apos; then x is a &apos;process&apos; and x is not a &apos;planned process&apos;</annotation:semiFormalNaturalLanguageAxiom>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="pt-br">se x é uma &apos;perda de contenção&apos; então x é um &apos;processo&apos; e x não é um &apos;processo planejado&apos;</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000016 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000016">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>ODR-011</dcterms:source>
        <dcterms:source>ODR-012</dcterms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a momentum-transfer operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de quantidade de movimento</rdfs:label>
        <rdfs:label xml:lang="en">momentum-transfer device</rdfs:label>
        <skos:example xml:lang="pt-br">bomba, compressor, ventilador, tubo, misturador</skos:example>
        <skos:example xml:lang="en">pump, compressor, fan, pipe, mixer</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition (McCabe-Smith-Harriott); cross-checked against IEC 81346-2 codes G, M, W and ISO 14224 Annex A.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="en">A dispersive (defined) category; a leaf declaring only its designed function is automatically classified here by the reasoner. Not asserted disjoint from the other equipment categories (selective partition).</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="pt-br">Uma categoria dispersiva (definida); uma folha que declara apenas sua função projetada é classificada aqui automaticamente pelo reasoner. Não asserida disjunta das demais categorias de equipamento (partição seletiva).</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>∀x (MomentumTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MomentumTransfer(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a momentum-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;momentum-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;momentum transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de quantidade de movimento&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de quantidade de movimento&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>ODR-011</dcterms:source>
        <dcterms:source>ODR-012</dcterms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a heat-transfer operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de calor</rdfs:label>
        <rdfs:label xml:lang="en">heat-transfer device</rdfs:label>
        <skos:example xml:lang="en">shell-and-tube exchanger, fired heater, reboiler</skos:example>
        <skos:example xml:lang="pt-br">trocador casco-e-tubo, aquecedor a fogo direto, refervedor</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 codes E, V.</annotation:adaptedFrom>
        <annotation:explanatoryNote xml:lang="pt-br">Categoria definida; um artefato que porta uma função secundária (e.g. um refervedor que também vaporiza) adquire pertinências adicionais de categoria -- intencional, não um defeito.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Defined category; an artifact bearing a secondary function (e.g. a reboiler that also vaporizes) acquires additional category memberships -- intended, not a defect.</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition>∀x (HeatTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(HeatTransfer(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a heat-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x is a &apos;heat-transfer device&apos; if and only if x is a &apos;material artifact&apos; that &apos;has function&apos; some &apos;designed function&apos; that is &apos;realized in&apos; some &apos;heat transfer&apos;</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x é um &apos;dispositivo de transferência de calor&apos; se e somente se x é um &apos;artefato material&apos; que &apos;tem função&apos; alguma &apos;função projetada&apos; que é &apos;realizada em&apos; alguma &apos;transferência de calor&apos;</annotation:semiFormalNaturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000018 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000018">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:intersectionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
                            <owl:Restriction>
                                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005"/>
                            </owl:Restriction>
                        </owl:intersectionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <dcterms:source>ODR-011</dcterms:source>
        <dcterms:source>ODR-012</dcterms:source>
        <rdfs:comment xml:lang="en">A material artifact that bears a designed function realized in a mass-transfer operation.</rdfs:comment>
        <rdfs:comment xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="pt-br">dispositivo de transferência de massa</rdfs:label>
        <rdfs:label xml:lang="en">mass-transfer device</rdfs:label>
        <skos:example xml:lang="en">absorber, stripper, distillation column, adsorber</skos:example>
        <skos:example xml:lang="pt-br">absorvedor, esgotador, coluna de destilação, adsorvedor</skos:example>
        <annotation:adaptedFrom>Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V.</annotation:adaptedFrom>
        <annotation:firstOrderLogicDefinition>∀x (MassTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MassTransfer(p) ∧ realizedIn(f,p))))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="en">A material artifact that bears a designed function realized in a mass-transfer operation.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa.</annotation:naturalLanguageDefinition>
