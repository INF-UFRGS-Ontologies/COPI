    <!-- https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/PlannedProcess"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasInput"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AlternatingCurrentPortion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasInput"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AlternatingElectricalCurrent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
