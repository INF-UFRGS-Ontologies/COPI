                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AlternatingCurrentPortion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/AlternatingElectricalCurrent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">electrical power transformation process</rdfs:label>
        <rdfs:label xml:lang="pt-br">processo de transformação de energia elétrica</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


