    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000002 -->

    <owl:ObjectProperty rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000002">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000056"/>
        <rdfs:domain rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:range rdf:resource="http://purl.obolibrary.org/obo/BFO_0000015"/>
        <dcterms:source>ODR-011 §4</dcterms:source>
        <rdfs:comment xml:lang="pt-br">A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ∘ obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas funções projetadas.</rdfs:comment>
        <rdfs:comment xml:lang="en">The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ∘ obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-core"/>
        <rdfs:label xml:lang="en">functionally participates in</rdfs:label>
        <rdfs:label xml:lang="pt-br">participa funcionalmente em</rdfs:label>
        <annotation:explanatoryNote xml:lang="pt-br">Distingue a participação mediada por função da participação geral: obo:BFO_0000056 (participa em) vale sempre que um continuante toma parte em algum processo por qualquer razão; copi:participatesIn é entailada apenas pela cadeia hasFunction ∘ BFO_0000054 (tem realização). Uma bomba participa funcionalmente em toda operação de aumento de pressão de líquido que realiza sua função de bombeamento; BFO_0000056 vale adicionalmente para qualquer outro envolvimento.</annotation:explanatoryNote>
        <annotation:explanatoryNote xml:lang="en">Distinguishes function-mediated from general participation: obo:BFO_0000056 (participates in) holds whenever a continuant takes part in any process for any reason; copi:participatesIn is entailed only via the chain hasFunction ∘ BFO_0000054 (has realization). A pump functionally participates in every liquid-pressure-increase operation that realizes its pumping function; BFO_0000056 additionally covers any other process involvement.</annotation:explanatoryNote>
        <annotation:firstOrderLogicDefinition xml:lang="en">∀x∀y (functionallyParticipatesIn(x,y) ↔ ∃f(hasFunction(x,f) ∧ hasRealization(f,y)))</annotation:firstOrderLogicDefinition>
        <annotation:isPrimitive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</annotation:isPrimitive>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ∘ obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas funções projetadas.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="en">The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ∘ obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="en">x &apos;functionally participates in&apos; y if and only if there exists a function f such that x &apos;has function&apos; f and f &apos;has realization&apos; y</annotation:semiFormalNaturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageDefinition xml:lang="pt-br">x &apos;participa funcionalmente em&apos; y se e somente se existe uma função f tal que x &apos;tem função&apos; f e f &apos;tem realização&apos; y</annotation:semiFormalNaturalLanguageDefinition>
    </owl:ObjectProperty>
    


