                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingElement"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DropletCollectionSurface"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/MaterialArtifact"/>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingElement"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DropletCollectionSurface"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DemistingFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">demister</rdfs:label>
        <rdfs:label xml:lang="pt-br">demister</rdfs:label>
        <skos:definition xml:lang="en">[CFIHOS] A physical object intended to catch fluid droplets.</skos:definition>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DEMISTER&gt; is a &lt;FunctionalObject&gt; that is capable of &lt;DEMISTING&gt;</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Demister(x) ↔ Separator(x) ∧ ∃f(DemistingFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um demister é um separador que possui uma função de desmistificação para remover gotículas de líquido de correntes gasosas através de mecanismos de coalescência.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every demister is a separator that has the function of demisting gas streams by coalescing and removing entrained liquid droplets.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DisplayOrOutputDevice"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Sensor"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                        <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DisplayOrOutputDevice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/Sensor"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://spec.industrialontologies.org/ontology/construct/hasFunction"/>
                <owl:someValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/DensityMeasurementFunction"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="en">densitometer</rdfs:label>
        <rdfs:label xml:lang="pt-br">densitômetro</rdfs:label>
        <skos:definition xml:lang="en">[ISO 15926-4] A &lt;DENSITOMETER&gt; is an &lt;INSTRUMENTATION ITEM&gt; and a &lt;MEASURING INSTRUMENT&gt; that measures the degree of darkness in photographic or semitransparent material. The densitometer is basically a light source aimed at a photoelectric cell which determines the density of the sample from differences in the readings</skos:definition>
        <skos:definition xml:lang="en">[OnePetro] A device used for reading the density of a flowing fluid or slurry.</skos:definition>
        <skos:definition xml:lang="en">[SLB Glossary] A device installed on a mixing or pumping system manifold to measure the density of fluids.</skos:definition>
        <annotation:firstOrderLogicAxiom xml:lang="en">∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))</annotation:firstOrderLogicAxiom>
        <annotation:naturalLanguageDefinition xml:lang="en">A densitometer is an instrument that bears a density measurement function.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Um densitômetro é um instrumento que possui uma função de medição de densidade.</annotation:naturalLanguageDefinition>
        <annotation:semiFormalNaturalLanguageAxiom xml:lang="en">Every densitometer is an instrument that has the function of measuring density.</annotation:semiFormalNaturalLanguageAxiom>
    </owl:Class>
    


