        <rdfs:label xml:lang="en">structural support process</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A PlannedProcess in which a structural element bears loads, distributes forces, or maintains structural integrity within a system, typically through its geometric configuration and material properties.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


