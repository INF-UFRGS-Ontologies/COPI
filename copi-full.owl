        <annotation:usageNote>Used for formal title of an artifact (but not individual elements such as classes or properties).</annotation:usageNote>
    </owl:AnnotationProperty>
    


    <!-- http://purl.org/ontology/bibo/status -->

    <owl:AnnotationProperty rdf:about="http://purl.org/ontology/bibo/status"/>
    


