                <owl:allValuesFrom rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000013"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:isDefinedBy rdf:resource="https://www.inf.ufrgs.br/ontologies/copi/copi-enriched"/>
        <rdfs:label xml:lang="en">gas absorption function</rdfs:label>
        <annotation:naturalLanguageDefinition xml:lang="en">A designed function that is realized in a gas absorption process.</annotation:naturalLanguageDefinition>
        <annotation:naturalLanguageDefinition xml:lang="pt-br">Uma função projetada que é realizada em um processo de absorção de gás.</annotation:naturalLanguageDefinition>
    </owl:Class>
    


    <!-- https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070 -->

    <owl:Class rdf:about="https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070">
        <rdfs:subClassOf rdf:resource="https://spec.industrialontologies.org/ontology/construct/DesignedFunction"/>
