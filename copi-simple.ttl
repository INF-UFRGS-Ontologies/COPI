###  https://www.inf.ufrgs.br/ontologies/copi/DeaerationProcess
copi:DeaerationProcess rdf:type owl:Class ;
                       rdfs:label "deaeration process"@en ,
                                  "processo de desaeração"@pt-br ;
                       skos:definition "A planned process in which dissolved oxygen and other non-condensable gases are removed from a liquid stream in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/DegassingFunction
copi:DegassingFunction rdf:type owl:Class ;
                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:someValuesFrom copi:DegassingProcess
                                       ] ,
                                       [ rdf:type owl:Restriction ;
