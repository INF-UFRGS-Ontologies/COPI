copi:PressureTransmissionProcess rdf:type owl:Class ;
                                 rdfs:label "pressure transmission process"@en ,
                                            "processo de transmissão de pressão"@pt-br ;
                                 skos:definition "A planned process in which a standardised signal representing a measured pressure value is transmitted to a remote control or monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressurizedFluidPortion
copi:PressurizedFluidPortion rdf:type owl:Class ;
                             rdfs:label "porção pressurizado de fluido"@pt-br ,
                                        "pressurized fluid portion"@en ;
                             skos:definition "A material artifact that constitutes a portion of fluid held at a pressure above the reference pressure in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidPortion
copi:ProcessFluidPortion rdf:type owl:Class ;
                         rdfs:label "porção de processo de fluido"@pt-br ,
                                    "process fluid portion"@en ;
                         skos:definition "A material artifact that constitutes a portion of the process fluid—hydrocarbon, water, or gas—handled at a defined point in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ProcessFluidSample
copi:ProcessFluidSample rdf:type owl:Class ;
                        rdfs:label "amostra de processo de fluido"@pt-br ,
                                   "process fluid sample"@en ;
                        skos:definition "An information content entity constituting a representative sample of process fluid withdrawn from a petroleum production stream for analysis or testing."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ProcessVariable
copi:ProcessVariable rdf:type owl:Class ;
                     rdfs:label "process variable"@en ,
                                "variável de processo"@pt-br ;
                     skos:definition "An information content entity constituting a measurable variable—pressure, temperature, flow rate, or level—that characterises the state of a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ProtectedTemperatureSensingElement
copi:ProtectedTemperatureSensingElement rdf:type owl:Class ;
                                        rdfs:label "elemento protegido de temperatura de sensoriamento"@pt-br ,
                                                   "protected temperature sensing element"@en ;
                                        skos:definition "A material artifact that constitutes a temperature sensing element installed within a thermowell or protective sheath to isolate it from the process medium while remaining thermally coupled."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PumpChamber
copi:PumpChamber rdf:type owl:Class ;
                 rdfs:label "câmara de bomba"@pt-br ,
                            "pump chamber"@en ;
                 skos:definition "A material artifact that constitutes the enclosed space within a pump casing in which fluid is pressurised by the impeller or piston."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PumpingProcess
copi:PumpingProcess rdf:type owl:Class ;
                    rdfs:label "processo de bombeamento"@pt-br ,
                               "pumping process"@en ;
                    skos:definition "A planned process in which mechanical energy is imparted to a fluid to increase its pressure, velocity, or elevation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/RaisedEdge
copi:RaisedEdge rdf:type owl:Class ;
                rdfs:label "borda saliente"@pt-br ,
                           "raised edge"@en ;
                skos:definition "A material artifact that constitutes a raised rim or flange on a component of petroleum production equipment that provides a sealing surface or structural boundary."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/RapidDepressurizationProcess
copi:RapidDepressurizationProcess rdf:type owl:Class ;
                                  rdfs:label "processo de despressurização rápida"@pt-br ,
                                             "rapid depressurization process"@en ;
                                  skos:definition "A planned process in which pressure within a process system is discharged at an accelerated rate to a safe destination in an emergency."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingFunction
copi:ReactiveHeatingFunction rdf:type owl:Class ;
                             rdfs:subClassOf copi:COPI_0000190 ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                               owl:someValuesFrom copi:ReactiveHeatingProcess
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                               owl:allValuesFrom copi:ReactiveHeatingProcess
                                             ] ;
                             rdfs:label "função de aquecimento reativo"@pt-br ,
                                        "reactive heating function"@en ;
                             skos:definition "A heating function borne by petroleum production equipment whose realization constitutes the generation and transfer of thermal energy through an exothermic chemical reaction."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ReactiveHeatingProcess
copi:ReactiveHeatingProcess rdf:type owl:Class ;
                            rdfs:subClassOf copi:HeatingProcess ;
                            rdfs:label "processo de aquecimento reativo"@pt-br ,
                                       "reactive heating process"@en ;
                            skos:definition "A heating process in which thermal energy is generated by a chemical reaction and transferred to the process, such as in a reactor or fired heater."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ReboilingFunction
copi:ReboilingFunction rdf:type owl:Class ;
                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:someValuesFrom copi:ReboilingProcess
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:allValuesFrom copi:ReboilingProcess
                                       ] ;
                       rdfs:label "função de refervimento"@pt-br ,
                                  "reboiling function"@en ;
                       skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the partial vaporisation of liquid at the base of a distillation column by supplying heat to drive vapour upward through the column."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ReboilingProcess
copi:ReboilingProcess rdf:type owl:Class ;
                      rdfs:label "processo de refervimento"@pt-br ,
                                 "reboiling process"@en ;
                      skos:definition "A planned process in which liquid at the base of a distillation column is partially vaporised by the supply of heat to drive vapour upward through the column."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ReferenceSignal
copi:ReferenceSignal rdf:type owl:Class ;
                     rdfs:label "reference signal"@en ,
                                "sinal de referência"@pt-br ;
                     skos:definition "An information content entity constituting a signal representing a reference value—such as a set point or calibration standard—used in control or measurement systems of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/RemovedMaterial
copi:RemovedMaterial rdf:type owl:Class ;
                     rdfs:label "material de removido"@pt-br ,
                                "removed material"@en ;
