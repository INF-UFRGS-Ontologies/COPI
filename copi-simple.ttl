                                                   owl:someValuesFrom copi:PressureContainmentProcess
                                                 ] ,
                                                 [ rdf:type owl:Restriction ;
                                                   owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                   owl:allValuesFrom copi:PressureContainmentProcess
                                                 ] ;
                                 rdfs:label "função de contenção de pressão"@pt-br ,
                                            "pressure containment function"@en ;
                                 skos:definition "A containment function borne by petroleum production equipment whose realization constitutes the retention of fluid within a defined pressure boundary to prevent uncontrolled release."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureContainmentProcess
copi:PressureContainmentProcess rdf:type owl:Class ;
                                rdfs:label "pressure containment process"@en ,
                                           "processo de contenção de pressão"@pt-br ;
                                skos:definition "A planned process in which a fluid is held within a defined pressure boundary to prevent uncontrolled release to the environment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureField
copi:PressureField rdf:type owl:Class ;
                   rdfs:label "campo de pressão"@pt-br ,
                              "pressure field"@en ;
                   skos:definition "A quality inhering in a material entity, constituting the pressure distribution within a fluid volume in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionFunction
copi:PressureIndicatingAndTransmissionFunction rdf:type owl:Class ;
                                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                                 owl:someValuesFrom copi:PressureIndicatingAndTransmissionProcess
                                                               ] ,
