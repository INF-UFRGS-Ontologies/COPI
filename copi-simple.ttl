###  https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingAndReceivingProcess
copi:PigLaunchingAndReceivingProcess rdf:type owl:Class ;
                                     rdfs:label "pig launching and receiving process"@en ,
                                                "processo de lançamento e recebimento de pig"@pt-br ;
                                     skos:definition "A planned process in which a pipeline pig is introduced into a pipeline under operating pressure and subsequently retrieved after completing its passage."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PigLaunchingFunction
copi:PigLaunchingFunction rdf:type owl:Class ;
                          rdfs:subClassOf [ rdf:type owl:Restriction ;
