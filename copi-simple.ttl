@base <https://www.inf.ufrgs.br/ontologies/copi/copi-simple.ttl> .

<https://www.inf.ufrgs.br/ontologies/copi/copi-simple.ttl> rdf:type owl:Ontology ;
                                                            owl:versionIRI <https://www.inf.ufrgs.br/ontologies/copi/releases/2026-06-29/copi-simple.ttl> ;
                                                            terms:bibliographicCitation "Santos, N.O., Antunes, C., Abel, M., Netto, J. (2026). Axiomatizing Industrial Reference Data: A BFO/IOF-Core Enrichment of ISO 15926-4 Equipment Classes. In: Formal Ontology in Information Systems (FOIS 2026). IOS Press." ;
                                                            terms:contributor "Cauã Antunes" ,
                                                                              "Haroldo Rojas" ,
                                                                              "Mara Abel" ,
                                                                              "Rafael Petry" ,
                                                                              "Régis Romeu" ;
                                                            terms:created "2026-03-01"^^xsd:date ;
                                                            terms:creator "Nicolau Oyhenard dos Santos" ;
                                                            terms:description "BFO/IOF-Core conformant ontology of equipment classes for petroleum production plants."@en ;
                                                            terms:issued "2026-06-23"^^xsd:date ;
                                                            terms:license <https://spdx.org/licenses/MIT.html> ;
                                                            terms:modified "2026-06-26"^^xsd:date ;
                                                            terms:publisher "Universidade Federal do Rio Grande do Sul (UFRGS)" ;
                                                            terms:rights "Copyright © 2026 Universidade Federal do Rio Grande do Sul (UFRGS). Available under the MIT License." ;
                                                            terms:source <http://purl.obolibrary.org/obo/bfo.owl> ,
                                                                         <https://github.com/INF-UFRGS-Ontologies/COPI> ,
                                                                         <https://spec.industrialontologies.org/ontology/core/Core/> ;
                                                            terms:title "Core Ontology of Petroleum Installations (COPI)"@en ,
                                                                        "Ontologia Core para Instalações de Petróleo (COPI)"@pt ;
                                                            bibo:status "unstable" ;
                                                            vann:preferredNamespacePrefix "copi" ;
                                                            vann:preferredNamespaceUri "https://www.inf.ufrgs.br/ontologies/copi/"^^xsd:anyURI ;
                                                            owl:versionInfo "2026-06-26" ,
                                                                            "2026-06-29" ;
                                                            skos:scopeNote "Artefatos materiais (bfo:material_entity) que (i) fazem parte de uma planta de produção de petróleo, e (ii) possuem ao menos uma função cuja realização envolve o transporte (p. ex. produção e injeção), processamento (separação e outros processos), controle, monitoramento, medição, contenção ou escoamento de material ou energia."@pt-br ,
                                                                           "COPI fornece categorias de alto nível de equipamentos definidas por função para demonstrar o mecanismo de classe definida. Os subtipos de equipamentos são anotados com referências aos termos do CFIHOS e do PCA RDL. COPI não é uma biblioteca de dados de referência; organizações devem utilizar o CFIHOS, o PCA RDL ou a ISO 14224 para classificação abrangente de equipamentos."@pt-br ,
                                                                           "COPI provides high-level equipment categories defined by function to demonstrate the defined-class mechanism. Equipment subtypes are annotated with references to CFIHOS and PCA RDL terms. COPI is not a reference data library; organizations should use CFIHOS, PCA RDL, or ISO 14224 for comprehensive equipment classification."@en ,
                                                                           "Material artifacts (bfo:material_entity) that (i) are part of a petroleum production plant, and (ii) bear at least one function whose realization involves the transport (e.g. production and injection), processing (separation and other processes), control, monitoring, measurement, containment or offloading of material or energy."@en ;
                                                            schema:logo <https://github.com/INF-UFRGS-Ontologies.png> .

#################################################################
#    Annotation properties
#################################################################

###  http://inf.ufrgs.br/ontologies/apv#ClassMinAnnotationCoverage
apv:ClassMinAnnotationCoverage rdf:type owl:AnnotationProperty .


###  http://inf.ufrgs.br/ontologies/apv#ClassURIFormationRule
apv:ClassURIFormationRule rdf:type owl:AnnotationProperty .


###  http://inf.ufrgs.br/ontologies/apv#GlobalMinLanguageCoverage
apv:GlobalMinLanguageCoverage rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/contributor
dc:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/identifier
dc:identifier rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/license
dc:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/abstract
terms:abstract rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy terms:abstract ;
               rdfs:label "abstract"@en-us ;
               skos:definition "summary of the resource"@en-us ;
               annotation:usageNote "This annotation is used to describe an artifact such as a vocabulary, ontology, or ontology module."@en-us ;
               rdfs:subPropertyOf terms:description .


###  http://purl.org/dc/terms/bibliographicCitation
terms:bibliographicCitation rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
terms:contributor rdf:type owl:AnnotationProperty ;
                  rdfs:isDefinedBy terms:contributor ;
                  rdfs:label "contributor"@en-us ;
                  skos:definition "entity responsible for making contributions to the resource"@en-us .


###  http://purl.org/dc/terms/created
terms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
terms:creator rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy terms:creator ;
              rdfs:label "creator"@en-us ;
              skos:definition "entity responsible for making the resource"@en-us ;
              rdfs:subPropertyOf terms:contributor .


###  http://purl.org/dc/terms/description
terms:description rdf:type owl:AnnotationProperty ;
                  rdfs:isDefinedBy terms:description ;
                  rdfs:label "description"@en-us ;
                  skos:definition "account of the resource"@en-us ;
                  annotation:usageNote "This annotation is used to describe an artifact such as a vocabulary, ontology, or ontology module." ;
                  rdfs:subPropertyOf skos:note .


###  http://purl.org/dc/terms/isPartOf
terms:isPartOf rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
terms:issued rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy terms:issued ;
             rdfs:label "issued"@en-us ;
             skos:definition "date of formal issuance of the resource"@en-us ;
             annotation:usageNote "This annotation is used to describe an artifact such as a vocabulary, ontology, or ontology module." .


###  http://purl.org/dc/terms/license
terms:license rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy terms:license ;
              rdfs:label "license"@en-us ;
              skos:definition "legal document giving official permission to do something with the resource"@en-us .


###  http://purl.org/dc/terms/modified
terms:modified rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy terms:modified ;
               rdfs:label "modified"@en-us ;
               skos:definition "date on which the resource was changed"@en-us .


###  http://purl.org/dc/terms/publisher
terms:publisher rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy terms:publisher ;
                rdfs:label "publisher"@en-us ;
                skos:definition "entity responsible for making the resource available"@en-us ;
                annotation:usageNote "Used to document the primary agent (organization or person) responsible for the resource. This will be \"Industrial Ontology Foundry\" for IOF artifacts." .


###  http://purl.org/dc/terms/references
terms:references rdf:type owl:AnnotationProperty ;
                 rdfs:isDefinedBy terms:references ;
                 rdfs:label "references"@en-us ;
                 skos:definition "related resource that is referenced, cited, or otherwise pointed to by the described resource"@en-us .


###  http://purl.org/dc/terms/rights
terms:rights rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy terms:rights ;
             rdfs:label "rights"@en-us ;
             skos:definition "information about rights held in and over the resource"@en-us .


###  http://purl.org/dc/terms/source
terms:source rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy terms:source ;
             rdfs:label "source"@en-us ;
             skos:definition "related resource from which the described resource is derived"@en-us ;
             annotation:explanatoryNote """The intent is to provide a user with a reference as to how the thing being annotated was derived or arrived at. 
 - The source can be a URL to a standard, common dictionary (e.g. Oxford), or similar reference. Or it can be a short description of where the entity being annotated was derived from.
 - The 'Source' annotation would most likely be used as an annotation on an annotation. For instance annotating a Natural Language definition annotation."""@en-us .


###  http://purl.org/dc/terms/title
terms:title rdf:type owl:AnnotationProperty ;
            rdfs:isDefinedBy terms:title ;
            rdfs:label "title"@en-us ;
            skos:definition "name given to the resource"@en-us ;
            annotation:usageNote "Used for formal title of an artifact (but not individual elements such as classes or properties)." .


###  http://purl.org/ontology/bibo/status
bibo:status rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty ;
              rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
              rdfs:label "alternative label"@en-us ;
              skos:definition "alternative lexical label for a resource"@en-us .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "change note"@en-us ;
                skos:definition "note about a modification to a concept"@en-us ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty ;
                rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                rdfs:label "definition"@en-us ;
                skos:definition "statement or formal explanation of the meaning of a concept"@en-us ;
                rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#editorialNote
skos:editorialNote rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                   rdfs:label "editorial note"@en-us ;
                   skos:definition "note for an editor, translator, or maintainer of the vocabulary"@en-us ;
                   rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty ;
             rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
             rdfs:label "example"@en-us ;
             skos:definition "example of the use of a concept"@en-us ;
             annotation:usageNote """Use of this annotation is optional, but recommended if it will help a user understand the intended interpretation(s).
- This annotation should use at most twice with/on a notion.
- Additional examples or more elaborate examples should be placed in the External Documentation (using rdfs:seeAlso)."""@en-us ;
             rdfs:subPropertyOf skos:note .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty ;
          rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
          rdfs:label "note"@en-us ;
          skos:definition "general note, for any purpose"@en-us .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty ;
               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
               rdfs:label "scope note"@en-us ;
               skos:definition "note that helps to clarify the meaning and/or the use of a concept"@en-us ;
               annotation:usageNote "Use of this annotation is optional, but recommended if it will help a user understand the scope and/or context for usage of the concept."@en-us .


###  https://schema.org/logo
schema:logo rdf:type owl:AnnotationProperty .


###  https://spec.industrialontologies.org/ontology/annotation/abbreviation
annotation:abbreviation rdf:type owl:AnnotationProperty ;
                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                        rdfs:label "abbreviation"@en-us ;
                        skos:definition "synonym that is an alternate short label for the resource"@en-us ;
                        rdfs:subPropertyOf skos:altLabel .


###  https://spec.industrialontologies.org/ontology/annotation/acronym
annotation:acronym rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                   rdfs:label "acronym"@en-us ;
                   skos:definition "an abbreviation usually formed from the initial components of a longer name or phrase"@en-us ;
                   annotation:usageNote """Use this annotation when there is a commonly accepted acronym.

HOWEVER: While acronyms and other abbreviations may be provided as annotations to elements in an IOF ontology, they must NOT BE USED as part of identifiers or labels, except where they have become the primary designator for a notion where the full 'name' is no longer commonly known or recognized. (e.g. LASER: Light Amplification by Stimulated Emission of Radiation; RADAR: RAdio Detection And Ranging; MODEM: Modulator-DEModulator; SCUBA: Self-Contained Underwater Breathing Apparatus; etc),"""@en-us ;
                   rdfs:subPropertyOf annotation:abbreviation .

[ rdf:type owl:Axiom ;
   owl:annotatedSource annotation:acronym ;
   owl:annotatedProperty skos:definition ;
   owl:annotatedTarget "an abbreviation usually formed from the initial components of a longer name or phrase"@en-us ;
   annotation:adaptedFrom "https://en.wikipedia.org/wiki/Acronym"
 ] .


###  https://spec.industrialontologies.org/ontology/annotation/adaptedFrom
annotation:adaptedFrom rdf:type owl:AnnotationProperty ;
                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                       rdfs:label "adapted from"@en-us ;
                       skos:definition "source for the resource that was modified to create the subject resource"@en-us ;
                       rdfs:subPropertyOf terms:source .


###  https://spec.industrialontologies.org/ontology/annotation/copyright
annotation:copyright rdf:type owl:AnnotationProperty ;
                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                     rdfs:label "copyright"@en-us ;
                     skos:definition "exclusive legal right, given to an originator or an assignee to print, publish, perform, film, or record literary, artistic, or musical material, and to authorize others to do the same"@en-us ;
                     annotation:usageNote "This annotation is to be used for an entire ontology and not individual elements."@en-us ;
                     rdfs:subPropertyOf terms:rights .


###  https://spec.industrialontologies.org/ontology/annotation/counterExample
annotation:counterExample rdf:type owl:AnnotationProperty ;
                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                          rdfs:label "counter example" ;
                          skos:definition "example that refutes or disproves a concept in some scenario and is intended to demonstrate how the concept might be misused" ;
                          annotation:usageNote """Use of this annotation is optional, but recommended if it will help a user understand the intended interpretation(s).
- This annotation should use at most twice with/on a notion.
- Additional examples or more elaborate examples should be placed in the External Documentation (using rdfs:seeAlso).""" ;
                          rdfs:subPropertyOf skos:note .


###  https://spec.industrialontologies.org/ontology/annotation/directSource
annotation:directSource rdf:type owl:AnnotationProperty ;
                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                        rdfs:label "direct source"@en-us ;
                        skos:definition "definitive source of the subject resource"@en-us ;
                        rdfs:subPropertyOf terms:source .


###  https://spec.industrialontologies.org/ontology/annotation/elucidation
annotation:elucidation rdf:type owl:AnnotationProperty ;
                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                       rdfs:label "elucidation"@en-us ;
                       owl:deprecated "true"^^xsd:boolean ;
                       skos:example "'Agent' is a subclass of the BFO class 'material entity', which in turn is a subclass of the BFO class 'independent continuant', which in turn is a subclass of the BFO class 'continuant'. So the position of 'Agent' is 'material entity ← independent continuant ← continuant'."@en-us ;
                       annotation:usageNote "This annotation is no longer used. The isPrimitive annotation is now set to true to indicate a primitive class when necessary and sufficient conditions can not be provided."@en-us ;
                       rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/annotation/excerptedFrom
annotation:excerptedFrom rdf:type owl:AnnotationProperty ;
                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                         rdfs:label "excerpted from"@en-us ;
                         skos:definition "source of a resource that was imported unmodified from an external ontology" ;
                         annotation:usageNote "This annotation is to be used when an element from a non-IOF ontology is used in an IOF ontology (and the source ontology is not imported in its entirety)."@en-us ;
                         rdfs:subPropertyOf terms:source .


###  https://spec.industrialontologies.org/ontology/annotation/explanatoryNote
annotation:explanatoryNote rdf:type owl:AnnotationProperty ;
                           rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                           rdfs:label "explanatory note"@en-us ;
                           skos:definition "note that provides additional explanatory information about a given notion or resource"@en-us ;
                           rdfs:subPropertyOf skos:note .


###  https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicAxiom
annotation:firstOrderLogicAxiom rdf:type owl:AnnotationProperty ;
                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                rdfs:label "first-order logic axiom"@en-us ;
                                skos:definition "logic axiom annotation written in first order logic"@en-us ;
                                annotation:usageNote "First-order logic axioms MAY be provided if the term is primitive ('is primitive' is true ) or non-primitive. A construct MAY include more than one first-order logic axiom annotation."@en-us ;
                                rdfs:subPropertyOf annotation:logicAxiom .


###  https://spec.industrialontologies.org/ontology/annotation/firstOrderLogicDefinition
annotation:firstOrderLogicDefinition rdf:type owl:AnnotationProperty ;
                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                     rdfs:label "first order logic definition"@en-us ;
                                     skos:definition "logic definition that expresses the axioms of a class or an object property in first order logic" ;
                                     skos:example """An example of a First Order Logic definition for 'Product' might be (again bearing in mind the natural language terms appearing should be regarded as symbols in the IOF signature):
 - Continuant(x) ∧ ¬(SpecificallyDependentContinuant(x) ∨ Person(x) ∨ Organization(x)) ∧ ∃r (ProductRole(r) ∧ hasRole(x, r))"""@en-us ;
                                     annotation:usageNote """The First Order Logic Definition annotation is comprised of the (complete) necessary and sufficient conditions.
 - This annotation is Required for each non-primitive (aka non-axiomatic) class (i.e. unary relation) of a published IOF OWL ontology. This is the most authoritative and comprehensive definition of an IOF element. 
 - IOF Common Logic ontologies do not require this annotation, but if included it must be logically equivalent to the Common Logic definition.
 - A primitive (aka axiomatic) term will not have a First Order Logic definition in either an OWL or Common Logic IOF ontology.
 - There should be at most one First Order Logic definition.
 - The specific symbols to be used for existential and universal quantification along with those for conjunction, disjunction, negation, conditional (i.e. if-then), and equivalence will be those commonly used in the mathematical formulas and statement.
 - Conjunction - ∧; Disjunction - ∨; Negation - ¬; Existential Quantification - ∃; Universal Quantification - ∀; Conditional - →; Equivalence - ↔; Left/Right Parentheses - (,); Left/Right Brackets - {,}."""@en-us ;
                                     rdfs:subPropertyOf annotation:logicDefinition .


###  https://spec.industrialontologies.org/ontology/annotation/isPrimitive
annotation:isPrimitive rdf:type owl:AnnotationProperty ;
                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                       rdfs:label "is primitive"@en-us ;
                       skos:definition "boolean flag indicating that necessary and sufficient conditions are not provided"@en-us ;
                       annotation:usageNote "'is primitive' must be present if the term does not have necessary and sufficient conditions and the value of the annotation must be set to true. When 'is primitive' is set to true, a value for a 'primitive rationale' annotation must also be provided."@en-us .


###  https://spec.industrialontologies.org/ontology/annotation/logicAxiom
annotation:logicAxiom rdf:type owl:AnnotationProperty ;
                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                      rdfs:label "logic axiom"@en-us ;
                      skos:definition "logical statements constraining the interpretation of the notion represented by the construct that do not provide necessary and sufficient conditions"@en-us ;
                      annotation:explanatoryNote "This annotation property is an abstraction of the more specialized logic axiom annotations used in IOF. However, this annotation property can also be used to group together the logic axiom annotation values of different forms (such as FOL and natural language) that express the same meaning for a particular construct."@en-us ;
                      annotation:usageNote "A first order logic axiom expression and a semi-formal natural language axiom expression should be added as Property values for each logic axiom annotation using 1 of each of the corresponding logic axiom annotation subproperties."@en-us ;
                      rdfs:subPropertyOf skos:note .


###  https://spec.industrialontologies.org/ontology/annotation/logicDefinition
annotation:logicDefinition rdf:type owl:AnnotationProperty ;
                           rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                           rdfs:label "logic definition"@en-us ;
                           skos:definition "definition in the form of a logical expression"@en-us ;
                           rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/annotation/maintainer
annotation:maintainer rdf:type owl:AnnotationProperty ;
                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                      rdfs:label "maintainer"@en-us ;
                      skos:definition "entity responsible for maintaining the resource" ;
                      annotation:usageNote "This annotation applies to an entire IOF ontology (i.e. the file) and not to individual elements."@en-us ;
                      rdfs:subPropertyOf terms:contributor .


###  https://spec.industrialontologies.org/ontology/annotation/maturity
annotation:maturity rdf:type owl:AnnotationProperty ;
                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                    rdfs:label "maturity"@en-us ;
                    skos:definition "annotation property used to indicate the development status of a resource"@en-us ;
                    annotation:usageNote "Any value for maturity MUST be an instance of MaturityLevel. All IOF ontologies MUST include exactly one maturity annotation. IOF constructs may include a maturity annotation."@en-us .


###  https://spec.industrialontologies.org/ontology/annotation/naturalLanguageDefinition
annotation:naturalLanguageDefinition rdf:type owl:AnnotationProperty ;
                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                     rdfs:label "natural language definition"@en-us ;
                                     skos:definition "definition written in plain text for human understanding"@en-us ;
                                     annotation:usageNote """This annotation is Required for each non-primitive or non-axiomatic class of an IOF (OWL or Common Logic) ontology. 
 - It is optional for primitive (aka axiomatic) classes since such the Elucidation annotation is required and will satisfy the role of a natural language definition.
 - It is optional, but recommended, for relations when the intent of a relation may be misunderstood.
 - There should be at most one.
 - This natural language definition should be subject matter expert friendly and consistent with any formal definition or elucidation.
 - Natural language definitions should use class and relation names with following caveats:
 a) Relations – For those relations whose label (i.e. local identifier) consist of multiple terms hyphenate the terms of the label: e.g. 'hasPlan' would be written as 'has-plan'
 b) Classes – For classes whose label has multiple distinct terms, e.g, ManufacturingOperationSpecification, separate the terms but bound them with apostrophe marks: 'Manufacturing Operation Specification'."""@en-us ;
                                     rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/annotation/primitiveRationale
annotation:primitiveRationale rdf:type owl:AnnotationProperty ;
                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                              rdfs:label "primitive rationale"@en-us ;
                              skos:definition "reason why necessary and sufficient conditions could not be provided"@en-us ;
                              annotation:usageNote "When 'is primitive' is set to true, a value for 'primitive rationale' must be provided. The rationale should indicate what is missing if additional work is required to define necessary and sufficient conditions."@en-us ;
                              rdfs:subPropertyOf skos:note .


###  https://spec.industrialontologies.org/ontology/annotation/replacedBy
annotation:replacedBy rdf:type owl:AnnotationProperty ;
                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                      rdfs:label "replaced by"@en-us ;
                      skos:definition "reference to the IRI of the target of a deprecated construct"@en-us ;
                      annotation:usageNote "The value of an iof-av:replacedBy annotation must be the IRI which replaces the target construct."@en-us .


###  https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageAxiom
annotation:semiFormalNaturalLanguageAxiom rdf:type owl:AnnotationProperty ;
                                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                          rdfs:label "semi-formal natural language axiom"@en-us ;
                                          skos:definition "logic axiom expressed in natural language"@en-us ;
                                          annotation:usageNote "Semi-formal natural language axioms MAY be provided if the term is primitive (is primitive is true). A construct MAY include more than one semi-formal natural language axiom annotation."@en-us ;
                                          rdfs:subPropertyOf annotation:logicAxiom .


###  https://spec.industrialontologies.org/ontology/annotation/semiFormalNaturalLanguageDefinition
annotation:semiFormalNaturalLanguageDefinition rdf:type owl:AnnotationProperty ;
                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                               rdfs:label "semi-formal natural language definition"@en-us ;
                                               skos:definition "logic definition that expresses a first order logic definition or common logic definition in natural language" ;
                                               annotation:usageNote """This annotation is required if an element in an IOF OWL ontology has a First Order Logic definition or in a IOF Common Logic (where the element is defined using Common Logic).
 - The intent of this annotation to provide a transition or bridge from the First Order Logic definition of a notion to the natural language definition. This definition is intended to help a user understand the intended interpretation of the notion.
 - As example using the First Order Logic definition of 'Product' above, a semi-formal translation of that might be: 
 - Product =def. Continuant that is not a Person and not an Organization and not a Specifically Dependent Continuant and there is a Product Role that the thing has or bears."""@en-us ;
                                               rdfs:subPropertyOf annotation:logicDefinition .


###  https://spec.industrialontologies.org/ontology/annotation/subjectMatterExpertExplanation
annotation:subjectMatterExpertExplanation rdf:type owl:AnnotationProperty ;
                                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                                          rdfs:label "subject matter expert explanation" ;
                                          skos:definition "definition of the term expressed in natural language that has the minimal usage of ontological terms and is intended to be a self-standing explanation" ;
                                          annotation:usageNote """Usage of this annotation is optional but is recommended in cases where:
- the natural language definition or elucidation rely heavily on the terms defined in the ontology
- there exists an explanation of the term that is more familiar to SMEs that does not coincide with the definition present in the ontology""" ;
                                          rdfs:subPropertyOf skos:definition .


###  https://spec.industrialontologies.org/ontology/annotation/symbol
annotation:symbol rdf:type owl:AnnotationProperty ;
                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                  rdfs:label "symbol"@en-us ;
                  skos:definition "abbreviation that is a design, mark, or charaters(s) used conventionally to represent something, such as currency, quantity, or variable in an expression"@en-us ;
                  skos:example """Chemical Symbols: H, O, Mg
Units of Measure: Km, Kg, G"""@en-us ;
                  annotation:adaptedFrom "https://spec.edmcouncil.org/fibo/ontology/FND/Utilities/AnnotationVocabulary/"^^xsd:anyURI ;
                  rdfs:subPropertyOf annotation:abbreviation .


###  https://spec.industrialontologies.org/ontology/annotation/synonym
annotation:synonym rdf:type owl:AnnotationProperty ;
                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                   rdfs:label "synonym"@en-us ;
                   skos:definition "alternative label (designation) used for the resource in some community"@en-us ;
                   rdfs:subPropertyOf skos:altLabel .


###  https://spec.industrialontologies.org/ontology/annotation/usageNote
annotation:usageNote rdf:type owl:AnnotationProperty ;
                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                     rdfs:label "usage note"@en-us ;
                     skos:definition "note that provides information about how a given notion or resource is used in the ontology's context"@en-us ;
                     rdfs:subPropertyOf skos:note .


###  https://spec.industrialontologies.org/ontology/annotation/wasDefinedBy
annotation:wasDefinedBy rdf:type owl:AnnotationProperty ;
                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                        rdfs:label "was defined by"@en-us ;
                        skos:definition "identifies the occurrence time and former location for a construct, annotation, or individual"@en-us ;
                        annotation:usageNote "This annotation MUST have two sub-annotations iof-av:wasMovedFrom and iof-av:wasMovedOn" .


###  https://spec.industrialontologies.org/ontology/annotation/wasMovedFrom
annotation:wasMovedFrom rdf:type owl:AnnotationProperty ;
                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                        rdfs:label "was moved from"@en-us ;
                        skos:definition "part of a iof-av:wasDefinedBy annotation indicating the previous ontology a construct, annotation, or individual was located"@en-us ;
                        annotation:usageNote "This annotation MUST be a sub-annotation of iof-av:wasDefinedBy" .


###  https://spec.industrialontologies.org/ontology/annotation/wasMovedOn
annotation:wasMovedOn rdf:type owl:AnnotationProperty ;
                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/meta/AnnotationVocabulary/"^^xsd:anyURI ;
                      rdfs:label "was moved on"@en-us ;
                      skos:definition "part of a iof-av:wasDefinedBy annotation indicating the date and time a  construct, annotation, or individual’s location was changed"@en-us ;
                      annotation:usageNote "This annotation MUST be a sub-annotation of iof-av:wasDefinedBy" .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000061
copi:COPI_0000061 rdf:type owl:AnnotationProperty ;
                  rdfs:comment "Reference to an ISO 15926 term IRI."@en ;
                  rdfs:label "iso15926Reference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000062
copi:COPI_0000062 rdf:type owl:AnnotationProperty ;
                  rdfs:comment "Reference to an ISO 14224 equipment taxonomy entry."@en ;
                  rdfs:label "iso14224Reference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000063
copi:COPI_0000063 rdf:type owl:AnnotationProperty ;
                  rdfs:comment "Reference to a CFIHOS (Capital Facilities Information Handover Specification) term."@en ;
                  rdfs:label "cfihosReference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000064
copi:COPI_0000064 rdf:type owl:AnnotationProperty ;
                  rdfs:comment "Reference to a DEXPI (Data Exchange in the Process Industry) prototype element."@en ;
                  rdfs:label "dexpiReference"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000065
copi:COPI_0000065 rdf:type owl:AnnotationProperty ;
                  rdfs:comment "Reference to a POSC Caesar RDL IRI."@en ;
                  rdfs:label "poscCaesarReference"@en .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000054
<http://purl.obolibrary.org/obo/BFO_0000054> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000055> ;
                                             dc:identifier "206-BFO" ;
                                             rdfs:label "has realization"@en ;
                                             skos:altLabel "realized in"@en ;
                                             skos:definition "b has realization c =Def c realizes b"@en ;
                                             skos:example "As for realizes"@en ;
                                             annotation:synonym "realized in"@en-us .


###  http://purl.obolibrary.org/obo/BFO_0000055
<http://purl.obolibrary.org/obo/BFO_0000055> rdf:type owl:ObjectProperty ;
                                             dc:identifier "059-BFO" ;
                                             rdfs:label "realizes"@en ;
                                             skos:definition "(Elucidation) realizes is a relation between a process b and realizable entity c such that c inheres in some d & for all t, if b has participant d then c exists & the type instantiated by b is correlated with the type instantiated by c"@en ;
                                             skos:example "A balding process realizes a disposition to go bald; a studying process realizes a student role; a process of pumping blood realizes the pumping function of a heart"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000056
<http://purl.obolibrary.org/obo/BFO_0000056> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                             dc:identifier "250-BFO" ;
                                             rdfs:label "participates in"@en ;
                                             skos:definition "(Elucidation) participates in holds between some b that is either a specifically dependent continuant or generically dependent continuant or independent continuant that is not a spatial region & some process p such that b participates in p some way"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000057
<http://purl.obolibrary.org/obo/BFO_0000057> rdf:type owl:ObjectProperty ;
                                             owl:propertyChainAxiom ( <http://purl.obolibrary.org/obo/BFO_0000117>
                                                                      <http://purl.obolibrary.org/obo/BFO_0000057>
                                                                    ) ;
                                             dc:identifier "248-BFO" ;
                                             rdfs:label "has participant"@en ;
                                             skos:definition "p has participant c =Def c participates in p"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en ;
                                             annotation:explanatoryNote "the IOF has decided to include transitive participation as an additional axiom of 'has participant at some time' which is reflected in the property chain associated with this property. That is, if A has an 'occurent part' B which 'has participant at some time' C then A 'has participant at some time' C." .


###  http://purl.obolibrary.org/obo/BFO_0000058
<http://purl.obolibrary.org/obo/BFO_0000058> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000059> ;
                                             dc:identifier "258-BFO" ;
                                             rdfs:label "is concretized by"@en ;
                                             skos:definition "c is concretized by b =Def b concretizes c"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000059
<http://purl.obolibrary.org/obo/BFO_0000059> rdf:type owl:ObjectProperty ;
                                             dc:identifier "256-BFO" ;
                                             rdfs:label "concretizes"@en ;
                                             skos:definition "b concretizes c =Def b is a process or a specifically dependent continuant & c is a generically dependent continuant & there is some time t such that c is the pattern or content which b shares at t with actual or potential copies"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000062
<http://purl.obolibrary.org/obo/BFO_0000062> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000063> ;
                                             rdf:type owl:TransitiveProperty ;
                                             dc:identifier "213-BFO" ;
                                             rdfs:label "preceded by"@en ;
                                             skos:definition "b preceded by c =Def b precedes c"@en ;
                                             skos:example "The temporal region occupied by the second half of the match is preceded by the temporal region occupied by the first half of the match"@en .


###  http://purl.obolibrary.org/obo/BFO_0000063
<http://purl.obolibrary.org/obo/BFO_0000063> rdf:type owl:ObjectProperty ,
                                                      owl:TransitiveProperty ;
                                             dc:identifier "270-BFO" ;
                                             rdfs:label "precedes"@en ;
                                             skos:definition "(Elucidation) precedes is a relation between occurrents o, o' such that if t is the temporal extent of o & t' is the temporal extent of o' then either the last instant of o is before the first instant of o' or the last instant of o is the first instant of o' & neither o nor o' are temporal instants"@en ;
                                             skos:example "The temporal region occupied by Mary's birth precedes the temporal region occupied by Mary's death."@en ;
                                             skos:scopeNote "Each temporal region is its own temporal extent. The temporal extent of a spatiotemporal region is the temporal region it temporally projects onto. The temporal extent of a process or process boundary that occupies temporal region t is t." ,
                                                            "Precedes defines a strict partial order on occurrents." ;
                                             annotation:explanatoryNote "while the scope of BFO: precedes is occurrent, for the purposes of formalization of Allen interval algebra we have added the FOL elaborations for 'time instant' 'time interval', 'process boundary' and 'process'. For the case of other occurrents the formalization already provided by BFO (https://github.com/BFO-ontology/BFO-2020/tree/master/21838-2/pdf) should be followed."@en-us ;
                                             annotation:firstOrderLogicAxiom "LA1: precedes(i,j) ∧ process(i) ∧ process(j) → ∃i1∃j1 (TemporalInterval(i1)∧TemporalInterval(j1)∧occupiesTemporalRegion(i,i1)∧occupiesTemporalRegion(j,j1) ∧ precedes(i1,j1))" ,
                                                                             "LA2: precedes(i,j) ∧ ProcessBoundary(i) ∧ ProcessBoundary(j) → ∃i1∃j1 (TemporalInstant(i1)∧TemporalInstant(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ precedes(i1,j1))" ,
                                                                             "LA3: precedes(i,j) ∧TemporalInstant(i) ∧TemporalInterval(j) → ∃j1(hasFirstInstant(j,j1)∧ precedes(i,j1))" ,
                                                                             "LA4: precedes(i,j) ∧ TemporalInterval(i) ∧ TemporalInstant(j) → ∃i1(hasLastInstant(i,i1) ∧ precedes(i1,j))" ,
                                                                             "LA5: precedes (i,j) ∧TemporalInstant (i) ∧ TemporalInstant(j) → ∃k∃l(hasValueExpressionAtAllTimes(i,k) ∧ hasValueExpressionAtAllTimes(j,l) ∧ ∃v1∃v2(hasDateTimeInstantValue(k,v1) ∧ hasDateTimeInstantValue(l,v2) ∧ (v1 < v2)))" ,
                                                                             "LA6: precedes(i,j) ∧ TemporalInterval(i) ∧ TemporalInterval(j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ hasLastInstant(i,i1) ∧ hasFirstInstant(j,j1) ∧ (precedes(i1,j1) ∨ occursSimultaneouslyWith(i1,j1)))" ;
                                             annotation:naturalLanguageDefinition "comes before (something) in time"@en-us ;
                                             annotation:semiFormalNaturalLanguageAxiom "LA1: If i and j are both ‘process’ and i 'precedes' j then the ‘temporal instant’ that i occupies 'precedes' ‘temporal instant’ that j occupies" ,
                                                                                       "LA2: If i and j are both ‘process boundary’ and i 'precedes' j then the ‘temporal instant’ that i occupies 'precedes' ‘temporal instant’ that j occupies" ,
                                                                                       "LA3: if i is ‘temporal instant’ and j is ‘temporal interval’ and i 'precedes' j then i 'precedes' the 'first instant of' j" ,
                                                                                       "LA4: if i is ‘temporal interval’ and j is ‘temporal instant’ and i 'precedes' j then the 'last instant of' i 'precedes' j" ,
                                                                                       "LA5: If i and j are both ‘temporal instant’ and i 'precedes' j then the 'temporal instant value expression' of i is less than the 'temporal instant value expression' of j" ,
                                                                                       "LA6: If both i and j are 'temporal intervals' and i is 'precedes' j then the 'last instant of' i 'precedes' the 'first instant of' j or the 'last instant of' i 'occurs simultaneously with' the 'first instant of' j" .


###  http://purl.obolibrary.org/obo/BFO_0000066
<http://purl.obolibrary.org/obo/BFO_0000066> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000183> ;
                                             dc:identifier "143-BFO" ;
                                             rdfs:label "occurs in"@en ;
                                             skos:definition "b occurs in c =Def b is a process or a process boundary & c is a material entity or site & there exists a spatiotemporal region r & b occupies spatiotemporal region r & for all time t, if b exists at t then c exists at t & there exist spatial regions s and s' where b spatially projects onto s at t & c occupies spatial region s' at t & s is a continuant part of s' at t"@en ;
                                             skos:example "A process of digestion occurs in the interior of an organism; a process of loading artillery rounds into a tank cannon occurs in the interior of the tank"@en .


###  http://purl.obolibrary.org/obo/BFO_0000082
<http://purl.obolibrary.org/obo/BFO_0000082> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000084
<http://purl.obolibrary.org/obo/BFO_0000084> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000101> ;
                                             dc:identifier "252-BFO" ;
                                             rdfs:label "generically depends on"@en ;
                                             skos:altLabel "g-depends on"@en ;
                                             skos:definition "b generically depends on c =Def b is a generically dependent continuant & c is an independent continuant that is not a spatial region & at some time t there inheres in c a specifically dependent continuant which concretizes b at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000101
<http://purl.obolibrary.org/obo/BFO_0000101> rdf:type owl:ObjectProperty ;
                                             dc:identifier "254-BFO" ;
                                             rdfs:label "is carrier of"@en ;
                                             skos:definition "b is carrier of c =Def there is some time t such that c generically depends on b at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000108
<http://purl.obolibrary.org/obo/BFO_0000108> rdf:type owl:ObjectProperty ;
                                             dc:identifier "118-BFO" ;
                                             rdfs:label "exists at"@en ;
                                             skos:definition "(Elucidation) exists at is a relation between a particular and some temporal region at which the particular exists"@en ;
                                             skos:example "First World War exists at 1914-1916; Mexico exists at January 1, 2000"@en .


###  http://purl.obolibrary.org/obo/BFO_0000110
<http://purl.obolibrary.org/obo/BFO_0000110> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000111
<http://purl.obolibrary.org/obo/BFO_0000111> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000115
<http://purl.obolibrary.org/obo/BFO_0000115> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000129> ;
                                             dc:identifier "230-BFO" ;
                                             rdfs:label "has member part"@en ;
                                             skos:definition "b has member part c =Def c member part of b"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000117
<http://purl.obolibrary.org/obo/BFO_0000117> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000132> ;
                                             rdf:type owl:TransitiveProperty ;
                                             dc:identifier "202-BFO" ;
                                             rdfs:label "has occurrent part"@en ;
                                             skos:definition "b has occurrent part c =Def c occurrent part of b"@en ;
                                             skos:example "Mary's life has occurrent part Mary's 5th birthday"@en .


###  http://purl.obolibrary.org/obo/BFO_0000118
<http://purl.obolibrary.org/obo/BFO_0000118> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000121
<http://purl.obolibrary.org/obo/BFO_0000121> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000117> ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000139> ;
                                             rdf:type owl:TransitiveProperty ;
                                             dc:identifier "211-BFO" ;
                                             rdfs:label "has temporal part"@en ;
                                             skos:definition "b has temporal part c =Def c temporal part of b"@en ;
                                             skos:example "Your life has temporal part the first year of your life"@en .


###  http://purl.obolibrary.org/obo/BFO_0000124
<http://purl.obolibrary.org/obo/BFO_0000124> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000171> ;
                                             dc:identifier "236-BFO" ;
                                             rdfs:label "location of"@en ;
                                             skos:definition "b location of c =Def c located in b"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000127
<http://purl.obolibrary.org/obo/BFO_0000127> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000218> ;
                                             dc:identifier "244-BFO" ;
                                             rdfs:label "material basis of"@en ;
                                             skos:definition "b material basis of c =Def c has material basis b"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000129
<http://purl.obolibrary.org/obo/BFO_0000129> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000176> ;
                                             dc:identifier "228-BFO" ;
                                             rdfs:label "member part of"@en ;
                                             skos:definition "b member part of c =Def b is an object & c is a material entity & there is some time t such that b continuant part of c at t & there is a mutually exhaustive and pairwise disjoint partition of c into objects x1, ..., xn (for some n ≠ 1) with b = xi (for some 1 <= i <= n)"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000132
<http://purl.obolibrary.org/obo/BFO_0000132> rdf:type owl:ObjectProperty ,
                                                      owl:TransitiveProperty ;
                                             dc:identifier "003-BFO" ;
                                             rdfs:label "occurrent part of"@en ;
                                             skos:definition "(Elucidation) occurrent part of is a relation between occurrents b and c when b is part of c"@en ;
                                             skos:example "Mary's 5th birthday is an occurrent part of Mary's life; the first set of the tennis match is an occurrent part of the tennis match"@en .


###  http://purl.obolibrary.org/obo/BFO_0000137
<http://purl.obolibrary.org/obo/BFO_0000137> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000138
<http://purl.obolibrary.org/obo/BFO_0000138> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000139
<http://purl.obolibrary.org/obo/BFO_0000139> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000132> ;
                                             rdf:type owl:TransitiveProperty ;
                                             dc:identifier "078-BFO" ;
                                             rdfs:label "temporal part of"@en ;
                                             skos:definition "b temporal part of c =Def b occurrent part of c & (b and c are temporal regions) or (b and c are spatiotemporal regions & b temporally projects onto an occurrent part of the temporal region that c temporally projects onto) or (b and c are processes or process boundaries & b occupies a temporal region that is an occurrent part of the temporal region that c occupies)"@en ;
                                             skos:example "Your heart beating from 4pm to 5pm today is a temporal part of the process of your heart beating; the 4th year of your life is a temporal part of your life, as is the process boundary which separates the 3rd and 4th years of your life; the first quarter of a game of football is a temporal part of the whole game"@en .


###  http://purl.obolibrary.org/obo/BFO_0000153
<http://purl.obolibrary.org/obo/BFO_0000153> rdf:type owl:ObjectProperty ,
                                                      owl:FunctionalProperty ;
                                             dc:identifier "080-BFO" ;
                                             rdfs:label "temporally projects onto"@en ;
                                             skos:definition "(Elucidation) temporally projects onto is a relation between a spatiotemporal region s and some temporal region which is the temporal extent of s"@en ;
                                             skos:example "The world line of a particle temporally projects onto the temporal region extending from the beginning to the end of the existence of the particle"@en .


###  http://purl.obolibrary.org/obo/BFO_0000167
<http://purl.obolibrary.org/obo/BFO_0000167> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000170
<http://purl.obolibrary.org/obo/BFO_0000170> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000171
<http://purl.obolibrary.org/obo/BFO_0000171> rdf:type owl:ObjectProperty ;
                                             dc:identifier "234-BFO" ;
                                             rdfs:label "located in"@en ;
                                             skos:definition "b located in c =Def b is an independent continuant & c is an independent & neither is a spatial region & there is some time t such that the spatial region which b occupies at t is continuant part of the spatial region which c occupies at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000172
<http://purl.obolibrary.org/obo/BFO_0000172> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000174
<http://purl.obolibrary.org/obo/BFO_0000174> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000175
<http://purl.obolibrary.org/obo/BFO_0000175> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000176
<http://purl.obolibrary.org/obo/BFO_0000176> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                             dc:identifier "221-BFO" ;
                                             rdfs:label "continuant part of"@en ;
                                             skos:definition "b continuant part of c =Def b and c are continuants & there is some time t such that b and c exist at t & b continuant part of c at t"@en ;
                                             skos:example "Milk teeth continuant part of human; surgically removed tumour continuant part of organism"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000177
<http://purl.obolibrary.org/obo/BFO_0000177> rdf:type owl:ObjectProperty .


###  http://purl.obolibrary.org/obo/BFO_0000178
<http://purl.obolibrary.org/obo/BFO_0000178> rdf:type owl:ObjectProperty ;
                                             dc:identifier "271-BFO" ;
                                             rdfs:label "has continuant part"@en ;
                                             skos:definition "b has continuant part c =Def c continuant part of b"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000183
<http://purl.obolibrary.org/obo/BFO_0000183> rdf:type owl:ObjectProperty ;
                                             dc:identifier "267-BFO" ;
                                             rdfs:label "environs"@en ;
                                             skos:altLabel "contains process"@en ;
                                             skos:definition "b environs c =Def c occurs in b"@en ;
                                             skos:example "Mouth environs process of mastication; city environs traffic"@en .


###  http://purl.obolibrary.org/obo/BFO_0000184
<http://purl.obolibrary.org/obo/BFO_0000184> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000185> ;
                                             rdf:type owl:FunctionalProperty ,
                                                      owl:InverseFunctionalProperty ;
                                             dc:identifier "144-BFO" ;
                                             rdfs:label "history of"@en ;
                                             skos:definition "(Elucidation) history of is a relation between history b and material entity c such that b is the unique history of c"@en ;
                                             skos:example "This life is the history of this organism"@en .


###  http://purl.obolibrary.org/obo/BFO_0000185
<http://purl.obolibrary.org/obo/BFO_0000185> rdf:type owl:ObjectProperty ;
                                             dc:identifier "145-BFO" ;
                                             rdfs:label "has history"@en ;
                                             skos:definition "b has history c =Def c history of b"@en ;
                                             skos:example "This organism has history this life"@en .


###  http://purl.obolibrary.org/obo/BFO_0000194
<http://purl.obolibrary.org/obo/BFO_0000194> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000195> ;
                                             dc:identifier "260-BFO" ;
                                             rdfs:label "specifically depended on by"@en ;
                                             skos:altLabel "s-depended on by"@en ;
                                             skos:definition "b specifically depended on by c =Def c specifically depends on b"@en ;
                                             skos:example "Coloured object specifically depended on by colour"@en .


###  http://purl.obolibrary.org/obo/BFO_0000195
<http://purl.obolibrary.org/obo/BFO_0000195> rdf:type owl:ObjectProperty ;
                                             dc:identifier "012-BFO" ;
                                             rdfs:label "specifically depends on"@en ;
                                             skos:altLabel "s-depends on"@en ;
                                             skos:definition "(Elucidation) specifically depends on is a relation between a specifically dependent continuant b and specifically dependent continuant or independent continuant that is not a spatial region c such that b and c share no parts in common & b is of a nature such that at all times t it cannot exist unless c exists & b is not a boundary of c"@en ;
                                             skos:example "A shape specifically depends on the shaped object; hue, saturation and brightness of a colour sample specifically depends on each other"@en ;
                                             skos:scopeNote "The analogue of specifically depends on for occurrents is has participant."@en .


###  http://purl.obolibrary.org/obo/BFO_0000196
<http://purl.obolibrary.org/obo/BFO_0000196> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000194> ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                             dc:identifier "053-BFO" ;
                                             rdfs:label "bearer of"@en ;
                                             skos:definition "b bearer of c =Def c inheres in b"@en ;
                                             skos:example "A patch of ink is the bearer of a colour quality; an organism is the bearer of a temperature quality"@en .


###  http://purl.obolibrary.org/obo/BFO_0000197
<http://purl.obolibrary.org/obo/BFO_0000197> rdf:type owl:ObjectProperty ;
                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000195> ;
                                             dc:identifier "051-BFO" ;
                                             rdfs:label "inheres in"@en ;
                                             skos:definition "b inheres in c =Def b is a specifically dependent continuant & c is an independent continuant that is not a spatial region & b specifically depends on c"@en ;
                                             skos:example "A shape inheres in a shaped object; a mass inheres in a material entity"@en .


###  http://purl.obolibrary.org/obo/BFO_0000199
<http://purl.obolibrary.org/obo/BFO_0000199> rdf:type owl:ObjectProperty ,
                                                      owl:FunctionalProperty ;
                                             dc:identifier "132-BFO" ;
                                             rdfs:label "occupies temporal region"@en ;
                                             skos:definition "p occupies temporal region t =Def p is a process or process boundary & the spatiotemporal region occupied by p temporally projects onto t"@en ;
                                             skos:example "The Second World War occupies the temporal region September 1, 1939 - September 2, 1945"@en .


###  http://purl.obolibrary.org/obo/BFO_0000200
<http://purl.obolibrary.org/obo/BFO_0000200> rdf:type owl:ObjectProperty ,
                                                      owl:FunctionalProperty ;
                                             dc:identifier "082-BFO" ;
                                             rdfs:label "occupies spatiotemporal region"@en ;
                                             skos:definition "(Elucidation) occupies spatiotemporal region is a relation between a process or process boundary p and the spatiotemporal region s which is its spatiotemporal extent"@en ;
                                             skos:example "A particle emitted by a nuclear reactor occupies the spatiotemporal region which is its trajectory"@en .


###  http://purl.obolibrary.org/obo/BFO_0000210
<http://purl.obolibrary.org/obo/BFO_0000210> rdf:type owl:ObjectProperty ;
                                             dc:identifier "232-BFO" ;
                                             rdfs:label "occupies spatial region"@en ;
                                             skos:definition "b occupies spatial region r =Def b is an independent continuant that is not a spatial region & r is a spatial region & there is some time t such that every continuant part of b occupies some continuant part of r at t and no continuant part of b occupies any spatial region that is not a continuant part of r at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000216
<http://purl.obolibrary.org/obo/BFO_0000216> rdf:type owl:ObjectProperty ;
                                             dc:identifier "246-BFO" ;
                                             rdfs:label "spatially projects onto"@en ;
                                             skos:definition "(Elucidation) spatially projects onto is a relation between some spatiotemporal region b and spatial region c such that at some time t, c is the spatial extent of b at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000218
<http://purl.obolibrary.org/obo/BFO_0000218> rdf:type owl:ObjectProperty ;
                                             dc:identifier "242-BFO" ;
                                             rdfs:label "has material basis"@en ;
                                             skos:definition "b has material basis c =Def b is a disposition & c is a material entity & there is some d bearer of b & there is some time t such that c is a continuant part of d at t & d has disposition b because c is a continuant part of d at t"@en ;
                                             skos:scopeNote "Users that require more sophisticated representations of time are encouraged to import a temporal extension of BFO-Core provided by the BFO development team. See documentation for guidance: <Link>"@en .


###  http://purl.obolibrary.org/obo/BFO_0000221
<http://purl.obolibrary.org/obo/BFO_0000221> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000222> ;
                                             dc:identifier "268-BFO" ;
                                             rdfs:label "first instant of"@en ;
                                             skos:definition "t first instant of t' =Def t is a temporal instant & t' is a temporal region t' & t precedes all temporal parts of t' other than t"@en ;
                                             skos:example "An hour starting at midnight yesterday has first instant midnight yesterday"@en .


###  http://purl.obolibrary.org/obo/BFO_0000222
<http://purl.obolibrary.org/obo/BFO_0000222> rdf:type owl:ObjectProperty ,
                                                      owl:FunctionalProperty ;
                                             dc:identifier "261-BFO" ;
                                             rdfs:label "has first instant"@en ;
                                             skos:definition "t has first instant t' =Def t' first instant of t"@en ;
                                             skos:example "The first hour of a year has first instant midnight on December 31"@en .


###  http://purl.obolibrary.org/obo/BFO_0000223
<http://purl.obolibrary.org/obo/BFO_0000223> rdf:type owl:ObjectProperty ;
                                             owl:inverseOf <http://purl.obolibrary.org/obo/BFO_0000224> ;
                                             dc:identifier "269-BFO" ;
                                             rdfs:label "last instant of"@en ;
                                             skos:definition "t last instant of t' =Def t is a temporal instant & t' is a temporal region & all temporal parts of t' other than t precede t"@en ;
                                             skos:example "Last midnight is the last instant of yesterday"@en .


###  http://purl.obolibrary.org/obo/BFO_0000224
<http://purl.obolibrary.org/obo/BFO_0000224> rdf:type owl:ObjectProperty ,
                                                      owl:FunctionalProperty ;
                                             dc:identifier "215-BFO" ;
                                             rdfs:label "has last instant"@en ;
                                             skos:definition "t has last instant t' =Def t' last instant of t"@en ;
                                             skos:example "The last hour of a year has last instant midnight December 31"@en .


###  https://spec.industrialontologies.org/ontology/construct/achievesAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/achievesAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000059> ;
                                                                              owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "achieves at some time"@en-us ;
                                                                              skos:example "The staffing and ramping up of production to 2 shifts per work day acheives the company plan of satisfying a surge in demand for its products."@en-us ;
                                                                              annotation:firstOrderLogicAxiom "achievesAtSomeTime(x,y) → Process(x) ∧ InformationContentEntity(y) ∧ (concretizesAtSomeTime(x,y) ∨ ∃z(continuantPartOfAtAllTimes(z,y) ∧ InformationContentEntity(z) ∧ concretizesAtSomeTime(x,z)))" ;
                                                                              annotation:naturalLanguageDefinition "relation from a process to an information content entity wherein the process partially or fully concretizes the information content entity"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "x achieves at some time y holds when x is a 'process' and y is an 'information content entity' and x 'concretizes at some time' y or a 'continuant part of at all times' y" .


###  https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/actsOnBehalfOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "acts on behalf of at some time"@en-us ;
                                                                                    skos:example "An agent acts on behalf of a business organization. A laywer acts on behalf of a person."@en-us ;
                                                                                    annotation:firstOrderLogicAxiom "actsOnBehalfOfAtSomeTime(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (Person(y) ∨ GroupOfAgents(y) ∨ EngineeredSystem(y)) ∧ ∃p∃d(PlannedProcess(p) ∧ ObjectiveSpecification(d) ∧ participatesInAtSomeTime(x,p) ∧achievesAtSomeTime(p,d) ∧ genericallyDependsOnAtSomeTime(d,y))" ;
                                                                                    annotation:naturalLanguageDefinition "relation from a material entity to a person or a group of agents or engineered system that holds when the material entity participates in some planned process in order to fulfill an objective for the person or group of agents or engineered system"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageAxiom "x acts on behalf of at some time y holds when x is a 'material entity' (that is not a 'fiat object part') and y is some 'person' or 'group of agents' or 'engineered system' and at some time t, there exists a 'planned process' p such that x 'participates in' p and p 'achieves at some time' some 'objective specification' d that 'generically depends on at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/after
<https://spec.industrialontologies.org/ontology/construct/after> rdf:type owl:ObjectProperty ;
                                                                 rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000062> ;
                                                                 owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/before> ;
                                                                 rdf:type owl:TransitiveProperty ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "after"@en-us ;
                                                                 skos:example "A metal surface is polished after the surface is cleaned to make it free from dust or grease; a product is manufactured after it is designed; March comes after January."@en-us ;
                                                                 annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                 annotation:firstOrderLogicAxiom "after(x,y) ↔ before(y,x)" ;
                                                                 annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is later than the first instant of the temporal extent of j"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageAxiom "'before' and 'after' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/before
<https://spec.industrialontologies.org/ontology/construct/before> rdf:type owl:ObjectProperty ;
                                                                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000063> ;
                                                                  rdf:type owl:TransitiveProperty ;
                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                  rdfs:label "before"@en-us ;
                                                                  skos:example "The surface of the metal is cleaned to make it free from dust or grease before polishing; a product is designed before it can be manufactured; January comes before March."@en-us ;
                                                                  annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                  annotation:firstOrderLogicAxiom "LA1: before(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))" ,
                                                                                                  "LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ before(i,j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ hasLastInstant(i,i1) ∧ hasFirstInstant(j,j1) ∧ precedes(i1,j1))" ,
                                                                                                  "LA3: Process(i) ∧ Process(j) ∧ ∃i1∃j1(TemporalInterval(i1) ∧ before(i,j) → TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ before(i1,j1))" ;
                                                                  annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is earlier than the first instant of the temporal extent of j"@en-us ;
                                                                  annotation:semiFormalNaturalLanguageAxiom "LA1: If i is 'before' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                            "LA2: If both i and j are 'temporal intervals' and i is 'before' j then the 'last instant of' i 'precedes' the 'first instant of' j" ,
                                                                                                            "LA3: If both i and j are 'process' and i is 'before' j then the 'temporal interval' that i occupies is 'before' the 'temporal interval' that j occupies" .


###  https://spec.industrialontologies.org/ontology/construct/capabilityOf
<https://spec.industrialontologies.org/ontology/construct/capabilityOf> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasCapability> ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "capability of"@en-us ;
                                                                        skos:example "turning at the maximal speed of 4000RPM is the capability of a lathe; temperature sensor has the capability to measuring temperature with a 0.01C precision is the capability of a temperature sensor; measuring pH in the range of 0-14 is the capability of a pH meter"@en-us ;
                                                                        annotation:firstOrderLogicAxiom "capabilityOf(x,y) → Capability(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)" ;
                                                                        annotation:naturalLanguageDefinition "relation from a capability to an independent continuant (the bearer), in which the capability specifically depends on the bearer for its existence"@en-us ;
                                                                        annotation:semiFormalNaturalLanguageAxiom "x capability of y holds when x is a 'capability' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/categorizedBy
<https://spec.industrialontologies.org/ontology/construct/categorizedBy> rdf:type owl:ObjectProperty ;
                                                                         rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/classifiedBy> ;
                                                                         owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/categorizes> ;
                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                         rdfs:label "categorized by"@en-us ;
                                                                         annotation:explanatoryNote "see the explanation under categorizes" ;
                                                                         annotation:firstOrderLogicDefinition "categorizedBy(c1, c2) ↔ categorizes(c2, c1)" ;
                                                                         annotation:naturalLanguageDefinition "relation between a lower-order classifier by a higher-order classifier such that the latter classifier categorizes the former"@en-us ;
                                                                         annotation:semiFormalNaturalLanguageDefinition "c1 is 'categorized by' c2 iff c2 categorizes c1" .


###  https://spec.industrialontologies.org/ontology/construct/categorizes
<https://spec.industrialontologies.org/ontology/construct/categorizes> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/classifies> ;
                                                                       owl:propertyChainAxiom ( <https://spec.industrialontologies.org/ontology/construct/categorizes>
                                                                                                <https://spec.industrialontologies.org/ontology/construct/generalizes>
                                                                                              ) ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                       rdfs:label "categorizes"@en-us ;
                                                                       skos:example "classifiers such as SUV, hatchback, and sedan are categorized under a higher-order classifier body style; classifiers like internal combustion, electric, and hybrid vehicles are categorized by fuel type; classifiers such as small, medium, and large are categorized by size; specific plasmid classifiers (e.g., pSEVA191) may be generalized by a classifier such as Ap, which is categorized by antibiotic resistance" ;
                                                                       annotation:explanatoryNote """1. The terms lower-order and higher-order are relative. In this pattern, a lower-order classifier is used to classify entities of a particular kind, whereas a higher-order classifier indicates a general basis on which the lower-order classifier classifies

2. The definition of categorizes uses 'Set' and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough set and a ‘set member of’ constructs are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, setMemberOf(x, s) is to be understood as x∈s.""" ;
                                                                       annotation:firstOrderLogicAxiom "categorizes(c1, c2) ∧ generalizes(c2, c3) → categorizes(c1, c3)" ;
                                                                       annotation:firstOrderLogicDefinition "categorizes(c1, c2) ↔ (classifies(c1, c2) ∧ ∃s1, s2 (designates(c1, s1) ∧ designates(c2, s2) ∧ setMemberOf(s2, s1))))" ;
                                                                       annotation:naturalLanguageDefinition "relation between classifiers in which a higher-order classifier classifies a lower-order classifier and designates a set that has as members only sets designated by lower-order classifiers that it organizes"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageAxiom "if c1 'categorizes' c2 and c2 'generalizes' c3, then c1 also 'categorizes' c3" ;
                                                                       annotation:semiFormalNaturalLanguageDefinition "c1 ‘categorizes’ c2 if and only if c1 ‘classifies’ c2 and there exists some s1 and some s2 such that c1 ‘designates’ s1, c2 ‘designates’ s2, and s2 is a set member of s1" .


###  https://spec.industrialontologies.org/ontology/construct/classifiedBy
<https://spec.industrialontologies.org/ontology/construct/classifiedBy> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotedBy> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/classifies> ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                        rdfs:label "classified by"@en-us ;
                                                                        annotation:explanatoryNote "See the explanatory note and detailed FOL formalization under classifies" ;
                                                                        annotation:firstOrderLogicDefinition "classifiedBy(x,c) ↔ classifies(c,x)" ;
                                                                        annotation:naturalLanguageDefinition "relation that holds between an entity y and an information content entity x when the information content entity designates a set whose members are all the entities of a particular type and y is a member of that set"@en-us ;
                                                                        annotation:semiFormalNaturalLanguageDefinition "x is 'classified by' c iff c classfies x" .


###  https://spec.industrialontologies.org/ontology/construct/classifies
<https://spec.industrialontologies.org/ontology/construct/classifies> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                      owl:propertyChainAxiom ( <https://spec.industrialontologies.org/ontology/construct/generalizes>
                                                                                               <https://spec.industrialontologies.org/ontology/construct/classifies>
                                                                                             ) ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                      rdfs:label "classifies"@en-us ;
                                                                      skos:example "UNSPSC code 44121706 classifies a wooden pencil" ;
                                                                      annotation:explanatoryNote """1. Any two entities classified by the same classifier are instances of a single, uniquely determined class; while the classifier classifies multiple entities, it designates one class (through a set instance) that fixes their common type.

2. The set designated by a classifier corresponds to a class means that every instance of the class is a member of that set. In this sense, the set is treated as a punned individual of the class, sharing the same IRI while remaining semantically distinct.

3. The definition of classifies uses 'Set' and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough set and a ‘set member of’ constructs are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, setMemberOf(x, s) is to be understood as x∈s.""" ;
                                                                      annotation:firstOrderLogicAxiom "LA1: classifies(c,x) → ∃s (Set(s) ∧ designates(c,s) ∧ setMemberOf(x, s))" ,
                                                                                                      "LA2: classifies(c,x) ∧ designates(c,s) → ∃C(Class(C) ∧ instanceOf(x,C) ∧ sameIRI(s,C) ∧ ∀y((setMemberOf(y,s) → instanceOf(y,C)) ∧ (setMemberOf(y,s)  → classifies(c,y))))" ;
                                                                      annotation:naturalLanguageDefinition "relation that holds between an information content entity x and an entity y when the information content entity designates a set whose members are instances of a particular type and y is a member of that set"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageAxiom "LA1: if c 'classifies' x, then there exists a set s such that c 'designates' s and x 'is a member of' s" ,
                                                                                                                "LA2: if a classifier c classifies an entity x and designates a set s, then there exists a class C such that x is an instance of C, s and C share the same IRI, and, for every entity y, if y is a member of s then y is an instance of C and if y is a set member of s then c classifies y" .


###  https://spec.industrialontologies.org/ontology/construct/componentPartOfAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/componentPartOfAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000137> ,
                                                                                                        <https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime> ;
                                                                                     rdf:type owl:TransitiveProperty ;
                                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                     rdfs:label "component part of at all times"@en-us ;
                                                                                     skos:example "transmission assembly is a component part of a car; engine control ;sparger is a component part of a bioreactor"@en-us ;
                                                                                     annotation:firstOrderLogicAxiom "componentPartOfAtAllTimes(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ properContinuantPartOfAtAllTimes(x,y)" ;
                                                                                     annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it is a proper part of at all times it exists"@en-us ;
                                                                                     annotation:semiFormalNaturalLanguageAxiom "x component part of at all times y holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x is 'proper continuant part of at all times' y" .


###  https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/componentPartOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000175> ;
                                                                                     owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                     rdfs:label "component part of at some time"@en-us ;
                                                                                     skos:example "a particular chromatography column is a component part of a chromatography system during several purification cycles; a particular tool is a component part of a CNC machine while it is being used for manufacturing a particular part"@en-us ;
                                                                                     annotation:explanatoryNote "The IOF does not consider as component part of material entities that are delineated by a non-physical (fiat) boundary from the material entity they are a part of." ;
                                                                                     annotation:firstOrderLogicAxiom "componentPartOfAtSomeTime(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ properContinuantPartOfAtSomeTime(x,y)" ;
                                                                                     annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it is a proper part of at some time"@en-us ;
                                                                                     annotation:semiFormalNaturalLanguageAxiom "x component part of at some time y holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x is 'proper continuant part of at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/containsOccurrenceOf
<https://spec.industrialontologies.org/ontology/construct/containsOccurrenceOf> rdf:type owl:ObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/occursDuring> ;
                                                                                rdf:type owl:TransitiveProperty ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "contains occurence of"@en-us ;
                                                                                skos:example "The grinding of metal contains occurrence of sparking; a storm contains occurrences of lightning."@en-us ;
                                                                                annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                annotation:firstOrderLogicAxiom "containsOccurrenceOf(x,y) ↔ occursDuring(y,x)" ;
                                                                                annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of j is later than the first instant of the temporal extent of i and the last instant of the temporal extent of j is earlier than the last instant of the temporal extent of i"@en-us ;
                                                                                annotation:semiFormalNaturalLanguageAxiom "'contains occurrence of' and 'occurs during' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/denotedBy
<https://spec.industrialontologies.org/ontology/construct/denotedBy> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                     owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "denoted by"@en-us ;
                                                                     skos:example "one or more individuals are denoted by the name 'John'; vehicle is denoted by a 'vehicle identification number'; molecules with the structure CH3-CH2-OH is denoted by 'ethanol'"@en-us ;
                                                                     annotation:naturalLanguageDefinition "relation from an entity to an information content entity that distinguishes the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/denotes
<https://spec.industrialontologies.org/ontology/construct/denotes> rdf:type owl:ObjectProperty ;
                                                                   rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isAbout> ;
                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                   rdfs:label "denotes"@en-us ;
                                                                   skos:example "the name 'John' denotes one or more individuals that have that name; 'vehicle identification number' denotes a vehicle; 'ethanol' is a name given by IUPAC which denotes molecules with the structure CH3-CH2-OH"@en-us ;
                                                                   annotation:explanatoryNote "The distinguishment implied by denotes is not necessarily unique, which is why this property is not made functional. For example, a name can, at one point, 'denote' multiple individuals." ;
                                                                   annotation:naturalLanguageDefinition "relation from an information content entity to an entity that the information content entity distinguishes"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/describedBy
<https://spec.industrialontologies.org/ontology/construct/describedBy> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                       owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/describes> ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                       rdfs:label "described by"@en-us ;
                                                                       skos:example "some current event is described by the content of a newspaper article; some facility visit is described by the content of a visitor's log; some accident is described by the content of an accident report"@en-us ;
                                                                       annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                       annotation:naturalLanguageDefinition "relation from an entity to an information content entity that characterizes the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/describes
<https://spec.industrialontologies.org/ontology/construct/describes> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isAbout> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "describes"@en-us ;
                                                                     skos:example "the content of a newspaper article describes some current event; the content of a visitor's log describes some facility visit; the content of an accident report describes some accident"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                     annotation:naturalLanguageDefinition "relation from an information content entity to an entity that the information content entity characterizes"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/designatedBy
<https://spec.industrialontologies.org/ontology/construct/designatedBy> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotedBy> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/designates> ;
                                                                        rdf:type owl:InverseFunctionalProperty ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "designated by"@en-us ;
                                                                        skos:example "a Web Page's location on the internet is designated by an URL; an individual in USA is designated by SSN ; a particular lot of product is designated by a 'lot number'"@en-us ;
                                                                        annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                        annotation:naturalLanguageDefinition "relation from an entity to an information content entity that uniquely distinguishes the entity from other entities"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/designates
<https://spec.industrialontologies.org/ontology/construct/designates> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                      rdf:type owl:FunctionalProperty ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "designates"@en-us ;
                                                                      skos:example "a URL designates the location of a Web Page on the internet;SSN designates an individual; 'lot number' designates a particular lot of product"@en-us ;
                                                                      annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                      annotation:explanatoryNote """1. To ensure uniqueness, each information content entity can designate exactly one entity. As such, this property is made functional.
2. The uniqueness of the entity is typically within a particular context that is represented in the identification scheme that conveys the meaning of the assignment.""" ;
                                                                      annotation:naturalLanguageDefinition "relation from an information content entity to an entity that the information content entity uniquely distinguishes from other entities"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/dispositionOf
<https://spec.industrialontologies.org/ontology/construct/dispositionOf> rdf:type owl:ObjectProperty ;
                                                                         rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                         owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasDisposition> ;
                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                         rdfs:label "disposition of"@en-us ;
                                                                         skos:example "the disposition to decay to an atom of element Y is the disposition of an atom of element X; the disposition to break apart is the disposition of a poorly assembled item"@en-us ;
                                                                         annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000092" ;
                                                                         annotation:firstOrderLogicAxiom "dispositionOf(x,y) → Disposition(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)" ;
                                                                         annotation:naturalLanguageDefinition "relation from a disposition to an independent continuant (the bearer), in which the disposition specifically depends on the bearer for its existence"@en-us ;
                                                                         annotation:semiFormalNaturalLanguageAxiom "x disposition of y holds when x is a 'disposition' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/functionOf
<https://spec.industrialontologies.org/ontology/construct/functionOf> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                      owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "function of"@en-us ;
                                                                      skos:example "this catalysis function is a function of this enzyme"@en-us ;
                                                                      annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000079" ;
                                                                      annotation:firstOrderLogicAxiom "functionOf(x,y) → Function(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)" ;
                                                                      annotation:naturalLanguageDefinition "relation from a function to an independent continuant (the bearer), in which the function specifically depends on the bearer for its existence"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageAxiom "x function of y holds when x is a 'function' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/generalizes
<https://spec.industrialontologies.org/ontology/construct/generalizes> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotes> ;
                                                                       owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/specializes> ;
                                                                       rdf:type owl:TransitiveProperty ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                       rdfs:label "generalizes"@en-us ;
                                                                       skos:example "UNSPSC classifier code 26101500 for engines genralizes commodity classifier code 26101507 for turboshaft engines." ;
                                                                       annotation:explanatoryNote """1. Since the set designated by a classifier corresponds to a class, a subset relation between designated sets implies a subclass relation between the corresponding classes: if s2 is a subset of s1, then the class corresponding to s2 is a subclass of the class corresponding to s1. In this sense, the classifier being generalized is associated with a more specific class, while the classifier that generalizes it is associated with a more general class.

2. For further details on what it means for a set to correspond to a class, see the FOL formalization and explanatory note for classifier.

3. Generalizes is asymmetric and transitive. Accordingly, if one classifier generalizes a second classifier, the second does not generalize the first; and if a first classifier generalizes a second and the second generalizes a third, then the first also generalizes the third.

4. The definition of generalizes uses 'Set' and related constructs which are not avalable in the current release. These constructs will be made available in the upcoming releasesAlthough Set and subset of are not explicitly available in the current release, standard set-theoretic semantics are assumed; in particular, subSetOf(s2, s1) is understood as s2 ⊆ s1.""" ;
                                                                       annotation:firstOrderLogicAxiom "LA1: generalizes(c1, c2) ∧ designates(c1, s1) ∧ designates(c2,s2) → subSetOf(s2, s1)" ,
                                                                                                       "LA2: generalizes(p, c) ∧ classifies(c, x)) → classifies(p, x)" ;
                                                                       annotation:firstOrderLogicDefinition "generalizes(c2​, c1​) ↔ ∀x(classifies(c2​, x) → classifies(c1​, x))" ;
                                                                       annotation:naturalLanguageDefinition "relation between two classifiers such that everything classified by the latter is also classified by the former"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageAxiom "LA1: If a 'classifier' c1 'generalizes' a 'classifier' c2, and c1 and c2 'designate' sets s1 and s2  then s2 'is subset of' s1" ,
                                                                                                                 "LA2: if p 'generalizes' c and c 'classifies' x, then p also 'classifies' x" ;
                                                                       annotation:semiFormalNaturalLanguageDefinition "‘c2’ generalizes ‘c1’ if and only if for every instance ‘x’, if ‘c2’ classifies ‘x’, then ‘c1’ classifies ‘x’." .


###  https://spec.industrialontologies.org/ontology/construct/hasCapability
<https://spec.industrialontologies.org/ontology/construct/hasCapability> rdf:type owl:ObjectProperty ;
                                                                         rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                         rdfs:label "has capability"@en-us ;
                                                                         skos:example "a lathe has a capability to turn at the maximal speed of 4000RPM; temperature sensor has the capability to measure temperature with a 0.01C precision; pH meter has the capability to measure pH in the range of 0-14"@en-us ;
                                                                         annotation:firstOrderLogicAxiom "hasCapability(x,y) → IndependentContinuant(x) ∧ Capability(y) ∧ bearerOf(x,y)" ;
                                                                         annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a capability, in which the capability specifically depends on the bearer for its existence"@en-us ;
                                                                         annotation:semiFormalNaturalLanguageAxiom "x has capability y holds when x is a 'independent continuant' and y is a 'capability' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000111> ,
                                                                                                         <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                                                                      rdf:type owl:TransitiveProperty ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "has component part at all times"@en-us ;
                                                                                      skos:example "car has component part a chasy; a bioractor has component part a stainless steel vessel"@en-us ;
                                                                                      annotation:firstOrderLogicAxiom "hasComponentPartAtAllTimes(x,y) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ hasProperContinuantPartAtAllTimes(x,y)" ;
                                                                                      annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it has as a proper part at all times it exists"@en-us ;
                                                                                      annotation:semiFormalNaturalLanguageAxiom "x has component part at all times y holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x 'has proper continuant part at all times' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000174> ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "has component part at some time"@en-us ;
                                                                                      skos:example "a particular chromatography column is a component part of a chromatography system has a component part a particular chromatography column during several purification cycles; a CNC machine has component part a particular tool while it is being used for manufacturing a particular part"@en-us ;
                                                                                      annotation:firstOrderLogicAxiom "hasComponentPartAtSomeTime(y,x) → (MaterialEntity(x) ∧ ¬(FiatObjectPart(x))) ∧ (MaterialEntity(y) ∧ ¬(FiatObjectPart(y))) ∧ properContinuantPartOfAtSomeTime(x,y)" ;
                                                                                      annotation:naturalLanguageDefinition "relation from a material entity to another material entity that it has as a proper part at some time"@en-us ;
                                                                                      annotation:semiFormalNaturalLanguageAxiom "y has component part at some time x holds when x is a 'material entity' that is not a 'fiat object part' and y is a 'material entity' that is not a 'fiat object part' and x is 'proper continuant part of at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasDisposition
<https://spec.industrialontologies.org/ontology/construct/hasDisposition> rdf:type owl:ObjectProperty ;
                                                                          rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                          rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                          rdfs:label "has disposition"@en-us ;
                                                                          skos:example "An atom of element X has the disposition to decay to an atom of element Y; a poorly assembled item has the disposition to break apart"@en-us ;
                                                                          annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000091" ;
                                                                          annotation:firstOrderLogicAxiom "hasDisposition(x,y) → IndependentContinuant(x) ∧ Disposition(y) ∧ bearerOf(x,y)" ;
                                                                          annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a disposition, in which the disposition specifically depends on the bearer for its existence"@en-us ;
                                                                          annotation:semiFormalNaturalLanguageAxiom "x has disposition y holds when x is a 'independent continuant' and y is a 'disposition' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasFunction
<https://spec.industrialontologies.org/ontology/construct/hasFunction> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                       rdfs:label "has function"@en-us ;
                                                                       skos:example "this enzyme has function this catalysis function (more colloquially: this enzyme has this catalysis function)"@en-us ;
                                                                       annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000085" ;
                                                                       annotation:explanatoryNote "A bearer can have many functions, and its functions can exist for different periods of time, but none of its functions can exist when the bearer does not exist. A function need not be realized at all the times that the function exists."@en-us ;
                                                                       annotation:firstOrderLogicAxiom "hasFunction(x,y) → IndependentContinuant(x) ∧ Function(y) ∧ bearerOf(x,y)" ;
                                                                       annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a function, in which the function specifically depends on the bearer for its existence"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageAxiom "x has function y holds when x is a 'independent continuant' and y is a 'function' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasInput
<https://spec.industrialontologies.org/ontology/construct/hasInput> rdf:type owl:ObjectProperty ;
                                                                    rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                    owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isInputOf> ;
                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                    rdfs:label "has input"@en-us ;
                                                                    skos:example "machine learning execution process has input a dataset;fermentation process has input growth medium; additive manufacturing process has input metal powder;"@en-us ;
                                                                    annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                    annotation:naturalLanguageDefinition "relation from a process to someone or something physical or digital (continuant) that is a necessary precondition for the process to start"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasMeasuredValueAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/hasMeasuredValueAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime> ;
                                                                                      owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime> ;
                                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                      rdfs:label "has measured value at some time"@en-us ;
                                                                                      skos:example "'80kg' is the value of the weight of a male human on the 5th of October 2022; '37C' is the temperature inside a bioreactor in the 30th min from the process start"@en-us ;
                                                                                      annotation:naturalLanguageDefinition "relation from an entity to a value expression that contains the value of the entity measured at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasOutput
<https://spec.industrialontologies.org/ontology/construct/hasOutput> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000057> ;
                                                                     owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isOutputOf> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "has output"@en-us ;
                                                                     skos:example "chemical manufacturing process has output a wastestream; toluene manufacturing process has output a certain quantity of toluene; car manufacturing process has output a car"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                     annotation:explanatoryNote "By introducing the condition that it must exist at the end of the process materials that only transitively exist during the process (e.g., reaction intermediary) are excluded from being considered the output." ;
                                                                     annotation:naturalLanguageDefinition "relation from a process to someone or something physical or digital (continuant) that participates in the process such that it is generated or modified during the process, and that it exists at the end of the process"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasProcessCharacteristic
<https://spec.industrialontologies.org/ontology/construct/hasProcessCharacteristic> rdf:type owl:ObjectProperty ;
                                                                                    owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf> ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "has process characteristic"@en-us ;
                                                                                    skos:example "the water flowing through a pipe during a given period has the average flow rate as a process characteristic, the heating process has the total energy consumed as a process characteristic, the batch sterilization process has the peak temperature as a process characteristic."@en-us ;
                                                                                    annotation:firstOrderLogicDefinition "hasProcessCharacteristics(p, c) → processCharacteristicsOf(c, p)" ;
                                                                                    annotation:naturalLanguageDefinition "relation between a process and its characteristic"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageDefinition "if p 'has process characteristics' c, then c is 'process characteristics of' p" .


###  https://spec.industrialontologies.org/ontology/construct/hasProcessProfile
<https://spec.industrialontologies.org/ontology/construct/hasProcessProfile> rdf:type owl:ObjectProperty ;
                                                                             rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000118> ;
                                                                             owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/processProfileOf> ;
                                                                             rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                             rdfs:label "has process profile"@en-us ;
                                                                             skos:example "The pH profile is a process profile of the cell culture growth process, the spindle speed profile is a process profile of the milling process, the flow rate profile is a process profile of the pipeline transport process." ;
                                                                             annotation:firstOrderLogicDefinition "hasProcessProfile(p, x) → processProfileOf(x, p)" ;
                                                                             annotation:naturalLanguageDefinition "relation that holds between a process and a process profile that is part of the process such that the part is temporally coextensive with another proper part that is mutually dependent on it and has no parts in common with it"@en-us ;
                                                                             annotation:semiFormalNaturalLanguageDefinition "if p 'has process profile' x, then x is 'process profile of' p" .


###  https://spec.industrialontologies.org/ontology/construct/hasQuality
<https://spec.industrialontologies.org/ontology/construct/hasQuality> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                      owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/qualityOf> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "has quality"@en-us ;
                                                                      skos:example "this apple has quality this red color"@en-us ;
                                                                      annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000086" ;
                                                                      annotation:explanatoryNote "A bearer can have many qualities, and its qualities can exist for different periods of time, but none of its qualities can exist when the bearer does not exist."@en-us ;
                                                                      annotation:firstOrderLogicAxiom "hasQuality(x,y) → IndependentContinuant(x) ∧ Quality(y) ∧ bearerOf(x,y)" ;
                                                                      annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a quality, in which the quality specifically depends on the bearer for its existence"@en-us ;
                                                                      annotation:semiFormalNaturalLanguageAxiom "x has function y holds when x is a 'independent continuant' and y is a 'quality' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasRole
<https://spec.industrialontologies.org/ontology/construct/hasRole> rdf:type owl:ObjectProperty ;
                                                                   rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                                                   owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/roleOf> ;
                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                   rdfs:label "has role"@en-us ;
                                                                   skos:example "this person has role this investigator role (more colloquially: this person has this role of investigator)"@en-us ;
                                                                   annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000087" ;
                                                                   annotation:explanatoryNote "A bearer can have many roles, and its roles can exist for different periods of time, but none of its roles can exist when the bearer does not exist. A role need not be realized at all the times that the role exists."@en-us ;
                                                                   annotation:firstOrderLogicAxiom "hasRole(x,y) → IndependentContinuant(x) ∧ Role(y) ∧ bearerOf(x,y)" ;
                                                                   annotation:naturalLanguageDefinition "relation from an independent continuant (the bearer) to a role, in which the role specifically depends on the bearer for its existence"@en-us ;
                                                                   annotation:semiFormalNaturalLanguageAxiom "x has role y holds when x is a 'independent continuant' and y is a 'role' and x is 'bearer of' y" .


###  https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput
<https://spec.industrialontologies.org/ontology/construct/hasSpecifiedOutput> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/hasOutput> ;
                                                                              owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "has specified output"@en-us ;
                                                                              skos:example "biopharmaceutical production process has specified output an antibody solution of 99.999% purity; a simulation execution has specified output a prediction of part porosity; a temperature measurement process has specified output a temperature measurement result; a car manufacturing process has specified output a car"@en-us ;
                                                                              annotation:adaptedFrom "http://purl.obolibrary.org/obo/OBI_0000299" ;
                                                                              annotation:explanatoryNote "this relation was added to specifically model the outputs that are not byproducts/wasteproducts" ;
                                                                              annotation:firstOrderLogicAxiom "hasSpecifiedOutput(x,y) → PlannedProcess(x) ∧ Continuant(y) ∧ ∃o(ObjectiveSpecification(o) ∧ prescribes(o,y) ∧ achievesAtSomeTime(x,o) ∧ hasOutput(x,y))" ;
                                                                              annotation:naturalLanguageDefinition "relation from a planned process to someone or something physical or digital (continuant) that is produced or modified in the planned process as prescribed by an objective"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "x 'has specified output' y holds when x is a 'planned process' and y is a 'continuant' and x 'has output' y and y is 'prescribed by' some 'objective specification' which x 'achieves at some time'" ;
                                                                              annotation:synonym "has intended output"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime> ;
                                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes> ;
                                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                        rdfs:label "has value expression at all times"@en-us ;
                                                                                        skos:example "speed of light in a vacuum has value expression 3×10^8 m/s ; electric charge carried by a single proton has the value expression 1.602176634×10−19 coulombs"@en-us ;
                                                                                        annotation:naturalLanguageDefinition "relation from an entity to a value expression that contains the value of the entity which does not change during the entire existence of the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/hasValueExpressionAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/describedBy> ;
                                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> ;
                                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                        rdfs:label "has value expression at some time"@en-us ;
                                                                                        skos:example "the diameter of a screw head has value expression 1cm that is specified in its design; a bioreactor has value expression 37C that was measured during the production process; \"low risk\" is the value expression of a process parameter \"low risk\" that is based on the risk analysis classification scheme; an antibody has value expression 3 g/l that was generated by a process simulation"@en-us ;
                                                                                        annotation:explanatoryNote "determined in this context can be interpreted as either being simulated or being measured" ;
                                                                                        annotation:naturalLanguageDefinition "relation from an entity to a value expression that contains the value of the entity determined or set at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isAbout
<https://spec.industrialontologies.org/ontology/construct/isAbout> rdf:type owl:ObjectProperty ;
                                                                   owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                   rdfs:label "is about"@en-us ;
                                                                   skos:example "a temperature recording is about temperature; SSN is about a particular individual; commercial service agreement is about a commercial service"@en-us ;
                                                                   annotation:adaptedFrom "IAO:http://purl.obolibrary.org/obo/IAO_0000136 and CCO:http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology" ;
                                                                   annotation:naturalLanguageDefinition "primitive, generic relationship between an information content entity and some entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isAchievedByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000058> ;
                                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                  rdfs:label "is achieved by at some time"@en-us ;
                                                                                  skos:example "The company plan of satisfying a surge in demand for its products is achieved by the staffing and ramping up of production to 2 shifts per work day."@en-us ;
                                                                                  annotation:firstOrderLogicAxiom "isAchievedByAtSomeTime(y,x) → Process(x) ∧ InformationContentEntity(y) ∧ (concretizesAtSomeTime(x,y) ∨ ∃z(continuantPartOf(z,y) ∧ InformationContentEntity(z) ∧ concretizesAtSomeTime(x,z)))" ;
                                                                                  annotation:naturalLanguageDefinition "relation from an information content entity to a process that partially or fully concretizes the information content entity"@en-us ;
                                                                                  annotation:semiFormalNaturalLanguageAxiom "y is achieved by at some time x holds when x is a 'process' and y is an 'information content entity' and x 'concretizes' y or a 'continuant part of' y, at some time t" .


###  https://spec.industrialontologies.org/ontology/construct/isAvailableToAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isAvailableToAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                   rdfs:label "is available to at some time"@en-us ;
                                                                                   skos:example "a roll of aluminum (resource) is avaiable to an agent to use in a forming process, a milling workstation (resource) is available to a manufacturer to produce some parts"@en-us ;
                                                                                   annotation:explanatoryNote "this definition of 'is available to' is not the same as the state of availability e.g a machine is idle hence it is in the available state" ;
                                                                                   annotation:firstOrderLogicAxiom "isAvailableToAtSomeTime(x,y) → (MaterialEntity(x) ∨ Site(x)) ∧ Agent(y) ∧ ∃p∃o∃c(Process(p) ∧ ObjectiveSpecification(o) ∧ Capability(c) ∧ hasCapability(x,c) ∧ genericallyDependsOnAtSomeTime(o,y) ∧ (realizes(p,c) ∧ participatesInAtSomeTime(y,p)→ AchievesAtSomeTime(p,o)))" ;
                                                                                   annotation:naturalLanguageDefinition "relation from a material entity or physical location to an agent that holds when the material entity or physical location have a capability that is needed by the agent to fulfil some objective carried by the agent"@en-us ;
                                                                                   annotation:semiFormalNaturalLanguageAxiom "x is available at some time y holds when x is a 'material entity' or 'site' and y is an 'agent' and x 'has capability' some 'capability' which when 'realized in' some 'process' p that y 'participates in at some time' implies that p 'achieves at some time' some 'objective specification' that 'generically depends on at some time' y" .


###  https://spec.industrialontologies.org/ontology/construct/isInputOf
<https://spec.industrialontologies.org/ontology/construct/isInputOf> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "is input of"@en-us ;
                                                                     skos:example "a dataset is an input of a machine learning execution process; growth medium is an input of a fermentation process; metal powder is an input of an additive manufacturing process;"@en-us ;
                                                                     annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                     annotation:naturalLanguageDefinition "relates someone or something physical or digital (continuant) to a process that it is a necessary precondition for the process to start"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isMadeOfAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/isMadeOfAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000110> ,
                                                                                                 <https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "is made of at all times"@en-us ;
                                                                              skos:example "A glass bottle is made of glass at all times during its existence as that bottle; A polymer tube is made of polymer at all times during its existence as that tube" ;
                                                                              annotation:explanatoryNote "This relation is asserted with an ‘at all times’ condition. It therefore implies that, for every time at which a exists, a has b as a continuant part. Equivalently, there is no time during the existence of a at which a fully lacks b as a part while still remaining the same material entity" ;
                                                                              annotation:naturalLanguageDefinition "relation between material entity b and material entity that is not a fiat object c such that b has continuant part at all times c and if portion of c is removed from b, that portion stops being part of b, while the remaining c continues to exist as the same material entity and b remains to have continuant part c"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isMadeOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000178> ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "is made of at some time"@en-us ;
                                                                              skos:example "A bottle is made of glass; a bioreactor vessel is made of stainless steel; a capsule shell is made of gelatin; a wooden tabletop is made of oak" ;
                                                                              annotation:counterExample "A car is not made of wheels; a bioreactor is not made of sensors; a computer is not made of circuit boards; an aircraft is not made of engines; a building is not made of windows; a pipeline is not made of valves" ;
                                                                              annotation:explanatoryNote """1) This relation captures the continuous material composition of an entity rather than its structural or component assembly. It depends on the presence of some quantity of the material, not on the exact total amount. The identity of b remains unchanged when its portions are removed; only the quantity of the material within a varies. The relation continues to hold as long as any remainder of b remains materially present in a.
2) It applies to continuous substances or amounts of matter such as glass, steel, polymer, or wood. It should not be used for discrete parts, modules, or components such as wheels, valves, or bolts. The material may be homogeneous or composite; chemical uniformity is not required.
3) The relation has the following characteristics: irreflexive, asymmetric, non-functional, non-transitive""" ;
                                                                              annotation:naturalLanguageDefinition "relation between material entity b and material entity that is not a fiat object c such that b has continuant part at some time c and if portion of c is removed from b, that portion stops being part of b, while the remaining c continues to exist as the same material entity and b remains to have continuant part c"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isMeasuredValueOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> ;
                                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                       rdfs:label "is measured value of at some time"@en-us ;
                                                                                       skos:example "'80kg' is the measured weight of a particular male human"@en-us ;
                                                                                       annotation:naturalLanguageDefinition "relation from a value expression to the entity indicating that the value expression contains the value of the entity measured at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isOutputOf
<https://spec.industrialontologies.org/ontology/construct/isOutputOf> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "is output of"@en-us ;
                                                                      skos:example "wastestream is an output of a chemical manufacturing process; a certain quantity of toluene is an output of a toluene manufacturing process; a car is an output of a car manufacturing process"@en-us ;
                                                                      annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/ExtendedRelationOntology"^^xsd:anyURI ;
                                                                      annotation:naturalLanguageDefinition "relation from someone or something physical or digital (continuant) to a process that it participates in such that it is generated or modified during the process, and it exists at the end of the process"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf
<https://spec.industrialontologies.org/ontology/construct/isSpecifiedOutputOf> rdf:type owl:ObjectProperty ;
                                                                               rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isOutputOf> ;
                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                               rdfs:label "is specified output of"@en-us ;
                                                                               skos:example "antibody solution of 99.999% purity is the specified output of a biopharmaceutical production process; prediction of part porosity is a specified output of a simulation execution; temperature measurement result is the specified output of a temperature measurement process; a car is the specified output of a car manufacturing process"@en-us ;
                                                                               annotation:firstOrderLogicAxiom "isSpecifiedOutputOf(y,x) → PlannedProcess(x) ∧ Continuant(y) ∧ ∃o(ObjectiveSpecification(o) ∧ prescribes(o,y) ∧ achievesAtSomeTime(x,o) ∧ hasOutput(x,y))" ;
                                                                               annotation:naturalLanguageDefinition "relation from someone or something physical or digital (continuant) to a planned process in which it is produced or modified as prescribed by some objective"@en-us ;
                                                                               annotation:semiFormalNaturalLanguageAxiom "y 'has specified output' x holds when x is a 'planned process' and y is a 'continuant' and x 'has output' y and y is 'prescribed by' some 'objective specification' which x 'achieves at some time'" ;
                                                                               annotation:synonym "is intended output of"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isSubjectOf
<https://spec.industrialontologies.org/ontology/construct/isSubjectOf> rdf:type owl:ObjectProperty ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                       rdfs:label "is subject of"@en-us ;
                                                                       skos:example "temperature is subject of temperature recording; particular individual is subject of SSN; commercial service is subject of commercial service agreement"@en-us ;
                                                                       annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                       annotation:naturalLanguageDefinition "primitive, generic relationship between an entity and some information content entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isTemporallyOverlappedBy
<https://spec.industrialontologies.org/ontology/construct/isTemporallyOverlappedBy> rdf:type owl:ObjectProperty ;
                                                                                    owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps> ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "is temporally overlapped by"@en-us ;
                                                                                    skos:example "When two plates are being welded at a joint, the heating of current point being welded is temporally overlapped by the cooling of a previously welded point; the receiving process is temporally overlapped by the sending process in a transaction process; Sumerian civilization (c. 3500 BCE - c. 2000 BCE) in Mesopotamia was temporally overlapped by Ancient Egyptian civilization (c. 3000 BCE - 30 BCE)."@en-us ;
                                                                                    annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                    annotation:firstOrderLogicAxiom "isTemporallyOverlappedBy(x,y) ↔ temporallyOverlaps(y,x)" ;
                                                                                    annotation:naturalLanguageDefinition "relation that holds between two intervals and processes i and j when the first instant of the temporal extent of j is earlier than and the last instant of the temporal extent of j is later than the first instant of the temporal extent of i, and the last instance of the temporal extent of j is earlier than the last instant of the temporal extent of i"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageAxiom "'is temporally overlapped by' and 'temporally overlaps' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes
<https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtAllTimes> rdf:type owl:ObjectProperty ;
                                                                                         rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> ;
                                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                         rdfs:label "is value expression of at all times"@en-us ;
                                                                                         skos:example "3×10^8 m/s is the value expression of the speed of light in a vacuum; 1.602176634×10−19 coulombs is the value expression of the electric charge carried by a single proton"@en-us ;
                                                                                         annotation:naturalLanguageDefinition "relation from a value expression to an entity indicating that the value expression contains the value of the entity which does not change during the entire existence of the entity"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/isValueExpressionOfAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                         rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/describes> ;
                                                                                         rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                         rdfs:label "is value expression of at some time"@en-us ;
                                                                                         skos:example "1cm is the value expression of the diameter of a screw head that is specified in its design; 37C is the value expression of the temperature of a bioreactor measured during the production process; \"low risk\" is the value expression of a process parameter based on the risk analysis classification scheme; 3 g/l is the value expression of titer of an antibody generated by a process simulation"@en-us ;
                                                                                         annotation:adaptedFrom "http://purl.obolibrary.org/obo/OBI_0001938" ;
                                                                                         annotation:naturalLanguageDefinition "relation from a value expression to the entity indicating that the value expression contains the value of the entity determined or set at some time t"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/measuredByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/measuredByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime> ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "measured by at some time"@en-us ;
                                                                                skos:example "the temperature within a production vessel is measured by a temperature sensor at certain points in time during a chemical production process; the weight of a material bulk is measured by a scale"@en-us ;
                                                                                annotation:naturalLanguageDefinition "relation from an entity to a material entity with a measurement capability that got realized to determine the value of the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/measuresAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "measures at some time"@en-us ;
                                                                              skos:example "a tempearture sensor measures the temperature within a production vessel at certain points in time during the chemical production process; a scale measures the weight of a material bulk"@en-us ;
                                                                              annotation:explanatoryNote "In this context, value is always determined relative to some classification scheme or on a quantitative scale" ;
                                                                              annotation:naturalLanguageDefinition "relation from a material entity to an entity indicating that the measurement capability of the material entity got realized to determine the value of the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/meets
<https://spec.industrialontologies.org/ontology/construct/meets> rdf:type owl:ObjectProperty ;
                                                                 rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000063> ;
                                                                 owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/metBy> ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "meets"@en-us ;
                                                                 skos:example "When an item is placed on a moving conveyor by a robotic arm, the process of placing the item meets the process of moving the item; summer meets fall; January meets February; the Christmas holiday period meets New Year’s holiday period."@en-us ;
                                                                 annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                 annotation:firstOrderLogicAxiom "LA1: meets(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))" ,
                                                                                                 "LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ meets(i,j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ hasLastInstant(i,i1) ∧ hasFirstInstant(j,j1) ∧ occursSimultaneouslyWith(i1,j1))" ,
                                                                                                 "LA3: Process(i) ∧ Process(j) ∧ meets(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ meets(i1,j1))" ;
                                                                 annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is the same as the first instant of the temporal extent of j"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'meets' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                           "LA2: If both i and j are 'temporal intervals' and i 'meets' j then the 'last instant of' i 'occurs simultaneously with' the 'first instant of' j" ,
                                                                                                           "LA3: If both i and j are 'process' and i 'meets' j then the 'temporal interval' that i occupies 'meets' the 'temporal interval' that j occupies" .


###  https://spec.industrialontologies.org/ontology/construct/metBy
<https://spec.industrialontologies.org/ontology/construct/metBy> rdf:type owl:ObjectProperty ;
                                                                 rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000062> ;
                                                                 rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                 rdfs:label "met by"@en-us ;
                                                                 skos:example "When an item is placed on a moving conveyor by a robotic arm, the process of moving of the item is met by the process of placing the item; fall is met by summer; February is met by January; the New Year’s holiday period is met by the Christmas holiday period."@en-us ;
                                                                 annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                 annotation:firstOrderLogicAxiom "metBy(x,y) ↔ meets(y,x)" ;
                                                                 annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of j is the same as the first instant of the temporal extent of i"@en-us ;
                                                                 annotation:semiFormalNaturalLanguageAxiom "'met by' and 'meets' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/observedByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/observedByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime> ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "observed by at some time"@en-us ;
                                                                                skos:example "a chemical reaction in an experiment is observed by a scientist, a machining process is observed by an operator, a group of COVID patients are observed by a doctor"@en-us ;
                                                                                annotation:firstOrderLogicAxiom "observedByAtSomeTime (y, x) → Agent(x) ∧ Entity(y) ∧ ∃p∃i(Process(p) ∧ InformationContentEntity(i) ∧ participatesInAtSomeTime(x,p) ∧ hasOutput(p,i) ∧ isAbout(i,y))" ;
                                                                                annotation:naturalLanguageDefinition "relation from an entity to an agent indicating that the agent participates in some process that outputs information about the entity, at some time"@en-us ;
                                                                                annotation:semiFormalNaturalLanguageAxiom "p is observed by b at some time t holds when p is an 'entity' and b is an 'agent' and there is a 'process' in which b 'participates in at some time' and that 'has output' some 'information content entity' that 'is about' p" .


###  https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/observesAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "observes at some time"@en-us ;
                                                                              skos:example "a scientist observing a chemical reaction in an experiment, an operator observes a machining process, a doctor observes a group of COVID patients"@en-us ;
                                                                              annotation:explanatoryNote "this property was not put under participates in at some time because the target of observation can be continuant or an occurent and in the case of an occurent an agent that observes the occurent might not participate in that occurent" ;
                                                                              annotation:firstOrderLogicAxiom "observesAtSomeTime (x, y) → Agent(x) ∧ Entity(y) ∧ ∃p∃i(Process(p) ∧ InformationContentEntity(i) ∧ participatesInAtSomeTime(x,p) ∧ hasOutput(p,i) ∧ isAbout(i,y))" ;
                                                                              annotation:naturalLanguageDefinition "relation from an agent to an entity indicating that the agent participates in some process that outputs information about the entity, at some time"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "b observes p at some time t when b is an 'agent' and p is an 'entity and there is a 'process' in which b 'participates in at some time' and that 'has output' some 'information content entity' that 'is about' p" .


###  https://spec.industrialontologies.org/ontology/construct/occursDuring
<https://spec.industrialontologies.org/ontology/construct/occursDuring> rdf:type owl:ObjectProperty ,
                                                                                 owl:TransitiveProperty ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "occurs during"@en-us ;
                                                                        skos:example "The final inspection and removal of defective products occur during the product is being moved to the packaging station by a conveyor belt; a sensor measures the thickness of the wall during the sand-grinding process; turkey is traditionally served during dinners on Thanksgiving In the United States."@en-us ;
                                                                        annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                        annotation:firstOrderLogicAxiom "LA1: occursDuring(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))" ,
                                                                                                        "LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ occursDuring(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ precedes(j1,i1) ∧ precedes(i2,j2))" ,
                                                                                                        "LA3: Process(i) ∧ Process(j) ∧ occursDuring(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ occursDuring(i1,j1))" ,
                                                                                                        "LA4: occursDuring(i,j) ↔ ∃k(temporallyFinishes(i,k) ∧ temporallyStarts(k,j))" ;
                                                                        annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of i is later than the first instant of the temporal extent of j and the last instant of the temporal extent of i is earlier than the last instant of the temporal extent of j"@en-us ;
                                                                        annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'occurs during' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                  "LA2: If both i and j are 'temporal intervals' and i 'occurs during' j' then first instant of' j ‘precedes’ the 'first instant of' i and the 'last instant of' i ‘precedes’ the 'last instant of' j" ,
                                                                                                                  "LA3: If both i and j are 'process' and i 'occurs during' j then the 'temporal interval' that i occupies 'occurs during' the 'temporal interval' that j occupies" ,
                                                                                                                  "LA4: i 'occurs during' j if and only if there exists k such that i temporally finishes k and k temporally starts j" .


###  https://spec.industrialontologies.org/ontology/construct/occursSimultaneouslyWith
<https://spec.industrialontologies.org/ontology/construct/occursSimultaneouslyWith> rdf:type owl:ObjectProperty ,
                                                                                             owl:SymmetricProperty ,
                                                                                             owl:TransitiveProperty ;
                                                                                    rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                    rdfs:label "occurs simultaneously with"@en-us ;
                                                                                    skos:example "The rotation of the chuck in a lathe occurs simultaneously with the running of the motor."@en-us ;
                                                                                    annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                    annotation:firstOrderLogicAxiom "LA1: occursSimultaneouslyWith(i,j) → (TemporalInstant(i) ∧ TemporalInstant(j)) ∨ (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j)) ∧ (ProcessBoundary(i) ∧ ProcessBoundary(j))" ,
                                                                                                                    "LA2: TemporalInstant(i) ∧ TemporalInstant(j) ∧ occursSimultaneouslyWith(i,j) → ∃k∃l(TemporalInstantValueExpression(k) ∧ TemporalInstantValueExpression(l) ∧ hasValueExpressionAtAllTimes(i,k) ∧ hasValueExpressionAtAllTimes(j,l) ∧ ∃v1∃v2(hasDateTimeInstantValue(k,v1) ∧ hasDateTimeInstantValue(l,v2) ∧ (v1 = v2)))" ,
                                                                                                                    "LA3: TemporalInterval(i) ∧ TemporalInterval(j) ∧ occursSimultaneouslyWith(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ occursSimultaneouslyWith(i1,j1) ∧ occursSimultaneouslyWith(i2,j2))" ,
                                                                                                                    "LA4: Process(i) ∧ Process(j) ∧ occursSimultaneouslyWith(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ occursSimultaneouslyWith(i1,j1))" ,
                                                                                                                    "LA5: ProcessBoundary(i) ∧ ProcessBoundary(j) ∧ occursSimultaneouslyWith(i,j) → ∃i1∃j1(TemporalInstant(i1) ∧ TemporalInstant(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ occursSimultaneouslyWith(i1,j1))" ;
                                                                                    annotation:naturalLanguageDefinition "relation that holds between two time instants when they are simultaneous or between two intervals when they have same first and last instants or between two processes or two process boundaries when their temporal extents are the same"@en-us ;
                                                                                    annotation:semiFormalNaturalLanguageAxiom "LA1: if i 'occurs simultaneously with' j then either i and j are both ‘temporal instant’, or both are ‘temporal interval’ or both are ‘process’ or both are ‘process boundary’" ,
                                                                                                                              "LA2: If both i and j are both ‘temporal instant’ and i 'occurs simoultaneously with' j then 'temporal instant value expression' of i is equal to the 'temporal instant value expression' of j" ,
                                                                                                                              "LA3: If i and j are both ‘temporal interval’ and i 'occurs simoultaneously with' j then the 'first instant of' i 'occurs simoultaneously with' the 'first instant of' j and the 'last instant of' i 'occurs simoultaneously with' the 'last instant of' j" ,
                                                                                                                              "LA4: If both i and j are ‘process’ and i 'occurs simoultaneously with' j then the ‘temporal interval’ occupied by i ‘occurs simoultaneously with’ the ‘temporal interval’ occupied by j" ,
                                                                                                                              "LA5: If i and j are both ‘process boundary’ and i 'occurs simoultaneously with' j then the ‘temporal instant’ that i occupies 'occurs simoultaneously with' ‘temporal instant’ that j occupies" .


###  https://spec.industrialontologies.org/ontology/construct/prescribedBy
<https://spec.industrialontologies.org/ontology/construct/prescribedBy> rdf:type owl:ObjectProperty ;
                                                                        rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isSubjectOf> ;
                                                                        owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/prescribes> ;
                                                                        rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                        rdfs:label "prescribed by"@en-us ;
                                                                        skos:example "some Artifact or Facility is modeled by a blueprint; a set of rules to be followed while acting in a role within a profession are prescribed by a professional code of conduct; tasks that need to be performed to achieve the Objectives of the Operation are prescribed by the Operation Plan"@en-us ;
                                                                        annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                        annotation:naturalLanguageDefinition "relation from an entity to an information content entity that the information content entity serves as a collection of rules or guide for if the entity is something that unfolds in time (occurrent), or as a model if the entity is someone or something physical or digital (continuant)"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/prescribes
<https://spec.industrialontologies.org/ontology/construct/prescribes> rdf:type owl:ObjectProperty ;
                                                                      rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/isAbout> ;
                                                                      rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                      rdfs:label "prescribes"@en-us ;
                                                                      skos:example "a blueprint serves as a model of some Artifact or Facility; a professional code of conduct serves as a set of rules to be followed while acting in a role within that profession; an Operations Plan serves as a guide for the tasks that need to be performed to achieve the Objectives of the Operation"@en-us ;
                                                                      annotation:adaptedFrom "http://www.ontologyrepository.com/CommonCoreOntologies/Mid/InformationEntityOntology"^^xsd:anyURI ;
                                                                      annotation:naturalLanguageDefinition "relation from an information content entity to an entity such that the information content entity serves as a collection of rules or guide for the entity if the entity is something that unfolds in time (occurrent), or as a model if the entity is someone or something physical or digital (continuant)"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf
<https://spec.industrialontologies.org/ontology/construct/processCharacteristicOf> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                   rdfs:label "process characteristic of"@en-us ;
                                                                                   skos:example "The average flow rate is a process characteristic of the water flowing through a pipe during a given period, the total energy consumed is a process characteristic of the heating process, the peak temperature is a process characteristic of the batch sterilization process." ;
                                                                                   annotation:naturalLanguageDefinition "relation between a characteristic and the process it is a characteristic of"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/processProfileOf
<https://spec.industrialontologies.org/ontology/construct/processProfileOf> rdf:type owl:ObjectProperty ;
                                                                            rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000138> ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                            rdfs:label "process profile of"@en-us ;
                                                                            skos:example "pH profile is a process profile of culture growth, agitation speed profile is a process profile of a mixing process, tool vibration profile is a process profile of a engine running" ;
                                                                            annotation:adaptedFrom "axiom label in BFO2 Reference (094-005) in http://purl.obolibrary.org/obo/BFO_0000144 from BFO 2.0" ;
                                                                            annotation:firstOrderLogicAxiom "∀x, y (processProfileOf(x,y) → (properOccurrentPartOf(x,y) ∧ ∃z, t (properOccurrentPartOf(z,y) ∧ TemporalRegion(t) ∧ occupiesSpatioTemporalRegion(x,t) ∧ occupiesSpatioTemporalRegion(y,t) ∧ occupiesSpatioTemporalRegion(z,t) ∧ ¬∃w(occurrentPartOf(w,x) ∧ occurrentPartOf(w,z)))))" ;
                                                                            annotation:naturalLanguageDefinition "relation that holds between a process profile and a process that it is part of such that the source process is a proper part of the target process and is temporally coextensive with another proper part of the target process that is mutually dependent on it and shares no parts with it."@en-us ;
                                                                            annotation:semiFormalNaturalLanguageAxiom "if x is 'process profile of' y, then x is a 'proper occurrent part of' y that shares a 'spatiotemporal region' with some other 'proper occurrent part' z of y such that x and z have no common 'occurrent part'" .


###  https://spec.industrialontologies.org/ontology/construct/qualityOf
<https://spec.industrialontologies.org/ontology/construct/qualityOf> rdf:type owl:ObjectProperty ;
                                                                     rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                     rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                     rdfs:label "quality of"@en-us ;
                                                                     skos:example "this red color is a quality of this apple"@en-us ;
                                                                     annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000080" ;
                                                                     annotation:firstOrderLogicAxiom "qualityOf(x,y) → Quality(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)" ;
                                                                     annotation:naturalLanguageDefinition "relation from a quality to an independent continuant (the bearer), in which the quality specifically depends on the bearer for its existence"@en-us ;
                                                                     annotation:semiFormalNaturalLanguageAxiom "x disposition of y holds when x is a 'quality' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/recognizedByAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/recognizedByAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                  owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime> ;
                                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                  rdfs:label "recognized by at some time"@en-us ;
                                                                                  skos:example "a failure event is recognized by an operator that results in information about the event such as the time of occurrence and the description about the failure; a defect on a part is recognized by a quality control engineer that results in information about the defect such as the nature of the defect and the cause of the defect"@en-us ;
                                                                                  annotation:naturalLanguageDefinition "relation from an entity to an agent that is able to describe the entity or is able to associate an information content entity that describes the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime
<https://spec.industrialontologies.org/ontology/construct/recognizesAtSomeTime> rdf:type owl:ObjectProperty ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "recognizes at some time"@en-us ;
                                                                                skos:example "operator recognizes a failure event that results in information about the event such as the time of occurrence and the description about the failure, a quality control engineer recognizes a defect on a part that results in information about the defect such as the nature of the defect and the cause of the defect"@en-us ;
                                                                                annotation:explanatoryNote "Recognition is preceded by an observation of an entity that is related to the entity being recognized or the entity being recognized is an entity that is an attribute of the entity being observed" ,
                                                                                                           "this property was not put under participates in at some time because the target of recognition can be continuant or an occurent and in the case of an occurent an agent that recognizes the occurent might not participate in that occurent" ;
                                                                                annotation:naturalLanguageDefinition "relation from an agent to an entity that the agent is able to describe the entity or is able to associate an information content entity that describes the entity, at some time"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/requirementSatisfiedBy
<https://spec.industrialontologies.org/ontology/construct/requirementSatisfiedBy> rdf:type owl:ObjectProperty ;
                                                                                  owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement> ;
                                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                  rdfs:label "requirement satisfied by"@en-us ;
                                                                                  skos:example "a UML requirement specification is satisfied by a a piece of software; functional requirement specification of a car is satisfied by its desgn specification"@en-us ;
                                                                                  annotation:naturalLanguageDefinition "relation from a requirement specification to an entity that conforms to the requirement specification"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/roleOf
<https://spec.industrialontologies.org/ontology/construct/roleOf> rdf:type owl:ObjectProperty ;
                                                                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000197> ;
                                                                  rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                  rdfs:label "role of"@en-us ;
                                                                  skos:example "this investigator role is a role of this person"@en-us ;
                                                                  annotation:adaptedFrom "http://purl.obolibrary.org/obo/RO_0000081" ;
                                                                  annotation:firstOrderLogicAxiom "roleOf(x,y) → Role(x) ∧ IndependentContinuant(y) ∧ inheresIn(x,y)" ;
                                                                  annotation:naturalLanguageDefinition "relation from a role to an independent continuant (the bearer), in which the role specifically depends on the bearer for its existence"@en-us ;
                                                                  annotation:semiFormalNaturalLanguageAxiom "x disposition of y holds when x is a 'role' and y is a 'independent continuant' and x is 'inheres in' y" .


###  https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement
<https://spec.industrialontologies.org/ontology/construct/satisfiesRequirement> rdf:type owl:ObjectProperty ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "satisfies requirement"@en-us ;
                                                                                skos:example "a piece of software satisfies a UML requirement specification, a design specification of a car satisfies its functional requirement specification"@en-us ;
                                                                                annotation:naturalLanguageDefinition "relation from an entity to a requirement specification that the entity conforms to"@en-us .


###  https://spec.industrialontologies.org/ontology/construct/specializes
<https://spec.industrialontologies.org/ontology/construct/specializes> rdf:type owl:ObjectProperty ;
                                                                       rdfs:subPropertyOf <https://spec.industrialontologies.org/ontology/construct/denotedBy> ;
                                                                       rdf:type owl:TransitiveProperty ;
                                                                       rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/" ;
                                                                       rdfs:label "specializes"@en-us ;
                                                                       annotation:explanatoryNote "See the expanded formalization and explanation under generalizes" ;
                                                                       annotation:firstOrderLogicDefinition "specializes(c1, c2) ↔ generalizes(c2, c1)" ;
                                                                       annotation:naturalLanguageDefinition "relation between two classifiers such that everything classified by the former is also classified by the latter"@en-us ;
                                                                       annotation:semiFormalNaturalLanguageDefinition "c1 is 'specializes' c2 iff c2 generalizes c1" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyFinishedBy
<https://spec.industrialontologies.org/ontology/construct/temporallyFinishedBy> rdf:type owl:ObjectProperty ;
                                                                                owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/temporallyFinishes> ;
                                                                                rdf:type owl:TransitiveProperty ;
                                                                                rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                                rdfs:label "temporally finished by"@en-us ;
                                                                                skos:example "A delivery process is temporally finished by the generation of “proof of delivery”; a football match is temporally finished by the Referee’s final whistle; every week is temporally finished by a Sunday."@en-us ;
                                                                                annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                                annotation:firstOrderLogicAxiom "temporallyFinishedBy(x,y) ↔ temporallyFinishes(y,x)" ;
                                                                                annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of j is the same as the last instant of the temporal extent of i and the first instant of i is preceded by the first instant of j"@en-us ;
                                                                                annotation:semiFormalNaturalLanguageAxiom "'temporally finished by' and 'temporally finishes' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyFinishes
<https://spec.industrialontologies.org/ontology/construct/temporallyFinishes> rdf:type owl:ObjectProperty ,
                                                                                       owl:TransitiveProperty ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "temporally finishes"@en-us ;
                                                                              skos:example "The generation of “proof of delivery” temporally finishes the delivery process; Referee’s final whistle temporally finishes the football match; Sunday temporally finishes the week."@en-us ;
                                                                              annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                              annotation:firstOrderLogicAxiom "LA1: temporallyFinishes(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))" ,
                                                                                                              "LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ temporallyFinishes(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ occursSimultaneouslyWith(i2,j2) ∧ precedes(j1,i1))" ,
                                                                                                              "LA3: Process(i) ∧ Process(j) ∧ temporallyFinishes(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ temporallyFinishes(i1,j1))" ,
                                                                                                              "LA4: temporallyFinishes(i,j) ↔ ∃k∃l(meets(i,k)∧meets(j,k) ∧ before(l,i) ∧ meets(l,j))" ;
                                                                              annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the last instant of the temporal extent of i is the same as the last instant of the temporal extent of j and the first instant of j precedes the first instant of i"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'temporally finishes' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                        "LA2: If both i and j are 'temporal intervals' and i 'temporally finishes' j then the 'last instant’ of i ‘occurs simultaneously with’ the 'last instant of' j and the 'first instant of' j 'precedes' the 'first instant’ of i" ,
                                                                                                                        "LA3: If both i and j are 'process' and i 'temporally finishes' j then the 'temporal interval' that i occupies 'temporally finishes' the 'temporal interval' that j occupies" ,
                                                                                                                        "LA4: i 'temporally finishes' j if and only if there exists k such that i 'meets' k and j 'meets' k, and there exists l that is 'before' i and 'meets' j" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps
<https://spec.industrialontologies.org/ontology/construct/temporallyOverlaps> rdf:type owl:ObjectProperty ;
                                                                              rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                              rdfs:label "temporally overlaps"@en-us ;
                                                                              skos:example "When two plates are being welded at a joint, the cooling of a previously welded point temporally overlaps the heating of the point which is currently being welded; the sending process temporally overlaps the receiving process in a transaction process; Ancient Egyptian civilization (c. 3000 BCE - 30 BCE) temporally overlapped the Sumerian civilization (c. 3500 BCE - c. 2000 BCE) in Mesopotamia and the Indus Valley Civilization (c. 2600 BCE - c. 1900 BCE) in South Asia."@en-us ;
                                                                              annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                              annotation:firstOrderLogicAxiom "LA1: temporallyOverlaps(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))" ,
                                                                                                              "LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ temporallyOverlaps(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ precedes(j1,i2) ∧ precedes(i1,j1) ∧ precedes(i2,j2))" ,
                                                                                                              "LA3: Process(i) ∧ Process(j) ∧ temporallyOverlaps(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ temporallyOverlaps(i1,j1))" ,
                                                                                                              "LA4: temporallyOverlaps(i,j) ↔ ∃k(temporallyFinishes(k,i) ∧ starts(k,j))" ;
                                                                              annotation:naturalLanguageDefinition "relation that holds between two intervals and processes i and j when the first instant of the temporal extent of i is earlier than and the last instant of the temporal extent of i is later than the first instant of the temporal extent of j, and the last instance of the temporal extent of i is earlier than the last instant of the temporal extent of j"@en-us ;
                                                                              annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'temporally overlaps' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                        "LA2: If both i and j are 'temporal intervals' and i 'temporally overlaps' j then the 'first instant’ of j ‘precedes’ the 'last instant of' i and the 'first instant of' i ‘precedes’ the 'first instant’ of j and the 'last instant of' i ‘precedes’ the 'last instant of' j" ,
                                                                                                                        "LA3: If both i and j are 'process' and i 'temporally overlaps' j then the 'temporal interval' that i occupies 'temporally overlaps' the 'temporal interval' that j occupies" ,
                                                                                                                        "LA4: i 'temporally overlaps' j if and only if there exists k that 'temporally finishes' i and 'temporally starts' j" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyStartedBy
<https://spec.industrialontologies.org/ontology/construct/temporallyStartedBy> rdf:type owl:ObjectProperty ;
                                                                               owl:inverseOf <https://spec.industrialontologies.org/ontology/construct/temporallyStarts> ;
                                                                               rdf:type owl:TransitiveProperty ;
                                                                               rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                               rdfs:label "temporally started by"@en-us ;
                                                                               skos:example "An internal combustion engine is temporally started (running) by the process of cranking; some machine is temporally started (running) by pressing a switch; every year is temporally started by the New Year’s Day."@en-us ;
                                                                               annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                               annotation:firstOrderLogicAxiom "temporallyStartedBy(x,y) ↔ temporallyStarts(y,x)" ;
                                                                               annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of j is the same as first the instant of the temporal extent of i and the last instant of j precedes the last instant of i"@en-us ;
                                                                               annotation:semiFormalNaturalLanguageAxiom "'temporally started by' and 'temporally starts' are inverse relations" .


###  https://spec.industrialontologies.org/ontology/construct/temporallyStarts
<https://spec.industrialontologies.org/ontology/construct/temporallyStarts> rdf:type owl:ObjectProperty ,
                                                                                     owl:TransitiveProperty ;
                                                                            rdfs:isDefinedBy "https://spec.industrialontologies.org/ontology/core/Core/"^^xsd:anyURI ;
                                                                            rdfs:label "temporally starts"@en-us ;
                                                                            skos:example "the process of cranking temporally starts (the running of) an internal combustion engine; the pressing of a switch temporally starts (the running of) some machine; the New Year’s Day temporally starts a year."@en-us ;
                                                                            annotation:adaptedFrom "https://dl.acm.org/doi/10.1145/182.358434" ;
                                                                            annotation:firstOrderLogicAxiom "LA1: temporallyStarts(i,j) → (TemporalInterval(i) ∧ TemporalInterval(j)) ∨ (Process(i) ∧ Process(j))" ,
                                                                                                            "LA2: TemporalInterval(i) ∧ TemporalInterval(j) ∧ temporallyStarts(i,j) → ∃i1∃i2∃j1∃j2(TemporalInstant(i1) ∧ TemporalInstant(i2) ∧ TemporalInstant(j1) ∧ TemporalInstant(j2) ∧ hasFirstInstant(i,i1) ∧ hasLastInstant(i,i2) ∧ hasFirstInstant(j,j1) ∧ hasLastInstant(j,j2) ∧ occursSimultaneouslyWith(i1,j1) ∧ precedes(i2,j2))" ,
                                                                                                            "LA3: Process(i) ∧ Process(j) ∧ temporallyStarts(i,j) → ∃i1∃j1(TemporalInterval(i1) ∧ TemporalInterval(j1) ∧ occupiesTemporalRegion(i,i1) ∧ occupiesTemporalRegion(j,j1) ∧ temporallyStarts(i1,j1))" ,
                                                                                                            "LA4: temporallyStarts(i,j) ↔ ∃k∃l(meets(k,i) ∧ meets(k,j) ∧ before(i,l) ∧ meets(j,l))" ;
                                                                            annotation:naturalLanguageDefinition "relation that holds between two intervals or processes i and j when the first instant of the temporal extent of i is the same as first the instant of the temporal extent of j and the last instant of i precedes the last instant of j"@en-us ;
                                                                            annotation:semiFormalNaturalLanguageAxiom "LA1: If i 'temporally starts' j then either both are 'temporal intervals' or both are 'process'" ,
                                                                                                                      "LA2: If both i and j are 'temporal intervals' and i 'temporally starts' j then the 'first instant’ of i ‘occurs simultaneously with’ the 'first instant of' j and the 'last instant of' i 'precedes' the 'last instant of' j" ,
                                                                                                                      "LA3: If both i and j are 'process' and i 'temporally starts' j then the 'temporal interval' that i occupies 'temporally starts' the 'temporal interval' that j occupies" ,
                                                                                                                      "LA4: i 'temporally starts' j if and only if there exists k that 'meets' i and j and there exists l such that i is 'before' l and j 'meets' l" .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000002
copi:COPI_0000002 rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf <http://purl.obolibrary.org/obo/BFO_0000056> ;
                  owl:propertyChainAxiom ( <https://spec.industrialontologies.org/ontology/construct/hasFunction>
                                           <http://purl.obolibrary.org/obo/BFO_0000054>
                                         ) ;
                  terms:source "ODR-011 §4" ;
                  rdfs:comment "A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ∘ obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas funções projetadas."@pt-br ,
                               "The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ∘ obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions."@en ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "functionally participates in"@en ,
                             "participa funcionalmente em"@pt-br ;
                  annotation:explanatoryNote "Distingue a participação mediada por função da participação geral: obo:BFO_0000056 (participa em) vale sempre que um continuante toma parte em algum processo por qualquer razão; copi:participatesIn é entailada apenas pela cadeia hasFunction ∘ BFO_0000054 (tem realização). Uma bomba participa funcionalmente em toda operação de aumento de pressão de líquido que realiza sua função de bombeamento; BFO_0000056 vale adicionalmente para qualquer outro envolvimento."@pt-br ,
                                             "Distinguishes function-mediated from general participation: obo:BFO_0000056 (participates in) holds whenever a continuant takes part in any process for any reason; copi:participatesIn is entailed only via the chain hasFunction ∘ BFO_0000054 (has realization). A pump functionally participates in every liquid-pressure-increase operation that realizes its pumping function; BFO_0000056 additionally covers any other process involvement."@en ;
                  annotation:firstOrderLogicDefinition "∀x∀y (functionallyParticipatesIn(x,y) ↔ ∃f(hasFunction(x,f) ∧ hasRealization(f,y)))"@en ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A sub-propriedade de bfo:participatesIn (BFO_0000056) entailada exclusivamente pela cadeia iof-constr:hasFunction ∘ obo:BFO_0000054: um artefato material participa funcionalmente em todo processo que realiza uma de suas funções projetadas."@pt-br ,
                                                       "The sub-property of bfo:participatesIn (BFO_0000056) entailed exclusively by the chain iof-constr:hasFunction ∘ obo:BFO_0000054: a material artifact functionally participates in every process that realizes one of its designed functions."@en ;
                  annotation:semiFormalNaturalLanguageDefinition "x 'functionally participates in' y if and only if there exists a function f such that x 'has function' f and f 'has realization' y"@en ,
                                                                 "x 'participa funcionalmente em' y se e somente se existe uma função f tal que x 'tem função' f e f 'tem realização' y"@pt-br .


#################################################################
#    Classes
#################################################################

###  https://www.inf.ufrgs.br/ontologies/copi/ACElectricalPower
copi:ACElectricalPower rdf:type owl:Class ;
                       rdfs:label "a c electrical power"@en ,
                                  "potência elétrico de CA"@pt-br ;
                       skos:definition "A quality inhering in a material entity, constituting alternating-current electrical power delivered to petroleum production equipment to drive motors, instrumentation, or control systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AbsorptionProcess
copi:AbsorptionProcess rdf:type owl:Class ;
                       rdfs:label "absorption process"@en ,
                                  "processo de absorção"@pt-br ;
                       skos:definition "A planned process in which one or more gaseous components are transferred from a gas phase into a liquid absorbent phase through contact in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AccumulationFunction
copi:AccumulationFunction rdf:type owl:Class ;
                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:someValuesFrom copi:AccumulationProcess
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:allValuesFrom copi:AccumulationProcess
                                          ] ;
                          rdfs:label "accumulation function"@en ,
                                     "função de acumulação"@pt-br ;
                          skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the collection and temporary holding of fluid to buffer flow variations or build up inventory."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AccumulationProcess
copi:AccumulationProcess rdf:type owl:Class ;
                         rdfs:label "accumulation process"@en ,
                                    "processo de acumulação"@pt-br ;
                         skos:definition "A planned process in which fluid is collected and temporarily held in a vessel to buffer flow variations or build up inventory in a petroleum production system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ActuationFunction
copi:ActuationFunction rdf:type owl:Class ;
                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:someValuesFrom copi:ActuationProcess
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:allValuesFrom copi:ActuationProcess
                                       ] ;
                       rdfs:label "actuation function"@en ,
                                  "função de atuação"@pt-br ;
                       skos:definition "A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation."@en ,
                                       "A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms."@en ,
                                       "A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device."@en ,
                                       "A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components."@en ;
                       annotation:naturalLanguageDefinition "A DesignedFunction that is realized in an ActuationProcess and that consists in converting a control input to mechanical movement or force that positions or operates another equipment component, where the control input is provided manually by human operation."@en ,
                                                            "A DesignedFunction that is realized in an ActuationProcess and that consists in converting control signals or energy inputs into mechanical motion or force to operate other equipment such as valves, dampers, or positioning mechanisms."@en ,
                                                            "A DesignedFunction that is realized in an ActuationProcess and that consists in converting one form of energy into mechanical motion to operate a mechanism or device."@en ,
                                                            "A DesignedFunction that is realized in an ActuationProcess and that consists in the capacity to convert an input energy signal (electrical, pneumatic, or hydraulic) into controlled mechanical motion for operating other equipment components."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ActuationProcess
copi:ActuationProcess rdf:type owl:Class ;
                      rdfs:label "actuation process"@en ,
                                 "processo de atuação"@pt-br ;
                      skos:definition "A PlannedProcess in which a control signal or energy input is converted by an actuator into mechanical motion or force that operates or positions another piece of equipment according to control requirements."@en ,
                                      "A PlannedProcess in which an actuator converts a control input signal to mechanical movement or force, enabling the positioning or operation of controlled equipment such as valves, dampers, or switches."@en ,
                                      "A PlannedProcess in which an actuator converts input energy (electrical, pneumatic, or hydraulic) into mechanical motion to operate valves, dampers, or other control devices."@en ,
                                      "A PlannedProcess in which an actuator converts input energy into controlled mechanical motion to operate valves, dampers, or other equipment requiring remote or automated positioning."@en ;
                      annotation:naturalLanguageDefinition "A PlannedProcess in which a control signal or energy input is converted by an actuator into mechanical motion or force that operates or positions another piece of equipment according to control requirements."@en ,
                                                           "A PlannedProcess in which an actuator converts a control input signal to mechanical movement or force, enabling the positioning or operation of controlled equipment such as valves, dampers, or switches."@en ,
                                                           "A PlannedProcess in which an actuator converts input energy (electrical, pneumatic, or hydraulic) into mechanical motion to operate valves, dampers, or other control devices."@en ,
                                                           "A PlannedProcess in which an actuator converts input energy into controlled mechanical motion to operate valves, dampers, or other equipment requiring remote or automated positioning."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AgitationFunction
copi:AgitationFunction rdf:type owl:Class ;
                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:someValuesFrom copi:AgitationProcess
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:allValuesFrom copi:AgitationProcess
                                       ] ;
                       rdfs:label "agitation function"@en ,
                                  "função de agitação"@pt-br ;
                       skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the mechanical stirring of a liquid to promote mixing, suspension of solids, or heat transfer."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AgitationProcess
copi:AgitationProcess rdf:type owl:Class ;
                      rdfs:label "agitation process"@en ,
                                 "processo de agitação"@pt-br ;
                      skos:definition "A planned process in which a liquid is mechanically stirred or agitated to promote mixing, heat transfer, or suspension of solids in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AirPortion
copi:AirPortion rdf:type owl:Class ;
                rdfs:label "air portion"@en ,
                           "porção de ar"@pt-br ;
                skos:definition "A material artifact that constitutes a portion of air participating as an oxidant, carrier, or motive fluid in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AnodeFunction
copi:AnodeFunction rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                     owl:someValuesFrom copi:ElectrochemicalOxidationProcess
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                     owl:allValuesFrom copi:ElectrochemicalOxidationProcess
                                   ] ;
                   rdfs:label "anode function"@en ,
                              "função de proteção anódica"@pt-br ;
                   skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the supply of electrons to a cathodic protection circuit to prevent corrosion of a protected metallic structure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementMeasuringProbe
copi:AxialDisplacementMeasuringProbe rdf:type owl:Class ;
                                     rdfs:label "axial displacement measuring probe"@en ,
                                                "sonda axial de deslocamento de medição"@pt-br ;
                                     skos:definition "A material artifact that constitutes a proximity probe that measures the axial displacement of a rotating shaft in petroleum production rotating equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionFunction
copi:AxialDisplacementTransmissionFunction rdf:type owl:Class ;
                                           rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                             owl:someValuesFrom copi:AxialDisplacementTransmissionProcess
                                                           ] ,
                                                           [ rdf:type owl:Restriction ;
                                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                             owl:allValuesFrom copi:AxialDisplacementTransmissionProcess
                                                           ] ;
                                           rdfs:label "axial displacement transmission function"@en ,
                                                      "função de transmissão de deslocamento axial"@pt-br ;
                                           skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the measurement of axial displacement of a rotating shaft and the transmission of the corresponding signal to a monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/AxialDisplacementTransmissionProcess
copi:AxialDisplacementTransmissionProcess rdf:type owl:Class ;
                                          rdfs:label "axial displacement transmission process"@en ,
                                                     "processo de transmissão de deslocamento axial"@pt-br ;
                                          skos:definition "A planned process in which the axial displacement of a rotating shaft is measured and the corresponding signal transmitted to a remote monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BackflowPreventionProcess
copi:BackflowPreventionProcess rdf:type owl:Class ;
                               rdfs:label "backflow prevention process"@en ,
                                          "processo de prevenção de refluxo"@pt-br ;
                               skos:definition "A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction."@en ;
                               annotation:naturalLanguageDefinition "A PlannedProcess in which fluid flow reversal is prevented by a closure member that moves to block the flow path when upstream pressure falls below downstream pressure or when flow attempts to reverse direction."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BinaryFlowControlProcess
copi:BinaryFlowControlProcess rdf:type owl:Class ;
                              rdfs:subClassOf copi:COPI_0000033 ;
                              rdfs:label "binary flow control process"@en ,
                                         "processo de controle binário de fluxo"@pt-br ;
                              skos:definition "A process-controlled flow process in which a flow path is completely opened or closed to allow or prevent fluid passage through petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BoilingFunction
copi:BoilingFunction rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:someValuesFrom copi:BoilingProcess
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:allValuesFrom copi:BoilingProcess
                                     ] ;
                     rdfs:label "boiling function"@en ,
                                "função de ebulição"@pt-br ;
                     skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the conversion of a liquid into vapour by supplying heat at or above the liquid's boiling point."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BoilingProcess
copi:BoilingProcess rdf:type owl:Class ;
                    rdfs:label "boiling process"@en ,
                               "processo de ebulição"@pt-br ;
                    skos:definition "A planned process in which a liquid is converted into vapour by supplying thermal energy at or above its boiling point in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingFunction
copi:BottomHoleDrillingFunction rdf:type owl:Class ;
                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:someValuesFrom copi:BottomHoleDrillingProcess
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:allValuesFrom copi:BottomHoleDrillingProcess
                                                ] ;
                                rdfs:label "bottom hole drilling function"@en ,
                                           "função de perfuração de fundo de poço"@pt-br ;
                                skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the cutting and disintegration of subsurface rock at the bottom of a wellbore to advance the drill hole."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BottomHoleDrillingProcess
copi:BottomHoleDrillingProcess rdf:type owl:Class ;
                               rdfs:label "bottom hole drilling process"@en ,
                                          "processo de perfuração de fundo de poço"@pt-br ;
                               skos:definition "A planned process in which subsurface rock at the bottom of a wellbore is cut and disintegrated by a drill bit to advance the drill hole."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BraidedConductor
copi:BraidedConductor rdf:type owl:Class ;
                      rdfs:label "braided conductor"@en ,
                                 "condutor de trançado"@pt-br ;
                      skos:definition "A material artifact that constitutes an electrical conductor composed of braided or stranded wires providing flexibility and mechanical strength in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BrakingFunction
copi:BrakingFunction rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:someValuesFrom copi:BrakingProcess
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:allValuesFrom copi:BrakingProcess
                                     ] ;
                     rdfs:label "braking function"@en ,
                                "função de frenagem"@pt-br ;
                     skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the application of a retarding force to decelerate or hold stationary a rotating or translating mechanical component."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BrakingProcess
copi:BrakingProcess rdf:type owl:Class ;
                    rdfs:label "braking process"@en ,
                               "processo de frenagem"@pt-br ;
                    skos:definition "A planned process in which a retarding force is applied to decelerate or hold stationary a rotating or translating mechanical component in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/BranchPort
copi:BranchPort rdf:type owl:Class ;
                rdfs:subClassOf copi:FluidPort ;
                rdfs:label "bocal de ramal"@pt-br ,
                           "branch port"@en ;
                skos:definition "A material artifact that constitutes a branch outlet port on a manifold or pipe fitting through which flow is diverted to a secondary flow path."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000001
copi:COPI_0000001 rdf:type owl:Class ;
                  terms:source "ODR-009 Amendment A (2026-06-18): copi:Operation as explicit root universal; genus correction to iof-constr:PlannedProcess" ;
                  rdfs:comment "A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation."@en ,
                               "Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "operation"@en ,
                             "operação"@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (Operation(x) → PlannedProcess(x))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A planned process that an item of process-industry equipment is designed to bring about or take part in; a process-industry unit operation."@en ,
                                                       "Um processo planejado que um item de equipamento de indústria de processo é projetado para causar ou do qual é projetado para participar; uma operação unitária de indústria de processo."@pt-br ;
                  annotation:primitiveRationale "Root universal for process-industry unit operations in the chemical-engineering tradition (cf. each category's adaptedFrom). Members share a typed participation signature (material inputs/outputs) and differ by transformation effected; no single formal condition differentiates Operation from PlannedProcess in OWL — the differentia is OWL-inexpressible, standard for a BFO primitive. (ODR-009 Amendment A, 2026-06-18)"@en ,
                                                "Universal raiz para operações unitárias de indústria de processo na tradição da engenharia química (cf. adaptedFrom de cada categoria). Os membros compartilham uma assinatura de participação tipada (entradas/saídas materiais) e diferem pela transformação efetuada; nenhuma condição formal única diferencia Operation de PlannedProcess em OWL — a diferença é inexpressível em OWL, padrão para um primitivo BFO. (ODR-009 Emenda A, 2026-06-18)"@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is an 'operation' then x is a 'planned process'"@en ,
                                                            "se x é uma 'operação' então x é um 'processo planejado'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000003
copi:COPI_0000003 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "Bird, Stewart & Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part I: momentum transport." ,
                               "ODR-009" ;
                  rdfs:comment "A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion."@en ,
                               "Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "momentum transfer"@en ,
                             "transferência de quantidade de movimento"@pt-br ;
                  skos:example "Elevar a pressão de um líquido de processo; comprimir um gás; circular uma lama."@pt-br ,
                               "Raising the pressure of a process liquid; compressing a gas; circulating a slurry."@en ;
                  annotation:adaptedFrom "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering (fluid-flow operations)." ;
                  annotation:explanatoryNote "Includes pressure-raising operations on liquids and gases, and bulk transport/mixing. Its leaf operations LiquidPressureIncrease and GasPressureIncrease are disjoint."@en ,
                                             "Inclui operações de aumento de pressão de líquidos e gases, e transporte/mistura globais. Suas operações folha LiquidPressureIncrease e GasPressureIncrease são disjuntas."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (MomentumTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that imparts mechanical energy to a fluid, changing its pressure or inducing its bulk motion."@en ,
                                                       "Um processo que confere energia mecânica a um fluido, alterando sua pressão ou induzindo seu movimento global."@pt-br ;
                  annotation:primitiveRationale "A unit-operations class grounded in the McCabe-Smith-Harriott tradition; its members share a typed-participation envelope but no single formally necessary-and-sufficient differentia, so only the envelope is asserted in OWL."@en ,
                                                "Uma classe de operações unitárias fundamentada na tradição de McCabe-Smith-Harriott; seus membros compartilham um envelope de participação tipada mas nenhuma diferença formal necessária-e-suficiente única, de modo que apenas o envelope é asserido em OWL."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'momentum transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de quantidade de movimento' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000004
copi:COPI_0000004 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "Bird, Stewart & Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part II: energy transport." ,
                               "ODR-009" ;
                  rdfs:comment "A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream."@en ,
                               "Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "heat transfer"@en ,
                             "transferência de calor"@pt-br ;
                  skos:example "Aquecimento sensível de uma corrente de processo contra uma utilidade quente."@pt-br ,
                               "Sensible heating of a process stream against a hot utility."@en ;
                  annotation:firstOrderLogicAxiom "∀x (HeatTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that transfers thermal energy between materials (or to/from a material) without, in itself, changing the phase or chemical identity of the process stream."@en ,
                                                       "Um processo que transfere energia térmica entre materiais (ou de/para um material) sem, em si, alterar a fase ou a identidade química da corrente de processo."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a constância de fase e de identidade química que distingue a transferência de calor sensível não é capturada em OWL, de modo que apenas o envelope é asserido."@pt-br ,
                                                "Unit-operations class; the constancy of phase and chemical identity that distinguishes sensible heat transfer is not captured in OWL, so only the envelope is asserted."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'heat transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de calor' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000005
copi:COPI_0000005 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "Bird, Stewart & Lightfoot, Transport Phenomena, 2nd ed. (Wiley, 2002) — Part III: mass transport." ,
                               "ODR-009" ;
                  rdfs:comment "A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference."@en ,
                               "Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico)."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "mass transfer"@en ,
                             "transferência de massa"@pt-br ;
                  skos:example "Absorption of a gas component into a liquid solvent; stripping; distillation."@en ,
                               "Absorção de um componente gasoso em um solvente líquido; esgotamento (stripping); destilação."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (MassTransfer(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process in which one or more chemical species migrate between phases driven by a concentration (chemical-potential) difference."@en ,
                                                       "Um processo no qual uma ou mais espécies químicas migram entre fases impulsionadas por uma diferença de concentração (potencial químico)."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a migração interfásica que individua seus membros é declarada para folhas específicas (e.g. GasAbsorption) mas não no nível da categoria em OWL."@pt-br ,
                                                "Unit-operations class; the inter-phase migration that individuates its members is stated for specific leaves (e.g. GasAbsorption) but not at the category level in OWL."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'mass transfer' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'transferência de massa' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000006
copi:COPI_0000006 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "ODR-009" ;
                  rdfs:comment "A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction."@en ,
                               "Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "mechanical separation"@en ,
                             "separação mecânica"@pt-br ;
                  skos:example "Separação gravitacional trifásica; separação ciclônica; filtração; centrifugação."@pt-br ,
                               "Three-phase gravity separation; cyclonic separation; filtration; centrifugation."@en ;
                  annotation:firstOrderLogicAxiom "∀x (MechanicalSeparation(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that separates a heterogeneous mixture into fractions by mechanical means (gravity, centrifugal, or barrier forces) without phase change or chemical reaction."@en ,
                                                       "Um processo que separa uma mistura heterogênea em frações por meios mecânicos (forças gravitacionais, centrífugas ou de barreira) sem mudança de fase ou reação química."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a separação de uma alimentação heterogênea por força mecânica não é formalizada em OWL além do envelope."@pt-br ,
                                                "Unit-operations class; the partition of a heterogeneous feed by mechanical force is not formalised in OWL beyond the envelope."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'mechanical separation' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'separação mecânica' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000007
copi:COPI_0000007 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "ODR-009" ;
                  rdfs:comment "A process in which chemical species are consumed and new species, present in no input, are formed."@en ,
                               "Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "chemical reaction"@en ,
                             "reação química"@pt-br ;
                  skos:example "Fermentation of sugars to ethanol; combustion; catalytic conversion."@en ,
                               "Fermentação de açúcares a etanol; combustão; conversão catalítica."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (ChemicalReaction(x) → Process(x) ∧ ∃o,c(hasOutput(x,o) ∧ hasConstituent(o,c) ∧ ¬∃i,c1(hasInput(x,i) ∧ hasConstituent(i,c1) ∧ sameSubstance(c1,c))))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process in which chemical species are consumed and new species, present in no input, are formed."@en ,
                                                       "Um processo no qual espécies químicas são consumidas e novas espécies, presentes em nenhuma entrada, são formadas."@pt-br ;
                  annotation:primitiveRationale "Classe de processo unitário; a formação de uma espécie genuinamente nova é parcialmente caracterizada em FOL mas apenas o gênero é asserido em OWL."@pt-br ,
                                                "Unit-process class; the formation of a genuinely new species is partly characterised in FOL but only the genus is asserted in OWL."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'chemical reaction' then x is a 'process' whose output has a constituent substance that no input has"@en ,
                                                            "se x é uma 'reação química' então x é um 'processo' cuja saída tem uma substância constituinte que nenhuma entrada possui"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000008
copi:COPI_0000008 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "ODR-009" ;
                  rdfs:comment "A process that changes the physical state (phase) of a material without changing its chemical identity."@en ,
                               "Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "mudança de fase"@pt-br ,
                             "phase change"@en ;
                  skos:example "Evaporation; condensation; crystallisation."@en ,
                               "Evaporação; condensação; cristalização."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (PhaseChange(x) → Process(x) ∧ ∃i∃o(MaterialEntity(i) ∧ MaterialEntity(o) ∧ hasInput(x,i) ∧ hasOutput(x,o)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that changes the physical state (phase) of a material without changing its chemical identity."@en ,
                                                       "Um processo que altera o estado físico (fase) de um material sem alterar sua identidade química."@pt-br ;
                  annotation:primitiveRationale "Classe de operações unitárias; a mudança de fase a identidade química constante é declarada para folhas (e.g. Vaporization) mas não no nível da categoria em OWL."@pt-br ,
                                                "Unit-operations class; the change of phase at constant chemical identity is stated for leaves (e.g. Vaporization) but not at category level in OWL."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'phase change' then x is a 'process' that 'has input' some 'material entity' and 'has output' some 'material entity'"@en ,
                                                            "se x é uma 'mudança de fase' então x é um 'processo' que 'tem entrada' alguma 'entidade material' e 'tem saída' alguma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000009
copi:COPI_0000009 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "ODR-009" ;
                  rdfs:comment "A process that maintains a contained material's state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category."@en ,
                               "Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação)."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "contenção de material"@pt-br ,
                             "material containment"@en ;
                  skos:example "Armazenar petróleo cru em um tanque; amortecer líquido em um tambor de surto."@pt-br ,
                               "Holding crude in a storage tank; buffering liquid in a surge drum."@en ;
                  annotation:firstOrderLogicAxiom "∀x (MaterialContainment(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that maintains a contained material's state and identity over time; a limiting case in which the process input and output coincide. An auxiliary (non-transformation) category."@en ,
                                                       "Um processo que mantém o estado e a identidade de um material contido ao longo do tempo; um caso-limite no qual a entrada e a saída do processo coincidem. Uma categoria auxiliar (não-transformação)."@pt-br ;
                  annotation:primitiveRationale "Auxiliary category retained because all plant equipment must be classifiable; the input=output identity is the limiting characterisation, not a transformation."@en ,
                                                "Categoria auxiliar mantida porque todo equipamento de planta deve ser classificável; a identidade entrada=saída é a caracterização-limite, não uma transformação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'material containment' then x is a 'process' that 'has input' and 'has output' the same 'material entity'"@en ,
                                                            "se x é uma 'contenção de material' então x é um 'processo' que 'tem entrada' e 'tem saída' a mesma 'entidade material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000010
copi:COPI_0000010 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000001 ;
                  terms:source "ODR-009" ;
                  rdfs:comment "A process that modulates a flow without changing the material's substance, phase, or composition."@en ,
                               "Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "controle de fluxo"@pt-br ,
                             "flow control"@en ;
                  skos:example "Estrangular uma corrente por uma válvula de controle; isolar por uma válvula de bloqueio; aliviar sobrepressão."@pt-br ,
                               "Throttling a stream through a control valve; isolating via a shutoff valve; relieving overpressure."@en ;
                  annotation:firstOrderLogicAxiom "∀x (FlowControl(x) → Process(x) ∧ ∃m(MaterialEntity(m) ∧ hasInput(x,m) ∧ hasOutput(x,m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process that modulates a flow without changing the material's substance, phase, or composition."@en ,
                                                       "Um processo que modula um escoamento sem alterar a substância, a fase ou a composição do material."@pt-br ;
                  annotation:primitiveRationale "Auxiliary category; the conservation of substance/phase/composition under modulation is the characterisation and is not a material transformation."@en ,
                                                "Categoria auxiliar; a conservação de substância/fase/composição sob modulação é a caracterização e não é uma transformação material."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'flow control' then x is a 'process' that conserves the substance, phase and composition of its material participant"@en ,
                                                            "se x é um 'controle de fluxo' então x é um 'processo' que conserva a substância, a fase e a composição de seu participante material"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000011
copi:COPI_0000011 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000003 ;
                  owl:disjointWith copi:COPI_0000012 ;
                  terms:source "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, pumping)." ,
                               "ODR-011" ;
                  rdfs:comment "A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid's pressure."@en ,
                               "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "aumento de pressão de líquido"@pt-br ,
                             "liquid pressure increase"@en ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfLiquid> ;
                  annotation:firstOrderLogicDefinition "∀x (LiquidPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Liquid(m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A momentum-transfer operation whose fluid input is an incompressible liquid and whose effect is to raise that liquid's pressure."@en ,
                                                       "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um líquido incompressível e cujo efeito é elevar a pressão desse líquido."@pt-br ;
                  annotation:primitiveRationale "OWL 2 DL cannot express the phase constraint on the fluid input; the OWL form asserts only the genus (MomentumTransfer). The disjointness with GasPressureIncrease is asserted to carry the pump/compressor partition."@en ,
                                                "OWL 2 DL não consegue expressar a restrição de fase sobre a entrada fluida; a forma OWL assere apenas o gênero (MomentumTransfer). A disjunção com GasPressureIncrease é asserida para sustentar a partição bomba/compressor."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'liquid pressure increase' if and only if x is a 'momentum transfer' whose fluid input is a 'liquid'"@en ,
                                                                 "x é um 'aumento de pressão de líquido' se e somente se x é uma 'transferência de quantidade de movimento' cuja entrada fluida é um 'líquido'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000012
copi:COPI_0000012 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000003 ;
                  terms:source "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. §3 (fluid flow, compression)." ,
                               "ODR-011" ;
                  rdfs:comment "A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas's pressure."@en ,
                               "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "aumento de pressão de gás"@pt-br ,
                             "gas pressure increase"@en ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#PressureChangeOfGas> ;
                  annotation:firstOrderLogicDefinition "∀x (GasPressureIncrease(x) ↔ MomentumTransfer(x) ∧ ∃g(Gas(g) ∧ hasInput(x,g)) ∧ ∀m(hasInput(x,m) ∧ Fluid(m) → Gas(m)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A momentum-transfer operation whose fluid input is a compressible gas and whose effect is to raise that gas's pressure."@en ,
                                                       "Uma operação de transferência de quantidade de movimento cuja entrada fluida é um gás compressível e cujo efeito é elevar a pressão desse gás."@pt-br ;
                  annotation:primitiveRationale "As for LiquidPressureIncrease: the phase constraint is not expressible in OWL 2 DL; only the genus is asserted."@en ,
                                                "Como em LiquidPressureIncrease: a restrição de fase não é expressável em OWL 2 DL; apenas o gênero é asserido."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'gas pressure increase' if and only if x is a 'momentum transfer' whose fluid input is a 'gas'"@en ,
                                                                 "x é um 'aumento de pressão de gás' se e somente se x é uma 'transferência de quantidade de movimento' cuja entrada fluida é um 'gás'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000013
copi:COPI_0000013 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000005 ;
                  terms:source "Green & Southard (eds.), Perry's Chemical Engineers' Handbook, 9th ed. §14 (absorption and stripping)." ,
                               "ODR-011" ;
                  rdfs:comment "A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid."@en ,
                               "Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "absorção de gás"@pt-br ,
                             "gas absorption"@en ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Absorption> ;
                  annotation:adaptedFrom "Treybal, Mass-Transfer Operations." ;
                  annotation:firstOrderLogicDefinition "∀p (GasAbsorption(p) ↔ MassTransfer(p) ∧ ∃g,l,l2,c(hasInput(p,g) ∧ Gas(g) ∧ hasInput(p,l) ∧ Liquid(l) ∧ hasOutput(p,l2) ∧ Liquid(l2) ∧ derivesFrom(l2,l) ∧ hasConstituent(g,c) ∧ ¬∃c1(hasConstituent(l,c1) ∧ sameSubstance(c1,c)) ∧ ∃c2(hasConstituent(l2,c2) ∧ sameSubstance(c2,c))))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A mass-transfer operation in which a chemical species carried by an input gas, and absent from the input solvent, becomes a constituent of the output liquid."@en ,
                                                       "Uma operação de transferência de massa na qual uma espécie química transportada por um gás de entrada, e ausente do solvente de entrada, torna-se constituinte do líquido de saída."@pt-br ;
                  annotation:primitiveRationale "Although a full first-order definition is available, OWL 2 DL carries only the typed-participation envelope; the relational differentia (a constituent migrating gas->liquid) is FOL-only."@en ,
                                                "Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o envelope de participação tipada; a diferença relacional (um constituinte migrando gás->líquido) é apenas-FOL."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'gas absorption' if and only if x is a 'mass transfer' in which a substance carried by the input gas, absent from the input solvent, is a constituent of the output liquid"@en ,
                                                                 "x é uma 'absorção de gás' se e somente se x é uma 'transferência de massa' na qual uma substância transportada pelo gás de entrada, ausente do solvente de entrada, é constituinte do líquido de saída"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000014
copi:COPI_0000014 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000008 ;
                  terms:source "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. §16 (evaporation)." ,
                               "ODR-011" ;
                  rdfs:comment "A phase-change operation in which a liquid input is converted to a vapour output."@en ,
                               "Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "vaporization"@en ,
                             "vaporização"@pt-br ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process_extensionTGL25001.owl#Vaporization> ;
                  annotation:firstOrderLogicDefinition "∀x (Vaporization(x) ↔ PhaseChange(x) ∧ ∃l(Liquid(l) ∧ hasInput(x,l)) ∧ ∃v(Vapour(v) ∧ hasOutput(x,v) ∧ derivesFrom(v,l)))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A phase-change operation in which a liquid input is converted to a vapour output."@en ,
                                                       "Uma operação de mudança de fase na qual uma entrada líquida é convertida em uma saída de vapor."@pt-br ;
                  annotation:primitiveRationale "OWL 2 DL carrega apenas o gênero (PhaseChange); a derivação líquido-para-vapor é apenas-FOL."@pt-br ,
                                                "OWL 2 DL carries only the genus (PhaseChange); the liquid-to-vapour derivation is FOL-only."@en ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'vaporization' if and only if x is a 'phase change' whose liquid input gives rise to a vapour output"@en ,
                                                                 "x é uma 'vaporização' se e somente se x é uma 'mudança de fase' cuja entrada líquida dá origem a uma saída de vapor"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000015
copi:COPI_0000015 rdf:type owl:Class ;
                  terms:source "ODR-009" ;
                  rdfs:comment "A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess."@en ,
                               "Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "loss of containment"@en ,
                             "perda de contenção"@pt-br ;
                  annotation:explanatoryNote "Relevant to HAZOP and failure-propagation work built over COPI."@en ,
                                             "Relevante para trabalhos de HAZOP e propagação de falhas construídos sobre o COPI."@pt-br ;
                  annotation:firstOrderLogicAxiom "∀x (LossOfContainment(x) → Process(x) ∧ ¬PlannedProcess(x))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A process in which a contained material escapes its intended boundary. An unplanned process; deliberately not an iof-constr:PlannedProcess."@en ,
                                                       "Um processo no qual um material contido escapa de seu limite pretendido. Um processo não planejado; deliberadamente não um iof-constr:PlannedProcess."@pt-br ;
                  annotation:primitiveRationale "Included to make the bfo:Process rooting concrete: the same boundary-failure kind is failure-relevant (ISO 14224) and cannot be a PlannedProcess; a planned-only hierarchy would exclude it."@en ,
                                                "Incluída para tornar concreta a ancoragem em bfo:Process: o mesmo tipo de falha de barreira é relevante para falhas (ISO 14224) e não pode ser um PlannedProcess; uma hierarquia só-planejada o excluiria."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "if x is a 'loss of containment' then x is a 'process' and x is not a 'planned process'"@en ,
                                                            "se x é uma 'perda de contenção' então x é um 'processo' e x não é um 'processo planejado'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000016
copi:COPI_0000016 rdf:type owl:Class ;
                  terms:source "ODR-011" ,
                               "ODR-012" ;
                  rdfs:comment "A material artifact that bears a designed function realized in a momentum-transfer operation."@en ,
                               "Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "dispositivo de transferência de quantidade de movimento"@pt-br ,
                             "momentum-transfer device"@en ;
                  skos:example "bomba, compressor, ventilador, tubo, misturador"@pt-br ,
                               "pump, compressor, fan, pipe, mixer"@en ;
                  annotation:adaptedFrom "Unit-operations tradition (McCabe-Smith-Harriott); cross-checked against IEC 81346-2 codes G, M, W and ISO 14224 Annex A." ;
                  annotation:explanatoryNote "A dispersive (defined) category; a leaf declaring only its designed function is automatically classified here by the reasoner. Not asserted disjoint from the other equipment categories (selective partition)."@en ,
                                             "Uma categoria dispersiva (definida); uma folha que declara apenas sua função projetada é classificada aqui automaticamente pelo reasoner. Não asserida disjunta das demais categorias de equipamento (partição seletiva)."@pt-br ;
                  annotation:firstOrderLogicDefinition "∀x (MomentumTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MomentumTransfer(p) ∧ realizedIn(f,p))))" ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a momentum-transfer operation."@en ,
                                                       "Um artefato material que porta uma função projetada realizada em uma operação de transferência de quantidade de movimento."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'momentum-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'momentum transfer'"@en ,
                                                                 "x é um 'dispositivo de transferência de quantidade de movimento' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de quantidade de movimento'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000017
copi:COPI_0000017 rdf:type owl:Class ;
                  terms:source "ODR-011" ,
                               "ODR-012" ;
                  rdfs:comment "A material artifact that bears a designed function realized in a heat-transfer operation."@en ,
                               "Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "dispositivo de transferência de calor"@pt-br ,
                             "heat-transfer device"@en ;
                  skos:example "shell-and-tube exchanger, fired heater, reboiler"@en ,
                               "trocador casco-e-tubo, aquecedor a fogo direto, refervedor"@pt-br ;
                  annotation:adaptedFrom "Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 codes E, V." ;
                  annotation:explanatoryNote "Categoria definida; um artefato que porta uma função secundária (e.g. um refervedor que também vaporiza) adquire pertinências adicionais de categoria -- intencional, não um defeito."@pt-br ,
                                             "Defined category; an artifact bearing a secondary function (e.g. a reboiler that also vaporizes) acquires additional category memberships -- intended, not a defect."@en ;
                  annotation:firstOrderLogicDefinition "∀x (HeatTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(HeatTransfer(p) ∧ realizedIn(f,p))))" ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a heat-transfer operation."@en ,
                                                       "Um artefato material que porta uma função projetada realizada em uma operação de transferência de calor."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'heat-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'heat transfer'"@en ,
                                                                 "x é um 'dispositivo de transferência de calor' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de calor'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000018
copi:COPI_0000018 rdf:type owl:Class ;
                  terms:source "ODR-011" ,
                               "ODR-012" ;
                  rdfs:comment "A material artifact that bears a designed function realized in a mass-transfer operation."@en ,
                               "Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "dispositivo de transferência de massa"@pt-br ,
                             "mass-transfer device"@en ;
                  skos:example "absorber, stripper, distillation column, adsorber"@en ,
                               "absorvedor, esgotador, coluna de destilação, adsorvedor"@pt-br ;
                  annotation:adaptedFrom "Unit-operations tradition; ISO 14224 Annex A; IEC 81346-2 code V." ;
                  annotation:firstOrderLogicDefinition "∀x (MassTransferDevice(x) ↔ MaterialArtifact(x) ∧ ∃f(DesignedFunction(f) ∧ hasFunction(x,f) ∧ ∃p(MassTransfer(p) ∧ realizedIn(f,p))))" ;
                  annotation:isPrimitive "false"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A material artifact that bears a designed function realized in a mass-transfer operation."@en ,
                                                       "Um artefato material que porta uma função projetada realizada em uma operação de transferência de massa."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'mass-transfer device' if and only if x is a 'material artifact' that 'has function' some 'designed function' that is 'realized in' some 'mass transfer'"@en ,
                                                                 "x é um 'dispositivo de transferência de massa' se e somente se x é um 'artefato material' que 'tem função' alguma 'função projetada' que é 'realizada em' alguma 'transferência de massa'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000019
