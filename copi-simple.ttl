copi:ChromatographicSignal rdf:type owl:Class ;
                           rdfs:label "chromatographic signal"@en ,
                                      "sinal de cromatográfico"@pt-br ;
                           skos:definition "A measurement information content entity constituting a signal generated by a chromatographic detector representing the presence and concentration of chemical components in a process sample."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionFunction
copi:CircuitProtectionFunction rdf:type owl:Class ;
                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                 owl:someValuesFrom copi:CircuitProtectionProcess
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                 owl:allValuesFrom copi:CircuitProtectionProcess
                                               ] ;
                               rdfs:label "circuit protection function"@en ,
                                          "função de proteção de circuito"@pt-br ;
                               skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the automatic interruption or limitation of current in an electrical circuit to protect equipment from overload or fault conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CircuitProtectionProcess
copi:CircuitProtectionProcess rdf:type owl:Class ;
                              rdfs:label "circuit protection process"@en ,
                                         "processo de proteção de circuito"@pt-br ;
                              skos:definition "A planned process in which current in an electrical circuit is automatically interrupted or limited to protect equipment from overload or fault conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CleanedGasPortion
copi:CleanedGasPortion rdf:type owl:Class ;
                       rdfs:label "cleaned gas portion"@en ,
                                  "porção limpo de gás"@pt-br ;
                       skos:definition "A material artifact that constitutes a portion of gas from which impurities have been removed by petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CleanedSurface
copi:CleanedSurface rdf:type owl:Class ;
                    rdfs:label "cleaned surface"@en ,
                               "superfície limpo"@pt-br ;
                    skos:definition "A material artifact that constitutes a surface from which scale, deposits, or contaminants have been removed by a cleaning process in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CoalescenceProcess
copi:CoalescenceProcess rdf:type owl:Class ;
                        rdfs:label "coalescence process"@en ,
                                   "processo de coalescência"@pt-br ;
                        skos:definition "A planned process in which dispersed droplets of one phase aggregate within another to form larger droplets that can be more readily separated from the continuous phase."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CombustionFunction
copi:CombustionFunction rdf:type owl:Class ;
                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                          owl:someValuesFrom copi:CombustionProcess
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                          owl:allValuesFrom copi:CombustionProcess
                                        ] ;
                        rdfs:label "combustion function"@en ,
                                   "função de combustão"@pt-br ;
                        skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the exothermic chemical reaction of a fuel with an oxidant to produce heat and combustion products."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CombustionGasPortion
copi:CombustionGasPortion rdf:type owl:Class ;
                          rdfs:label "combustion gas portion"@en ,
                                     "porção de combustão de gás"@pt-br ;
                          skos:definition "A material artifact that constitutes a portion of gas undergoing or having undergone a combustion reaction in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CombustionProcess
copi:CombustionProcess rdf:type owl:Class ;
                       rdfs:label "combustion process"@en ,
                                  "processo de combustão"@pt-br ;
                       skos:definition "A planned process in which a fuel reacts exothermically with an oxidant to produce heat and combustion products in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CombustionProductPortion
copi:CombustionProductPortion rdf:type owl:Class ;
                              rdfs:label "combustion product portion"@en ,
                                         "porção de combustão de produto"@pt-br ;
                              skos:definition "A material artifact that constitutes a portion of the chemical products resulting from a combustion reaction in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CombustionProducts
copi:CombustionProducts rdf:type owl:Class ;
                        rdfs:label "combustion products"@en ,
                                   "produtos de combustão"@pt-br ;
                        skos:definition "A material artifact that constitutes the chemical products—primarily carbon dioxide and water vapour—resulting from the combustion of a fuel in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CompositionAnalysisData
copi:CompositionAnalysisData rdf:type owl:Class ;
                             rdfs:label "composition analysis data"@en ,
                                        "dados de composição de análise"@pt-br ;
                             skos:definition "An information content entity constituting data representing the chemical composition of a process fluid as determined by analytical instrumentation in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CompressedAirPortion
copi:CompressedAirPortion rdf:type owl:Class ;
                          rdfs:label "compressed air portion"@en ,
                                     "porção comprimido de ar"@pt-br ;
                          skos:definition "A material artifact that constitutes a portion of air that has been compressed to a pressure above atmospheric for use in pneumatic systems of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CompressedGasPortion
copi:CompressedGasPortion rdf:type owl:Class ;
                          rdfs:label "compressed gas portion"@en ,
                                     "porção comprimido de gás"@pt-br ;
                          skos:definition "A material artifact that constitutes a portion of gas that has been compressed to a higher pressure for transport, storage, or processing in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CompressionProcess
copi:CompressionProcess rdf:type owl:Class ;
                        rdfs:label "compression process"@en ,
                                   "processo de compressão"@pt-br ;
                        skos:definition "A planned process in which the pressure of a gas is increased by reducing its volume through mechanical work applied by petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CompressorInternals
copi:CompressorInternals rdf:type owl:Class ;
                         rdfs:label "compressor internals"@en ,
                                    "internos de compressor"@pt-br ;
                         skos:definition "A material artifact that constitutes the internal components—such as impellers, valves, and seals—contained within the casing of a compressor in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CondensationFunction
copi:CondensationFunction rdf:type owl:Class ;
                          rdfs:subClassOf [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:someValuesFrom copi:CondensationProcess
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:allValuesFrom copi:CondensationProcess
                                          ] ;
                          rdfs:label "condensation function"@en ,
                                     "função de condensação"@pt-br ;
                          skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the conversion of a vapour into liquid by removing thermal energy until the substance reaches its dew point."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CondensationProcess
copi:CondensationProcess rdf:type owl:Class ;
                         rdfs:label "condensation process"@en ,
                                    "processo de condensação"@pt-br ;
                         skos:definition "A planned process in which a vapour is converted into liquid by removing thermal energy until the substance reaches its dew point in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionFunction
