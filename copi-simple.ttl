copi:SealedJoint rdf:type owl:Class ;
                 rdfs:label "junta selado"@pt-br ,
                            "sealed joint"@en ;
                 skos:definition "A material artifact that constitutes a joint between two components in petroleum production equipment that is sealed to prevent leakage of process fluid."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/SealingFunction
copi:SealingFunction rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:someValuesFrom copi:SealingProcess
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:allValuesFrom copi:SealingProcess
                                     ] ;
                     rdfs:label "função de vedação"@pt-br ,
                                "sealing function"@en ;
