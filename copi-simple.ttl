copi:RockCuttings rdf:type owl:Class ;
                  rdfs:label "cascalhos de rocha"@pt-br ,
                             "rock cuttings"@en ;
                  skos:definition "A material artifact that constitutes rock fragments produced by the drill bit during drilling and transported to surface by the circulating drilling fluid."@en .


