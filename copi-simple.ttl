###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction
copi:ElectricalConductionFunction rdf:type owl:Class ;
                                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom copi:ElectricalConductionProcess
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:allValuesFrom copi:ElectricalConductionProcess
                                                  ] ;
                                  rdfs:label "electrical conduction function"@en ,
                                             "função de condução elétrica"@pt-br ;
                                  skos:definition "A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly."@en ,
                                                  "A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission."@en ;
                                  annotation:naturalLanguageDefinition "A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly."@en ,
                                                                       "A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess
copi:ElectricalConductionProcess rdf:type owl:Class ;
                                 rdfs:label "electrical conduction process"@en ,
                                            "processo de condução elétrica"@pt-br ;
                                 skos:definition "A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system."@en ,
                                                 "A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices."@en ;
                                 annotation:naturalLanguageDefinition "A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system."@en ,
                                                                      "A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionFunction
copi:ElectricalConnectionFunction rdf:type owl:Class ;
                                  rdfs:subClassOf copi:ConnectionFunction ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom copi:ElectricalConnectionProcess
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:allValuesFrom copi:ElectricalConnectionProcess
                                                  ] ;
                                  rdfs:label "electrical connection function"@en ,
                                             "função de conexão elétrica"@pt-br ;
                                  skos:definition "A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint."@en ;
                                  annotation:naturalLanguageDefinition "A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess
copi:ElectricalConnectionProcess rdf:type owl:Class ;
                                 rdfs:label "electrical connection process"@en ,
                                            "processo de conexão elétrica"@pt-br ;
                                 skos:definition "A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection."@en ;
                                 annotation:naturalLanguageDefinition "A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrent
copi:ElectricalCurrent rdf:type owl:Class ;
                       rdfs:label "corrente elétrico"@pt-br ,
                                  "electrical current"@en ;
                       skos:definition "A process in which the flow of electric charge through a conductor in an electrical circuit of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentFlow
copi:ElectricalCurrentFlow rdf:type owl:Class ;
                           rdfs:label "electrical current flow"@en ,
                                      "fluxo elétrico de corrente"@pt-br ;
                           skos:definition "A process in which the directed movement of electric charge carriers through a conductor in petroleum production electrical systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalCurrentInterruptionProcess
copi:ElectricalCurrentInterruptionProcess rdf:type owl:Class ;
                                          rdfs:label "electrical current interruption process"@en ,
                                                     "processo de interrupção de corrente elétrica"@pt-br ;
                                          skos:definition "A planned process in which an electrical circuit is opened to stop the flow of current, either under normal operating conditions or in response to a fault."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalEnergyPortion
copi:ElectricalEnergyPortion rdf:type owl:Class ;
                             rdfs:label "electrical energy portion"@en ,
                                        "porção elétrico de energia"@pt-br ;
                             skos:definition "A material artifact that constitutes a quantity of electrical energy supplied to or consumed by petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalPowerTransformationProcess
copi:ElectricalPowerTransformationProcess rdf:type owl:Class ;
                                          rdfs:label "electrical power transformation process"@en ,
                                                     "processo de transformação de energia elétrica"@pt-br ;
                                          skos:definition "A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level."@en ,
                                                          "A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system."@en ;
                                          annotation:naturalLanguageDefinition "A PlannedProcess in which electrical energy is converted from one voltage level to another by a transformer through electromagnetic induction between primary and secondary windings, resulting in power transfer at the desired voltage level."@en ,
                                                                               "A PlannedProcess in which electrical power at one voltage and current level is converted to electrical power at a different voltage and current level through electromagnetic induction in a transformer winding system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalSignal
copi:ElectricalSignal rdf:type owl:Class ;
                      rdfs:label "electrical signal"@en ,
                                 "sinal elétrico"@pt-br ;
                      skos:definition "An information content entity constituting an electrical signal carrying a measurement, control, or status value within petroleum production instrumentation and control systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalSwitch
copi:ElectricalSwitch rdf:type owl:Class ;
                      rdfs:label "electrical switch"@en ,
                                 "interruptor elétrico"@pt-br ;
                      skos:definition "A material artifact that constitutes a device that opens or closes an electrical circuit in response to a manual or automatic input in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectrochemicalOxidationProcess
copi:ElectrochemicalOxidationProcess rdf:type owl:Class ;
                                     rdfs:label "electrochemical oxidation process"@en ,
                                                "processo de oxidação eletroquímica"@pt-br ;
                                     skos:definition "A planned process in which a material is oxidised at an electrode surface through an electrochemical reaction, such as in cathodic protection or electrochemical sensing."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectromagneticRadiation
copi:ElectromagneticRadiation rdf:type owl:Class ;
                              rdfs:label "electromagnetic radiation"@en ,
                                         "radiação eletromagnético"@pt-br ;
                              skos:definition "A process in which electromagnetic energy—such as infrared or ultraviolet radiation—detected or emitted by petroleum production instrumentation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EmergencyShutDownProcess
copi:EmergencyShutDownProcess rdf:type owl:Class ;
                              rdfs:label "emergency shut down process"@en ,
                                         "processo de parada de emergência"@pt-br ;
                              skos:definition "A planned process in which process flows or equipment are rapidly and automatically isolated in response to a detected hazardous condition."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnclosureFunction
copi:EnclosureFunction rdf:type owl:Class ;
                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:someValuesFrom copi:EnclosureProcess
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:allValuesFrom copi:EnclosureProcess
                                       ] ;
                       rdfs:label "enclosure function"@en ,
                                  "função de proteção e invólucro"@pt-br ;
                       skos:definition "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points."@en ,
                                       "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity."@en ,
                                       "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components."@en ,
                                       "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms."@en ,
                                       "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components."@en ,
                                       "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity."@en ,
                                       "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems."@en ,
                                       "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions."@en ;
                       annotation:naturalLanguageDefinition "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary around internal components while maintaining structural integrity and enabling controlled fluid flow through integral connection points."@en ,
                                                            "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that contains, supports, and isolates internal components from external environment while maintaining structural integrity."@en ,
                                                            "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective boundary that separates an internal space from the external environment while providing structural support for contained components."@en ,
                                                            "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a protective housing or containment boundary for internal components or mechanisms."@en ,
                                                            "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that contains and directs fluid flow while accommodating internal flow control components."@en ,
                                                            "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing a structural boundary that houses and protects internal mechanical components from the environment while maintaining structural integrity."@en ,
                                                            "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing physical containment and environmental protection for internal components or systems."@en ,
                                                            "A DesignedFunction that is realized in an EnclosureProcess and that consists in providing protective containment and structural support for internal mechanical components, maintaining their spatial arrangement and protecting them from external environmental conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnclosureProcess
copi:EnclosureProcess rdf:type owl:Class ;
                      rdfs:label "enclosure process"@en ,
                                 "processo de proteção e invólucro"@pt-br ;
                      skos:definition "A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies."@en ,
                                      "A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance."@en ,
                                      "A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries."@en ,
                                      "A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation."@en ,
                                      "A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment."@en ,
                                      "A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations."@en ,
                                      "A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow."@en ,
                                      "A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment."@en ;
                      annotation:naturalLanguageDefinition "A PlannedProcess in which a body or housing artifact provides structural containment and protection for internal mechanical components or assemblies."@en ,
                                                           "A PlannedProcess in which a casing provides protective containment around internal components, maintaining their operational environment and structural integrity while allowing controlled access for maintenance."@en ,
                                                           "A PlannedProcess in which a casing provides protective containment around mechanical components while enabling controlled fluid passage through designed openings and maintaining pressure boundaries."@en ,
                                                           "A PlannedProcess in which a housing artifact creates and maintains a protective boundary around internal components, simultaneously providing structural support and environmental separation."@en ,
                                                           "A PlannedProcess in which a housing or casing provides containment and protection for internal components, maintaining separation between the internal mechanism and external environment."@en ,
                                                           "A PlannedProcess in which a housing structure provides physical containment and environmental protection for internal components, shielding them from external conditions such as moisture, dust, mechanical impact, and temperature variations."@en ,
                                                           "A PlannedProcess in which a structural body provides containment and directional guidance for fluid flow while housing internal valve components that control the flow."@en ,
                                                           "A PlannedProcess in which a structural housing provides containment and protection for mechanical components, creating a defined boundary between internal mechanisms and the external environment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionFunction
copi:EnergyDiffusionFunction rdf:type owl:Class ;
                             rdfs:subClassOf [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                               owl:someValuesFrom copi:EnergyDiffusionProcess
                                             ] ,
                                             [ rdf:type owl:Restriction ;
                                               owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                               owl:allValuesFrom copi:EnergyDiffusionProcess
                                             ] ;
                             rdfs:label "energy diffusion function"@en ,
                                        "função de difusão de energia"@pt-br ;
                             skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the dispersion of thermal, acoustic, or kinetic energy over a larger volume or surface to reduce its local intensity."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnergyDiffusionProcess
copi:EnergyDiffusionProcess rdf:type owl:Class ;
                            rdfs:label "energy diffusion process"@en ,
                                       "processo de difusão de energia"@pt-br ;
                            skos:definition "A planned process in which thermal, acoustic, or kinetic energy is dispersed over a larger volume or surface to reduce its local intensity."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionFunction
copi:EnergyExtractionFunction rdf:type owl:Class ;
                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:someValuesFrom copi:EnergyExtractionProcess
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:allValuesFrom copi:EnergyExtractionProcess
                                              ] ;
                              rdfs:label "energy extraction function"@en ,
                                         "função de extração de energia"@pt-br ;
                              skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the recovery of useful work or heat from a process stream, pressure differential, or thermal source."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnergyExtractionProcess
copi:EnergyExtractionProcess rdf:type owl:Class ;
                             rdfs:label "energy extraction process"@en ,
                                        "processo de extração de energia"@pt-br ;
                             skos:definition "A planned process in which useful work or heat is recovered from a process stream, pressure differential, or thermal source in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnergyPortion
copi:EnergyPortion rdf:type owl:Class ;
                   rdfs:label "energy portion"@en ,
                              "porção de energia"@pt-br ;
                   skos:definition "A material artifact that constitutes a quantity of energy in a defined form that participates in a process within petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferFunction
copi:EnergyTransferFunction rdf:type owl:Class ;
                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:someValuesFrom copi:EnergyTransferProcess
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:allValuesFrom copi:EnergyTransferProcess
                                            ] ;
                            rdfs:label "energy transfer function"@en ,
                                       "função de transferência de energia"@pt-br ;
                            skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the movement of energy in the form of heat, work, or electromagnetic radiation from one medium or system to another."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EnergyTransferProcess
copi:EnergyTransferProcess rdf:type owl:Class ;
                           rdfs:label "energy transfer process"@en ,
                                      "processo de transferência de energia"@pt-br ;
                           skos:definition "A planned process in which energy in the form of heat, work, or electromagnetic radiation is transferred from one medium or system to another."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EquipmentItem
copi:EquipmentItem rdf:type owl:Class ;
                   rdfs:label "equipment item"@en ,
                              "item de equipamento"@pt-br ;
                   skos:definition "A material artifact that constitutes a discrete item of petroleum production equipment assembled or installed as a unit within a production system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportFunction
copi:EquipmentSupportFunction rdf:type owl:Class ;
                              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:someValuesFrom copi:EquipmentSupportProcess
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:allValuesFrom copi:EquipmentSupportProcess
                                              ] ;
                              rdfs:label "equipment support function"@en ,
                                         "função de suporte de equipamento"@pt-br ;
                              skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the mechanical support of process equipment to maintain its position and transmit loads to a structural foundation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/EquipmentSupportProcess
copi:EquipmentSupportProcess rdf:type owl:Class ;
                             rdfs:label "equipment support process"@en ,
                                        "processo de suporte de equipamento"@pt-br ;
                             skos:definition "A planned process in which process equipment is mechanically supported to maintain its position and transmit structural loads to a foundation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ExhaustGas
copi:ExhaustGas rdf:type owl:Class ;
                rdfs:label "exhaust gas"@en ,
                           "gás de escapamento"@pt-br ;
                skos:definition "A material artifact that constitutes the combustion exhaust gas discharged from an engine, turbine, or fired heater in a petroleum production installation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ExhaustGasPortion
copi:ExhaustGasPortion rdf:type owl:Class ;
                       rdfs:label "exhaust gas portion"@en ,
                                  "porção de escapamento de gás"@pt-br ;
                       skos:definition "A material artifact that constitutes a portion of exhaust gas at a defined point in the exhaust system of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ExpandedGasPortion
copi:ExpandedGasPortion rdf:type owl:Class ;
                        rdfs:label "expanded gas portion"@en ,
                                   "porção expandido de gás"@pt-br ;
                        skos:definition "A material artifact that constitutes a portion of gas that has undergone expansion and pressure reduction in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FilterMedium
copi:FilterMedium rdf:type owl:Class ;
                  rdfs:label "filter medium"@en ,
                             "meio de filtro"@pt-br ;
                  skos:definition "A material artifact that constitutes the porous material through which a fluid stream passes to remove suspended particulates or liquid droplets in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FilteredConstituents
copi:FilteredConstituents rdf:type owl:Class ;
                          rdfs:label "constituintes filtrado"@pt-br ,
                                     "filtered constituents"@en ;
                          skos:definition "A material artifact that constitutes the fluid constituents that pass through a filter medium during a filtration process in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FilteredContaminants
copi:FilteredContaminants rdf:type owl:Class ;
                          rdfs:label "contaminantes filtrado"@pt-br ,
                                     "filtered contaminants"@en ;
                          skos:definition "A material artifact that constitutes the solid or liquid contaminants captured and retained by a filter medium during a filtration process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FilteredFluidPortion
copi:FilteredFluidPortion rdf:type owl:Class ;
                          rdfs:label "filtered fluid portion"@en ,
                                     "porção filtrado de fluido"@pt-br ;
                          skos:definition "A material artifact that constitutes a portion of fluid from which particulate or liquid contaminants have been removed by filtration."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FiltrationProcess
copi:FiltrationProcess rdf:type owl:Class ;
                       rdfs:label "filtration process"@en ,
                                  "processo de filtração"@pt-br ;
                       skos:definition "A PlannedProcess in which particles, contaminants, or unwanted substances are selectively retained from a fluid stream by a filter element through mechanical screening or other separation mechanisms while clean fluid passes through."@en ;
                       annotation:naturalLanguageDefinition "A PlannedProcess in which particles, contaminants, or unwanted substances are selectively retained from a fluid stream by a filter element through mechanical screening or other separation mechanisms while clean fluid passes through."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FinnedTube
copi:FinnedTube rdf:type owl:Class ;
                rdfs:label "finned tube"@en ,
                           "tubo de aletado"@pt-br ;
                skos:definition "A material artifact that constitutes a heat transfer tube with extended surfaces—fins—that increase the external surface area to enhance heat exchange with a gas stream."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingFunction
copi:FiredHeatingFunction rdf:type owl:Class ;
                          rdfs:subClassOf copi:COPI_0000190 ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:someValuesFrom copi:FiredHeatingProcess
                                          ] ,
                                          [ rdf:type owl:Restriction ;
                                            owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                            owl:allValuesFrom copi:FiredHeatingProcess
                                          ] ;
                          rdfs:label "fired heating function"@en ,
                                     "função de aquecimento a combustão"@pt-br ;
                          skos:definition "A heating function borne by petroleum production equipment whose realization constitutes the transfer of thermal energy generated by combustion to a process stream or vessel."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FiredHeatingProcess
copi:FiredHeatingProcess rdf:type owl:Class ;
                         rdfs:subClassOf copi:HeatingProcess ;
                         rdfs:label "fired heating process"@en ,
                                    "processo de aquecimento a combustão"@pt-br ;
                         skos:definition "A heating process in which thermal energy is generated by the combustion of fuel and transferred to a process stream or vessel through a fired heater."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlameArrestFunction
copi:FlameArrestFunction rdf:type owl:Class ;
                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:someValuesFrom copi:FlameArrestProcess
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:allValuesFrom copi:FlameArrestProcess
                                         ] ;
                         rdfs:label "flame arrest function"@en ,
                                    "função de contenção de chama"@pt-br ;
                         skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the prevention of flame propagation through a flammable gas mixture by quenching the flame front in narrow passages."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlameArrestProcess
copi:FlameArrestProcess rdf:type owl:Class ;
                        rdfs:label "flame arrest process"@en ,
                                   "processo de contenção de chama"@pt-br ;
                        skos:definition "A planned process in which flame propagation through a flammable gas mixture is prevented by quenching the flame front in narrow passages of a flame arrester."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionFunction
copi:FlameDetectionFunction rdf:type owl:Class ;
                            rdfs:subClassOf copi:DetectionFunction ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:someValuesFrom copi:FlameDetectionProcess
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:allValuesFrom copi:FlameDetectionProcess
                                            ] ;
                            rdfs:label "flame detection function"@en ,
                                       "função de detecção de chama"@pt-br ;
                            skos:definition "A detection function borne by petroleum production equipment whose realization constitutes the sensing of the presence of a flame or combustion event by detecting radiant energy or other combustion signatures."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlameDetectionProcess
copi:FlameDetectionProcess rdf:type owl:Class ;
                           rdfs:subClassOf copi:DetectionProcess ;
                           rdfs:label "flame detection process"@en ,
                                      "processo de detecção de chama"@pt-br ;
                           skos:definition "A detection process in which the presence of a flame or combustion event is sensed by detecting radiant energy or other combustion signatures."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationFunction
copi:FlashVaporizationFunction rdf:type owl:Class ;
                               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                 owl:someValuesFrom copi:FlashVaporizationProcess
                                               ] ,
                                               [ rdf:type owl:Restriction ;
                                                 owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                 owl:allValuesFrom copi:FlashVaporizationProcess
                                               ] ;
                               rdfs:label "flash vaporization function"@en ,
                                          "função de vaporização flash"@pt-br ;
                               skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the partial vaporisation of a pressurised liquid stream caused by a rapid reduction in pressure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlashVaporizationProcess
copi:FlashVaporizationProcess rdf:type owl:Class ;
                              rdfs:label "flash vaporization process"@en ,
                                         "processo de vaporização flash"@pt-br ;
                              skos:definition "A planned process in which a pressurised liquid stream is partially vaporised as a result of a rapid reduction in pressure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlexibleDiaphragm
copi:FlexibleDiaphragm rdf:type owl:Class ;
                       rdfs:label "diafragma flexível"@pt-br ,
                                  "flexible diaphragm"@en ;
                       skos:definition "A material artifact that constitutes a flexible membrane that separates two chambers and transmits pressure between them in petroleum production measurement or control equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowControlProcess
copi:FlowControlProcess rdf:type owl:Class ;
                        rdfs:label "flow control process"@en ,
                                   "processo de controle de fluxo"@pt-br ;
                        skos:definition "A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics."@en ,
                                        "A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics."@en ,
                                        "A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages."@en ;
                        annotation:naturalLanguageDefinition "A PlannedProcess in which fluid flow is permitted, obstructed, diverted or regulated through the mechanical positioning of a closure member within the flow stream, resulting in the desired flow characteristics."@en ,
                                                             "A PlannedProcess in which fluid flow is regulated, directed, or restricted through a valve body by positioning internal closure elements to achieve desired flow characteristics."@en ,
                                                             "A PlannedProcess in which the flow of fluid through a conduit is regulated, directed, or interrupted by mechanical means, typically involving the movement of closure elements against seating surfaces to modify flow passages."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowIndicationProcess
copi:FlowIndicationProcess rdf:type owl:Class ;
                           rdfs:label "flow indication process"@en ,
                                      "processo de indicação de fluxo"@pt-br ;
                           skos:definition "A planned process in which the instantaneous flow rate of a process stream is measured and displayed locally or transmitted to a remote monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurement
copi:FlowMeasurement rdf:type owl:Class ;
                     rdfs:label "flow measurement"@en ,
                                "medição de fluxo"@pt-br ;
                     skos:definition "A measurement information content entity constituting a quantitative value representing the flow rate of a process stream as measured by petroleum production instrumentation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowMeasurementProcess
copi:FlowMeasurementProcess rdf:type owl:Class ;
                            rdfs:label "flow measurement process"@en ,
                                       "processo de medição de fluxo"@pt-br ;
                            skos:definition "A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications."@en ;
                            annotation:naturalLanguageDefinition "A PlannedProcess in which a measuring element determines the flow rate of a fluid by sensing flow-related physical phenomena and converting them into measurable signals or indications."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowModificationFunction
copi:FlowModificationFunction rdf:type owl:Class ;
                              rdfs:subClassOf copi:COPI_0000026 ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:someValuesFrom copi:FlowModificationProcess
                                              ] ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:allValuesFrom copi:FlowModificationProcess
                                              ] ;
                              rdfs:label "flow modification function"@en ,
                                         "função de modificação de fluxo"@pt-br ;
                              skos:definition "A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction."@en ;
                              annotation:naturalLanguageDefinition "A FlowControlFunction that is realized in a FlowModificationProcess and that consists in altering the characteristics of fluid flow (such as velocity profile, turbulence, pressure drop pattern, or flow distribution) without primarily controlling the flow rate or direction."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowModificationProcess
copi:FlowModificationProcess rdf:type owl:Class ;
                             rdfs:label "flow modification process"@en ,
                                        "processo de modificação de fluxo"@pt-br ;
                             skos:definition "A PlannedProcess in which the characteristics of fluid flow are altered by a flow modification accessory, resulting in changes to flow patterns, velocity profiles, turbulence levels, or pressure drop characteristics while the fluid passes through or around the device."@en ;
                             annotation:naturalLanguageDefinition "A PlannedProcess in which the characteristics of fluid flow are altered by a flow modification accessory, resulting in changes to flow patterns, velocity profiles, turbulence levels, or pressure drop characteristics while the fluid passes through or around the device."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowRestrictionProcess
copi:FlowRestrictionProcess rdf:type owl:Class ;
                            rdfs:label "flow restriction process"@en ,
                                       "processo de restrição de fluxo"@pt-br ;
                            skos:definition "A planned process in which the flow rate or pressure of a fluid stream is reduced in a controlled manner by introducing a fixed or variable resistance."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/FlowSignalTransmissionProcess
