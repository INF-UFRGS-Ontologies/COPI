copi:PositionSignal rdf:type owl:Class ;
                    rdfs:label "position signal"@en ,
                               "sinal de posição"@pt-br ;
                    skos:definition "A measurement information content entity constituting an electrical signal representing the position of a mechanical component in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PositionTransmissionFunction
copi:PositionTransmissionFunction rdf:type owl:Class ;
                                  rdfs:subClassOf copi:COPI_0000030 ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom copi:PositionMeasurementAndTransmissionProcess
