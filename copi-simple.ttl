copi:PipeShearingProcess rdf:type owl:Class ;
                         rdfs:label "pipe shearing process"@en ,
                                    "processo de corte de tubulação"@pt-br ;
                         skos:definition "A planned process in which a tubular string within a wellbore is mechanically cut to enable emergency well control."@en .


