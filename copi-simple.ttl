copi:PositionMeasurementAndTransmissionProcess rdf:type owl:Class ;
                                               rdfs:subClassOf copi:MeasurementProcess ;
                                               rdfs:label "position measurement and transmission process"@en ,
                                                          "processo de medição e transmissão de posição"@pt-br ;
                                               skos:definition "A measurement process in which the position of a mechanical component is measured and the corresponding signal transmitted to a remote control or monitoring system."@en .


