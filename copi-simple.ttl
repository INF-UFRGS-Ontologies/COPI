copi:TurbineSection rdf:type owl:Class ;
                    rdfs:label "seção de turbina"@pt-br ,
                               "turbine section"@en ;
                    skos:definition "An assembly of rotor blades, stator vanes, and casing components that extracts energy from a fluid stream in a turbine stage of petroleum production turbomachinery."@en .


