copi:VibrationSignal rdf:type owl:Class ;
                     rdfs:label "sinal de vibração"@pt-br ,
                                "vibration signal"@en ;
                     skos:definition "A measurement information content entity constituting an electrical signal representing the amplitude or frequency of mechanical vibration measured in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/VisualInformation
copi:VisualInformation rdf:type owl:Class ;
                       rdfs:label "informação visual"@pt-br ,
                                  "visual information"@en ;
                       skos:definition "An information content entity constituting visual information—such as a colour, indicator state, or display value—conveying process or equipment status to an operator."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionFunction
copi:VisualInspectionFunction rdf:type owl:Class ;
                              rdfs:subClassOf copi:COPI_0000029 ,
                                              [ rdf:type owl:Restriction ;
                                                owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                owl:someValuesFrom copi:VisualInspectionProcess
                                              ] ,
                                              [ rdf:type owl:Restriction ;
