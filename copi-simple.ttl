                                              ] ;
                              rdfs:label "função de inspeção visual"@pt-br ,
                                         "visual inspection function"@en ;
                              skos:definition "A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes."@en ;
                              annotation:naturalLanguageDefinition "A DesignedFunction that is realized in a VisualInspectionProcess and that consists in enabling direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems for operational monitoring, safety verification, or maintenance purposes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/VisualInspectionProcess
copi:VisualInspectionProcess rdf:type owl:Class ;
                             rdfs:label "processo de inspeção visual"@pt-br ,
                                        "visual inspection process"@en ;
                             skos:definition "A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state."@en ;
                             annotation:naturalLanguageDefinition "A PlannedProcess in which an operator or automated vision system directly observes the interior of a vessel or piping system through a transparent window or port to assess fluid level, flow conditions, phase behavior, contamination, or other visual indicators of process state."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/VisualSignal
