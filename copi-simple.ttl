                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom copi:ElectricalConnectionProcess
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:allValuesFrom copi:ElectricalConnectionProcess
                                                  ] ;
                                  rdfs:label "electrical connection function"@en ,
                                             "função de conexão elétrica"@pt-br ;
                                  annotation:naturalLanguageDefinition "A ConnectionFunction that is realized in an ElectricalConnectionProcess and that consists in maintaining intimate electrical contact between two or more electrical conductor parts to enable continuous current flow through the joint."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalConnectionProcess
copi:ElectricalConnectionProcess rdf:type owl:Class ;
                                 rdfs:label "electrical connection process"@en ,
                                            "processo de conexão elétrica"@pt-br ;
                                 annotation:naturalLanguageDefinition "A PlannedProcess in which two or more electrical conductor parts are held in intimate contact by an electrical connector, resulting in a conductive path that enables electrical current flow through the connection."@en .


