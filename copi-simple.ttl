###  https://www.inf.ufrgs.br/ontologies/copi/PigReceivingProcess
copi:PigReceivingProcess rdf:type owl:Class ;
                         rdfs:label "pig receiving process"@en ,
                                    "processo de recebimento de pig"@pt-br ;
                         skos:definition "A planned process in which a pipeline pig is retrieved and contained in a receiving trap after completing its passage through a pipeline."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PipePig
copi:PipePig rdf:type owl:Class ;
             rdfs:label "pig de tubo"@pt-br ,
                        "pipe pig"@en ;
             skos:definition "A material artifact that constitutes a device propelled through a pipeline by the flow of product to perform internal inspection, cleaning, or product separation."@en .


