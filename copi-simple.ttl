copi:SealingSystem rdf:type owl:Class ;
                   rdfs:label "sealing system"@en ,
                              "sistema de vedação"@pt-br ;
                   skos:definition "A material artifact that constitutes the assembly of seals, gaskets, and packing that prevents leakage between two components of petroleum production equipment."@en .


