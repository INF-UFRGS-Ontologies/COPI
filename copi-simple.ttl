                      rdfs:label "fluido de hidrocarboneto"@pt-br ,
                                 "hydrocarbon fluid"@en ;
                      skos:definition "A material artifact that constitutes a fluid consisting primarily of hydrocarbon compounds produced from or processed in a petroleum production system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InLineFilter
copi:InLineFilter rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000081 ;
                  rdfs:label "filtro em linha"@pt-br ,
                             "in line filter"@en ;
                  skos:definition "An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations."@en ;
                  annotation:firstOrderLogicAxiom "∀x (InLineFilter(x) → Filter(x) ∧ ∃m,e (InLineInstallation(m) ∧ ConnectedEquipment(e) ∧ hasInstallationMethod(x,m) ∧ supportedBy(x,e)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An in-line filter is a filter that is installed directly within a fluid line and supported by connected piping or equipment, designed to remove particles or contaminants from fluid streams during normal flow operations."@en ,
                                                       "Um filtro em linha é um filtro que é instalado diretamente dentro de uma linha de fluido e suportado por tubulações ou equipamentos conectados, projetado para remover partículas ou contaminantes de correntes de fluido durante operações normais de fluxo."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type defined by physical installation configuration. Under OWA, any filter with in-line connections and piping support could be classified as in-line filter, but specialized hybrid equipment or custom installations might have these features without belonging to the standard in-line filter maintenance category. Starting with necessary conditions protects against false positives."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every in-line filter is a filter that has an in-line installation method and is supported by connected equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/IndicationProcess
copi:IndicationProcess rdf:type owl:Class ;
                       rdfs:label "indication process"@en ,
                                  "processo de indicação"@pt-br ;
                       skos:definition "A planned process in which the value of a process variable is measured and displayed locally or transmitted to enable monitoring."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InformationBearingArtifact
copi:InformationBearingArtifact rdf:type owl:Class ;
                                rdfs:label "artefato de informação de mancal"@pt-br ,
                                           "information bearing artifact"@en ;
                                skos:definition "A material artifact that bears information—in the form of a signal, display, or record—representing a process variable or equipment state in petroleum production systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InformationBearingEntity
copi:InformationBearingEntity rdf:type owl:Class ;
                              rdfs:label "entidade de informação de mancal"@pt-br ,
                                         "information bearing entity"@en ;
                              skos:definition "An information content entity constituting that carries or encodes information representing a process variable, equipment state, or analytical result in petroleum production systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InformationContentEntity
copi:InformationContentEntity rdf:type owl:Class ;
                              rdfs:label "entidade de informação de conteúdo"@pt-br ,
                                         "information content entity"@en ;
                              skos:definition "An information content entity constituting the informational content—a measurement value, alarm state, or analysis result—encoded in a signal or record within petroleum production systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayFunction
copi:InformationDisplayFunction rdf:type owl:Class ;
                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:someValuesFrom copi:InformationDisplayProcess
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:allValuesFrom copi:InformationDisplayProcess
                                                ] ;
                                rdfs:label "função de exibição de informação"@pt-br ,
                                           "information display function"@en ;
                                skos:definition "A DesignedFunction that is realized in an InformationDisplayProcess and that consists in presenting or exhibiting information visually to operators or other users for the purpose of communication, monitoring, or decision-making."@en ;
                                annotation:naturalLanguageDefinition "A DesignedFunction that is realized in an InformationDisplayProcess and that consists in presenting or exhibiting information visually to operators or other users for the purpose of communication, monitoring, or decision-making."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InformationDisplayProcess
copi:InformationDisplayProcess rdf:type owl:Class ;
                               rdfs:label "information display process"@en ,
                                          "processo de exibição de informação"@pt-br ;
                               skos:definition "A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities."@en ;
                               annotation:naturalLanguageDefinition "A PlannedProcess in which information is visually presented or exhibited by a display device to operators or users, enabling communication, monitoring, or decision-making activities."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InformationSignal
copi:InformationSignal rdf:type owl:Class ;
                       rdfs:label "information signal"@en ,
                                  "sinal de informação"@pt-br ;
                       skos:definition "An information content entity constituting a signal carrying informational content such as a measurement value or status indication within petroleum production instrumentation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InjectionFunction
copi:InjectionFunction rdf:type owl:Class ;
                       rdfs:subClassOf [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:someValuesFrom copi:InjectionProcess
                                       ] ,
                                       [ rdf:type owl:Restriction ;
                                         owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                         owl:allValuesFrom copi:InjectionProcess
                                       ] ;
                       rdfs:label "função de injeção"@pt-br ,
                                  "injection function"@en ;
                       skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the introduction of a fluid, chemical, or material into a process stream, vessel, or wellbore under controlled conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InjectionProcess
copi:InjectionProcess rdf:type owl:Class ;
                      rdfs:label "injection process"@en ,
                                 "processo de injeção"@pt-br ;
                      skos:definition "A planned process in which a fluid, chemical, or material is introduced into a process stream, vessel, or wellbore under controlled conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InstrumentationProcess
copi:InstrumentationProcess rdf:type owl:Class ;
                            rdfs:label "instrumentation process"@en ,
                                       "processo de instrumentação"@pt-br ;
                            skos:definition "A planned process in which physical process variables are measured, transmitted, or controlled by instrumentation to enable monitoring and regulation of petroleum production operations."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InterfacingFunction
copi:InterfacingFunction rdf:type owl:Class ;
                         rdfs:subClassOf [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:someValuesFrom copi:InterfacingProcess
                                         ] ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                           owl:allValuesFrom copi:InterfacingProcess
                                         ] ;
                         rdfs:label "função de interfaceamento"@pt-br ,
                                    "interfacing function"@en ;
                         skos:definition "A DesignedFunction that is realized in an InterfacingProcess and that consists in providing a standardized point of interface for communication, connection, or interaction with another object or system."@en ;
                         annotation:naturalLanguageDefinition "A DesignedFunction that is realized in an InterfacingProcess and that consists in providing a standardized point of interface for communication, connection, or interaction with another object or system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/InterfacingProcess
copi:InterfacingProcess rdf:type owl:Class ;
                        rdfs:label "interfacing process"@en ,
                                   "processo de interfaceamento"@pt-br ;
                        skos:definition "A PlannedProcess in which a port establishes and maintains a point of interface that enables communication, connection, or interaction between distinct objects or systems."@en ;
                        annotation:naturalLanguageDefinition "A PlannedProcess in which a port establishes and maintains a point of interface that enables communication, connection, or interaction between distinct objects or systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/KineticMotion
copi:KineticMotion rdf:type owl:Class ;
                   rdfs:label "kinetic motion"@en ,
                              "movimento cinético"@pt-br ;
                   skos:definition "A process in which the directed mechanical motion of a component or fluid stream carrying kinetic energy in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationFunction
copi:KnockOutSeparationFunction rdf:type owl:Class ;
                                rdfs:subClassOf copi:COPI_0000195 ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:someValuesFrom copi:KnockOutSeparationProcess
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:allValuesFrom copi:KnockOutSeparationProcess
                                                ] ;
                                rdfs:label "função de separação knock-out"@pt-br ,
                                           "knock out separation function"@en ;
                                skos:definition "A separation function borne by petroleum production equipment whose realization constitutes the removal of entrained liquid droplets from a gas stream by gravity or inertial impingement."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/KnockOutSeparationProcess
copi:KnockOutSeparationProcess rdf:type owl:Class ;
                               rdfs:subClassOf copi:SeparationProcess ;
                               rdfs:label "knock out separation process"@en ,
                                          "processo de separação knock-out"@pt-br ;
                               skos:definition "A separation process in which entrained liquid droplets are removed from a gas stream by gravity or inertial impingement in a knockout vessel."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelDetectionProcess
copi:LevelDetectionProcess rdf:type owl:Class ;
                           rdfs:label "level detection process"@en ,
                                      "processo de detecção de nível"@pt-br ;
                           skos:definition "A planned process in which the fluid level within a vessel is detected as reaching a defined high or low threshold."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelIndicationProcess
copi:LevelIndicationProcess rdf:type owl:Class ;
                            rdfs:label "level indication process"@en ,
                                       "processo de indicação de nível"@pt-br ;
                            skos:definition "A planned process in which the fluid level within a vessel or container is measured and displayed locally or transmitted to a remote monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelInformation
copi:LevelInformation rdf:type owl:Class ;
                      rdfs:label "informação de nível"@pt-br ,
                                 "level information"@en ;
                      skos:definition "An information content entity constituting a measurement or display value representing the fluid level in a vessel of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelMeasurementAndTransmissionProcess
copi:LevelMeasurementAndTransmissionProcess rdf:type owl:Class ;
                                            rdfs:label "level measurement and transmission process"@en ,
                                                       "processo de medição e transmissão de nível"@pt-br ;
                                            skos:definition "A planned process in which the fluid level within a vessel is measured and the corresponding signal transmitted to a remote control or monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelSignal
copi:LevelSignal rdf:type owl:Class ;
                 rdfs:label "level signal"@en ,
                            "sinal de nível"@pt-br ;
                 skos:definition "A measurement information content entity constituting an electrical or pneumatic signal representing the fluid level in a vessel of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingFunction
copi:LevelSwitchingFunction rdf:type owl:Class ;
                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:someValuesFrom copi:LevelSwitchingProcess
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:allValuesFrom copi:LevelSwitchingProcess
                                            ] ;
                            rdfs:label "função de chaveamento de nível"@pt-br ,
                                       "level switching function"@en ;
                            skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the fluid level in a vessel crosses a defined high or low threshold."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LevelSwitchingProcess
copi:LevelSwitchingProcess rdf:type owl:Class ;
                           rdfs:label "level switching process"@en ,
                                      "processo de chaveamento de nível"@pt-br ;
                           skos:definition "A planned process in which a discrete switching signal is generated when the fluid level in a vessel crosses a defined high or low threshold."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LightPhase
copi:LightPhase rdf:type owl:Class ;
                rdfs:label "fase leve"@pt-br ,
                           "light phase"@en ;
                skos:definition "A material artifact that constitutes the less dense of two or more phases present in a separation process within petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LiquidMixturePortion
copi:LiquidMixturePortion rdf:type owl:Class ;
                          rdfs:label "liquid mixture portion"@en ,
                                     "porção líquido de mistura"@pt-br ;
                          skos:definition "A material artifact that constitutes a portion of a mixture of two or more liquid phases at a defined point in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LiquidPortion
copi:LiquidPortion rdf:type owl:Class ;
                   rdfs:label "liquid portion"@en ,
                              "porção líquido"@pt-br ;
                   skos:definition "A material artifact that constitutes a portion of liquid phase material at a defined point in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LocalPressureDisplay
copi:LocalPressureDisplay rdf:type owl:Class ;
                          rdfs:label "display local de pressão"@pt-br ,
                                     "local pressure display"@en ;
                          skos:definition "A measurement information content entity constituting an instrument mounted locally to a pressure measurement point that visually displays the process pressure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LocalTemperatureDisplay
copi:LocalTemperatureDisplay rdf:type owl:Class ;
                             rdfs:label "display local de temperatura"@pt-br ,
                                        "local temperature display"@en ;
                             skos:definition "A measurement information content entity constituting an instrument mounted locally to a temperature measurement point that visually displays the process temperature."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LoggingData
copi:LoggingData rdf:type owl:Class ;
                 rdfs:label "dados de perfilagem"@pt-br ,
                            "logging data"@en ;
                 skos:definition "An information content entity constituting data acquired by measurement tools deployed in a wellbore to characterise subsurface formation properties."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/LowPressureSignal
copi:LowPressureSignal rdf:type owl:Class ;
                       rdfs:label "low pressure signal"@en ,
                                  "sinal baixo de pressão"@pt-br ;
                       skos:definition "An information content entity constituting an electrical or pneumatic signal representing a low-pressure condition in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ManualControlSignal
copi:ManualControlSignal rdf:type owl:Class ;
                         rdfs:label "manual control signal"@en ,
                                    "sinal manual de controle"@pt-br ;
                         skos:definition "An information content entity constituting a control signal generated by an operator to adjust the set point or state of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MassFlowRateSignal
copi:MassFlowRateSignal rdf:type owl:Class ;
                        rdfs:label "mass flow rate signal"@en ,
                                   "sinal de massa de fluxo de taxa"@pt-br ;
                        skos:definition "A measurement information content entity constituting an electrical signal representing the mass flow rate of a process stream as measured by petroleum production instrumentation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MasterValve
copi:MasterValve rdf:type owl:Class ;
                 rdfs:subClassOf copi:COPI_0000077 ;
                 rdfs:label "master valve"@en ,
                            "válvula de principal"@pt-br ;
                 skos:definition "A material artifact that constitutes the main isolation valve at the base of a Christmas tree that controls fluid flow from the tubing head."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MaterialArtifact
copi:MaterialArtifact rdf:type owl:Class ;
                      rdfs:label "artefato de material"@pt-br ,
                                 "material artifact"@en ;
                      skos:definition "A material artifact that constitutes a physical object that is part of a petroleum production system and bears functions whose realizations are planned processes in petroleum production operations."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MaterialComponent
copi:MaterialComponent rdf:type owl:Class ;
                       rdfs:label "componente de material"@pt-br ,
                                  "material component"@en ;
                       skos:definition "A material artifact that constitutes a discrete material component of petroleum production equipment that contributes to its overall function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MaterialPortion
copi:MaterialPortion rdf:type owl:Class ;
                     rdfs:label "material portion"@en ,
                                "porção de material"@pt-br ;
                     skos:definition "A material artifact that constitutes a defined quantity of a material substance at a specified point in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingFunction
copi:MaterialProcessingFunction rdf:type owl:Class ;
                                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:someValuesFrom copi:MaterialProcessingProcess
                                                ] ,
                                                [ rdf:type owl:Restriction ;
                                                  owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                  owl:allValuesFrom copi:MaterialProcessingProcess
                                                ] ;
                                rdfs:label "função de processamento de material"@pt-br ,
                                           "material processing function"@en ;
                                skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the physical or chemical transformation of a material to alter its composition, form, or physical state."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MaterialProcessingProcess
copi:MaterialProcessingProcess rdf:type owl:Class ;
                               rdfs:label "material processing process"@en ,
                                          "processo de processamento de material"@pt-br ;
                               skos:definition "A planned process in which a material is physically or chemically transformed to alter its composition, form, or physical state in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MatingSurface
copi:MatingSurface rdf:type owl:Class ;
                   rdfs:label "mating surface"@en ,
                              "superfície de encaixe"@pt-br ;
                   skos:definition "A material artifact that constitutes a machined surface that mates with a corresponding surface of another component to form a seal or mechanical joint in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MeasurementProcess
copi:MeasurementProcess rdf:type owl:Class ;
                        rdfs:label "measurement process"@en ,
                                   "processo de medição"@pt-br ;
                        skos:definition "A planned process in which the value of a physical or chemical quantity is determined and expressed as a numerical value with an associated unit."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MeasurementSignal
copi:MeasurementSignal rdf:type owl:Class ;
                       rdfs:label "measurement signal"@en ,
                                  "sinal de medição"@pt-br ;
                       skos:definition "A measurement information content entity constituting an electrical or pneumatic signal representing a measured process variable value in petroleum production instrumentation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MeasuringElement
copi:MeasuringElement rdf:type owl:Class ;
                      rdfs:label "elemento de medição"@pt-br ,
                                 "measuring element"@en ;
                      skos:definition "A material artifact that constitutes a primary measurement element within petroleum production instrumentation that directly responds to the measured variable."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalDisplacement
copi:MechanicalDisplacement rdf:type owl:Class ;
                            rdfs:label "deslocamento mecânico"@pt-br ,
                                       "mechanical displacement"@en ;
                            skos:definition "A quality inhering in a material entity, constituting the displacement of a mechanical component from its reference position in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationFunction
copi:MechanicalEnergyGenerationFunction rdf:type owl:Class ;
                                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                          owl:someValuesFrom copi:MechanicalEnergyGenerationProcess
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                          owl:allValuesFrom copi:MechanicalEnergyGenerationProcess
                                                        ] ;
                                        rdfs:label "função de geração de energia mecânica"@pt-br ,
                                                   "mechanical energy generation function"@en ;
                                        skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the conversion of thermal, chemical, or electrical energy into mechanical energy in the form of rotational or linear motion."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyGenerationProcess
copi:MechanicalEnergyGenerationProcess rdf:type owl:Class ;
                                       rdfs:label "mechanical energy generation process"@en ,
                                                  "processo de geração de energia mecânica"@pt-br ;
                                       skos:definition "A planned process in which thermal, chemical, or electrical energy is converted into rotational or linear mechanical energy by petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalEnergyPortion
copi:MechanicalEnergyPortion rdf:type owl:Class ;
                             rdfs:label "mechanical energy portion"@en ,
                                        "porção mecânico de energia"@pt-br ;
                             skos:definition "A material artifact that constitutes a quantity of mechanical energy—kinetic or potential—present in a component or fluid of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalForce
copi:MechanicalForce rdf:type owl:Class ;
                     rdfs:label "força mecânico"@pt-br ,
                                "mechanical force"@en ;
                     skos:definition "A quality inhering in a material entity, constituting a force applied to or by a mechanical component in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalLoad
copi:MechanicalLoad rdf:type owl:Class ;
                    rdfs:label "carga mecânico"@pt-br ,
                               "mechanical load"@en ;
                    skos:definition "A quality inhering in a material entity, constituting the aggregate mechanical force or moment applied to a structural component of petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalMotion
copi:MechanicalMotion rdf:type owl:Class ;
                      rdfs:label "mechanical motion"@en ,
                                 "movimento mecânico"@pt-br ;
                      skos:definition "A process in which the movement of a mechanical component along a defined path in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalMovement
copi:MechanicalMovement rdf:type owl:Class ;
                        rdfs:label "mechanical movement"@en ,
                                   "movimento mecânico"@pt-br ;
                        skos:definition "A process in which the translational or rotational displacement of a mechanical element relative to a reference frame in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalRotation
copi:MechanicalRotation rdf:type owl:Class ;
                        rdfs:label "mechanical rotation"@en ,
                                   "rotação mecânico"@pt-br ;
                        skos:definition "A process in which the angular motion of a rotating component about its axis in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MechanicalSupport
copi:MechanicalSupport rdf:type owl:Class ;
                       rdfs:label "mechanical support"@en ,
                                  "suporte mecânico"@pt-br ;
                       skos:definition "A material artifact that constitutes a structural member that bears mechanical loads to maintain the position and alignment of petroleum production equipment."@en .


