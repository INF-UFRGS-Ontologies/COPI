copi:TurbomachineryPowerGenerationProcess rdf:type owl:Class ;
                                          rdfs:label "processo de geração de energia por turbomáquina"@pt-br ,
                                                     "turbomachinery power generation process"@en ;
                                          skos:definition "A planned process in which fluid enthalpy is converted into shaft power through the interaction of a fluid stream with rotating turbine blades."@en .


