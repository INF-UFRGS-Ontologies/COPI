copi:TubingBundle rdf:type owl:Class ;
                  rdfs:label "feixe de coluna de produção"@pt-br ,
                             "tubing bundle"@en ;
                  skos:definition "An assembly of multiple tubing strings grouped and routed together for injection or production purposes in petroleum production wells or risers."@en .


