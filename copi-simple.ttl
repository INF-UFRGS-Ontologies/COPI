copi:SteelPipe rdf:type owl:Class ;
               rdfs:label "steel pipe"@en ,
                          "tubo de de aço"@pt-br ;
               skos:definition "A material artifact that constitutes a pipe made of steel used to convey fluids under pressure in petroleum production piping systems."@en .


