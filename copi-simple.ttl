copi:PhysicalVariable rdf:type owl:Class ;
                      rdfs:label "physical variable"@en ,
                                 "variável físico"@pt-br ;
                      skos:definition "An information content entity constituting a measurable physical property—such as pressure, temperature, or flow rate—of a process stream or equipment state in petroleum production."@en .


