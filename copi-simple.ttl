###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionFunction
copi:ElectricalConductionFunction rdf:type owl:Class ;
                                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom copi:ElectricalConductionProcess
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:allValuesFrom copi:ElectricalConductionProcess
                                                  ] ;
                                  rdfs:label "electrical conduction function"@en ,
                                             "função de condução elétrica"@pt-br ;
                                  annotation:naturalLanguageDefinition "A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a conductive pathway for electrical current within an electrical contact assembly."@en ,
                                                                       "A DesignedFunction that is realized in an ElectricalConductionProcess and that consists in providing a pathway for electrical current to pass from one electrical apparatus to another, enabling electrical connectivity and power or signal transmission."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ElectricalConductionProcess
copi:ElectricalConductionProcess rdf:type owl:Class ;
                                 rdfs:label "electrical conduction process"@en ,
                                            "processo de condução elétrica"@pt-br ;
                                 annotation:naturalLanguageDefinition "A PlannedProcess in which electrical current is conducted through a conductive material part within an electrical switching or contact system."@en ,
                                                                      "A PlannedProcess in which electrical current is conducted through an electrical connection from one electrical apparatus to another, resulting in the transmission of electrical power or signals between the connected devices."@en .


