###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000052
copi:COPI_0000052 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a material entity that represents the intensity of thermal energy of that entity."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "temperature"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a material entity that represents the intensity of thermal energy of that entity."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000053
copi:COPI_0000053 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "pressure"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a fluid or solid that represents the force per unit area exerted by the substance on its boundary."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000054
copi:COPI_0000054 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "flow rate"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a fluid stream that represents the volume or mass of fluid passing a cross-section per unit time."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000055
copi:COPI_0000055 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "level"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a vessel or container that represents the height of a liquid surface above a reference datum."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000056
copi:COPI_0000056 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "composition"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a mixture or stream that represents the proportions of its constituent components or phases."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000057
copi:COPI_0000057 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "vibration"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a mechanical system that represents oscillatory motion or periodic displacement from an equilibrium position."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000058
copi:COPI_0000058 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in an electrical system that represents the rate of electrical energy transfer."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "electrical power"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in an electrical system that represents the rate of electrical energy transfer."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000059
copi:COPI_0000059 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "mechanical power"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a rotating or reciprocating mechanical system that represents the rate of mechanical work."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000060
copi:COPI_0000060 rdf:type owl:Class ;
                  rdfs:comment "A quality inhering in a rotating element that represents the number of complete revolutions per unit time."@en ;
                  rdfs:isDefinedBy copi:copi-vocab ;
                  rdfs:label "rotational speed"@en ;
                  annotation:naturalLanguageDefinition "A quality inhering in a rotating element that represents the number of complete revolutions per unit time."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000066
copi:COPI_0000066 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:PumpingProcess
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:PumpingProcess
                                  ] ;
                  rdfs:label "função de bombeamento"@pt-br ,
                             "pumping function"@en ;
                  skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the transfer of mechanical energy to a fluid to increase its pressure, velocity, or both."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000067
copi:COPI_0000067 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:CompressionProcess
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:CompressionProcess
                                  ] ;
                  rdfs:label "compression function"@en ,
                             "função de compressão"@pt-br ;
                  skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the compression of a gas stream to increase its pressure for transport, injection, or processing."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000068
copi:COPI_0000068 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:COPI_0000004
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:COPI_0000004
                                  ] ;
                  rdfs:label "função de transferência de calor"@pt-br ,
                             "heat transfer function"@en ;
                  skos:definition "A DesignedFunction that is realized in a HeatTransferProcess and that consists in facilitating the transfer of thermal energy between two or more fluid media while maintaining their physical separation."@en ;
                  annotation:naturalLanguageDefinition "A DesignedFunction that is realized in a HeatTransferProcess and that consists in facilitating the transfer of thermal energy between two or more fluid media while maintaining their physical separation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000069
copi:COPI_0000069 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:AbsorptionProcess
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:AbsorptionProcess
                                  ] ;
                  rdfs:label "função de absorção de gás"@pt-br ,
                             "gas absorption function"@en ;
                  skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the selective transfer of gaseous components from a gas phase into a liquid absorbent phase."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000070
copi:COPI_0000070 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:TemperatureSensingProcess
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:TemperatureSensingProcess
                                  ] ;
                  rdfs:label "função de sensoriamento de temperatura"@pt-br ,
                             "temperature sensing function"@en ;
                  skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the detection and measurement of the temperature of a process stream or equipment surface."@en .


