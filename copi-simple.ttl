###  https://www.inf.ufrgs.br/ontologies/copi/ControlIndicator
copi:ControlIndicator rdf:type owl:Class ;
                      rdfs:label "control indicator"@en ,
                                 "indicador de controle"@pt-br ;
                      skos:definition "A material artifact that constitutes a component that displays and enables adjustment of a set point or control parameter in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ControlProcess
copi:ControlProcess rdf:type owl:Class ;
                    rdfs:label "control process"@en ,
                               "processo de controle"@pt-br ;
                    skos:definition "A planned process in which a process variable is regulated by adjusting a manipulated variable in response to a measured deviation from a set point."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CoolantPortion
copi:CoolantPortion rdf:type owl:Class ;
                    rdfs:label "coolant portion"@en ,
                               "porção de refrigerante"@pt-br ;
                    skos:definition "A material artifact that constitutes a portion of cooling medium used to remove thermal energy from a process stream or equipment component."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CooledHeatingMedium
copi:CooledHeatingMedium rdf:type owl:Class ;
                         rdfs:label "cooled heating medium"@en ,
                                    "meio de resfriado de aquecimento"@pt-br ;
                         skos:definition "A material artifact that constitutes a heating medium that has transferred thermal energy to a process stream and returned to a lower temperature."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CoolingFunction
copi:CoolingFunction rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:someValuesFrom copi:CoolingProcess
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:allValuesFrom copi:CoolingProcess
                                     ] ;
                     rdfs:label "cooling function"@en ,
                                "função de resfriamento"@pt-br ;
                     skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the removal of thermal energy from a process stream or equipment component to reduce its temperature."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CoolingProcess
copi:CoolingProcess rdf:type owl:Class ;
                    rdfs:label "cooling process"@en ,
                               "processo de resfriamento"@pt-br ;
                    skos:definition "A planned process in which thermal energy is removed from a process stream or equipment component to reduce its temperature in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CorrosionProducts
copi:CorrosionProducts rdf:type owl:Class ;
                       rdfs:label "corrosion products"@en ,
                                  "produtos de corrosão"@pt-br ;
                       skos:definition "A material artifact that constitutes the solid products—oxides, hydroxides, or sulfides—formed on a metallic surface as a result of corrosion in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/CuttingsAndFluid
copi:CuttingsAndFluid rdf:type owl:Class ;
                      rdfs:label "cuttings and fluid"@en ,
                                 "fluido de cascalhos de e"@pt-br ;
                      skos:definition "A material artifact that constitutes a mixture of rock cuttings and drilling fluid circulated from the wellbore bottom to the surface during drilling operations."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/DampingFunction
copi:DampingFunction rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:someValuesFrom copi:DampingProcess
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:allValuesFrom copi:DampingProcess
                                     ] ;
                     rdfs:label "damping function"@en ,
                                "função de amortecimento"@pt-br ;
                     skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the absorption and dissipation of mechanical energy to reduce the amplitude of oscillations or vibrations."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/DampingProcess
copi:DampingProcess rdf:type owl:Class ;
                    rdfs:label "damping process"@en ,
                               "processo de amortecimento"@pt-br ;
                    skos:definition "A planned process in which mechanical energy is absorbed and dissipated to reduce the amplitude of oscillations or vibrations in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/DeaerationFunction
copi:DeaerationFunction rdf:type owl:Class ;
                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                          owl:someValuesFrom copi:DeaerationProcess
                                        ] ,
                                        [ rdf:type owl:Restriction ;
