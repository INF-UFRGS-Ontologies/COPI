###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000205
copi:COPI_0000205 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000024 ,
                                  copi:COPI_0000144 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureSensor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:VacuumReferenceeChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000031
                                  ] ;
                  rdfs:label "absolute pressure transmitter"@en ,
                             "transmissor de pressão absoluta"@pt-br ;
                  skos:definition "[CFIHOS] A pressure transmitter where pressure is applied to one side of the sensor while the other side has a vacuum chamber."@en ,
                                  "[ISO 15926-4] An <ABSOLUTE PRESSURE TRANSMITTER> is a <PRESSURE TRANSMITTER> and an <ABSOLUTE PRESSURE MEASURING INSTRUMENT>"@en ;
                  annotation:firstOrderLogicAxiom "∀x (AbsolutePressureTransmitter(x) → PressureTransmitter(x) ∧ ∃y (VacuumReferenceeChamber(y) ∧ hasComponentPartAtAllTimes(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber on one side of the pressure sensor while the other side receives the process pressure."@en ,
                                                       "Um transmissor de pressão absoluta é um transmissor de pressão que possui uma câmara de referência de vácuo de um lado do sensor de pressão enquanto o outro lado recebe a pressão do processo."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on vacuum reference chamber configuration. Under Open World Assumption, defining sufficient conditions could lead to unintended classification of complex instruments that contain vacuum chambers but serve different primary functions. The structural differentia is necessary but making it sufficient requires domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every absolute pressure transmitter is a pressure transmitter that has a vacuum reference chamber as a component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000206
copi:COPI_0000206 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:EnergyStorageMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:StorageChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:AccumulationFunction
                                  ] ;
                  rdfs:label "accumulator"@en ,
                             "acumulador"@pt-br ;
                  skos:definition "[CFIHOS] A physical object for storing energy, and which after discharge may be recharged."@en ,
                                  "[ISO 15926-4] An <ACCUMULATOR> is a <FunctionalObject> that has a capability of <ACCUMULATING> matter and/or energy"@en ,
                                  "[OnePetro] In context of a pressure control device, accumulators are canisters of hydraulic fluid, pressurized with a nitrogen gas cap of sufficient pressure and volume to operate all the rams on a BOP in case of power failure to the BOP.                  In context of a processing plant, an accumulator is a vessel that receives and temporarily stores a liquid used in the feed stock or the processing of a feed stream in a gas plant or other processing facility."@en ,
                                  "[POSC Caesar] A functional object capable of storing energy, and which after discharge may be recharged."@en ,
                                  "[SLB Glossary] A device used in a hydraulic system to store energy or, in some applications, dampen pressure fluctuations."@en ;
                  skos:exactMatch copi:COPI_0000206 ;
                  annotation:firstOrderLogicAxiom "∀x (Accumulator(x) ↔ (Vessel(x) ∧ ∃f (AccumulationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "An accumulator is a vessel that has the designed function to accumulate (store and controllably release) energy or matter."@en ,
                                                       "Um acumulador é um vaso que tem a função projetada de acumular (armazenar e liberar de forma controlada) energia ou matéria."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every accumulator is a vessel that bears an accumulation function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000207
copi:COPI_0000207 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:EnergyConverter
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OutputMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ActuationFunction
                                  ] ;
                  rdfs:label "actuator"@en ,
                             "atuador"@pt-br ;
                  skos:definition "[CFIHOS] A physical object for changing a signal into a corresponding movement."@en ,
                                  "[ISO 15926-4] An <ACTUATOR> is a <FunctionalObject> that is capable of <ACTUATING>"@en ,
                                  "[OnePetro] An actuator is a type of motor for moving or controlling a mechanism or system. Actuator's are a vital part of offshore operations."@en ,
                                  "[POSC Caesar] A transducer that is intended to convert energy (electric, mechanical, pneumatic or hydraulic) from an external source into kinetic energy (motion) in response to a signal or or power input."@en ;
                  skos:exactMatch copi:COPI_0000207 ;
                  annotation:firstOrderLogicAxiom "∀x (Actuator(x) ↔ Assembly(x) ∧ ∃f (ActuationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "An actuator is an assembly that bears an actuation function to convert energy from an external source into kinetic motion in response to control signals."@en ,
                                                       "Um atuador é um conjunto que possui uma função de atuação para converter energia de uma fonte externa em movimento cinético em resposta a sinais de controle."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every actuator is an assembly that has the function of converting external energy into controlled kinetic motion."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000208
copi:COPI_0000208 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000314 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AgitatorDrive
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MovingVane
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotatingShaft
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:AgitationFunction
                                  ] ;
                  rdfs:label "agitador"@pt-br ,
                             "agitator"@en ;
                  skos:definition "[CFIHOS] A propeller like device with agitational or rotational movement located in a tank to prevent the content of the tank to build component segments."@en ,
                                  "[DEXPI] An Agitator is a dynamic mixer that stirs or shakes fluids by reaction force from moving vanes."@en ,
                                  "[ISO 15926-4] An <AGITATOR> is a <DYNAMIC MIXER> that stirs or shakes fluids by reaction force from moving vanes"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Agitator(x) ↔ Mixer(x) ∧ ∃f(AgitationFunction(f) ∧ bearerOf(x,f)) ∧ ∃v(MovingVane(v) ∧ hasComponentPartAtAllTimes(x,v)))"@en ;
                  annotation:naturalLanguageDefinition "An agitator is a mixer that stirs or shakes fluids by reaction force from moving vanes."@en ,
                                                       "Um agitador é um misturador que mexe ou agita fluidos por força de reação de palhetas móveis."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every agitator is a mixer that has the function to agitate fluids and has moving vanes as component parts at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000209
copi:COPI_0000209 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirFinSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000293
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TubeBundle
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000068
                                  ] ;
                  rdfs:label "air cooled heat exchanger"@en ,
                             "trocador de calor resfriado a ar"@pt-br ;
                  skos:definition "[CFIHOS] A cooler that is intended to use air as the cooling medium."@en ,
                                  "[ISO 15926-4] An <AIR COOLED HEAT EXCHANGER> is a <HEAT EXCHANGER> and an <AIR COOLED OBJECT> and a <FLUID CONTAINER>"@en ,
                                  "[POSC Caesar] A cooler that is intended to use air as the cooling medium."@en ;
                  annotation:firstOrderLogicAxiom "∀x(AirCooledHeatExchanger(x) → HeatExchanger(x) ∧ ∃y(AirFinSystem(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(TubeBundle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃p(AirCoolingProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An air cooled heat exchanger is a heat exchanger that has finned air cooling surfaces and uses ambient air as the cooling medium to transfer thermal energy from process fluids."@en ,
                                                       "Um trocador de calor resfriado a ar é um trocador de calor que possui superfícies aletadas de resfriamento a ar e usa ar ambiente como meio de resfriamento para transferir energia térmica de fluidos de processo."@pt-br ;
                  annotation:primitiveRationale "Under the Open World Assumption, defining air cooling constructively as sufficient conditions could lead to false positives. Complex hybrid equipment or specialized configurations with air cooling components might be inappropriately classified. Starting with necessary conditions allows for proper validation by domain experts before upgrading to equivalence."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every air cooled heat exchanger is a heat exchanger that has component parts including an air fin system and tube bundle, and participates in air cooling processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000210
copi:COPI_0000210 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AnalogueDial
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000076
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:IndicatorPointer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000173
                                  ] ;
                  rdfs:label "analogue temperature indicator"@en ,
                             "indicador analógico de temperatura"@pt-br ;
                  skos:definition "[ISO 15926-4] An <ANALOGUE TEMPERATURE INDICATOR> is an <ANALOGUE INDICATOR> that indicates temperature in an analogue way"@en ;
                  skos:exactMatch copi:COPI_0000210 ;
                  annotation:firstOrderLogicAxiom "∀x (AnalogueTemperatureIndicator(x) ↔ Instrument(x) ∧ ∃f(TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃d(AnalogueDial(d) ∧ hasComponentPartAtAllTimes(x,d)))"@en ;
                  annotation:naturalLanguageDefinition "An analogue temperature indicator is an instrument that bears a temperature indication function and has an analogue dial for visual temperature display."@en ,
                                                       "Um indicador analógico de temperatura é um instrumento que possui uma função de indicação de temperatura e tem um mostrador analógico para exibição visual da temperatura."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every analogue temperature indicator is an instrument that bears a temperature indication function and has component parts including a temperature sensor, analogue dial, and indicator pointer."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000211
copi:COPI_0000211 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  copi:COPI_0000078 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000026
                                  ] ;
                  rdfs:label "angle valve body"@en ,
                             "corpo de válvula angular"@pt-br ;
                  skos:definition "[ISO 15926-4] An <ANGLE VALVE BODY> is a <VALVE BODY> of an angle valve"@en ;
                  annotation:firstOrderLogicAxiom "∀x (AngleValveBody(x) → ValveBody(x) ∧ ∃g (AngularFlowPath(g) ∧ hasGeometry(x,g)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A ValveBody that has an internal flow path geometry where the inlet and outlet axes are positioned at an angle to each other, creating an L-shaped or angled flow configuration."@en ,
                                                       "Um ValveBody que possui uma geometria de caminho de fluxo interno onde os eixos de entrada e saída são posicionados em ângulo um em relação ao outro, criando uma configuração de fluxo em formato de L ou angular."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on geometric configuration. Under OWA, sufficient conditions for geometric characteristics like 'angular flow path' are difficult to specify precisely without detailed geometric constraints that could lead to false classification of complex multi-path valve bodies or hybrid designs."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "AngleValveBody subClassOf ValveBody and hasGeometry some AngularFlowPath"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000212
copi:COPI_0000212 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ActiveMaterial
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000262
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:AnodeFunction
                                  ] ;
                  rdfs:label "anode"@en ,
                             "ânodo"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that is capable of emitting positive charge carriers to and/or receiving negative charge carriers from the medium of lower conductivity."@en ,
                                  "[ISO 15926-4] An <ANODE> is an <ELECTRICAL DEVICE> that has a capability of <EMITTING> positive charge carriers to, and/or <RECEIVING> negative charge carriers from, the medium of lower conductivity"@en ,
                                  "[OnePetro] The positively charged site in a cell. Oxidation site. The site of metal loss in corrosion."@en ,
                                  "[SLB Glossary] The half of a battery that is positively charged and to which anions migrate by electrostatic attraction."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Anode(x) ↔ ElectricalEquipment(x) ∧ ∃f(AnodeFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "An anode is electrical equipment that bears the function of serving as the positive electrode in electrochemical processes, capable of emitting positive charge carriers to and/or receiving negative charge carriers from a medium of lower conductivity."@en ,
                                                       "Um ânodo é um equipamento elétrico que possui a função de servir como eletrodo positivo em processos eletroquímicos, capaz de emitir portadores de carga positiva para e/ou receber portadores de carga negativa de um meio de menor condutividade."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every anode is electrical equipment that has the function of electrochemical oxidation and has electrical connection and active material as component parts at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000213
copi:COPI_0000213 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AxialDisplacementMeasuringProbe
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalProcessingUnit
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalTransmissionModule
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:AxialDisplacementTransmissionFunction
                                  ] ;
                  rdfs:label "axial displacement transmitter"@en ,
                             "transmissor de deslocamento axial"@pt-br ;
                  skos:definition "[CFIHOS] A transmitter measuring an axial displacement and generating a standardized output signal representing the axial measured displacement."@en ,
                                  "[ISO 15926-4] An <AXIAL DISPLACEMENT TRANSMITTER> is a <DISPLACEMENT TRANSMITTER> for <AXIAL DISPLACEMENT> measurement, using an <AXIAL DISPLACEMENT MEASURING PROBE>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(AxialDisplacementTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(AxialDisplacementTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(AxialDisplacementMeasuringProbe(p) ∧ hasComponentPartAtAllTimes(x,p))))"@en ;
                  annotation:naturalLanguageDefinition "An axial displacement transmitter is a transmitter that measures axial displacement and generates a standardized output signal representing the measured axial displacement."@en ,
                                                       "Um transmissor de deslocamento axial é um transmissor que mede deslocamento axial e gera um sinal de saída padronizado representando o deslocamento axial medido."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every axial displacement transmitter is a transmitter that has the function to measure axial displacement and has as component part an axial displacement measuring probe."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000214
copi:COPI_0000214 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BasinFloor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BasinWall
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000197
                                  ] ;
                  rdfs:label "bacia"@pt-br ,
                             "basin"@en ;
                  skos:definition "[CFIHOS] A container intended to store liquid or solid material partly or totally below grade and that is typically open."@en ,
                                  "[ISO 15926-4] A <BASIN> is a <FLUID CONTAINER>, intended to store liquid or solid material partly or totally below grade and that is typically open"@en ,
                                  "[OnePetro] A large area with a general containment and an often thick accumulation of rock. A sedimentary basin is an area of regional settling that can be characterized in space, time, and sedimentary fill .It is a physical depression at the earth's surface which accumulates and preserves sediments. The scale of basins varies greatly, from ocean basins to small ponds.                  ==References==                   Helwig, J. A. 1985. Origin and Classification of Sedimentary Basins. Offshore Technology Conference. http://www.doi.org/doi:10.4043/4843-MS"@en ,
                                  "[SLB Glossary] A depression in the crust of the Earth, caused by plate tectonic activity and subsidence, in which sediments accumulate."@en ;
                  skos:exactMatch copi:COPI_0000214 ;
                  annotation:firstOrderLogicAxiom "Basin(x) ↔ Vessel(x) ∧ ∃f(StorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(OpenTop(p) ∧ hasGeometricProperty(x,p)) ∧ ∃q(PartlyBelowGrade(q) ∧ hasInstallationProperty(x,q))"@en ;
                  annotation:naturalLanguageDefinition "A basin is a vessel that is designed to store liquid or solid material, characterized by being typically open at the top and installed partly or totally below grade."@en ,
                                                       "Uma bacia é um vaso projetado para armazenar material líquido ou sólido, caracterizado por ser tipicamente aberto no topo e instalado parcial ou totalmente abaixo do nível do solo."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every basin is a vessel that bears a storage function and has an open top configuration and is installed partly below grade."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000215
copi:COPI_0000215 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SupportingSurface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:SupportFunction
                                  ] ;
                  rdfs:label "bearing"@en ,
                             "mancal"@pt-br ;
                  skos:definition "[CFIHOS] A physical object intended to support and locate a moving or static element and capable of reducing friction and transfer forces in a connection."@en ,
                                  "[ISO 15926-4] A <BEARING> is a <SUPPORT> intended to support and locate a moving or static element"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Bearing(x) ↔ MaterialArtifact(x) ∧ ∃f(SupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(FrictionReductionProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A bearing is a material artifact that is designed to support and locate moving or static mechanical elements while reducing friction in the connection."@en ,
                                                       "Um mancal é um artefato material que é projetado para suportar e localizar elementos mecânicos móveis ou estáticos enquanto reduz o atrito na conexão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every bearing is a material artifact that bears a support function and participates in friction reduction processes"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000216
copi:COPI_0000216 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000321 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:EnlargedBore
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SideOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DrillingFluidConductionFunction
                                  ] ;
                  rdfs:label "bell nipple"@en ,
                             "bell nipple"@pt-br ;
                  skos:definition "[CFIHOS] A Bell nipple is a section of large diameter pipe fitted to the top of the blowout preventers that the flow line attaches to via a side outlet, to allow the drilling fluid to flow back over the shale shakers to the mud tanks. Also an enlarged pipe at the top of a casing string that serves as a funnel to guide drilling tools into the top of a well."@en ,
                                  "[ISO 15926-4] A <BELL NIPPLE> is an <ARTEFACT> and a large diameter <PIPING NETWORK SEGMENT> fitted to the top of the blowout preventers that the flow line attaches to via a side outlet, to allow the drilling fluid to flow back over the shale shakers to the mud tanks. Also an enlarged pipe at the top of a casing string that serves as a funnel to guide drilling tools into the top of a well"@en ,
                                  "[OnePetro] A funnel shaped pipe at the top of the casing that guides tool string entry and may have a side port for fluid pumping."@en ,
                                  "[SLB Glossary] An enlarged pipe at the top of a casing string that serves as a funnel to guide drilling tools into the top of a well."@en ;
                  skos:exactMatch copi:COPI_0000216 ;
                  annotation:firstOrderLogicAxiom "∀x(BellNipple(x) ↔ (Pipe(x) ∧ ∃f(DrillingFluidConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(EnlargedDiameter(s) ∧ hasCharacteristicShape(x,s)) ∧ ∃l(WellheadAssembly(l) ∧ hasLocation(x,l))))"@en ;
                  annotation:naturalLanguageDefinition "A bell nipple is a pipe that conducts drilling fluids in drilling operations and is characterized by an enlarged diameter that serves as a funnel and a location at the wellhead assembly."@en ,
                                                       "Um bell nipple é um tubo que conduz fluidos de perfuração em operações de perfuração e é caracterizado por um diâmetro alargado que serve como funil e uma localização no conjunto da cabeça do poço."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every bell nipple is a pipe that bears a DrillingFluidConductionFunction and has an enlarged diameter shape and is located at a wellhead assembly."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000217
copi:COPI_0000217 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000124 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HeatExchangeSurface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MudDrum
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SteamDrum
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:BoilingFunction
                                  ] ;
                  rdfs:label "boiler"@en ,
                             "caldeira"@pt-br ;
                  skos:definition "[CFIHOS] An indirect contact heat exchanger that is intended to heat a liquid."@en ,
                                  "[DEXPI] A that brings a liquid to its boiling point."@en ,
                                  "[ISO 15926-4] A <BOILER> is a <HEATER> that brings a <LIQUID> to its boiling point"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Boiler(x) ↔ Heater(x) ∧ ∃f(BoilingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A boiler is a heater that brings a liquid to its boiling point through indirect contact heat exchange, producing steam or vapor."@en ,
                                                       "Uma caldeira é um aquecedor que leva um líquido ao seu ponto de ebulição através de troca de calor por contato indireto, produzindo vapor."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every boiler is a heater that bears a BoilingFunction and has component parts including a steam drum and heat exchange surface."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000218
copi:COPI_0000218 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BitSub
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DrillBit
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DrillCollar
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:BottomHoleDrillingFunction
                                  ] ;
                  rdfs:label "bottom hole assembly"@en ,
                             "conjunto de fundo de poço"@pt-br ;
                  skos:definition "[ISO 15926-4] A <BOTTOM HOLE ASSEMBLY> is a <DRILLING COMPONENT> that is the lower part of a drill string, extending from the bit to the drill pipe."@en ,
                                  "[OnePetro] The equipment or tools at the bottom of the tubing or drill string. The BHA is changed to achieve a certain result."@en ;
                  annotation:firstOrderLogicAxiom "∀x(BottomHoleAssembly(x) ↔ DrillingComponent(x) ∧ ∃y(DrillBit(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(BottomHoleLocation(z) ∧ locatedAt(x,z)))"@en ;
                  annotation:naturalLanguageDefinition "A bottom hole assembly is a drilling component that performs specialized drilling operations at the bottom of the drill string, characterized by including a drill bit and being positioned at the bottom hole location."@en ,
                                                       "Um conjunto de fundo de poço é um componente de perfuração que realiza operações especializadas de perfuração na parte inferior da coluna de perfuração, caracterizado por incluir uma broca e estar posicionado no local do fundo do poço."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every bottom hole assembly is a drilling component that has a drill bit as component part at all times and is located at bottom hole location."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000219
copi:COPI_0000219 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BrakingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MountingStructure
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:BrakingFunction
                                  ] ;
                  rdfs:label "brake"@en ,
                             "freio"@pt-br ;
                  skos:definition "[CFIHOS] A physical object intended to arrest or prevent the motion of an item. Typically by means of friction."@en ,
                                  "[ISO 15926-4] A <BRAKE> is a <FunctionalObject> that has the capability of <BRAKING>"@en ,
                                  "[OnePetro] In a drillng context, a brake is the main device for stopping the travel of the drawworks of a rig when running or pulling a drill string."@en ,
                                  "[SLB Glossary] The mechanism on the drawworks that permits the driller to control the speed and motion of the drilling line and the drillstring."@en ;
                  skos:exactMatch copi:COPI_0000219 ;
                  annotation:firstOrderLogicAxiom "∀x(Brake(x) ↔ (Assembly(x) ∧ ∃f(BrakingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A brake is an assembly that bears a braking function to arrest or prevent the motion of an object, typically through friction or electromagnetic force application."@en ,
                                                       "Um freio é um conjunto que possui uma função de frenagem para deter ou prevenir o movimento de um objeto, tipicamente através da aplicação de força de atrito ou eletromagnética."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every brake is an assembly that has the function of braking, and every assembly that has the function of braking is a brake."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000220
copi:COPI_0000220 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000124 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirSupplySystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CombustionChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FuelSupplySystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:CombustionFunction
                                  ] ;
                  rdfs:label "burner"@en ,
                             "queimador"@pt-br ;
                  skos:definition "[ISO 15926-4] A <BURNER> is a <FunctionalObject> that is intended to release thermal energy by burning a combustible mixture"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Burner(x) ↔ (Heater(x) ∧ ∃f (CombustionFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A burner is a heater that releases thermal energy by burning a combustible mixture of fuel and air."@en ,
                                                       "Um queimador é um aquecedor que libera energia térmica através da queima de uma mistura combustível de combustível e ar."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every burner is a heater that has the function of combustion, which is realized by burning a fuel-air mixture to release thermal energy."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000221
copi:COPI_0000221 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ContinuousBase
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RaisedEdge
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:CableSupportFunction
                                  ] ;
                  rdfs:label "bandeja de cabos"@pt-br ,
                             "cable tray"@en ;
                  skos:definition "[CFIHOS] A unit or assembly of units or sections and associated fittings forming a rigid structural system used to securely fasten or support cables and raceways."@en ,
                                  "[POSC Caesar] An artefact and electrical cable conduit consisting of a continuous base, raised edges and no covering"@en ;
                  annotation:firstOrderLogicAxiom "∀x(CableTray(x) ↔ Assembly(x) ∧ ∃f(CableSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ContinuousBase(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃e(RaisedEdge(e) ∧ hasComponentPartAtAllTimes(x,e)))"@en ;
                  annotation:naturalLanguageDefinition "A cable tray is an assembly that bears a cable support function and consists of a continuous base with raised edges, forming a rigid structural system for securely supporting and routing electrical cables."@en ,
                                                       "Uma bandeja de cabos é um conjunto que possui função de suporte de cabos e consiste em uma base contínua com bordas elevadas, formando um sistema estrutural rígido para suportar e rotear cabos elétricos de forma segura."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every cable tray is an assembly that has the function to support cables and has a continuous base part and raised edge parts."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000222
copi:COPI_0000222 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CasingWall
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                    owl:someValuesFrom copi:CasingConnectionPoint
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnclosureFunction
                                  ] ;
                  rdfs:label "casing"@en ,
                             "casing"@pt-br ;
                  skos:definition "[CFIHOS] An enclosure that can maintain a pressure difference."@en ,
                                  "[ISO 15926-4] A <CASING> is an <ARTEFACT> and an <ENCLOSURE> that is the stationary enclosure of a machine intended to contain a fluid and equipment internals"@en ,
                                  "[OnePetro] One of several strings of steel pipe in a well design that, together with cement, forms a barrier to fluid movement along the drilled hole. It is commonly at least partly cemented in the wellbore."@en ,
                                  "[SLB Glossary] Large-diameter pipe lowered into an openhole and cemented in place."@en ;
                  skos:exactMatch copi:COPI_0000222 ;
                  annotation:firstOrderLogicAxiom "∀x(Casing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(CasingWall(w) ∧ hasComponentPartAtAllTimes(x,w)) ∧ ∃p(PressureContainmentFunction(p) ∧ hasFunction(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A casing is an assembly that provides structural enclosure with pressure containment capability, characterized by walls that separate internal components or fluids from the external environment."@en ,
                                                       "Um casing é um conjunto que fornece invólucro estrutural com capacidade de contenção de pressão, caracterizado por paredes que separam componentes internos ou fluidos do ambiente externo."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on structural configuration. Under OWA, sufficient conditions for enclosure structure could lead to over-classification of complex assemblies that contain enclosure elements but serve different primary functions (e.g., pressure vessels, housings, containers)."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every casing is an assembly that has an enclosure function and has component part some casing wall and has function some pressure containment function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000223
copi:COPI_0000223 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                    owl:someValuesFrom copi:CathodicProtectionFunction
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                    owl:someValuesFrom copi:COPI_0000212
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/has_participant_at_some_time> ;
                                    owl:someValuesFrom copi:ProtectedStructure
                                  ] ;
                  rdfs:label "cathodic protection system"@en ,
                             "sistema de proteção catódica"@pt-br ;
                  skos:definition "[CFIHOS] A corrosion protection system using sacrificial anodes or impressed current anodes offering material and giving protection to carbon and low-alloy steel equipment or structures."@en ,
                                  "[ISO 15926-4] A <CATHODIC PROTECTION SYSTEM> is an <ARTEFACT> and a <CORROSION PROTECTION SYSTEM> using sacrificial anodes or impressed current anodes offering material and giving protection to carbon and low-alloy steel equipment or structures"@en ;
                  annotation:firstOrderLogicAxiom "∀x(CathodicProtectionSystem(x) ↔ CorrosionProtectionSystem(x) ∧ ∃f(CathodicProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃a(Anode(a) ∧ hasComponentPartAtSomeTime(x,a)))"@en ;
                  annotation:naturalLanguageDefinition "A cathodic protection system is a corrosion protection system that uses electrochemical cathodic protection mechanisms with anodes to prevent corrosion of carbon and low-alloy steel equipment or structures."@en ,
                                                       "Um sistema de proteção catódica é um sistema de proteção contra corrosão que usa mecanismos eletroquímicos de proteção catódica com ânodos para prevenir a corrosão de equipamentos ou estruturas de aço carbono e baixa liga."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every cathodic protection system is a corrosion protection system that bears a cathodic protection function and has anodes as component parts."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000224
copi:COPI_0000224 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000222 ;
                  rdfs:label "centrifugal compressor casing"@en ,
                             "invólucro"@pt-br ;
                  skos:definition "[ISO 15926-4] A <CENTRIFUGAL COMPRESSOR CASING> is a <COMPRESSOR CASING> that is intended to be used for a centrifugal compressor."@en ;
                  annotation:firstOrderLogicAxiom "∀x(CentrifugalCompressorCasing(x) → Casing(x) ∧ ∃y(CentrifugalCompressor(y) ∧ intendedFor(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A casing that is specifically designed and dimensioned for structural compatibility with centrifugal compressor mechanisms, providing enclosure and protection for rotating impellers and associated flow components."@en ,
                                                       "Um invólucro que é especificamente projetado e dimensionado para compatibilidade estrutural com mecanismos de compressor centrífugo, fornecendo contenção e proteção para impulsores rotativos e componentes de fluxo associados."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by structural compatibility. Under OWA, asserting equivalence could force classification of any casing with centrifugal compressor compatibility, including hybrid or specialized equipment that should not be automatically classified as standard centrifugal compressor casings."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every centrifugal compressor casing is a casing that is intended for use with centrifugal compressors"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000225
copi:COPI_0000225 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DriveSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HousingStructure
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotatingDrum
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000195
                                  ] ;
                  rdfs:label "centrifuge"@en ,
                             "centrífuga"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that uses centrifugal force to separate phases of different densities."@en ,
                                  "[ISO 15926-4] A <CENTRIFUGE> is a <MACHINE> and a <SEPARATOR> that uses centrifugal force to separate phases of different densities"@en ,
                                  "[OnePetro] A device that separates materials by density through a centrifugal motion."@en ,
                                  "[POSC Caesar] A 'separator' and 'machine' that uses centrifugal force to separate phases of different densities."@en ,
                                  "[SLB Glossary] An item of solids-removal equipment that removes fine and ultrafine solids."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Centrifuge(x) → Separator(x) ∧ ∃d (RotatingDrum(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p (CentrifugalForceProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A centrifuge is a separator that uses centrifugal force generated by a rotating drum to separate phases of different densities."@en ,
                                                       "Uma centrífuga é um separador que usa força centrífuga gerada por um tambor rotativo para separar fases de diferentes densidades."@pt-br ;
                  annotation:primitiveRationale "Although functionally defined as a separator, the constructive differentia (centrifugal mechanism) makes sufficient conditions complex under OWA. Any equipment with a rotating drum could potentially be classified as a centrifuge even if designed for other purposes (mixing, drying, etc.). Starting with necessary conditions protects against false positives."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every centrifuge is a separator that has a rotating drum as component part and participates in centrifugal force processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000226
copi:COPI_0000226 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000078 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnclosureFunction
                                  ] ;
                  rdfs:label "check valve body"@en ,
                             "corpo de válvula"@pt-br ;
                  skos:definition "[ISO 15926-4] A <CHECK VALVE BODY> is a <VALVE BODY> of a check valve"@en ;
                  annotation:firstOrderLogicAxiom "∀x(CheckValveBody(x) → ValveBody(x) ∧ ∃y(CheckValve(y) ∧ designedFor(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A valve body that is specifically designed to accommodate and house the internal mechanisms of a check valve within a pressure-containing boundary."@en ,
                                                       "Um corpo de válvula que é especificamente projetado para acomodar e alojar os mecanismos internos de uma válvula de retenção dentro de uma barreira de contenção de pressão."@pt-br ;
                  annotation:primitiveRationale "Constructive identity based on structural design for check valve accommodation. Under OWA, any housing designed for check valves could include specialized configurations, custom manifolds, or hybrid designs that should not be automatically classified as standard check valve bodies without domain expert validation of the structural differentia."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "CheckValveBody subClassOf ValveBody and (designedFor some CheckValve)"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000227
copi:COPI_0000227 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000370 ,
                                  copi:ClosureMember ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000161
                                  ] ;
                  rdfs:label "check valve closure member"@en ,
                             "membro de fechamento de válvula de retenção"@pt-br ;
                  skos:definition "[ISO 15926-4] A <CHECK VALVE CLOSURE MEMBER> is an <ARTEFACT> and a <VALVE CLOSURE MEMBER> that is intended to prevent back flow"@en ;
                  annotation:firstOrderLogicAxiom "∀x(CheckValveClosureMember(x) → MaterialArtifact(x) ∧ ∃y(CheckValve(y) ∧ isComponentPartOf(x,y)) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that is a component part of a check valve and that bears a BackflowPreventionFunction, consisting in a mechanical element that prevents fluid flow reversal by physically blocking the flow path when pressure conditions indicate potential backflow."@en ,
                                                       "Um MaterialArtifact que é uma parte componente de uma válvula de retenção e que possui uma BackflowPreventionFunction, consistindo em um elemento mecânico que previne o refluxo de fluido bloqueando fisicamente o caminho de fluxo quando as condições de pressão indicam potencial refluxo."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by structural role and mechanism. Under OWA, sufficient conditions would force classification of any artifact with backflow prevention function and check valve association, potentially including hybrid or specialized designs that should not be automatically classified as standard closure members without domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every check valve closure member is a MaterialArtifact that is component part of some check valve and bears some BackflowPreventionFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000228
copi:COPI_0000228 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ChristmasTreeBody
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlowControlEquipment
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MasterValve
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:WingValve
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:WellFluidControlFunction
                                  ] ;
                  rdfs:label "christmas tree"@en ,
                             "árvore de natal"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that is an assembly of pipes and piping parts, with valves and associated control equipment that is connected to the top of a wellhead and is intended for control of fluid from a well."@en ,
                                  "[ISO 15926-4] A <CHRISTMAS TREE> is a <PIPING SYSTEM> that is an assembly of pipes and piping parts, with valves and associated control equipment that is connected to the top of a wellhead and is intended for control of fluid from a well."@en ,
                                  "[OnePetro] The control sections that sits above the basic wellhead. It may contain hangers, master valves, annular valves, wing valves, and gauges or pressure, flow rate or monitoring measurement equipment."@en ,
                                  "[POSC Caesar] An 'artefact' that is an assembly of pipes and piping parts, with valves and associated control equipment that is connected to the top of a wellhead and is intended for control of fluid from a well."@en ,
                                  "[SLB Glossary] The set of valves, spools, and fittings connected to the top of a well to direct and control the flow of formation fluids from the well."@en ;
                  skos:exactMatch copi:COPI_0000228 ;
                  annotation:firstOrderLogicAxiom "∀x (ChristmasTree(x) ↔ (Assembly(x) ∧ ∃f(WellFluidControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ hasComponentPartAtAllTimes(x,w)) ∧ ∃v(MasterValve(v) ∧ hasComponentPartAtAllTimes(x,v))))"@en ;
                  annotation:naturalLanguageDefinition "A christmas tree is an assembly that bears a well fluid control function, is connected to a wellhead, and contains master valves for controlling formation fluids from oil and gas wells."@en ,
                                                       "Uma árvore de natal é um conjunto que possui uma função de controle de fluidos de poço, está conectada a uma cabeça de poço, e contém válvulas mestras para controlar fluidos de formação de poços de petróleo e gás."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every christmas tree is an assembly that has the function to control well fluids and is connected to a wellhead and has master valves as component parts."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000229
copi:COPI_0000229 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CarrierFluidSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ChromatographyDetector
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SampleInjectionSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SeparationColumn
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ChromatographicAnalysisFunction
                                  ] ;
                  rdfs:label "chromatograph"@en ,
                             "cromatógrafo"@pt-br ;
                  skos:definition "[CFIHOS] An analysing instrument that applies the principle of chromatography to analyse the molecular composition of a substance."@en ,
                                  "[ISO 15926-4] A <CHROMATOGRAPH> is a <PROCESS ANALYSER> that analyses the molecular composition of a substance"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Chromatograph(x) ↔ ProcessAnalyzer(x) ∧ ∃f (ChromatographicAnalysisFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A chromatograph is a process analyzer that bears a chromatographic analysis function."@en ,
                                                       "Um cromatógrafo é um analisador de processo que possui uma função de análise cromatográfica."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every chromatograph is a process analyzer that has the function of chromatographic analysis."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000230
copi:COPI_0000230 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CompensationMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ConnectionInterface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:MovementCompensationFunction
                                  ] ;
                  rdfs:label "compensador"@pt-br ,
                             "compensator"@en ;
                  skos:definition "[CFIHOS] A device compensating for axial or radial movement between two elements that is connected."@en ,
                                  "[ISO 15926-4] A <COMPENSATOR> is a <FunctionalObject> that has a capability of <COMPENSATING> for axial or radial movement between two elements that is connected"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Compensator(x) ↔ MaterialArtifact(x) ∧ ∃f(MovementCompensationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A compensator is a material artifact that has the designed function of compensating for axial or radial movement between two connected elements."@en ,
                                                       "Um compensador é um artefato material que tem a função projetada de compensar movimento axial ou radial entre dois elementos conectados."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every compensator is a material artifact that bears a movement compensation function and has component parts including a compensation mechanism and connection interfaces."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000231
copi:COPI_0000231 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000222 ;
                  rdfs:label "Invólucro"@pt-br ,
                             "compressor casing"@en ;
                  skos:definition "[ISO 15926-4] A <COMPRESSOR CASING> is a  <CASING> that is the typical enclosure for compressors housing the shaft with impeller(s) and other compressor internals"@en ;
                  annotation:firstOrderLogicAxiom "∀x (CompressorCasing(x) → (Casing(x) ∧ ∃y (Compressor(y) ∧ intendedForUseWith(x,y))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A Casing that is intended for housing compressor internals including the shaft with impellers and other compressor-specific mechanical components."@en ,
                                                       "Um Invólucro que é destinado a abrigar componentes internos do compressor, incluindo o eixo com impulsores e outros componentes mecânicos específicos do compressor."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on structural configuration. Under OWA, sufficient conditions for compressor-specific casing identity could lead to false positives where any enclosure intended for compressors might be classified as a standard compressor casing, including specialized or hybrid enclosures that warrant distinct classification."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "CompressorCasing ⊑ Casing ⊓ ∃intendedForUseWith.Compressor"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000232
copi:COPI_0000232 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CondensateOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CondensationSurface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:CondensationFunction
                                  ] ;
                  rdfs:label "condensador"@pt-br ,
                             "condenser"@en ;
                  skos:definition "[CFIHOS] A cooler that is intended to change a vapour to liquid."@en ,
                                  "[ISO 15926-4] A <CONDENSER> is a <COOLER> that has a capability of  <CONDENSING> a <FLUID> from <VAPOUR> to <LIQUID>"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Condenser(x) ↔ (HeatExchanger(x) ∧ ∃f(CondensationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A condenser is a heat exchanger that bears a designed function to condense vapor to liquid by removing latent heat of vaporization."@en ,
                                                       "Um condensador é um trocador de calor que possui uma função projetada para condensar vapor em líquido removendo o calor latente de vaporização."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every condenser is a heat exchanger that bears a condensation function, and every heat exchanger that bears a condensation function is a condenser."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000233
copi:COPI_0000233 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000024 ,
                                  copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ConductivitySensor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalConditioningModule
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ConductivityTransmissionFunction
                                  ] ;
                  rdfs:label "conductivity transmitter"@en ,
                             "transmissor de condutividade"@pt-br ;
                  skos:definition "[CFIHOS] A transmitter that is intended to measure and transmit conductivity."@en ,
                                  "[ISO 15926-4] A <CONDUCTIVITY TRANSMITTER> is an <CONDUCTIVITY METER> and a <PROCESS VARIABLE TRANSMITTER>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(ConductivityTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(ConductivityMeasurementFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A conductivity transmitter is a transmitter that bears a conductivity measurement function."@en ,
                                                       "Um transmissor de condutividade é um transmissor que possui uma função de medição de condutividade."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every conductivity transmitter is a transmitter that has the function to measure and transmit electrical conductivity of process fluids."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000234
copi:COPI_0000234 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ComparisonElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MeasurementElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OutputElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ControlFunction
                                  ] ;
                  rdfs:label "controlador"@pt-br ,
                             "controller"@en ;
                  skos:definition "[CFIHOS] A regulator that operates automatically to affect a controlled variable by comparing the value of the controlled variable with the value of a reference variable in order to reduce the difference between them."@en ,
                                  "[ISO 15926-4] A <CONTROLLER> is an <INSTRUMENTATION FUNCTION> that is capable of <CONTROLLING>"@en ,
                                  "[SLB Glossary] A device that measures a controlled variable, compares it with a predetermined setting and signals an actuator to readjust the opening of a valve."@en ,
                                  "[isa5_1] a device having an output that varies to regulate a controlled variable in a specified manner that may be a self-contained analog or digital instrument, or may be the equivalent of such an instrument in a shared- control system."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Controller(x) ↔ Instrument(x) ∧ ∃f(ControlFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A controller is an instrument that bears a control function, automatically regulating a controlled variable by measuring it, comparing with a reference value, and generating output signals to reduce deviation."@en ,
                                                       "Um controlador é um instrumento que possui uma função de controle, regulando automaticamente uma variável controlada ao medi-la, comparar com um valor de referência e gerar sinais de saída para reduzir o desvio."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every controller is an instrument that has the function to control a process variable by automatic feedback regulation"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000235
copi:COPI_0000235 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FluidPathway
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HeatTransferSurface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:CoolingFunction
                                  ] ;
                  rdfs:label "cooler"@en ,
                             "resfriador"@pt-br ;
                  skos:definition "[CFIHOS] A heat exchanger that is intended to cool a physical object."@en ,
                                  "[ISO 15926-4] A <COOLER> is a <HEAT EXCHANGER> that has a capability of <COOLING>"@en ,
                                  "[POSC Caesar] A heat exchanger that is intended to cool a physical object."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Cooler(x) ↔ HeatExchanger(x) ∧ ∃f (CoolingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A cooler is a heat exchanger that bears a CoolingFunction."@en ,
                                                       "Um resfriador é um trocador de calor que possui uma FunçãoDeResfriamento."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every cooler is a heat exchanger that has the function of cooling."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000236
copi:COPI_0000236 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HeatExchangeSurface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Tower
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:CoolingFunction
                                  ] ;
                  rdfs:label "cooling tower"@en ,
                             "torre de resfriamento"@pt-br ;
                  skos:definition "[CFIHOS] A cooler and an air cooled heat exchanger that is a tall structure through which air circulates by convection."@en ,
                                  "[ISO 15926-4] A <COOLING TOWER> is an <AIR COOLED HEAT EXCHANGER> and a <TOWER> that is a tall structure through which air circulates by convection"@en ,
                                  "[POSC Caesar] A cooler and an air cooled heat exchanger that is a tall structure through which air circulates by convection"@en ;
                  skos:exactMatch copi:COPI_0000236 ;
                  annotation:firstOrderLogicAxiom "∀x(CoolingTower(x) ↔ HeatExchanger(x) ∧ ∃t(Tower(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(ConvectiveAirCirculationProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A cooling tower is a heat exchanger that incorporates a tall tower structure through which air circulates by convection to remove heat from process fluids."@en ,
                                                       "Uma torre de resfriamento é um trocador de calor que incorpora uma estrutura de torre alta através da qual o ar circula por convecção para remover calor de fluidos de processo."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every cooling tower is a heat exchanger that has a tower structure as component part at all times and participates in convective air circulation processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000237
copi:COPI_0000237 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000278 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CoriolisFlowTube
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CoriolisForceDetector
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlowTubeOscillationDriver
                                  ] ;
                  rdfs:label "coriolis mass flow meter"@en ,
                             "medidor de vazão Coriolis"@pt-br ;
                  skos:definition "[CFIHOS] A mass flow meter that uses the Coriolis principle to measure a mass flow rate through the meter."@en ,
                                  "[POSC Caesar] A mass flow meter that uses the Coriolis principle to measure a mass flow rate through the meter."@en ;
                  annotation:firstOrderLogicAxiom "∀x(CoriolisMassFlowMeter(x) → FlowMeter(x) ∧ ∃y(CoriolisFlowTube(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CoriolisPrinciple(z) ∧ utilizesPhysicalPrinciple(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A flow meter that utilizes the Coriolis principle through specialized oscillating flow tubes to directly measure mass flow rate of fluids."@en ,
                                                       "Um medidor de vazão que utiliza o princípio de Coriolis através de tubos de fluxo oscilantes especializados para medir diretamente a vazão mássica de fluidos."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. Under the Open World Assumption, defining sufficient conditions based on Coriolis principle usage could lead to false positives where other devices using Coriolis forces (like gyroscopes or accelerometers) might be incorrectly classified as flow meters. The structural differentia provides necessary conditions that can be validated by domain experts."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every coriolis mass flow meter is a flow meter that has component part at all times some Coriolis flow tube and utilizes the Coriolis principle."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000238
copi:COPI_0000238 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ConnectionFunction
                                  ] ;
                  rdfs:label "acoplamento"@pt-br ,
                             "coupling"@en ;
                  skos:definition "[CFIHOS] Connecting with a coupling or coupler."@en ,
                                  "[ISO 15926-4] <COUPLING> is the <Activity> of connecting with a coupling or coupler"@en ,
                                  "[OnePetro] The connection point of jointed pipe. It may be a steel shell with female threads to which the pins are connected or a formed female connection (box) on the end of tubing."@en ,
                                  "[POSC Caesar] Connecting with a coupling or coupler"@en ,
                                  "[SLB Glossary] An electrical or mechanical device that joins parts of systems and can affect the interaction of, or energy transfer between, parts of systems."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Coupling(x) ↔ MaterialArtifact(x) ∧ ∃f(ConnectionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A coupling is a material artifact that bears a connection function to join separate parts or systems together."@en ,
                                                       "Um acoplamento é um artefato material que possui uma função de conexão para unir partes ou sistemas separados."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every coupling is a material artifact that has the function to connect separate parts or systems together."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000239
copi:COPI_0000239 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DampingFunction
                                  ] ;
                  rdfs:label "amortecedor"@pt-br ,
                             "damper"@en ;
                  skos:definition "[CFIHOS] A device that damps, typically a valve or plate (as in the flue of a furnace) for regulating the draft, or a device to stop vibration, typically a shock absorber or snubber."@en ,
                                  "[ISO 15926-4] A <DAMPER> is a <FunctionalObject> that has the capability of <DAMPING>"@en ,
                                  "[POSC Caesar] A device for suppressing unfavourable characteristics or behavior."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Damper(x) ↔ (Assembly(x) ∧ ∃f (DampingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A damper is an assembly that bears the designed function to suppress, regulate, or reduce unfavorable dynamic characteristics such as vibrations, pressure fluctuations, or flow disturbances."@en ,
                                                       "Um amortecedor é um conjunto que possui a função projetada de suprimir, regular ou reduzir características dinâmicas desfavoráveis como vibrações, flutuações de pressão ou distúrbios de fluxo."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every damper is an assembly that bears a damping function, and every assembly that bears a damping function is a damper."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000240
copi:COPI_0000240 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DeaeratedLiquidOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DegassingChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:LiquidInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DeaerationFunction
                                  ] ;
                  rdfs:label "deaerator"@en ,
                             "desaerador"@pt-br ;
                  skos:definition "[ISO 15926-4] A <DEAERATOR> is an <ARTEFACT> and a <SEPARATOR> intended to release dissolved gases from a liquid, typically to release oxygen and carbon dioxide from water"@en ,
                                  "[OnePetro] Devices used to separate gasses from liquids."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Deaerator(x) ↔ (Separator(x) ∧ ∃f(DeaerationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A deaerator is a separator designed to remove dissolved gases from liquid streams through specialized degassing processes."@en ,
                                                       "Um desaerador é um separador projetado para remover gases dissolvidos de correntes líquidas através de processos especializados de desgaseificação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every deaerator is a separator that bears a deaeration function for removing dissolved gases from liquids"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000241
copi:COPI_0000241 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CleanFluidOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FluidInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasSeparationChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DegassingFunction
                                  ] ;
                  rdfs:label "degaseificador"@pt-br ,
                             "degasser"@en ;
                  skos:definition "[CFIHOS] A device that removes air or gases (methane, H2S, CO2 and others) from drilling liquids."@en ,
                                  "[ISO 15926-4] A <DEGASSER> is an <ARTEFACT> and a  <FLASH SEPARATOR> that is a device used in drilling to remove gasses from drilling fluid which could otherwise form bubbles"@en ,
                                  "[OnePetro] Any device that helps remove gas from circulated fluid."@en ,
                                  "[SLB Glossary] A device that removes air or gases (methane, H2S, CO2, and others) from drilling liquids."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Degasser(x) ↔ (Separator(x) ∧ ∃f (DegassingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A degasser is a separator that removes gases from drilling fluids by realizing a degassing function."@en ,
                                                       "Um degaseificador é um separador que remove gases de fluidos de perfuração realizando uma função de degaseificação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every degasser is a separator that bears a degassing function and has drilling fluid as input and degassed drilling fluid plus separated gases as outputs."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000242
copi:COPI_0000242 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirIntake
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000115
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MoistureCollectionSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DehumidificationFunction
                                  ] ;
                  rdfs:label "dehumidifier"@en ,
                             "desumidificador"@pt-br ;
                  skos:definition "[CFIHOS] A piece of equipment specifically designed to remove moisture from air."@en ,
                                  "[ISO 15926-4] A <DEHUMIDIFIER> is a <FunctionalObject> that is capable of <DEHUMIDIFYING>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Dehumidifier(x) ↔ Assembly(x) ∧ ∃f(DehumidificationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A dehumidifier is an assembly that bears the function to remove moisture from air."@en ,
                                                       "Um desumidificador é um conjunto que possui a função de remover umidade do ar."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every dehumidifier is an assembly that has the function to perform dehumidification."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000243
copi:COPI_0000243 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:InletConnection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OutletConnection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TreatingVessel
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DehydrationFunction
                                  ] ;
                  rdfs:label "dehydrator"@en ,
                             "desidratador"@pt-br ;
                  skos:definition "[ISO 15926-4] A <DEHYDRATOR> is a <FunctionalObject> that is capable of <DEHYDRATING>"@en ,
                                  "[OnePetro] A treating vessel designed to remove water from a process stream."@en ,
                                  "[SLB Glossary] A device used to remove water and water vapors from gas."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Dehydrator(x) ↔ Separator(x) ∧ ∃f (DehydrationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A dehydrator is a separator that bears the designed function of removing water and water vapor from process streams."@en ,
                                                       "Um desidratador é um separador que possui a função projetada de remover água e vapor de água de correntes de processo."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every dehydrator is a separator that has the function of dehydration."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000244
copi:COPI_0000244 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DemistingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DropletCollectionSurface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DemistingFunction
                                  ] ;
                  rdfs:label "demister"@en ,
                             "demister"@pt-br ;
                  skos:definition "[CFIHOS] A physical object intended to catch fluid droplets."@en ,
                                  "[ISO 15926-4] A <DEMISTER> is a <FunctionalObject> that is capable of <DEMISTING>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Demister(x) ↔ Separator(x) ∧ ∃f(DemistingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A demister is a separator that bears a demisting function for removing liquid droplets from gas streams through coalescence mechanisms."@en ,
                                                       "Um demister é um separador que possui uma função de desmistificação para remover gotículas de líquido de correntes gasosas através de mecanismos de coalescência."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every demister is a separator that has the function of demisting gas streams by coalescing and removing entrained liquid droplets."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000245
copi:COPI_0000245 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DisplayOrOutputDevice
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Sensor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DensityMeasurementFunction
                                  ] ;
                  rdfs:label "densitometer"@en ,
                             "densitômetro"@pt-br ;
                  skos:definition "[ISO 15926-4] A <DENSITOMETER> is an <INSTRUMENTATION ITEM> and a <MEASURING INSTRUMENT> that measures the degree of darkness in photographic or semitransparent material. The densitometer is basically a light source aimed at a photoelectric cell which determines the density of the sample from differences in the readings"@en ,
                                  "[OnePetro] A device used for reading the density of a flowing fluid or slurry."@en ,
                                  "[SLB Glossary] A device installed on a mixing or pumping system manifold to measure the density of fluids."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Densitometer(x) ↔ Instrument(x) ∧ ∃f(DensityMeasurementFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A densitometer is an instrument that bears a density measurement function."@en ,
                                                       "Um densitômetro é um instrumento que possui uma função de medição de densidade."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every densitometer is an instrument that has the function of measuring density."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000246
copi:COPI_0000246 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SensingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalGenerationDevice
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DetectionFunction
                                  ] ;
                  rdfs:label "detector"@en ,
                             "detector"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that is an assembly of a sensing element and necessary ancillary devices making it able of detecting a state, e.g. pressure, temperature, or detect the presence of a selected substance, and produce a signal based on the detection."@en ,
                                  "[ISO 15926-4] A <DETECTOR> is an <INSTRUMENTATION FUNCTION> that has a capability of <DETECTING>"@en ,
                                  "[SLB Glossary] A sensor or receiver, such as a geophone or hydrophone, gravimeter or magnetometer."@en ,
                                  "[isa5_1] a device that is used to detect the presence of something, such as flammable or toxic gases or discrete parts; see also primary element and sensor."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Detector(x) ↔ Instrument(x) ∧ ∃f(DetectionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A detector is an instrument that bears a detection function, enabling it to sense states, substances, or phenomena and produce signals based on the detection."@en ,
                                                       "Um detector é um instrumento que possui uma função de detecção, permitindo-lhe detectar estados, substâncias ou fenômenos e produzir sinais baseados na detecção."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every detector is an instrument that has a detection function and has component parts including a sensing element and signal generation device."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000247
copi:COPI_0000247 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000076
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CondensationDetector
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SampleChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DewPointMeasurementFunction
                                  ] ;
                  rdfs:label "analisador de ponto de orvalho"@pt-br ,
                             "dew point analyser"@en ;
                  skos:definition "[CFIHOS] An analysing instrument intended to determine the dew point of a substance."@en ,
                                  "[ISO 15926-4] A <DEW POINT ANALYSER> is a <PROCESS ANALYSER> intended to determine the dew point of a substance"@en ;
                  annotation:firstOrderLogicAxiom "∀x(DewPointAnalyser(x) ↔ Instrument(x) ∧ ∃f(DewPointMeasurementFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A dew point analyser is an instrument that bears a dew point measurement function."@en ,
                                                       "Um analisador de ponto de orvalho é um instrumento que possui uma função de medição de ponto de orvalho."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every dew point analyser is an instrument that has the function to determine the dew point of a substance"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000248
copi:COPI_0000248 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000207 ;
                  rdfs:label "atuador de diafragma"@pt-br ,
                             "diaphragm actuator"@en ;
                  skos:definition "[ISO 15926-4] A <DIAPHRAGM ACTUATOR> is an <INSTRUMENTATION ITEM> and a <CONTROLLED ACTUATOR> that is using a <DIAPHRAGM>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(DiaphragmActuator(x) → (Actuator(x) ∧ ∃y(Diaphragm(y) ∧ hasComponentPartAtAllTimes(x,y))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A diaphragm actuator is an actuator that uses a diaphragm as an essential component for converting control signals into mechanical motion or force to operate other equipment."@en ,
                                                       "Um atuador de diafragma é um atuador que utiliza um diafragma como componente essencial para converter sinais de controle em movimento mecânico ou força para operar outros equipamentos."@pt-br ;
                  annotation:primitiveRationale "Classification basis is constructive - identity given by diaphragm mechanism. Under OWA, sufficient conditions would force any equipment with a diaphragm component to be classified as a diaphragm actuator, potentially including complex hybrid systems or custom equipment where the diaphragm serves auxiliary functions. Starting with necessary conditions protects against such false positives."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "DiaphragmActuator ⊑ Actuator ⊓ ∃hasComponentPartAtAllTimes.Diaphragm"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000249
copi:COPI_0000249 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000337 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DiaphragmChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlexibleDiaphragm
                                  ] ;
                  rdfs:label "bomba de diafragma"@pt-br ,
                             "diaphragm pump"@en ;
                  skos:definition "[ISO 15926-4] A <DIAPHRAGM PUMP> is a <RECIPROCATING PUMP> intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere; flow rate is achieved through reciprocatory motion of the diaphragm"@en ,
                                  "[POSC Caesar] A reciprocating pump intended to pump a liquid with a small capacity. This is done by means of thin flexible diaphragms to seal pumped fluid from leakage to atmosphere."@en ;
                  annotation:firstOrderLogicAxiom "∀x(DiaphragmPump(x) → (ReciprocatingPump(x) ∧ ∃d(FlexibleDiaphragm(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃p(DiaphragmSealing(p) ∧ participatesIn(x,p))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A diaphragm pump is a reciprocating pump that uses flexible diaphragms to displace liquid and seal the pumped fluid from atmospheric leakage."@en ,
                                                       "Uma bomba de diafragma é uma bomba alternativa que usa diafragmas flexíveis para deslocar líquido e selar o fluido bombeado contra vazamento atmosférico."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type defined by physical mechanism. Under OWA, any pump with a flexible diaphragm component could be classified as a diaphragm pump, but there may be hybrid or specialized equipment containing diaphragms that should not be automatically classified into this maintenance category."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every diaphragm pump is a reciprocating pump that has flexible diaphragm as component part at all times and participates in diaphragm sealing."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000250
copi:COPI_0000250 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000264 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CompressionChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CompressionIgnitionSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Piston
                                  ] ;
                  rdfs:label "diesel engine"@en ,
                             "motor diesel"@pt-br ;
                  skos:definition "[CFIHOS] An internal combustion engine in which ignition of the fuel injected into the cylinder is performed by the heat of compression of the air charge."@en ,
                                  "[ISO 15926-4] A <DIESEL ENGINE> is  an <INTERNAL COMBUSTION ENGINE> and a <RECIPROCATING PISTON ENGINE> in which ignition of the fuel injected into the cylinder is performed by the heat of compression of the air charge"@en ,
                                  "[POSC Caesar] An internal combustion engine in which ignition of the fuel injected into the cylinder is performed by the heat of compression of the air charge."@en ;
                  annotation:firstOrderLogicAxiom "DieselEngine(x) → Engine(x) ∧ ∃s(CompressionIgnitionSystem(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f(FuelInjectionSystem(f) ∧ hasComponentPartAtAllTimes(x,f)) ∧ ∃p(CompressionIgnitionProcess(p) ∧ participatesIn(x,p))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A diesel engine is an engine that ignites fuel through compression heat rather than spark ignition, requiring compression ignition and fuel injection systems."@en ,
                                                       "Um motor diesel é um motor que inflama combustível através do calor de compressão em vez de ignição por centelha, requerendo sistemas de ignição por compressão e injeção de combustível."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. While compression ignition is characteristic of diesel engines, under OWA we cannot be certain that any engine with compression ignition systems is necessarily a diesel engine - there could be hybrid or specialized engines with similar mechanisms that should not be auto-classified as standard diesel engines without expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "A diesel engine is necessarily an engine that has compression ignition system and fuel injection system and participates in compression ignition process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000251
copi:COPI_0000251 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000142 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000179
                                  ] ;
                  rdfs:label "differential pressure measuring element"@en ,
                             "elemento medidor de pressão diferencial"@pt-br ;
                  skos:definition "[ISO 15926-4] A <DIFFERENTIAL PRESSURE MEASURING ELEMENT> is a <PRESSURE MEASURING ELEMENT> for the measurement of <DIFFERENTIAL PRESSURE>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(DifferentialPressureMeasuringElement(x) ↔ (PressureElement(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A pressure element that bears a differential pressure measurement function and that consists in sensing the pressure difference between two fluid media or connection points to enable measurement of differential pressure through mechanical deflection proportional to the pressure difference."@en ,
                                                       "Um elemento de pressão que porta uma função de medição de pressão diferencial e que consiste em detectar a diferença de pressão entre duas mídias fluidas ou pontos de conexão para permitir a medição de pressão diferencial através de deflexão mecânica proporcional à diferença de pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "DifferentialPressureMeasuringElement equivalentTo PressureElement and bearerOf some DifferentialPressureMeasurementFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000252
copi:COPI_0000252 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DifferentialPressureSensor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureInput
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SwitchingMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DifferentialPressureSwitchingFunction
                                  ] ;
                  rdfs:label "differential pressure switch"@en ,
                             "interruptor de pressão diferencial"@pt-br ;
                  skos:definition "[CFIHOS] A pilot switch intended to switch or give an on/off signal when the measured differential pressure has reached a pre-set value."@en ,
                                  "[ISO 15926-4] A <DIFFERENTIAL PRESSURE SWITCH> is a <PRESSURE SWITCH> and a <DIFFERENTIAL PRESSURE MEASURING INSTRUMENT>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(DifferentialPressureSwitch(x) ↔ PressureSwitch(x) ∧ ∃f(DifferentialPressureSwitchingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A differential pressure switch is a pressure switch that bears a differential pressure switching function to switch or provide on/off signals when the measured differential pressure between two inputs reaches a pre-set value."@en ,
                                                       "Um interruptor de pressão diferencial é um interruptor de pressão que possui uma função de comutação de pressão diferencial para comutar ou fornecer sinais liga/desliga quando a pressão diferencial medida entre duas entradas atinge um valor pré-estabelecido."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every differential pressure switch is a pressure switch that has the function to switch based on differential pressure measurements between two pressure inputs."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000253
copi:COPI_0000253 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DivergingChannel
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlowGuide
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnergyDiffusionFunction
                                  ] ;
                  rdfs:label "diffuser"@en ,
                             "difusor"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that contains a diverging channel-shaped chamber in which part of the kinetic energy of the fluid is converted into pressure energy."@en ,
                                  "[ISO 15926-4] A <DIFFUSER> is a <FunctionalObject> that has the capability of <DIFFUSING> which is used in pumps to convert kinetic energy imparted by impeller to potential energy i.e. pressure head."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Diffuser(x) ↔ Assembly(x) ∧ ∃f(EnergyDiffusionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A diffuser is an assembly that has the designed function of converting kinetic energy of fluid flow into pressure energy through controlled deceleration in a diverging passage."@en ,
                                                       "Um difusor é um conjunto que tem a função projetada de converter energia cinética do fluxo de fluido em energia de pressão através de desaceleração controlada em uma passagem divergente."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every diffuser is an assembly that bears an energy diffusion function and has a diverging channel as component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000254
copi:COPI_0000254 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:InformationDisplayFunction
                                  ] ;
                  rdfs:label "display"@en ,
                             "display"@pt-br ;
                  skos:definition "[ISO 15926-4] A <DISPLAY> is a <FunctionalObject> that is capable of <DISPLAYING> something"@en ,
                                  "[POSC Caesar] A physical object that is intended for presenting information."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Display(x) ↔ Instrument(x) ∧ ∃f(InformationDisplayFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A Display is an Instrument that bears an InformationDisplayFunction and that presents information visually to operators or users."@en ,
                                                       "Um Display é um Instrumento que possui uma InformationDisplayFunction e que apresenta informações visualmente para operadores ou usuários."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Display is an Instrument that necessarily bears an InformationDisplayFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000255
copi:COPI_0000255 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BottomOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ColumnShell
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FeedInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:InternalTrays
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OverheadOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DistillationFunction
                                  ] ;
                  rdfs:label "coluna de destilação"@pt-br ,
                             "distillation column"@en ;
                  skos:definition "[CFIHOS] A process column intended to enable a distillation process."@en ,
                                  "[ISO 15926-4] A <DISTILLATION COLUMN> is  a <DISTILLATION SEPARATOR> and a <PROCESS COLUMN> and a <DISTILLER> intended to enable a distillation process"@en ,
                                  "[POSC Caesar] A process column intended to enable a distillation process"@en ;
                  annotation:firstOrderLogicAxiom "∀x (DistillationColumn(x) ↔ (Separator(x) ∧ ∃f (DistillationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A distillation column is a separator that bears a distillation function to enable separation of fluid mixtures based on differences in component boiling points through vapor-liquid equilibrium."@en ,
                                                       "Uma coluna de destilação é um separador que possui uma função de destilação para permitir a separação de misturas de fluidos baseada nas diferenças dos pontos de ebulição dos componentes através do equilíbrio vapor-líquido."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every distillation column is a separator that has the function to perform distillation processes"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000256
copi:COPI_0000256 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DivertingFunction
                                  ] ;
                  rdfs:label "diverter"@en ,
                             "diverter"@pt-br ;
                  skos:definition "[CFIHOS] A 'device' that is providing diversion of something from an expected course or direction."@en ,
                                  "[ISO 15926-4] A <DIVERTER> is a <FunctionalObject> that has a capability of <DIVERTING>"@en ,
                                  "[OnePetro] In the context of acidizing, a diverter is a material that forces acid to enter another zone by having a higher viscosity or building a filter cake.                  In the context of a wellhead, a diverter is a device in the flowpath at the wellhead that forces fluid to go down a pipe to a pit or tank."@en ,
                                  "[SLB Glossary] A chemical agent or mechanical device used in injection treatments, such as matrix stimulation, to ensure a uniform distribution of treatment fluid across the treatment interval."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Diverter(x) ↔ MaterialArtifact(x) ∧ ∃f(DivertingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A diverter is a material artifact that bears a designed function to divert or redirect materials, fluids, or flows from their expected course to alternative paths or destinations."@en ,
                                                       "Um diverter é um artefato material que possui uma função projetada para desviar ou redirecionar materiais, fluidos ou fluxos de seu curso esperado para caminhos ou destinos alternativos."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every diverter is a material artifact that has the function of diverting materials or flows from expected paths to alternative destinations."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000257
copi:COPI_0000257 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000192
                                  ] ;
                  rdfs:label "drive shaft"@en ,
                             "eixo de transmissão"@pt-br ;
                  skos:definition "[ISO 15926-4] A <DRIVE SHAFT> is an <ARTEFACT> and an <ENERGY TRANSFERRER> that is a shaft used to transfer rotational power from a prime driver to several individual machines by use of drive belts and pulley wheels"@en ;
                  annotation:firstOrderLogicAxiom "∀x (DriveShaft(x) ↔ (Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(RotationalPowerTransferProcess(p) ∧ participatesIn(x,p))))"@en ;
                  annotation:naturalLanguageDefinition "A drive shaft is an Assembly that bears a PowerTransmissionFunction and consists in a shaft-based system used to transfer rotational mechanical energy from a prime mover to multiple driven machines."@en ,
                                                       "Um eixo de transmissão é um Assembly que possui uma PowerTransmissionFunction e consiste em um sistema baseado em eixo usado para transferir energia mecânica rotacional de um motor primário para múltiplas máquinas acionadas."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "DriveShaft ≡ Assembly ⊓ ∃bearerOf.PowerTransmissionFunction ⊓ ∃participatesIn.RotationalPowerTransferProcess"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000258
copi:COPI_0000258 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DryingChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MaterialHandlingSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:DryingFunction
                                  ] ;
                  rdfs:label "dryer"@en ,
                             "secador"@pt-br ;
                  skos:definition "[DEXPI] An object that has the capability of drying (from ``_)."@en ,
                                  "[ISO 15926-4] A <DRYER> is a <FunctionalObject> that has a capability of <DRYING>"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Dryer(x) ↔ Assembly(x) ∧ ∃f(DryingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A dryer is an assembly that bears a drying function to remove moisture from materials."@en ,
                                                       "Um secador é um conjunto que possui uma função de secagem para remover umidade de materiais."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every dryer is an assembly that has the function of drying materials by removing moisture."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000259
copi:COPI_0000259 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000072 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DischargeOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MotiveFluidNozzle
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SuctionInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:VenturaThroat
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000066
                                  ] ;
                  rdfs:label "eductor"@en ,
                             "edutor"@pt-br ;
                  skos:definition "[CFIHOS] A form of suction pump; a device using a high pressure jet of water to create partial vacuum at an intake opening to draw liquid from a sump."@en ,
                                  "[ISO 15926-4] An <EDUCTOR> is an <ARTEFACT> and a <PUMP> that is a form of suction pump; a device using a high pressure jet of water to create partial vacuum at an intake opening to draw liquid from a sump"@en ,
                                  "[OnePetro] A device that through flow of a power fluid through a nozzle, creates a low pressure area useful for moving fluids."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Eductor(x) → Pump(x) ∧ ∃n(MotiveFluidNozzle(n) ∧ hasComponentPartAtAllTimes(x,n)) ∧ ∃t(VenturaThroat(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃p(JetEntrainmentProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An eductor is a pump that uses a high-pressure motive fluid jet to create a low-pressure zone that entrains and moves a second fluid via momentum transfer."@en ,
                                                       "Um edutor é uma bomba que usa um jato de fluido motriz de alta pressão para criar uma zona de baixa pressão que arrasta e move um segundo fluido via transferência de momento."@pt-br ;
                  annotation:primitiveRationale "The constructive differentia based on jet entrainment mechanism could potentially apply to hybrid or specialized equipment that incorporates eductor principles but should not be automatically classified as a standard eductor type. Under OWA, necessary conditions protect against false positive classifications."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every eductor is a pump that has a motive fluid nozzle and Ventura throat as component parts and participates in a jet entrainment process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000260
copi:COPI_0000260 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000207 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricToMechanicalConverter
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricalTerminal
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HousingEnclosure
                                  ] ;
                  rdfs:label "atuador elétrico"@pt-br ,
                             "electric actuator"@en ;
                  skos:definition "[CFIHOS] An actuator that produces a specified movement when excited by an electric signal."@en ,
                                  "[ISO 15926-4] An <ELECTRIC ACTUATOR> is an <INSTRUMENTATION ITEM> and a <CONTROLLED ACTUATOR> and an <ELECTRICAL APPARATUS> and an <ELECTRIC TO MECHANICAL ENERGY CONVERTER> that produces a specified movement when actuated by electrical energy"@en ,
                                  "[POSC Caesar] An actuator that produces a specified movement when excited by an electric signal."@en ;
                  annotation:firstOrderLogicAxiom "∀x(ElectricActuator(x) → Actuator(x) ∧ ∃y(ElectricToMechanicalConverter(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ElectricalSignal(z) ∧ hasInput(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An electric actuator is an actuator that converts electrical energy to mechanical movement through an electric-to-mechanical converter component and operates via electrical signal input."@en ,
                                                       "Um atuador elétrico é um atuador que converte energia elétrica em movimento mecânico através de um componente conversor elétrico-mecânico e opera via entrada de sinal elétrico."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on electrical energy conversion mechanism. Under OWA, asserting equivalence would force any artifact with electrical-to-mechanical conversion into this category, potentially misclassifying specialized hybrid equipment or complex electrical machinery that should not be categorized as standard actuators."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every electric actuator is an actuator that has an electric-to-mechanical converter component at all times and has electrical signal input."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000261
copi:COPI_0000261 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000342
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000355
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricalTerminal
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ElectricEnergyGenerationFunction
                                  ] ;
                  rdfs:label "electric generator"@en ,
                             "gerador elétrico"@pt-br ;
                  skos:definition "[CFIHOS] An energy transducer that transforms non-electric energy into electric energy."@en ,
                                  "[ISO 15926-4] An <ELECTRIC GENERATOR> is a <GENERATOR> that transforms non-electric energy into <ELECTRIC ENERGY>"@en ;
                  annotation:firstOrderLogicAxiom "∀x (ElectricGenerator(x) ↔ (Assembly(x) ∧ ∃f(ElectricEnergyGenerationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "An electric generator is an assembly that bears the function of converting non-electric energy into electric energy"@en ,
                                                       "Um gerador elétrico é um conjunto que possui a função de converter energia não-elétrica em energia elétrica"@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every electric generator is an assembly that has the function to convert non-electric energy into electric energy"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000262
copi:COPI_0000262 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ElectricalConductionFunction
                                  ] ;
                  rdfs:label "conexão elétrica"@pt-br ,
                             "electrical connection"@en ;
                  skos:definition "[ISO 15926-4] An <ELECTRICAL CONNECTION> is a <DirectConnection> for letting pass a <CURRENT> from one <ELECTRICAL APPARATUS> to another"@en ;
                  annotation:firstOrderLogicAxiom "∀x(ElectricalConnection(x) ↔ (MaterialArtifact(x) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ElectricalConductionProcess(p) ∧ participatesIn(x,p) ∧ ∃y(ElectricalApparatus(y) ∧ has_participant_at_some_time(p,y)))))"@en ;
                  annotation:naturalLanguageDefinition "An electrical connection is a MaterialArtifact that bears an ElectricalConductionFunction and that provides a pathway for electrical current to pass from one electrical apparatus to another."@en ,
                                                       "Uma conexão elétrica é um MaterialArtifact que possui uma ElectricalConductionFunction e que fornece um caminho para a corrente elétrica passar de um aparelho elétrico para outro."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every electrical connection is a material artifact that bears an electrical conduction function and participates in processes involving electrical apparatus."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000263
copi:COPI_0000263 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000238 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ElectricalConnectionFunction
                                  ] ;
                  rdfs:label "conector elétrico"@pt-br ,
                             "electrical connector"@en ;
                  skos:definition "[CFIHOS] A connector for holding two parts of a conductor in intimate contact."@en ,
                                  "[ISO 15926-4] An <ELECTRICAL CONNECTOR> is an <ARTEFACT> and an <CONNECTOR> for holding two parts of <ELECTRICAL CONDUCTOR> in intimate contact"@en ;
                  annotation:firstOrderLogicAxiom "∀x(ElectricalConnector(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalConnectionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "An electrical connector is an electrical equipment that bears an electrical connection function and that maintains intimate electrical contact between two or more electrical conductor parts to enable continuous current flow."@en ,
                                                       "Um conector elétrico é um equipamento elétrico que possui uma função de conexão elétrica e que mantém contato elétrico íntimo entre duas ou mais partes de condutor elétrico para permitir fluxo contínuo de corrente."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "ElectricalConnector ≡ ElectricalEquipment ⊓ ∃bearerOf.ElectricalConnectionFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000264
copi:COPI_0000264 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000315 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CombustionChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FuelInjectionSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:IgnitionSystem
                                  ] ;
                  rdfs:label "engine"@en ,
                             "motor"@pt-br ;
                  skos:definition "[CFIHOS] An internal combustion engine that is an induction compression ignition exhaust engine which ignites a fuel air mixture."@en ,
                                  "[ISO 15926-4] An <ENGINE> is a <MOTOR> and a <MACHINE> that converts energy into mechanical force and motion"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Engine(x) ↔ Motor(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(ChemicalFuelPortion(p) ∧ hasInput(x,p)) ∧ ∃c(CombustionProcess(c) ∧ participatesIn(x,c)))"@en ;
                  annotation:naturalLanguageDefinition "An engine is a motor that converts chemical fuel energy into mechanical force and motion through combustion processes."@en ,
                                                       "Um motor é um motor que converte energia de combustível químico em força mecânica e movimento através de processos de combustão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every Engine is a Motor that has function MechanicalEnergyGenerationFunction and has input ChemicalFuelPortion and participates in CombustionProcess."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000265
copi:COPI_0000265 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ConnectionInterface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlexibleElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ThermalExpansionAccommodationFunction
                                  ] ;
                  rdfs:label "expansion joint"@en ,
                             "junta de expansão"@pt-br ;
                  skos:definition "[CFIHOS] Flexible joint between two pipes to receive expansion from the pipes."@en ,
                                  "[ISO 15926-4] An <EXPANSION JOINT> is an <ARTEFACT> and a <JOINT> that makes allowance for thermal expansion of the parts joined without distortion"@en ,
                                  "[OnePetro] A device in a length of pipe that allows some pipe length expansion or contraction."@en ,
                                  "[SLB Glossary] A device or completion component designed to enable relative movement between two fixed assemblies in the event of thermal expansion or contraction."@en ;
                  annotation:firstOrderLogicAxiom "∀x (ExpansionJoint(x) ↔ (MaterialArtifact(x) ∧ ∃f(ThermalExpansionAccommodationFunction(f) ∧ bearerOf(x,f)) ∧ ∃g(FlexibilityFunction(g) ∧ hasFunction(x,g))))"@en ;
                  annotation:naturalLanguageDefinition "An expansion joint is a material artifact that bears the designed function of accommodating thermal expansion and contraction between connected components through inherent flexibility while maintaining structural integrity."@en ,
                                                       "Uma junta de expansão é um artefato material que possui a função projetada de acomodar expansão e contração térmica entre componentes conectados através de flexibilidade inerente, mantendo a integridade estrutural."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every expansion joint is a material artifact that bears a thermal expansion accommodation function and has a flexibility function, and every material artifact that bears a thermal expansion accommodation function and has a flexibility function is an expansion joint."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000266
copi:COPI_0000266 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000081 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CartridgeHousing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ReplaceableFilterMedium
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000194
                                  ] ;
                  rdfs:label "cartucho de filtro"@pt-br ,
                             "filter cartridge"@en ;
                  skos:definition "[CFIHOS] A filter element intended to collect particles from a stream in a filter or strainer."@en ,
                                  "[ISO 15926-4] A <FILTER CARTRIDGE> is an <ARTEFACT> and a <FILTER ELEMENT> intended to collect particles from a stream in a filter or strainer"@en ,
                                  "[POSC Caesar] A filter element intended to collect particles from a stream in a filter or strainer."@en ;
                  annotation:firstOrderLogicAxiom "∀x (FilterCartridge(x) → Filter(x) ∧ ∃m (ReplaceableFilterMedium(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p (CartridgeGeometryProperty(p) ∧ bearerOf(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A filter cartridge is a filter that has a replaceable filter medium in a cartridge form factor designed for insertion into and removal from a filter housing."@en ,
                                                       "Um cartucho de filtro é um filtro que possui um meio filtrante substituível em formato de cartucho projetado para inserção e remoção de um alojamento de filtro."@pt-br ;
                  annotation:primitiveRationale "Constructive type where the structural differentia (cartridge geometry and replaceability) is necessary but making it sufficient under OWA could lead to false positives - other equipment containing replaceable filter elements might be incorrectly classified as filter cartridges rather than their proper specialized categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every filter cartridge is a filter that has a replaceable filter medium as component part and bears a cartridge geometry property."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000267
copi:COPI_0000267 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000081 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000194
                                  ] ;
                  rdfs:label "elemento filtrante"@pt-br ,
                             "filter element"@en ;
                  skos:definition "[ISO 15926-4] A <FILTER ELEMENT> is a <FILTER> and that is the part of a filter assembly that is made from filter media"@en ;
                  annotation:firstOrderLogicAxiom "∀x(FilterElement(x) → Filter(x) ∧ ∃m(FilterMedia(m) ∧ madeFrom(x,m)) ∧ ∃a(FilterAssembly(a) ∧ componentPartOf(x,a)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A Filter that is made from filter media and that is a component part of a filter assembly."@en ,
                                                       "Um Filtro que é feito de meio filtrante e que é uma parte componente de um conjunto de filtro."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on material composition (filter media) and mereological relationship (component of assembly). Under OWA, asserting equivalence could lead to unintended classification of any artifact made from filter media as a filter element, including specialized or hybrid components that contain filter media but serve different primary functions."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "FilterElement SubClassOf Filter and (madeFrom some FilterMedia) and (componentPartOf some FilterAssembly)"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000268
copi:COPI_0000268 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000081 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FilterCell
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FilterMedium
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000194
                                  ] ;
                  rdfs:label "filter press"@en ,
                             "prensa filtrante"@pt-br ;
                  skos:definition "[ISO 15926-4] A <FILTER PRESS> is a <FILTER> and a <PRESS(machine)> intended to separate substance through compression"@en ,
                                  "[OnePetro] Usually a DE filter."@en ,
                                  "[SLB Glossary] A pressurized cell, fitted with a filter medium, used for evaluating filtration characteristics of a drilling fluid while it is either static or stirred."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FilterPress(x) → Filter(x) ∧ ∃p(PressureMechanism(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃proc(MechanicalCompressionProcess(proc) ∧ participatesIn(x,proc)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A filter press is a filter that applies mechanical compression force to enhance the separation of substances through a pressurized filtration process."@en ,
                                                       "Uma prensa filtrante é um filtro que aplica força de compressão mecânica para melhorar a separação de substâncias através de um processo de filtração pressurizada."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is classified as 'both' functional and constructive. The structural differentia (pressure mechanism and compression process) involves specific mechanical configurations that are harder to make sufficient under Open World Assumption without detailed engineering specifications."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every filter press is a filter that has a pressure mechanism as part and participates in mechanical compression processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000269
copi:COPI_0000269 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FinnedTube
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HeatExchangerCasing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TubeBundle
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000068
                                  ] ;
                  rdfs:label "finned tube heat exchanger"@en ,
                             "trocador de calor de tubos aletados"@pt-br ;
                  skos:definition "[CFIHOS] A heat exchanger that has finned tubes."@en ,
                                  "[ISO 15926-4] A <FINNED TUBE HEAT EXCHANGER> is an <INDIRECT CONTACT HEAT EXCHANGER> that has finned tubes"@en ,
                                  "[POSC Caesar] A heat exchange that has finned tubes."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FinnedTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃y(FinnedTube(y) ∧ hasComponentPartAtAllTimes(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A finned tube heat exchanger is a heat exchanger that has finned tubes as the primary heat transfer surface enhancement mechanism."@en ,
                                                       "Um trocador de calor de tubos aletados é um trocador de calor que possui tubos aletados como mecanismo primário de aumento da superfície de transferência de calor."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. While finned tubes are the defining structural feature, making sufficient conditions (equivalence) under Open World Assumption could lead to false positives where any assembly containing finned tubes would be classified as this specific heat exchanger type, including complex multi-function equipment or specialized hybrid systems."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every finned tube heat exchanger is a heat exchanger that has finned tubes as component parts at all times"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000270
copi:COPI_0000270 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000124 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000220
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000281
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HeatTransferTubes
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Stack
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FiredHeatingFunction
                                  ] ;
                  rdfs:label "aquecedor a combustão"@pt-br ,
                             "fired heater"@en ;
                  skos:definition "[CFIHOS] Is a fired heat transfer equipment intended to burn fuel and to transfer the heat of combustion to a liquid without vaporising the liquid."@en ,
                                  "[ISO 15926-4] A <FIRED HEATER> is an <ARTEFACT> and a <HEATER> in which the heat converted from burning solids, liquids or gas is transferred to a media"@en ;
                  annotation:firstOrderLogicAxiom "∀x(FiredHeater(x) ↔ (Heater(x) ∧ ∃f(FiredHeatingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A fired heater is a heater that burns fuel (solid, liquid, or gas) to generate heat for transfer to a process fluid medium."@en ,
                                                       "Um aquecedor a combustão é um aquecedor que queima combustível (sólido, líquido ou gasoso) para gerar calor para transferência para um fluido de processo."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every fired heater is a heater that bears a FiredHeatingFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000271
copi:COPI_0000271 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000297
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlameArrestElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FlameArrestFunction
                                  ] ;
                  rdfs:label "arrestador de chama"@pt-br ,
                             "flame arrestor"@en ;
                  skos:definition "[CFIHOS] An arrestor which is a trap over an opening, e.g. of a ventilation system or a pipe, to prevent flames from entering the system."@en ,
                                  "[ISO 15926-4] A <FLAME ARRESTOR> is an <ARTEFACT> and an <ARRESTOR> that is a trap covering an opening, e.g of a ventilation system or a pipe, to prevent flames from entering the system"@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlameArrestor(x) ↔ SafetyDevice(x) ∧ ∃f(FlameArrestFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A flame arrestor is a safety device that bears a flame arrest function to prevent flames from entering a system through an opening."@en ,
                                                       "Um arrestador de chama é um dispositivo de segurança que possui uma função de arrestar chama para prevenir que chamas entrem em um sistema através de uma abertura."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flame arrestor is a safety device that has the function of arresting flames and processes gaseous portions while preventing flame propagation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000272
copi:COPI_0000272 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000246 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlameSensingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalProcessingUnit
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FlameDetectionFunction
                                  ] ;
                  rdfs:label "detector de chama"@pt-br ,
                             "flame detector"@en ;
                  skos:definition "[CFIHOS] A detector that is intended to sense a flame."@en ,
                                  "[ISO 15926-4] A <FLAME DETECTOR> is a <DETECTOR> and a <FLAME DETECTING INSTRUMENT> using a <FLAME DETECTING MEASURING ELEMENT> that is designed to detect the presence of a flame"@en ,
                                  "[POSC Caesar] A detector that is intended to sense a flame."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlameDetector(x) ↔ Detector(x) ∧ ∃f(FlameDetectionFunction(f) ∧ hasFunction(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A flame detector is a detector that has the function to detect the presence of flames."@en ,
                                                       "Um detector de chama é um detector que tem a função de detectar a presença de chamas."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flame detector is a detector that has a flame detection function, and every detector that has a flame detection function is a flame detector."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000273
copi:COPI_0000273 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000238 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BoltHole
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlangeBody
                                  ] ;
                  rdfs:label "flange"@en ,
                             "flange"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that is a projecting flat rim, plate, collar or rib."@en ,
                                  "[ISO 15926-4] A <FLANGE> is an <ARTEFACT> and a <CONNECTOR> that is a projecting flat rim, plate, collar, or rib for strength or for attachment to another object"@en ,
                                  "[OnePetro] A common, high pressure wellhead connection, using bolt attached flange plates and metal-to-metal seals."@en ,
                                  "[SLB Glossary] A connection profile used in pipe work and associated equipment to provide a means of assembling and disassembling components."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Flange(x) → MaterialArtifact(x) ∧ ∃g(ProjectingFlatRimGeometry(g) ∧ hasCharacteristic(x,g)) ∧ ∃f(MechanicalConnectionFunction(f) ∧ hasFunction(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A flange is a material artifact characterized by a projecting flat rim, plate, collar, or rib geometry, designed to provide mechanical connection between components."@en ,
                                                       "Um flange é um artefato material caracterizado por uma geometria de aro plano projetante, placa, colar ou nervura, projetado para fornecer conexão mecânica entre componentes."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type defined by structural geometry. Under OWA, any artifact with projecting flat rim geometry would be forced into the flange category, which could incorrectly classify specialized equipment or complex assemblies that contain flange-like features but serve different primary functions."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flange is a material artifact that has a projecting flat rim geometry and has the function of mechanically connecting components."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000274
copi:COPI_0000274 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000275 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000275
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlareStack
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PilotSystem
                                  ] ;
                  rdfs:label "flare"@en ,
                             "flare"@pt-br ;
                  skos:definition "[CFIHOS] A system that burns waste in an elevated flame in the open air."@en ,
                                  "[DEXPI] An artefact and waste gas emitter that is intended to burn waste gas in secure distance from the plant or platform."@en ,
                                  "[ISO 15926-4] A <FLARE> is a <BURNER> that has a capability of <FLARING>"@en ,
                                  "[OnePetro] A burner on a remote line used for disposal of hydrocarbons during clean-up, emergency shut downs and for disposal of small volume waste streams of mixed gasses that cannot easily or safely be separated."@en ,
                                  "[SLB Glossary] The burning of unwanted gas through a pipe (also called a flare)."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Flare(x) ↔ (Burner(x) ∧ ∃f (WasteGasDisposalFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A flare is a burner that safely disposes of unwanted gases through controlled combustion at an elevated location."@en ,
                                                       "Um flare é um queimador que descarta com segurança gases indesejados através de combustão controlada em local elevado."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flare is a burner that bears a waste gas disposal function and has component parts flare tip, flare stack, and pilot system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000275
copi:COPI_0000275 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000220 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BurnerTip
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlameStabilizer
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:IgnitionSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:WasteGasDisposalFunction
                                  ] ;
                  rdfs:label "flare tip"@en ,
                             "queimador de flare"@pt-br ;
                  skos:definition "[CFIHOS] A burner that burns gas emitted from a process into the atmosphere."@en ,
                                  "[ISO 15926-4] A <FLARE TIP> is an <ARTEFACT> and a <BURNER> that burns gas emitted from a process into the atmosphere"@en ,
                                  "[POSC Caesar] A burner that burns gas emitted from a process into the atmosphere."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlareTip(x) ↔ Burner(x) ∧ ∃f(WasteGasDisposalFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A flare tip is a burner that specifically burns waste gas emitted from industrial processes and discharges the combustion products into the atmosphere."@en ,
                                                       "Um queimador de flare é um queimador que especificamente queima gás residual emitido de processos industriais e descarrega os produtos de combustão na atmosfera."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flare tip is a burner that has the function to dispose of waste gas from processes by burning it into the atmosphere"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000276
copi:COPI_0000276 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FeedInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:LiquidOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:VaporOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FlashVaporizationFunction
                                  ] ;
                  rdfs:label "flash drum"@en ,
                             "tambor de flash"@pt-br ;
                  skos:definition "[CFIHOS] A tank or vessel in which a process stream is charged or pumped and where lighter products flash off or vaporize and are drawn off at the top. The remainder heavier fractions are drawn off at the bottom of the vessel."@en ,
                                  "[ISO 15926-4] A <FLASH DRUM> is an <ARTEFACT> and a <VESSEL> in which a process stream is charged or pumped and where lighter products flash off or vaporize and are drawn off at the top. The remainer heavier fractions are drawn off at the bottom of the vessel"@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlashDrum(x) ↔ Separator(x) ∧ ∃f(FlashVaporizationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A flash drum is a separator that performs flash vaporization to separate lighter components (which vaporize and are drawn off at the top) from heavier components (which remain liquid and are drawn off at the bottom)."@en ,
                                                       "Um tambor de flash é um separador que realiza vaporização flash para separar componentes mais leves (que vaporizam e são retirados no topo) de componentes mais pesados (que permanecem líquidos e são retirados no fundo)."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flash drum is a separator that bears a flash vaporization function and has a vapor outlet, liquid outlet, and feed inlet."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000277
copi:COPI_0000277 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000339 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlexiblePipeBody
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FluidConductingBore
                                  ] ;
                  rdfs:label "flexible riser"@en ,
                             "riser flexível"@pt-br ;
                  skos:definition "[CFIHOS] A flexible vertical or near vertical pipe for the flow of liquid or gas between the seabed and the surface."@en ,
                                  "[ISO 15926-4] A <FLEXIBLE RISER> is an <ARTEFACT> and a <RISER> that is a flexible vertical or near vertical pipe for the flow of liquid or gas between the seabed and the surface"@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlexibleRiser(x) → Riser(x) ∧ ∃q(FlexibleProperty(q) ∧ hasQuality(x,q)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A flexible riser is a riser that has flexible material construction allowing vertical or near-vertical fluid conduction between seabed and surface while accommodating vessel movement."@en ,
                                                       "Um riser flexível é um riser que possui construção de material flexível permitindo condução de fluido vertical ou quase vertical entre o fundo do mar e a superfície, acomodando o movimento da embarcação."@pt-br ;
                  annotation:primitiveRationale "Constructive type where flexibility is a material/structural property. Under OWA, asserting equivalence would force any pipe with flexible qualities to be classified as a flexible riser, even if it serves different functions or has different deployment contexts. Starting with necessary conditions protects against false positives."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flexible riser is a riser that has a flexible property"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000278
copi:COPI_0000278 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlowSensingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalProcessingUnit
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000174
                                  ] ;
                  rdfs:label "flow meter"@en ,
                             "medidor de vazão"@pt-br ;
                  skos:definition "[CFIHOS] A detecting instrument intended to measure and indicate flow rate and/or produce a signal which represents the measured flow rate."@en ,
                                  "[POSC Caesar] A detecting instrument intended to measure and indicate flow rate and/or produce a signal which represents the measured flow rate."@en ,
                                  "[SLB Glossary] A device installed in a pump manifold or treating line to measure the fluid flow rate."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlowMeter(x) ↔ Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A flow meter is an instrument that bears a function to measure flow rate and produce corresponding signals or indications."@en ,
                                                       "Um medidor de vazão é um instrumento que possui uma função de medir taxa de fluxo e produzir sinais ou indicações correspondentes."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flow meter is an instrument that bears a flow measurement function and has component parts including a flow sensing element and signal processing unit"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000279
copi:COPI_0000279 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlowSensingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SetPointAdjustmentMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SwitchingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FlowSwitchingFunction
                                  ] ;
                  rdfs:label "flow switch"@en ,
                             "interruptor de fluxo"@pt-br ;
                  skos:definition "[CFIHOS] A functional switch that is intended to give a signal when the flow have reached a pre-set value."@en ,
                                  "[ISO 15926-4] A <FLOW SWITCH> is an <INSTRUMENTATION ITEM> and a <PROCESS SWITCH> and a <FLOW MEASURING INSTRUMENT>, that is specially and exclusively designed for <SWITCHING> at a given <FLOW RATE>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlowSwitch(x) ↔ Instrument(x) ∧ ∃f(FlowSwitchingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A flow switch is an instrument that bears a flow switching function to automatically open or close electrical circuits when fluid flow rate reaches predetermined threshold values."@en ,
                                                       "Um interruptor de fluxo é um instrumento que possui uma função de comutação de fluxo para automaticamente abrir ou fechar circuitos elétricos quando a taxa de fluxo de fluido atinge valores de limiar predeterminados."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flow switch is an instrument that has the function to switch electrical circuits based on flow rate detection at preset thresholds."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000280
copi:COPI_0000280 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000326 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FacilityConnection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlowlinePipe
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:WellheadConnection
                                  ] ;
                  rdfs:label "flowline"@en ,
                             "linha de fluxo"@pt-br ;
                  skos:definition "[ISO 15926-4] A <FLOWLINE> is an <ARTEFACT> and  a <PIPELINE> carrying oil, gas or water that connects the wellhead to a manifold or to production facilities, such as heater-treaters and separators"@en ,
                                  "[OnePetro] The pipe connection between the well and the separators or tank battery."@en ,
                                  "[SLB Glossary] The large-diameter metal pipe that connects the bell nipple under the rotary table to the possum belly at the mud tanks."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Flowline(x) ↔ Pipeline(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellhead(w) ∧ connectsDirectly(x,w)) ∧ ∃m((Manifold(m) ∨ ProductionFacility(m)) ∧ connectsDirectly(x,m)) ∧ ∃h(HydrocarbonFluid(h) ∧ hasInput(x,h)))"@en ;
                  annotation:naturalLanguageDefinition "A flowline is a pipeline that transports oil, gas, or water directly from a wellhead to a manifold or production facility."@en ,
                                                       "Uma linha de fluxo é um duto que transporta óleo, gás ou água diretamente de uma cabeça de poço para um manifold ou instalação de produção."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flowline is a pipeline that bears a fluid transport function, has a wellhead connection, has a manifold or production facility connection, and transports hydrocarbon fluids."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000281
copi:COPI_0000281 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000124 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CombustionChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ProcessFluidPathway
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ReactiveHeatingFunction
                                  ] ;
                  rdfs:label "forno"@pt-br ,
                             "furnace"@en ;
                  skos:definition "[CFIHOS] A physical object that is intended to induce a reaction in a process fluid by heating it."@en ,
                                  "[ISO 15926-4] A <FURNACE> is a <HEATER> that is intended to induce a reaction in a process fluid by heating it"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Furnace(x) ↔ Heater(x) ∧ ∃f(ReactiveHeatingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A furnace is a heater that bears the function to induce chemical reactions in process fluids through heating."@en ,
                                                       "Um forno é um aquecedor que possui a função de induzir reações químicas em fluidos de processo através do aquecimento."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every furnace is a heater that has the function to induce reactions in process fluids by heating them."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000282
copi:COPI_0000282 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FuseBase
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FuseElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:CircuitProtectionFunction
                                  ] ;
                  rdfs:label "fuse"@en ,
                             "fusível"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that by the fusing of one or more of its specially designed and proportioned components, opens the circuit in which it is inserted by breaking the current when this exceeds a given value for a sufficient time."@en ,
                                  "[ISO 15926-4] A <FUSE> is an <ARTEFACT> and a <PROTECTOR> and an <ELECTRICAL ELEMENT> that opens the circuit in which it is inserted by breaking the current when this exceeds a given value for a sufficient time"@en ,
                                  "[POSC Caesar] A physical object that by the fusing of one or more of its specially designed and proportioned components, opens the circuit in which it is inserted by breaking the current when this exceeds a given value for a sufficient time."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Fuse(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FuseElement(e) ∧ hasComponentPartAtAllTimes(x,e)))"@en ;
                  annotation:naturalLanguageDefinition "A fuse is an electrical equipment that protects circuits by interrupting current flow through the intentional melting of a fusible element when current exceeds specified values for a sufficient duration."@en ,
                                                       "Um fusível é um equipamento elétrico que protege circuitos interrompendo o fluxo de corrente através do derretimento intencional de um elemento fusível quando a corrente excede valores especificados por uma duração suficiente."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every fuse is an electrical equipment that bears a circuit protection function and has a fuse element that melts under overcurrent conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000283
copi:COPI_0000283 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BottomOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CyclonicFlowChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TangentialInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TopOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000195
                                  ] ;
                  rdfs:label "gas cyclone separator"@en ,
                             "separador ciclônico de gás"@pt-br ;
                  skos:definition "[CFIHOS] A static device generating centrifugal force from an incoming flow which separates solid or liquids from a gas of a different density."@en ;
                  annotation:firstOrderLogicAxiom "∀x (GasCycloneSeparator(x) → Separator(x) ∧ ∃y(CyclonicFlowChamber(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(CentrifugalSeparationProcess(z) ∧ participatesIn(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A gas cyclone separator is a separator that separates solid particles or liquid droplets from gas using centrifugal force generated by cyclonic flow geometry."@en ,
                                                       "Um separador ciclônico de gás é um separador que separa partículas sólidas ou gotículas líquidas do gás usando força centrífuga gerada pela geometria de fluxo ciclônico."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by cyclonic mechanism. Under Open World Assumption, any device with cyclonic flow chamber could be falsely classified as gas cyclone separator, including specialized multi-stage cyclones or hybrid separator designs that should not be forced into this standard maintenance category."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gas cyclone separator is a separator that has a cyclonic flow chamber as component part and participates in centrifugal separation processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000284
copi:COPI_0000284 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000246 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasDetectingMeasuringElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:GasDetectionFunction
                                  ] ;
                  rdfs:label "detector de gás"@pt-br ,
                             "gas detector"@en ;
                  skos:definition "[CFIHOS] A detector that is intended to sense the presence of a specified concentration of a gas."@en ,
                                  "[ISO 15926-4] A <GAS DETECTOR> is a <DETECTOR> and a <GAS DETECTING INSTRUMENT> using a <GAS DETECTING MEASURING ELEMENT> that is intended to sense the presence of a specified concentration of a gas"@en ,
                                  "[POSC Caesar] A detector that is intended to sense the presence of a specified concentration of a gas."@en ;
                  annotation:firstOrderLogicAxiom "∀x(GasDetector(x) ↔ (Detector(x) ∧ ∃f(GasDetectionFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A gas detector is a detector that has the designed function to sense the presence of a specified concentration of a gas."@en ,
                                                       "Um detector de gás é um detector que tem a função projetada de detectar a presença de uma concentração especificada de um gás."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gas detector is a detector that bears a GasDetectionFunction and has a GasDetectingMeasuringElement as component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000285
copi:COPI_0000285 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000264 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CylinderBlock
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasFuelAdmissionSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ReciprocatingPistonMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SparkIgnitionSystem
                                  ] ;
                  rdfs:label "gas engine"@en ,
                             "motor a gás"@pt-br ;
                  skos:definition "[CFIHOS] An internal combustion engine that is a reciprocating engine in which gaseous fuel is mixed with air to form a combustible mixture in a cylinder which is fired by spark ignition."@en ,
                                  "[ISO 15926-4] A <GAS ENGINE> is an <INTERNAL COMBUSTION ENGINE> and a <RECIPROCATING PISTON ENGINE> in which gaseous fuel is mixed with air to form a combustible mixture in a cylinder which is fired by spark ignition"@en ,
                                  "[POSC Caesar] An internal combustion engine that is a reciprocating engine in which gaseous fuel is mixed with air to form a combustible mixture in a cylinder which is fired by spark ignition."@en ;
                  annotation:firstOrderLogicAxiom "∀x(GasEngine(x) → Engine(x) ∧ ∃f,s,r(GaseousFuelPortion(f) ∧ SparkIgnitionSystem(s) ∧ ReciprocatingPistonMechanism(r) ∧ hasInput(x,f) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,r)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A gas engine is an engine that uses gaseous fuel as input, employs a spark ignition system, and operates with a reciprocating piston mechanism to generate mechanical energy."@en ,
                                                       "Um motor a gás é um motor que usa combustível gasoso como entrada, emprega um sistema de ignição por centelha e opera com um mecanismo de pistão alternativo para gerar energia mecânica."@pt-br ;
                  annotation:primitiveRationale "Gas engine is defined by constructive characteristics (gaseous fuel, spark ignition, reciprocating mechanism) rather than a unique function. Under Open World Assumption, making these conditions sufficient could lead to false positives where complex hybrid engines or experimental designs with these features are automatically classified as standard gas engines when they might require different maintenance/operational categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gas engine is an engine that has gaseous fuel portion as input and has spark ignition system as component part at all times and has reciprocating piston mechanism as component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000286
copi:COPI_0000286 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000366 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000073
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CombustionChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TurbineSection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:TurbomachineryPowerGenerationFunction
                                  ] ;
                  rdfs:label "gas turbine"@en ,
                             "turbina a gás"@pt-br ;
                  skos:definition "[CFIHOS] A turbine that compresses air which is then mixed with fuel for combustion and expansion through a turbine section to generate relatively high power output for either mechanical drive or power generation."@en ,
                                  "[ISO 15926-4] A <GAS TURBINE> is a <TURBINE> that compresses air which is then mixed with fuel for combustion and expansion through a turbine section to generate relatively high power output for either mechanical drive or power generation"@en ,
                                  "[POSC Caesar] A turbine that compresses air which is then mixed with fuel for combustion and expansion through a turbine section to generate relatively high power output for either mechanical drive or power generation."@en ;
                  annotation:firstOrderLogicAxiom "∀x(GasTurbine(x) ↔ Turbine(x) ∧ ∃c,h(Compressor(c) ∧ CombustionChamber(h) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃p1,p2(AirCompressionProcess(p1) ∧ FuelCombustionProcess(p2) ∧ participatesIn(x,p1) ∧ participatesIn(x,p2)))"@en ;
                  annotation:naturalLanguageDefinition "A gas turbine is a turbine that has an integrated compressor and combustion chamber, designed to compress ambient air, mix it with fuel for combustion, and expand the resulting hot gases through a turbine section to generate mechanical power."@en ,
                                                       "Uma turbina a gás é uma turbina que possui um compressor e câmara de combustão integrados, projetada para comprimir ar ambiente, misturá-lo com combustível para combustão, e expandir os gases quentes resultantes através de uma seção de turbina para gerar energia mecânica."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gas turbine is a turbine that has component parts compressor and combustion chamber at all times, and participates in air compression process and fuel combustion process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000287
copi:COPI_0000287 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DeformableMaterial
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:SealingFunction
                                  ] ;
                  rdfs:label "gasket"@en ,
                             "junta"@pt-br ;
                  skos:definition "[CFIHOS] A seal that is one or more closed loops of deformable material used between mating surfaces which have only very limited movement relative to each other."@en ,
                                  "[ISO 15926-4] A <GASKET> is an <ARTEFACT> and a <SEAL> that is one or more closed loops of deformable material used between mating surfaces which have only very limited movement relative to each other"@en ,
                                  "[OnePetro] Any of several replaceable seals in equipment or tools."@en ,
                                  "[POSC Caesar] A seal that is one or more closed loops of deformable material used between mating surfaces which have only very limited movement relative to each other."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Gasket(x) ↔ MaterialArtifact(x) ∧ ∃f(SealingFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(DeformableMaterial(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃g(ClosedLoopGeometry(g) ∧ hasProperty(x,g)))"@en ;
                  annotation:naturalLanguageDefinition "A gasket is a material artifact made of deformable material arranged in closed loops that bears a sealing function to prevent leakage between mating surfaces with limited relative movement."@en ,
                                                       "Uma junta é um artefato material feito de material deformável arranjado em loops fechados que possui uma função de vedação para prevenir vazamentos entre superfícies de acoplamento com movimento relativo limitado."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gasket is a material artifact that has component part some deformable material and bears some sealing function and has property some closed loop geometry."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000288
copi:COPI_0000288 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000222 ;
                  rdfs:label "carcaça de caixa de engrenagens"@pt-br ,
                             "gear casing"@en ;
                  skos:definition "[ISO 15926-4] A <GEAR CASING> is a <HOUSING> that contains the internal components of a gear."@en ;
                  annotation:firstOrderLogicAxiom "∀x(GearCasing(x) → casing(x) ∧ ∃y(GearMechanism(y) ∧ hasContent(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A casing that contains and houses the internal components of a gear mechanism, providing protective enclosure and structural support."@en ,
                                                       "Um invólucro que contém e abriga os componentes internos de um mecanismo de engrenagem, fornecendo invólucro protetor e suporte estrutural."@pt-br ;
                  annotation:primitiveRationale "This is a constructive type defined by its physical configuration as a specific type of casing. Under OWA, declaring equivalence could lead to over-classification where any casing containing gear-like components might be inappropriately classified as a standard gear casing, including custom enclosures or hybrid systems that should not fall into this maintenance category."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "GearCasing ⊑ casing ⊓ ∃hasContent.GearMechanism"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000289
copi:COPI_0000289 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000072 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000335
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DischargePort
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GearMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SuctionPort
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000066
                                  ] ;
                  rdfs:label "bomba de engrenagem"@pt-br ,
                             "gear pump"@en ;
                  skos:definition "[ISO 15926-4] A <GEAR PUMP> is a <ROTARY PUMP> that contains gear teeth within an casing or enclosure to transport liquid at relatively high back pressures"@en ,
                                  "[POSC Caesar] A rotary pump that contains gear teeth within an casing or enclosure to transport liquid at relatively high back pressures and by which gear meshing serves as reverse flow seal."@en ;
                  annotation:firstOrderLogicAxiom "∀x (GearPump(x) → Pump(x) ∧ ∃g,c (GearMechanism(g) ∧ PumpCasing(c) ∧ hasComponentPartAtAllTimes(x,g) ∧ hasComponentPartAtAllTimes(x,c)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A gear pump is a pump that contains gear teeth within a casing or enclosure to transport liquid at relatively high back pressures through meshing action."@en ,
                                                       "Uma bomba de engrenagem é uma bomba que contém dentes de engrenagem dentro de um invólucro ou carcaça para transportar líquido em pressões de retorno relativamente altas através de ação de engrenamento."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. While the gear mechanism is definitionally necessary for gear pumps, making it sufficient under OWA could lead to false positives - any complex equipment containing gears (like gearboxes with integrated pumps or multi-function units) might be incorrectly classified as standard gear pumps for maintenance purposes."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gear pump is a pump that has as component part at all times a gear mechanism and a pump casing, and bears a pumping function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000290
copi:COPI_0000290 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000121 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000192
                                  ] ;
                  rdfs:label "gear wheel"@en ,
                             "roda dentada"@pt-br ;
                  skos:definition "[ISO 15926-4] A <GEAR WHEEL> is an <ARTEFACT> and a <TRANSMITTER(force)> and that is a toothed wheel usend in conjunction with another, or with a rack, to transmit motion"@en ;
                  annotation:firstOrderLogicAxiom "∀x(GearWheel(x) → Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃t(Tooth(t) ∧ hasComponentPartAtAllTimes(x,t)) ∧ ∃w(WheelBody(w) ∧ hasComponentPartAtAllTimes(x,w)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An Assembly that bears a PowerTransmissionFunction and that has circumferential teeth for positive mechanical engagement with mating gears or racks to transmit rotational motion and power."@en ,
                                                       "Um Assembly que porta uma PowerTransmissionFunction e que possui dentes circunferenciais para engajamento mecânico positivo com engrenagens ou cremalheiras correspondentes para transmitir movimento rotacional e potência."@pt-br ;
                  annotation:primitiveRationale "Constructive differentia based on physical structure (toothed geometry). Under OWA, asserting equivalence could force classification of complex hybrid mechanisms or specialized toothed components that should not be categorized as standard gear wheels for maintenance purposes."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "GearWheel SubClassOf Assembly and (bearerOf some PowerTransmissionFunction) and (hasComponentPartAtAllTimes some Tooth) and (hasComponentPartAtAllTimes some WheelBody)"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000291
copi:COPI_0000291 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000078 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnclosureFunction
                                  ] ;
                  rdfs:label "corpo de válvula globo"@pt-br ,
                             "globe valve body"@en ;
                  skos:definition "[ISO 15926-4] A <GLOBE VALVE BODY> is a <VALVE BODY> of a globe valve"@en ;
                  annotation:firstOrderLogicAxiom "∀x (GlobeValveBody(x) → ValveBody(x) ∧ ∃g (GlobularGeometry(g) ∧ hasDesignCharacteristic(x,g)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A valve body that has a globular geometry designed to accommodate the perpendicular flow path and disc closure mechanism characteristic of globe valve operation."@en ,
                                                       "Um corpo de válvula que possui geometria globular projetada para acomodar o caminho de fluxo perpendicular e o mecanismo de fechamento por disco característico da operação de válvula globo."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by structural geometry. Under OWA, asserting equivalence based on globular geometry alone could lead to false classifications of complex assemblies or hybrid components that contain globular elements but should not be classified as standard globe valve bodies."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every globe valve body is a valve body that has globular geometry for perpendicular flow path accommodation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000292
copi:COPI_0000292 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Inlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Outlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SeparationChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:GravitySeparationFunction
                                  ] ;
                  rdfs:label "gravity separator"@en ,
                             "separador gravitacional"@pt-br ;
                  skos:definition "[CFIHOS] A separator that is based on the difference in specific gravity for the substances to be separated."@en ,
                                  "[ISO 15926-4] A <GRAVITY SEPARATOR> is an <ARTEFACT> and a <FLUID SEPARATOR> that is based on the difference in specific gravity for the substances to be separated"@en ,
                                  "[POSC Caesar] A separator that is based on the difference in specific gravity for the substances to be separated."@en ;
                  annotation:firstOrderLogicAxiom "∀x(GravitySeparator(x) ↔ Separator(x) ∧ ∃f(GravitySeparationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A gravity separator is a separator that performs separation based on differences in specific gravity of the substances being separated."@en ,
                                                       "Um separador gravitacional é um separador que realiza separação baseada nas diferenças de gravidade específica das substâncias sendo separadas."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gravity separator is a separator that bears a GravitySeparationFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000293
copi:COPI_0000293 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000311 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FluidPathway
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MultipleConnections
                                  ] ;
                  rdfs:label "header"@en ,
                             "header"@pt-br ;
                  skos:definition "[ISO 15926-4] A <HEADER> is an <ARTEFACT> and a <PIPING NETWORK SEGMENT> that is pipe or manifold that is used to collect the discharge from many smaller pipes (a collecting header) , or can be used to distribute fluid to many smaller pipes (distributing header)"@en ,
                                  "[SLB Glossary] The location, acquisition and processing parameters, and other pertinent information attached to a well log, seismic record and traces."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Header(x) ↔ (manifold(x) ∧ ∃y(SmallPipe(y) ∧ connects_to(x,y)) ∧ ∃z(MultiStreamDistributionProcess(z) ∧ participatesIn(x,z))))"@en ;
                  annotation:naturalLanguageDefinition "A header is a manifold that connects to many smaller pipes for collecting discharge from multiple sources or distributing fluid to multiple destinations."@en ,
                                                       "Um header é um manifold que se conecta a muitos tubos menores para coletar descarga de múltiplas fontes ou distribuir fluido para múltiplos destinos."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Header ≡ manifold ⊓ ∃connects_to.SmallPipe ⊓ ∃participatesIn.MultiStreamDistributionProcess"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000294
copi:COPI_0000294 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000068
                                  ] ;
                  rdfs:label "MaterialArtifact que possui uma HeatTransferFunction e"@pt-br ,
                             "heat transfer plate"@en ;
                  skos:definition "[ISO 15926-4] A <HEAT TRANSFER PLATE> is a <PLATE> that is intended to be used in a non tubular heat exchanger to segregate the two media"@en ;
                  annotation:firstOrderLogicAxiom "∀x(HeatTransferPlate(x) → MaterialArtifact(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MediaSeparationProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that bears a HeatTransferFunction and that is intended to be used in a non-tubular heat exchanger to segregate two fluid media while facilitating thermal energy transfer between them."@en ,
                                                       "Um MaterialArtifact que possui uma HeatTransferFunction e que é destinado a ser usado em um trocador de calor não tubular para segregar dois meios fluidos enquanto facilita a transferência de energia térmica entre eles."@pt-br ;
                  annotation:primitiveRationale "Constructive classification basis requires necessary conditions only. Under OWA, sufficient conditions for 'plate geometry used in non-tubular heat exchangers' could lead to false positives - other components with plate-like surfaces might be incorrectly classified as heat transfer plates without domain expert validation of the structural and application-specific criteria."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every heat transfer plate is a MaterialArtifact that bears a HeatTransferFunction and participates in segregating two fluid media in a non-tubular heat exchanger."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000295
copi:COPI_0000295 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SolidDischargeOpening
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:StorageCompartment
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:SolidStorageAndDispensingFunction
                                  ] ;
                  rdfs:label "hopper"@en ,
                             "hopper"@pt-br ;
                  skos:definition "[CFIHOS] A vessel with a conical shape for filling or dosing purposes."@en ,
                                  "[ISO 15926-4] A <HOPPER> is a <CONTAINER> with a conical shape that is intended to store solids for filling or dosing purposes"@en ,
                                  "[OnePetro] Mixing chamber where dry components can be evenly mixed with liquids. The dry materials are introduced at the bottom of the hopper through a nozzle."@en ,
                                  "[POSC Caesar] A vessel with a conical shape for filling or dosing purposes"@en ,
                                  "[SLB Glossary] The device used to facilitate the addition of drilling fluid additives to the whole mud system."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Hopper(x) ↔ (Vessel(x) ∧ ∃f(SolidStorageAndDispensingFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SolidDischargeOpening(p) ∧ hasComponentPartAtAllTimes(x,p))))"@en ;
                  annotation:naturalLanguageDefinition "A hopper is a vessel that is designed to store solid materials and dispense them through a controlled discharge opening."@en ,
                                                       "Um hopper é um vaso projetado para armazenar materiais sólidos e dispensá-los através de uma abertura de descarga controlada."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every hopper is a vessel that bears a SolidStorageAndDispensingFunction and has a SolidDischargeOpening as component part."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000296
copi:COPI_0000296 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000321 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FlexibleTubularBody
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:InnerLining
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ReinforcementLayer
                                  ] ;
                  rdfs:label "hose"@en ,
                             "mangueira"@pt-br ;
                  skos:definition "[CFIHOS] A tubular which is flexible and capable of conveying liquids under pressure."@en ,
                                  "[ISO 15926-4] A <HOSE> is a <TUBULAR> that is flexible and capable of conducting liquids under pressure"@en ,
                                  "[POSC Caesar] A tubular which is flexible and capable of conveying liquids under pressure."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Hose(x) → Pipe(x) ∧ ∃q(Flexibility(q) ∧ hasQuality(x,q)) ∧ ∃c(PressurizedFluidConduction(c) ∧ capableOf(x,c)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A hose is a flexible pipe designed to conduct liquids under pressure while accommodating positional movement and bending."@en ,
                                                       "Uma mangueira é um tubo flexível projetado para conduzir líquidos sob pressão enquanto acomoda movimento posicional e flexão."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type defined by physical properties (flexibility). Under OWA, asserting equivalence would force any artifact with flexibility and pressure capability to be classified as a hose, potentially including complex equipment with flexible components that should not be categorized as standard hoses."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every hose is a pipe that has flexibility and is capable of conducting liquids under pressure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000297
copi:COPI_0000297 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnclosureFunction
                                  ] ;
                  rdfs:label "carcaça"@pt-br ,
                             "housing"@en ;
                  skos:definition "[CFIHOS] An enclosure that also provides support."@en ,
                                  "[ISO 15926-4] A <HOUSING> is an <ARTEFACT> and an <ENCLOSURE> and a <SUPPORT> that, next to separation, also provides support"@en ,
                                  "[SLB Glossary] The outside steel case of a cartridge or a sonde in a wireline logging tool."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Housing(x) → Assembly(x) ∧ ∃f₁(EnclosureFunction(f₁) ∧ bearerOf(x,f₁)) ∧ ∃f₂(SupportFunction(f₂) ∧ bearerOf(x,f₂)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An Assembly that bears both an EnclosureFunction and a SupportFunction, providing protective boundaries around internal components while structurally supporting them."@en ,
                                                       "Um Assembly que possui tanto uma EnclosureFunction quanto uma SupportFunction, fornecendo limites protetivos ao redor de componentes internos enquanto os suporta estruturalmente."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on physical configuration. Under OWA, sufficient conditions would force any assembly with enclosure and support functions to be classified as a standard housing, potentially misclassifying specialized equipment with housing-like properties but different maintenance categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Housing SubClassOf Assembly and (bearerOf some EnclosureFunction) and (bearerOf some SupportFunction)"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000298
copi:COPI_0000298 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000207 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HydraulicCylinder
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HydraulicFluidPort
                                  ] ;
                  rdfs:label "atuador hidráulico"@pt-br ,
                             "hydraulic actuator"@en ;
                  skos:definition "[CFIHOS] An actuator intended to be operated by hydraulic power."@en ,
                                  "[ISO 15926-4] A <HYDRAULIC ACTUATOR> is an <INSTRUMENTATION ITEM> and a <CONTROLLED ACTUATOR> and a <HYDRAULICALLY ACTUATED ARTEFACT>"@en ,
                                  "[POSC Caesar] An actuator intended to be operated by hydraulic power."@en ;
                  annotation:firstOrderLogicAxiom "∀x(HydraulicActuator(x) → Actuator(x) ∧ ∃y(HydraulicFluidPortion(y) ∧ hasInput(x,y)) ∧ ∃z(HydraulicToMechanicalEnergyConversionProcess(z) ∧ participatesIn(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A hydraulic actuator is an actuator that converts hydraulic fluid pressure into mechanical motion through hydraulic power transmission."@en ,
                                                       "Um atuador hidráulico é um atuador que converte pressão de fluido hidráulico em movimento mecânico através de transmissão de potência hidráulica."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on hydraulic power source. Under Open World Assumption, asserting equivalence could incorrectly classify complex hydraulic-mechanical hybrid systems or specialized equipment containing hydraulic actuator components as standard hydraulic actuators."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every hydraulic actuator is an actuator that has hydraulic fluid portion as input and participates in hydraulic to mechanical energy conversion process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000299
copi:COPI_0000299 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000315 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HydraulicFluidInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HydraulicFluidOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HydraulicMechanicalConverter
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotationalOutput
                                  ] ;
                  rdfs:label "hydraulic motor"@en ,
                             "motor hidráulico"@pt-br ;
                  skos:definition "[CFIHOS] A motor that is intended to generate power by means of high pressure oil."@en ,
                                  "[ISO 15926-4] A <HYDRAULIC MOTOR> is an <ARTEFACT> and a <MOTOR> and a <HYDRAULIC TO ROTATION ENERGY CONVERTER> that is intended to generate power by means of high pressure oil"@en ,
                                  "[POSC Caesar] A motor that is intended to generate power by means of high pressure oil."@en ;
                  annotation:firstOrderLogicAxiom "∀x(HydraulicMotor(x) → Motor(x) ∧ ∃f,p(HydraulicFluidPortion(f) ∧ hasInput(x,f) ∧ HydraulicToMechanicalEnergyConversionProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A hydraulic motor is a motor that generates mechanical energy by converting high pressure hydraulic oil to rotational motion."@en ,
                                                       "Um motor hidráulico é um motor que gera energia mecânica convertendo óleo hidráulico de alta pressão em movimento rotacional."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on hydraulic mechanism. Under Open World Assumption, any device with hydraulic input might be misclassified as a hydraulic motor without domain expert validation of the complete structural requirements."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every hydraulic motor is a motor that has hydraulic fluid input and participates in hydraulic-to-mechanical energy conversion process"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000300
copi:COPI_0000300 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000331 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HydraulicPumpInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HydraulicPumpOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:HydraulicPumpingFunction
                                  ] ;
                  rdfs:label "bomba hidráulica"@pt-br ,
                             "hydraulic pump"@en ;
                  skos:definition "[ISO 15926-4] A <HYDRAULIC PUMP> is a <POSITIVE DISPLACEMENT PUMP> used in hydraulic drive systems and can be hydrostatic or hydrodynamic. It is a mechanical source of power that converts mechanical power into hydraulic energy (hydrostatic energy i.e. flow, pressure). It generates flow with enough power to overcome pressure induced by the load at the pump outlet. When a hydraulic pump operates, creates a vacuum at the pump inlet, which forces liquid from the reservoir into the inlet line to the pump and by mechanical action delivers this liquid to the pump outlet and forces it into the hydraulic system."@en ,
                                  "[OnePetro] An artificial lift system that is powered by injected fluid (usually water), that powers a pump similar to the rotating pump used in electrical submersible pumps."@en ;
                  annotation:firstOrderLogicAxiom "∀x (HydraulicPump(x) ↔ PositiveDisplacementPump(x) ∧ ∃f(HydraulicPumpingFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(HydraulicPowerTransmissionProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A hydraulic pump is a positive displacement pump that converts mechanical power into hydraulic energy for hydraulic drive systems."@en ,
                                                       "Uma bomba hidráulica é uma bomba de deslocamento positivo que converte energia mecânica em energia hidráulica para sistemas de acionamento hidráulico."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every hydraulic pump is a positive displacement pump that bears a hydraulic pumping function and participates in hydraulic power transmission processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000301
copi:COPI_0000301 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ConicalSection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OverflowOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TangentialInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:UnderflowOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000195
                                  ] ;
                  rdfs:label "hidrociclone"@pt-br ,
                             "hydrocyclone"@en ;
                  skos:definition "[ISO 15926-4] A <HYDROCYCLONE> is a <CYCLONE> and a <CYLINDRICAL VESSEL>, intended to separate a fluid by hydraulic forces"@en ,
                                  "[OnePetro] A cone shaped device for separating fluids and the solids dispersed in fluids."@en ,
                                  "[SLB Glossary] An item of solids-control equipment consisting of an inverted cone, the mud being fed tangentially into the upper (larger diameter) part."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Hydrocyclone(x) ↔ Separator(x) ∧ ∃c(ConicalSection(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃p(CentrifugalSeparationProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A hydrocyclone is a separator that separates fluid mixtures using centrifugal forces generated by tangential flow through a conical chamber."@en ,
                                                       "Um hidrociclone é um separador que separa misturas de fluidos usando forças centrífugas geradas por fluxo tangencial através de uma câmara cônica."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every hydrocyclone is a separator that has a conical section as component part at all times and participates in centrifugal separation processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000302
copi:COPI_0000302 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Hub
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotatingVanes
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnergyTransferFunction
                                  ] ;
                  rdfs:label "impeller"@en ,
                             "impulsor"@pt-br ;
                  skos:definition "[DEXPI] An energy converter component that is an assembly of rotating vanes within an enclosure which is used to impart energy to or derive energy from a fluid through dynamic force (from ``_)."@en ,
                                  "[ISO 15926-4] An <IMPELLER> is a <MECHANICAL TO MECHANICAL ENERGY CONVERTER> that is an assembly of rotating vanes within an enclosure which is used to impart energy to or derive energy from a fluid through dynamic force"@en ,
                                  "[OnePetro] The rotating pump component that drives the fluid in a centrifugal pump."@en ,
                                  "[SLB Glossary] In electromagnetics or electrical circuit theory, the ratio of voltage to current when these are represented by phasor quantities in alternating current circuits. (A phasor is a complex number that represents the amplitude and phase of a quantity that varies sinusoidally in time.) Electrical impedance, also symbolized by Z, is a complex number that has the same units (ohms) as resistivity."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Impeller(x) → Assembly(x) ∧ ∃v,h(RotatingVanes(v) ∧ Hub(h) ∧ hasComponentPartAtAllTimes(x,v) ∧ hasComponentPartAtAllTimes(x,h) ∧ ∃m(RotationalMotion(m) ∧ participatesIn(x,m)) ∧ ∃f(EnergyTransferFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An impeller is an assembly consisting of rotating vanes mounted on a hub that transfers energy to or from fluids through dynamic rotational force within an enclosure."@en ,
                                                       "Um impulsor é um conjunto que consiste em pás rotativas montadas em um cubo que transfere energia para ou de fluidos através de força rotacional dinâmica dentro de um invólucro."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for the rotating vane assembly could lead to false positives where other rotating equipment with vanes (like turbine rotors or fan assemblies) might be incorrectly classified as impellers when they should remain in their specific equipment categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every impeller is an assembly that has rotating vanes and a hub as component parts at all times, participates in rotational motion, and bears an energy transfer function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000303
copi:COPI_0000303 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000281 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirIntakeSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ExhaustStack
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:WasteFeedSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:WasteCombustionFunction
                                  ] ;
                  rdfs:label "incinerador"@pt-br ,
                             "incinerator"@en ;
                  skos:definition "[CFIHOS] A furnace that is intended for the combustion of waste material."@en ,
                                  "[ISO 15926-4] An <INCINERATOR> is an <ARTEFACT> and a <FURNACE> that is intended for the combustion of waste material"@en ,
                                  "[OnePetro] Also known as an enclosed combustor                  Flares are not 100% efficient, and some methane (un-combusted) is emitted during flaring as a result of un-combusted gas being released via the equipment exhaust stream. Flares cannot be performance tested to guarantee that they achieve the same efficiency as an incinerator or enclosed combustor. Studies suggest that the efficiency of a flare during windy conditions can be as low as 50%. The many components and complex network of small gathering lines in flare are a source of fugitive emissions.                  Incinerators are used when flaring is not a viable option. The combustion efficiency of an incinerator is known to be over 99% which is higher than a flare. Plus, they are more suitable for applications involving carcinogenic gases like BTEX and H2S applications. Incineration of waste gas products may not be a new concept for the                  oil and gas industry however, in recent years the design and technology have resulted in optimal performance, increased reliability and reduce capital and operating costs for operators.                  An enclosed combustor is a newer iteration of the incinerator. The combustion device is completely enclosed except for the combustion air intake and the exhaust discharge. It operates like an incinerator with more restriction to allow it to be able to operate in a reduced spacing capacity. The surfaces exposed to the atmosphere operate below the temperature that would ignite a flammable substance present in the surrounding area. Because of the reduced space capacity all air intakes must be equipped with a flame arresting device as a safety feature to allow the unit to be 10 meters away from wells or operating equipment. https://energynow.com/2021/07/the-differences-between-flares-incinerators-and-enclosed-combustors/"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Incinerator(x) ↔ Furnace(x) ∧ ∃f(WasteCombustionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "An incinerator is a furnace that is designed to combust waste material for disposal purposes."@en ,
                                                       "Um incinerador é um forno que é projetado para combustir material de resíduo para fins de descarte."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every incinerator is a furnace that bears a waste combustion function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000304
copi:COPI_0000304 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000072 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:InjectionPort
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:InjectionFunction
                                  ] ;
                  rdfs:label "bomba de injeção"@pt-br ,
                             "injection pump"@en ;
                  skos:definition "[ISO 15926-4] An <INJECTION PUMP> is a < POSITIVE DISPLACEMENT PUMP> that is typically applied for relatively high pressures in case of injection systems"@en ,
                                  "[SLB Glossary] Any pump used to inject fluid into the reservoir or production system."@en ;
                  annotation:firstOrderLogicAxiom "∀x(InjectionPump(x) ↔ Pump(x) ∧ ∃f(InjectionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "An injection pump is a pump that is specifically designed to inject fluid into reservoirs or production systems, typically at relatively high pressures."@en ,
                                                       "Uma bomba de injeção é uma bomba especificamente projetada para injetar fluido em reservatórios ou sistemas de produção, tipicamente em pressões relativamente altas."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every injection pump is a pump that bears an injection function for delivering fluids to reservoirs or production systems."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000305
copi:COPI_0000305 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000375 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                    owl:someValuesFrom copi:InjectionFunction
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000304
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:InjectionTubing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureControlSystem
                                  ] ;
                  rdfs:label "injection well"@en ,
                             "poço de injeção"@pt-br ;
                  skos:definition "[ISO 15926-4] An <INJECTION WELL> is  a <WELL> with the purpose of injecting a material into a reservoir, normally with a pressure higher than the formation pressure"@en ,
                                  "[OnePetro] A well either specifically drilled, or, more likely, a poor producer that is converted to inject fluids to stabilize the decline of pressure in a productive zone. An injector is required to have a pressure connection to the pay and to a producing well. Water is typically injected at the base of the pay or, in a gas well, or gas is injected into the gas cap."@en ,
                                  "[SLB Glossary] A well in which fluids are injected rather than produced, the primary objective typically being to maintain reservoir pressure."@en ;
                  annotation:firstOrderLogicAxiom "∀x (InjectionWell(x) ↔ (Well(x) ∧ ∃f (InjectionFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "An injection well is a well that bears the designed function of injecting materials into a reservoir at pressure higher than formation pressure."@en ,
                                                       "Um poço de injeção é um poço que possui a função projetada de injetar materiais em um reservatório a uma pressão superior à pressão da formação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every injection well is a well that has the function to inject materials into a reservoir under pressure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000306
copi:COPI_0000306 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000346 ;
                  rdfs:label "eixo de entrada"@pt-br ,
                             "input shaft"@en ;
                  skos:definition "[ISO 15926-4] An <INPUT SHAFT> is a <SHAFT> that is the entrance of mechanical energy and driven by an external energy source."@en ;
                  annotation:firstOrderLogicAxiom "∀x(InputShaft(x) → Shaft(x) ∧ ∃p(MechanicalEnergyReceptionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(ExternalEnergySource(s) ∧ connectedTo(x,s)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An input shaft is a shaft that serves as the entrance point for mechanical energy from an external energy source in a power transmission system."@en ,
                                                       "Um eixo de entrada é um eixo que serve como ponto de entrada para energia mecânica de uma fonte de energia externa em um sistema de transmissão de potência."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on physical configuration as energy entrance point. Under OWA, defining sufficient conditions could lead to false positives where any shaft receiving external energy input would be classified as a standard input shaft, even specialized or hybrid configurations that should remain in different maintenance categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "An InputShaft is a Shaft that participates in mechanical energy reception and is connected to an external energy source."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000307
copi:COPI_0000307 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:HeatTransferBundle
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SeparateVapourSpace
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Shell
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ReboilingFunction
                                  ] ;
                  rdfs:label "kettle reboiler"@en ,
                             "refervedor tipo kettle"@pt-br ;
                  skos:definition "[CFIHOS] A reboiler often boils liquid coming from the bottom of a distillation column, after which the resulting vapour is returned to the distillation column."@en ,
                                  "[ISO 15926-4] A <KETTLE REBOILER> is a <REBOILER> that is horizontal and has a separate vapour space."@en ;
                  annotation:firstOrderLogicAxiom "∀x(KettleReboiler(x) → Reboiler(x) ∧ ∃q(HorizontalOrientation(q) ∧ hasQuality(x,q)) ∧ ∃v(SeparateVapourSpace(v) ∧ hasComponentPartAtAllTimes(x,v)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A kettle reboiler is a reboiler that has horizontal orientation and contains a separate vapour space for vapor-liquid disengagement."@en ,
                                                       "Um refervedor tipo kettle é um refervedor que possui orientação horizontal e contém um espaço de vapor separado para desengajamento vapor-líquido."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by specific physical configuration. Under Open World Assumption, sufficient conditions could incorrectly classify equipment with horizontal orientation and vapor space but fundamentally different purposes (e.g., horizontal separators, flash drums) as kettle reboilers. The structural differentia provides necessary conditions for the kettle reboiler maintenance/procurement category."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every kettle reboiler is a reboiler that has horizontal orientation and has a separate vapour space as component part."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000308
copi:COPI_0000308 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DrumBody
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:LiquidOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:VaporInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:VaporOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:KnockOutSeparationFunction
                                  ] ;
                  rdfs:label "knock out drum"@en ,
                             "vaso separador de condensado"@pt-br ;
                  skos:definition "[CFIHOS] A drum intended to separate relatively small quantities of liquid from a vapour stream."@en ,
                                  "[ISO 15926-4] A <KNOCK OUT DRUM> is an <ARTEFACT> and a <VESSEL> and a <VAPOUR-LIQUID SEPATATOR> intended to separate relatively small quantities of liquid from a vapour stream"@en ,
                                  "[POSC Caesar] A drum intended to separate relatively small quantities of liquid from a vapour stream"@en ;
                  annotation:firstOrderLogicAxiom "∀x(KnockOutDrum(x) ↔ Separator(x) ∧ ∃f(KnockOutSeparationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A knock out drum is a separator designed to separate relatively small quantities of liquid from a vapor stream through gravitational and momentum-based phase separation."@en ,
                                                       "Um vaso separador de condensado é um separador projetado para separar quantidades relativamente pequenas de líquido de uma corrente de vapor através de separação de fases gravitacional e baseada em momento."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every knock out drum is a separator that bears a knock out separation function, which is realized in processes that separate small quantities of liquid from vapor streams."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000309
copi:COPI_0000309 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricalOutput
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:LevelSensor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SwitchingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:LevelSwitchingFunction
                                  ] ;
                  rdfs:label "interruptor de nível"@pt-br ,
                             "level switch"@en ;
                  skos:definition "[CFIHOS] A functional switch that is intended to give an on/off signal when particulate material or fluid level have reached a pre-set value."@en ,
                                  "[ISO 15926-4] A <LEVEL SWITCH> is an <INSTRUMENTATION ITEM> and a <LEVEL MEASURING INSTRUMENT>"@en ,
                                  "[POSC Caesar] A functional switch that is intended to give an on/off signal when particulate material or fluid level have reached a preset value."@en ;
                  annotation:firstOrderLogicAxiom "∀x(LevelSwitch(x) ↔ (Instrument(x) ∧ ∃f(LevelSwitchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(DiscreteElectricalSignal(s) ∧ hasOutput(x,s))))"@en ;
                  annotation:naturalLanguageDefinition "A level switch is an instrument that bears a LevelSwitchingFunction, combining level detection with switching capability to provide discrete on/off electrical signals when fluid or particulate material levels reach preset values."@en ,
                                                       "Um interruptor de nível é um instrumento que possui uma Função de Comutação de Nível, combinando detecção de nível com capacidade de comutação para fornecer sinais elétricos discretos ligado/desligado quando níveis de fluidos ou materiais particulados atingem valores predefinidos."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every level switch is an instrument that has the function of level switching and outputs discrete electrical signals based on preset level conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000310
copi:COPI_0000310 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricalOutput
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ForceReceivingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TransductionElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ForceToElectricalTransductionFunction
                                  ] ;
                  rdfs:label "célula de carga"@pt-br ,
                             "load cell"@en ;
                  skos:definition "[CFIHOS] A transducer which produces a signal with a defined relationship to the force applied to it."@en ,
                                  "[ISO 15926-4] A <LOAD CELL> is an <ARTEFACT> and a <FORCE MEASURING ELEMENT> and a <TRANSDUCER> that converts a force such as tension, compression, pressure, or torque into an electrical signal that can be measured"@en ,
                                  "[OnePetro] A device based on strain gauge technology that helps measure the surface weight of coiled tubing."@en ,
                                  "[SLB Glossary] The sensor component in a weight-indicator system that detects the tensional or compressional forces being imparted to the running string at surface."@en ;
                  annotation:firstOrderLogicAxiom "∀x (LoadCell(x) ↔ Instrument(x) ∧ ∃f(ForceToElectricalTransductionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A load cell is an instrument that converts mechanical force (tension, compression, pressure, or torque) into a proportional electrical signal for measurement purposes."@en ,
                                                       "Uma célula de carga é um instrumento que converte força mecânica (tração, compressão, pressão ou torque) em um sinal elétrico proporcional para fins de medição."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every load cell is an instrument that bears a force-to-electrical transduction function and has a force-receiving element, transduction element, and electrical output."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000311
copi:COPI_0000311 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Chamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FluidOpening
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FluidDistributionFunction
                                  ] ;
                  rdfs:label "manifold"@en ,
                             "manifold"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that contains a chamber with several openings."@en ,
                                  "[ISO 15926-4] A <MANIFOLD> is an <ARTEFACT> and a <FLUID CONDUCTOR> that is an arrangement of piping or valves designed to control, distribute and typically monitor fluid flow"@en ,
                                  "[OnePetro] A junction or center for connecting several pipes and selectively routing the flow."@en ,
                                  "[POSC Caesar] A fluid container that contains a chamber with several openings."@en ,
                                  "[POSC Caesar] IMF purpose entity"@en ,
                                  "[SLB Glossary] An arrangement of piping or valves designed to control, distribute and typically monitor fluid flow."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Manifold(x) → Assembly(x) ∧ ∃c(Chamber(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃o(MultipleFluidOpenings(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃f(FluidDistributionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A manifold is an assembly that has a chamber with multiple fluid openings designed to distribute fluid flow."@en ,
                                                       "Um manifold é um conjunto que possui uma câmara com múltiplas aberturas de fluido projetada para distribuir o fluxo de fluido."@pt-br ;
                  annotation:primitiveRationale "As a constructive type, manifolds are defined by structural configuration. Under OWA, asserting equivalence would force any assembly with a chamber and multiple openings to be classified as a manifold, potentially misclassifying complex equipment with manifold-like components (e.g., turbine casings, complex valves). Starting with necessary conditions protects against false positives."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every manifold is an assembly that has-component-part-at-all-times some chamber and has-component-part-at-all-times some multiple fluid openings and bears some fluid distribution function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000312
copi:COPI_0000312 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000207 ;
                  rdfs:label "atuador manual"@pt-br ,
                             "manual actuator"@en ;
                  skos:definition "[ISO 15926-4] A <MANUAL ACTUATOR> is an <ARTEFACT> and an <ACTUATOR> which action has to be trigged manually"@en ;
                  annotation:firstOrderLogicAxiom "∀x (ManualActuator(x) ↔ Actuator(x) ∧ ∃s(ManualControlSignal(s) ∧ hasInput(x,s)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A manual actuator is an actuator that converts human-operated control inputs into mechanical movement or force through direct physical operation."@en ,
                                                       "Um atuador manual é um atuador que converte entradas de controle operadas por humanos em movimento mecânico ou força através de operação física direta."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "ManualActuator is an actuator that has input ManualControlSignal and has output MechanicalPower"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000313
copi:COPI_0000313 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ProcessingChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ProcessingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:MaterialProcessingFunction
                                  ] ;
                  rdfs:label "mill"@en ,
                             "moinho"@pt-br ;
                  skos:definition "[ISO 15926-4] A <MILL> is a <FACILITY> that consists of the land, buildings, machinery, apparatus, and fixtures, mostly employed in <MANUFACTURING> of discrete <COMMODITY MATERIAL>s"@en ,
                                  "[OnePetro] A cutting tool used to grind up metal, dress off a fish, or open up a window for a kick-off."@en ,
                                  "[SLB Glossary] A mill is usually used to remove junk in the hole or to grind away all or part of a casing string."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Mill(x) ↔ (Assembly(x) ∧ ∃f(MaterialProcessingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A mill is an assembly that bears a material processing function to reduce particle size or modify solid materials through mechanical grinding, cutting, or crushing operations."@en ,
                                                       "Um moinho é um conjunto que possui uma função de processamento de material para reduzir o tamanho de partículas ou modificar materiais sólidos através de operações mecânicas de moagem, corte ou trituração."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every mill is an assembly that has the function to process materials, and every assembly that has the function to process materials is a mill."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000314
copi:COPI_0000314 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MixingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:MixingFunction
                                  ] ;
                  rdfs:label "misturador"@pt-br ,
                             "mixer"@en ;
                  skos:definition "[CFIHOS] A physical object intended to be used for fluid mixing processes typically a rotating piece of equipment comprised of a driver such as a motor which rotates an agitator immersed in the fluid(s) that need to be mixed."@en ,
                                  "[DEXPI] An apparatus or machine that has the capability of mixing (from ``_)."@en ,
                                  "[ISO 15926-4] A <MIXER> is a <FunctionalObject> that has a capability of <MIXING>"@en ,
                                  "[POSC Caesar] A fluid container that mixes two ore more fluid ingredients."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Mixer(x) ↔ (Assembly(x) ∧ ∃f (MixingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A mixer is an assembly that has the designed function to blend or combine two or more fluid ingredients into a homogeneous mixture."@en ,
                                                       "Um misturador é um conjunto que tem a função projetada de misturar ou combinar dois ou mais ingredientes fluidos em uma mistura homogênea."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every mixer is an assembly that bears a mixing function, and every assembly that bears a mixing function is a mixer."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000315
copi:COPI_0000315 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BearingSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MotorHousing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotatingShaft
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:MechanicalEnergyGenerationFunction
                                  ] ;
                  rdfs:label "motor"@en ,
                             "motor"@pt-br ;
                  skos:definition "[CFIHOS] A device that generates rotational kinetic energy."@en ,
                                  "[DEXPI] A driver that is powered by electricity or internal combustion (from ``_)."@en ,
                                  "[ISO 15926-4] A <MOTOR> is an <ARTEFACT> and a <DRIVER(function)> that is powered by electricity or internal combustion"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Motor(x) ↔ Assembly(x) ∧ ∃f(MechanicalEnergyGenerationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(RotationalKineticEnergy(e) ∧ hasOutput(x,e)))"@en ;
                  annotation:naturalLanguageDefinition "A motor is an assembly that bears a mechanical energy generation function to convert electrical, chemical, pneumatic, or hydraulic energy into rotational mechanical energy."@en ,
                                                       "Um motor é um conjunto que possui uma função de geração de energia mecânica para converter energia elétrica, química, pneumática ou hidráulica em energia mecânica rotacional."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every motor is an assembly that has the function of generating mechanical energy and has as output rotational kinetic energy."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000316
copi:COPI_0000316 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ProtrudingPart
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ShapedOrifice
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FluidDirectionFunction
                                  ] ;
                  rdfs:label "bocal"@pt-br ,
                             "nozzle"@en ;
                  skos:definition "[CFIHOS] A physical object that has a protruding part through which a stream of fluid is directed."@en ,
                                  "[DEXPI] A projecting short piece of pipe that is attached to another (hollow) body."@en ,
                                  "[ISO 15926-4] A <NOZZLE> is an <ARTEFACT> and a <FLUID PORT> and a <CONNECTOR> that is a protruding part through which a stream of fluid is directed"@en ,
                                  "[OnePetro] A shaped orifice for directing fluid flow."@en ,
                                  "[POSC Caesar] A physical object that has a protruding part through which a stream of fluid is directed."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Nozzle(x) ↔ MaterialArtifact(x) ∧ ∃f(FluidDirectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃o(ShapedOrifice(o) ∧ hasComponentPartAtAllTimes(x,o)) ∧ ∃p(ProtrudingPart(p) ∧ hasComponentPartAtAllTimes(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A nozzle is a material artifact that has a protruding part with a shaped orifice designed to direct fluid flow into a specific pattern."@en ,
                                                       "Um bocal é um artefato material que possui uma parte protuberante com um orifício moldado projetado para direcionar o fluxo de fluido em um padrão específico."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every nozzle is a material artifact that bears a fluid direction function and has a shaped orifice and protruding part as component parts."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000317
copi:COPI_0000317 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000346 ;
                  rdfs:label "eixo de saída"@pt-br ,
                             "output shaft"@en ;
                  skos:definition "[ISO 15926-4] An <OUTPUT SHAFT> is a <SHAFT> that is the exit of mechanical energy and driver of an external energy consumer."@en ;
                  annotation:firstOrderLogicAxiom "∀x (OutputShaft(x) → Shaft(x) ∧ ∃p (MechanicalEnergyOutputProcess(p) ∧ participatesIn(x,p)) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A Shaft that participates in mechanical energy output processes, serving as the exit point for mechanical energy transmission from a prime mover to external energy consuming equipment."@en ,
                                                       "Um Eixo que participa em processos de saída de energia mecânica, servindo como ponto de saída para transmissão de energia mecânica de um motor primário para equipamentos consumidores de energia externos."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on positional role within mechanical systems. Under OWA, sufficient conditions would be difficult to specify without risk of misclassifying intermediate shafts or complex multi-shaft arrangements that happen to have output characteristics."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every output shaft is a shaft that participates in at least one mechanical energy output process and bears a power transmission function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000318
copi:COPI_0000318 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:LauncherValve
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PigLoadingChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PipelineConnection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PigLaunchingFunction
                                  ] ;
                  rdfs:label "lançador de pig"@pt-br ,
                             "pig launcher"@en ;
                  skos:definition "[CFIHOS] A pressure vessel intended for sending a pig into a pipeline."@en ,
                                  "[ISO 15926-4] A <PIG LAUNCHER> is a <FunctionalObject> that is capable of <LAUNCHING> a <PIPE PIG> into a pipeline"@en ,
                                  "[POSC Caesar] A chamber connected to a pipeline intended for sending pigs into the pipeline."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PigLauncher(x) ↔ (Vessel(x) ∧ ∃f(PigLaunchingFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(PipelineConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))"@en ;
                  annotation:naturalLanguageDefinition "A pig launcher is a vessel that bears a pig launching function for inserting pipeline pigs into pipeline systems."@en ,
                                                       "Um lançador de pig é um vaso que possui função de lançamento de pig para inserir pigs de duto em sistemas de tubulação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pig launcher is a vessel that has the function to launch pipeline pigs and has a pipeline connection component."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000319
copi:COPI_0000319 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PigChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PigEntryPort
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureBoundary
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PigReceivingFunction
                                  ] ;
                  rdfs:label "pig receiver"@en ,
                             "recebedor de pig"@pt-br ;
                  skos:definition "[CFIHOS] A pressure vessel intended for receiving a pig from a pipeline."@en ,
                                  "[ISO 15926-4] A <PIG RECEIVER> is a <RECEIVER> that is capable of <RECEIVING> a <PIPE PIG> from a pipeline"@en ,
                                  "[POSC Caesar] A chamber connected to the end of a pipeline intended for receiving pigs."@en ;
                  annotation:firstOrderLogicAxiom "∀x (PigReceiver(x) ↔ (Vessel(x) ∧ ∃f(PigReceivingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A pig receiver is a vessel that has the function to receive pipe pigs from a pipeline."@en ,
                                                       "Um recebedor de pig é um vaso que tem a função de receber pigs de tubulação de um duto."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pig receiver is a vessel that bears a pig receiving function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000320
copi:COPI_0000320 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000318
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000319
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Closure
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PigLaunchingAndReceivingFunction
                                  ] ;
                  rdfs:label "armadilha de pig"@pt-br ,
                             "pig trap"@en ;
                  skos:definition "[CFIHOS] A facility on a pipeline for inserting and retrieving a scraper or pig."@en ,
                                  "[ISO 15926-4] A <PIG TRAP> is an <ARTEFACT> and a <TOOL> that is a pipeline maintenance tool, which includes a launcher and receiver, introducing a <PIPE PIG> into the line"@en ,
                                  "[POSC Caesar] \""@en ;
                  annotation:firstOrderLogicAxiom "∀x(PigTrap(x) ↔ Assembly(x) ∧ ∃f(PigLaunchingAndReceivingFunction(f) ∧ bearerOf(x,f)) ∧ ∃l(PigLauncher(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃r(PigReceiver(r) ∧ hasComponentPartAtAllTimes(x,r)))"@en ;
                  annotation:naturalLanguageDefinition "A pig trap is an assembly that bears the function of launching and receiving pipe pigs for pipeline maintenance and has both launcher and receiver components."@en ,
                                                       "Uma armadilha de pig é um conjunto que possui a função de lançar e receber pigs de tubulação para manutenção de dutos e possui componentes de lançador e receptor."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pig trap is an assembly that bears a pig launching and receiving function and has component parts that are a pig launcher and a pig receiver."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000321
copi:COPI_0000321 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PipeInterior
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PipeWall
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FluidConductionFunction
                                  ] ;
                  rdfs:label "pipe"@en ,
                             "tubo"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that is a long tube or hollow body intended for conduction of liquid, gaseous or finely divided solid materials, or used for structural purposes."@en ,
                                  "[DEXPI] An elementary piece of piping, i.e., not interrupted by any item."@en ,
                                  "[ISO 15926-4] A <PIPE> is an <ARTEFACT> and a <FLUID CONDUCTOR> that is a long tube or hollow body intended for conduction of liquid, gaseous or finely divided solid materials, or used for structural purposes"@en ,
                                  "[POSC Caesar] An 'artefact' that is a long tube or hollow body intended for conduction of liquid, gaseous or finely divided solid materials, or used for structural purposes."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Pipe(x) → MaterialArtifact(x) ∧ ∃f(FluidConductionFunction(f) ∧ hasFunction(x,f)) ∧ ∃g(TubularGeometry(g) ∧ hasPhysicalProperty(x,g)) ∧ ∃h(LongitudinalExtent(h) ∧ hasPhysicalProperty(x,h)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A pipe is a material artifact characterized by tubular geometry and longitudinal extent, designed to conduct liquid, gaseous or finely divided solid materials from one location to another, or to serve structural purposes."@en ,
                                                       "Um tubo é um artefato material caracterizado por geometria tubular e extensão longitudinal, projetado para conduzir materiais líquidos, gasosos ou sólidos finamente divididos de um local para outro, ou para servir a propósitos estruturais."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because pipe is defined by constructive/geometric properties (tubular geometry, longitudinal extent) rather than purely functional criteria. Under Open World Assumption, asserting sufficient conditions based on geometric properties could lead to unintended classification of complex tubular structures that happen to conduct fluids but should not be categorized as standard pipes."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pipe is a material artifact that has fluid conduction function and has tubular geometry and has longitudinal extent."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000322
copi:COPI_0000322 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000321 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BentPipeSection
                                  ] ;
                  rdfs:label "curva de tubo"@pt-br ,
                             "pipe bend"@en ;
                  skos:definition "[CFIHOS] A physical object that is used to change piping direction with a non-standard radius."@en ,
                                  "[ISO 15926-4] A <PIPE BEND> is a <PIPING COMPONENT> that is intended to change piping direction with a non-standard radius"@en ,
                                  "[POSC Caesar] An 'artefact' that is intended to change piping direction with a non-standard radius"@en ;
                  annotation:firstOrderLogicAxiom "∀x (PipeBend(x) → Pipe(x) ∧ ∃g (CurvedGeometry(g) ∧ hasQuality(x,g)) ∧ ∃r (NonStandardBendRadius(r) ∧ hasQuality(x,r)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A pipe bend is a pipe that has a curved geometry to change piping direction with a non-standard radius."@en ,
                                                       "Uma curva de tubo é um tubo que possui geometria curvada para mudar a direção da tubulação com um raio não padrão."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. While the curved geometry with non-standard radius is distinctive, making it sufficient under OWA could force classification of complex piping assemblies or custom manifolds containing bent sections into this maintenance category inappropriately."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pipe bend is a pipe that has curved geometry and has non-standard bend radius."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000323
copi:COPI_0000323 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000321 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CurvedFluidPassage
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElbowBody
                                  ] ;
                  rdfs:label "cotovelo de tubulação"@pt-br ,
                             "pipe elbow"@en ;
                  skos:definition "[ISO 15926-4] A <PIPE ELBOW> is a <PIPING COMPONENT> and an <ELBOW> that is intended to make a change in the direction of a pipe run between 0 and 135 degrees"@en ,
                                  "[POSC Caesar] An 'elbow' and an 'artefact' that is intended to make a change in the direction of a pipe run between 0 and 135 degrees."@en ;
                  annotation:firstOrderLogicAxiom "∀x (PipeElbow(x) → (Pipe(x) ∧ ∃g(CurvedGeometry(g) ∧ hasGeometricProperty(x,g)) ∧ ∃p(DirectionalChangeCapacity(p) ∧ hasProperty(x,p))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A pipe elbow is a pipe that has curved geometry enabling directional changes in pipe runs between 0 and 135 degrees."@en ,
                                                       "Um cotovelo de tubulação é uma tubulação que possui geometria curva permitindo mudanças direcionais em trechos de tubulação entre 0 e 135 graus."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type protects against false positives under OWA. Any curved piping component would be forcibly classified as a pipe elbow under equivalent axioms, including specialized equipment like coiled tubing, serpentine heat exchanger tubes, or custom manifold sections that contain curved passages but should not be asserted into the standard pipe elbow maintenance category."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pipe elbow is a pipe that has curved geometry and enables directional change capacity between 0 and 135 degrees."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000324
copi:COPI_0000324 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000321 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:InletEnd
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OutletEnd
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ReducerBody
                                  ] ;
                  rdfs:label "pipe reducer"@en ,
                             "redutor de tubulação"@pt-br ;
                  skos:definition "[CFIHOS] An 'artefact' that has different nominal pipe size at the two ends, intended to connect pipes or piping components."@en ,
                                  "[ISO 15926-4] A <PIPE REDUCER> is a <PIPING COMPONENT> and a <REDUCER> either concentric or eccentric of different  nominal pipe size at the two ends, intended to connect pipes or piping components of different nominal pipe sizes or non standard sizes"@en ,
                                  "[POSC Caesar] An 'artefact' that has different nominal pipe size at the two ends, intended to connect pipes or piping components."@en ;
                  annotation:firstOrderLogicAxiom "∀x (PipeReducer(x) → Pipe(x) ∧ ∃i,o (InletEnd(i) ∧ OutletEnd(o) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ DifferentNominalPipeSizes(i,o)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A pipe reducer is a pipe that has different nominal pipe sizes at its two ends, intended to connect pipes or piping components of different sizes."@en ,
                                                       "Um redutor de tubulação é um tubo que possui tamanhos nominais diferentes de tubulação em suas duas extremidades, destinado a conectar tubos ou componentes de tubulação de tamanhos diferentes."@pt-br ;
                  annotation:primitiveRationale "As a constructive type defined by geometric configuration, sufficient conditions are omitted under the Open World Assumption to prevent false positives. Complex assemblies or custom manifolds containing size transitions should not be automatically classified as standard pipe reducers without explicit assertion."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pipe reducer is a pipe that has an inlet end and outlet end with different nominal pipe sizes"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000325
copi:COPI_0000325 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000321 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BranchPort
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RunPort
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TeeBody
                                  ] ;
                  rdfs:label "pipe tee"@en ,
                             "tê de tubulação"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that has three piping ends in T-shape, including a branch at 90 degrees."@en ,
                                  "[ISO 15926-4] A <PIPE TEE> is a <PIPING COMPONENT> and a <PIPING NETWORK NODE> and three piping ends in T-shape, including a branch at 90 degrees"@en ,
                                  "[POSC Caesar] An 'artefact' that has three piping ends in T-shape, including a branch at 90 degrees."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PipeTee(x) → Pipe(x) ∧ ∃p1,p2,p3(BranchPort(p1) ∧ RunPort(p2) ∧ RunPort(p3) ∧ hasPartAtAllTimes(x,p1) ∧ hasPartAtAllTimes(x,p2) ∧ hasPartAtAllTimes(x,p3) ∧ perpendicularTo(p1,p2) ∧ perpendicularTo(p1,p3)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A pipe tee is a pipe fitting that has three fluid ports arranged in T-shaped configuration, with one branch port perpendicular to two run ports, designed to realize fluid conduction function through flow division or combination."@en ,
                                                       "Um tê de tubulação é uma conexão de tubulação que possui três portas de fluido dispostas em configuração em formato de T, com uma porta de ramal perpendicular a duas portas de passagem, projetada para realizar função de condução de fluido através de divisão ou combinação de fluxo."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. The T-shaped geometric configuration with three specific ports is a structural differentia that is harder to make sufficient under OWA. Custom manifolds or complex fittings might contain T-shaped passages but should not be automatically classified as standard pipe tees without domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pipe tee is a pipe that has exactly three fluid ports arranged in T-configuration and bears a fluid conduction function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000326
copi:COPI_0000326 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                    owl:someValuesFrom copi:FluidTransportFunction
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                    owl:someValuesFrom copi:COPI_0000321
                                  ] ;
                  rdfs:label "pipeline"@en ,
                             "pipeline"@pt-br ;
                  skos:definition "[CFIHOS] A fluid conductor that consists of pipe, possibly also including pumps, valves, and control devices, intended for conveying liquids, gases, or finely divided solids."@en ,
                                  "[ISO 15926-4] A <PIPELINE> is a <CONTINOUS FLUID TRANSPORTER> and a <FLUID CONDUCTOR> and a <SYSTEM> that consists of pipe, possibly also including pumps, valves, and control devices, intended for conveying liquids, gases, or finely divided solids"@en ,
                                  "[OnePetro] The principle underground transport of produced gas and oil."@en ,
                                  "[POSC Caesar] A fluid conductor that consists of pipe, possibly also including pumps, valves, and control devices, intended for conveying liquids, gases, or finely divided solids."@en ,
                                  "[SLB Glossary] A tube or system of tubes used for transporting crude oil and natural gas from the field or gathering system to the refinery."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Pipeline(x) ↔ EngineeredSystem(x) ∧ ∃f(FluidTransportFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A pipeline is an engineered system that bears a fluid transport function, consisting of pipes and possibly including pumps, valves, and control devices, designed for conveying liquids, gases, or finely divided solids between locations."@en ,
                                                       "Um pipeline é um sistema engenheirado que possui uma função de transporte de fluidos, consistindo de tubos e possivelmente incluindo bombas, válvulas e dispositivos de controle, projetado para transportar líquidos, gases ou sólidos finamente divididos entre locais."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pipeline is an engineered system that bears a fluid transport function and has pipe as a component part at some time."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000327
copi:COPI_0000327 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000207 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AirIntake
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PneumaticCylinder
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PneumaticSeal
                                  ] ;
                  rdfs:label "atuador pneumático"@pt-br ,
                             "pneumatic actuator"@en ;
                  skos:definition "[CFIHOS] An actuator that is intended to be operated by pneumatic power."@en ,
                                  "[ISO 15926-4] A <PNEUMATIC ACTUATOR> is an <INSTRUMENTATION ITEM> and a <CONTROLLED ACTUATOR> that is intended to be operated by pneumatic power"@en ,
                                  "[POSC Caesar] An actuator that is intended to be operated by pneumatic power."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PneumaticActuator(x) → Actuator(x) ∧ ∃y(PneumaticPower(y) ∧ hasOperatingMedium(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A pneumatic actuator is an actuator that operates using pneumatic power."@en ,
                                                       "Um atuador pneumático é um atuador que opera usando energia pneumática."@pt-br ;
                  annotation:primitiveRationale "Constructive type where pneumatic mechanism is necessary but may not be sufficient under OWA. Specialized pneumatic equipment (pneumatic tools, pneumatic cylinders) might have pneumatic power but should not be classified as actuators without additional validation of their actuation role in control systems."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pneumatic actuator is an actuator that has operating medium some pneumatic power."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000328
copi:COPI_0000328 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000315 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotaryOutput
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PneumaticMotorFunction
                                  ] ;
                  rdfs:label "motor pneumático"@pt-br ,
                             "pneumatic motor"@en ;
                  skos:definition "[CFIHOS] A motor that is driven by compressed gas. Typically air."@en ,
                                  "[ISO 15926-4] A <PNEUMATIC MOTOR> is an <AIR MOTOR> that is driven by compressed gas (typically air)"@en ,
                                  "[POSC Caesar] A motor that is driven by compressed gas. Typically air."@en ;
                  annotation:firstOrderLogicAxiom "∀x (PneumaticMotor(x) ↔ Motor(x) ∧ ∃f(PneumaticMotorFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A pneumatic motor is a motor that converts compressed gas energy into mechanical rotational energy."@en ,
                                                       "Um motor pneumático é um motor que converte energia de gás comprimido em energia mecânica rotacional."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pneumatic motor is a motor that bears a PneumaticMotorFunction."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000329
copi:COPI_0000329 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:InterfacingFunction
                                  ] ;
                  rdfs:label "MaterialArtifact que possui uma InterfacingFunction e"@pt-br ,
                             "port"@en ;
                  skos:definition "[ISO 15926-4] A <PORT> is a <FunctionalObject> that is capable of <PROVIDING> a point of interface for communication with another object"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Port(x) ↔ (MaterialArtifact(x) ∧ ∃f(InterfacingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that bears an InterfacingFunction and that is capable of providing a point of interface for communication with another object."@en ,
                                                       "Um MaterialArtifact que possui uma InterfacingFunction e que é capaz de fornecer um ponto de interface para comunicação com outro objeto."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Port ≡ MaterialArtifact ⊓ ∃bearerOf.InterfacingFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000330
copi:COPI_0000330 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000024 ,
                                  copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000363
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PositionSensor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalConditioner
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PositionTransmissionFunction
                                  ] ;
                  rdfs:label "position transmitter"@en ,
                             "transmissor de posição"@pt-br ;
                  skos:definition "[CFIHOS] A transmitter that is producing a standardized output signal dependent of a received input signal from a position detector."@en ,
                                  "[ISO 15926-4] A <POSITION TRANSMITTER>is a <PROCESS VARIABLE TRANSMITTER> and a <POSITION MEASURING INSTRUMENT>"@en ,
                                  "[isa5_1] ISA 5.1 tag abbreviation 'ZT'. First letter 'Z': Position, Dimension. Succeeding letters: 'T' = Transmit."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PositionTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PositionTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PositionSignal(s) ∧ hasInput(x,s)))"@en ;
                  annotation:naturalLanguageDefinition "A position transmitter is a transmitter that measures position or displacement and converts it to a standardized output signal."@en ,
                                                       "Um transmissor de posição é um transmissor que mede posição ou deslocamento e o converte em um sinal de saída padronizado."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every position transmitter is a transmitter that has the function of position transmission and receives position or displacement signals as input."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000331
copi:COPI_0000331 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000072 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000335
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DisplacementMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000066
                                  ] ;
                  rdfs:label "bomba de deslocamento positivo"@pt-br ,
                             "positive displacement pump"@en ;
                  skos:definition "[ISO 15926-4] A <POSITIVE DISPLACEMENT PUMP> is an <ARTEFACT> and a <PUMP> intended to transport liquid through the reciprocating or rotary displacement principle and with either fixed or adjustable volume flow rates. NOTE - Combine with either BARE PUMP or PUMP SYSTEM,"@en ,
                                  "[SLB Glossary] A type of fluid pump in which the displacement volume of the pump is fixed for each rotation of the pump."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PositiveDisplacementPump(x) → Pump(x) ∧ ∃y(DisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(PositiveDisplacementProcess(z) ∧ participatesIn(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A positive displacement pump is a pump that transports liquid through reciprocating or rotary displacement principle with fixed displacement volume per cycle."@en ,
                                                       "Uma bomba de deslocamento positivo é uma bomba que transporta líquido através do princípio de deslocamento alternativo ou rotativo com volume de deslocamento fixo por ciclo."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by physical mechanism. Under OWA, sufficient conditions based on displacement mechanism alone could lead to false positives where specialized equipment containing displacement elements might be incorrectly classified as standard positive displacement pumps."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every positive displacement pump is a pump that has a displacement mechanism as component part at all times and participates in positive displacement processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000332
copi:COPI_0000332 rdf:type owl:Class ;
                  rdfs:subClassOf copi:PrimaryWinding ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000199
                                  ] ;
                  rdfs:label "enrolamento de transformador"@pt-br ,
                             "power transformer primary winding"@en ;
                  skos:definition "[ISO 15926-4] A <POWER TRANSFORMER PRIMARY WINDING> is a <TRANSFORMER PRIMARY WINDING> intended to be the winding of a power transformer"@en ;
                  annotation:firstOrderLogicAxiom "∀x(PowerTransformerPrimaryWinding(x) → TransformerWinding(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(PrimaryWindingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A TransformerWinding that is part of a power transformer and that serves as the primary winding receiving input electrical power for electromagnetic transformation."@en ,
                                                       "Um enrolamento de transformador que é parte de um transformador de potência e que serve como enrolamento primário recebendo energia elétrica de entrada para transformação eletromagnética."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on structural position within power transformer. Under OWA, sufficient conditions for primary winding configuration would risk false positives for specialized or hybrid transformer components that contain primary-like windings but should not be classified as standard power transformer primary windings."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "PowerTransformerPrimaryWinding is-a TransformerWinding that is-part-of PowerTransformer and has-function PrimaryWindingFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000333
copi:COPI_0000333 rdf:type owl:Class ;
                  rdfs:subClassOf copi:SecondaryWinding ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000199
                                  ] ;
                  rdfs:label "enrolamento secundário de transformador de potência"@pt-br ,
                             "power transformer secondary winding"@en ;
                  skos:definition "[ISO 15926-4] A <POWER TRANSFORMER SECONDARY WINDING> is a <TRANSFORMER SECONDARY WINDING> intended to be the secondary winding of a power transformer"@en ;
                  annotation:firstOrderLogicAxiom "∀x(PowerTransformerSecondaryWinding(x) → FiatObjectPart(x) ∧ ∃y(PowerTransformer(y) ∧ partOf(x,y)) ∧ ∃f(SecondaryWindingFunction(f) ∧ hasFunction(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A FiatObjectPart that is the secondary winding of a power transformer and that bears a SecondaryWindingFunction consisting in delivering transformed electrical power at the output voltage level."@en ,
                                                       "Uma FiatObjectPart que é o enrolamento secundário de um transformador de potência e que possui uma SecondaryWindingFunction consistindo em fornecer energia elétrica transformada no nível de tensão de saída."@pt-br ;
                  annotation:primitiveRationale "Constructive classification basis - the physical configuration (being the secondary winding of a power transformer) provides necessary conditions, but sufficient conditions are harder to assert under OWA without risking false positives for specialized or hybrid transformer configurations."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "PowerTransformerSecondaryWinding SubClassOf FiatObjectPart and (partOf some PowerTransformer) and (hasFunction some SecondaryWindingFunction)"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000334
copi:COPI_0000334 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricalTerminals
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureIndicator
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureSensor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SignalProcessor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PressureIndicatingAndTransmissionFunction
                                  ] ;
                  rdfs:label "pressure indicating transmitter"@en ,
                             "transmissor indicador de pressão"@pt-br ;
                  skos:definition "[isa5_1] ISA 5.1 tag abbreviation 'PIT'. First letter 'P': Pressure. Succeeding letters: 'I' = Indicate, 'T' = Transmit."@en ;
                  annotation:firstOrderLogicAxiom "∀x (PressureIndicatingTransmitter(x) ↔ Transmitter(x) ∧ ∃f(PressureIndicatingAndTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(PressureSignal(i) ∧ hasInput(x,i)) ∧ ∃o1(ElectricalSignal(o1) ∧ hasOutput(x,o1)) ∧ ∃o2(LocalPressureDisplay(o2) ∧ hasOutput(x,o2)))"@en ;
                  annotation:naturalLanguageDefinition "A pressure indicating transmitter is a transmitter that measures pressure and provides both local visual indication and electrical signal transmission of the pressure value."@en ,
                                                       "Um transmissor indicador de pressão é um transmissor que mede pressão e fornece tanto indicação visual local quanto transmissão de sinal elétrico do valor da pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pressure indicating transmitter is a transmitter that bears a pressure indicating and transmission function, has pressure signal as input, and has both electrical signal output and local pressure display."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000335
copi:COPI_0000335 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000222 ;
                  rdfs:label "carcaça de bomba"@pt-br ,
                             "pump casing"@en ;
                  skos:definition "[ISO 15926-4] A <PUMP CASING> is a  <CASING> and a single wall surrounding the impeller. The suction and discharge nozzles form an integral part of the casing. Typically applied for centrifugal pumps"@en ;
                  annotation:firstOrderLogicAxiom "∀x(PumpCasing(x) → Casing(x) ∧ ∃y(Impeller(y) ∧ surrounds(x,y)) ∧ ∃z(SuctionNozzle(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ∃w(DischargeNozzle(w) ∧ hasComponentPartAtAllTimes(x,w)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A casing that surrounds an impeller and has integral suction and discharge nozzles as structural components, typically applied in centrifugal pumps."@en ,
                                                       "Um invólucro que envolve um impulsor e possui bocais de sucção e descarga integrais como componentes estruturais, tipicamente aplicado em bombas centrífugas."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on physical configuration. Under Open World Assumption, structural characteristics are harder to make sufficient - any assembly with an impeller and integral nozzles might be classified as a pump casing even if it serves a different specialized purpose. Starting with necessary conditions protects against false positives."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pump casing is a casing that surrounds an impeller and has integral suction and discharge nozzles forming part of its structure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000336
copi:COPI_0000336 rdf:type owl:Class ;
                  rdfs:subClassOf copi:RotatingShaft ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000192
                                  ] ;
                  rdfs:label "eixo de bomba"@pt-br ,
                             "pump shaft"@en ;
                  skos:definition "[ISO 15926-4] A <PUMP SHAFT> is a <SHAFT> of a pump that is provided with impeller(s), bearings, bushings, sealing elements etc."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PumpShaft(x) → MaterialArtifact(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃i(Impeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃b(Bearing(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃p(Pump(p) ∧ partOf(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction and that is equipped with impeller(s), bearings, bushings, and sealing elements as part of a pump assembly for transmitting rotational mechanical energy to enable fluid pumping operations."@en ,
                                                       "Um eixo de bomba é um MaterialArtifact que possui uma PowerTransmissionFunction e que é equipado com impulsor(es), mancais, buchas e elementos de vedação como parte de um conjunto de bomba para transmitir energia mecânica rotacional e possibilitar operações de bombeamento de fluidos."@pt-br ;
                  annotation:primitiveRationale "As a constructive type defined by physical configuration, sufficient conditions are omitted to avoid false positives under OWA. Any rotating component with an impeller and bearings could theoretically be classified as a pump shaft under sufficient conditions, including hybrid equipment or specialized assemblies that should not be automatically categorized as standard pump shafts."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pump shaft is a MaterialArtifact that bears a PowerTransmissionFunction, has impeller(s) as component parts, has bearings as component parts, and is part of a pump assembly."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000337
copi:COPI_0000337 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000072 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CylindricalChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:DischargeValve
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:IntakeValve
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PistonOrPlunger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ReciprocatingDisplacementMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000066
                                  ] ;
                  rdfs:label "bomba alternativa"@pt-br ,
                             "reciprocating pump"@en ;
                  skos:definition "[CFIHOS] A positive displacement pump which contains a displacing element intended to be moved in a reciprocating movement to exert pressure on a fluid, typically moving within a cylindrical space."@en ,
                                  "[ISO 15926-4] A <RECIPROCATING PUMP> is a <POSITIVE DISPLACEMENT PUMP> which contains a displacing element intended to be moved in a reciprocating movement to exert pressure on a fluid, typically moving within a cylindrical space."@en ,
                                  "[OnePetro] A piston pump."@en ,
                                  "[POSC Caesar] a positive displacement pump which contains a displacing element intended to be moved in a reciprocating movement to exert pressure on a fluid, typically moving within a cylindrical space."@en ,
                                  "[SLB Glossary] A type of fluid pump in which reciprocating pistons or plungers displace the fluid."@en ;
                  annotation:firstOrderLogicAxiom "∀x(ReciprocatingPump(x) → Pump(x) ∧ ∃m(ReciprocatingDisplacementMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃p(PistonOrPlunger(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃c(CylindricalChamber(c) ∧ hasComponentPartAtAllTimes(x,c)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A reciprocating pump is a pump that contains pistons or plungers designed to move in a reciprocating motion within cylindrical chambers to displace fluid through positive displacement action."@en ,
                                                       "Uma bomba alternativa é uma bomba que contém pistões ou êmbolos projetados para se moverem em movimento alternativo dentro de câmaras cilíndricas para deslocar fluido através de ação de deslocamento positivo."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. Under Open World Assumption, asserting equivalence based on structural differentia could lead to false positives where complex equipment containing reciprocating elements (like reciprocating compressors with auxiliary pumps, or hybrid systems) might be incorrectly classified as standard reciprocating pumps. The structural mechanism is necessary but sufficient conditions require domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every reciprocating pump is a pump that has as component part at all times a reciprocating displacement mechanism and has as component part at all times pistons or plungers and has as component part at all times cylindrical chambers."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000338
copi:COPI_0000338 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RelayCoil
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SwitchingContacts
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:SignalRelayFunction
                                  ] ;
                  rdfs:label "relay"@en ,
                             "relé"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that can be any electrical device, usually incorporating an electromagnet, whereby a current or signal in one circuit can open or close another circuit."@en ,
                                  "[ISO 15926-4] A <RELAY> is a <SWITCHING DEVICE> that usually is incorporating an electromagnet, whereby a current or signal in one circuit can open or close another circuit"@en ,
                                  "[isa5_1] a device, whose function is to pass on information in an unchanged form or in some modified form, often used to mean the preferred term computing device."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Relay(x) ↔ (ElectricalSwitchingDevice(x) ∧ ∃f(SignalRelayFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A relay is an electrical switching device that bears a signal relay function, realized by passing on information or signals from one circuit to control operations in another circuit."@en ,
                                                       "Um relé é um dispositivo de comutação elétrica que possui uma função de relé de sinal, realizada ao transmitir informações ou sinais de um circuito para controlar operações em outro circuito."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every Relay is an ElectricalSwitchingDevice that bearerOf some SignalRelayFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000339
copi:COPI_0000339 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000321 ;
                  rdfs:label "riser"@en ,
                             "riser"@pt-br ;
                  skos:definition "[CFIHOS] A physical object that is a vertical or near vertical pipe for the upward flow of liquid or gas."@en ,
                                  "[ISO 15926-4] A <RISER> is a <FLUID CONDUCTOR> and a <FLUID TRANSPORTER> that is a vertical or near vertical pipe for the upward flow of liquid or gas"@en ,
                                  "[OnePetro] Pipe through which liquid travels upward."@en ,
                                  "[POSC Caesar] A physical object that is a vertical or near vertical pipe for the upward flow of liquid or gas."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Riser(x) → Pipe(x) ∧ ∃q(VerticalOrientation(q) ∧ hasQuality(x,q)) ∧ ∃p(UpwardFlowProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A riser is a pipe that has vertical or near-vertical orientation and is designed for the upward flow of liquid or gas."@en ,
                                                       "Um riser é um tubo que tem orientação vertical ou quase vertical e é projetado para o fluxo ascendente de líquido ou gás."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type defined by physical configuration. Under OWA, any pipe with vertical orientation and upward flow could be forced into this category, including specialized equipment that should not be classified as standard risers (e.g., reactor internals, distillation column internals). Starting with necessary conditions protects against false positives."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every riser is a pipe that has vertical orientation and participates in upward flow processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000340
copi:COPI_0000340 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000207 ;
                  rdfs:label "atuador rotativo"@pt-br ,
                             "rotary actuator"@en ;
                  skos:definition "[ISO 15926-4] A <ROTARY ACTUATOR> is an <ARTEFACT> and an <ACTUATOR> causing a rotary motion"@en ;
                  annotation:firstOrderLogicAxiom "∀x (RotaryActuator(x) → Actuator(x) ∧ ∃p (RotaryMotionProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A rotary actuator is an actuator that causes rotary motion by converting control signals into controlled rotational mechanical output."@en ,
                                                       "Um atuador rotativo é um atuador que causa movimento rotativo convertendo sinais de controle em saída mecânica rotacional controlada."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on rotary motion mechanism. Under OWA, providing sufficient conditions could lead to over-classification where any equipment that happens to produce rotary motion (motors, turbines, etc.) might be incorrectly classified as rotary actuators. The rotary motion differentia is necessary but requires domain expert validation to confirm it is sufficient for the actuator equipment category."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every rotary actuator is an actuator that participates in rotary motion processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000341
copi:COPI_0000341 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000331 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000257
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PumpChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotaryDisplacementMechanism
                                  ] ;
                  rdfs:label "bomba rotativa"@pt-br ,
                             "rotary pump"@en ;
                  skos:definition "[CFIHOS] A positive displacement pump that consists of a chamber containing gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing and which has no separate inlet and outlet valves."@en ,
                                  "[ISO 15926-4] A <ROTARY PUMP> is a <POSITIVE DISPLACEMENT PUMP> that consists of a chamber containing gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing and which has no separate inlet and outlet valves."@en ,
                                  "[POSC Caesar] A positive displacement pump that consists of a chamber containing gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing and which has no separate inlet and outlet valves."@en ;
                  annotation:firstOrderLogicAxiom "∀x (RotaryPump(x) → PositiveDisplacementPump(x) ∧ ∃y (RotaryDisplacementMechanism(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ¬∃z (SeparateInletValve(z) ∧ hasComponentPartAtAllTimes(x,z)) ∧ ¬∃w (SeparateOutletValve(w) ∧ hasComponentPartAtAllTimes(x,w)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A rotary pump is a positive displacement pump that contains a chamber with gears, cams, screws, vanes, plungers or similar elements actuated by relative rotation of the drive shaft or casing, and which has no separate inlet and outlet valves."@en ,
                                                       "Uma bomba rotativa é uma bomba de deslocamento positivo que contém uma câmara com engrenagens, cames, parafusos, palhetas, êmbolos ou elementos similares acionados pela rotação relativa do eixo de acionamento ou carcaça, e que não possui válvulas separadas de entrada e saída."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. While the rotary mechanism is clearly necessary for rotary pumps, making it sufficient under OWA could lead to false positives where complex equipment containing rotary elements (like gearboxes with pumping side-effects or hybrid machines) might be misclassified as standard rotary pumps. The constructive differentia should be validated by domain experts before upgrading to equivalence."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every rotary pump is a positive displacement pump that has a rotary displacement mechanism as component part and lacks separate inlet and outlet valves."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000342
copi:COPI_0000342 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:RotationalEnergyTransferFunction
                                  ] ;
                  rdfs:label "rotor"@en ,
                             "rotor"@pt-br ;
                  skos:definition "[ISO 15926-4] A <ROTOR> is a <MACHINE COMPONENT> that is the rotating portion of a machine"@en ,
                                  "[OnePetro] The rotating shaft in a PDM motor."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Rotor(x) → Assembly(x) ∧ ∃p(RotationalMotionProcess(p) ∧ participatesIn(x,p)) ∧ ∃s(RotorShaft(s) ∧ hasComponentPartAtAllTimes(x,s)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An Assembly that participates in rotational motion and has a rotor shaft as an essential component, designed to transfer mechanical energy through rotational motion within a machine assembly."@en ,
                                                       "Um Assembly que participa em movimento rotacional e tem um eixo do rotor como componente essencial, projetado para transferir energia mecânica através de movimento rotacional dentro de um conjunto de máquina."@pt-br ;
                  annotation:primitiveRationale "As a constructive type defined by physical configuration (rotating portion with shaft), providing sufficient conditions under OWA could lead to overclassification. Complex assemblies containing rotating elements might be incorrectly classified as rotors rather than their proper categories (motors, compressors, etc.)."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every Rotor is an Assembly that participates in some RotationalMotionProcess and has some rotor shaft as component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000343
copi:COPI_0000343 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RuptureElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SeatingSurface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000169
                                  ] ;
                  rdfs:label "disco de ruptura"@pt-br ,
                             "rupture disc"@en ;
                  skos:definition "[CFIHOS] A physical object that is a pressure relieving device designed to burst at a calibrated pressure to prevent pressure in systems or vessels from reaching unsafe levels."@en ,
                                  "[ISO 15926-4] A <RUPTURE DISC> is an <INSTRUMENT COMPONENT> and an <OVERPRESSURE PROTECTOR> that is designed to burst at a certain excess pressure. It is a part of <RUPTURE DISC ASSEMBLY>"@en ,
                                  "[POSC Caesar] A physical object that is designed to burst at a certain excess pressure. It is part of a rupture disc assembly."@en ;
                  annotation:firstOrderLogicAxiom "∀x (RuptureDisc(x) ↔ Instrument(x) ∧ ∃f(PressureReliefFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(IrreversibleRuptureProcess(p) ∧ participatesIn(x,p)) ∧ ∃q(CalibrationPressure(q) ∧ hasQuality(x,q)))"@en ;
                  annotation:naturalLanguageDefinition "A rupture disc is an instrument that realizes pressure relief through irreversible rupture at a calibrated pressure."@en ,
                                                       "Um disco de ruptura é um instrumento que realiza alívio de pressão através de ruptura irreversível em uma pressão calibrada."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every rupture disc is an instrument that has the function to relieve pressure and participates in irreversible rupture processes at calibrated pressure thresholds."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000344
copi:COPI_0000344 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ScrapingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ScrapingFunction
                                  ] ;
                  rdfs:label "raspador"@pt-br ,
                             "scraper"@en ;
                  skos:definition "[CFIHOS] A physical object intended to mechanically remove a deposit from a surface."@en ,
                                  "[ISO 15926-4] A <SCRAPER> is a <FunctionalObject> that is capable of <SCRAPING>"@en ,
                                  "[OnePetro] A device that cuts through paraffin, asphaltenes, etc. inside the pipe. Run on wireline."@en ,
                                  "[SLB Glossary] Also called a pig, a device with blades or brushes inserted in a pipeline for cleaning purposes."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Scraper(x) ↔ (MaterialArtifact(x) ∧ ∃f(ScrapingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A scraper is a material artifact that bears a scraping function for mechanically removing deposits, debris, or contaminants from surfaces."@en ,
                                                       "Um raspador é um artefato material que possui uma função de raspagem para remover mecanicamente depósitos, detritos ou contaminantes de superfícies."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every scraper is a material artifact that has a scraping function, and every material artifact that has a scraping function is a scraper."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000345
copi:COPI_0000345 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000158
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:LiquidInlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000195
                                  ] ;
                  rdfs:label "lavador de gases"@pt-br ,
                             "scrubber"@en ;
                  skos:definition "[CFIHOS] A distillation column intended to clean gas by washing the gas flow with water or with another liquid entering at the top of the vessel and sprayed in the gas. Typically to remove dust and small particles."@en ,
                                  "[ISO 15926-4] A <SCRUBBER> is an <ARTEFACT> and a <SEPARATOR> intended to clean gas by washing the gas flow with water or with another liquid entering at the top of the vessel and sprayed in the gas. Typically to remove dust and small particles"@en ,
                                  "[OnePetro] A reactor that removes various components from produced gas."@en ,
                                  "[POSC Caesar] A distillation column intended to clean gas by washing the gas flow with water or with another liquid entering at the top of the vessel and sprayed in the gas. Typically to remove dust and small particles."@en ,
                                  "[SLB Glossary] A device to remove dirt, water, foreign matter, or undesired liquids that are part of the gas flowstream."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Scrubber(x) ↔ Separator(x) ∧ ∃f,p,g,l (SeparationFunction(f) ∧ bearerOf(x,f) ∧ LiquidWashingProcess(p) ∧ participatesIn(x,p) ∧ GasPortion(g) ∧ LiquidPortion(l) ∧ hasInput(x,g) ∧ hasInput(x,l)))"@en ;
                  annotation:naturalLanguageDefinition "A scrubber is a separator that cleans gas by washing the gas flow with liquid to remove contaminants such as dust, particles, or undesired substances."@en ,
                                                       "Um lavador de gases é um separador que limpa gás através da lavagem do fluxo gasoso com líquido para remover contaminantes como poeira, partículas ou substâncias indesejadas."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every scrubber is a separator that has the function of separation and participates in liquid washing processes with both gas and liquid inputs."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000346
copi:COPI_0000346 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000257 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ShaftKey
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ShaftSeal
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ShaftSleeve
                                  ] ;
                  rdfs:label "eixo"@pt-br ,
                             "shaft"@en ;
                  skos:definition "[ISO 15926-4] A <SHAFT> is an <ENGINE COMPONENT> that is the core rotating element on which the rotating parts are mounted and through which energy is either transmitted from the prime mover or generated in case of a driver."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Shaft(x) → Assembly(x) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃k(ShaftKey(k) ∧ hasComponentPartAtAllTimes(x,k)) ∧ ∃s(ShaftSeal(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃l(ShaftSleeve(l) ∧ hasComponentPartAtAllTimes(x,l)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An Assembly that bears a PowerTransmissionFunction and that has component parts including shaft keys for torque transmission and shaft seals for leakage prevention, serving as the core rotating element in rotating machinery."@en ,
                                                       "Um Assembly que porta uma PowerTransmissionFunction e que possui partes componentes incluindo chavetas de eixo para transmissão de torque e vedações de eixo para prevenção de vazamento, servindo como o elemento rotativo central em máquinas rotativas."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on physical structure. Under OWA, sufficient conditions for shaft identity could lead to false positives - any assembly with a shaft key and rotational motion might be classified as a shaft rather than a more specific equipment type that contains a shaft. The structural differentia provides necessary conditions while allowing domain experts to validate sufficiency."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every shaft is an assembly that transmits power through rotation and has shaft keys, shaft seals, and shaft sleeves as essential components."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000347
copi:COPI_0000347 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ShakingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:VibrationMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ShakingFunction
                                  ] ;
                  rdfs:label "agitador"@pt-br ,
                             "shaker"@en ;
                  skos:definition "[ISO 15926-4] A <SHAKER> is a <FunctionalObject> that has the capability of <SHAKING>"@en ,
                                  "[OnePetro] A piece of drilling equipment, usually with a vibrating screen, where drill cuttings are removed from the flowing mud."@en ,
                                  "[SLB Glossary] Abbreviation for shale shaker, the primary and probably most important device on the rig for removing drilled solids from the mud."@en ;
                  annotation:firstOrderLogicAxiom "Shaker(x) ↔ Assembly(x) ∧ ∃f(ShakingFunction(f) ∧ bearerOf(x,f))"@en ;
                  annotation:naturalLanguageDefinition "A shaker is an assembly that bears a shaking function, capable of producing vibrating or oscillating motion for material processing, agitation, or separation."@en ,
                                                       "Um agitador é um conjunto que possui uma função de agitação, capaz de produzir movimento vibratório ou oscilatório para processamento, agitação ou separação de materiais."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every shaker is an assembly that has the capability of shaking and contains a vibration mechanism and a shaking element."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000348
copi:COPI_0000348 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RamBody
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ShearingBlade
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PipeShearingFunction
                                  ] ;
                  rdfs:label "aríete de corte"@pt-br ,
                             "shear ram"@en ;
                  skos:definition "[CFIHOS] A shear valve is a ram-type BOP, similar in operation to a gate valve, but uses a pair of opposing steel plungers, rams. The rams extend toward the centre of the wellbore to restrict flow or retract open in order to permit flow."@en ,
                                  "[ISO 15926-4] A <SHEAR RAM> is an <ARTEFACT> and a <RAM> that is a closure mechanism on a wells blowout-preventer stack fitted with chisel-like jaws that are hydraulically operated. When the ram is closed on the pipe, the jaws or blades cut the pipe, permitting the upper section to be removed from the BOP stack"@en ,
                                  "[OnePetro] A ram in the BOP that shears off the pipe."@en ,
                                  "[SLB Glossary] A blowout preventer (BOP) closing element fitted with hardened tool steel blades designed to cut the drillpipe or tubing when the BOP is closed, and then fully close to provide isolation or sealing of the wellbore."@en ;
                  annotation:firstOrderLogicAxiom "∀x(ShearRam(x) ↔ Ram(x) ∧ ∃f(PipeShearingFunction(f) ∧ bearerOf(x,f)) ∧ ∃b(ShearingBlade(b) ∧ hasComponentPartAtAllTimes(x,b)))"@en ;
                  annotation:naturalLanguageDefinition "A shear ram is a ram that bears a pipe shearing function and has hardened cutting blades designed to cut drillpipe or tubing during blowout prevention operations."@en ,
                                                       "Um aríete de corte é um aríete que possui função de corte de tubulação e tem lâminas de corte endurecidas projetadas para cortar a coluna de perfuração ou tubulação durante operações de prevenção de blowout."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every shear ram is a ram that has the function to shear pipe and has shearing blades as component parts at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000349
copi:COPI_0000349 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GroovedRim
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Hub
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000192
                                  ] ;
                  rdfs:label "polia"@pt-br ,
                             "sheave"@en ;
                  skos:definition "[CFIHOS] A wheel which is grooved for use with vee-belts, ropes, round belts, wire or pipe."@en ,
                                  "[ISO 15926-4] A <SHEAVE> is an <ARTEFACT> and a <WHEEL> which is grooved for use with vee-belts, ropes, round belts, wire or pipe"@en ,
                                  "[OnePetro] A grooved pulley."@en ,
                                  "[SLB Glossary] In oilfield usage, the term usually refers to either the pulleys permanently mounted on the top of the rig (the crown blocks), or the pulleys used for running wireline tools into the wellbore."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Sheave(x) → MaterialArtifact(x) ∧ ∃y(GroovedRim(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃f(PowerTransmissionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A sheave is a material artifact that is a grooved wheel designed to transmit mechanical power through interface with belts, ropes, wires, or pipes."@en ,
                                                       "Uma polia é um artefato material que é uma roda sulcada projetada para transmitir energia mecânica através da interface com correias, cordas, cabos ou tubos."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on physical structure. Under OWA, defining sufficient conditions based solely on having a grooved rim could lead to false positives where other grooved mechanical elements (like timing belt pulleys with different design intents) are automatically classified as sheaves. The structural differentia provides necessary conditions while allowing domain experts to confirm sufficient conditions."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every sheave is a material artifact that has a grooved rim as component part and bears a power transmission function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000350
copi:COPI_0000350 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AcousticTreatmentElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:InletConnection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OutletConnection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SilencerHousing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:NoiseSilencingFunction
                                  ] ;
                  rdfs:label "silencer"@en ,
                             "silenciador"@pt-br ;
                  skos:definition "[CFIHOS] A physical object intended to reduce a noise level."@en ,
                                  "[ISO 15926-4] A <SILENCER> is a <FunctionalObject> that has a capability of <SILENCING>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Silencer(x) ↔ Assembly(x) ∧ ∃f(NoiseSilencingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A silencer is an assembly that bears the designed function of reducing noise levels through acoustic treatment of fluid streams."@en ,
                                                       "Um silenciador é uma montagem que possui a função projetada de reduzir níveis de ruído através do tratamento acústico de fluxos de fluidos."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every silencer is an assembly that has the function to silence noise, and every assembly that has the function to silence noise is a silencer."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000351
copi:COPI_0000351 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ConicalBottom
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SiloWall
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:SolidBulkStorageFunction
                                  ] ;
                  rdfs:label "silo"@en ,
                             "silo"@pt-br ;
                  skos:definition "[CFIHOS] A vessel that has a bottom in the shape of a cone and is intended to store solid particles."@en ,
                                  "[DEXPI] A with a conical shape that is intended to store solids in bulk (from ``_)."@en ,
                                  "[ISO 15926-4] A <SILO> is a <CONTAINER> with a conical shape that is intended to store solids in bulk"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Silo(x) ↔ (Vessel(x) ∧ ∃f(SolidBulkStorageFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(ConicalBottom(c) ∧ hasComponentPartAtAllTimes(x,c))))"@en ;
                  annotation:naturalLanguageDefinition "A silo is a vessel that bears a solid bulk storage function and has a conical bottom section for facilitating the storage and discharge of bulk solid materials."@en ,
                                                       "Um silo é um vaso que possui uma função de armazenamento de sólidos a granel e tem uma seção inferior cônica para facilitar o armazenamento e descarga de materiais sólidos a granel."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every silo is a vessel that has the function of storing bulk solids and has a conical bottom component."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000352
copi:COPI_0000352 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:MountingPoint
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SupportFrame
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EquipmentSupportFunction
                                  ] ;
                  rdfs:label "skid"@en ,
                             "skid"@pt-br ;
                  skos:definition "[ISO 15926-4] A <SKID> is an <ARTEFACT> and a <SUPPORT> intended to support items when being manufactured, transported, handled or installed"@en ,
                                  "[OnePetro] Move a well to a close-by locations with minimum rig down of equipment."@en ,
                                  "[POSC Caesar] A 'support' intended to support items when being manufactured, transported, handled or installed."@en ,
                                  "[SLB Glossary] A steel frame on which portable equipment is mounted to facilitate handling with cranes or flatbed trucks."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Skid(x) ↔ (Assembly(x) ∧ ∃f(EquipmentSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SupportFrame(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(MountingPoint(m) ∧ hasComponentPartAtAllTimes(x,m))))"@en ;
                  annotation:naturalLanguageDefinition "A skid is an assembly that bears an equipment support function, consisting of a support frame and mounting points, designed to support equipment items during manufacturing, transportation, handling, and installation."@en ,
                                                       "Um skid é uma montagem que possui uma função de suporte de equipamento, consistindo de uma estrutura de suporte e pontos de montagem, projetada para suportar itens de equipamento durante fabricação, transporte, manuseio e instalação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every skid is an assembly that bears an equipment support function and has a support frame and mounting points as component parts at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000353
copi:COPI_0000353 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000260 ;
                  rdfs:label "atuador solenoide"@pt-br ,
                             "solenoid actuator"@en ;
                  skos:definition "[ISO 15926-4] A <SOLENOID ACTUATOR> is an <ELECTRIC ACTUATOR> and an <ELECTRIC TO MECHANICAL ENERGY CONVERTER> and an <ELECTROMECHANICAL DEVICE>  that is utilizing a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action"@en ;
                  annotation:firstOrderLogicAxiom "∀x(SolenoidActuator(x) → ElectricActuator(x) ∧ ∃s(Solenoid(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃p(Plunger(p) ∧ hasComponentPartAtAllTimes(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A solenoid actuator is an electric actuator that utilizes a continuous duty linear solenoid to convert electrical energy into mechanical power via a plunger with an axial stroke in either a push or pull action."@en ,
                                                       "Um atuador solenoide é um atuador elétrico que utiliza um solenoide linear de serviço contínuo para converter energia elétrica em energia mecânica através de um êmbolo com curso axial em ação de empurrar ou puxar."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by solenoid mechanism. Under OWA, sufficient conditions would force any device with solenoid and plunger components to be classified as a solenoid actuator, potentially misclassifying complex hybrid devices or specialized equipment containing solenoid components but serving different primary functions."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every solenoid actuator is an electric actuator that has a solenoid as component part and has a plunger as component part and converts electrical power to linear mechanical motion."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000354
copi:COPI_0000354 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:SpacingFunction
                                  ] ;
                  rdfs:label "espaçador"@pt-br ,
                             "spacer"@en ;
                  skos:definition "[CFIHOS] A physical object that is intended to keep other physical objects at a predefined distance and hence having a spacer function."@en ,
                                  "[ISO 15926-4] A <SPACER> is a <FunctionalObject> that has the capability of <SPACING>"@en ,
                                  "[OnePetro] In the context of pumping, a spacer is a fluid used between two fluids to prevent contamination."@en ,
                                  "[SLB Glossary] A viscous fluid used to aid removal of drilling fluids before a primary cementing operation."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Spacer(x) ↔ MaterialArtifact(x) ∧ ∃f(SpacingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A spacer is a material artifact that has the function of maintaining spatial separation or distance between physical objects or fluids."@en ,
                                                       "Um espaçador é um artefato material que tem a função de manter separação espacial ou distância entre objetos físicos ou fluidos."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every spacer is a material artifact that bears a spacing function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000355
copi:COPI_0000355 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtSomeTime> ;
                                    owl:someValuesFrom copi:StatorWinding
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:StationaryMachineComponentFunction
                                  ] ;
                  rdfs:label "MaterialArtifact que possui uma StationaryMachineComponentFunction e"@pt-br ,
                             "stator"@en ;
                  skos:definition "[ISO 15926-4] A <STATOR> is a <MACHINE COMPONENT> that is the arrangement of primary coils being the stator winding and being the stationary part of a machine"@en ,
                                  "[OnePetro] In the context of a PDM motor, a stator is the stationary rubber element of a PDM motor."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Stator(x) → MaterialArtifact(x) ∧ ∃f(StationaryMachineComponentFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(RotatingMachine(m) ∧ partOf(x,m)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that bears a StationaryMachineComponentFunction and that is the stationary structural component within rotating machinery, providing housing and positional stability for active elements such as windings, vanes, or seals."@en ,
                                                       "Um MaterialArtifact que possui uma StationaryMachineComponentFunction e que é o componente estrutural estacionário dentro de máquinas rotativas, fornecendo alojamento e estabilidade posicional para elementos ativos como bobinas, palhetas ou vedações."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on structural positioning within rotating machinery. Under OWA, any artifact described as stationary within a rotating machine context could be classified as a stator, but this may include specialized hybrid components, mounting structures, or custom configurations that should not be automatically asserted into the standard stator maintenance category. The structural differentia (stationary positioning) is necessary but making it sufficient requires domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every Stator is a MaterialArtifact that bears a StationaryMachineComponentFunction and is part of some RotatingMachine"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000356
copi:COPI_0000356 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000262 ;
                  rdfs:label "contato de chave"@pt-br ,
                             "switch contact"@en ;
                  skos:definition "[ISO 15926-4] A <SWITCH CONTACT> is an <ELECTRICAL CONTACT> that is one of the conductive parts forming a contact."@en ;
                  annotation:firstOrderLogicAxiom "∀x (SwitchContact(x) → ElectricalContact(x) ∧ ∃y(ElectricalContact(y) ∧ partOf(x,y)) ∧ ∃f(ElectricalConductionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A switch contact is an electrical contact that is one of the conductive parts forming a contact assembly."@en ,
                                                       "Um contato de chave é um contato elétrico que é uma das partes condutoras que formam um conjunto de contato."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on structural role as a conductive part. Under OWA, asserting sufficient conditions could incorrectly classify any conductive part of an electrical contact as a switch contact, when there may be other specialized conductive components (bus bars, terminals, etc.) that serve different structural roles."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every switch contact is an electrical contact that is part of an electrical contact assembly and bears an electrical conduction function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000357
copi:COPI_0000357 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ControlIndicator
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricalSwitch
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Panel
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ElectricalCircuitControlFunction
                                  ] ;
                  rdfs:label "quadro de distribuição"@pt-br ,
                             "switchboard"@en ;
                  skos:definition "[CFIHOS] A switchgear and controlgear bearing a set of switches for connecting and disconnecting the various circuits of an electrical system, as of a telegraph, telephone, etc."@en ,
                                  "[ISO 15926-4] A <SWITCHBOARD> is an <ARTEFACT> and a <SWITCHING DEVICE>that is one or more panels accommodating control switches, indicators, and other apparatus for operating electric circuits"@en ,
                                  "[POSC Caesar] A switchgear and controlgear bearing a set of switches for connecting and disconnecting the various circuits of an electrical system, as of a telegraph, telephone, etc."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Switchboard(x) ↔ ElectricalEquipment(x) ∧ ∃p,s,i(Panel(p) ∧ ElectricalSwitch(s) ∧ ControlIndicator(i) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃f(ElectricalCircuitControlFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A switchboard is electrical equipment that consists of panels accommodating switches, indicators, and control apparatus for connecting, disconnecting, and controlling various circuits of an electrical system."@en ,
                                                       "Um quadro de distribuição é um equipamento elétrico que consiste em painéis que acomodam chaves, indicadores e aparatos de controle para conectar, desconectar e controlar vários circuitos de um sistema elétrico."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every switchboard is electrical equipment that has component parts (panels, switches, indicators) and bears the function to control electrical circuits"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000358
copi:COPI_0000358 rdf:type owl:Class ;
                  rdfs:subClassOf copi:TemperatureElement ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TemperatureSensingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:TemperatureMeasurementFunction
                                  ] ;
                  rdfs:label "elemento de medição de temperatura"@pt-br ,
                             "temperature measuring element"@en ;
                  skos:definition "[ISO 15926-4] A <TEMPERATURE MEASURING ELEMENT> is a <MEASURING ELEMENT> for the measurement of <TEMPERATURE>"@en ;
                  annotation:firstOrderLogicAxiom "∀x(TemperatureMeasuringElement(x) ↔ MeasuringElement(x) ∧ ∃f(TemperatureMeasurementFunction(f) ∧ hasFunction(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A temperature measuring element is a measuring element that has the function to measure temperature."@en ,
                                                       "Um elemento de medição de temperatura é um elemento de medição que tem a função de medir temperatura."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every temperature measuring element is a measuring element that has a temperature measurement function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000359
copi:COPI_0000359 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000201
                                  ] ;
                  rdfs:label "termowell stem"@pt-br ,
                             "thermowell stem"@en ;
                  skos:definition "[ISO 15926-4] A <THERMOWELL STEM> is an <INSTRUMENTATION ITEM> and a <Feature> and an <ENCLOSURE> that is the hollow cylindrical part of a thermowell that is housing the thermocouple or thermoelement and is protruding into the process medium"@en ;
                  annotation:firstOrderLogicAxiom "∀x(ThermowellStem(x) → FiatObjectPart(x) ∧ ∃y(Thermowell(y) ∧ partOf(x,y)) ∧ ∃q(HollowCylindricalShape(q) ∧ hasQuality(x,q)) ∧ ∃l(ProcessMediumIntrusionZone(l) ∧ hasLocation(x,l)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A thermowell stem is a fiat object part that is part of a thermowell and that has a hollow cylindrical shape positioned to protrude into the process medium, providing protective housing for temperature sensing elements while enabling thermal conduction."@en ,
                                                       "Um termowell stem é uma parte de objeto fiducial que é parte de um termowell e que tem uma forma cilíndrica oca posicionada para se projetar no meio do processo, fornecendo habitação protetora para elementos de detecção de temperatura enquanto permite condução térmica."@pt-br ;
                  annotation:primitiveRationale "Constructive classification basis. The structural differentia (hollow cylindrical shape, positioning in process medium) is necessary but may not be sufficient under OWA - there could be other specialized parts of thermowells with similar geometry but different specific roles or configurations."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every thermowell stem is a fiat object part that is part of some thermowell and has hollow cylindrical shape and is located in process medium intrusion zone."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000360
copi:COPI_0000360 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:StructuralSupportFunction
                                  ] ;
                  rdfs:label "Placa que possui geometria de espessura fina e"@pt-br ,
                             "thin plate"@en ;
                  skos:definition "[ISO 15926-4] A <THIN PLATE> is a <PLATE> that is a thin steel plate format (Sheet plate) Normally made by coldforming"@en ;
                  annotation:firstOrderLogicAxiom "∀x(ThinPlate(x) → Plate(x) ∧ ∃q1(ThinThickness(q1) ∧ hasQuality(x,q1)) ∧ ∃q2(ColdFormedManufacturing(q2) ∧ hasQuality(x,q2)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A Plate that has thin thickness geometry and is manufactured through cold forming processes, typically used for structural support applications requiring reduced weight or specific geometric constraints."@en ,
                                                       "Uma Placa que possui geometria de espessura fina e é fabricada através de processos de conformação a frio, tipicamente usada para aplicações de suporte estrutural que requerem peso reduzido ou restrições geométricas específicas."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by physical geometry (thinness) and manufacturing method (cold forming). Under OWA, sufficient conditions for thin plates are difficult to specify without risking false positives from specialized hybrid structures that contain thin cold-formed elements but should not be classified as standard thin plates."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "ThinPlate ⊑ Plate ⊓ ∃hasQuality.ThinThickness ⊓ ∃hasQuality.ColdFormedManufacturing"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000361
copi:COPI_0000361 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:GasOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:OilOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SeparationChamber
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:WaterOutlet
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ThreePhaseSeparationFunction
                                  ] ;
                  rdfs:label "separador trifásico"@pt-br ,
                             "three phase separator"@en ;
                  skos:definition "[ISO 15926-4] A <THREE-PHASE SEPARATOR> is an <ARTEFACT> and a <FLUID SEPARATOR> intended to separate three fluids in different phases, typically gas and liquid and water"@en ,
                                  "[POSC Caesar] A separator intended to separate three fluids in different phases, typically gas and liquid and water"@en ,
                                  "[SLB Glossary] A vessel that separates the well fluids into gas and two types of liquids: oil and water."@en ;
                  annotation:firstOrderLogicAxiom "∀x (ThreePhaseSeparator(x) ↔ (Separator(x) ∧ ∃f (ThreePhaseSeparationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A three-phase separator is a separator that bears a three-phase separation function to separate well fluids into gas, oil, and water phases."@en ,
                                                       "Um separador trifásico é um separador que possui uma função de separação trifásica para separar fluidos de poço em fases gasosa, oleosa e aquosa."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every three-phase separator is a separator that has the function of separating fluid into gas, oil, and water phases, and has gas outlet, oil outlet, and water outlet as component parts."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000362
copi:COPI_0000362 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ConversionElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SensingElement
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:TransductionFunction
                                  ] ;
                  rdfs:label "transducer"@en ,
                             "transdutor"@pt-br ;
                  skos:definition "[ISO 15926-4] A <TRANSDUCER> is an <ENERGY CONVERTER> that is capable of converting a <PROCESS VARIABLE> in one form or magnitude of energy to another form or magnitude of the same energy"@en ,
                                  "[POSC Caesar] An artefact that accepts information in the form of a physical or chemical variable (its input variable) and converts it into an output variable of the same or another nature, according to a definite law."@en ,
                                  "[isa5_1] a general term for a device, which can be a primary element, transmitter, relay, converter or other device, that receives information in the form of one or more physical quantities, modifies the information or its form, or both if required, and produces a resultant output signal."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Transducer(x) ↔ Instrument(x) ∧ ∃f (TransductionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A transducer is an instrument that bears a TransductionFunction to convert information from one form or magnitude of energy to another form or magnitude."@en ,
                                                       "Um transdutor é um instrumento que possui uma FunçãoDeTransdução para converter informação de uma forma ou magnitude de energia para outra forma ou magnitude."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every transducer is an instrument that has the designed function to convert energy or signal forms while preserving information content."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000363
copi:COPI_0000363 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnclosureFunction
                                  ] ;
                  rdfs:label "invólucro de transmissor"@pt-br ,
                             "transmitter housing"@en ;
                  skos:definition "[ISO 15926-4] A <TRANSMITTER HOUSING> is an <INSTRUMENT HOUSING> of a transmitter."@en ;
                  annotation:firstOrderLogicAxiom "∀x(TransmitterHousing(x) → Assembly(x) ∧ ∃f(EnclosureFunction(f) ∧ bearerOf(x,f)) ∧ ∃c(TransmitterElectronicCircuit(c) ∧ hasComponentPartAtAllTimes(x,c)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A transmitter housing is an Assembly that bears an EnclosureFunction and that has a transmitter electronic circuit as a component part at all times, designed to provide environmental protection and physical containment for transmitter components."@en ,
                                                       "Um invólucro de transmissor é uma Assembly que possui uma EnclosureFunction e que tem um circuito eletrônico de transmissor como parte componente em todos os momentos, projetado para fornecer proteção ambiental e contenção física para componentes do transmissor."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on physical structure as housing. Under OWA, sufficient conditions for transmitter housing would require specifying exact structural features (materials, dimensions, sealing mechanisms) that distinguish it from other instrument housings. The necessary conditions establish the core identity without risking false positives from other housing types that might share some structural features."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "TransmitterHousing ⊑ Assembly ⊓ ∃bearerOf.EnclosureFunction ⊓ ∃hasComponentPartAtAllTimes.TransmitterElectronicCircuit"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000364
copi:COPI_0000364 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SealingSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:SupportMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TubingConnection
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:TubingSupportFunction
                                  ] ;
                  rdfs:label "suporte de coluna de produção"@pt-br ,
                             "tubing hanger"@en ;
                  skos:definition "[CFIHOS] A well string hanger that is used for production tubing. The tubing hanger incorporates a sealing system to ensure that the tubing conduit and annulus are hydraulically isolated."@en ,
                                  "[ISO 15926-4] A <TUBING HANGER> is a <WELL STRING HANGER> that is installed on top of the tubing string and supports the string when landed in the tubing hanger or tubing head."@en ,
                                  "[OnePetro] A slip set or donut that suspends and holds the top of the tubing in the wellhead."@en ,
                                  "[SLB Glossary] A device attached to the topmost tubing joint in the wellhead to support the tubing string."@en ;
                  annotation:firstOrderLogicAxiom "∀x(TubingHanger(x) ↔ (Assembly(x) ∧ ∃f(TubingSupportFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SealingSystem(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃m(SupportMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(TubingConnection(c) ∧ hasComponentPartAtAllTimes(x,c))))"@en ;
                  annotation:naturalLanguageDefinition "A tubing hanger is an assembly that supports tubing strings in wellheads with integrated sealing to isolate tubing conduit from annulus."@en ,
                                                       "Um suporte de coluna de produção é um conjunto que suporta colunas de produção em cabeças de poço com vedação integrada para isolar o conduto da coluna do anular."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every tubing hanger is an assembly that bears a tubing support function and has component parts including a sealing system, support mechanism, and tubing connection."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000365
copi:COPI_0000365 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ChristmasTreeConnectionInterface
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TubingBowl
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TubingHangerSupportStructure
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:TubingSupportAndConnectionFunction
                                  ] ;
                  rdfs:label "cabeça de coluna"@pt-br ,
                             "tubing head"@en ;
                  skos:definition "[ISO 15926-4] A <TUBING HEAD> is a <DRILLING COMPONENT> that is fixed to the top of the tubing set in a well."@en ,
                                  "[OnePetro] A flanged spool containing the tubing bowl where the tubing hanger will set and seal."@en ,
                                  "[SLB Glossary] A wellhead component that supports the tubing hanger and provides a means of attaching the Christmas tree to the wellhead."@en ;
                  annotation:firstOrderLogicAxiom "∀x(TubingHead(x) ↔ WellheadComponent(x) ∧ ∃f(TubingSupportAndConnectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p1(TubingBowl(p1) ∧ hasComponentPartAtAllTimes(x,p1)) ∧ ∃p2(ChristmasTreeConnectionInterface(p2) ∧ hasComponentPartAtAllTimes(x,p2)))"@en ;
                  annotation:naturalLanguageDefinition "A tubing head is a wellhead component that supports the tubing hanger and provides a connection interface for attaching the Christmas tree to the wellhead assembly."@en ,
                                                       "Uma cabeça de coluna é um componente de cabeça de poço que suporta o suspensor de coluna e fornece uma interface de conexão para fixar a árvore de natal ao conjunto de cabeça de poço."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every tubing head is a wellhead component that bears a tubing support and connection function, has a tubing bowl as component part, and has a Christmas tree connection interface as component part."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000366
copi:COPI_0000366 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BearingSystem
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:FluidInteractionBlades
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:RotatingShaft
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TurbineCasing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:EnergyExtractionFunction
                                  ] ;
                  rdfs:label "turbina"@pt-br ,
                             "turbine"@en ;
                  skos:definition "[CFIHOS] A physical object that is intended to rotate within a fluid and to transform energy within a fluid into mechanical power."@en ,
                                  "[DEXPI] An object that is a rotary mechanical device that extracts energy from a fluid flow and converts it into useful work (from ``_)."@en ,
                                  "[ISO 15926-4] A <TURBINE> is an <ARTEFACT> and a <DRIVER(function)> that is a rotary mechanical device that extracts energy from a fluid flow and converts it into useful work"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Turbine(x) ↔ Assembly(x) ∧ ∃f(EnergyExtractionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(RotatingShaft(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃b(FluidInteractionBlades(b) ∧ hasComponentPartAtAllTimes(x,b)))"@en ;
                  annotation:naturalLanguageDefinition "A turbine is an assembly that bears an energy extraction function and has rotating shaft and fluid-interacting blades that extract energy from flowing fluids and convert it into useful mechanical work."@en ,
                                                       "Uma turbina é um conjunto que possui uma função de extração de energia e tem eixo rotativo e pás de interação com fluidos que extraem energia de fluidos em movimento e a convertem em trabalho mecânico útil."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every turbine is an assembly that bears an energy extraction function and has component parts including a rotating shaft, fluid interaction blades, casing, and bearing system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000367
copi:COPI_0000367 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CableBundle
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ConnectorAssembly
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ProtectiveSheathing
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TubingBundle
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:MultiServiceTransmissionFunction
                                  ] ;
                  rdfs:label "umbilical"@en ,
                             "umbilical"@pt-br ;
                  skos:definition "[CFIHOS] An assembly of hydraulic hoses which can also include electrical cables or optic fibres, used to control a sub sea structure or remote operated vehicle from a platform or a vessel."@en ,
                                  "[ISO 15926-4] A <UMBILICAL> is a <DRILLING COMPONENT> that is a flexible and easily disconnectable collection of cables and/or tubing for control, power, communication or chemical injection purposes."@en ,
                                  "[OnePetro] A control line attached to a remove piece of equipment, usually a subsea wellhead, to provide hydraulic or electrical control, or inject small amounts of chemicals."@en ,
                                  "[POSC Caesar] A device which is a flexible and easily disconnectable collection of cables and/or tubing for control, power, communication or chemical injection purposes."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Umbilical(x) → Assembly(x) ∧ ∃c,t,s,conn (CableBundle(c) ∧ TubingBundle(t) ∧ ProtectiveSheathing(s) ∧ ConnectorAssembly(conn) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,t) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,conn) ∧ hasQuality(x,Flexibility) ∧ hasQuality(x,EasyDisconnectability)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An umbilical is an assembly that is a flexible and easily disconnectable bundle containing both cables and tubing for multi-service transmission including control, power, communication, and chemical injection."@en ,
                                                       "Um umbilical é uma montagem que é um feixe flexível e facilmente desconectável contendo cabos e tubulação para transmissão de múltiplos serviços incluindo controle, energia, comunicação e injeção química."@pt-br ;
                  annotation:primitiveRationale "Constructive basis requires necessary conditions only. Under OWA, any assembly with cables, tubing, flexibility, and disconnectability could be forcibly classified as umbilical, including specialized multi-service bundles, complex wiring harnesses, or custom transmission assemblies that contain these elements but serve different industrial contexts and maintenance categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every umbilical is an assembly that has component parts including cable bundles and tubing bundles, and has the qualities of flexibility and easy disconnectability."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000368
copi:COPI_0000368 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:AutomaticTransferMechanism
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BackupEnergyStorage
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PowerConditioningCircuit
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:UninterruptedPowerSupplyFunction
                                  ] ;
                  rdfs:label "unidade UPS"@pt-br ,
                             "ups unit"@en ;
                  skos:definition "[CFIHOS] An ac power supply unit that maintains a continuous supply of electric power to the equipment it protects."@en ,
                                  "[ISO 15926-4] An <UPS UNIT> is an <AC ELECTRIC POWER SUPPLY UNIT> that maintains a uninterrupted supply of electric power to the equipment it protects"@en ,
                                  "[POSC Caesar] An A.C. power supply unit that maintains a continuous supply of electric power to the equipment it protects."@en ;
                  annotation:firstOrderLogicAxiom "∀x(UPSUnit(x) ↔ ElectricalEquipment(x) ∧ ∃f(UninterruptedPowerSupplyFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A UPS unit is electrical equipment that bears the designed function of maintaining uninterrupted AC electric power supply to protected equipment during power disturbances."@en ,
                                                       "Uma unidade UPS é um equipamento elétrico que possui a função projetada de manter o fornecimento ininterrupto de energia elétrica AC para equipamentos protegidos durante distúrbios de energia."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every UPS unit is electrical equipment that has the function of maintaining uninterrupted AC electric power supply."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000369
copi:COPI_0000369 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000255 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ReinforcedColumnShell
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:VacuumSystem
                                  ] ;
                  rdfs:label "coluna de vácuo"@pt-br ,
                             "vacuum column"@en ;
                  skos:definition "[CFIHOS] A distillation column intended to withstand outside pressure."@en ,
                                  "[ISO 15926-4] A <VACUUM COLUMN> is an <ARTEFACT> and a <DISTILLATION COLUMN> intended to withstand outside pressure"@en ,
                                  "[POSC Caesar] A distillation column intended to withstand outside pressure"@en ;
                  annotation:firstOrderLogicAxiom "∀x(VacuumColumn(x) → DistillationColumn(x) ∧ ∃q(VacuumPressureResistanceQuality(q) ∧ bearerOf(x,q)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A vacuum column is a distillation column that is designed to withstand outside pressure during vacuum operation."@en ,
                                                       "Uma coluna de vácuo é uma coluna de destilação projetada para resistir à pressão externa durante operação sob vácuo."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on structural capability. Under OWA, defining sufficient conditions for vacuum-capable design would be complex and could lead to false positives. The structural differentia (vacuum resistance) requires domain expert validation of what constitutes adequate vacuum design capability."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every vacuum column is a distillation column that bears a vacuum pressure resistance quality."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000370
copi:COPI_0000370 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000026
                                  ] ;
                  rdfs:label "membro de fechamento de válvula"@pt-br ,
                             "valve closure member"@en ;
                  skos:definition "[ISO 15926-4] A <VALVE CLOSURE MEMBER> is a <CLOSURE> that is the part of a valve which is positioned in the flow stream to permit, obstruct, divert or regulate flow"@en ;
                  annotation:firstOrderLogicAxiom "∀x (ValveClosureMember(x) → MaterialArtifact(x) ∧ ∃v (Valve(v) ∧ isComponentPartOf(x,v)) ∧ ∃p (FlowControlProcess(p) ∧ participatesIn(x,p)) ∧ ∃q (PositionableInFlowStream(q) ∧ hasQuality(x,q)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that is a component part of a valve and that is positioned in the flow stream to permit, obstruct, divert or regulate flow through mechanical positioning."@en ,
                                                       "Um MaterialArtifact que é uma parte componente de uma válvula e que é posicionado no fluxo para permitir, obstruir, desviar ou regular o fluxo através de posicionamento mecânico."@pt-br ;
                  annotation:primitiveRationale "As a constructive type defined by physical configuration and mechanical role, the valve closure member should use necessary conditions. The structural differentia (being positioned in flow stream) is harder to make sufficient under OWA - other components or hybrid devices might satisfy the conditions but not be classified as standard valve closure members."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every valve closure member is a material artifact that is a component part of some valve and participates in flow control processes by being positioned within the flow stream."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000371
copi:COPI_0000371 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000026
                                  ] ;
                  rdfs:label "assento de válvula"@pt-br ,
                             "valve seat"@en ;
                  skos:definition "[ISO 15926-4] A <VALVE SEAT> is a <VALVE COMPONENT> that is the part of a valve against which the closure member bears to provide shut-off and throughput of process fluids flows"@en ;
                  annotation:firstOrderLogicAxiom "∀x (ValveSeat(x) → (MaterialArtifact(x) ∧ ∃y(Valve(y) ∧ partOf(x,y)) ∧ ∃z(ValveClosureMember(z) ∧ adjacentTo(x,z)) ∧ ∃q(SealingSurfaceQuality(q) ∧ bearerOf(x,q))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that is part of a valve and that provides the seating surface against which the closure member bears to achieve shut-off and control of process fluid flow."@en ,
                                                       "Um MaterialArtifact que é parte de uma válvula e que fornece a superfície de assentamento contra a qual o membro de fechamento se apoia para alcançar o fechamento e controle do fluxo de fluido de processo."@pt-br ;
                  annotation:primitiveRationale "Valve seat is a constructive type defined by its structural configuration and interface role. Under the Open World Assumption, making this an equivalence class could lead to false positives where any artifact that is part of a valve and adjacent to a closure member gets classified as a valve seat, even if it serves a different structural role (such as guides, stops, or supports)."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "ValveSeat ⊑ MaterialArtifact ⊓ ∃partOf.Valve ⊓ ∃adjacentTo.ValveClosureMember ⊓ ∃bearerOf.SealingSurfaceQuality"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000372
copi:COPI_0000372 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ValveStemSeal
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:ForceTransmissionFunction
                                  ] ;
                  rdfs:label "haste de válvula"@pt-br ,
                             "valve stem"@en ;
                  skos:definition "[ISO 15926-4] A <VALVE STEM> is a <VALVE COMPONENT> and a <TRANSMITTER(force)> that is a rod or shaft which is transmitting motion from an operator to the closure member of a valve"@en ;
                  annotation:firstOrderLogicAxiom "∀x(ValveStem(x) → Assembly(x) ∧ ∃f(ForceTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(ValveStemSeal(s) ∧ hasComponentPartAtAllTimes(x,s)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An Assembly that bears a ForceTransmissionFunction and that has a valve stem seal as a component part, specifically designed to transmit motion from a valve operator to the valve closure member."@en ,
                                                       "Um Assembly que porta uma ForceTransmissionFunction e que tem um selo de haste de válvula como parte componente, especificamente projetado para transmitir movimento de um operador de válvula para o membro de fechamento da válvula."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by physical structure (rod/shaft mechanism). Under Open World Assumption, sufficient conditions would force any assembly with a valve stem seal and force transmission function to be classified as a valve stem, which could include complex multi-component assemblies, manifolds, or specialized valve mechanisms that contain these elements but should not be asserted into the standard valve stem maintenance category."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "ValveStem SubClassOf Assembly and bearerOf some ForceTransmissionFunction and hasComponentPartAtAllTimes some ValveStemSeal"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000373
copi:COPI_0000373 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000022 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000025
                                  ] ;
                  rdfs:label "tampo de vaso"@pt-br ,
                             "vessel head"@en ;
                  skos:definition "[ISO 15926-4] A <VESSEL HEAD> is an <EQUIPMENT COMPONENT> that is intended to close a vessel shell."@en ;
                  annotation:firstOrderLogicAxiom "∀x(VesselHead(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃r(VesselClosureRole(r) ∧ realizes(x,r)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A FiatObjectPart that is part of a vessel and that closes a vessel shell by providing an end boundary for containment."@en ,
                                                       "Uma FiatObjectPart que é parte de um vaso e que fecha o casco do vaso fornecendo uma fronteira terminal para contenção."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on structural configuration. Under OWA, asserting sufficient conditions for vessel head closure would inappropriately classify any part that closes a vessel (including specialized manifolds, complex multi-port heads, or custom closures) as standard vessel heads, potentially creating false positives in maintenance categorization."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every vessel head is a fiat object part that is part of some vessel and realizes a vessel closure role."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000374
copi:COPI_0000374 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000022 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000025
                                  ] ;
                  rdfs:label "parte de objeto por fiat"@pt-br ,
                             "vessel shell"@en ;
                  skos:definition "[ISO 15926-4] A <VESSEL SHELL> is an <ARTEFACT> and a <SHELL(structure)> that is all or part of the pressure containing outer part of a vessel"@en ;
                  annotation:firstOrderLogicAxiom "∀x(VesselShell(x) → FiatObjectPart(x) ∧ ∃y(Vessel(y) ∧ partOf(x,y)) ∧ ∃f(PressureContainmentFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A fiat object part that is the outer pressure-containing structural boundary of a vessel, designed to enclose and isolate internal contents while withstanding internal pressure loads."@en ,
                                                       "Uma parte de objeto por fiat que é o limite estrutural externo de contenção de pressão de um vaso, projetada para encerrar e isolar o conteúdo interno enquanto suporta cargas de pressão interna."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by structural configuration as outer pressure-containing part of vessel. Under Open World Assumption, sufficient conditions are difficult to establish - other structural components might also be pressure-containing parts of vessels in specialized designs."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "VesselShell SubClassOf: FiatObjectPart and partOf some Vessel and bearerOf some PressureContainmentFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000375
copi:COPI_0000375 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000196> ;
                                    owl:someValuesFrom copi:SubsurfaceResourceInteractionFunction
                                  ] ;
                  rdfs:label "poço"@pt-br ,
                             "well"@en ;
                  skos:definition "[CFIHOS] A well is a collection of (zero or more) holes drilled into the Earth for the purpose of either (1) finding or producing underground resources; or (2) providing services related to the production of underground resources."@en ,
                                  "[ISO 15926-4] A <WELL> is a <FunctionalObject> that is arranged to obtain or produce from, or store or inject a material into, the earth"@en ,
                                  "[ppdm] A Well is a permitted or actual drilled hole in the ground designed to exchange (or facilitate the exchange of) fluids between a subsurface reservoir and the surface (or another reservoir), or to enable the detection and measurement of rock properties. Key concept: A physical Well is created each time the drill bit breaks the surface of the earth. Clarification: A Well is the parent of the Wellhead Stream(s), Well Origin, and all Well Components down hole from its Well Origin. A Well has a single Well Origin and all Wellbore(s) that extend from this Well Origin are parts of the Well. Re-entry through the same Well Origin for a Well that has not been plugged and abandoned does not create a new Well. A Well that has the same geographic coordinates as a previously existing plugged and abandoned, reclaimed or undrilled Well is a new Well. WB2-Cl2 Diagram Note: The Well depicted on page 3 groups multiple Well Components, including: one active Well WB2-C1 Origin (WO1), one inactive Wellbore (WB1), two active Wellbores (WB2, WB3), three inactive Wellbore Completions (WB1-C1, WB1-C2, WB1-C3) and three active Wellbore Completions (WB2-C1, WB3-C1, WB3-C2) and two active Wellbore Contact Intervals (WB2- CI1, WB2-CI2). ® Copyright 2014, PPDM Association. All Rights Reserved PAGE 4"@en ;
                  annotation:firstOrderLogicAxiom "∀x(Well(x) ↔ EngineeredSystem(x) ∧ ∃f(SubsurfaceResourceInteractionFunction(f) ∧ bearerOf(x,f)) ∧ ∃w(Wellbore(w) ∧ hasComponentPartAtSomeTime(x,w)))"@en ;
                  annotation:naturalLanguageDefinition "A well is an engineered system that interacts with subsurface resources through a drilled wellbore, designed to obtain, produce, store, or inject materials into or from the earth."@en ,
                                                       "Um poço é um sistema projetado que interage com recursos do subsolo através de um furo perfurado, projetado para obter, produzir, armazenar ou injetar materiais na terra ou a partir dela."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every well is an engineered system that bears a subsurface resource interaction function and has a wellbore as component part."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000376
copi:COPI_0000376 rdf:type owl:Class ;
                  rdfs:label "poço perfurado"@pt-br ,
                             "wellbore"@en ;
                  skos:definition "[OnePetro] In drilling, the drilled hole."@en ,
                                  "[SLB Glossary] The drilled hole or borehole, including the openhole or uncased portion of the well."@en ,
                                  "[ppdm] A Wellbore is a path of drilled footage, from the Well Origin (top/start) to a terminating point (bottom/end). Key concept: Wellbores do not need to be drilled in one continuous operation; they are defined as a path from the Well Origin to a terminating point. Clarification: There are one or more Wellbores in a planned or drilled Well, namely the original Wellbore, and a Wellbore for each intended, actual or accidental sidetrack. Each Wellbore has a unique terminating point. A deepening of an existing Wellbore is considered a new Wellbore with the same Well Origin. Note that in this case, the original terminating point will be located within the new Wellbore. Widening of an existing Wellbore does not constitute a new, separate Wellbore."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Wellbore(x) ↔ Site(x) ∧ ∃f(SubsurfaceAccessFunction(f) ∧ hasFunction(x,f)) ∧ ∃w(Well(w) ∧ spatiallyContainedIn(x,w)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A wellbore is a site that provides a drilled pathway for subsurface access and is spatially contained within a well system."@en ,
                                                       "Um poço perfurado é um local que fornece um caminho perfurado para acesso subsuperficial e está espacialmente contido dentro de um sistema de poço."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every wellbore is a site that has the function of providing subsurface access and is spatially contained within a well."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000377
copi:COPI_0000377 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:CasingHanger
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:PressureContainmentBody
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:WellheadSpool
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:WellSurfaceControlFunction
                                  ] ;
                  rdfs:label "cabeçal de poço"@pt-br ,
                             "wellhead"@en ;
                  skos:definition "[CFIHOS] The wellhead is assembled from, or incorporates facilities for, the upper casing and tubing hangers. This effectively provides the upper termination of the wellbore and provides a mounting position for the surface flow-control equipment or Christmas tree."@en ,
                                  "[ISO 15926-4] A <WELLHEAD> is an <ARTEFACT> that is the top of the casing of a production oil well including the attached control and flow valves"@en ,
                                  "[OnePetro] The mechanical connection between the tree and the casing. May house tubular hangers, annular access valves. It is connected to the casing by welding, threads, hydraulic forming or set screws."@en ,
                                  "[SLB Glossary] The system of spools, valves and assorted adapters that provide pressure control of a production well."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Wellhead(x) ↔ Assembly(x) ∧ ∃f(WellSurfaceControlFunction(f) ∧ bearerOf(x,f)) ∧ ∃h(CasingHanger(h) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃w(Wellbore(w) ∧ hasConnectionTo(x,w)))"@en ;
                  annotation:naturalLanguageDefinition "A wellhead is an assembly that bears a well surface control function and provides the structural and control interface between a wellbore and surface equipment."@en ,
                                                       "Um cabeçal de poço é um conjunto que porta uma função de controle superficial do poço e fornece a interface estrutural e de controle entre um poço e os equipamentos de superfície."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every wellhead is an assembly that bears a well surface control function and has component parts including casing hangers and connection to wellbore"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000378
copi:COPI_0000378 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:BraidedConductor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:ElectricalConductor
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:WirelineLoggingFunction
                                  ] ;
                  rdfs:label "wireline"@en ,
                             "wireline"@pt-br ;
                  skos:definition "[ISO 15926-4] A <WIRELINE> is an <ELECTRICAL CABLE> used to lower tools into and transmit data about the conditions of the wellbore called wireline logs. Usually consisting of braided cables, wirelines are used to perform wireline logging, as well."@en ,
                                  "[OnePetro] Related to any aspect of logging that employs an electrical cable to lower tools into the borehole and to transmit data. Wireline logging is distinct from measurements-while-drilling (MWD) and mud logging."@en ,
                                  "[SLB Glossary] schlumberger wireline, well logging, well intervention, slickline, formation evaluation"@en ;
                  annotation:firstOrderLogicAxiom "∀x (Wireline(x) ↔ ElectricalCable(x) ∧ ∃f (WirelineLoggingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A wireline is an electrical cable that bears a wireline logging function for lowering tools into wellbores and transmitting data about wellbore conditions."@en ,
                                                       "Um wireline é um cabo elétrico que possui uma função de perfilagem wireline para descer ferramentas em poços e transmitir dados sobre as condições do poço."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every wireline is an electrical cable that has the function to lower tools into wellbores and transmit logging data signals to the surface."@en .


