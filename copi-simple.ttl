                                             owl:someValuesFrom copi:FlowSwitchingProcess
                                           ] ,
                                           [ rdf:type owl:Restriction ;
                                             owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                             owl:allValuesFrom copi:FlowSwitchingProcess
                                           ] ;
                           rdfs:label "flow switching function"@en ,
                                      "função de chaveamento de fluxo"@pt-br ;
                           skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the generation of a discrete switching signal when the flow rate of a process stream crosses a defined threshold."@en .


