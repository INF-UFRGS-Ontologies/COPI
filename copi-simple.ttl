                                                                 owl:allValuesFrom copi:PressureIndicatingAndTransmissionProcess
                                                               ] ;
                                               rdfs:label "função de indicação e transmissão de pressão"@pt-br ,
                                                          "pressure indicating and transmission function"@en ;
                                               skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the measurement of process pressure and both its local display and the transmission of the corresponding signal to a remote monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureIndicatingAndTransmissionProcess
copi:PressureIndicatingAndTransmissionProcess rdf:type owl:Class ;
                                              rdfs:label "pressure indicating and transmission process"@en ,
                                                         "processo de indicação e transmissão de pressão"@pt-br ;
                                              skos:definition "A planned process in which process pressure is measured and both displayed locally and transmitted as a standardised signal to a remote monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureMeasurementProcess
copi:PressureMeasurementProcess rdf:type owl:Class ;
                                rdfs:label "pressure measurement process"@en ,
                                           "processo de medição de pressão"@pt-br ;
                                skos:definition "A planned process in which the absolute or gauge pressure of a process stream is measured and expressed as a quantitative value."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureReading
copi:PressureReading rdf:type owl:Class ;
                     rdfs:label "leitura de pressão"@pt-br ,
                                "pressure reading"@en ;
                     skos:definition "A measurement information content entity constituting a quantitative value representing the pressure of a process stream as measured and displayed by petroleum production instrumentation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureReductionProcess
copi:PressureReductionProcess rdf:type owl:Class ;
                              rdfs:label "pressure reduction process"@en ,
                                         "processo de redução de pressão"@pt-br ;
                              skos:definition "A planned process in which the pressure of a fluid is reduced from a higher upstream value to a controlled lower downstream value."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureReliefProcess
copi:PressureReliefProcess rdf:type owl:Class ;
                           rdfs:label "pressure relief process"@en ,
                                      "processo de alívio de pressão"@pt-br ;
                           skos:definition "A planned process in which a flow path is automatically opened to discharge fluid when process pressure exceeds a defined set point, protecting equipment from overpressure."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureReliefValve
copi:PressureReliefValve rdf:type owl:Class ;
                         rdfs:label "pressure relief valve"@en ,
                                    "válvula de pressão de alívio"@pt-br ;
                         skos:definition "A material artifact that constitutes a self-actuating safety valve that opens at a defined set pressure to discharge fluid and protect equipment from overpressure."@en ;
                         skos:exactMatch copi:COPI_0000145 .


