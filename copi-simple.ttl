copi:StorageProcess rdf:type owl:Class ;
                    rdfs:label "processo de armazenamento"@pt-br ,
                               "storage process"@en ;
                    skos:definition "A planned process in which a fluid or material is held within a contained space for a defined period before further processing or distribution."@en .


