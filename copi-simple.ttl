                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                        owl:allValuesFrom copi:ConductivityTransmissionProcess
                                                      ] ;
                                      rdfs:label "conductivity transmission function"@en ,
                                                 "função de transmissão de condutividade"@pt-br ;
                                      skos:definition "A signal transmission function borne by petroleum production equipment whose realization constitutes the measurement of fluid electrical conductivity and the transmission of the corresponding signal to a remote monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ConductivityTransmissionProcess
copi:ConductivityTransmissionProcess rdf:type owl:Class ;
                                     rdfs:subClassOf copi:COPI_0000035 ;
                                     rdfs:label "conductivity transmission process"@en ,
                                                "processo de transmissão de condutividade"@pt-br ;
                                     skos:definition "A signal transmission process in which the electrical conductivity of a fluid is measured and the corresponding signal transmitted to a remote monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ConnectionFunction
copi:ConnectionFunction rdf:type owl:Class ;
                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                          owl:someValuesFrom copi:ConnectionProcess
                                        ] ,
                                        [ rdf:type owl:Restriction ;
                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                          owl:allValuesFrom copi:ConnectionProcess
                                        ] ;
                        rdfs:label "connection function"@en ,
                                   "função de conexão"@pt-br ;
                        skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the mechanical or fluid joining of two or more components to allow the transfer of force, fluid, or signal between them."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ConnectionProcess
copi:ConnectionProcess rdf:type owl:Class ;
                       rdfs:label "connection process"@en ,
                                  "processo de conexão"@pt-br ;
                       skos:definition "A planned process in which two or more components or systems are mechanically or fluidly joined to allow the transfer of force, fluid, or signal between them."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ContainmentProcess
copi:ContainmentProcess rdf:type owl:Class ;
                        rdfs:label "containment process"@en ,
                                   "processo de contenção"@pt-br ;
                        skos:definition "A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment."@en ,
                                        "A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads."@en ,
                                        "A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact."@en ;
                        annotation:naturalLanguageDefinition "A PlannedProcess in which a container artifact encloses and maintains internal components or fluids within its structural boundaries, providing physical separation from the external environment."@en ,
                                                             "A PlannedProcess in which a structural boundary maintains separation between internal contents and external environment, preventing uncontrolled release while withstanding internal pressure loads."@en ,
                                                             "A PlannedProcess in which material is enclosed and retained within a defined spatial boundary by a containing artifact."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ContaminatedSurface
copi:ContaminatedSurface rdf:type owl:Class ;
                         rdfs:label "contaminated surface"@en ,
                                    "superfície contaminado"@pt-br ;
                         skos:definition "A material artifact that constitutes a surface bearing scale, deposits, or contaminants that are to be removed by a cleaning process in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ContinuousBase
copi:ContinuousBase rdf:type owl:Class ;
                    rdfs:label "base contínuo"@pt-br ,
                               "continuous base"@en ;
                    skos:definition "A material artifact that constitutes the base structure that provides continuous support for equipment or pipework in a petroleum production installation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/ControlFunction
copi:ControlFunction rdf:type owl:Class ;
                     rdfs:subClassOf [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:someValuesFrom copi:ControlProcess
                                     ] ,
                                     [ rdf:type owl:Restriction ;
                                       owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                       owl:allValuesFrom copi:ControlProcess
                                     ] ;
                     rdfs:label "control function"@en ,
                                "função de controle"@pt-br ;
