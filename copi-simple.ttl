                  rdfs:label "bomba"@pt-br ,
                             "pump"@en ;
                  skos:definition "A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Pump(x) ↔ (Assembly(x) ∧ ∃f (PumpingFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A pump is an assembly that bears the designed function of adding mechanical energy to fluid for pressurization and transport."@en ,
                                                       "Uma bomba é um conjunto que possui a função projetada de adicionar energia mecânica ao fluido para pressurização e transporte."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pump is an assembly that has the function of pumping fluid"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000073
copi:COPI_0000073 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000067
                                  ] ;
                  rdfs:label "compressor"@en ,
                             "compressor"@pt-br ;
                  skos:definition "A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Compressor(x) ↔ Assembly(x) ∧ ∃f(CompressionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A compressor is an assembly that bears the designed function of compressing gases by adding mechanical energy to increase their pressure."@en ,
                                                       "Um compressor é um conjunto que possui a função projetada de comprimir gases através da adição de energia mecânica para aumentar sua pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every compressor is an assembly that bears a compression function and has component parts including a compressor casing, compression element, gas inlet, and gas outlet."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000074
copi:COPI_0000074 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:Shell
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:TubeBundle
                                  ] ;
                  rdfs:label "shell and tube heat exchanger"@en ,
                             "trocador de calor de casco e tubos"@pt-br ;
                  skos:definition "A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell."@en ;
                  annotation:firstOrderLogicAxiom "ShellAndTubeHeatExchanger(x) → HeatExchanger(x) ∧ ∃tb(TubeBundle(tb) ∧ hasComponentPartAtAllTimes(x,tb)) ∧ ∃s(Shell(s) ∧ hasComponentPartAtAllTimes(x,s) ∧ spatiallyContains(s,tb))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A shell and tube heat exchanger is a heat exchanger that has a tube bundle spatially contained within a surrounding shell."@en ,
                                                       "Um trocador de calor de casco e tubos é um trocador de calor que possui um feixe de tubos contido espacialmente dentro de um casco envolvente."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type to avoid false positives under OWA. Any equipment with a shell and tube bundle could theoretically be classified as a standard shell-and-tube heat exchanger, but specialized variants (like graphite shell-and-tube or custom multi-stream designs) should not be automatically forced into this maintenance category without domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every shell and tube heat exchanger is a heat exchanger that has a tube bundle as component part and has a shell as component part, where the tube bundle is spatially contained within the shell."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000077
copi:COPI_0000077 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000026
                                  ] ;
                  rdfs:label "valve"@en ,
                             "válvula"@pt-br ;
                  skos:definition "A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Valve(x) ↔ MaterialArtifact(x) ∧ ∃f(FlowControlFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A valve is an assembly that bears a flow control function to permit, obstruct, regulate, or divert fluid streams."@en ,
                                                       "Uma válvula é um conjunto que possui uma função de controle de fluxo para permitir, obstruir, regular ou desviar correntes de fluido."@pt-br ;
                  annotation:primitiveRationale "Might be too restrictive to define as sufficient being a material artifact and having a flow control function."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every valve is a material artifact that has the function to control fluid flow by permitting, obstructing, regulating, or diverting fluid streams."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000078
copi:COPI_0000078 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000022 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000025
                                  ] ;
                  rdfs:label "corpo de válvula"@pt-br ,
                             "valve body"@en ;
                  skos:definition "A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components."@en ;
                  annotation:firstOrderLogicAxiom "∀x(ValveBody(x) → ValveComponent(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃y(WorkingComponent(y) ∧ houses(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A ValveComponent that bears a ContainmentFunction and that serves as the main fluid and pressure containing component of a valve, housing and supporting the working components."@en ,
                                                       "Um ValveComponent que porta uma ContainmentFunction e que serve como o principal componente de contenção de fluido e pressão de uma válvula, alojando e suportando os componentes de trabalho."@pt-br ;
                  annotation:primitiveRationale "Constructive type - the structural characteristics of being the main pressure-containing housing component are necessary conditions but may not be sufficient under OWA, as various specialized valve body configurations exist that might contain additional components or have hybrid designs that could lead to false positive classifications."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every valve body is a valve component that contains and supports valve working components and bears the function of fluid and pressure containment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000080
copi:COPI_0000080 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000287 ;
                  rdfs:label "assento"@pt-br ,
                             "seat"@en ;
                  skos:definition "A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Seat(x) → MaterialArtifact(x) ∧ ∃y(SealingSurface(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(ValveClosingProcess(z) ∧ participatesIn(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that has a sealing surface component and participates in valve closing processes, consisting in that part of a valve against which the closure element bears to provide tight shutoff."@en ,
                                                       "Um MaterialArtifact que possui um componente de superfície de vedação e participa em processos de fechamento de válvulas, consistindo na parte da válvula contra a qual o elemento de fechamento se apoia para proporcionar vedação hermética."@pt-br ;
                  annotation:primitiveRationale "Constructive type based on physical configuration. Under OWA, sufficient conditions for 'seat' based solely on structural properties could lead to false positives where other valve components with sealing surfaces are incorrectly classified as seats."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every Seat is a MaterialArtifact that has some sealing surface component at all times and participates in some valve closing process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000081
copi:COPI_0000081 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000194
                                  ] ;
                  rdfs:label "filter"@en ,
                             "filtro"@pt-br ;
                  skos:definition "A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Filter(x) ↔ (Separator(x) ∧ ∃f(FiltrationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilterElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃h(FilterHousing(h) ∧ hasComponentPartAtAllTimes(x,h))))"@en ;
                  annotation:naturalLanguageDefinition "A filter is a separator that bears a filtration function to selectively remove unwanted constituents from a fluid stream using a filter element within a filter housing."@en ,
                                                       "Um filtro é um separador que possui uma função de filtração para remover seletivamente constituintes indesejados de um fluxo de fluido usando um elemento filtrante dentro de um alojamento de filtro."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every filter is a separator that has a filtration function and has a filter element as component part and has a filter housing as component part"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000082
copi:COPI_0000082 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000116 ;
                  rdfs:label "MeasuringElement que possui uma FlowMeasurementFunction e"@pt-br ,
                             "flow measuring element"@en ;
                  skos:definition "A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlowMeasuringElement(x) ↔ (MeasuringElement(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A MeasuringElement that bears a FlowMeasurementFunction and that is designed to determine and quantify the rate of fluid flow through a system."@en ,
                                                       "Um MeasuringElement que possui uma FlowMeasurementFunction e que é projetado para determinar e quantificar a taxa de fluxo de fluido através de um sistema."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every FlowMeasuringElement is a MeasuringElement that bears a FlowMeasurementFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000083
copi:COPI_0000083 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:FlowModificationFunction
                                  ] ;
                  rdfs:label "MaterialArtifact que possui uma FlowModificationFunction e"@pt-br ,
                             "flow modification accessory"@en ;
                  skos:definition "A MaterialArtifact that bears a FlowModificationFunction and that is used as a component in flow control assemblies to alter the characteristics of fluid flow such as velocity profile, turbulence, or pressure distribution."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlowModificationAccessory(x) ↔ (MaterialArtifact(x) ∧ ∃f(FlowModificationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A MaterialArtifact that bears a FlowModificationFunction and that is used as a component in flow control assemblies to alter the characteristics of fluid flow such as velocity profile, turbulence, or pressure distribution."@en ,
                                                       "Um MaterialArtifact que possui uma FlowModificationFunction e que é usado como componente em conjuntos de controle de fluxo para alterar as características do fluxo de fluido, como perfil de velocidade, turbulência ou distribuição de pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flow modification accessory is a MaterialArtifact that bears a FlowModificationFunction and participates in processes that alter fluid flow characteristics."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000084
copi:COPI_0000084 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000152 ,
                                  copi:COPI_0000158 ;
                  rdfs:label "separador"@pt-br ,
                             "separator"@en ;
                  skos:definition "A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Separator(x) ↔ (Vessel(x) ∧ ∃f (SeparationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A separator is a vessel that bears a SeparationFunction - designed to separate different substances or phases from a mixed fluid stream into distinct output streams."@en ,
                                                       "Um separador é um vaso que possui uma FunçãoDeSeparação - projetado para separar diferentes substâncias ou fases de uma corrente fluida mista em correntes de saída distintas."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every separator is a vessel that has the function of separating mixed fluid streams into distinct phases or components."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000085
copi:COPI_0000085 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:VisualInspectionFunction
                                  ] ;
                  rdfs:label "sight glass"@en ,
                             "visor"@pt-br ;
                  skos:definition "An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems."@en ;
                  annotation:firstOrderLogicAxiom "∀x(SightGlass(x) ↔ Instrument(x) ∧ ∃f(VisualInspectionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "An Instrument that bears a VisualInspectionFunction and that consists in a transparent viewing interface that enables direct optical observation of internal conditions, fluid properties, or process states within containers, vessels, or piping systems."@en ,
                                                       "Um Instrumento que porta uma VisualInspectionFunction e que consiste em uma interface de visualização transparente que permite observação óptica direta de condições internas, propriedades de fluidos ou estados de processo dentro de recipientes, vasos ou sistemas de tubulação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every sight glass is an instrument that bears a visual inspection function and enables direct optical observation of process internals through a transparent viewing interface."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000086
copi:COPI_0000086 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000199
                                  ] ;
                  rdfs:label "transformador"@pt-br ,
                             "transformer"@en ;
                  skos:definition "A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Transformer(x) ↔ ElectricalEquipment(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(PrimaryWinding(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃s(SecondaryWinding(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(MagneticCore(c) ∧ hasComponentPartAtAllTimes(x,c)))"@en ;
                  annotation:naturalLanguageDefinition "A transformer is an electrical equipment that transforms electrical power from one circuit to another at the same frequency through electromagnetic induction using windings and a magnetic core."@en ,
                                                       "Um transformador é um equipamento elétrico que transforma energia elétrica de um circuito para outro na mesma frequência através de indução eletromagnética usando enrolamentos e um núcleo magnético."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every transformer is an electrical equipment that bears an electrical power transformation function and has component parts including primary winding, secondary winding, and magnetic core."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000087
copi:COPI_0000087 rdf:type owl:Class ;
                  rdfs:label "control valve"@en ,
                             "válvula de controle"@pt-br ;
                  skos:exactMatch copi:COPI_0000087 .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000088
copi:COPI_0000088 rdf:type owl:Class ;
                  rdfs:label "isolation valve"@en ,
                             "válvula de isolamento"@pt-br ;
                  skos:definition "A material artifact that bears a binary flow control function whose realization constitutes the complete opening or closing of a flow path to isolate a process segment in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000089
copi:COPI_0000089 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000004 ;
                  terms:source "Green & Southard (eds.), Perry's Chemical Engineers' Handbook, 9th ed. §11 (heat transfer)." ,
                               "ODR-016 §A (HeatExchange leaf, Nível 2 Incremento 1a)" ;
                  rdfs:comment "A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams."@en ,
                               "Uma operação de transferência de calor na qual energia térmica é trocada entre dois ou mais fluidos, tipicamente separados por uma superfície sólida de troca de calor, sem mistura dessas correntes."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "heat exchange"@en ,
                             "troca de calor"@pt-br ;
                  rdfs:seeAlso <http://www.theworldavatar.com/ontology/ontocape/chemical_process_system/CPS_function/process.owl#TemperatureChange> ;
                  annotation:adaptedFrom "McCabe, Smith & Harriott, Unit Operations of Chemical Engineering, 8th ed. §11–12 (heat transfer without/with phase change)." ;
                  annotation:firstOrderLogicDefinition "∀x (HeatExchange(x) ↔ HeatTransfer(x) ∧ ∃f1,f2,f3,f4(hasInput(x,f1) ∧ Fluid(f1) ∧ hasInput(x,f2) ∧ Fluid(f2) ∧ f1≠f2 ∧ hasOutput(x,f3) ∧ Fluid(f3) ∧ hasOutput(x,f4) ∧ Fluid(f4) ∧ f3≠f4 ∧ derivesFrom(f3,f1) ∧ derivesFrom(f4,f2) ∧ ¬∃c3(hasConstituent(f3,c3) ∧ ¬∃c1(hasConstituent(f1,c1) ∧ sameSubstance(c1,c3))) ∧ ¬∃c4(hasConstituent(f4,c4) ∧ ¬∃c2(hasConstituent(f2,c2) ∧ sameSubstance(c2,c4)))))" ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A heat-transfer operation in which thermal energy is exchanged between two or more fluid streams, typically separated by a solid heat-transfer surface, without mixing those streams."@en ,
                                                       "Uma operação de transferência de calor na qual energia térmica é trocada entre dois ou mais fluidos, tipicamente separados por uma superfície sólida de troca de calor, sem mistura dessas correntes."@pt-br ;
                  annotation:primitiveRationale "Although a full first-order definition is available, OWL 2 DL carries only the genus (HeatTransfer); the pair-wise input–output correspondence (derivesFrom linking each output to its source input) and the cross-stream composition conservation (no constituent transferred between streams) are FOL-only constructs that exceed OWL 2 DL expressivity."@en ,
                                                "Embora exista uma definição de primeira ordem completa, o OWL 2 DL carrega apenas o gênero (HeatTransfer); a correspondência par-a-par entrada–saída (derivesFrom ligando cada saída à sua entrada de origem) e a conservação de composição entre correntes (nenhum constituinte transferido entre as correntes) são construtos apenas-FOL que excedem a expressividade do OWL 2 DL."@pt-br ;
                  annotation:semiFormalNaturalLanguageDefinition "x is a 'heat exchange' if and only if x is a 'heat transfer' in which two distinct fluid inputs each give rise to a corresponding fluid output of identical composition, with no constituent transferred between streams"@en ,
                                                                 "x é uma 'troca de calor' se e somente se x é uma 'transferência de calor' na qual dois fluidos de entrada distintos dão origem cada um a um fluido de saída correspondente de composição idêntica, sem transferência de constituinte entre as correntes"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000090
copi:COPI_0000090 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:PressureContainmentFunction
                                  ] ;
                  terms:source "ODR-018" ;
                  rdfs:comment "A closed assembly designed to hold fluids at a pressure substantially different from ambient, with a shell rated to withstand the resulting mechanical stress."@en ,
                               "Um conjunto fechado projetado para conter fluidos a uma pressão substancialmente diferente da ambiente, com casco classificado para suportar a tensão mecânica resultante."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "pressure vessel"@en ,
                             "vaso de pressão"@pt-br ;
                  skos:definition "A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads."@en ;
                  annotation:firstOrderLogicAxiom "∀x (PressureVessel(x) → Assembly(x))" ,
                                                  "∀x (PressureVessel(x) ↔ (Vessel(x) ∧ ∃f (PressureContainmentFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A closed assembly designed to hold fluids at a pressure substantially different from ambient, with a shell rated to withstand the resulting mechanical stress."@en ,
                                                       "A pressure vessel is a vessel that bears a pressure containment function, designed to safely withstand internal and/or external pressure loads."@en ,
                                                       "Um conjunto fechado projetado para conter fluidos a uma pressão substancialmente diferente da ambiente, com casco classificado para suportar a tensão mecânica resultante."@pt-br ,
                                                       "Um vaso de pressão é um vaso que possui uma função de contenção sob pressão, projetado para suportar com segurança cargas de pressão internas e/ou externas."@pt-br ;
                  annotation:primitiveRationale "A diferença estrutural de contenção de pressão (casco classificado, especificação de tensão mecânica) é expressa informalmente na NLD; OWL carrega apenas o gênero (Assembly). Axiomas estruturais são adiados ao Incremento 2b."@pt-br ,
                                                "The pressure-containing structural differentia (rated shell, mechanical stress specification) is expressed informally in the NLD; OWL carries only the genus (Assembly). Structural axioms are deferred to Incremento 2b."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pressure vessel is a vessel that has a pressure containment function, and every vessel with a pressure containment function is a pressure vessel."@en ,
                                                            "if x is a 'pressure vessel' then x is an 'assembly'"@en ,
                                                            "se x é um 'vaso de pressão', então x é um 'conjunto'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000091
copi:COPI_0000091 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000024 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000029
                                  ] ;
                  terms:source "ODR-018" ;
                  rdfs:comment "A material artifact designed to sense, measure, or indicate a physical quantity of a process stream or plant item."@en ,
                               "Um artefato material projetado para detectar, medir ou indicar uma grandeza física de uma corrente de processo ou item de planta."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "instrument"@en ,
                             "instrumento"@pt-br ;
                  skos:definition "An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Instrument(x) → MaterialArtifact(x))" ,
                                                  "∀x(Instrument(x) ↔ (Assembly(x) ∧ ∃f(InstrumentationFunction(f) ∧ hasFunction(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A material artifact designed to sense, measure, or indicate a physical quantity of a process stream or plant item."@en ,
                                                       "An instrument is a material artifact that has the designed function to perform measurement, monitoring, or control of process variables."@en ,
                                                       "Um artefato material projetado para detectar, medir ou indicar uma grandeza física de uma corrente de processo ou item de planta."@pt-br ,
                                                       "Um instrumento é um artefato material que tem a função projetada de realizar medição, monitoramento ou controle de variáveis de processo."@pt-br ;
                  annotation:primitiveRationale "A diferença estrutural de detecção-ou-medição é expressa informalmente na NLD; OWL carrega apenas o gênero (MaterialArtifact). O eixo estrutural (Instrument) é ortogonal ao eixo funcional (MeasurementInstrument); um artefato é ambos simultaneamente — intencional (ODR-018)."@pt-br ,
                                                "The sensing-or-measuring structural differentia is expressed informally in the NLD; OWL carries only the genus (MaterialArtifact). The structural axis (Instrument) is orthogonal to the functional axis (MeasurementInstrument); an artifact is both simultaneously — intended (ODR-018)."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every instrument is a material artifact that has an instrumentation function, and every material artifact that has an instrumentation function is an instrument."@en ,
                                                            "if x is an 'instrument' then x is a 'material artifact'"@en ,
                                                            "se x é um 'instrumento', então x é um 'artefato material'"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000092
copi:COPI_0000092 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000017 ,
                                  copi:COPI_0000090 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000068
                                  ] ;
                  terms:source "ODR-018, ODR-019" ;
                  rdfs:comment "A pressure vessel in which two fluid circuits are separated by a solid heat-transfer surface, so that thermal energy passes between them without the circuits mixing."@en ,
                               "Um vaso de pressão no qual dois circuitos de fluido são separados por uma superfície sólida de transferência de calor, de modo que energia térmica passa entre eles sem mistura dos circuitos."@pt-br ;
                  rdfs:isDefinedBy copi:copi-core ;
                  rdfs:label "heat exchanger"@en ,
                             "trocador de calor"@pt-br ;
                  skos:definition "A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation."@en ;
                  annotation:firstOrderLogicAxiom "∀x (HeatExchanger(x) → PressureVessel(x) ∧ ∃s(SolidHeatTransferSurface(s) ∧ hasComponentPartAtAllTimes(x,s)))" ,
                                                  "∀x (HeatExchanger(x) ↔ (Assembly(x) ∧ ∃f(HeatTransferFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A heat exchanger is a pressure vessel that bears the designed function of transferring thermal energy between two or more fluid streams while maintaining their separation."@en ,
                                                       "A pressure vessel in which two fluid circuits are separated by a solid heat-transfer surface, so that thermal energy passes between them without the circuits mixing."@en ,
                                                       "Um trocador de calor é um vaso de pressão que possui a função projetada de transferir energia térmica entre duas ou mais correntes de fluido mantendo sua separação."@pt-br ,
                                                       "Um vaso de pressão no qual dois circuitos de fluido são separados por uma superfície sólida de transferência de calor, de modo que energia térmica passa entre eles sem mistura dos circuitos."@pt-br ;
                  annotation:primitiveRationale "SolidHeatTransferSurface is a FOL-only predicate (no OWL IRI), analogous to Fluid and sameSubstance in operation axioms; OWL carries only the genus (PressureVessel). The two-circuit-separation and no-mixing differentia are in the NLD. Full equivalentClass axiomatisation is deferred to Incremento 2c."@en ,
                                                "SolidHeatTransferSurface é um predicado somente-FOL (sem IRI OWL), análogo a Fluid e sameSubstance nos axiomas de operação; OWL carrega apenas o gênero (PressureVessel). A differentia de separação de dois circuitos e não-mistura está na NLD. Axiomatização plena equivalentClass adiada ao Incremento 2c."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every heat exchanger is an assembly that has the function of heat transfer and has component parts including heat transfer surfaces and fluid passages for separated streams."@en ,
                                                            "if x is a 'heat exchanger' then x is a 'pressure vessel' that has a 'solid heat-transfer surface' as a component part at all times"@en ,
                                                            "se x é um 'trocador de calor', então x é um 'vaso de pressão' que tem uma 'superfície sólida de transferência de calor' como parte componente em todo momento"@pt-br .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000093
copi:COPI_0000093 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "angle valve"@en ,
                             "válvula angular"@pt-br ;
                  skos:definition "An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other."@en ;
                  annotation:firstOrderLogicAxiom "∀x (AngleValve(x) → Valve(x) ∧ ∃p (hasPart(x,p) ∧ NonInlinePortArrangement(p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An angle valve is a valve that has valve ports which are not in-line but arranged at an angle to each other."@en ,
                                                       "Uma válvula angular é uma válvula que tem portas da válvula que não estão alinhadas, mas dispostas em ângulo uma em relação à outra."@pt-br ;
                  annotation:primitiveRationale "Constructive type defined by geometric configuration. Under OWA, sufficient conditions for non-inline port arrangement could lead to false positives where complex multi-port manifolds or specialized valves with angular components get incorrectly classified as standard angle valves."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every angle valve is a valve that has a non-inline port arrangement."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000094
copi:COPI_0000094 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  copi:COPI_0000087 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000027
                                  ] ;
                  rdfs:label "ball control valve"@en ,
                             "válvula de controle esférica"@pt-br ;
                  skos:definition "A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals."@en ;
                  annotation:firstOrderLogicAxiom "∀x(BallControlValve(x) → ControlValve(x) ∧ ∃b(BallClosure(b) ∧ hasComponentPartAtAllTimes(x,b)) ∧ ∃a(RotaryActuator(a) ∧ hasComponentPartAtAllTimes(x,a)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A ball control valve is a control valve that uses a spherical ball closure element with rotary actuation to modulate fluid flow in response to control signals."@en ,
                                                       "Uma válvula de controle esférica é uma válvula de controle que usa um elemento de fechamento esférico com atuação rotativa para modular o fluxo de fluido em resposta a sinais de controle."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive subtype. While the ball closure mechanism is structurally distinctive, declaring equivalence could force classification of complex multi-way valves or specialized manifolds containing ball elements as standard ball control valves, which may not align with industrial maintenance categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "BallControlValve SubClassOf ControlValve and hasComponentPartAtAllTimes some BallClosure and hasComponentPartAtAllTimes some RotaryActuator"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000095
copi:COPI_0000095 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "ball valve"@en ,
                             "válvula esfera"@pt-br ;
                  skos:definition "A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports."@en ;
                  skos:exactMatch copi:COPI_0000095 ;
                  annotation:firstOrderLogicAxiom "∀x(BallValve(x) → Valve(x) ∧ ∃y(BallClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(RotationalMotionProcess(z) ∧ participatesIn(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A ball valve is a valve that controls fluid flow using a spherical ball closure member that rotates approximately 90 degrees to align or misalign its flow passage with the valve body ports."@en ,
                                                       "Uma válvula esfera é uma válvula que controla o fluxo de fluidos usando um elemento de fechamento esférico que gira aproximadamente 90 graus para alinhar ou desalinhar sua passagem de fluxo com as portas do corpo da válvula."@pt-br ;
                  annotation:primitiveRationale "As a constructive type defined by physical mechanism, sufficient conditions are omitted to avoid false positives under Open World Assumption. Complex multi-way valves or specialized equipment containing ball mechanisms should not be automatically classified as standard ball valves without domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every ball valve is a valve that has a ball closure component and participates in rotational motion processes"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000096
copi:COPI_0000096 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "block and bleed valve"@en ,
                             "válvula de bloqueio e sangria"@pt-br ;
                  skos:definition "A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure."@en ;
                  annotation:firstOrderLogicAxiom "∀x(BlockAndBleedValve(x) → Valve(x) ∧ ∃s(SingleSeat(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃l(BleederLine(l) ∧ hasComponentPartAtAllTimes(x,l)) ∧ ∃v(BleederValve(v) ∧ hasComponentPartAtAllTimes(x,v)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A block and bleed valve is a valve that has one seat which provides a seal, and a bleeder line and valve that are tapped into the valve bonnet for controlled venting of downstream pressure."@en ,
                                                       "Uma válvula de bloqueio e sangria é uma válvula que possui um assento que fornece vedação, e uma linha de sangria e válvula que são conectadas ao castelo da válvula para ventilação controlada da pressão a jusante."@pt-br ;
                  annotation:primitiveRationale "Constructive types require necessary conditions only due to Open World Assumption. The structural differentia (single seat + bleeder system) could theoretically be present in specialized equipment that should not be classified as a standard block and bleed valve without domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every block and bleed valve is a valve that has component parts: exactly one seat, a bleeder line, and a bleeder valve integrated into the bonnet."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000097
copi:COPI_0000097 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000166
                                  ] ;
                  rdfs:label "blow down valve"@en ,
                             "válvula de blow down"@pt-br ;
                  skos:definition "A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems."@en ;
                  annotation:firstOrderLogicAxiom "∀x (BlowDownValve(x) ↔ Valve(x) ∧ ∃f (RapidDepressurizationFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A blow down valve is a valve that bears a designed function for rapid depressurization of high pressure systems."@en ,
                                                       "Uma válvula de blow down é uma válvula que possui uma função projetada para despressurização rápida de sistemas de alta pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every blow down valve is a valve that has the function of rapid depressurization."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000098
copi:COPI_0000098 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000073 ;
                  rdfs:label "blower"@en ,
                             "soprador"@pt-br ;
                  skos:definition "A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow."@en ;
                  skos:exactMatch copi:COPI_0000098 ;
                  annotation:firstOrderLogicAxiom "∀x (Blower(x) ↔ (Compressor(x) ∧ ∃f,p,v (CompressionFunction(f) ∧ bearerOf(x,f) ∧ MediumPressureRange(p) ∧ MediumVolumeFlowRange(v) ∧ hasOperatingParameter(x,p) ∧ hasOperatingParameter(x,v))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A blower is a compressor that compresses and supplies air or gas at medium pressure and medium volume flow."@en ,
                                                       "Um soprador é um compressor que comprime e fornece ar ou gás em pressão média e vazão volumétrica média."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every blower is a compressor that has the function of compressing gas and operates at medium pressure and medium volume flow ranges."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000099
copi:COPI_0000099 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  copi:COPI_0000087 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000207
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000027
                                  ] ;
                  rdfs:label "butterfly control valve"@en ,
                             "válvula borboleta de controle"@pt-br ;
                  skos:definition "A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals."@en ;
                  annotation:firstOrderLogicAxiom "∀x(ButterflyControlValve(x) → Valve(x) ∧ ∃d(RotatingDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(Actuator(a) ∧ hasComponentPartAtAllTimes(x,a)) ∧ ∃f(ProcessControlledFlowFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A butterfly control valve is a control valve that has a rotating disc closure mechanism and bears a process-controlled flow function enabling automated flow modulation in response to external control signals."@en ,
                                                       "Uma válvula borboleta de controle é uma válvula de controle que possui um mecanismo de fechamento por disco rotativo e possui uma função de fluxo controlado por processo, permitindo modulação automatizada do fluxo em resposta a sinais de controle externos."@pt-br ;
                  annotation:primitiveRationale "This is a constructive type that combines two existing differentia (butterfly mechanism + control function). Under OWA, providing sufficient conditions could lead to false positives where any valve with both a rotating disc and control capability would be classified as this specific type, even if it has additional specialized features or hybrid mechanisms."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every butterfly control valve is a valve that has-component-part-at-all-times some rotating disc and has-component-part-at-all-times some actuator and bearer-of some process-controlled flow function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000100
copi:COPI_0000100 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "butterfly valve"@en ,
                             "válvula borboleta"@pt-br ;
                  skos:definition "A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction."@en ;
                  skos:exactMatch copi:COPI_0000100 ;
                  annotation:firstOrderLogicAxiom "∀x (ButterflyValve(x) → Valve(x) ∧ ∃y(DiscTypeClosure(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(TransverseRotationAxis(z) ∧ hasComponentPartAtAllTimes(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A butterfly valve is a valve that has a disc-type closure member with a shaft parallel to the plane of the disc and an axis of rotation transverse to the flow direction."@en ,
                                                       "Uma válvula borboleta é uma válvula que possui um membro de fechamento tipo disco com haste paralela ao plano do disco e eixo de rotação transversal à direção do fluxo."@pt-br ;
                  annotation:primitiveRationale "This is a constructive classification based on physical mechanism. Under the Open World Assumption, any artifact with a disc-type closure and transverse rotation axis would be forced into the ButterflyValve class, including specialized hybrid equipment or custom manifolds containing butterfly mechanisms that should not be classified as standard butterfly valves for maintenance purposes."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every butterfly valve is a valve that has a disc-type closure member and has a transverse rotation axis."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000101
copi:COPI_0000101 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000073 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000224
                                  ] ;
                  rdfs:label "centrifugal compressor"@en ,
                             "compressor centrífugo"@pt-br ;
                  skos:definition "A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action."@en ;
                  skos:exactMatch copi:COPI_0000101 ;
                  annotation:firstOrderLogicAxiom "∀x (CentrifugalCompressor(x) → Compressor(x) ∧ ∃i(CentrifugalImpeller(i) ∧ hasComponentPartAtAllTimes(x,i)) ∧ ∃p(RadialFlowPattern(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A centrifugal compressor is a compressor that uses one or more centrifugal impellers to accelerate gas through radial flow and generate pressure increase by centrifugal action."@en ,
                                                       "Um compressor centrífugo é um compressor que usa um ou mais impelidores centrífugos para acelerar o gás através de fluxo radial e gerar aumento de pressão por ação centrífuga."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type because under OWA, any equipment with a centrifugal impeller could be incorrectly classified as a standard centrifugal compressor, including specialized hybrid equipment or multi-stage systems that contain centrifugal elements but should not be forced into this maintenance category. Domain expert validation needed to confirm structural differentia is sufficient."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every centrifugal compressor is a compressor that has component part at all times some centrifugal impeller and participates in some radial flow pattern."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000102
copi:COPI_0000102 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000072 ;
                  rdfs:label "bomba centrífuga"@pt-br ,
                             "centrifugal pump"@en ;
                  skos:definition "A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing."@en ;
                  skos:exactMatch copi:COPI_0000102 ;
                  annotation:firstOrderLogicAxiom "∀x(CentrifugalPump(x) → Pump(x) ∧ ∃y(CentrifugalImpeller(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(VoluteCasing(z) ∧ hasComponentPartAtAllTimes(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A centrifugal pump is a pump that uses centrifugal force generated by rotating impellers with vanes to increase fluid pressure through a volute casing."@en ,
                                                       "Uma bomba centrífuga é uma bomba que usa força centrífuga gerada por impulsores rotativos com pás para aumentar a pressão do fluido através de uma carcaça voluta."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on physical mechanism. Under Open World Assumption, any equipment with centrifugal impellers and volute casing could be inferred as a standard centrifugal pump, potentially misclassifying specialized hybrid equipment or complex pump systems that contain centrifugal stages but serve different operational roles."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every centrifugal pump is a pump that has a centrifugal impeller as component part at all times and has a volute casing as component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000103
copi:COPI_0000103 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000161
                                  ] ;
                  rdfs:label "check valve"@en ,
                             "válvula de retenção"@pt-br ;
                  skos:definition "A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow."@en ;
                  skos:exactMatch copi:COPI_0000103 ;
                  annotation:firstOrderLogicAxiom "∀x(CheckValve(x) ↔ Valve(x) ∧ ∃f(BackflowPreventionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A check valve is a valve that bears a backflow prevention function, automatically permitting fluid to flow in one direction only while preventing reverse flow."@en ,
                                                       "Uma válvula de retenção é uma válvula que possui uma função de prevenção de refluxo, permitindo automaticamente que o fluido flua em apenas uma direção enquanto previne o fluxo reverso."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every check valve is a valve that has the function to prevent backflow and automatically allow unidirectional fluid flow."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000104
copi:COPI_0000104 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  copi:COPI_0000087 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000207
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000027
                                  ] ;
                  rdfs:label "choke control valve"@en ,
                             "válvula de controle de choke"@pt-br ;
                  skos:definition "A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction."@en ;
                  annotation:firstOrderLogicAxiom "∀x (ChokeControlValve(x) → ControlValve(x) ∧ ∃y (ChokeGeometry(y) ∧ hasComponentPartAtAllTimes(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A choke control valve is a control valve that has a choke geometry component for pressure reduction through flow restriction."@en ,
                                                       "Uma válvula de controle de choke é uma válvula de controle que possui um componente de geometria de choke para redução de pressão através de restrição de fluxo."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is classified as 'both' functional and constructive. The constructive differentia (choke geometry) makes it safer to use necessary conditions to avoid forcing all valves with choke components into this specific control category under the Open World Assumption."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every choke control valve is a control valve that has a choke geometry component at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000105
copi:COPI_0000105 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000164
                                  ] ;
                  rdfs:label "choke valve"@en ,
                             "válvula choke"@pt-br ;
                  skos:definition "A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation."@en ;
                  skos:exactMatch copi:COPI_0000105 ;
                  annotation:firstOrderLogicAxiom "∀x (ChokeValve(x) ↔ (Valve(x) ∧ ∃f (PressureReductionFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A choke valve is a valve that bears a pressure reduction function, designed to reduce fluid pressure from inlet to outlet through controlled flow restriction and energy dissipation."@en ,
                                                       "Uma válvula choke é uma válvula que possui uma função de redução de pressão, projetada para reduzir a pressão do fluido da entrada para a saída através de restrição controlada do fluxo e dissipação de energia."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every choke valve is a valve that bears a pressure reduction function and has a flow restriction element as component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000106
copi:COPI_0000106 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000200
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:CircuitProtectionFunction
                                  ] ;
                  rdfs:label "circuit breaker"@en ,
                             "disjuntor"@pt-br ;
                  skos:definition "A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current."@en ,
                                  "A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals."@en ;
                  skos:exactMatch copi:COPI_0000106 ;
                  annotation:firstOrderLogicAxiom "∀x (CircuitBreaker(x) ↔ ElectricalSwitchingDevice(x) ∧ ∃f (ElectricalCurrentInterruptionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p (RegularInterruptionProcess(p) ∧ participatesIn(x,p)))"@en ,
                                                  "∀x(CircuitBreaker(x) ↔ ElectricalEquipment(x) ∧ ∃f(CircuitProtectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(CurrentInterruptionProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A circuit breaker is a material artifact that bears an electrical current interruption function and regularly participates in processes that safely interrupt electrical current."@en ,
                                                       "A circuit-breaker is an electrical equipment that bears a circuit protection function and participates in current interruption processes at regular intervals."@en ,
                                                       "Um disjuntor é um dispositivo de chaveamento elétrico que possui uma função de interrupção de corrente elétrica e participa regularmente em processos que interrompem com segurança a corrente elétrica."@pt-br ,
                                                       "Um disjuntor é um equipamento elétrico que possui uma função de proteção de circuito e participa em processos de interrupção de corrente em intervalos regulares."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every circuit breaker is an electrical switching device that has the function to interrupt electrical current and participates in regular current interruption processes."@en ,
                                                            "Every circuit-breaker is an electrical equipment that has the function to protect circuits and participates in the process of interrupting electrical current at regular intervals."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000107
copi:COPI_0000107 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000084 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000196
                                  ] ;
                  rdfs:label "coalescedor"@pt-br ,
                             "coalescer"@en ;
                  skos:definition "A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Coalescer(x) ↔ (Separator(x) ∧ ∃f(CoalescenceFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(GravitySeparationProcess(p) ∧ participatesIn(x,p)) ∧ ∃o(SkimmableLiquidPortion(o) ∧ hasOutput(x,o))))"@en ;
                  annotation:naturalLanguageDefinition "A coalescer is a separator that uses coalescence media to promote droplet merger in immiscible liquid mixtures, enabling gravity-based separation where the less dense liquid phase can be skimmed off."@en ,
                                                       "Um coalescedor é um separador que usa meio de coalescência para promover a fusão de gotículas em misturas líquidas imiscíveis, permitindo separação por gravidade onde a fase líquida menos densa pode ser removida por escumação."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every coalescer is a separator that bears a coalescence function and participates in gravity separation processes to produce skimmable liquid portions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000108
copi:COPI_0000108 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000329
                                  ] ;
                  rdfs:label "diaphragm valve"@en ,
                             "válvula de diafragma"@pt-br ;
                  skos:definition "A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow."@en ;
                  annotation:firstOrderLogicAxiom "∀x (DiaphragmValve(x) → Valve(x) ∧ ∃d,p (ResilientDiaphragm(d) ∧ Port(p) ∧ hasComponentPartAtAllTimes(x,d) ∧ hasComponentPartAtAllTimes(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A diaphragm valve is a valve that uses a resilient diaphragm forced against a port as its closure mechanism to control fluid flow."@en ,
                                                       "Uma válvula de diafragma é uma válvula que usa um diafragma resiliente forçado contra uma porta como seu mecanismo de fechamento para controlar o fluxo de fluido."@pt-br ;
                  annotation:primitiveRationale "Since this is a constructive type defined by physical mechanism (diaphragm closure), necessary conditions are used to avoid over-classification under the Open World Assumption. Not every equipment with a diaphragm component should automatically be classified as a diaphragm valve - the structural differentia requires domain validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every diaphragm valve is a valve that has a resilient diaphragm as component part and has a port as component part and participates in diaphragm closure processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000109
copi:COPI_0000109 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000143 ,
                                  copi:COPI_0000251 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000251
                                  ] ;
                  rdfs:label "differential pressure gauge"@en ,
                             "manômetro de pressão diferencial"@pt-br ;
                  skos:definition "A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element."@en ;
                  annotation:firstOrderLogicAxiom "∀x (DifferentialPressureGauge(x) ↔ PressureGauge(x) ∧ ∃f(DifferentialPressureMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(DifferentialPressureMeasuringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(PressurePortPair(p) ∧ hasComponentPartAtAllTimes(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A differential pressure gauge is a pressure gauge that measures and indicates the difference between two pressure inputs using a differential pressure measuring element."@en ,
                                                       "Um manômetro de pressão diferencial é um manômetro que mede e indica a diferença entre duas entradas de pressão usando um elemento de medição de pressão diferencial."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every differential pressure gauge is a pressure gauge that bears a DifferentialPressureMeasurementFunction and has component parts including a DifferentialPressureMeasuringElement and PressurePortPair."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000110
copi:COPI_0000110 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000144 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000186
                                  ] ;
                  rdfs:label "differential pressure transmitter"@en ,
                             "transmissor de pressão diferencial"@pt-br ;
                  skos:definition "A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal."@en ;
                  annotation:firstOrderLogicAxiom "∀x (DifferentialPressureTransmitter(x) ↔ PressureTransmitter(x) ∧ ∃f (DifferentialPressureTransmissionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function, enabling it to measure the pressure difference between two input pressure signals and transmit this difference as a standardized output signal."@en ,
                                                       "Um transmissor de pressão diferencial é um transmissor de pressão que possui uma função de transmissão de pressão diferencial, permitindo medir a diferença de pressão entre dois sinais de pressão de entrada e transmitir essa diferença como um sinal de saída padronizado."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every differential pressure transmitter is a pressure transmitter that bears a differential pressure transmission function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000111
copi:COPI_0000111 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "double block and bleed valve"@en ,
                             "válvula de bloqueio duplo e sangria"@pt-br ;
                  skos:definition "A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats."@en ;
                  annotation:firstOrderLogicAxiom "∀x (DoubleBlockAndBleedValve(x) → (Valve(x) ∧ ∃p,s,b (PrimarySeat(p) ∧ SecondarySeat(s) ∧ BleedPort(b) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,s) ∧ hasComponentPartAtAllTimes(x,b))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A double block and bleed valve is a valve that incorporates two seats each providing sealing capability and includes a means of venting the space between the seats."@en ,
                                                       "Uma válvula de bloqueio duplo e sangria é uma válvula que incorpora duas sedes, cada uma proporcionando capacidade de vedação, e inclui um meio de ventilação do espaço entre as sedes."@pt-br ;
                  annotation:primitiveRationale "Constructive basis - the structural differentia (dual seats plus bleed port) defines necessary conditions, but under OWA we cannot assert that ANY artifact with these structural components is definitively a double block and bleed valve, as specialized multi-way valves or custom manifolds might contain similar mechanisms without being standard maintenance categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every double block and bleed valve is a valve that has a primary seat and has a secondary seat and has a bleed port."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000112
copi:COPI_0000112 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000147 ,
                                  copi:COPI_0000148 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000170
                                  ] ;
                  rdfs:label "down hole safety valve"@en ,
                             "válvula de segurança de fundo de poço"@pt-br ;
                  skos:definition "A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments."@en ;
                  annotation:firstOrderLogicAxiom "∀x(DownHoleSafetyValve(x) ↔ SafetyValve(x) ∧ ∃f(SubsurfaceSafetyFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(SubsurfaceOperationProcess(p) ∧ participatesIn(x,p)))"@en ;
                  annotation:naturalLanguageDefinition "A down hole safety valve is a safety valve that bears a subsurface safety function for pressure relief and flow control operations in wellbore or other subsurface environments."@en ,
                                                       "Uma válvula de segurança de fundo de poço é uma válvula de segurança que possui uma função de segurança subsuperficial para operações de alívio de pressão e controle de fluxo em poços ou outros ambientes subsuperficiais."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every down hole safety valve is a safety valve that bears a SubsurfaceSafetyFunction and participates in SubsurfaceOperationProcess"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000113
copi:COPI_0000113 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000193
                                  ] ;
                  rdfs:label "electric motor"@en ,
                             "motor elétrico"@pt-br ;
                  skos:definition "An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components."@en ;
                  annotation:firstOrderLogicAxiom "ElectricMotor(x) ↔ Assembly(x) ∧ ∃f(ElectricToMechanicalConversionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(Stator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃r(Rotor(r) ∧ hasComponentPartAtAllTimes(x,r))"@en ;
                  annotation:naturalLanguageDefinition "An electric motor is an assembly that bears an electric-to-mechanical energy conversion function and has both a stator and rotor as essential components."@en ,
                                                       "Um motor elétrico é um conjunto que possui uma função de conversão de energia elétrica para mecânica e tem tanto um estator quanto um rotor como componentes essenciais."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every electric motor is an assembly that bears an electric-to-mechanical conversion function and has component parts including a stator and rotor at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000114
copi:COPI_0000114 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000165
                                  ] ;
                  rdfs:label "emergency shut down valve"@en ,
                             "válvula de parada de emergência"@pt-br ;
                  skos:definition "An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability."@en ;
                  annotation:firstOrderLogicAxiom "∀x (EmergencyShutDownValve(x) ↔ (Valve(x) ∧ ∃f(EmergencyShutDownFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "An emergency shut down valve is a valve that bears an emergency shut down function, enabling rapid flow isolation in emergency situations through actuated mechanisms with fail-safe capability."@en ,
                                                       "Uma válvula de parada de emergência é uma válvula que possui uma função de parada de emergência, permitindo o isolamento rápido de fluxo em situações de emergência através de mecanismos atuados com capacidade à prova de falhas."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every emergency shut down valve is a valve that has an emergency shut down function and has an actuator and has a fail-safe system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000115
copi:COPI_0000115 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000191
                                  ] ;
                  rdfs:label "fan"@en ,
                             "ventilador"@pt-br ;
                  skos:definition "A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Fan(x) ↔ (Assembly(x) ∧ ∃f(GasMovementFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A fan is an assembly that bears a gas movement function for delivering or exhausting volumes of vapor or gas at low differential pressure."@en ,
                                                       "Um ventilador é um conjunto que possui uma função de movimentação de gás para fornecer ou exaurir volumes de vapor ou gás com baixa pressão diferencial."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every fan is an assembly that bears a gas movement function, and every assembly that bears a gas movement function is a fan."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000116
copi:COPI_0000116 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000278 ;
                  rdfs:label "elemento de vazão"@pt-br ,
                             "flow element"@en ;
                  skos:definition "A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow."@en ;
                  annotation:firstOrderLogicAxiom "∀x(FlowElement(x) ↔ (Instrument(x) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A flow element is an instrument that has the function to measure flow rates in a flowstream and produce signals proportional to the measured flow."@en ,
                                                       "Um elemento de vazão é um instrumento que tem a função de medir vazões em um fluxo e produzir sinais proporcionais à vazão medida."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flow element is an instrument that bears a FlowMeasurementFunction and has component parts including a FlowSensingElement and SignalGenerationComponent."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000117
copi:COPI_0000117 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000127 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000082
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000171
                                  ] ;
                  rdfs:label "flow indicator"@en ,
                             "indicador de fluxo"@pt-br ;
                  skos:definition "A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element."@en ;
                  annotation:firstOrderLogicAxiom "∀x (FlowIndicator(x) ↔ (Instrument(x) ∧ ∃f(FlowIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FlowMeasuringElement(e) ∧ hasComponentPartAtSomeTime(x,e)) ∧ ∃d(DisplayElement(d) ∧ hasComponentPartAtAllTimes(x,d))))"@en ;
                  annotation:naturalLanguageDefinition "A flow indicator is an indicator that is designed to indicate flow rates using a flow measuring element and display element."@en ,
                                                       "Um indicador de fluxo é um indicador projetado para indicar taxas de fluxo usando um elemento de medição de fluxo e elemento de exibição."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flow indicator is an instrument that bears a flow indication function and has a flow measuring element and display element as component parts."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000118
copi:COPI_0000118 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000185
                                  ] ;
                  rdfs:label "flow transmitter"@en ,
                             "transmissor de fluxo"@pt-br ;
                  skos:definition "A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements."@en ;
                  annotation:firstOrderLogicAxiom "∀x (FlowTransmitter(x) ↔ Transmitter(x) ∧ ∃f(FlowSignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃m(FlowMeasurement(m) ∧ hasInput(x,m)))"@en ;
                  annotation:naturalLanguageDefinition "A flow transmitter is a transmitter that produces standardized output signals proportional to flow measurements from flow sensing elements."@en ,
                                                       "Um transmissor de fluxo é um transmissor que produz sinais de saída padronizados proporcionais às medições de fluxo provenientes de elementos sensores de fluxo."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every flow transmitter is a transmitter that has the function of transmitting flow signals and has as input flow measurements."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000119
copi:COPI_0000119 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  copi:COPI_0000087 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000027
                                  ] ;
                  rdfs:label "gate control valve"@en ,
                             "válvula de controle tipo gaveta"@pt-br ;
                  skos:definition "A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals."@en ;
                  annotation:firstOrderLogicAxiom "∀x(GateControlValve(x) → ControlValve(x) ∧ ∃g(GateClosureMechanism(g) ∧ hasComponentPartAtAllTimes(x,g)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A gate control valve is a control valve that uses a gate or wedge closure element moving perpendicular to the flow path to modulate fluid flow in response to control signals."@en ,
                                                       "Uma válvula de controle tipo gaveta é uma válvula de controle que usa um elemento de fechamento tipo gaveta ou cunha movendo-se perpendicular ao caminho do fluxo para modular o fluxo de fluido em resposta a sinais de controle."@pt-br ;
                  annotation:primitiveRationale "This is a constructive subtype where the structural differentia (gate closure mechanism) defines necessary conditions. Under OWA, making this sufficient could force any assembly with a gate closure into this maintenance category, including specialized multi-way valves or custom manifolds that should not be classified as standard gate control valves."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gate control valve is a control valve that has a gate closure mechanism as component part at all times"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000120
copi:COPI_0000120 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000371
                                  ] ;
                  rdfs:label "gate valve"@en ,
                             "válvula gaveta"@pt-br ;
                  skos:definition "A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow."@en ;
                  annotation:firstOrderLogicAxiom "∀x (GateValve(x) → (Valve(x) ∧ ∃g(GateClosure(g) ∧ hasComponentPartAtAllTimes(x,g)) ∧ ∃m(LinearActuationMechanism(m) ∧ hasComponentPartAtAllTimes(x,m))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A gate valve is a valve that has a gate or disc closure member with linear motion parallel to the plane of flat seats, which are transverse to the direction of flow."@en ,
                                                       "Uma válvula gaveta é uma válvula que possui um membro de fechamento tipo gaveta ou disco com movimento linear paralelo ao plano dos assentos planos, que são transversais à direção do fluxo."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on physical mechanism. Under OWA, defining sufficient conditions for structural features like 'linear sliding gate' risks false positives from complex hybrid equipment or custom manifolds that contain gate mechanisms but should not be classified as standard gate valves. Necessary conditions provide safer classification that can be validated by domain experts."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gate valve is a valve that has a gate closure component and a linear actuation mechanism."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000121
copi:COPI_0000121 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000257 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000290
                                  ] ;
                  rdfs:label "caixa de engrenagens"@pt-br ,
                             "gearbox"@en ;
                  skos:definition "A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Gearbox(x) → Assembly(x) ∧ ∃c,g1,g2,i,o (GearCasing(c) ∧ GearWheel(g1) ∧ GearWheel(g2) ∧ g1≠g2 ∧ InputShaft(i) ∧ OutputShaft(o) ∧ hasComponentPartAtAllTimes(x,c) ∧ hasComponentPartAtAllTimes(x,g1) ∧ hasComponentPartAtAllTimes(x,g2) ∧ hasComponentPartAtAllTimes(x,i) ∧ hasComponentPartAtAllTimes(x,o) ∧ ∃f (PowerTransmissionFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A gearbox is an assembly that consists of a gear casing containing an arrangement of two or more gear-wheels that transmit rotating motion from an input shaft to an output shaft."@en ,
                                                       "Uma caixa de engrenagens é um conjunto que consiste em um invólucro de engrenagens contendo um arranjo de duas ou mais rodas de engrenagem que transmitem movimento rotativo de um eixo de entrada para um eixo de saída."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type because the structural differentia (specific gear casing and gear-wheel arrangement) is complex and making it sufficient under Open World Assumption could lead to false positives - specialized equipment containing gear mechanisms might be incorrectly classified as standard gearboxes."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every gearbox is an assembly that has component parts including a gear casing, at least two gear-wheels, an input shaft, and an output shaft, and bears a power transmission function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000122
copi:COPI_0000122 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  copi:COPI_0000087 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000027
                                  ] ;
                  rdfs:label "globe control valve"@en ,
                             "válvula de controle globo"@pt-br ;
                  skos:definition "A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals."@en ;
                  annotation:firstOrderLogicAxiom "∀x (GlobeControlValve(x) → ControlValve(x) ∧ ∃y,z (GlobeValveBody(y) ∧ LinearMotionClosure(z) ∧ hasComponentPartAtAllTimes(x,y) ∧ hasComponentPartAtAllTimes(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A globe control valve is a control valve that has a globe-shaped body and uses linear motion closure mechanism to modulate fluid flow in response to process control signals."@en ,
                                                       "Uma válvula de controle globo é uma válvula de controle que possui um corpo em formato de globo e usa um mecanismo de fechamento de movimento linear para modular o fluxo de fluido em resposta a sinais de controle de processo."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive subtype (both classification basis). The structural differentia (globe body + linear closure) provides strong necessary conditions, but declaring sufficiency under OWA could lead to unwanted automatic classification of specialized equipment that contains globe mechanisms but should not be categorized as standard globe control valves."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every globe control valve is a control valve that has a globe valve body and has a linear motion closure as component parts at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000123
copi:COPI_0000123 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "globe valve"@en ,
                             "válvula globo"@pt-br ;
                  skos:definition "A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path."@en ;
                  annotation:firstOrderLogicAxiom "∀x(GlobeValve(x) → Valve(x) ∧ ∃y,z(hasComponentPartAtAllTimes(x,y) ∧ LinearMotionClosure(y) ∧ hasComponentPartAtAllTimes(x,z) ∧ NormalSeat(z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A globe valve is a valve characterized by a closure member (disc or plug) that operates with linear motion perpendicular to a seat that is oriented normal to the fluid flow path."@en ,
                                                       "Uma válvula globo é uma válvula caracterizada por um elemento de fechamento (disco ou tampão) que opera com movimento linear perpendicular a uma sede orientada normal ao caminho do fluxo do fluido."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. Under OWA, making the structural differentia sufficient could force classification of specialized equipment containing linear motion closures (like complex multi-way valves or custom manifolds) as standard globe valves when they may warrant distinct maintenance categories."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every globe valve is a valve that has as component part at all times a linear motion closure and a normal seat."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000124
copi:COPI_0000124 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000190
                                  ] ;
                  rdfs:label "aquecedor"@pt-br ,
                             "heater"@en ;
                  skos:definition "A heater is an assembly that bears a heating function to add thermal energy to a medium."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Heater(x) ↔ Assembly(x) ∧ ∃f(HeatingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A heater is an assembly that bears a heating function to add thermal energy to a medium."@en ,
                                                       "Um aquecedor é um conjunto que possui uma função de aquecimento para adicionar energia térmica a um meio."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every heater is an assembly that bears a heating function and has heating elements and housing as component parts at all times"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000125
copi:COPI_0000125 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000180
                                  ] ;
                  rdfs:label "analisador de umidade"@pt-br ,
                             "humidity analyser"@en ;
                  skos:definition "A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments."@en ;
                  annotation:firstOrderLogicAxiom "∀x (HumidityAnalyser(x) ↔ ProcessAnalyzer(x) ∧ ∃f (HumidityMeasurementFunction(f) ∧ hasFunction(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A humidity analyser is an instrument designed to measure and indicate humidity or moisture content in process streams or environments."@en ,
                                                       "Um analisador de umidade é um analisador de processo que é projetado para medir e indicar o conteúdo de umidade ou vapor d'água em correntes de processo ou ambientes."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every humidity analyser is a process analyzer that has the function to measure humidity content."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000127
copi:COPI_0000127 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000028
                                  ] ;
                  rdfs:label "indicador"@pt-br ,
                             "indicator"@en ;
                  skos:definition "An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Indicator(x) ↔ (Instrument(x) ∧ ∃f(IndicationFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "An indicator is an instrument that displays or shows the value or status of a measured variable or condition to make it perceptible to operators."@en ,
                                                       "Um indicador é um instrumento que exibe ou mostra o valor ou status de uma variável medida ou condição para torná-la perceptível aos operadores."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every indicator is an instrument that bears an indication function to display process information in human-perceptible form."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000128
copi:COPI_0000128 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000176
                                  ] ;
                  rdfs:label "elemento de nível"@pt-br ,
                             "level element"@en ;
                  skos:definition "A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container."@en ;
                  annotation:firstOrderLogicAxiom "∀x (LevelElement(x) ↔ Detector(x) ∧ ∃f(LevelDetectionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A level element is an instrument that bears a level detection function for determining fluid level in a vessel or container."@en ,
                                                       "Um elemento de nível é um instrumento que possui uma função de detecção de nível para determinar o nível de fluido em um vaso ou recipiente."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every level element is a detector that has the function to detect fluid level"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000129
copi:COPI_0000129 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000127 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000172
                                  ] ;
                  rdfs:label "indicador de nível"@pt-br ,
                             "level indicator"@en ;
                  skos:definition "A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank."@en ;
                  annotation:firstOrderLogicAxiom "∀x (LevelIndicator(x) ↔ (Indicator(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A level indicator is an indicator that measures and locally displays the level of liquid or bulk solid material in a vessel or tank."@en ,
                                                       "Um indicador de nível é um indicador que mede e exibe localmente o nível de material líquido ou sólido a granel em um vaso ou tanque."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every level indicator is an indicator that has the function to measure and locally indicate level."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000130
copi:COPI_0000130 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000085 ,
                                  copi:COPI_0000129 ;
                  rdfs:label "level sight glass"@en ,
                             "visor de nível"@pt-br ;
                  skos:definition "A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection."@en ;
                  annotation:firstOrderLogicAxiom "∀x (LevelSightGlass(x) ↔ SightGlass(x) ∧ ∃f (LevelIndicationFunction(f) ∧ hasFunction(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A level sight glass is a sight glass that bears a designed function to indicate liquid level through visual inspection."@en ,
                                                       "Um visor de nível é um visor que possui uma função projetada para indicar o nível de líquido através de inspeção visual."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every level sight glass is a sight glass that has the function of level indication."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000131
copi:COPI_0000131 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000187
                                  ] ;
                  rdfs:label "level transmitter"@en ,
                             "transmissor de nível"@pt-br ;
                  skos:definition "A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level."@en ;
                  annotation:firstOrderLogicAxiom "∀x(LevelTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(LevelMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A level transmitter is a transmitter that measures the level (height) of liquid or bulk solid material in a container and produces a standardized electrical output signal proportional to the measured level."@en ,
                                                       "Um transmissor de nível é um transmissor que mede o nível (altura) de material líquido ou sólido a granel em um recipiente e produz um sinal elétrico de saída padronizado proporcional ao nível medido."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every level transmitter is a transmitter that bears a LevelMeasurementAndTransmissionFunction"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000132
copi:COPI_0000132 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000183
                                  ] ;
                  rdfs:label "limit switch"@en ,
                             "limit switch"@pt-br ;
                  skos:definition "A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached."@en ;
                  annotation:firstOrderLogicAxiom "∀x (LimitSwitch(x) ↔ Instrument(x) ∧ ∃f(PositionLimitDetectionFunction(f) ∧ bearerOf(x,f)) ∧ ∃p(MechanicalMotion(p) ∧ hasInput(x,p)) ∧ ∃s(ElectricalSignal(s) ∧ hasOutput(x,s)))"@en ;
                  annotation:naturalLanguageDefinition "A limit switch is an instrument that bears a position limit detection function, mechanically actuated by object motion to provide electrical switching signals when predetermined position limits are reached."@en ,
                                                       "Um limit switch é um instrumento que possui uma função de detecção de limite de posição, acionado mecanicamente pelo movimento de objetos para fornecer sinais de chaveamento elétrico quando limites de posição predeterminados são atingidos."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every limit switch is an instrument that has the function to detect position limits and is mechanically operated by object motion to generate electrical switching signals."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000133
copi:COPI_0000133 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "manual valve"@en ,
                             "válvula manual"@pt-br ;
                  skos:definition "A manual valve is a valve that has a manual actuator requiring hand power for operation."@en ;
                  annotation:firstOrderLogicAxiom "∀x(ManualValve(x) → Valve(x) ∧ ∃y(ManualActuator(y) ∧ hasComponentPartAtAllTimes(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A manual valve is a valve that has a manual actuator requiring hand power for operation."@en ,
                                                       "Uma válvula manual é uma válvula que possui um atuador manual que requer força manual para operação."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on actuation mechanism. Under OWA, any valve with a manual actuator component might be classified as manual valve even if it has additional automated features (hybrid valves). Starting with necessary conditions allows domain experts to validate that manual actuation is both necessary and sufficient before upgrading to equivalent axiom."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every manual valve is a valve that has a manual actuator as component part."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000134
copi:COPI_0000134 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "needle valve"@en ,
                             "válvula agulha"@pt-br ;
                  skos:definition "A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control."@en ;
                  annotation:firstOrderLogicAxiom "∀x(NeedleValve(x) → Valve(x) ∧ ∃y(NeedlePlug(y) ∧ hasComponentPartAtAllTimes(x,y)) ∧ ∃z(SmallOrificeSeat(z) ∧ hasComponentPartAtAllTimes(x,z)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A needle valve is a valve that has a conical needle-shaped closure member that seats into a small orifice to provide precise flow control."@en ,
                                                       "Uma válvula agulha é uma válvula que possui um membro de fechamento cônico em forma de agulha que se assenta em um pequeno orifício para fornecer controle preciso de fluxo."@pt-br ;
                  annotation:primitiveRationale "As a constructive type defined by specific structural features (needle plug geometry), providing sufficient conditions under the Open World Assumption could lead to over-classification. Complex valve assemblies or custom equipment containing needle-like mechanisms might be incorrectly classified as standard needle valves for maintenance purposes."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every needle valve is a valve that has a needle plug component and has a small orifice seat component."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000135
copi:COPI_0000135 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000023 ,
                                  copi:COPI_0000087 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000162
                                  ] ;
                  rdfs:label "on off control valve"@en ,
                             "válvula de controle liga-desliga"@pt-br ;
                  skos:definition "An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed."@en ;
                  annotation:firstOrderLogicAxiom "∀x(OnOffControlValve(x) ↔ ControlValve(x) ∧ ∃f(BinaryFlowControlFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "An on-off control valve is a control valve that bears a binary flow control function, having only two defined positions: fully open and fully closed."@en ,
                                                       "Uma válvula de controle liga-desliga é uma válvula de controle que possui uma função de controle de fluxo binária, tendo apenas duas posições definidas: totalmente aberta e totalmente fechada."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every on-off control valve is a control valve that has a BinaryFlowControlFunction and has component part a BinaryPositioner."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000136
copi:COPI_0000136 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000082 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000360
                                  ] ;
                  rdfs:label "orifice plate"@en ,
                             "placa de orifício"@pt-br ;
                  skos:definition "An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement."@en ;
                  annotation:firstOrderLogicAxiom "∀x(OrificePlate(x) → FlowMeasuringElement(x) ∧ ∃p,h(ThinPlate(p) ∧ SpecifiedHole(h) ∧ hasComponentPartAtAllTimes(x,p) ∧ hasComponentPartAtAllTimes(x,h)) ∧ ∃f(FlowMeasurementFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "An orifice plate is a flow measuring element that consists of a thin plate with a specified hole through which fluid flows to create differential pressure for flow rate measurement."@en ,
                                                       "Uma placa de orifício é um elemento de medição de fluxo que consiste de uma placa fina com um orifício especificado através do qual o fluido flui para criar pressão diferencial para medição da taxa de fluxo."@pt-br ;
                  annotation:primitiveRationale "Constructive classification based on physical structure. Under OWA, any plate with a hole could potentially be classified as an orifice plate, but many perforated plates serve different purposes (structural, filtering, etc.). The structural differentia alone is not sufficient without industrial context validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every orifice plate is a flow measuring element that has a thin plate component and has a specified hole component and bears a flow measurement function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000137
copi:COPI_0000137 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000181
                                  ] ;
                  rdfs:label "medidor de sequência de fases"@pt-br ,
                             "phase sequence meter"@en ;
                  skos:definition "A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PhaseSequenceMeter(x) ↔ ElectricMeasuringInstrument(x) ∧ ∃f(PhaseSequenceMeasurementFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(PolyphaseElectricalSignal(s) ∧ hasInput(x,s)))"@en ;
                  annotation:naturalLanguageDefinition "A phase sequence meter is an electric measuring instrument that bears a phase sequence measurement function to determine and indicate the sequence in which the instantaneous voltages of phase conductors reach their maximum value in a polyphase electrical system."@en ,
                                                       "Um medidor de sequência de fases é um instrumento de medição elétrica que possui uma função de medição de sequência de fases para determinar e indicar a sequência na qual as tensões instantâneas dos condutores de fase atingem seu valor máximo em um sistema elétrico polifásico."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every phase sequence meter is an electric measuring instrument that has the function to measure phase sequence and has as input polyphase electrical signals."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000138
copi:COPI_0000138 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000103 ;
                  rdfs:label "piston check valve"@en ,
                             "válvula de retenção tipo pistão"@pt-br ;
                  skos:definition "A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PistonCheckValve(x) → CheckValve(x) ∧ ∃y(PistonClosure(y) ∧ hasComponentPartAtAllTimes(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A piston check valve is a check valve that has a piston-type closure member that moves linearly along the flow axis under gravity or spring loading to prevent backflow."@en ,
                                                       "Uma válvula de retenção tipo pistão é uma válvula de retenção que possui um elemento de fechamento tipo pistão que se move linearmente ao longo do eixo de fluxo sob ação da gravidade ou mola para prevenir refluxo."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type defined by physical mechanism. Under Open World Assumption, any artifact with a piston closure could potentially be classified as piston check valve, but specialized hybrid valves or custom manifolds containing piston mechanisms should not be automatically asserted into this standard maintenance category without domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every piston check valve is a check valve that has a piston closure as component part."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000139
copi:COPI_0000139 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000092 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000294
                                  ] ;
                  rdfs:label "plate heat exchanger"@en ,
                             "trocador de calor de placas"@pt-br ;
                  skos:definition "A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PlateHeatExchanger(x) → HeatExchanger(x) ∧ ∃p(HeatTransferPlate(p) ∧ hasComponentPartAtAllTimes(x,p)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A plate heat exchanger is a heat exchanger that has heat transfer plates as its primary heat transfer surface."@en ,
                                                       "Um trocador de calor de placas é um trocador de calor que possui placas de transferência de calor como sua superfície primária de transferência de calor."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type. While the plate-based structure is characteristic, under the Open World Assumption, asserting equivalence could lead to false positives where any equipment with heat transfer plates (e.g., specialized hybrid equipment, multi-function process units) would be automatically classified as a standard plate heat exchanger. Domain expert validation is needed to confirm the structural differentia is sufficient."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every plate heat exchanger is a heat exchanger that has component part heat transfer plates at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000140
copi:COPI_0000140 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000371
                                  ] ;
                  rdfs:label "plug valve"@en ,
                             "válvula plug"@pt-br ;
                  skos:definition "A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PlugValve(x) → Valve(x) ∧ ∃p(PlugClosure(p) ∧ hasComponentPartAtAllTimes(x,p)) ∧ ∃r(QuarterTurnRotationProcess(r) ∧ participatesIn(x,r)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A plug valve is a valve that has a cylindrical or tapered plug closure member which operates by quarter-turn rotation on its axis to control fluid flow by sealing against a seat."@en ,
                                                       "Uma válvula plug é uma válvula que possui um elemento de fechamento em forma de plugue cilíndrico ou cônico que opera por rotação de um quarto de volta em seu eixo para controlar o fluxo de fluido selando contra um assento."@pt-br ;
                  annotation:primitiveRationale "Constructive classification requires necessary conditions only. Under OWA, any artifact with a plug closure and quarter-turn mechanism would be forcibly classified as a plug valve, but specialized multi-port valves or custom manifolds containing plug mechanisms should not automatically inherit the standard plug valve classification without domain expert validation."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every plug valve is a valve that has a plug closure component and participates in quarter-turn rotation processes"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000141
copi:COPI_0000141 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000086 ;
                  rdfs:label "power transformer"@en ,
                             "transformador de potência"@pt-br ;
                  skos:definition "A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PowerTransformer(x) ↔ (Transformer(x) ∧ ∃f(ElectricalPowerTransformationFunction(f) ∧ bearerOf(x,f)) ∧ ∃r(ElectricalPowerTransmissionRole(r) ∧ bearerOf(x,r))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A power transformer is a transformer that bears an electrical power transformation function, realized by electromagnetic induction to transform alternating voltage and current systems to different levels at the same frequency for power transmission purposes."@en ,
                                                       "Um transformador de potência é um transformador que possui uma função de transformação de energia elétrica, realizada por indução eletromagnética para transformar sistemas de tensão e corrente alternadas para diferentes níveis na mesma frequência para fins de transmissão de energia."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every power transformer is a transformer that has the function of transforming electrical power through electromagnetic induction, taking alternating current at one voltage level as input and producing alternating current at different voltage level(s) as output for power transmission."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000142
copi:COPI_0000142 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000177
                                  ] ;
                  rdfs:label "elemento de pressão"@pt-br ,
                             "pressure element"@en ;
                  skos:definition "A pressure element is an instrument that bears a pressure sensing function."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PressureElement(x) ↔ DetectingElement(x) ∧ ∃f(PressureSensingFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A pressure element is an instrument that bears a pressure sensing function."@en ,
                                                       "Um elemento de pressão é um instrumento que possui uma função de detecção de pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pressure element is a detecting element that has the function of sensing pressure"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000143
copi:COPI_0000143 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000127 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000178
                                  ] ;
                  rdfs:label "manômetro"@pt-br ,
                             "pressure gauge"@en ;
                  skos:definition "A pressure gauge is an indicator that bears the function of measuring and displaying pressure values."@en ;
                  annotation:firstOrderLogicAxiom "∀x (PressureGauge(x) ↔ (Instrument(x) ∧ ∃f (PressureMeasurementFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A pressure gauge is an indicator that bears the function of measuring and displaying pressure values."@en ,
                                                       "Um manômetro é um indicador que possui a função de medir e exibir valores de pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pressure gauge is an instrument that has the function to measure and display pressure"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000144
copi:COPI_0000144 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000031
                                  ] ;
                  rdfs:label "pressure transmitter"@en ,
                             "transmissor de pressão"@pt-br ;
                  skos:definition "A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems."@en ;
                  annotation:firstOrderLogicAxiom "∀x(PressureTransmitter(x) ↔ (Transmitter(x) ∧ ∃f(PressureTransmissionFunction(f) ∧ hasFunction(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A pressure transmitter is a transmitter that converts pressure measurements into standardized output signals for transmission to control or monitoring systems."@en ,
                                                       "Um transmissor de pressão é um transmissor que converte medições de pressão em sinais de saída padronizados para transmissão a sistemas de controle ou monitoramento."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every pressure transmitter is a transmitter that has the function to transmit pressure measurement signals."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000145
copi:COPI_0000145 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000169
                                  ] ;
                  rdfs:label "relief valve"@en ,
                             "válvula de alívio"@pt-br ;
                  skos:definition "A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system."@en ;
                  annotation:firstOrderLogicAxiom "∀x (ReliefValve(x) ↔ (Valve(x) ∧ ∃f (PressureReliefFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A relief valve is a valve that is designed to automatically open at a predetermined pressure setpoint to relieve excess pressure and prevent unsafe pressure levels in a system."@en ,
                                                       "Uma válvula de alívio é uma válvula projetada para abrir automaticamente em um ponto de ajuste de pressão predeterminado para aliviar o excesso de pressão e prevenir níveis de pressão inseguros em um sistema."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every relief valve is a valve that bears a pressure relief function, which realizes a pressure relief process that automatically opens the valve when system pressure exceeds a predetermined setpoint."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000146
copi:COPI_0000146 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000083 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000163
                                  ] ;
                  rdfs:label "orifício de restrição"@pt-br ,
                             "restriction orifice"@en ;
                  skos:definition "A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction."@en ;
                  annotation:firstOrderLogicAxiom "∀x(RestrictionOrifice(x) ↔ FlowModificationAccessory(x) ∧ ∃f(FlowRestrictionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A restriction orifice is a flow modification accessory that bears the function to restrict fluid flow by creating controlled pressure drop through geometric constriction."@en ,
                                                       "Um orifício de restrição é um acessório de modificação de fluxo que possui a função de restringir o fluxo de fluido criando queda de pressão controlada através de constrição geométrica."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every restriction orifice is a flow modification accessory that bears a flow restriction function"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000147
copi:COPI_0000147 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000032
                                  ] ;
                  rdfs:label "safety relief valve"@en ,
                             "válvula de segurança e alívio"@pt-br ;
                  skos:definition "A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities."@en ;
                  annotation:firstOrderLogicAxiom "∀x(SafetyReliefValve(x) ↔ (Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A safety relief valve is a valve that bears a safety relief function combining both safety protection and pressure relief capabilities."@en ,
                                                       "Uma válvula de segurança e alívio é uma válvula que possui uma função de alívio de segurança que combina capacidades de proteção de segurança e alívio de pressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every safety relief valve is a valve that has the function of providing both safety protection and pressure relief."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000148
copi:COPI_0000148 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000168
                                  ] ;
                  rdfs:label "safety valve"@en ,
                             "válvula de segurança"@pt-br ;
                  skos:definition "A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions."@en ;
                  annotation:firstOrderLogicAxiom "∀x(SafetyValve(x) ↔ Valve(x) ∧ ∃f(SafetyReliefFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A safety valve is a valve that bears a safety venting function for automatic pressure relief through rapid full opening to protect against dangerous overpressure conditions."@en ,
                                                       "Uma válvula de segurança é uma válvula que possui uma função de ventilação de segurança para alívio automático de pressão por abertura rápida e total para proteção contra condições perigosas de sobrepressão."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every safety valve is a valve that has the function to automatically relieve excess pressure for emergency protection"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000149
copi:COPI_0000149 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ;
                  rdfs:label "self operating valve"@en ,
                             "válvula auto-operante"@pt-br ;
                  skos:definition "A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation."@en ;
                  annotation:firstOrderLogicAxiom "∀x(SelfOperatingValve(x) → Valve(x) ∧ ∃m(SelfOperatingMechanism(m) ∧ hasComponentPartAtAllTimes(x,m)) ∧ ∃c(EnergyIndependentOperationCapability(c) ∧ bearerOf(x,c)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A self-operating valve is a valve that includes an internal means of operation (such as spring, gravity, fluid pressure, or counterbalance) and does not depend on an external source of energy for its actuation."@en ,
                                                       "Uma válvula auto-operante é uma válvula que inclui um mecanismo interno de operação (como mola, gravidade, pressão do fluido ou contrapeso) e não depende de uma fonte externa de energia para seu acionamento."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type defined by physical configuration (self-operating mechanism). Under OWA, any valve with an internal operating mechanism might be classified as self-operating even if it has additional external actuators or specialized applications. Domain expert validation needed to confirm structural differentia is sufficient."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every self-operating valve is a valve that has a self-operating mechanism as component part at all times and bears the capability of energy-independent operation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000150
copi:COPI_0000150 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000077 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasComponentPartAtAllTimes> ;
                                    owl:someValuesFrom copi:COPI_0000353
                                  ] ;
                  rdfs:label "solenoid valve"@en ,
                             "válvula solenoide"@pt-br ;
                  skos:definition "A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow."@en ;
                  annotation:firstOrderLogicAxiom "∀x (SolenoidValve(x) → Valve(x) ∧ ∃s (SolenoidActuator(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃f (ElectricalControlFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A solenoid valve is a valve that has a solenoid actuator for electrical control of fluid flow."@en ,
                                                       "Uma válvula solenoide é uma válvula que possui um atuador solenoide para controle elétrico do fluxo de fluido."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive type where the solenoid mechanism is the distinguishing structural feature. Under OWA, making it equivalent could incorrectly classify complex valve assemblies that contain solenoid components but are not standard solenoid valves."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every solenoid valve is a valve that has a solenoid actuator component and bears an electrical control function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000151
copi:COPI_0000151 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000158 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000197
                                  ] ;
                  rdfs:label "storage tank"@en ,
                             "tanque de armazenamento"@pt-br ;
                  skos:altLabel "tank"@en ;
                  skos:definition "A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing."@en ;
                  annotation:firstOrderLogicAxiom "∀x(StorageTank(x) ↔ (Tank(x) ∧ ∃f(ExtendedStorageFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A storage tank is a vessel that is designed to store fluids or materials for extended periods without transformation or active processing."@en ,
                                                       "Um tanque de armazenamento é um vaso projetado para armazenar fluidos ou materiais por períodos prolongados sem transformação ou processamento ativo."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every storage tank is a tank that has the function to store materials for extended periods."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000152
copi:COPI_0000152 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000195
                                  ] ;
                  rdfs:label "filtro grosso"@pt-br ,
                             "strainer"@en ;
                  skos:definition "A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Strainer(x) ↔ (MaterialArtifact(x) ∧ ∃f(SeparationFunction(f) ∧ bearerOf(x,f)) ∧ ∃e(FilteringElement(e) ∧ hasComponentPartAtAllTimes(x,e)) ∧ ∃p(SolidLiquidSeparationProcess(p) ∧ participatesIn(x,p))))"@en ;
                  annotation:naturalLanguageDefinition "A strainer is a material artifact that bears a separation function and has a filtering element, designed to separate solid particles from fluids by passing the fluid through screens or perforations."@en ,
                                                       "Um filtro grosso é um artefato material que possui uma função de separação e tem um elemento filtrante, projetado para separar partículas sólidas de fluidos fazendo o fluido passar através de telas ou perfurações."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every strainer is a material artifact that bears a separation function and has a filtering element as component part at all times and participates in solid-liquid separation processes."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000153
copi:COPI_0000153 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000103 ;
                  rdfs:label "swing check valve"@en ,
                             "válvula de retenção basculante"@pt-br ;
                  skos:definition "A swing check valve is a check valve that has a closure member consisting of a disc which swings freely on a hinge mechanism and opens automatically when flow is established and closes automatically when flow ceases or reverses."@en ;
                  annotation:firstOrderLogicAxiom "∀x(SwingCheckValve(x) → CheckValve(x) ∧ ∃d(HingedDisc(d) ∧ hasComponentPartAtAllTimes(x,d)) ∧ ∃a(SwingArm(a) ∧ hasComponentPartAtAllTimes(x,a)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A swing check valve is a check valve that has a closure member consisting of a disc which swings freely on a hinge mechanism and opens automatically when flow is established and closes automatically when flow ceases or reverses."@en ,
                                                       "Uma válvula de retenção basculante é uma válvula de retenção que possui um elemento de fechamento consistindo de um disco que gira livremente em um mecanismo de dobradiça e abre automaticamente quando o fluxo é estabelecido e fecha automaticamente quando o fluxo cessa ou se inverte."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions for this constructive type to avoid false positives under OWA. Any artifact with a hinged disc mechanism should not automatically be classified as a swing check valve without domain expert validation, as specialized equipment may contain swing mechanisms but serve different primary functions."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every swing check valve is a check valve that has a hinged disc as component part and has a swing arm as component part"@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000154
copi:COPI_0000154 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000127 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000173
                                  ] ;
                  rdfs:label "indicador de temperatura"@pt-br ,
                             "temperature indicator"@en ;
                  skos:definition "A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location."@en ;
                  annotation:firstOrderLogicAxiom "∀x (TemperatureIndicator(x) ↔ (Instrument(x) ∧ ∃f (TemperatureIndicationFunction(f) ∧ bearerOf(x,f)) ∧ ∃s (TemperatureSensingElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃d (LocalDisplay(d) ∧ hasComponentPartAtAllTimes(x,d))))"@en ;
                  annotation:naturalLanguageDefinition "A temperature indicator is an indicator that measures temperature and displays the measured value locally at the instrument location."@en ,
                                                       "Um indicador de temperatura é um indicador que mede temperatura e exibe o valor medido localmente na localização do instrumento."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every temperature indicator is an instrument that has the function of temperature indication and has component parts including a temperature sensing element and a local display."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000155
copi:COPI_0000155 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000188
                                  ] ;
                  rdfs:label "temperature transmitter"@en ,
                             "transmissor de temperatura"@pt-br ;
                  skos:definition "A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element."@en ;
                  annotation:firstOrderLogicAxiom "∀x(TemperatureTransmitter(x) ↔ Transmitter(x) ∧ ∃f(TemperatureMeasurementAndTransmissionFunction(f) ∧ bearerOf(x,f)))"@en ;
                  annotation:naturalLanguageDefinition "A temperature transmitter is a transmitter that measures temperature and produces a standardized output signal dependent on the received input signal from a temperature element."@en ,
                                                       "Um transmissor de temperatura é um transmissor que mede temperatura e produz um sinal de saída padronizado dependente do sinal de entrada recebido de um elemento de temperatura."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every temperature transmitter is a transmitter that has the function to measure temperature and transmit standardized signals based on temperature input."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000156
copi:COPI_0000156 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000201
                                  ] ;
                  rdfs:label "poço termométrico"@pt-br ,
                             "thermowell"@en ;
                  skos:definition "A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe."@en ;
                  annotation:firstOrderLogicAxiom "∀x (Thermowell(x) → Instrument(x) ∧ ∃r,c,f (PressureTightReceptacle(r) ∧ ProcessConnection(c) ∧ TemperatureSensorProtectionFunction(f) ∧ hasComponentPartAtAllTimes(x,r) ∧ hasComponentPartAtAllTimes(x,c) ∧ bearerOf(x,f)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A thermowell is an instrument that is a pressure-tight receptacle adapted to receive a temperature sensing element, provided with external threads or other means for pressure-tight attachment to a vessel or pipe."@en ,
                                                       "Um poço termométrico é um instrumento que é um receptáculo resistente à pressão adaptado para receber um elemento sensor de temperatura, provido com roscas externas ou outros meios para fixação resistente à pressão a um vaso ou tubulação."@pt-br ;
                  annotation:primitiveRationale "Thermowell has constructive classification basis. The structural differentia (pressure-tight receptacle with process connection) defines necessary conditions, but making these sufficient under OWA could lead to false classifications of other threaded pressure-tight devices that happen to contain receptacles but are not intended as thermowells."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every thermowell is an instrument that has a pressure-tight receptacle as component part and has a process connection as component part and is designed for temperature sensing elements."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000157
copi:COPI_0000157 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000091 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000030
                                  ] ;
                  rdfs:label "transmissor"@pt-br ,
                             "transmitter"@en ;
                  skos:definition "A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Transmitter(x) ↔ Instrument(x) ∧ ∃f(SignalTransmissionFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(SensorElement(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃c(SignalConditioner(c) ∧ hasComponentPartAtAllTimes(x,c)) ∧ ∃t(TransmissionModule(t) ∧ hasComponentPartAtAllTimes(x,t)))"@en ;
                  annotation:naturalLanguageDefinition "A transmitter is an instrument that bears a signal transmission function, receiving process variable signals from sensors and converting them into standardized output signals for transmission to control systems."@en ,
                                                       "Um transmissor é um instrumento que possui uma função de transmissão de sinal, recebendo sinais de variáveis de processo de sensores e convertendo-os em sinais de saída padronizados para transmissão a sistemas de controle."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every transmitter is an instrument that has the function of signal transmission and has a sensor element and signal conditioner and transmission module and receives process variable inputs and produces standardized signal outputs."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000158
copi:COPI_0000158 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000022 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000025
                                  ] ;
                  rdfs:label "vaso"@pt-br ,
                             "vessel"@en ;
                  skos:definition "A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes."@en ;
                  annotation:firstOrderLogicAxiom "∀x(Vessel(x) ↔ Assembly(x) ∧ ∃f(ContainmentFunction(f) ∧ bearerOf(x,f)) ∧ ∃s(VesselShell(s) ∧ hasComponentPartAtAllTimes(x,s)) ∧ ∃h(VesselHead(h) ∧ hasComponentPartAtAllTimes(x,h)))"@en ;
                  annotation:naturalLanguageDefinition "A vessel is an assembly designed to contain fluids or solids for storage and/or processing purposes."@en ,
                                                       "Um vaso é um conjunto projetado para conter fluidos ou sólidos para fins de armazenamento e/ou processamento."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every vessel is an assembly that bears a containment function and has a vessel shell and vessel head as component parts at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000159
copi:COPI_0000159 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000157 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/hasFunction> ;
                                    owl:someValuesFrom copi:COPI_0000189
                                  ] ;
                  rdfs:label "transmissor de vibração"@pt-br ,
                             "vibration transmitter"@en ;
                  skos:definition "A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters."@en ;
                  annotation:firstOrderLogicAxiom "∀x (VibrationTransmitter(x) ↔ (Transmitter(x) ∧ ∃v (VibrationSignal(v) ∧ hasInput(x,v)) ∧ ∃f (VibrationMeasurementFunction(f) ∧ bearerOf(x,f))))"@en ;
                  annotation:naturalLanguageDefinition "A vibration transmitter is a transmitter that measures mechanical vibrations and produces an output signal proportional to the measured vibration parameters."@en ,
                                                       "Um transmissor de vibração é um transmissor que mede vibrações mecânicas e produz um sinal de saída proporcional aos parâmetros de vibração medidos."@pt-br ;
                  annotation:semiFormalNaturalLanguageAxiom "Every vibration transmitter is a transmitter that has a vibration signal as input and bears a vibration measurement function."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000160
copi:COPI_0000160 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000103 ;
                  rdfs:label "válvula de retenção wafer"@pt-br ,
                             "wafer check valve"@en ;
                  skos:definition "A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges."@en ;
                  annotation:firstOrderLogicAxiom "∀x(WaferCheckValve(x) → CheckValve(x) ∧ ∃y(WaferPatternValveBody(y) ∧ hasComponentPartAtAllTimes(x,y)))"@en ;
                  annotation:isPrimitive "true"^^xsd:boolean ;
                  annotation:naturalLanguageDefinition "A wafer check valve is a check valve that has a wafer pattern valve body designed for mounting between flanges."@en ,
                                                       "Uma válvula de retenção wafer é uma válvula de retenção que possui um corpo de válvula padrão wafer projetado para montagem entre flanges."@pt-br ;
                  annotation:primitiveRationale "Using necessary conditions because this is a constructive subtype (both functional and structural aspects). The wafer pattern mounting configuration is a structural differentia that, while characteristic, may have edge cases or specialized variants that should not be automatically classified without expert validation. The structural differentia should be confirmed as both necessary and sufficient in industrial practice before upgrading to equivalent mode."@en ;
                  annotation:semiFormalNaturalLanguageAxiom "Every wafer check valve is a check valve that has a wafer pattern valve body as component part at all times."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000161
copi:COPI_0000161 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000026 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:BackflowPreventionProcess
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:BackflowPreventionProcess
                                  ] ;
                  rdfs:label "backflow prevention function"@en ,
                             "função de prevenção de refluxo"@pt-br ;
                  skos:definition "A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions."@en ;
                  annotation:naturalLanguageDefinition "A FlowControlFunction that is realized in a BackflowPreventionProcess and that consists in preventing the reversal of fluid flow direction by physically blocking the flow path when pressure differential indicates potential backflow conditions."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/COPI_0000162
copi:COPI_0000162 rdf:type owl:Class ;
                  rdfs:subClassOf copi:COPI_0000027 ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:someValuesFrom copi:BinaryFlowControlProcess
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                    owl:allValuesFrom copi:BinaryFlowControlProcess
                                  ] ;
                  rdfs:label "binary flow control function"@en ,
                             "função de controle binário de fluxo"@pt-br ;
                  skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the complete opening or closing of a flow path to allow or prevent fluid passage."@en .


