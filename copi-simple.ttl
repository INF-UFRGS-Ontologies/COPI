copi:SpacingProcess rdf:type owl:Class ;
                    rdfs:label "processo de espaçamento"@pt-br ,
                               "spacing process"@en ;
                    skos:definition "A planned process in which a defined spatial separation between components is maintained to ensure correct alignment, clearance, or insulation."@en .


