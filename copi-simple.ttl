###  https://www.inf.ufrgs.br/ontologies/copi/StationaryMachineComponentFunction
copi:StationaryMachineComponentFunction rdf:type owl:Class ;
                                        rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                          owl:someValuesFrom copi:StationaryMachineComponentProcess
                                                        ] ,
                                                        [ rdf:type owl:Restriction ;
                                                          owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                          owl:allValuesFrom copi:StationaryMachineComponentProcess
                                                        ] ;
                                        rdfs:label "função de componente estacionário de máquina"@pt-br ,
                                                   "stationary machine component function"@en ;
                                        skos:definition "A DesignedFunction that is realized in a StationaryMachineComponentProcess and that consists in providing a stationary structural foundation and housing for active elements (such as windings, vanes, or seals) within rotating machinery, maintaining positional stability relative to moving components."@en ;
                                        annotation:naturalLanguageDefinition "A DesignedFunction that is realized in a StationaryMachineComponentProcess and that consists in providing a stationary structural foundation and housing for active elements (such as windings, vanes, or seals) within rotating machinery, maintaining positional stability relative to moving components."@en .


