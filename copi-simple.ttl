copi:PressureSensingProcess rdf:type owl:Class ;
                            rdfs:label "pressure sensing process"@en ,
                                       "processo de sensoriamento de pressão"@pt-br ;
                            skos:definition "A planned process in which fluid pressure is detected and converted into a measurable electrical or pneumatic signal."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PressureSensor
copi:PressureSensor rdf:type owl:Class ;
                    rdfs:label "pressure sensor"@en ,
                               "sensor de pressão"@pt-br ;
                    skos:definition "A material artifact that constitutes a sensing element assembly that measures fluid pressure and converts it into an electrical or pneumatic signal."@en .


