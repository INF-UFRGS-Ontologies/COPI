copi:MechanicalWork rdf:type owl:Class ;
                    rdfs:label "mechanical work"@en ,
                               "trabalho mecânico"@pt-br ;
                    skos:definition "A process in which the work performed by or on a mechanical component through the application of force over a displacement in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MetallicStructure
copi:MetallicStructure rdf:type owl:Class ;
                       rdfs:label "estrutura metálico"@pt-br ,
                                  "metallic structure"@en ;
                       skos:definition "A material artifact that constitutes a metallic structural element—frame, vessel shell, or structural member—that forms part of a petroleum production installation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MixedFluidPortion
copi:MixedFluidPortion rdf:type owl:Class ;
                       rdfs:label "mixed fluid portion"@en ,
                                  "porção misto de fluido"@pt-br ;
                       skos:definition "A material artifact that constitutes a portion of fluid formed by the combination of two or more streams in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MixingFunction
copi:MixingFunction rdf:type owl:Class ;
                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                      owl:someValuesFrom copi:MixingProcess
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                      owl:allValuesFrom copi:MixingProcess
                                    ] ;
                    rdfs:label "função de mistura"@pt-br ,
                               "mixing function"@en ;
                    skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the combination and blending of two or more fluid streams or components to achieve a homogeneous mixture."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MixingProcess
copi:MixingProcess rdf:type owl:Class ;
                   rdfs:label "mixing process"@en ,
                              "processo de mistura"@pt-br ;
                   skos:definition "A planned process in which two or more fluid streams or components are combined and blended to achieve a homogeneous mixture."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationFunction
copi:MovementCompensationFunction rdf:type owl:Class ;
                                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:someValuesFrom copi:MovementCompensationProcess
                                                  ] ,
                                                  [ rdf:type owl:Restriction ;
                                                    owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                    owl:allValuesFrom copi:MovementCompensationProcess
                                                  ] ;
                                  rdfs:label "função de compensação de movimentação"@pt-br ,
                                             "movement compensation function"@en ;
                                  skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the accommodation of relative movement between connected components caused by thermal expansion, vibration, or settlement."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MovementCompensationProcess
copi:MovementCompensationProcess rdf:type owl:Class ;
                                 rdfs:label "movement compensation process"@en ,
                                            "processo de compensação de movimentação"@pt-br ;
                                 skos:definition "A planned process in which relative movement between connected components caused by thermal expansion, vibration, or settlement is accommodated without transmitting excessive stress."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MovingObject
copi:MovingObject rdf:type owl:Class ;
                  rdfs:label "moving object"@en ,
                             "objeto móvel"@pt-br ;
                  skos:definition "A material artifact that constitutes a moving element within petroleum production equipment—such as a piston, rotor, or actuator—that transmits force or motion."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MovingVane
copi:MovingVane rdf:type owl:Class ;
                rdfs:label "moving vane"@en ,
                           "palheta móvel"@pt-br ;
                skos:definition "A material artifact that constitutes a moving blade or vane within a turbine, pump, or separator that interacts with a fluid stream in petroleum production equipment."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionFunction
copi:MultiServiceTransmissionFunction rdf:type owl:Class ;
                                      rdfs:subClassOf [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                        owl:someValuesFrom copi:MultiServiceTransmissionProcess
                                                      ] ,
                                                      [ rdf:type owl:Restriction ;
                                                        owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                                        owl:allValuesFrom copi:MultiServiceTransmissionProcess
                                                      ] ;
                                      rdfs:label "função de transmissão de múltiplos serviços"@pt-br ,
                                                 "multi service transmission function"@en ;
                                      skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the simultaneous measurement and transmission of multiple process variables to a remote control or monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MultiServiceTransmissionProcess
copi:MultiServiceTransmissionProcess rdf:type owl:Class ;
                                     rdfs:label "multi service transmission process"@en ,
                                                "processo de transmissão de múltiplos serviços"@pt-br ;
                                     skos:definition "A planned process in which multiple process variables are simultaneously measured and their corresponding signals transmitted to a remote control or monitoring system."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/MultiphaseFluidPortion
copi:MultiphaseFluidPortion rdf:type owl:Class ;
                            rdfs:label "multiphase fluid portion"@en ,
                                       "porção multifásico de fluido"@pt-br ;
                            skos:definition "A material artifact that constitutes a portion of fluid containing two or more distinct phases—gas, liquid hydrocarbon, or water—at a defined point in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingFunction
copi:NoiseSilencingFunction rdf:type owl:Class ;
                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:someValuesFrom copi:NoiseSilencingProcess
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty <http://purl.obolibrary.org/obo/BFO_0000054> ;
                                              owl:allValuesFrom copi:NoiseSilencingProcess
                                            ] ;
                            rdfs:label "função de silenciamento de ruído"@pt-br ,
                                       "noise silencing function"@en ;
                            skos:definition "A designed function borne by petroleum production equipment whose realization constitutes the attenuation of acoustic energy in a fluid stream or mechanical system to reduce radiated noise to acceptable levels."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/NoiseSilencingProcess
copi:NoiseSilencingProcess rdf:type owl:Class ;
                           rdfs:label "noise silencing process"@en ,
                                      "processo de silenciamento de ruído"@pt-br ;
                           skos:definition "A planned process in which acoustic energy in a fluid stream or mechanical system is attenuated to reduce radiated noise to an acceptable level."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/OilPortion
copi:OilPortion rdf:type owl:Class ;
                rdfs:label "oil portion"@en ,
                           "porção de óleo"@pt-br ;
                skos:definition "A material artifact that constitutes a portion of liquid hydrocarbon at a defined point in a petroleum production process."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/Panel
copi:Panel rdf:type owl:Class ;
           rdfs:label "painel"@pt-br ,
                      "panel"@en ;
           skos:definition "A material artifact that constitutes a flat structural panel that provides a mounting surface for instrumentation, controls, or electrical equipment in a petroleum production installation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceIndication
copi:PhaseSequenceIndication rdf:type owl:Class ;
                             rdfs:label "indicação de fase de sequência"@pt-br ,
                                        "phase sequence indication"@en ;
                             skos:definition "A measurement information content entity constituting a displayed or transmitted value representing the phase sequence of an alternating-current electrical supply in a petroleum production installation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PhaseSequenceMeasurementProcess
copi:PhaseSequenceMeasurementProcess rdf:type owl:Class ;
                                     rdfs:label "phase sequence measurement process"@en ,
                                                "processo de medição de sequência de fases"@pt-br ;
                                     skos:definition "A planned process in which the phase sequence of an alternating-current electrical supply is measured and verified by petroleum production instrumentation."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/PhysicalObject
copi:PhysicalObject rdf:type owl:Class ;
                    rdfs:label "objeto físico"@pt-br ,
                               "physical object"@en ;
                    skos:definition "A material artifact that constitutes a discrete physical entity within a petroleum production system that occupies space and has defined material properties."@en .


