copi:COPI_0000051 rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty <https://spec.industrialontologies.org/ontology/construct/describes> ;
                                    owl:someValuesFrom copi:COPI_0000056
                                  ] ;
