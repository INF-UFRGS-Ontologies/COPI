copi:PressureSignal rdf:type owl:Class ;
                    rdfs:label "pressure signal"@en ,
                               "sinal de pressão"@pt-br ;
                    skos:definition "A measurement information content entity constituting an electrical or pneumatic signal representing the pressure of a process stream in petroleum production equipment."@en .


