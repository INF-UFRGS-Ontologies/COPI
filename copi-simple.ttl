copi:UninterruptedPowerSupplyProcess rdf:type owl:Class ;
                                     rdfs:label "processo de fornecimento ininterrupto de energia"@pt-br ,
                                                "uninterrupted power supply process"@en ;
                                     skos:definition "A planned process in which continuous electrical power is provided to critical loads during interruptions to the main power supply."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/VacuumReferenceeChamber
copi:VacuumReferenceeChamber rdf:type owl:Class ;
                             rdfs:label "câmara de vácuo de referência"@pt-br ,
                                        "vacuum referencee chamber"@en ;
                             skos:definition "A material artifact that constitutes a sealed reference cavity maintained at a known low pressure for use as a reference in absolute pressure measurement instruments."@en .


###  https://www.inf.ufrgs.br/ontologies/copi/VaporPortion
