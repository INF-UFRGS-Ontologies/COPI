copi:RotationalMotion rdf:type owl:Class ;
                      rdfs:label "movimento rotacional"@pt-br ,
                                 "rotational motion"@en ;
                      skos:definition "A process in which the angular motion of a rotating component about its axis in petroleum production rotating equipment."@en .


